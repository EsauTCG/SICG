@using Microsoft.AspNetCore.Mvc.Rendering
@model Plataforma_CG.Models.UsuarioSQL

@{
    ViewData["Title"] = "Editar Usuario SQL";
    Layout = "~/Views/Shared/_Layout2.cshtml";

    var series = ViewBag.Series as List<SelectListItem> ?? new List<SelectListItem>();
    var seriesSeleccionadas = Model?.SeriesSeleccionadasIds ?? new List<int>();

    var almacenes = ViewBag.Almacenes as List<SelectListItem> ?? new List<SelectListItem>();
    var almacenSeleccionados = Model?.AlmacenesSeleccionados ?? new List<string>();
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger edit-alert mt-3">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
    </div>
}

<style>

    :root {
        --edit-brand-grad: linear-gradient(90deg, #8B0000 0%, #5a0000 50%, #1a0000 100%);
        --edit-brand: #8B0000;
        --edit-brand-hover: #650000;
        --edit-bg: linear-gradient(135deg, #eef2f6 0%, #e9edf2 50%, #d7dde3 100%);
        --edit-pane: #ffffff;
        --edit-panel: #f6f8fb;
        --edit-panel-2: #eef2f7;
        --edit-line: #d8dce3;
        --edit-line-strong: #c9ced8;
        --edit-ink: #20262e;
        --edit-ink-strong: #1e2a35;
        --edit-title: #2b3642;
        --edit-muted: #636d7b;
        --edit-input-bg: #ffffff;
        --edit-input-text: #20262e;
        --edit-input-placeholder: #8a94a3;
        --edit-readonly-bg: #f1f4f8;
        --edit-item-bg: #f8fafc;
        --edit-item-hover: #eef2f7;
        --edit-item-selected: #fff1f1;
        --edit-radius: 10px;
        --edit-shadow: 0 1px 0 rgba(0,0,0,.05), 0 12px 24px rgba(0,0,0,.06);
        --edit-shadow-sm: 0 6px 16px rgba(0,0,0,.06);
        --edit-focus: 0 0 0 .2rem rgba(139,0,0,.18);
        --edit-warning-bg: #fff8e1;
        --edit-warning-text: #7a5200;
        --edit-warning-border: #f1d27a;
        --edit-danger-bg: #fff1f2;
        --edit-danger-text: #9f1239;
        --edit-danger-border: #fecdd3;
    }

    body[data-theme="dark"] {
        --edit-brand-grad: linear-gradient(90deg, #991b1b 0%, #600b0b 52%, #220606 100%);
        --edit-brand: #dc2626;
        --edit-brand-hover: #ef4444;
        --edit-bg: linear-gradient(135deg, #0f172a 0%, #111827 52%, #0b1220 100%);
        --edit-pane: #111827;
        --edit-panel: #1f2937;
        --edit-panel-2: #172033;
        --edit-line: rgba(255,255,255,.12);
        --edit-line-strong: rgba(248,113,113,.28);
        --edit-ink: #e5e7eb;
        --edit-ink-strong: #f9fafb;
        --edit-title: #f9fafb;
        --edit-muted: #cbd5e1;
        --edit-input-bg: #0b1220;
        --edit-input-text: #f9fafb;
        --edit-input-placeholder: #94a3b8;
        --edit-readonly-bg: #182235;
        --edit-item-bg: #172033;
        --edit-item-hover: #202b40;
        --edit-item-selected: rgba(185,28,28,.18);
        --edit-shadow: 0 12px 28px rgba(0,0,0,.32);
        --edit-shadow-sm: 0 8px 20px rgba(0,0,0,.24);
        --edit-focus: 0 0 0 .2rem rgba(248,113,113,.20);
        --edit-warning-bg: rgba(245,158,11,.13);
        --edit-warning-text: #fde68a;
        --edit-warning-border: rgba(245,158,11,.36);
        --edit-danger-bg: rgba(239,68,68,.13);
        --edit-danger-text: #fecaca;
        --edit-danger-border: rgba(248,113,113,.36);
    }

    body {
        background: var(--edit-bg) !important;
        color: var(--edit-ink);
    }

        /* Evita que el contenedor blanco del layout cubra el fondo oscuro. */
        body[data-theme="dark"] .layout-main-content {
            background: var(--edit-bg) !important;
        }

            body[data-theme="dark"] .layout-main-content .layout-container-fluid {
                background: transparent !important;
                box-shadow: none !important;
            }

    .container-sap {
        max-width: 980px;
        margin: 1.25rem auto 2rem;
        color: var(--edit-ink);
    }

    /* ============================================================
               MENSAJE DE ERROR
               ============================================================ */

    .edit-alert {
        max-width: 980px;
        margin-left: auto;
        margin-right: auto;
        background: var(--edit-danger-bg) !important;
        color: var(--edit-danger-text) !important;
        border-color: var(--edit-danger-border) !important;
    }

    /* ============================================================
               BARRA DE TÍTULO
               ============================================================ */

    .sap-titlebar {
        background: linear-gradient(180deg, var(--edit-panel), var(--edit-panel-2));
        border: 1px solid var(--edit-line-strong);
        border-radius: var(--edit-radius);
        padding: .85rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        flex-wrap: wrap;
        box-shadow: var(--edit-shadow);
        color: var(--edit-ink);
    }

    body[data-theme="dark"] .sap-titlebar {
        background: linear-gradient(135deg, #1f2937 0%, #172033 55%, #111827 100%);
    }

    .sap-titlebar .title {
        margin: 0;
        display: flex;
        align-items: center;
        gap: .55rem;
        font-weight: 800;
        letter-spacing: .2px;
        color: var(--edit-title);
    }

        .sap-titlebar .title i {
            color: var(--edit-brand);
        }

    body[data-theme="dark"] .sap-titlebar .title i {
        color: #fca5a5;
    }

    .sap-titlebar .sub {
        margin: 0;
        font-size: .92rem;
        color: var(--edit-muted);
    }

    .sap-titlebar .actions .btn {
        border-radius: 999px;
        font-weight: 700;
    }

    /* ============================================================
               TARJETA PRINCIPAL Y ENCABEZADOS
               ============================================================ */

    .sap-card {
        background: var(--edit-pane);
        border: 1px solid var(--edit-line);
        border-radius: var(--edit-radius);
        box-shadow: var(--edit-shadow);
        overflow: hidden;
        color: var(--edit-ink);
    }

    .sap-card-head {
        padding: .75rem 1rem;
        border-bottom: 1px solid var(--edit-line);
        background: linear-gradient(180deg, var(--edit-panel), var(--edit-panel-2));
        font-weight: 800;
        color: var(--edit-title);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .5rem;
        flex-wrap: wrap;
    }

    body[data-theme="dark"] .sap-card-head {
        background: linear-gradient(180deg, #1f2937, #172033);
    }

    .form-wrap {
        padding: 1.2rem;
        background: var(--edit-pane);
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: .8rem;
    }

    @@media (min-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    /* ============================================================
               CAMPOS
               ============================================================ */

    .field-card {
        display: flex;
        gap: .85rem;
        align-items: stretch;
        background: var(--edit-pane);
        border: 1px solid var(--edit-line);
        border-radius: 10px;
        padding: .9rem 1rem;
        box-shadow: var(--edit-shadow-sm);
        color: var(--edit-ink);
        transition: border-color .2s ease, background .2s ease, transform .2s ease;
    }

        .field-card:hover {
            border-color: var(--edit-line-strong);
        }

    .field-icon {
        width: 42px;
        min-width: 42px;
        height: 42px;
        border-radius: 50%;
        background: var(--edit-brand-grad);
        color: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        box-shadow: 0 6px 16px rgba(139,0,0,.20);
    }

    body[data-theme="dark"] .field-icon {
        box-shadow: 0 8px 18px rgba(0,0,0,.32);
    }

    .field-body {
        flex: 1;
        min-width: 0;
    }

    .field-label {
        font-weight: 700;
        color: var(--edit-ink-strong);
        margin-bottom: .35rem;
    }

    .grid-full {
        grid-column: 1 / -1;
    }

    .series-field-card {
        align-items: flex-start;
    }

    /* ============================================================
               INPUTS, SELECTS Y TEXTOS AUXILIARES
               ============================================================ */

    .container-sap .form-control,
    .container-sap .form-select {
        background-color: var(--edit-input-bg) !important;
        color: var(--edit-input-text) !important;
        border: 1px solid var(--edit-line) !important;
        border-radius: 8px;
        font-size: .95rem;
        box-shadow: none;
    }

        .container-sap .form-control:focus,
        .container-sap .form-select:focus {
            border-color: var(--edit-brand) !important;
            box-shadow: var(--edit-focus) !important;
            outline: none;
        }

        .container-sap .form-control::placeholder {
            color: var(--edit-input-placeholder) !important;
        }

        .container-sap .form-control[readonly],
        .container-sap .form-control:disabled,
        .container-sap .form-select:disabled {
            background-color: var(--edit-readonly-bg) !important;
            color: var(--edit-muted) !important;
            opacity: 1;
        }

    body[data-theme="dark"] .container-sap .form-select {
        color-scheme: dark;
    }

        body[data-theme="dark"] .container-sap .form-select option {
            background: #111827;
            color: #f9fafb;
        }

    .container-sap .text-muted,
    .container-sap .form-text,
    .container-sap small {
        color: var(--edit-muted) !important;
    }

    .container-sap .form-check-label {
        color: var(--edit-ink-strong);
    }

    .container-sap .text-danger {
        color: #dc2626 !important;
    }

    body[data-theme="dark"] .container-sap .text-danger {
        color: #fca5a5 !important;
    }

    /* Corrige el color que algunos navegadores aplican al autocompletar. */
    body[data-theme="dark"] .container-sap input:-webkit-autofill,
    body[data-theme="dark"] .container-sap input:-webkit-autofill:hover,
    body[data-theme="dark"] .container-sap input:-webkit-autofill:focus {
        -webkit-text-fill-color: var(--edit-input-text);
        -webkit-box-shadow: 0 0 0 1000px var(--edit-input-bg) inset;
        transition: background-color 9999s ease-in-out 0s;
    }

    /* ============================================================
               BOTONES
               ============================================================ */

    .container-sap .btn {
        border-radius: 8px;
        font-weight: 600;
        padding: .6rem 1.1rem;
    }

    .container-sap .btn-reflejo {
        background: var(--edit-brand-grad);
        color: #ffffff;
        border: 1px solid transparent;
    }

        .container-sap .btn-reflejo:hover,
        .container-sap .btn-reflejo:focus {
            color: #ffffff;
            filter: brightness(1.10);
            transform: translateY(-1px);
        }

    .container-sap .btn-secondary {
        background: #5b6478;
        border: 1px solid #5b6478;
        color: #ffffff;
    }

        .container-sap .btn-secondary:hover {
            color: #ffffff;
            filter: brightness(1.08);
        }

    body[data-theme="dark"] .container-sap .btn-secondary {
        background: #334155;
        border-color: rgba(203,213,225,.28);
        color: #f8fafc;
    }

        body[data-theme="dark"] .container-sap .btn-secondary:hover {
            background: #475569;
            border-color: rgba(203,213,225,.45);
        }

    body[data-theme="dark"] .container-sap .btn-outline-primary {
        color: #fca5a5;
        border-color: rgba(248,113,113,.55);
        background: rgba(127,29,29,.08);
    }

        body[data-theme="dark"] .container-sap .btn-outline-primary:hover {
            color: #ffffff;
            background: rgba(185,28,28,.88);
            border-color: rgba(248,113,113,.90);
        }

    body[data-theme="dark"] .container-sap .btn-outline-secondary {
        color: #e5e7eb;
        border-color: rgba(203,213,225,.42);
        background: rgba(15,23,42,.35);
    }

        body[data-theme="dark"] .container-sap .btn-outline-secondary:hover {
            color: #ffffff;
            background: #475569;
            border-color: rgba(203,213,225,.60);
        }

    .actions-row {
        display: flex;
        gap: .6rem;
        justify-content: center;
        margin-top: .6rem;
        flex-wrap: wrap;
    }

    /* ============================================================
               SERIES Y ALMACENES
               ============================================================ */

    .series-actions,
    .almacen-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 10px;
    }

    .series-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
        gap: 8px;
    }

    .serie-item {
        border: 1px solid var(--edit-line);
        border-radius: 10px;
        padding: 8px 10px;
        background: var(--edit-item-bg);
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
        color: var(--edit-ink-strong);
        cursor: pointer;
        transition: background .2s ease, border-color .2s ease, transform .2s ease;
    }

        .serie-item:hover {
            background: var(--edit-item-hover);
            border-color: var(--edit-line-strong);
            transform: translateY(-1px);
        }

        .serie-item:has(.form-check-input:checked) {
            background: var(--edit-item-selected);
            border-color: rgba(139,0,0,.35);
        }

    body[data-theme="dark"] .serie-item:has(.form-check-input:checked) {
        border-color: rgba(248,113,113,.48);
    }

    .serie-item input {
        width: 16px;
        height: 16px;
        flex: 0 0 auto;
    }

    .container-sap .form-check-input {
        background-color: var(--edit-input-bg);
        border-color: var(--edit-line-strong);
        accent-color: var(--edit-brand);
    }

        .container-sap .form-check-input:checked {
            background-color: var(--edit-brand);
            border-color: var(--edit-brand);
        }

        .container-sap .form-check-input:focus {
            border-color: var(--edit-brand);
            box-shadow: var(--edit-focus);
        }

    body[data-theme="dark"] .container-sap .form-switch .form-check-input:not(:checked) {
        background-color: #0b1220;
        border-color: rgba(203,213,225,.42);
    }

    /* ============================================================
               ALERTAS
               ============================================================ */

    .container-sap .alert-warning {
        background: var(--edit-warning-bg) !important;
        color: var(--edit-warning-text) !important;
        border-color: var(--edit-warning-border) !important;
    }

    /* ============================================================
               RESPONSIVE
               ============================================================ */

    @@media (max-width: 767.98px) {
        .container-sap {
            margin: .85rem .75rem 1.5rem;
        }

        .edit-alert {
            margin-left: .75rem;
            margin-right: .75rem;
        }

        .sap-titlebar {
            align-items: flex-start;
        }

            .sap-titlebar .actions,
            .sap-titlebar .actions .btn {
                width: 100%;
            }

        .form-wrap {
            padding: .85rem;
        }

        .field-card {
            padding: .8rem;
        }

        .series-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 480px) {
        .field-card {
            flex-direction: column;
        }

        .field-icon {
            width: 38px;
            min-width: 38px;
            height: 38px;
        }

        .field-body.d-flex {
            align-items: flex-start !important;
        }

        .form-switch.ms-2,
        .form-switch.ms-auto {
            margin-left: 0 !important;
        }

        .actions-row .btn {
            width: 100%;
        }
    }
</style>


<div class="container-sap">

    <!-- Titlebar -->
    <div class="sap-titlebar">
        <div>
            <h4 class="title"><i class="bi bi-person-gear"></i> Editar Usuario SQL</h4>
            <p class="sub mb-0">Actualiza datos generales, perfil y vínculo con vendedor.</p>
        </div>
        <div class="actions">
            <a href="@Url.Action("UsuariosConfiguracion", "Usuarios")" class="btn btn-secondary btn-sm">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
        </div>
    </div>

    <!-- Card -->
    <div class="sap-card mt-3">
        <div class="sap-card-head">
            <span class="d-flex align-items-center gap-2">
                <i class="bi bi-pencil-square"></i> Formulario de edición
            </span>
        </div>

        <div class="form-wrap">
            <form asp-controller="Usuarios" asp-action="Editar" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="form-grid">

                    <!-- Usuario (solo lectura) -->
                    <div class="field-card">
                        <div class="field-icon"><i class="bi bi-person"></i></div>
                        <div class="field-body">
                            <div class="field-label">Usuario</div>
                            <input asp-for="Usuario" class="form-control" readonly />
                        </div>
                    </div>

                    <!-- Nombre -->
                    <div class="field-card">
                        <div class="field-icon"><i class="bi bi-person-badge"></i></div>
                        <div class="field-body">
                            <div class="field-label">Nombre completo</div>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Perfil -->
                    <div class="field-card grid-full">
                        <div class="field-icon"><i class="bi bi-person-gear"></i></div>
                        <div class="field-body">
                            <div class="field-label">Perfil</div>
                            <select asp-for="PerfilId" class="form-select"
                                    asp-items="@(new SelectList(ViewBag.Perfiles, "Id", "Nombre"))">
                                <option value="">-- Seleccione un perfil --</option>
                            </select>
                            <span asp-validation-for="PerfilId" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Es Vendedor -->
                    <div class="field-card grid-full">
                        <div class="field-icon"><i class="bi bi-briefcase"></i></div>
                        <div class="field-body d-flex align-items-center justify-content-between">
                            <div>
                                <div class="field-label mb-1">¿Es vendedor?</div>
                                <div class="text-muted small">Si se activa, podrás indicar el ID del vendedor.</div>
                            </div>
                            <div class="form-check form-switch ms-2">
                                <input asp-for="EsVendedor" type="checkbox" class="form-check-input" id="chkVendedor" />
                                <label class="form-check-label" for="chkVendedor">Activar</label>
                            </div>
                        </div>
                    </div>

                    <!-- Vendedor ID (condicional) -->
                    <div class="field-card grid-full" id="vendedorIdCard" style="display:none;">
                        <div class="field-icon"><i class="bi bi-person-vcard"></i></div>
                        <div class="field-body">
                            <div class="field-label">ID Vendedor</div>
                            <input asp-for="VendedorId" class="form-control" type="number" min="0" />
                            <span class="form-text">Ingresa el identificador del vendedor (numérico).</span>
                        </div>
                    </div>

                    <!-- Privilegio especial TransferenciasSucursal -->
                    <div class="field-card grid-full">
                        <div class="field-icon">
                            <i class="bi bi-shield-check"></i>
                        </div>

                        <div class="field-body d-flex align-items-center justify-content-between gap-3 flex-wrap">
                            <div>
                                <div class="field-label mb-1">
                                    Privilegio especial en TransferenciasSucursal
                                </div>

                                <div class="text-muted small">
                                    Permite que este usuario vea todas las transferencias, sin filtrar por serie/sucursal.
                                </div>

                                <span asp-validation-for="IgnoraFiltroSerieTransferencias" class="text-danger small"></span>
                            </div>

                            <div class="form-check form-switch ms-auto">
                                <input asp-for="IgnoraFiltroSerieTransferencias"
                                       type="checkbox"
                                       class="form-check-input"
                                       id="IgnoraFiltroSerieTransferencias" />

                                <label class="form-check-label" for="IgnoraFiltroSerieTransferencias">
                                    Activar
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Series permitidas -->
                    <div class="field-card grid-full series-field-card">
                        <div class="field-icon"><i class="bi bi-diagram-3"></i></div>
                        <div class="field-body">
                            <div class="field-label">Series permitidas para Orden de Venta</div>

                            <div class="series-actions">
                                <button type="button" class="btn btn-sm btn-outline-primary" id="btnMarcarSeries">
                                    <i class="bi bi-check2-all me-1"></i> Marcar todas
                                </button>

                                <button type="button" class="btn btn-sm btn-outline-secondary" id="btnLimpiarSeries">
                                    <i class="bi bi-eraser me-1"></i> Limpiar
                                </button>
                            </div>

                            @if (!series.Any())
                            {
                                <div class="alert alert-warning mb-0">
                                    No hay series registradas en el catálogo.
                                </div>
                            }
                            else
                            {
                                <div class="series-grid">
                                    @foreach (var s in series)
                                    {
                                        var serieId = int.Parse(s.Value);
                                        var estaSeleccionada = seriesSeleccionadas.Contains(serieId);

                                        <label class="serie-item">
                                            <input class="form-check-input serie-check"
                                                   type="checkbox"
                                                   name="SeriesSeleccionadasIds"
                                                   value="@s.Value"
                                                   checked="@estaSeleccionada" />
                                            <span>@s.Text</span>
                                        </label>
                                    }
                                </div>
                            }

                            <div class="text-muted small mt-2">
                                El usuario solo podrá seleccionar estas series al crear una Orden de Venta.
                            </div>
                        </div>
                    </div>

                    <!-- Almacenes permitidos -->
                    <div class="field-card grid-full series-field-card">
                        <div class="field-icon">
                            <i class="bi bi-box-seam"></i>
                        </div>

                        <div class="field-body">
                            <div class="field-label">Almacenes permitidos</div>

                            <div class="almacen-actions">
                                <button type="button" class="btn btn-sm btn-outline-primary" id="btnMarcarAlmacen">
                                    <i class="bi bi-check2-all me-1"></i> Marcar todos
                                </button>

                                <button type="button" class="btn btn-sm btn-outline-secondary" id="btnLimpiarAlmacen">
                                    <i class="bi bi-eraser me-1"></i> Limpiar
                                </button>
                            </div>

                            @if (!almacenes.Any())
                            {
                                <div class="alert alert-warning mb-0">
                                    No hay almacenes
                                </div>
                            }
                            else
                            {
                                <div class="series-grid">
                                    @foreach (var a in almacenes)
                                    {
                                        var estaSeleccionado =
                                        almacenSeleccionados.Contains(a.Value);

                                        <label class="serie-item">
                                            <input class="form-check-input almacen-check"
                                                   type="checkbox"
                                                   name="AlmacenesSeleccionados"
                                                   value="@a.Value"
                                                   checked="@estaSeleccionado" />

                                            <span>@a.Text</span>
                                        </label>
                                    }
                                </div>
                            }

                            <div class="text-muted small mt-2">
                                El usuario solo podrá utilizar estos almacenes
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Cambio de contraseña -->
                <div class="sap-card-head mt-3">
                    <i class="bi bi-shield-lock"></i> Cambio de contraseña
                </div>

                <div class="form-grid">

                    <div class="field-card">
                        <div class="field-icon"><i class="bi bi-key"></i></div>
                        <div class="field-body">
                            <div class="field-label">Nueva contraseña</div>
                            <input asp-for="NuevaPassword" class="form-control" type="password" autocomplete="new-password" />
                            <span asp-validation-for="NuevaPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="field-card">
                        <div class="field-icon"><i class="bi bi-key-fill"></i></div>
                        <div class="field-body">
                            <div class="field-label">Confirmar contraseña</div>
                            <input asp-for="ConfirmarPassword" class="form-control" type="password" autocomplete="new-password" />
                            <span asp-validation-for="ConfirmarPassword" class="text-danger small"></span>
                        </div>
                    </div>

                </div>

                <p class="text-muted small mt-2">
                    Deja estos campos vacíos si no deseas cambiar la contraseña.
                </p>

                <div class="actions-row">
                    <button type="submit" class="btn btn-reflejo">
                        <i class="bi bi-save me-1"></i> Guardar cambios
                    </button>
                    <a href="@Url.Action("UsuariosConfiguracion", "Usuarios")" class="btn btn-secondary">
                        <i class="bi bi-x-circle me-1"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Toggle vendedor (muestra/oculta campo y limpia valor al ocultar)
        const chkVendedor = document.getElementById("chkVendedor");
        const cardVendedor = document.getElementById("vendedorIdCard");
        const inputVendedor = document.querySelector("[name='VendedorId']");

        function toggleVendedor() {
            if (chkVendedor.checked) {
                cardVendedor.style.display = "flex";
            } else {
                cardVendedor.style.display = "none";
                if (inputVendedor) inputVendedor.value = "";
            }
        }
        if (chkVendedor) {
            chkVendedor.addEventListener("change", toggleVendedor);
            toggleVendedor(); // al cargar
        }

        const btnMarcarSeries = document.getElementById("btnMarcarSeries");
        const btnLimpiarSeries = document.getElementById("btnLimpiarSeries");

        btnMarcarSeries?.addEventListener("click", function () {
            document.querySelectorAll(".serie-check").forEach(x => x.checked = true);
        });

        btnLimpiarSeries?.addEventListener("click", function () {
            document.querySelectorAll(".serie-check").forEach(x => x.checked = false);
        });

        //Almacen
        const btnMarcarAlmacen = document.getElementById("btnMarcarAlmacen");
        const btnLimpiarAlmacen = document.getElementById("btnLimpiarAlmacen");

        btnMarcarAlmacen?.addEventListener("click", function () {
            document.querySelectorAll(".almacen-check").forEach(x => x.checked = true);
        });

        btnLimpiarAlmacen?.addEventListener("click", function () {
            document.querySelectorAll(".almacen-check").forEach(x => x.checked = false);
        });

    </script>
}
