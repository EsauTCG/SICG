        .copy-token-btn:active {
            transform: scale(0.96);
        }

    .token-value {
        padding-right: .2rem;
        word-break: break-all;
    }

    .files-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: .9rem;
    }

    .file-type-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 4px 12px rgba(0,0,0,.035);
    }

    .file-type-head {
        padding: .85rem 1rem;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, #fff 0%, #fafbfd 100%);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .8rem;
    }

    .file-type-title {
        margin: 0;
        font-size: .95rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .file-type-title i {
            color: var(--primary);
        }

    .file-count {
        background: var(--primary-soft);
        color: var(--primary);
        border: 1px solid #f0cfcf;
        border-radius: 999px;
        padding: .3rem .65rem;
        font-size: .76rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .file-type-body {
        padding: .85rem;
        display: flex;
        flex-wrap: wrap;
        gap: .6rem;
    }

    .file-item {
        display: inline-flex;
        align-items: center;
        gap: .55rem;
        padding: .55rem .75rem;
        border: 1px solid #e7ecf2;
        border-radius: 999px;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        text-decoration: none;
        color: var(--text);
        transition: var(--transition);
        max-width: 100%;
    }

        .file-item:hover {
            border-color: var(--primary);
            background: var(--primary-soft);
            color: var(--primary);
            box-shadow: 0 6px 14px rgba(139,0,0,.08);
            transform: translateY(-1px);
        }

    .file-item-icon {
        width: 28px;
        height: 28px;
        border-radius: 9px;
        background: var(--primary-soft);
        color: var(--primary);
        display: grid;
        place-items: center;
        flex-shrink: 0;
        font-size: .86rem;
    }

    .file-item-main {
        min-width: 0;
        flex: 1;
    }

    .file-item-name {
        font-size: .8rem;
        font-weight: 800;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .file-item-meta {
        display: none;
    }

    .file-item-action {
        color: var(--primary);
        font-size: .9rem;
        flex-shrink: 0;
    }

    .empty-file-box {
        border: 1px dashed var(--border-strong);
        background: linear-gradient(180deg, #f8fafc 0%, #f4f7fb 100%);
        border-radius: 14px;
        padding: .8rem .9rem;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: .55rem;
    }

    /* ============================================================
       DARK MODE - DETALLE DEL EMBARQUE
============================================================ */

body[data-theme="dark"] {
    --primary: #ef4444;
    --primary-dark: #991b1b;
    --primary-soft: rgba(127,29,29,0.22);
    --accent: #f87171;

    --bg: #0f172a;
    --panel: #111827;
    --panel-soft: #172033;
    --border: rgba(255,255,255,0.12);
    --border-strong: rgba(203,213,225,0.28);
    --text: #f9fafb;
    --muted: #cbd5e1;

    --success: #22c55e;
    --success-soft: rgba(22,101,52,0.26);
    --warning: #f59e0b;
    --warning-soft: rgba(180,83,9,0.22);
    --danger: #f87171;
    --danger-soft: rgba(153,27,27,0.30);
    --info: #60a5fa;
    --info-soft: rgba(30,64,175,0.24);

    --shadow-sm: 0 10px 26px rgba(0,0,0,.34);
    --shadow-md: 0 18px 42px rgba(0,0,0,.46);
}

/* Fondo general */
body[data-theme="dark"] {
    background: #0f172a !important;
    color: #e5e7eb !important;
}

body[data-theme="dark"] .layout-main-content {
