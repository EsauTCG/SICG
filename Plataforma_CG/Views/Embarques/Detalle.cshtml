                                    <tr>
                                        <td>@ov.Consecutivo</td>
                                        <td>@ov.NombreCliente</td>
                                        <td>@ov.Ruta</td>
                                        <td>
                                            @(ov.FechaEntrega != null
                                                                                ? Convert.ToDateTime(ov.FechaEntrega).ToString("yyyy-MM-dd")
                                                                                : "-")
                                </td>
                                <td class="text-center">
                                    @if (Model.FechaSalida == null && Model.QR == null && (Model.Estatus == 1 || Model.Estatus == 7))
                                            {
                                                <form asp-action="QuitarDocumentoEmbarque"
                                                      asp-controller="Embarques"
                                                      method="post"
                                                      class="d-inline"
                                                      onsubmit="return confirm('¿Seguro que deseas quitar esta orden del embarque? La orden regresará a estatus autorizado.');">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="embarqueId" value="@Model.Id" />
                                                    <input type="hidden" name="documentoId" value="@ov.Id" />
                                                    <input type="hidden" name="tipoDocumento" value="OV" />

                                                    @if (User.IsInRole("Administracion de Ventas") || User.IsInRole("Administrador"))
                                                    {
                                                        <button type="submit" class="btn-remove-doc">
                                                            <i class="bi bi-trash3"></i>
                                                            Quitar
                                                        </button>
                                                    }

                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Bloqueado</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (ViewBag.Transferencias != null && ((IEnumerable<dynamic>)ViewBag.Transferencias).Any())
        {
            <div class="card-ui">
                <div class="card-head">
                    <div>
                        <h5 class="card-title">
                            <i class="bi bi-arrow-left-right"></i>
                            Transferencias Incluidas
                        </h5>
                        <div class="card-sub">Movimientos internos relacionados al embarque</div>
                    </div>
                    <span class="badge-counter">@totalTR registro(s)</span>
                </div>

                <div class="card-body">
                    <div class="table-responsive-ui">
                        <table class="table-soft">
                            <thead>
                                <tr>
                                    <th>Consecutivo</th>
                                    <th>Sucursal</th>
                                    <th>Fecha Solicitud</th>
                                    <th>Usuario Solicita</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tr in ViewBag.Transferencias)
                                {
                                    <tr>
                                        <td>@tr.Consecutivo</td>
                                        <td>@tr.Sucursal</td>
                                        <td>
                                            @(tr.FechaSolicitud != null
                                                                                ? Convert.ToDateTime(tr.FechaSolicitud).ToString("yyyy-MM-dd")
                                                                                : "-")
                                </td>
                                <td>@tr.UsuarioSolicita</td>
                                <td class="text-center">
                                    @if (Model.FechaSalida == null && Model.QR == null && (Model.Estatus == 1 || Model.Estatus == 7))
                                            {
                                                <form asp-action="QuitarDocumentoEmbarque"
                                                      asp-controller="Embarques"
                                                      method="post"
                                                      class="d-inline"
                                                      onsubmit="return confirm('¿Seguro que deseas quitar esta transferencia del embarque? La transferencia regresará a estatus autorizado.');">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="embarqueId" value="@Model.Id" />
                                                    <input type="hidden" name="documentoId" value="@tr.Id" />
                                                    <input type="hidden" name="tipoDocumento" value="TRANSFERENCIA" />

                                                    @if (User.IsInRole("Administracion de Ventas") || User.IsInRole("Administrador"))
                                                    {
                                                        <button type="submit" class="btn-remove-doc">
                                                            <i class="bi bi-trash3"></i>
                                                            Quitar
                                                        </button>
                                                    }

                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Bloqueado</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="modal fade" id="modalPreviewArchivo" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title fw-bold" id="modalPreviewArchivoTitulo">
                            Vista previa
                        </h5>
                        <div class="text-muted small" id="modalPreviewArchivoTipo">
                            Archivo
                        </div>
                    </div>

                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>

                <div class="modal-body">
                    <img id="modalPreviewArchivoImg"
                         class="preview-modal-img d-none"
                         src=""
                         alt="Vista previa" />

                    <iframe id="modalPreviewArchivoFrame"
                            class="preview-modal-frame d-none"
                            src="">
                    </iframe>

                    <div id="modalPreviewArchivoNoDisponible" class="preview-unavailable d-none">
                        <i id="modalPreviewArchivoIcono" class="bi bi-file-earmark"></i>
                        <h6>Vista previa no disponible directamente</h6>
                        <p class="mb-0">
                            Este tipo de archivo normalmente debe abrirse en su aplicación correspondiente.
                        </p>
                    </div>
                </div>

                <div class="modal-footer">
                    <a id="modalPreviewArchivoAbrir"
                       href="#"
                       target="_blank"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-box-arrow-up-right"></i>
                        Abrir original
                    </a>

                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/embarque.js"></script>

    <script>
        const EMB_ID = @Model.Id;
        const QR_URL = "@Model.QR?.UrlQR";
        const QR_TOKEN = "@Model.QR?.Token";
        const QR_FECHA = "@Model.QR?.FechaGeneracion";

        async function copiarToken(token) {
            if (!token || token.trim() === "") {
                alert("No hay token disponible para copiar.");
                return;
            }

            try {
                await navigator.clipboard.writeText(token);
            } catch (error) {
                console.error("Error al copiar token:", error);

                const tempInput = document.createElement("input");
                tempInput.value = token;
                document.body.appendChild(tempInput);
                tempInput.select();
                tempInput.setSelectionRange(0, 99999);

                try {
                    document.execCommand("copy");
                } catch (err) {
                    alert("No se pudo copiar el token.");
                }

                document.body.removeChild(tempInput);
            }
        }

        function obtenerExtensionArchivo(url) {
            if (!url) return "";

            const cleanUrl = url.split("?")[0].split("#")[0];
            const index = cleanUrl.lastIndexOf(".");

            if (index === -1) return "";

            return cleanUrl.substring(index).toLowerCase();
        }

        function esImagenArchivo(url) {
            const ext = obtenerExtensionArchivo(url);
            return [".jpg", ".jpeg", ".png", ".webp", ".gif", ".bmp"].includes(ext);
        }

        function esPdfArchivo(url) {
            return obtenerExtensionArchivo(url) === ".pdf";
        }

        function obtenerIconoArchivo(url) {
            const ext = obtenerExtensionArchivo(url);

            if ([".jpg", ".jpeg", ".png", ".webp", ".gif", ".bmp"].includes(ext)) {
                return "bi-file-earmark-image";
            }

            if (ext === ".pdf") {
                return "bi-file-earmark-pdf";
            }

            if ([".xls", ".xlsx", ".csv"].includes(ext)) {
                return "bi-file-earmark-excel";
            }

            if ([".doc", ".docx"].includes(ext)) {
                return "bi-file-earmark-word";
            }

            return "bi-file-earmark";
        }

        function abrirPreviewArchivoDesdeBoton(btn) {
            const url = btn.dataset.fileUrl || btn.dataset.photoUrl;
            const title = btn.dataset.fileTitle || btn.dataset.photoTitle || "Vista previa";
            const type = btn.dataset.fileType || "Archivo";

            if (!url) return;

            const modalEl = document.getElementById("modalPreviewArchivo");
            const titulo = document.getElementById("modalPreviewArchivoTitulo");
            const tipo = document.getElementById("modalPreviewArchivoTipo");
            const img = document.getElementById("modalPreviewArchivoImg");
            const frame = document.getElementById("modalPreviewArchivoFrame");
            const noDisponible = document.getElementById("modalPreviewArchivoNoDisponible");
            const icono = document.getElementById("modalPreviewArchivoIcono");
            const abrirOriginal = document.getElementById("modalPreviewArchivoAbrir");

            if (!modalEl || !titulo || !tipo || !img || !frame || !noDisponible || !abrirOriginal) return;

            titulo.textContent = title;
            tipo.textContent = type;
            abrirOriginal.href = url;

            img.classList.add("d-none");
            frame.classList.add("d-none");
            noDisponible.classList.add("d-none");

            img.removeAttribute("src");
            frame.removeAttribute("src");

            if (esImagenArchivo(url)) {
                img.src = url;
                img.classList.remove("d-none");
            } else if (esPdfArchivo(url)) {
                frame.src = url;
                frame.classList.remove("d-none");
            } else {
                icono.className = `bi ${obtenerIconoArchivo(url)}`;
                noDisponible.classList.remove("d-none");
            }

            const modal = new bootstrap.Modal(modalEl);
            modal.show();
        }

        /* Para no romper tus fotos de calidad actuales */
        function abrirFotoCalidadDesdeBoton(btn) {
            btn.dataset.fileUrl = btn.dataset.photoUrl;
            btn.dataset.fileTitle = btn.dataset.photoTitle || "Evidencia fotográfica";
            btn.dataset.fileType = "Imagen";

            abrirPreviewArchivoDesdeBoton(btn);
        }

    </script>
}