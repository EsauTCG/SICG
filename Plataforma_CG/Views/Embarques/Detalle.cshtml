                            {
                                @foreach (var grupo in documentosCalidadCargados.GroupBy(x => x.Grupo))
                                {
                                    var grupoIcono = grupo.Key == "Expediente de calidad"
                                    ? "bi-folder2-open"
                                    : "bi-archive";

                                    <div class="file-quality-group">
                                        <div class="file-quality-group-title">
                                            <i class="bi @grupoIcono"></i>
                                            @grupo.Key
                                        </div>

