                                                            <div>
                                                                <div class="doc-preview-name">@tituloArchivo</div>
                                                                <div class="doc-preview-meta">
                                                                    @tipoArchivo · @archivo.FechaRegistro.ToString("yyyy-MM-dd HH:mm")

