            content: "";
            position: absolute;
            right: -45px;
            top: -45px;
            width: 190px;
            height: 190px;
            border-radius: 50%;
            background: rgba(255,255,255,.06);
        }

    .detail-header-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
    }

    .detail-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .header-icon {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.16);
        display: grid;
        place-items: center;
        font-size: 1.45rem;
    }

    .detail-title {
        margin: 0;
        font-size: 1.7rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .detail-sub {
        margin: .35rem 0 0;
        color: rgba(255,255,255,.88);
        font-size: .95rem;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: .7rem;
        flex-wrap: wrap;
    }

    .header-chip {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .58rem .95rem;
        border-radius: 999px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.16);
        font-size: .88rem;
        font-weight: 700;
    }

    .btn-top {
        border: none;
        border-radius: 999px;
        padding: .72rem 1rem;
        font-weight: 800;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
