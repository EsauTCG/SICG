body[data-theme="dark"] {
    --primary: #ef4444;
    --primary-dark: #991b1b;
    --primary-soft: rgba(127,29,29,0.22);
    --accent: #f87171;

    --bg: #0f172a;
    --panel: #111827;
    --panel-soft: #172033;
    --border: rgba(255,255,255,0.12);
    --border-strong: rgba(203,213,225,0.28);
    --text: #f9fafb;
