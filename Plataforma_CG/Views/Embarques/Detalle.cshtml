            color: var(--text);
        }

        .status-pill.route {
            background: #fff0e1;
            color: #c56a00;
        }

        .status-pill.secondary {
            background: #eef1f4;
            color: #6c757d;
        }

    .content-grid {
        display: grid;
        grid-template-columns: 1.05fr .95fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .card-ui {
        background: var(--panel);
        border: 1px solid var(--border);
