@model Plataforma_CG.Models.Embarque

@{
    ViewData["Title"] = "Detalle del Embarque";
    Layout = "~/Views/Shared/_Layout2.cshtml";

    var totalOV = ((IEnumerable<dynamic>)ViewBag.OrdenesVenta)?.Count() ?? 0;
    var totalTR = ((IEnumerable<dynamic>)ViewBag.Transferencias)?.Count() ?? 0;

    var calidadAprobada = Model.CalidadAprobada == true;
    var documentacionAprobada = Model.DocumentacionAprobada == true;
    var documentacionCalidadAprobada = Model.DocumentacionCalidadAprobada == true;

    var validacionesCompletas = calidadAprobada
        && documentacionAprobada
        && documentacionCalidadAprobada;

    var archivos = Model.Archivos ?? new List<Plataforma_CG.Models.EmbarqueArchivo>();

    // DOCUMENTACIÓN LOGÍSTICA
    var cartasPorte = archivos.Where(a => a.Tipo == "CARTA_PORTE").ToList();
    var tieneCartaPorte = cartasPorte.Any();

    var cartaPorteSinDefinir = Model.RequiereCartaPorte == null;
    var cartaPorteRequerida = Model.RequiereCartaPorte == true;
    var cartaPorteNoAplica = Model.RequiereCartaPorte == false;

    var cartaPorteOk = cartaPorteNoAplica || (cartaPorteRequerida && tieneCartaPorte);

    string cartaPorteTexto =
        cartaPorteSinDefinir ? "Sin definir" :
        cartaPorteNoAplica ? "No aplica" :
        tieneCartaPorte ? "Requerida y cargada" :
        "Requerida pendiente";

    string cartaPorteClase =
        cartaPorteOk ? "success" :
        cartaPorteSinDefinir ? "warning" :
        "danger";

    string cartaPorteIcono =
        cartaPorteOk ? "bi-check-circle" :
        cartaPorteSinDefinir ? "bi-hourglass-split" :
        "bi-exclamation-triangle";

    // DOCUMENTACIÓN CALIDAD
    var calidadCartasGarantia = archivos.Where(a => a.Tipo == "CALIDAD_CARTA_GARANTIA").ToList();
    var calidadLibreClembuterol = archivos.Where(a => a.Tipo == "CALIDAD_LIBRE_CLEMBUTEROL").ToList();
    var calidadLibreResiduosToxicos = archivos.Where(a => a.Tipo == "CALIDAD_LIBRE_RESIDUOS_TOXICOS").ToList();
    var calidadCartasEEB = archivos.Where(a => a.Tipo == "CALIDAD_CARTA_EEB").ToList();
    var calidadAvisosMovilizacion = archivos.Where(a => a.Tipo == "CALIDAD_AVISO_MOVILIZACION").ToList();
    var calidadHojasTrabajo = archivos.Where(a => a.Tipo == "CALIDAD_HOJA_TRABAJO").ToList();

    var totalDocsLogistica = cartasPorte.Count;

    var totalDocsCalidad =
        calidadCartasGarantia.Count +
        calidadLibreClembuterol.Count +
        calidadLibreResiduosToxicos.Count +
        calidadCartasEEB.Count +
        calidadAvisosMovilizacion.Count +
        calidadHojasTrabajo.Count;

    string estatusTexto =
        Model.Estatus == 7 && !validacionesCompletas ? "Pendiente de validaciones" :
        Model.Estatus == 1 ? "Pendiente de validaciones" :
        Model.Estatus == 7 ? "Liberado para QR" :
        Model.Estatus == 2 ? "En Ruta" :
        Model.Estatus == 3 ? "En Destino" :
        Model.Estatus == 4 ? "Retrasado" :
        Model.Estatus == 5 ? "Entregado" :
        Model.Estatus == 6 ? "Devuelto" : "Desconocido";

    string estatusClase =
        Model.Estatus == 7 && !validacionesCompletas ? "warning" :
        Model.Estatus == 1 ? "warning" :
        Model.Estatus == 7 ? "success" :
        Model.Estatus == 2 ? "route" :
        Model.Estatus == 3 ? "info" :
        Model.Estatus == 4 ? "danger" :
        Model.Estatus == 5 ? "primary" :
        Model.Estatus == 6 ? "secondary" : "neutral";
        
}

<style>
    :root {
        --primary: #8B0000;
        --primary-dark: #5a0000;
        --primary-soft: #fdf1f1;
        --accent: #c82333;
        --bg: #f3f6fa;
        --panel: #ffffff;
        --panel-soft: #f8fafc;
        --border: #dfe5ec;
        --border-strong: #cfd7e1;
        --text: #1f2937;
        --muted: #6b7280;
        --success: #198754;
        --success-soft: #eaf7ef;
        --warning: #f59e0b;
        --warning-soft: #fff8e8;
        --danger: #dc3545;
        --danger-soft: #fdeeee;
        --info: #0d6efd;
        --info-soft: #edf4ff;
        --shadow-sm: 0 6px 18px rgba(15, 23, 42, 0.06);
        --shadow-md: 0 14px 34px rgba(15, 23, 42, 0.10);
        --radius-xl: 22px;
        --radius-lg: 18px;
        --radius-md: 14px;
        --radius-sm: 10px;
        --transition: all .22s ease;
    }

    body {
        background: linear-gradient(180deg, #f8fafc 0%, #eef3f8 100%);
        color: var(--text);
    }

    .detail-wrap {
        max-width: 1320px;
        margin: 2rem auto;
        padding: 0 1rem 2rem;
    }

    .detail-header {
        background: linear-gradient(135deg, #8B0000 0%, #5a0000 55%, #240000 100%);
        color: white;
        border-radius: var(--radius-xl);
        padding: 1.5rem 1.6rem;
        box-shadow: var(--shadow-md);
        margin-bottom: 1.1rem;
        position: relative;
        overflow: hidden;
    }

