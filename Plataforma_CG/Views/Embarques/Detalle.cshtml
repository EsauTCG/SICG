        font-size: .86rem;
        margin-top: .18rem;
    }

    .card-body {
        padding: 1.1rem;
    }

    .info-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .info-table tr:not(:last-child) td,
        .info-table tr:not(:last-child) th {
            border-bottom: 1px solid #edf1f5;
        }

        .info-table th,
        .info-table td {
            padding: .9rem .35rem;
            vertical-align: top;
        }

        .info-table th {
            width: 210px;
            color: var(--muted);
            font-size: .88rem;
            font-weight: 800;
        }

        .info-table td {
            color: var(--text);
