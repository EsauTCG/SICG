                                                                @if (EsImagenArchivo(archivo.RutaArchivo))
                                                                {
                                                                    <img src="@archivo.RutaArchivo" alt="@tituloArchivo" loading="lazy" />
                                                                }
                                                                else
                                                                {
                                                                    <i class="bi @iconoArchivo"></i>
                                                                }
