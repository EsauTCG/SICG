        }

        .status-pill.warning {
            background: var(--warning-soft);
            color: #9a6700;
        }

        .status-pill.primary {
            background: var(--info-soft);
            color: var(--info);
        }

        .status-pill.danger {
            background: var(--danger-soft);
            color: var(--danger);
        }

        .status-pill.neutral {
