    }

    .badge-counter {
        background: #f3f6f9;
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: .42rem .75rem;
        font-size: .82rem;
        font-weight: 800;
        color: var(--text);
    }

    @@media (max-width: 1100px) {
        .summary-grid {
            grid-template-columns: repeat(2, minmax(0,1fr));
        }

        .content-grid,
        .quality-sections {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .detail-wrap {
            padding: 0 .65rem 1.5rem;
        }

        .detail-header {
            padding: 1.1rem;
            border-radius: 18px;
        }

        .detail-header-left {
            align-items: flex-start;
        }

        .detail-title {
            font-size: 1.28rem;
        }

        .summary-grid,
        .quality-overview,
        .qr-meta {
            grid-template-columns: 1fr;
        }

        .header-icon {
            width: 50px;
            height: 50px;
            font-size: 1.2rem;
        }

        .info-table th,
        .info-table td {
            display: block;
            width: 100%;
            padding: .5rem 0;
        }

        .info-table th {
            border-bottom: none !important;
            padding-bottom: .15rem;
        }

        .info-table td {
            padding-top: 0;
        }

        .qr-box img {
            width: 190px;
            height: 190px;
        }

        .table-soft {
            min-width: 650px;
        }

        .tbtn,
        .btn-doc {
            width: 100%;
            justify-content: center;
        }

        .qr-actions,
        .doc-actions {
            flex-direction: column;
        }

        .detail-name-line {
            align-items: flex-start;
        }

        .detail-name-value {
            border-radius: 14px;
        }
    }

    .token-box {
        position: relative;
    }

    .mini-box-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .6rem;
        margin-bottom: .35rem;
    }

    .copy-token-btn {
        width: 34px;
        height: 34px;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--primary);
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: var(--transition);
        flex-shrink: 0;
    }

        .copy-token-btn:hover {
            background: var(--primary-soft);
            border-color: var(--primary);
            transform: translateY(-1px);
        }

        .copy-token-btn:active {
            transform: scale(0.96);
        }

    .token-value {
        padding-right: .2rem;
        word-break: break-all;
    }

    .files-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: .9rem;
    }

    .file-type-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 4px 12px rgba(0,0,0,.035);
    }

    .file-type-head {
        padding: .85rem 1rem;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, #fff 0%, #fafbfd 100%);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .8rem;
    }

    .file-type-title {
        margin: 0;
        font-size: .95rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: .55rem;
    }

        .file-type-title i {
            color: var(--primary);
        }

    .file-count {
        background: var(--primary-soft);
        color: var(--primary);
        border: 1px solid #f0cfcf;
        border-radius: 999px;
        padding: .3rem .65rem;
        font-size: .76rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .file-type-body {
        padding: .85rem;
        display: flex;
        flex-wrap: wrap;
        gap: .6rem;
    }

    .file-item {
        display: inline-flex;
        align-items: center;
        gap: .55rem;
        padding: .55rem .75rem;
        border: 1px solid #e7ecf2;
        border-radius: 999px;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        text-decoration: none;
        color: var(--text);
        transition: var(--transition);
        max-width: 100%;
    }

        .file-item:hover {
            border-color: var(--primary);
            background: var(--primary-soft);
            color: var(--primary);
            box-shadow: 0 6px 14px rgba(139,0,0,.08);
            transform: translateY(-1px);
        }

    .file-item-icon {
        width: 28px;
        height: 28px;
        border-radius: 9px;
        background: var(--primary-soft);
        color: var(--primary);
        display: grid;
        place-items: center;
        flex-shrink: 0;
        font-size: .86rem;
    }

    .file-item-main {
        min-width: 0;
        flex: 1;
    }

    .file-item-name {
        font-size: .8rem;
        font-weight: 800;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .file-item-meta {
        display: none;
    }

    .file-item-action {
        color: var(--primary);
        font-size: .9rem;
        flex-shrink: 0;
    }

    .empty-file-box {
        border: 1px dashed var(--border-strong);
        background: linear-gradient(180deg, #f8fafc 0%, #f4f7fb 100%);
        border-radius: 14px;
        padding: .8rem .9rem;
        color: var(--muted);
        font-size: .84rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: .55rem;
    }

    /* ============================================================
