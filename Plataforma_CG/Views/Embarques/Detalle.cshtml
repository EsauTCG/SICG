        border: 1px solid var(--border);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 4px 12px rgba(0,0,0,.03);
    }

    .quality-block-head {
        padding: .9rem 1rem;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, #fff 0%, #fafbfd 100%);
    }

