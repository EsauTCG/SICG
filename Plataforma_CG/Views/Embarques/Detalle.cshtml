    }

    .qr-actions {
        display: flex;
        justify-content: center;
        gap: .7rem;
        flex-wrap: wrap;
        margin-top: 1rem;
    }

    .tbtn {
        border: none;
        border-radius: 12px;
        padding: .72rem 1rem;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        transition: var(--transition);
    }

        .tbtn.primary {
            background: linear-gradient(to right, #8B0000, #5a0000);
            color: #fff;
        }

        .tbtn.primary2 {
            background: linear-gradient(to right, #8B0000, #5a0000);
