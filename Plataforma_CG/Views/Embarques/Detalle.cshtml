        margin: 0;
        font-size: .98rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .quality-block-title i {
            color: var(--primary);
        }

    .quality-block-body {
        padding: 1rem;
    }

    .quality-list-grid {
        display: grid;
        gap: .8rem;
    }

    .quality-item {
        background: var(--panel-soft);
        border: 1px solid #e7ecf2;
        border-radius: 14px;
        padding: .8rem .9rem;
    }

    .quality-item-label {
        color: var(--muted);
        font-size: .78rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .35px;
        margin-bottom: .18rem;
    }

    .quality-item-value {
        color: var(--text);
        font-size: .93rem;
        font-weight: 700;
        word-break: break-word;
    }

    .table-responsive-ui {
