        overflow-x: auto;
    }

    .table-soft {
        width: 100%;
        margin-bottom: 0;
        background: white;
        border-collapse: separate;
        border-spacing: 0;
    }

        .table-soft thead th {
            background: #f3f6f9;
            color: var(--text);
            font-weight: 800;
            white-space: nowrap;
            border-bottom: 1px solid var(--border);
            font-size: .87rem;
            padding: .85rem;
        }

        .table-soft td {
            vertical-align: middle;
            font-size: .92rem;
            padding: .82rem;
            border-bottom: 1px solid #edf1f5;
        }

        .table-soft tbody tr:hover {
