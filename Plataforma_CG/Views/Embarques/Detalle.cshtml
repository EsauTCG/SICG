@model Plataforma_CG.Models.Embarque

@{
    ViewData["Title"] = "Detalle del Embarque";
    Layout = "~/Views/Shared/_Layout2.cshtml";

    var totalOV = ((IEnumerable<dynamic>)ViewBag.OrdenesVenta)?.Count() ?? 0;
    var totalTR = ((IEnumerable<dynamic>)ViewBag.Transferencias)?.Count() ?? 0;

    var calidadAprobada = Model.CalidadAprobada == true;
    var documentacionAprobada = Model.DocumentacionAprobada == true;
    var documentacionCalidadAprobada = Model.DocumentacionCalidadAprobada == true;

    var validacionesCompletas = calidadAprobada
        && documentacionAprobada
        && documentacionCalidadAprobada;

    var archivos = Model.Archivos ?? new List<Plataforma_CG.Models.EmbarqueArchivo>();

    var fotosCalidad =
    ViewBag.FotosCalidad as List<Plataforma_CG.Models.Embarque.EmbarqueCalidadFoto>
    ?? new List<Plataforma_CG.Models.Embarque.EmbarqueCalidadFoto>();

    var embarqueConsecutivo = !string.IsNullOrWhiteSpace(Model.Consecutivo)
    ? Model.Consecutivo
    : $"EMB-{Model.Id}";

    var tieneNombreEmbarque = !string.IsNullOrWhiteSpace(Model.NombreEmbarque);

    var nombreEmbarqueTexto = tieneNombreEmbarque
        ? Model.NombreEmbarque.Trim()
        : "Sin nombre asignado";

    var nombreEmbarqueClase = tieneNombreEmbarque
        ? "detail-name-value"
        : "detail-name-value empty";

    // DOCUMENTACIÓN LOGÍSTICA
    var cartasPorte = archivos
        .Where(a => a.Tipo == "CARTA_PORTE")
        .OrderByDescending(a => a.FechaRegistro)
        .ToList();

    var tieneCartaPorte = cartasPorte.Any();

    var certificacionesLavado = archivos
        .Where(a => a.Tipo == "CERTIFICACION_LAVADO")
        .OrderByDescending(a => a.FechaRegistro)
        .ToList();

    var tieneCertificacionLavado = certificacionesLavado.Any();

    var certificacionesFumigacion = archivos
        .Where(a => a.Tipo == "CERTIFICACION_FUMIGACION")
        .OrderByDescending(a => a.FechaRegistro)
        .ToList();

    var tieneCertificacionFumigacion = certificacionesFumigacion.Any();

    string certificacionLavadoTexto = tieneCertificacionLavado
        ? "Cargada"
        : "No cargada";

    string certificacionLavadoClase = tieneCertificacionLavado
        ? "success"
        : "warning";

    string certificacionLavadoIcono = tieneCertificacionLavado
        ? "bi-check-circle"
        : "bi-info-circle";

    string certificacionFumigacionTexto = tieneCertificacionFumigacion
        ? "Cargada"
        : "No cargada";

    string certificacionFumigacionClase = tieneCertificacionFumigacion
        ? "success"
        : "warning";

    string certificacionFumigacionIcono = tieneCertificacionFumigacion
        ? "bi-check-circle"
        : "bi-info-circle";

    var cartaPorteSinDefinir = Model.RequiereCartaPorte == null;
    var cartaPorteRequerida = Model.RequiereCartaPorte == true;
    var cartaPorteNoAplica = Model.RequiereCartaPorte == false;

    var cartaPorteOk = cartaPorteNoAplica || (cartaPorteRequerida && tieneCartaPorte);

    string cartaPorteTexto =
        cartaPorteSinDefinir ? "Sin definir" :
        cartaPorteNoAplica ? "No aplica" :
        tieneCartaPorte ? "Requerida y cargada" :
        "Requerida pendiente";

    string cartaPorteClase =
        cartaPorteOk ? "success" :
        cartaPorteSinDefinir ? "warning" :
        "danger";

    string cartaPorteIcono =
        cartaPorteOk ? "bi-check-circle" :
        cartaPorteSinDefinir ? "bi-hourglass-split" :
        "bi-exclamation-triangle";

    // DOCUMENTACIÓN CALIDAD
    var tiposDocumentosCalidad = new[]
    {
    // =========================
    // EXPEDIENTE DE CALIDAD
    // =========================
    new { Grupo = "Expediente de calidad", Tipo = "CALIDAD_AVISO_MOVILIZACION", Label = "Aviso de movilización", Icon = "bi-truck" },
    new { Grupo = "Expediente de calidad", Tipo = "CALIDAD_HOJA_TRABAJO", Label = "Hoja de trabajo", Icon = "bi-clipboard-check" },
    new { Grupo = "Expediente de calidad", Tipo = "CALIDAD_CARTA_GARANTIA", Label = "Carta Garantía", Icon = "bi-patch-check" },
    new { Grupo = "Expediente de calidad", Tipo = "CALIDAD_CARTA_EEB", Label = "Carta Libre de EEB", Icon = "bi-file-earmark-medical" },
    new { Grupo = "Expediente de calidad", Tipo = "CALIDAD_LIBRE_CLEMBUTEROL", Label = "Carta libre de Clembuterol", Icon = "bi-shield-check" },
    new { Grupo = "Expediente de calidad", Tipo = "CALIDAD_LIBRE_RESIDUOS_TOXICOS", Label = "Carta libre de residuos tóxicos", Icon = "bi-shield-exclamation" },

    // NUEVOS
    new { Grupo = "Expediente de calidad", Tipo = "CALIDAD_MICROBIOLOGICOS", Label = "Microbiológicos", Icon = "bi-virus" },
    new { Grupo = "Expediente de calidad", Tipo = "CALIDAD_FICHA_TECNICA", Label = "Ficha Técnica", Icon = "bi-file-earmark-text" },
    new { Grupo = "Expediente de calidad", Tipo = "CALIDAD_FACTURA", Label = "Factura", Icon = "bi-receipt" },

    // =========================
    // POCO PRESENTES
    // =========================
    new { Grupo = "Documentos poco presentes", Tipo = "CALIDAD_ROMANEOS", Label = "Romaneos", Icon = "bi-box-seam" },
    new { Grupo = "Documentos poco presentes", Tipo = "CALIDAD_REMISION", Label = "Remisión", Icon = "bi-journal-text" }
};

    var documentosCalidadCargados = tiposDocumentosCalidad
        .Select(t => new
        {
            t.Grupo,
            t.Tipo,
            t.Label,
            t.Icon,
            Archivos = archivos
                .Where(a => a.Tipo == t.Tipo)
                .OrderByDescending(a => a.FechaRegistro)
                .ToList()
        })
        .Where(t => t.Archivos.Any())
        .ToList();

    var totalDocsLogistica =
      cartasPorte.Count +
      certificacionesLavado.Count +
      certificacionesFumigacion.Count;
    var totalDocsCalidad = documentosCalidadCargados.Sum(t => t.Archivos.Count);

    string estatusTexto =
        Model.Estatus == 7 && !validacionesCompletas ? "Pendiente de validaciones" :
        Model.Estatus == 1 ? "Pendiente de validaciones" :
        Model.Estatus == 7 ? "Liberado para QR" :
        Model.Estatus == 2 ? "En Ruta" :
        Model.Estatus == 3 ? "En Destino" :
        Model.Estatus == 4 ? "Retrasado" :
        Model.Estatus == 5 ? "Entregado" :
        Model.Estatus == 6 ? "Devuelto" : "Desconocido";

    string estatusClase =
        Model.Estatus == 7 && !validacionesCompletas ? "warning" :
        Model.Estatus == 1 ? "warning" :
        Model.Estatus == 7 ? "success" :
        Model.Estatus == 2 ? "route" :
        Model.Estatus == 3 ? "info" :
        Model.Estatus == 4 ? "danger" :
        Model.Estatus == 5 ? "primary" :
        Model.Estatus == 6 ? "secondary" : "neutral";
        
}

@functions {
    private string GetExtensionArchivo(string? ruta)
    {
        if (string.IsNullOrWhiteSpace(ruta))
            return "";

        return System.IO.Path.GetExtension(ruta).ToLowerInvariant();
    }

    private bool EsImagenArchivo(string? ruta)
    {
        var ext = GetExtensionArchivo(ruta);
        return ext == ".jpg"
            || ext == ".jpeg"
            || ext == ".png"
            || ext == ".webp"
            || ext == ".gif"
            || ext == ".bmp";
    }

    private bool EsPdfArchivo(string? ruta)
    {
        return GetExtensionArchivo(ruta) == ".pdf";
    }

    private bool EsExcelArchivo(string? ruta)
    {
        var ext = GetExtensionArchivo(ruta);
        return ext == ".xls"
            || ext == ".xlsx"
            || ext == ".csv";
    }

    private bool EsWordArchivo(string? ruta)
    {
        var ext = GetExtensionArchivo(ruta);
        return ext == ".doc"
            || ext == ".docx";
    }

    private string GetIconoArchivo(string? ruta)
    {
        if (EsImagenArchivo(ruta)) return "bi-file-earmark-image";
        if (EsPdfArchivo(ruta)) return "bi-file-earmark-pdf";
        if (EsExcelArchivo(ruta)) return "bi-file-earmark-excel";
        if (EsWordArchivo(ruta)) return "bi-file-earmark-word";

        return "bi-file-earmark";
    }

    private string GetTipoArchivoTexto(string? ruta)
    {
        if (EsImagenArchivo(ruta)) return "Imagen";
        if (EsPdfArchivo(ruta)) return "PDF";
        if (EsExcelArchivo(ruta)) return "Excel / CSV";
        if (EsWordArchivo(ruta)) return "Word";

        var ext = GetExtensionArchivo(ruta);
        return string.IsNullOrWhiteSpace(ext) ? "Archivo" : ext.Replace(".", "").ToUpperInvariant();
    }
}

