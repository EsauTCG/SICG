    /* ============================================================
       AGRUPACIÓN VISUAL - DOCUMENTOS CARGADOS
    ============================================================ */

    .file-section {
        border: 1px solid var(--border);
        border-radius: 20px;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        overflow: hidden;
        box-shadow: 0 6px 16px rgba(15, 23, 42, 0.045);
    }

        .file-section + .file-section {
            margin-top: 1rem;
        }

    .file-section-head {
        padding: .95rem 1.1rem;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, #f9fafb 0%, #f3f6f9 100%);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .75rem;
        flex-wrap: wrap;
    }

    .file-section-title {
        margin: 0;
        display: flex;
        align-items: center;
        gap: .6rem;
        font-size: .98rem;
        font-weight: 900;
        color: var(--text);
    }

        .file-section-title i {
            color: var(--primary);
            font-size: 1.05rem;
        }

    .file-section-sub {
        margin-top: .18rem;
        color: var(--muted);
        font-size: .82rem;
        font-weight: 600;
    }

    .file-section-count {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .42rem .78rem;
        border-radius: 999px;
        background: var(--primary-soft);
        color: var(--primary);
        border: 1px solid #f0cfcf;
        font-size: .78rem;
        font-weight: 900;
        white-space: nowrap;
    }

    .file-section-body {
        padding: .95rem;
        display: grid;
        grid-template-columns: 1fr;
        gap: .9rem;
    }

    /* Opcional: separa visualmente logística y calidad con tonos muy suaves */
    .file-section-logistica .file-section-title i {
        color: var(--info);
    }

    .file-section-calidad .file-section-title i {
        color: var(--success);
    }

    .file-section-logistica .file-section-count {
        background: var(--info-soft);
        color: var(--info);
        border-color: #c9ddff;
    }

    .file-section-calidad .file-section-count {
        background: var(--success-soft);
        color: var(--success);
        border-color: #bfe4cd;
    }

    /* Dark mode para las nuevas secciones */
    body[data-theme="dark"] .file-section {
        background: #111827 !important;
        border-color: rgba(255,255,255,0.12) !important;
        box-shadow: var(--shadow-sm) !important;
    }

    body[data-theme="dark"] .file-section-head {
        background: linear-gradient(180deg, #1f2937 0%, #172033 100%) !important;
        border-bottom-color: rgba(255,255,255,0.12) !important;
    }

    body[data-theme="dark"] .file-section-title {
        color: #f9fafb !important;
    }

        body[data-theme="dark"] .file-section-title i {
            color: #fca5a5 !important;
        }

    body[data-theme="dark"] .file-section-sub {
        color: #cbd5e1 !important;
    }

    body[data-theme="dark"] .file-section-body {
        background: #111827 !important;
    }

    body[data-theme="dark"] .file-section-count {
        background: rgba(127,29,29,0.24) !important;
        color: #fca5a5 !important;
        border-color: rgba(248,113,113,0.35) !important;
    }

    body[data-theme="dark"] .file-section-logistica .file-section-count {
        background: rgba(30,64,175,0.24) !important;
        color: #bfdbfe !important;
        border-color: rgba(96,165,250,0.45) !important;
    }

    body[data-theme="dark"] .file-section-calidad .file-section-count {
        background: rgba(22,101,52,0.26) !important;
        color: #bbf7d0 !important;
        border-color: rgba(74,222,128,0.40) !important;
    }

    body[data-theme="dark"] .file-section-logistica .file-section-title i {
        color: #93c5fd !important;
    }

    body[data-theme="dark"] .file-section-calidad .file-section-title i {
        color: #86efac !important;
    }

    .btn-remove-doc {
        border: 1px solid var(--danger);
        background: var(--danger-soft);
        color: var(--danger);
        border-radius: 999px;
        padding: .45rem .75rem;
        font-size: .82rem;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        transition: var(--transition);
    }

        .btn-remove-doc:hover {
            background: var(--danger);
            color: #fff;
            transform: translateY(-1px);
        }

    body[data-theme="dark"] .btn-remove-doc {
        border-color: rgba(248,113,113,0.55);
        background: rgba(153,27,27,0.22);
        color: #fca5a5;
    }

        body[data-theme="dark"] .btn-remove-doc:hover {
            background: #dc2626;
            color: #fff;
        }

    .btn-top-disabled {
        background: rgba(255,255,255,.16);
        color: rgba(255,255,255,.85);
        border: 1px solid rgba(255,255,255,.20);
        cursor: not-allowed;
        opacity: .95;
    }

        .btn-top-disabled:hover {
            color: rgba(255,255,255,.85);
            transform: none;
        }

    body[data-theme="dark"] .btn-top-disabled {
        background: rgba(15,23,42,.55) !important;
        color: #cbd5e1 !important;
        border-color: rgba(255,255,255,.16) !important;
    }

</style>

<div class="detail-wrap">

    <div class="detail-header">
        <div class="detail-header-top">
            <div class="detail-header-left">
                <div class="header-icon">
                    <i class="bi bi-clipboard-data"></i>
                </div>
                <div>
                    <h1 class="detail-title">Detalle del Embarque #@Model.Consecutivo</h1>
                    <p class="detail-sub">
                        Consulta el estado general del embarque, su validación de calidad, documentos relacionados y el código QR.
                    </p>
                </div>
            </div>

            <div class="header-actions">
                <span class="header-chip">
                    <i class="bi bi-calendar3"></i>
                    @Model.FechaCreacion.ToString("yyyy-MM-dd")
                </span>

                @if (User.IsInRole("Administracion de Ventas") || User.IsInRole("Administrador"))
                {
                    @if (Model.FechaSalida == null && Model.QR == null && (Model.Estatus == 1 || Model.Estatus == 7))
                    {
                        <a class="btn-top btn-top-light" href="@Url.Action("EditarEmbarques", "Embarques", new { id = Model.Id })">
                            <i class="bi bi-pencil-square"></i> Editar Embarque
                        </a>
                    }
                    else
                    {
                        string motivoBloqueoEditar =
                        Model.QR != null ? "No se pueden agregar más documentos porque el QR ya fue generado." :
                        Model.FechaSalida != null ? "No se pueden agregar más documentos porque el embarque ya tiene salida registrada." :
                        !(Model.Estatus == 1 || Model.Estatus == 7) ? "No se pueden agregar más documentos por el estatus actual del embarque." :
                        "No se pueden agregar más documentos.";

                        <span class="btn-top btn-top-disabled"
                              title="@motivoBloqueoEditar">
                            <i class="bi bi-lock-fill"></i>
                            Edición bloqueada
                        </span>
                    }
                }

                <a class="btn-top btn-top-light" href="@Url.Action("Embarque", "Embarques")">
                    <i class="bi bi-arrow-left-circle"></i> Volver
                </a>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    }

    <div class="summary-grid">
        <div class="summary-card">
            <div class="summary-icon @(Model.Estatus == 7 && validacionesCompletas ? "success" : Model.Estatus == 7 && !validacionesCompletas ? "warning" : "primary")">
                <i class="bi @(Model.Estatus == 7 && validacionesCompletas ? "bi-qr-code" : Model.Estatus == 7 && !validacionesCompletas ? "bi-hourglass-split" : "bi-truck")"></i>
            </div>
            <div>
                <div class="summary-label">Estatus</div>
                <div class="summary-value">
                    <span class="status-pill @estatusClase">@estatusTexto</span>
                </div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon info">
                <i class="bi bi-box-seam"></i>
            </div>
            <div>
                <div class="summary-label">Órdenes</div>
                <div class="summary-value">@totalOV</div>
                <div class="summary-sub">Documentos comerciales</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon warning">
                <i class="bi bi-arrow-left-right"></i>
            </div>
            <div>
                <div class="summary-label">Transferencias</div>
                <div class="summary-value">@totalTR</div>
                <div class="summary-sub">Movimientos asociados</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon @(validacionesCompletas ? "success" : "warning")">
                <i class="bi @(validacionesCompletas ? "bi-shield-check" : "bi-shield-exclamation")"></i>
            </div>
            <div>
                <div class="summary-label">Validaciones</div>
                <div class="summary-value">
                    @(validacionesCompletas ? "Completas" : "Pendientes")
                </div>
                <div class="summary-sub">
                    Calidad: @(calidadAprobada ? "OK" : "Pendiente") ·
                    Docs Logística: @(documentacionAprobada ? "OK" : "Pendiente") ·
                    Docs Calidad: @(documentacionCalidadAprobada ? "OK" : "Pendiente")
                </div>
            </div>
        </div>
    </div>

    <div class="content-grid">
        <div class="card-ui">
            <div class="card-head">
                <div>
                    <h5 class="card-title">
                        <i class="bi bi-info-circle"></i>
                        Información General
                    </h5>
                    <div class="card-sub">Datos base del embarque</div>
                </div>
            </div>

            <div class="card-body">
                <table class="info-table">
                    <tr>
                        <th>Fecha creación</th>
                        <td>@Model.FechaCreacion</td>
                    </tr>
                    <tr>
                        <th>Estatus</th>
                        <td>
                            <span class="status-pill @estatusClase">@estatusTexto</span>
                        </td>
                    </tr>
                    <tr>
                        <th>Observaciones</th>
                        <td>@(!string.IsNullOrWhiteSpace(Model.Observaciones) ? Model.Observaciones : "-")</td>
                    </tr>
                    <tr>
                        <th>Calidad</th>
                        <td>@(calidadAprobada ? "Aprobada" : "Pendiente")</td>
                    </tr>
                    <tr>
                        <th>Documentación logística</th>
                        <td>
                            <span class="status-pill @(documentacionAprobada ? "success" : "warning")">
                                <i class="bi @(documentacionAprobada ? "bi-check-circle" : "bi-hourglass-split")"></i>
                                @(documentacionAprobada ? "Aprobada" : "Pendiente")
                            </span>
                        </td>
                    </tr>

                    <tr>
                        <th>Carta Porte</th>
                        <td>
                            <span class="status-pill @cartaPorteClase">
                                <i class="bi @cartaPorteIcono"></i>
                                @cartaPorteTexto
                            </span>

                            @if (cartaPorteNoAplica)
                            {
                                <div class="summary-sub mt-2">
                                    Logística indicó que este embarque no requiere Carta Porte.
                                </div>
                            }
                            else if (cartaPorteRequerida && !tieneCartaPorte)
                            {
                                <div class="summary-sub mt-2">
                                    Logística indicó que sí aplica, pero aún no hay archivo cargado.
                                </div>
                            }
                        </td>
                    </tr>

                    <tr>
                        <th>Documentación calidad</th>
                        <td>
                            <span class="status-pill @(documentacionCalidadAprobada ? "success" : "warning")">
                                <i class="bi @(documentacionCalidadAprobada ? "bi-check-circle" : "bi-hourglass-split")"></i>
                                @(documentacionCalidadAprobada ? "Aprobada" : "Pendiente")
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <th>Fecha validación calidad</th>
                        <td>@(Model.FechaValidacionCalidad?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                    </tr>
                    <tr>
                        <th>Usuario validó calidad</th>
                        <td>@(string.IsNullOrEmpty(Model.UsuarioValidaCalidad) ? "-" : Model.UsuarioValidaCalidad)</td>
                    </tr>
                    <tr>
                        <th>Fecha validación documentación</th>
                        <td>@(Model.FechaValidacionDocumentacion?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                    </tr>
                    <tr>
                        <th>Fecha validación documentación calidad</th>
                        <td>@(Model.FechaValidacionDocumentacionCalidad?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                    </tr>
                    <tr>
                        <th>Usuario validó documentación calidad</th>
                        <td>@(string.IsNullOrEmpty(Model.UsuarioValidaDocumentacionCalidad) ? "-" : Model.UsuarioValidaDocumentacionCalidad)</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="card-ui">
            <div class="card-head">
                <div>
                    <h5 class="card-title">
                        <i class="bi bi-folder2-open"></i>
                        Documentos cargados
                    </h5>
                    <div class="card-sub">
                        Expediente del embarque ·
                        Carta Porte: @totalDocsLogistica archivo(s) ·
                        Documentos de calidad: @totalDocsCalidad archivo(s)
                    </div>
                </div>
            </div>

            <div class="card-body">
                <div class="files-grid">

                    <!-- =========================================================
                         DOCUMENTACIÓN LOGÍSTICA
                    ========================================================== -->
                    <div class="file-section file-section-logistica">
                        <div class="file-section-head">
                            <div>
                                <h6 class="file-section-title">
                                    <i class="bi bi-truck"></i>
                                    Documentación logística
                                </h6>
                                <div class="file-section-sub">
                                    Logística solo controla Carta Porte y define si aplica o no aplica para este embarque.
                                </div>
                            </div>

                            <span class="file-section-count">
                                <i class="bi bi-files"></i>
                                @totalDocsLogistica archivo(s)
                            </span>
                        </div>

                        <div class="file-section-body">

                            <div class="file-type-card">
                                <div class="file-type-head">
                                    <h6 class="file-type-title">
                                        <i class="bi bi-file-earmark-text"></i>
                                        Carta Porte
                                    </h6>

                                    <span class="status-pill @cartaPorteClase">
                                        <i class="bi @cartaPorteIcono"></i>
                                        @cartaPorteTexto
                                    </span>
                                </div>

                                <div class="file-type-body">

                                    @if (cartaPorteNoAplica)
                                    {
                                        <div class="empty-file-box">
                                            <i class="bi bi-info-circle"></i>
                                            Carta Porte marcada como No aplica por logística.
                                        </div>
                                    }
                                    else if (cartasPorte.Any())
                                    {
                                        @foreach (var archivo in cartasPorte.OrderByDescending(x => x.FechaRegistro))
                                        {
                                            <a href="@archivo.RutaArchivo" target="_blank" class="file-item">
                                                <div class="file-item-icon">
                                                    <i class="bi bi-file-earmark-text"></i>
                                                </div>

                                                <div class="file-item-main">
                                                    <div class="file-item-name">Carta Porte #@archivo.Id</div>
                                                    <div class="file-item-meta">
                                                        @(archivo.FechaRegistro.ToString("yyyy-MM-dd HH:mm"))
                                                    </div>
                                                </div>

                                                <div class="file-item-action">
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </div>
                                            </a>
                                        }
                                    }
                                    else if (cartaPorteRequerida)
                                    {
                                        <div class="empty-file-box">
                                            <i class="bi bi-exclamation-triangle"></i>
                                            Carta Porte requerida, pero aún no se ha cargado archivo.
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="empty-file-box">
                                            <i class="bi bi-hourglass-split"></i>
                                            Logística aún no define si Carta Porte aplica o no aplica.
                                        </div>
                                    }

                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- =========================================================
                         DOCUMENTACIÓN DE CALIDAD
                    ========================================================== -->
                    <div class="file-section file-section-calidad">
                        <div class="file-section-head">
                            <div>
                                <h6 class="file-section-title">
                                    <i class="bi bi-shield-check"></i>
                                    Documentación de calidad
                                </h6>
                                <div class="file-section-sub">
                                    Certificados, cartas, avisos y documentos de control solicitados por calidad.
                                </div>
                            </div>

                            <span class="file-section-count">
                                <i class="bi bi-files"></i>
                                @totalDocsCalidad archivo(s)
                            </span>
                        </div>

                        <div class="file-section-body">

                            <div class="file-type-card">
                                <div class="file-type-head">
                                    <h6 class="file-type-title">
                                        <i class="bi bi-patch-check"></i>
                                        Calidad - Carta Garantías
                                    </h6>
                                    <span class="file-count">@calidadCartasGarantia.Count archivo(s)</span>
                                </div>

                                <div class="file-type-body">
                                    @if (calidadCartasGarantia.Any())
                                    {
                                        @foreach (var archivo in calidadCartasGarantia.OrderByDescending(x => x.FechaRegistro))
                                        {
                                            <a href="@archivo.RutaArchivo" target="_blank" class="file-item">
                                                <div class="file-item-icon">
                                                    <i class="bi bi-patch-check"></i>
                                                </div>

                                                <div class="file-item-main">
                                                    <div class="file-item-name">Carta Garantías #@archivo.Id</div>
                                                </div>

                                                <div class="file-item-action">
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </div>
                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        <div class="empty-file-box">
                                            <i class="bi bi-inbox"></i>
                                            Sin archivos cargados.
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="file-type-card">
                                <div class="file-type-head">
                                    <h6 class="file-type-title">
                                        <i class="bi bi-shield-check"></i>
                                        Calidad - Libre Clembuterol
                                    </h6>
                                    <span class="file-count">@calidadLibreClembuterol.Count archivo(s)</span>
                                </div>

                                <div class="file-type-body">
                                    @if (calidadLibreClembuterol.Any())
                                    {
                                        @foreach (var archivo in calidadLibreClembuterol.OrderByDescending(x => x.FechaRegistro))
                                        {
                                            <a href="@archivo.RutaArchivo" target="_blank" class="file-item">
                                                <div class="file-item-icon">
                                                    <i class="bi bi-shield-check"></i>
                                                </div>

                                                <div class="file-item-main">
                                                    <div class="file-item-name">Libre Clembuterol #@archivo.Id</div>
                                                </div>

                                                <div class="file-item-action">
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </div>
                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        <div class="empty-file-box">
                                            <i class="bi bi-inbox"></i>
                                            Sin archivos cargados.
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="file-type-card">
                                <div class="file-type-head">
                                    <h6 class="file-type-title">
                                        <i class="bi bi-shield-exclamation"></i>
                                        Calidad - Libre residuos tóxicos
                                    </h6>
                                    <span class="file-count">@calidadLibreResiduosToxicos.Count archivo(s)</span>
                                </div>

                                <div class="file-type-body">
                                    @if (calidadLibreResiduosToxicos.Any())
                                    {
                                        @foreach (var archivo in calidadLibreResiduosToxicos.OrderByDescending(x => x.FechaRegistro))
                                        {
                                            <a href="@archivo.RutaArchivo" target="_blank" class="file-item">
                                                <div class="file-item-icon">
                                                    <i class="bi bi-shield-exclamation"></i>
                                                </div>

                                                <div class="file-item-main">
                                                    <div class="file-item-name">Libre residuos tóxicos #@archivo.Id</div>
                                                </div>

                                                <div class="file-item-action">
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </div>
                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        <div class="empty-file-box">
                                            <i class="bi bi-inbox"></i>
                                            Sin archivos cargados.
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="file-type-card">
                                <div class="file-type-head">
                                    <h6 class="file-type-title">
                                        <i class="bi bi-file-earmark-medical"></i>
                                        Calidad - Carta EEB
                                    </h6>
                                    <span class="file-count">@calidadCartasEEB.Count archivo(s)</span>
                                </div>

                                <div class="file-type-body">
                                    @if (calidadCartasEEB.Any())
                                    {
                                        @foreach (var archivo in calidadCartasEEB.OrderByDescending(x => x.FechaRegistro))
                                        {
                                            <a href="@archivo.RutaArchivo" target="_blank" class="file-item">
                                                <div class="file-item-icon">
                                                    <i class="bi bi-file-earmark-medical"></i>
                                                </div>

                                                <div class="file-item-main">
                                                    <div class="file-item-name">Carta EEB #@archivo.Id</div>
                                                </div>

                                                <div class="file-item-action">
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </div>
                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        <div class="empty-file-box">
                                            <i class="bi bi-inbox"></i>
                                            Sin archivos cargados.
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="file-type-card">
                                <div class="file-type-head">
                                    <h6 class="file-type-title">
                                        <i class="bi bi-truck"></i>
                                        Calidad - Aviso de movilización
                                    </h6>
                                    <span class="file-count">@calidadAvisosMovilizacion.Count archivo(s)</span>
                                </div>

                                <div class="file-type-body">
                                    @if (calidadAvisosMovilizacion.Any())
                                    {
                                        @foreach (var archivo in calidadAvisosMovilizacion.OrderByDescending(x => x.FechaRegistro))
                                        {
                                            <a href="@archivo.RutaArchivo" target="_blank" class="file-item">
                                                <div class="file-item-icon">
                                                    <i class="bi bi-truck"></i>
                                                </div>

                                                <div class="file-item-main">
                                                    <div class="file-item-name">Aviso movilización #@archivo.Id</div>
                                                </div>

                                                <div class="file-item-action">
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </div>
                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        <div class="empty-file-box">
                                            <i class="bi bi-inbox"></i>
                                            Sin archivos cargados.
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="file-type-card">
                                <div class="file-type-head">
                                    <h6 class="file-type-title">
                                        <i class="bi bi-clipboard-check"></i>
                                        Calidad - Hoja de trabajo
                                    </h6>
                                    <span class="file-count">@calidadHojasTrabajo.Count archivo(s)</span>
                                </div>

                                <div class="file-type-body">
                                    @if (calidadHojasTrabajo.Any())
                                    {
                                        @foreach (var archivo in calidadHojasTrabajo.OrderByDescending(x => x.FechaRegistro))
                                        {
                                            <a href="@archivo.RutaArchivo" target="_blank" class="file-item">
                                                <div class="file-item-icon">
                                                    <i class="bi bi-clipboard-check"></i>
                                                </div>

                                                <div class="file-item-main">
                                                    <div class="file-item-name">Hoja de trabajo #@archivo.Id</div>
                                                </div>

                                                <div class="file-item-action">
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </div>
                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        <div class="empty-file-box">
                                            <i class="bi bi-inbox"></i>
                                            Sin archivos cargados.
                                        </div>
                                    }
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    @if (Model.QR != null)
    {
        <div class="card-ui mb-3">
            <div class="card-head">
                <div>
                    <h5 class="card-title">
                        <i class="bi bi-qr-code"></i>
                        Código QR del Embarque
                    </h5>
                    <div class="card-sub">Consulta, descarga o imprime el QR generado</div>
                </div>
            </div>

            <div class="card-body">
                <div class="qr-box">
                    <img src="@Model.QR.UrlQR" id="imgQR" />

                    <div class="qr-meta">
                        <div class="mini-box token-box">
                            <div class="mini-box-top">
                                <div class="mini-box-label">Token</div>

                                <button type="button"
                                        class="copy-token-btn"
                                        onclick="copiarToken('@Model.QR.Token')"
                                        title="Copiar token">
                                    <i class="bi bi-clipboard"></i>
                                </button>
                            </div>

                            <div class="mini-box-value token-value">@Model.QR.Token</div>
                        </div>

                        <div class="mini-box">
                            <div class="mini-box-label">Generado</div>
                            <div class="mini-box-value">@Model.QR.FechaGeneracion</div>
                        </div>
                    </div>

                    <div class="qr-actions">
                        <button class="tbtn primary" onclick="descargarQR(@Model.Id)">
                            <i class="bi bi-download"></i> Descargar QR
                        </button>

                        <button class="tbtn btn btn-outline-secondary" onclick="imprimirQR('@Model.QR.UrlQR', '@Model.QR.Token', '@Model.QR.FechaGeneracion', @Model.Id, '@Model.Consecutivo')">
                            <i class="bi bi-printer"></i> Imprimir QR
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @if (validacionesCompletas)
        {
            <div class="card-ui mb-3">
                <div class="card-body text-center">
                    <a asp-action="GenerarQR" asp-route-id="@Model.Id" class="tbtn primary2">
                        <i class="bi bi-qr-code"></i> Generar QR
                    </a>

                    <div class="mt-3 text-success fw-bold">
                        <i class="bi bi-check-circle"></i>
                        El embarque ya cuenta con las 3 validaciones requeridas.
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                <div class="fw-bold mb-2">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i>
                    El QR no se puede generar todavía.
                </div>

                <div class="mb-2">
                    Para generar el QR deben estar aprobadas las tres validaciones:
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <span class="status-pill @(calidadAprobada ? "success" : "warning")">
                        <i class="bi @(calidadAprobada ? "bi-check-circle" : "bi-hourglass-split")"></i>
                        Calidad @(calidadAprobada ? "OK" : "pendiente")
                    </span>

                    <span class="status-pill @(documentacionAprobada ? "success" : "warning")">
                        <i class="bi @(documentacionAprobada ? "bi-check-circle" : "bi-hourglass-split")"></i>
                        Documentación logística @(documentacionAprobada ? "OK" : "pendiente")
                    </span>

                    <span class="status-pill @(documentacionCalidadAprobada ? "success" : "warning")">
                        <i class="bi @(documentacionCalidadAprobada ? "bi-check-circle" : "bi-hourglass-split")"></i>
                        Documentación calidad @(documentacionCalidadAprobada ? "OK" : "pendiente")
                    </span>
                </div>
            </div>
        }
    }

    <div class="card-ui mb-3">
        <div class="card-head">
            <div>
                <h5 class="card-title">
                    <i class="bi bi-shield-check"></i>
                    Validación de Calidad
                </h5>
                <div class="card-sub">Resumen visual de la inspección y liberación del embarque</div>
            </div>
            @if (Model.FechaValidacionCalidad != null)
            {
                <span class="badge-counter">Validado por @Model.UsuarioValidaCalidad</span>
            }
        </div>

        <div class="card-body">
            @if (Model.FechaValidacionCalidad != null)
            {
                <div class="quality-overview">
                    <div class="quality-chip-box">
                        <div class="quality-chip-label">Tipo de salida</div>
                        <div class="quality-chip-value">@(!string.IsNullOrWhiteSpace(Model.SalidaTipo) ? Model.SalidaTipo : "-")</div>
                    </div>

                    <div class="quality-chip-box">
                        <div class="quality-chip-label">Estado unidad</div>
                        <div class="quality-chip-value">@(!string.IsNullOrWhiteSpace(Model.EstadoUnidadCalidad) ? Model.EstadoUnidadCalidad : "-")</div>
                    </div>

                    <div class="quality-chip-box">
                        <div class="quality-chip-label">Estado productos</div>
                        <div class="quality-chip-value">@(!string.IsNullOrWhiteSpace(Model.EstadoProductosCalidad) ? Model.EstadoProductosCalidad : "-")</div>
                    </div>
                </div>

                <div class="quality-sections">
                    <div class="quality-block">
                        <div class="quality-block-head">
                            <h6 class="quality-block-title">
                                <i class="bi bi-truck"></i>
                                Transporte y unidad
                            </h6>
                        </div>
                        <div class="quality-block-body">
                            <div class="quality-list-grid">
                                <div class="quality-item">
                                    <div class="quality-item-label">Placa transporte</div>
                                    <div class="quality-item-value">@(!string.IsNullOrWhiteSpace(Model.PlacaTransporte) ? Model.PlacaTransporte : "-")</div>
                                </div>
                                <div class="quality-item">
                                    <div class="quality-item-label">Temperatura de programación</div>
                                    <div class="quality-item-value">@(Model.TemperaturaProgramacion != null ? $"{Model.TemperaturaProgramacion} °C" : "-")</div>
                                </div>
                                <div class="quality-item">
                                    <div class="quality-item-label">Temperatura unidad inicio</div>
                                    <div class="quality-item-value">@(Model.TemperaturaUnidadInicio != null ? $"{Model.TemperaturaUnidadInicio} °C" : "-")</div>
                                </div>
                                <div class="quality-item">
                                    <div class="quality-item-label">Temperatura unidad término</div>
                                    <div class="quality-item-value">@(Model.TemperaturaUnidadTermino != null ? $"{Model.TemperaturaUnidadTermino} °C" : "-")</div>
                                </div>
                                <div class="quality-item">
                                    <div class="quality-item-label">Temperatura unidad</div>
                                    <div class="quality-item-value">@(Model.TemperaturaUnidadCalidad != null ? $"{Model.TemperaturaUnidadCalidad} °C" : "-")</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="quality-block">
                        <div class="quality-block-head">
                            <h6 class="quality-block-title">
                                <i class="bi bi-clock-history"></i>
                                Tiempos de embarque
                            </h6>
                        </div>
                        <div class="quality-block-body">
                            <div class="quality-list-grid">
                                <div class="quality-item">
                                    <div class="quality-item-label">Hora inicio embarque</div>
                                    <div class="quality-item-value">
                                        @(Model.HoraInicioEmbarque?.ToString("yyyy-MM-dd HH:mm") ?? "-")
                                    </div>
                                </div>
                                <div class="quality-item">
                                    <div class="quality-item-label">Hora término embarque</div>
                                    <div class="quality-item-value">
                                        @(Model.HoraTerminoEmbarque?.ToString("yyyy-MM-dd HH:mm") ?? "-")
                                    </div>
                                </div>
                                <div class="quality-item">
                                    <div class="quality-item-label">Fecha validación</div>
                                    <div class="quality-item-value">
                                        @(Model.FechaValidacionCalidad?.ToString("yyyy-MM-dd HH:mm") ?? "-")
                                    </div>
                                </div>
                                <div class="quality-item">
                                    <div class="quality-item-label">Usuario valida</div>
                                    <div class="quality-item-value">@(!string.IsNullOrWhiteSpace(Model.UsuarioValidaCalidad) ? Model.UsuarioValidaCalidad : "-")</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="quality-block">
                        <div class="quality-block-head">
                            <h6 class="quality-block-title">
                                <i class="bi bi-tools"></i>
                                Equipos de medición
                            </h6>
                        </div>
                        <div class="quality-block-body">
                            <div class="quality-list-grid">
                                <div class="quality-item">
                                    <div class="quality-item-label">Código termograficador</div>
                                    <div class="quality-item-value">@(!string.IsNullOrWhiteSpace(Model.CodigoTermograficador) ? Model.CodigoTermograficador : "-")</div>
                                </div>
                                <div class="quality-item">
                                    <div class="quality-item-label">N° termómetro utilizado</div>
                                    <div class="quality-item-value">@(!string.IsNullOrWhiteSpace(Model.NumeroTermometro) ? Model.NumeroTermometro : "-")</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="quality-block">
                        <div class="quality-block-head">
                            <h6 class="quality-block-title">
                                <i class="bi bi-clipboard-check"></i>
                                Observaciones de calidad
                            </h6>
                        </div>
                        <div class="quality-block-body">
                            <div class="quality-list-grid">
                                <div class="quality-item">
                                    <div class="quality-item-label">Acciones correctivas</div>
                                    <div class="quality-item-value">@(!string.IsNullOrWhiteSpace(Model.AccionesCorrectivasCalidad) ? Model.AccionesCorrectivasCalidad : "-")</div>
                                </div>
                                <div class="quality-item">
                                    <div class="quality-item-label">Observaciones calidad</div>
                                    <div class="quality-item-value">@(!string.IsNullOrWhiteSpace(Model.ObservacionesCalidad) ? Model.ObservacionesCalidad : "-")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="empty-quality">
                    Este embarque aún no cuenta con validación de calidad registrada.
                </div>
            }
        </div>
    </div>

    <div class="section-stack">
        <div class="card-ui">
            <div class="card-head">
                <div>
                    <h5 class="card-title">
                        <i class="bi bi-list-check"></i>
                        Resumen de Documentos
                    </h5>
                    <div class="card-sub">Totales de documentos incluidos en el embarque</div>
                </div>
            </div>
            <div class="card-body">
                <p class="mb-0">
                    <span class="badge bg-primary">Órdenes: @totalOV</span>
                    <span class="badge bg-warning text-dark">Transferencias: @totalTR</span>
                </p>
            </div>
        </div>

        @if (ViewBag.OrdenesVenta != null && ((IEnumerable<dynamic>)ViewBag.OrdenesVenta).Any())
        {
            <div class="card-ui">
                <div class="card-head">
                    <div>
                        <h5 class="card-title">
                            <i class="bi bi-box-seam"></i>
                            Órdenes Incluidas
                        </h5>
                        <div class="card-sub">Documentos de venta ligados al embarque</div>
                    </div>
                    <span class="badge-counter">@totalOV registro(s)</span>
                </div>

                <div class="card-body">
                    <div class="table-responsive-ui">
                        <table class="table-soft">
                            <thead>
                                <tr>
                                    <th>Consecutivo</th>
                                    <th>Cliente</th>
                                    <th>Ruta</th>
                                    <th>Fecha Entrega</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ov in ViewBag.OrdenesVenta)
                                {
                                    <tr>
                                        <td>@ov.Consecutivo</td>
                                        <td>@ov.NombreCliente</td>
                                        <td>@ov.Ruta</td>
                                        <td>
                                            @(ov.FechaEntrega != null
                                                                                ? Convert.ToDateTime(ov.FechaEntrega).ToString("yyyy-MM-dd")
                                                                                : "-")
                                </td>
                                <td class="text-center">
                                    @if (Model.FechaSalida == null && Model.QR == null && (Model.Estatus == 1 || Model.Estatus == 7))
                                            {
                                                <form asp-action="QuitarDocumentoEmbarque"
                                                      asp-controller="Embarques"
                                                      method="post"
                                                      class="d-inline"
                                                      onsubmit="return confirm('¿Seguro que deseas quitar esta orden del embarque? La orden regresará a estatus autorizado.');">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="embarqueId" value="@Model.Id" />
                                                    <input type="hidden" name="documentoId" value="@ov.Id" />
                                                    <input type="hidden" name="tipoDocumento" value="OV" />

                                                    @if (User.IsInRole("Administracion de Ventas") || User.IsInRole("Administrador"))
                                                    {
                                                        <button type="submit" class="btn-remove-doc">
                                                            <i class="bi bi-trash3"></i>
                                                            Quitar
                                                        </button>
                                                    }

                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Bloqueado</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (ViewBag.Transferencias != null && ((IEnumerable<dynamic>)ViewBag.Transferencias).Any())
        {
            <div class="card-ui">
                <div class="card-head">
                    <div>
                        <h5 class="card-title">
                            <i class="bi bi-arrow-left-right"></i>
                            Transferencias Incluidas
                        </h5>
                        <div class="card-sub">Movimientos internos relacionados al embarque</div>
                    </div>
                    <span class="badge-counter">@totalTR registro(s)</span>
                </div>

                <div class="card-body">
                    <div class="table-responsive-ui">
                        <table class="table-soft">
                            <thead>
                                <tr>
                                    <th>Consecutivo</th>
                                    <th>Sucursal</th>
                                    <th>Fecha Solicitud</th>
                                    <th>Usuario Solicita</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tr in ViewBag.Transferencias)
                                {
                                    <tr>
                                        <td>@tr.Consecutivo</td>
                                        <td>@tr.Sucursal</td>
                                        <td>
                                            @(tr.FechaSolicitud != null
                                                                                ? Convert.ToDateTime(tr.FechaSolicitud).ToString("yyyy-MM-dd")
                                                                                : "-")
                                </td>
                                <td>@tr.UsuarioSolicita</td>
                                <td class="text-center">
                                    @if (Model.FechaSalida == null && Model.QR == null && (Model.Estatus == 1 || Model.Estatus == 7))
                                            {
                                                <form asp-action="QuitarDocumentoEmbarque"
                                                      asp-controller="Embarques"
                                                      method="post"
                                                      class="d-inline"
                                                      onsubmit="return confirm('¿Seguro que deseas quitar esta transferencia del embarque? La transferencia regresará a estatus autorizado.');">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="embarqueId" value="@Model.Id" />
                                                    <input type="hidden" name="documentoId" value="@tr.Id" />
                                                    <input type="hidden" name="tipoDocumento" value="TRANSFERENCIA" />

                                                    @if (User.IsInRole("Administracion de Ventas") || User.IsInRole("Administrador"))
                                                    {
                                                        <button type="submit" class="btn-remove-doc">
                                                            <i class="bi bi-trash3"></i>
                                                            Quitar
                                                        </button>
                                                    }

                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Bloqueado</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>

</div>

@section Scripts {
    <script src="~/js/embarque.js"></script>

    <script>
        const EMB_ID = @Model.Id;
        const QR_URL = "@Model.QR?.UrlQR";
        const QR_TOKEN = "@Model.QR?.Token";
        const QR_FECHA = "@Model.QR?.FechaGeneracion";

        async function copiarToken(token) {
            if (!token || token.trim() === "") {
                alert("No hay token disponible para copiar.");
                return;
            }

            try {
                await navigator.clipboard.writeText(token);
            } catch (error) {
                console.error("Error al copiar token:", error);

                const tempInput = document.createElement("input");
                tempInput.value = token;
                document.body.appendChild(tempInput);
                tempInput.select();
                tempInput.setSelectionRange(0, 99999);

                try {
                    document.execCommand("copy");
                } catch (err) {
                    alert("No se pudo copiar el token.");
                }

                document.body.removeChild(tempInput);
            }
        }
    </script>
}