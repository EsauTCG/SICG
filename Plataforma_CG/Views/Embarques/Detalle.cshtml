    }

    .btn-top-light {
        background: white;
        color: var(--primary);
    }

        .btn-top-light:hover {
            color: var(--primary-dark);
            transform: translateY(-1px);
        }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0,1fr));
        gap: 1rem;
        margin: 1rem 0 1.2rem;
    }

    .summary-card {
