@model Plataforma_CG.Models.Embarque

@{
    ViewData["Title"] = "Editar Embarque";
    Layout = "~/Views/Shared/_Layout2.cshtml";

    var totalOV = ViewBag.TotalOrdenesDisponibles is int totalOrdenes
        ? totalOrdenes
        : 0;

    var totalTR = ViewBag.TotalTransferenciasDisponibles is int totalTransferencias
        ? totalTransferencias
        : 0;

    var totalDisponibles = totalOV + totalTR;
}

<style>
    :root {
        --primary: #8B0000;
        --primary-dark: #5a0000;
        --primary-soft: #f8eaea;
        --bg-card: #ffffff;
        --bg-muted: #f8f9fb;
        --text: #1f2937;
        --text-soft: #6b7280;
        --border: #e5e7eb;
        --border-strong: #d1d5db;
        --success: #198754;
        --warning: #f59e0b;
        --danger: #dc3545;
        --radius-xl: 18px;
        --radius-lg: 14px;
        --radius-md: 10px;
        --shadow-sm: 0 4px 10px rgba(0,0,0,.05);
        --shadow-md: 0 10px 30px rgba(0,0,0,.08);
        --transition: all .22s ease;
    }

    body {
        background: linear-gradient(180deg, #f8f9fb 0%, #eef2f7 100%);
        color: var(--text);
        font-family: "Segoe UI", sans-serif;
    }

    .embarque-page {
        max-width: 1280px;
        margin: 2rem auto;
        padding: 0 1rem 2rem;
    }

    .page-header {
        background: linear-gradient(135deg, var(--primary) 0%, #6d0000 55%, #2c0000 100%);
        color: #fff;
        border-radius: var(--radius-xl);
        padding: 1.4rem 1.5rem;
        box-shadow: var(--shadow-md);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .page-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .header-icon {
        width: 58px;
        height: 58px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.18);
        font-size: 1.5rem;
    }

    .page-title {
        margin: 0;
        font-size: 1.6rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .page-subtitle {
        margin: .3rem 0 0;
        color: rgba(255,255,255,.85);
        font-size: .95rem;
    }

    .page-header-right {
        display: flex;
        align-items: center;
        gap: .75rem;
        flex-wrap: wrap;
    }

    .header-chip {
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.18);
        border-radius: 999px;
        padding: .55rem .9rem;
        font-size: .92rem;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
    }

    .btn-top {
        border: none;
        border-radius: 999px;
        padding: .72rem 1rem;
        font-weight: 700;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        transition: var(--transition);
    }

    .btn-top-light {
        background: #fff;
        color: var(--primary);
    }

        .btn-top-light:hover {
            transform: translateY(-1px);
            color: var(--primary-dark);
        }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0,1fr));
        gap: 1rem;
        margin: 1.1rem 0 1.3rem;
    }

    .summary-card {
        background: rgba(255,255,255,.75);
        backdrop-filter: blur(6px);
        border: 1px solid rgba(255,255,255,.85);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        padding: 1rem 1.1rem;
        display: flex;
        align-items: center;
        gap: .9rem;
    }

    .summary-icon {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        background: var(--primary-soft);
        color: var(--primary);
        display: grid;
        place-items: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .summary-label {
        font-size: .82rem;
        text-transform: uppercase;
        letter-spacing: .6px;
        color: var(--text-soft);
        margin-bottom: .2rem;
        font-weight: 700;
    }

    .summary-value {
        font-size: 1.35rem;
        font-weight: 800;
        line-height: 1;
    }

    .floating-toolbar {
        position: sticky;
        top: 70px;
        z-index: 20;
        margin-bottom: 1rem;
        background: rgba(255,255,255,.88);
        border: 1px solid var(--border);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        box-shadow: var(--shadow-sm);
        padding: .75rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .75rem;
        flex-wrap: wrap;
    }

    .toolbar-left,
    .toolbar-right {
        display: flex;
        align-items: center;
        gap: .65rem;
        flex-wrap: wrap;
    }

    .btn-ui {
        border: none;
        border-radius: 12px;
        padding: .8rem 1rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: .55rem;
        transition: var(--transition);
        cursor: pointer;
        text-decoration: none;
    }

    .btn-primary-ui {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: #fff;
        box-shadow: 0 8px 18px rgba(139,0,0,.18);
    }

        .btn-primary-ui:hover {
            transform: translateY(-1px);
            color: #fff;
        }

    .btn-soft {
        background: #fff;
        color: var(--text);
        border: 1px solid var(--border);
    }

        .btn-soft:hover {
            background: #f9fafb;
            color: var(--text);
        }

    .btn-primary-ui:disabled {
        opacity: .55;
        cursor: not-allowed;
        transform: none;
    }

    .card-ui {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

    .table-card {
        margin-top: 1rem;
    }

    .card-head {
        padding: 1rem 1.2rem;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, #fff 0%, #fafafb 100%);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .8rem;
        flex-wrap: wrap;
    }

    .card-title {
        margin: 0;
        font-size: 1rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

        .card-title i {
            color: var(--primary);
        }

    .card-sub {
        color: var(--text-soft);
        font-size: .88rem;
        margin-top: .2rem;
    }

    .card-body {
        padding: 1.2rem;
    }

    .table-tools {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .8rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .table-meta {
        font-size: .9rem;
        color: var(--text-soft);
        font-weight: 600;
    }

    .filters-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: .8rem;
        margin-bottom: 1rem;
        align-items: end;
    }

    .filter-field label {
        display: block;
        font-size: .82rem;
        font-weight: 700;
        color: var(--text-soft);
        margin-bottom: .45rem;
    }

    .filter-field input,
    .filter-field select {
        width: 100%;
        border: 1.5px solid var(--border);
        border-radius: 12px;
        padding: .8rem .95rem;
        font-size: .92rem;
        background: #fff;
        outline: none;
        transition: var(--transition);
    }

        .filter-field input:focus,
        .filter-field select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(139,0,0,.08);
        }

    .filter-actions {
        display: flex;
        gap: .6rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .result-counter {
        font-size: .9rem;
        color: var(--text-soft);
        font-weight: 700;
        margin-bottom: .8rem;
    }

    .table-scroll {
        max-height: 430px;
        overflow: auto;
        border: 1px solid var(--border);
        border-radius: 16px;
    }

    .table-ui {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        min-width: 760px;
    }

        .table-ui thead th {
            position: sticky;
            top: 0;
            background: #fcfcfd;
            z-index: 2;
            font-size: .78rem;
            text-transform: uppercase;
            letter-spacing: .6px;
            color: var(--text-soft);
            padding: 1rem .95rem;
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .table-ui tbody td {
            padding: .95rem;
            border-bottom: 1px solid #eef1f4;
            vertical-align: middle;
        }

        .table-ui tbody tr:hover {
            background: #fafbfd;
        }

    .id-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 56px;
        padding: .35rem .65rem;
        background: var(--primary-soft);
        color: var(--primary);
        border-radius: 999px;
        font-weight: 800;
        font-size: .88rem;
    }

    .check-ui {
        appearance: none;
        width: 22px;
        height: 22px;
        border: 2px solid var(--primary);
        border-radius: 7px;
        background: #fff;
        position: relative;
        cursor: pointer;
        transition: var(--transition);
        vertical-align: middle;
    }

        .check-ui:hover {
            transform: scale(1.03);
            box-shadow: 0 0 0 4px rgba(139,0,0,.06);
        }

        .check-ui:checked {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-color: var(--primary-dark);
        }

            .check-ui:checked::after {
                content: "✓";
                position: absolute;
                left: 4px;
                top: -1px;
                color: #fff;
                font-size: 14px;
                font-weight: 800;
            }

    .empty-note {
        text-align: center;
        padding: 2rem 1rem;
        color: var(--text-soft);
    }

    .alert {
        border-radius: 14px;
    }

    body[data-theme="dark"] {
        --primary: #ef4444;
        --primary-dark: #991b1b;
        --primary-soft: rgba(127,29,29,0.24);
        --bg-card: #111827;
        --bg-muted: #172033;
        --text: #f9fafb;
        --text-soft: #cbd5e1;
        --border: rgba(255,255,255,0.12);
        --border-strong: rgba(203,213,225,0.28);
        background: #0f172a !important;
        color: #e5e7eb !important;
    }

        body[data-theme="dark"] .layout-main-content {
            background: #0f172a !important;
        }

        body[data-theme="dark"] .page-header {
            background: linear-gradient(135deg, #7f1d1d 0%, #450a0a 55%, #111827 100%) !important;
            border: 1px solid rgba(248,113,113,0.22) !important;
        }

        body[data-theme="dark"] .summary-card,
        body[data-theme="dark"] .floating-toolbar,
        body[data-theme="dark"] .card-ui {
            background: rgba(17,24,39,.94) !important;
            color: #e5e7eb !important;
            border-color: rgba(255,255,255,0.12) !important;
        }

        body[data-theme="dark"] .card-head {
            background: linear-gradient(180deg, #1f2937 0%, #172033 100%) !important;
            border-bottom-color: rgba(255,255,255,0.12) !important;
        }

        body[data-theme="dark"] .btn-soft,
        body[data-theme="dark"] .btn-top-light {
            background: #0b1220 !important;
            color: #fca5a5 !important;
            border: 1px solid rgba(248,113,113,0.35) !important;
        }

        body[data-theme="dark"] .filter-field input,
        body[data-theme="dark"] .filter-field select {
            background: #0f172a !important;
            color: #f9fafb !important;
            border-color: rgba(255,255,255,0.14) !important;
        }

        body[data-theme="dark"] .table-scroll {
            border-color: rgba(255,255,255,0.12) !important;
        }

        body[data-theme="dark"] .table-ui {
            background: #111827 !important;
            color: #e5e7eb !important;
        }

            body[data-theme="dark"] .table-ui thead th {
                background: #172033 !important;
                color: #f9fafb !important;
                border-bottom-color: rgba(255,255,255,0.12) !important;
            }

            body[data-theme="dark"] .table-ui tbody td {
                border-bottom-color: rgba(255,255,255,0.10) !important;
                color: #e5e7eb !important;
            }

            body[data-theme="dark"] .table-ui tbody tr:hover {
                background: rgba(248,113,113,0.08) !important;
            }

    @@media (max-width: 1100px) {
        .summary-grid,
        .filters-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .embarque-page {
            padding: 0 .7rem 1.5rem;
        }

        .page-header {
            padding: 1.1rem;
        }

        .page-title {
            font-size: 1.3rem;
        }

        .summary-grid,
        .filters-grid {
            grid-template-columns: 1fr;
        }

        .floating-toolbar {
            top: 6px;
            align-items: stretch;
        }

        .toolbar-left,
        .toolbar-right,
        .btn-ui {
            width: 100%;
            justify-content: center;
        }

        .table-scroll {
            max-height: 520px;
            overflow-y: auto;
            overflow-x: hidden;
            border-radius: 16px;
            padding: .75rem;
            background: #f8f9fb;
            -webkit-overflow-scrolling: touch;
        }

        .table-ui {
            min-width: 0 !important;
            width: 100%;
        }

            .table-ui thead {
                display: none;
            }

            .table-ui tbody {
                display: flex;
                flex-direction: column;
                gap: .85rem;
            }

                .table-ui tbody tr {
                    display: grid;
                    grid-template-columns: 1fr;
                    gap: .45rem;
                    background: #fff;
                    border: 1px solid var(--border);
                    border-radius: 16px;
                    padding: 1rem;
                    box-shadow: var(--shadow-sm);
                }

                .table-ui tbody td {
                    border-bottom: none;
                    padding: .25rem 0;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    gap: 1rem;
                    text-align: right;
                    font-size: .92rem;
                }

                    .table-ui tbody td::before {
                        content: attr(data-label);
                        font-size: .78rem;
                        font-weight: 800;
                        color: var(--text-soft);
                        text-transform: uppercase;
                        letter-spacing: .4px;
                        text-align: left;
                        flex-shrink: 0;
                    }

                    .table-ui tbody td:first-child {
                        background: var(--bg-muted);
                        border-radius: 12px;
                        padding: .75rem;
                        margin-bottom: .25rem;
                    }

        body[data-theme="dark"] .table-scroll {
            background: #0f172a !important;
        }

        body[data-theme="dark"] .table-ui tbody tr {
            background: #111827 !important;
            border-color: rgba(255,255,255,0.12) !important;
        }
    }

    /* Loader de guardado */
    .embarque-loader[hidden] {
        display: none !important;
    }

    .embarque-loader {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(15, 23, 42, .68);
        backdrop-filter: blur(4px);
        display: grid;
        place-items: center;
        padding: 1rem;
    }

    .embarque-loader-card {
        width: min(420px, 100%);
        background: #fff;
        color: var(--text);
        border: 1px solid var(--border);
        border-radius: 20px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, .25);
        padding: 1.6rem;
        text-align: center;
    }

        .embarque-loader-card .spinner-border {
            width: 2.5rem;
            height: 2.5rem;
            color: var(--primary);
            margin-bottom: 1rem;
        }

        .embarque-loader-card h5 {
            font-weight: 800;
            margin-bottom: .45rem;
        }

        .embarque-loader-card p {
            color: var(--text-soft);
            margin: 0;
        }

    body[data-theme="dark"] .embarque-loader-card {
        background: #111827;
        color: #f9fafb;
        border-color: rgba(255,255,255,.12);
    }

</style>

<div class="embarque-page">

    <div class="page-header">
        <div class="page-header-left">
            <div class="header-icon">
                <i class="bi bi-pencil-square"></i>
            </div>

            <div>
                <h1 class="page-title">Editar Embarque #@Model.Consecutivo</h1>

                <div class="page-subtitle">
                    Agrega órdenes o transferencias mediante consultas paginadas,
                    sin cargar todos los registros al abrir la página.
                </div>
            </div>
        </div>

        <div class="page-header-right">
            <span class="header-chip">
                <i class="bi bi-calendar3"></i>
                @Model.FechaCreacion.ToString("yyyy-MM-dd")
            </span>

            <a class="btn-top btn-top-light"
               href="@Url.Action("Detalle", "Embarques", new { id = Model.Id })">
                <i class="bi bi-arrow-left-circle"></i>
                Volver al detalle
            </a>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i>
            @TempData["Error"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i>
            @TempData["Success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="Cerrar"></button>
        </div>
    }

    <div class="summary-grid">
        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-truck"></i>
            </div>

            <div>
                <div class="summary-label">Embarque</div>
                <div class="summary-value">@Model.Consecutivo</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-bag-check"></i>
            </div>

            <div>
                <div class="summary-label">Órdenes disponibles</div>
                <div class="summary-value">@totalOV</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-arrow-left-right"></i>
            </div>

            <div>
                <div class="summary-label">Transferencias disponibles</div>
                <div class="summary-value">@totalTR</div>
            </div>
        </div>
    </div>

    @if (totalDisponibles <= 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-1"></i>
            No hay órdenes ni transferencias disponibles para agregar a este embarque.
        </div>
    }
    else
    {
        <form asp-action="AgregarDocumentosEmbarque"
              asp-controller="Embarques"
              method="post"
              id="formAgregarDocumentos">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   name="embarqueId"
                   value="@Model.Id" />

            <div id="documentosSeleccionadosPost"></div>

            <div class="floating-toolbar">
                <div class="toolbar-left">
                    <button type="submit"
                            class="btn-ui btn-primary-ui"
                            id="btnGuardarDocumentos"
                            disabled>
                        <i class="bi bi-plus-circle"></i>
                        Agregar seleccionados
                    </button>

                    <span class="header-chip"
                          style="color:var(--text); background:var(--bg-card); border:1px solid var(--border);">
                        <i class="bi bi-bag-check"></i>
                        OV:
                        <strong id="cantidadSeleccionadaOV">0</strong>
                    </span>

                    <span class="header-chip"
                          style="color:var(--text); background:var(--bg-card); border:1px solid var(--border);">
                        <i class="bi bi-arrow-left-right"></i>
                        TR:
                        <strong id="cantidadSeleccionadaTR">0</strong>
                    </span>
                </div>

                <div class="toolbar-right">
                    <button type="button"
                            class="btn-ui btn-soft"
                            onclick="seleccionarVisibles()">
                        <i class="bi bi-check2-square"></i>
                        Seleccionar visibles
                    </button>

                    <button type="button"
                            class="btn-ui btn-soft"
                            onclick="limpiarSeleccion()">
                        <i class="bi bi-x-square"></i>
                        Limpiar selección
                    </button>

                    <button type="button"
                            class="btn-ui btn-soft"
                            onclick="irASeccion('seccionOV')">
                        <i class="bi bi-bag-check"></i>
                        Órdenes
                    </button>

                    <button type="button"
                            class="btn-ui btn-soft"
                            onclick="irASeccion('seccionTR')">
                        <i class="bi bi-arrow-left-right"></i>
                        Transferencias
                    </button>
                </div>
            </div>

            <div class="card-ui table-card"
                 id="seccionOV">

                <div class="card-head">
                    <div>
                        <div class="card-title">
                            <i class="bi bi-bag-check"></i>
                            Órdenes disponibles
                        </div>

                        <div class="card-sub">
                            La consulta se realiza en bloques de 50 registros.
                        </div>
                    </div>

                    <span class="header-chip"
                          style="color:var(--text); background:var(--bg-card); border:1px solid var(--border);">
                        Total: @totalOV
                    </span>
                </div>

                <div class="card-body">
                    <div class="filters-grid">
                        <div class="filter-field">
                            <label for="filtroConsecutivoOV">Consecutivo</label>

                            <input type="text"
                                   id="filtroConsecutivoOV"
                                   placeholder="Filtrar por consecutivo..."
                                   autocomplete="off" />
                        </div>

                        <div class="filter-field">
                            <label for="filtroRutaOV">Ruta</label>

                            <input type="text"
                                   id="filtroRutaOV"
                                   placeholder="Filtrar por ruta..."
                                   autocomplete="off" />
                        </div>

                        <div class="filter-field">
                            <label for="soloSeleccionadasOV">Mostrar</label>

                            <select id="soloSeleccionadasOV">
                                <option value="todas">Todas</option>
                                <option value="seleccionadas">Solo seleccionadas</option>
                                <option value="noseleccionadas">Solo no seleccionadas</option>
                            </select>
                        </div>
                    </div>

                    <div class="filter-actions">
                        <button type="button"
                                class="btn-ui btn-soft"
                                onclick="limpiarFiltrosOV()">
                            <i class="bi bi-eraser"></i>
                            Limpiar filtros
                        </button>
                    </div>

                    <div class="result-counter"
                         id="contadorOV">
                        Mostrando 0 registros
                    </div>

                    <div class="table-scroll">
                        <table class="table-ui"
                               id="tablaOV">

                            <thead>
                                <tr>
                                    <th style="width:70px;">Sel.</th>
                                    <th>ID</th>
                                    <th>Cliente</th>
                                    <th>Consecutivo</th>
                                    <th>Ruta</th>
                                </tr>
                            </thead>

                            <tbody id="tbodyOV">
                                <tr>
                                    <td colspan="5"
                                        class="empty-note">
                                        <div class="spinner-border spinner-border-sm"
                                             role="status"></div>
                                        Consultando órdenes disponibles...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="text-center mt-3">
                        <button type="button"
                                id="btnCargarMasOV"
                                class="btn-ui btn-soft"
                                style="display:none;">
                            <i class="bi bi-chevron-down"></i>
                            Cargar más órdenes
                        </button>
                    </div>
                </div>
            </div>

            <div class="card-ui table-card"
                 id="seccionTR">

                <div class="card-head">
                    <div>
                        <div class="card-title">
                            <i class="bi bi-arrow-left-right"></i>
                            Transferencias disponibles
                        </div>

                        <div class="card-sub">
                            La consulta se realiza en bloques de 50 registros.
                        </div>
                    </div>

                    <span class="header-chip"
                          style="color:var(--text); background:var(--bg-card); border:1px solid var(--border);">
                        Total: @totalTR
                    </span>
                </div>

                <div class="card-body">
                    <div class="filters-grid">
                        <div class="filter-field">
                            <label for="filtroConsecutivoTR">Consecutivo</label>

                            <input type="text"
                                   id="filtroConsecutivoTR"
                                   placeholder="Filtrar por consecutivo..."
                                   autocomplete="off" />
                        </div>

                        <div class="filter-field">
                            <label for="filtroSucursalTR">Sucursal</label>

                            <input type="text"
                                   id="filtroSucursalTR"
                                   placeholder="Filtrar por sucursal..."
                                   autocomplete="off" />
                        </div>

                        <div class="filter-field">
                            <label for="filtroFechaTR">Fecha</label>

                            <input type="text"
                                   id="filtroFechaTR"
                                   placeholder="Ej. 15/04/2026"
                                   autocomplete="off" />
                        </div>

                        <div class="filter-field">
                            <label for="soloSeleccionadasTR">Mostrar</label>

                            <select id="soloSeleccionadasTR">
                                <option value="todas">Todas</option>
                                <option value="seleccionadas">Solo seleccionadas</option>
                                <option value="noseleccionadas">Solo no seleccionadas</option>
                            </select>
                        </div>
                    </div>

                    <div class="filter-actions">
                        <button type="button"
                                class="btn-ui btn-soft"
                                onclick="limpiarFiltrosTR()">
                            <i class="bi bi-eraser"></i>
                            Limpiar filtros
                        </button>
                    </div>

                    <div class="result-counter"
                         id="contadorTR">
                        Mostrando 0 registros
                    </div>

                    <div class="table-scroll">
                        <table class="table-ui"
                               id="tablaTR">

                            <thead>
                                <tr>
                                    <th style="width:70px;">Sel.</th>
                                    <th>ID</th>
                                    <th>Sucursal</th>
                                    <th>Consecutivo</th>
                                    <th>Fecha solicitud</th>
                                </tr>
                            </thead>

                            <tbody id="tbodyTR">
                                <tr>
                                    <td colspan="5"
                                        class="empty-note">
                                        <div class="spinner-border spinner-border-sm"
                                             role="status"></div>
                                        Consultando transferencias disponibles...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="text-center mt-3">
                        <button type="button"
                                id="btnCargarMasTR"
                                class="btn-ui btn-soft"
                                style="display:none;">
                            <i class="bi bi-chevron-down"></i>
                            Cargar más transferencias
                        </button>
                    </div>
                </div>
            </div>
        </form>

        <div id="loaderEditarEmbarque"
             class="embarque-loader"
             hidden>

            <div class="embarque-loader-card">
                <div class="spinner-border"
                     role="status"></div>

                <h5>Agregando documentos</h5>

                <p>
                    Estamos actualizando el embarque.
                    No cierres esta ventana.
                </p>
            </div>
        </div>
    }
</div>

<script>
    const PAGE_SIZE = 50;

    const urlOrdenes =
        '@Url.Action("ObtenerOrdenesDisponibles", "Embarques")';

    const urlTransferencias =
        '@Url.Action("ObtenerTransferenciasDisponibles", "Embarques")';

    const seleccionadasOV = new Map();
    const seleccionadasTR = new Map();

    const estadoOV = {
        pagina: 0,
        total: 0,
        hayMas: true,
        cargando: false,
        abortController: null,
        idsRenderizados: new Set()
    };

    const estadoTR = {
        pagina: 0,
        total: 0,
        hayMas: true,
        cargando: false,
        abortController: null,
        idsRenderizados: new Set()
    };

    function escaparHtml(valor) {
        const elemento = document.createElement("div");
        elemento.textContent = valor ?? "";
        return elemento.innerHTML;
    }

    function normalizar(valor) {
        return (valor ?? "")
            .toString()
            .trim()
            .toLowerCase();
    }

    function debounce(funcion, espera) {
        let timeout;

        return function (...args) {
            clearTimeout(timeout);

            timeout = setTimeout(() => {
                funcion.apply(this, args);
            }, espera);
        };
    }

    function irASeccion(idSeccion) {
        const seccion = document.getElementById(idSeccion);

        if (!seccion) {
            return;
        }

        seccion.scrollIntoView({
            behavior: "smooth",
            block: "start"
        });
    }

    function actualizarEstadoSeleccion() {
        const contadorOV =
            document.getElementById("cantidadSeleccionadaOV");

        const contadorTR =
            document.getElementById("cantidadSeleccionadaTR");

        const boton =
            document.getElementById("btnGuardarDocumentos");

        if (contadorOV) {
            contadorOV.textContent = seleccionadasOV.size;
        }

        if (contadorTR) {
            contadorTR.textContent = seleccionadasTR.size;
        }

        if (boton) {
            boton.disabled =
                seleccionadasOV.size === 0 &&
                seleccionadasTR.size === 0;
        }
    }

    function mostrarCargando(tbodyId, columnas, mensaje) {
        const tbody = document.getElementById(tbodyId);

        tbody.innerHTML = `
            <tr>
                <td colspan="${columnas}" class="empty-note">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                    ${escaparHtml(mensaje)}
                </td>
            </tr>
        `;
    }

    function mostrarVacio(tbodyId, columnas, mensaje) {
        const tbody = document.getElementById(tbodyId);

        tbody.innerHTML = `
            <tr>
                <td colspan="${columnas}" class="empty-note">
                    <i class="bi bi-inbox"></i>
                    ${escaparHtml(mensaje)}
                </td>
            </tr>
        `;
    }

    function mostrarError(tbodyId, columnas) {
        const tbody = document.getElementById(tbodyId);

        tbody.innerHTML = `
            <tr>
                <td colspan="${columnas}" class="empty-note text-danger">
                    <i class="bi bi-exclamation-triangle"></i>
                    No fue posible consultar los registros.
                </td>
            </tr>
        `;
    }

    function crearFilaOV(item) {
        const fila = document.createElement("tr");
        fila.dataset.id = item.id;

        fila.innerHTML = `
            <td data-label="Seleccionar">
                <input type="checkbox"
                       class="check-ui check-ov"
                       value="${item.id}" />
            </td>

            <td data-label="ID">
                <span class="id-badge">#${item.id}</span>
            </td>

            <td data-label="Cliente">
                ${escaparHtml(item.nombreCliente)}
            </td>

            <td data-label="Consecutivo">
                ${escaparHtml(item.consecutivo)}
            </td>

            <td data-label="Ruta">
                ${escaparHtml(item.ruta)}
            </td>
        `;

        const checkbox = fila.querySelector(".check-ov");

        checkbox.checked = seleccionadasOV.has(item.id);

        checkbox.addEventListener("change", function () {
            if (this.checked) {
                seleccionadasOV.set(item.id, item);
            } else {
                seleccionadasOV.delete(item.id);
            }

            actualizarEstadoSeleccion();

            const modo =
                document.getElementById("soloSeleccionadasOV").value;

            if (modo === "seleccionadas") {
                renderizarSeleccionadasOV();
            }

            if (modo === "noseleccionadas" && this.checked) {
                fila.remove();
                actualizarContadorOV();
            }
        });

        return fila;
    }

    function crearFilaTR(item) {
        const fila = document.createElement("tr");
        fila.dataset.id = item.id;

        fila.innerHTML = `
            <td data-label="Seleccionar">
                <input type="checkbox"
                       class="check-ui check-tr"
                       value="${item.id}" />
            </td>

            <td data-label="ID">
                <span class="id-badge">#${item.id}</span>
            </td>

            <td data-label="Sucursal">
                ${escaparHtml(item.sucursal)}
            </td>

            <td data-label="Consecutivo">
                ${escaparHtml(item.consecutivo)}
            </td>

            <td data-label="Fecha">
                ${escaparHtml(item.fechaSolicitudTexto)}
            </td>
        `;

        const checkbox = fila.querySelector(".check-tr");

        checkbox.checked = seleccionadasTR.has(item.id);

        checkbox.addEventListener("change", function () {
            if (this.checked) {
                seleccionadasTR.set(item.id, item);
            } else {
                seleccionadasTR.delete(item.id);
            }

            actualizarEstadoSeleccion();

            const modo =
                document.getElementById("soloSeleccionadasTR").value;

            if (modo === "seleccionadas") {
                renderizarSeleccionadasTR();
            }

            if (modo === "noseleccionadas" && this.checked) {
                fila.remove();
                actualizarContadorTR();
            }
        });

        return fila;
    }

    function actualizarContadorOV() {
        const visibles =
            document.querySelectorAll("#tbodyOV tr[data-id]").length;

        const contador =
            document.getElementById("contadorOV");

        if (contador) {
            contador.textContent =
                `Mostrando ${visibles} de ${estadoOV.total} registro(s). ` +
                `Seleccionadas: ${seleccionadasOV.size}`;
        }
    }

    function actualizarContadorTR() {
        const visibles =
            document.querySelectorAll("#tbodyTR tr[data-id]").length;

        const contador =
            document.getElementById("contadorTR");

        if (contador) {
            contador.textContent =
                `Mostrando ${visibles} de ${estadoTR.total} registro(s). ` +
                `Seleccionadas: ${seleccionadasTR.size}`;
        }
    }

    function cumpleFiltrosLocalesOV(item) {
        const consecutivo = normalizar(
            document.getElementById("filtroConsecutivoOV")?.value
        );

        const ruta = normalizar(
            document.getElementById("filtroRutaOV")?.value
        );

        return (
            !consecutivo ||
            normalizar(item.consecutivo).includes(consecutivo)
        ) && (
            !ruta ||
            normalizar(item.ruta).includes(ruta)
        );
    }

    function cumpleFiltrosLocalesTR(item) {
        const sucursal = normalizar(
            document.getElementById("filtroSucursalTR")?.value
        );

        const consecutivo = normalizar(
            document.getElementById("filtroConsecutivoTR")?.value
        );

        const fecha = normalizar(
            document.getElementById("filtroFechaTR")?.value
        );

        return (
            !sucursal ||
            normalizar(item.sucursal).includes(sucursal)
        ) && (
            !consecutivo ||
            normalizar(item.consecutivo).includes(consecutivo)
        ) && (
            !fecha ||
            normalizar(item.fechaSolicitudTexto).includes(fecha)
        );
    }

    function renderizarSeleccionadasOV() {
        const tbody = document.getElementById("tbodyOV");
        tbody.innerHTML = "";

        const items = Array
            .from(seleccionadasOV.values())
            .filter(cumpleFiltrosLocalesOV);

        items.forEach(item => {
            tbody.appendChild(crearFilaOV(item));
        });

        if (!items.length) {
            mostrarVacio(
                "tbodyOV",
                5,
                "No hay órdenes seleccionadas con estos filtros."
            );
        }

        document.getElementById("btnCargarMasOV").style.display = "none";
        actualizarContadorOV();
    }

    function renderizarSeleccionadasTR() {
        const tbody = document.getElementById("tbodyTR");
        tbody.innerHTML = "";

        const items = Array
            .from(seleccionadasTR.values())
            .filter(cumpleFiltrosLocalesTR);

        items.forEach(item => {
            tbody.appendChild(crearFilaTR(item));
        });

        if (!items.length) {
            mostrarVacio(
                "tbodyTR",
                5,
                "No hay transferencias seleccionadas con estos filtros."
            );
        }

        document.getElementById("btnCargarMasTR").style.display = "none";
        actualizarContadorTR();
    }

    async function cargarOV(reiniciar = false) {
        const modo =
            document.getElementById("soloSeleccionadasOV").value;

        if (modo === "seleccionadas") {
            renderizarSeleccionadasOV();
            return;
        }

        if (!reiniciar && (estadoOV.cargando || !estadoOV.hayMas)) {
            return;
        }

        if (reiniciar) {
            estadoOV.abortController?.abort();

            estadoOV.pagina = 0;
            estadoOV.total = 0;
            estadoOV.hayMas = true;
            estadoOV.idsRenderizados.clear();

            mostrarCargando(
                "tbodyOV",
                5,
                "Consultando órdenes disponibles..."
            );
        }

        const controladorActual = new AbortController();

        estadoOV.abortController = controladorActual;
        estadoOV.cargando = true;

        const boton = document.getElementById("btnCargarMasOV");
        boton.disabled = true;

        try {
            const paginaSiguiente = estadoOV.pagina + 1;

            const parametros = new URLSearchParams({
                pagina: paginaSiguiente,
                tamanoPagina: PAGE_SIZE,
                consecutivo:
                    document.getElementById("filtroConsecutivoOV")?.value ?? "",
                ruta:
                    document.getElementById("filtroRutaOV")?.value ?? ""
            });

            const respuesta = await fetch(
                `${urlOrdenes}?${parametros.toString()}`,
                {
                    signal: controladorActual.signal,
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                }
            );

            if (!respuesta.ok) {
                throw new Error("Error consultando órdenes.");
            }

            const resultado = await respuesta.json();
            const tbody = document.getElementById("tbodyOV");

            if (reiniciar) {
                tbody.innerHTML = "";
            }

            resultado.items.forEach(item => {
                if (
                    modo === "noseleccionadas" &&
                    seleccionadasOV.has(item.id)
                ) {
                    return;
                }

                if (estadoOV.idsRenderizados.has(item.id)) {
                    return;
                }

                estadoOV.idsRenderizados.add(item.id);
                tbody.appendChild(crearFilaOV(item));
            });

            estadoOV.pagina = resultado.pagina;
            estadoOV.total = resultado.total;
            estadoOV.hayMas = resultado.hayMas;

            if (!tbody.querySelector("tr[data-id]")) {
                mostrarVacio(
                    "tbodyOV",
                    5,
                    "No hay órdenes disponibles con estos filtros."
                );
            }

            boton.style.display =
                estadoOV.hayMas ? "inline-flex" : "none";

            actualizarContadorOV();
        }
        catch (error) {
            if (error.name !== "AbortError") {
                mostrarError("tbodyOV", 5);
            }
        }
        finally {
            if (estadoOV.abortController === controladorActual) {
                estadoOV.cargando = false;
                boton.disabled = false;
            }
        }
    }

    async function cargarTR(reiniciar = false) {
        const modo =
            document.getElementById("soloSeleccionadasTR").value;

        if (modo === "seleccionadas") {
            renderizarSeleccionadasTR();
            return;
        }

        if (!reiniciar && (estadoTR.cargando || !estadoTR.hayMas)) {
            return;
        }

        if (reiniciar) {
            estadoTR.abortController?.abort();

            estadoTR.pagina = 0;
            estadoTR.total = 0;
            estadoTR.hayMas = true;
            estadoTR.idsRenderizados.clear();

            mostrarCargando(
                "tbodyTR",
                5,
                "Consultando transferencias disponibles..."
            );
        }

        const controladorActual = new AbortController();

        estadoTR.abortController = controladorActual;
        estadoTR.cargando = true;

        const boton = document.getElementById("btnCargarMasTR");
        boton.disabled = true;

        try {
            const paginaSiguiente = estadoTR.pagina + 1;

            const parametros = new URLSearchParams({
                pagina: paginaSiguiente,
                tamanoPagina: PAGE_SIZE,
                sucursal:
                    document.getElementById("filtroSucursalTR")?.value ?? "",
                consecutivo:
                    document.getElementById("filtroConsecutivoTR")?.value ?? "",
                fecha:
                    document.getElementById("filtroFechaTR")?.value ?? ""
            });

            const respuesta = await fetch(
                `${urlTransferencias}?${parametros.toString()}`,
                {
                    signal: controladorActual.signal,
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                }
            );

            if (!respuesta.ok) {
                throw new Error("Error consultando transferencias.");
            }

            const resultado = await respuesta.json();
            const tbody = document.getElementById("tbodyTR");

            if (reiniciar) {
                tbody.innerHTML = "";
            }

            resultado.items.forEach(item => {
                if (
                    modo === "noseleccionadas" &&
                    seleccionadasTR.has(item.id)
                ) {
                    return;
                }

                if (estadoTR.idsRenderizados.has(item.id)) {
                    return;
                }

                estadoTR.idsRenderizados.add(item.id);
                tbody.appendChild(crearFilaTR(item));
            });

            estadoTR.pagina = resultado.pagina;
            estadoTR.total = resultado.total;
            estadoTR.hayMas = resultado.hayMas;

            if (!tbody.querySelector("tr[data-id]")) {
                mostrarVacio(
                    "tbodyTR",
                    5,
                    "No hay transferencias disponibles con estos filtros."
                );
            }

            boton.style.display =
                estadoTR.hayMas ? "inline-flex" : "none";

            actualizarContadorTR();
        }
        catch (error) {
            if (error.name !== "AbortError") {
                mostrarError("tbodyTR", 5);
            }
        }
        finally {
            if (estadoTR.abortController === controladorActual) {
                estadoTR.cargando = false;
                boton.disabled = false;
            }
        }
    }

    const aplicarFiltrosOV = debounce(() => {
        cargarOV(true);
    }, 350);

    const aplicarFiltrosTR = debounce(() => {
        cargarTR(true);
    }, 350);

    function limpiarFiltrosOV() {
        const consecutivo =
            document.getElementById("filtroConsecutivoOV");

        const ruta =
            document.getElementById("filtroRutaOV");

        const modo =
            document.getElementById("soloSeleccionadasOV");

        if (consecutivo) {
            consecutivo.value = "";
        }

        if (ruta) {
            ruta.value = "";
        }

        if (modo) {
            modo.value = "todas";
        }

        cargarOV(true);
    }

    function limpiarFiltrosTR() {
        const sucursal =
            document.getElementById("filtroSucursalTR");

        const consecutivo =
            document.getElementById("filtroConsecutivoTR");

        const fecha =
            document.getElementById("filtroFechaTR");

        const modo =
            document.getElementById("soloSeleccionadasTR");

        if (sucursal) {
            sucursal.value = "";
        }

        if (consecutivo) {
            consecutivo.value = "";
        }

        if (fecha) {
            fecha.value = "";
        }

        if (modo) {
            modo.value = "todas";
        }

        cargarTR(true);
    }

    function seleccionarVisibles() {
        document
            .querySelectorAll(
                "#tbodyOV .check-ov:not(:checked), " +
                "#tbodyTR .check-tr:not(:checked)"
            )
            .forEach(checkbox => {
                checkbox.checked = true;

                checkbox.dispatchEvent(
                    new Event("change", {
                        bubbles: true
                    })
                );
            });
    }

    function limpiarSeleccion() {
        seleccionadasOV.clear();
        seleccionadasTR.clear();

        actualizarEstadoSeleccion();
        cargarOV(true);
        cargarTR(true);
    }

    function agregarInputOculto(contenedor, nombre, valor) {
        const input = document.createElement("input");

        input.type = "hidden";
        input.name = nombre;
        input.value = valor;

        contenedor.appendChild(input);
    }

    document.addEventListener("DOMContentLoaded", function () {
        const form =
            document.getElementById("formAgregarDocumentos");

        if (!form) {
            return;
        }

        [
            "filtroConsecutivoOV",
            "filtroRutaOV"
        ].forEach(id => {
            document
                .getElementById(id)
                ?.addEventListener("input", aplicarFiltrosOV);
        });

        [
            "filtroSucursalTR",
            "filtroConsecutivoTR",
            "filtroFechaTR"
        ].forEach(id => {
            document
                .getElementById(id)
                ?.addEventListener("input", aplicarFiltrosTR);
        });

        document
            .getElementById("soloSeleccionadasOV")
            ?.addEventListener("change", () => cargarOV(true));

        document
            .getElementById("soloSeleccionadasTR")
            ?.addEventListener("change", () => cargarTR(true));

        document
            .getElementById("btnCargarMasOV")
            ?.addEventListener("click", () => cargarOV(false));

        document
            .getElementById("btnCargarMasTR")
            ?.addEventListener("click", () => cargarTR(false));

        const botonGuardar =
            document.getElementById("btnGuardarDocumentos");

        const loader =
            document.getElementById("loaderEditarEmbarque");

        const contenedorInputs =
            document.getElementById("documentosSeleccionadosPost");

        let enviando = false;

        form.addEventListener("submit", function (event) {
            if (enviando) {
                event.preventDefault();
                return;
            }

            const totalSeleccionados =
                seleccionadasOV.size +
                seleccionadasTR.size;

            if (totalSeleccionados === 0) {
                event.preventDefault();

                alert(
                    "Debes seleccionar al menos una orden o transferencia."
                );

                return;
            }

            const confirmar = confirm(
                `¿Seguro que deseas agregar ${totalSeleccionados} ` +
                `documento(s) al embarque?`
            );

            if (!confirmar) {
                event.preventDefault();
                return;
            }

            contenedorInputs.innerHTML = "";

            seleccionadasOV.forEach((item, id) => {
                agregarInputOculto(
                    contenedorInputs,
                    "ordenesSeleccionadas",
                    id
                );
            });

            seleccionadasTR.forEach((item, id) => {
                agregarInputOculto(
                    contenedorInputs,
                    "transferenciasSeleccionadas",
                    id
                );
            });

            enviando = true;
            botonGuardar.disabled = true;
            loader.hidden = false;
        });

        actualizarEstadoSeleccion();

        // Solo se consultan 50 registros por sección al abrir.
        cargarOV(true);
        cargarTR(true);
    });
</script>
