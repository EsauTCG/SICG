</style>

<div class="embarque-page">

    <div class="page-header">
        <div class="page-header-left">
            <div class="header-icon">
                <i class="bi bi-truck"></i>
            </div>
            <div>
                <h1 class="page-title">Crear Embarque</h1>
                <div class="page-subtitle">
                    Prepara el embarque y selecciona las órdenes o transferencias a integrar.
                    La documentación se cargará posteriormente en un módulo separado.
                </div>
            </div>
        </div>

        <div class="page-header-right">
            <span class="header-chip">
                <i class="bi bi-calendar3"></i>
                @DateTime.Now.ToShortDateString()
            </span>

            <a class="btn-top btn-top-light" href="@Url.Action("Embarque", "Embarques")">
                <i class="bi bi-arrow-left-circle"></i> Volver
            </a>
        </div>
    </div>

    <div class="summary-grid">
        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-bag-check"></i>
            </div>
            <div>
                <div class="summary-label">Órdenes disponibles</div>
                <div class="summary-value">@totalOV</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-arrow-left-right"></i>
            </div>
            <div>
                <div class="summary-label">Transferencias disponibles</div>
                <div class="summary-value">@totalTR</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-file-earmark-arrow-up"></i>
            </div>
            <div>
                <div class="summary-label">Carga posterior</div>
                <div class="summary-value" style="font-size:1.05rem;">Documentación</div>
            </div>
        </div>
    </div>

    <form asp-action="Crear" method="post">

        <div class="floating-toolbar">
            <div class="toolbar-left">
                <button type="submit" class="btn-ui btn-primary-ui">
                    <i class="bi bi-save"></i>
                    Crear Embarque
                </button>
            </div>

            <div class="toolbar-right">
                <button type="button" class="btn-ui btn-soft" onclick="irASeccion('seccionOV')">
                    <i class="bi bi-bag-check"></i>
                    Ir a OV
                </button>

                <button type="button" class="btn-ui btn-soft" onclick="irASeccion('seccionTR')">
                    <i class="bi bi-arrow-left-right"></i>
                    Ir a Transferencias
                </button>
            </div>
        </div>

        <div class="content-grid">
            <div class="card-ui">
                <div class="card-head">
                    <div>
                        <div class="card-title">
                            <i class="bi bi-tag"></i>
                            Identificación del Embarque
                        </div>
                        <div class="card-sub">
                            Agrega un nombre fácil de reconocer para identificar este embarque además del consecutivo.
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <div class="form-grid-embarque">

                        <div>
                            <label class="form-label-ui" for="nombreEmbarque">
                                Nombre del embarque
                            </label>

                            <input type="text"
                                   id="nombreEmbarque"
                                   name="nombreEmbarque"
                                   class="input-text-ui"
                                   maxlength="150"
                                   placeholder="Ejemplo: Ruta León - Cliente Walmart - Carga urgente"
                                   autocomplete="off" />

                            <div class="char-counter">
                                <span id="contadorNombreEmbarque">0</span>/150
                            </div>

                            <div class="hint-text">
                                Este nombre es opcional, pero ayudará a buscar e identificar el embarque más rápido.
                            </div>
                        </div>

                        <div>
                            <label class="form-label-ui" for="observaciones">
                                Notas del embarque
                            </label>

                            <textarea class="textarea-ui"
                                      id="observaciones"
                                      name="observaciones"
                                      placeholder="Ejemplo: condiciones de salida, observaciones del transporte, comentarios para validación, etc."></textarea>

                            <div class="hint-text">
                                Este campo es opcional, pero ayuda a dejar evidencia clara del embarque.
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger shadow-sm">@TempData["Error"]</div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success shadow-sm">@TempData["Success"]</div>
        }

        <div class="card-ui table-card scroll-target" id="seccionOV">
            <div class="card-head">
                <div>
                    <div class="card-title">
                        <i class="bi bi-list-check"></i>
                        Órdenes disponibles
                    </div>
                    <div class="card-sub">
                        Selecciona las órdenes de venta que formarán parte del embarque.
                    </div>
                </div>
                <span class="header-chip" style="color:var(--text); background:#fff; border:1px solid var(--border);">
                    Total: @totalOV
                </span>
            </div>

            <div class="card-body">
                <div class="table-tools">
                    <div class="table-meta">Listado de órdenes listo para selección</div>
                </div>

                <div class="filters-grid" id="filtrosOV">
                    <div class="filter-field">
                        <label for="buscarOV">Búsqueda general</label>
                        <input type="text" id="buscarOV" class="input-search" placeholder="Cliente, consecutivo o ruta..." autocomplete="off" />
                    </div>

                    <div class="filter-field">
                        <label for="filtroClienteOV">Cliente</label>
                        <input type="text" id="filtroClienteOV" placeholder="Filtrar por cliente..." autocomplete="off" />
                    </div>

                    <div class="filter-field">
                        <label for="filtroConsecutivoOV">Consecutivo</label>
                        <input type="text" id="filtroConsecutivoOV" placeholder="Filtrar por consecutivo..." autocomplete="off" />
                    </div>

                    <div class="filter-field">
                        <label for="filtroRutaOV">Ruta</label>
                        <input type="text" id="filtroRutaOV" placeholder="Filtrar por ruta..." autocomplete="off" />
                    </div>

                    <div class="filter-field">
                        <label for="soloSeleccionadasOV">Mostrar</label>
                        <select id="soloSeleccionadasOV">
                            <option value="todas">Todas</option>
                            <option value="seleccionadas">Solo seleccionadas</option>
                            <option value="noseleccionadas">Solo no seleccionadas</option>
                        </select>
                    </div>
                </div>

                <div class="filter-actions">
                    <button type="button" class="btn-ui btn-soft" onclick="limpiarFiltrosOV()">
                        <i class="bi bi-eraser"></i>
                        Limpiar filtros
                    </button>
                </div>

                <div class="result-counter" id="contadorOV">Mostrando 0 registros</div>

                <div class="table-scroll">
                    <table class="table-ui" id="tablaOV">
                        <thead>
                            <tr>
                                <th style="width:70px;">Sel.</th>
                                <th>ID</th>
                                <th>Cliente</th>
                                <th>Consecutivo</th>
                                <th>Ruta</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var ov in Model)
                                {
                                    <tr data-cliente="@ov.NombreCliente"
                                        data-consecutivo="@ov.Consecutivo"
                                        data-ruta="@ov.Ruta">
                                        <td data-label="Seleccionar">
                                            <input type="checkbox"
                                                   class="check-ui"
                                                   name="ordenesSeleccionadas"
                                                   value="@ov.Id" />
                                        </td>
                                        <td data-label="ID"><span class="id-badge">#@ov.Id</span></td>
                                        <td data-label="Cliente">@ov.NombreCliente</td>
                                        <td data-label="Consecutivo">@ov.Consecutivo</td>
                                        <td data-label="Ruta">@ov.Ruta</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="empty-note">
                                        No hay órdenes disponibles para mostrar.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card-ui table-card section-divider scroll-target" id="seccionTR">
            <div class="card-head">
                <div>
                    <div class="card-title">
                        <i class="bi bi-arrow-left-right"></i>
                        Transferencias disponibles
                    </div>
                    <div class="card-sub">
                        Selecciona las transferencias que también se incluirán en el embarque.
                    </div>
                </div>
                <span class="header-chip" style="color:var(--text); background:#fff; border:1px solid var(--border);">
                    Total: @totalTR
                </span>
            </div>

            <div class="card-body">
                <div class="table-tools">
                    <div class="table-meta">Listado de transferencias listo para selección</div>
                </div>

                <div class="filters-grid" id="filtrosTR">
                    <div class="filter-field">
                        <label for="buscarTR">Búsqueda general</label>
                        <input type="text" id="buscarTR" class="input-search" placeholder="Sucursal, consecutivo o fecha..." />
                    </div>

                    <div class="filter-field">
                        <label for="filtroSucursalTR">Sucursal</label>
                        <input type="text" id="filtroSucursalTR" placeholder="Filtrar por sucursal..." />
                    </div>

                    <div class="filter-field">
                        <label for="filtroConsecutivoTR">Consecutivo</label>
                        <input type="text" id="filtroConsecutivoTR" placeholder="Filtrar por consecutivo..." />
                    </div>

                    <div class="filter-field">
                        <label for="filtroFechaTR">Fecha</label>
                        <input type="text" id="filtroFechaTR" placeholder="Ej. 15/04/2026" />
                    </div>

                    <div class="filter-field">
                        <label for="soloSeleccionadasTR">Mostrar</label>
                        <select id="soloSeleccionadasTR">
                            <option value="todas">Todas</option>
                            <option value="seleccionadas">Solo seleccionadas</option>
                            <option value="noseleccionadas">Solo no seleccionadas</option>
                        </select>
                    </div>
                </div>

                <div class="filter-actions">
                    <button type="button" class="btn-ui btn-soft" onclick="limpiarFiltrosTR()">
                        <i class="bi bi-eraser"></i>
                        Limpiar filtros
                    </button>
                </div>

                <div class="result-counter" id="contadorTR">Mostrando 0 registros</div>

                <div class="table-scroll">
                    <table class="table-ui" id="tablaTR">
                        <thead>
                            <tr>
                                <th style="width:70px;">Sel.</th>
                                <th>ID</th>
                                <th>Sucursal</th>
                                <th>Consecutivo</th>
                                <th>Fecha Solicitud</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (transferencias.Any())
                            {
                                @foreach (var tr in transferencias)
                                {
                                    <tr data-sucursal="@tr.Sucursal"
                                        data-consecutivo="@tr.Consecutivo"
                                        data-fecha="@tr.FechaSolicitud?.ToShortDateString()">
                                        <td data-label="Seleccionar">
                                            <input type="checkbox"
                                                   class="check-ui"
                                                   name="transferenciasSeleccionadas"
                                                   value="@tr.Id" />
                                        </td>
                                        <td data-label="ID"><span class="id-badge">#@tr.Id</span></td>
                                        <td data-label="Sucursal">@tr.Sucursal</td>
                                        <td data-label="Consecutivo">@tr.Consecutivo</td>
                                        <td data-label="Fecha">@tr.FechaSolicitud?.ToShortDateString()</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="empty-note">
                                        No hay transferencias disponibles para mostrar.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </form>
</div>

<script>

    function irASeccion(id) {
        const seccion = document.getElementById(id);

        if (!seccion) {
            console.warn("No se encontró la sección:", id);
            return;
        }

        const toolbar = document.querySelector(".floating-toolbar");
        const toolbarHeight = toolbar ? toolbar.offsetHeight : 0;

        const extraOffset = 18;

        const posicion =
            seccion.getBoundingClientRect().top +
            window.pageYOffset -
            toolbarHeight -
            extraOffset;

        window.scrollTo({
            top: posicion,
            behavior: "smooth"
        });
    }

    function normalizar(valor) {
        return (valor || "").toString().trim().toLowerCase();
    }

    function actualizarContador(tableId, counterId) {
        const table = document.getElementById(tableId);
        const counter = document.getElementById(counterId);
        if (!table || !counter) return;

        const filas = [...table.querySelectorAll("tbody tr")]
            .filter(f => !f.querySelector(".empty-note") && f.style.display !== "none");

        counter.textContent = `Mostrando ${filas.length} registro(s)`;
    }

    function filtrarOV() {
        const table = document.getElementById("tablaOV");
        if (!table) return;

        const general = normalizar(document.getElementById("buscarOV").value);
        const cliente = normalizar(document.getElementById("filtroClienteOV").value);
        const consecutivo = normalizar(document.getElementById("filtroConsecutivoOV").value);
        const ruta = normalizar(document.getElementById("filtroRutaOV").value);
        const modo = document.getElementById("soloSeleccionadasOV").value;

        const filas = table.querySelectorAll("tbody tr");

        filas.forEach(fila => {
            if (fila.querySelector(".empty-note")) return;

            const txtCliente = normalizar(fila.dataset.cliente);
            const txtConsecutivo = normalizar(fila.dataset.consecutivo);
            const txtRuta = normalizar(fila.dataset.ruta);
            const textoCompleto = normalizar(fila.innerText);
            const check = fila.querySelector('input[type="checkbox"]');
            const seleccionada = check ? check.checked : false;

            const cumpleGeneral = !general || textoCompleto.includes(general);
            const cumpleCliente = !cliente || txtCliente.includes(cliente);
            const cumpleConsecutivo = !consecutivo || txtConsecutivo.includes(consecutivo);
            const cumpleRuta = !ruta || txtRuta.includes(ruta);

            let cumpleSeleccion = true;
            if (modo === "seleccionadas") cumpleSeleccion = seleccionada;
            if (modo === "noseleccionadas") cumpleSeleccion = !seleccionada;

            fila.style.display =
                cumpleGeneral &&
                cumpleCliente &&
                cumpleConsecutivo &&
                cumpleRuta &&
                cumpleSeleccion
                    ? ""
                    : "none";
        });

        actualizarContador("tablaOV", "contadorOV");
    }

    function filtrarTR() {
        const table = document.getElementById("tablaTR");
        if (!table) return;

        const general = normalizar(document.getElementById("buscarTR").value);
        const sucursal = normalizar(document.getElementById("filtroSucursalTR").value);
        const consecutivo = normalizar(document.getElementById("filtroConsecutivoTR").value);
        const fecha = normalizar(document.getElementById("filtroFechaTR").value);
        const modo = document.getElementById("soloSeleccionadasTR").value;

        const filas = table.querySelectorAll("tbody tr");

        filas.forEach(fila => {
            if (fila.querySelector(".empty-note")) return;

            const txtSucursal = normalizar(fila.dataset.sucursal);
            const txtConsecutivo = normalizar(fila.dataset.consecutivo);
            const txtFecha = normalizar(fila.dataset.fecha);
            const textoCompleto = normalizar(fila.innerText);
            const check = fila.querySelector('input[type="checkbox"]');
            const seleccionada = check ? check.checked : false;

            const cumpleGeneral = !general || textoCompleto.includes(general);
            const cumpleSucursal = !sucursal || txtSucursal.includes(sucursal);
            const cumpleConsecutivo = !consecutivo || txtConsecutivo.includes(consecutivo);
            const cumpleFecha = !fecha || txtFecha.includes(fecha);

            let cumpleSeleccion = true;
            if (modo === "seleccionadas") cumpleSeleccion = seleccionada;
            if (modo === "noseleccionadas") cumpleSeleccion = !seleccionada;

            fila.style.display =
                cumpleGeneral &&
                cumpleSucursal &&
                cumpleConsecutivo &&
                cumpleFecha &&
                cumpleSeleccion
                    ? ""
                    : "none";
        });

        actualizarContador("tablaTR", "contadorTR");
    }

    function limpiarFiltrosOV() {
        document.getElementById("buscarOV").value = "";
        document.getElementById("filtroClienteOV").value = "";
        document.getElementById("filtroConsecutivoOV").value = "";
        document.getElementById("filtroRutaOV").value = "";
        document.getElementById("soloSeleccionadasOV").value = "todas";
        filtrarOV();
    }

    function limpiarFiltrosTR() {
        document.getElementById("buscarTR").value = "";
        document.getElementById("filtroSucursalTR").value = "";
        document.getElementById("filtroConsecutivoTR").value = "";
        document.getElementById("filtroFechaTR").value = "";
        document.getElementById("soloSeleccionadasTR").value = "todas";
        filtrarTR();
    }

    function enlazarEventosOV() {
        ["buscarOV", "filtroClienteOV", "filtroConsecutivoOV", "filtroRutaOV", "soloSeleccionadasOV"]
            .forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    el.addEventListener("input", filtrarOV);
                    el.addEventListener("change", filtrarOV);
                }
            });

        document.querySelectorAll('#tablaOV input[type="checkbox"]').forEach(chk => {
            chk.addEventListener("change", filtrarOV);
        });
    }

    function enlazarEventosTR() {
        ["buscarTR", "filtroSucursalTR", "filtroConsecutivoTR", "filtroFechaTR", "soloSeleccionadasTR"]
            .forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    el.addEventListener("input", filtrarTR);
                    el.addEventListener("change", filtrarTR);
                }
            });

        document.querySelectorAll('#tablaTR input[type="checkbox"]').forEach(chk => {
            chk.addEventListener("change", filtrarTR);
        });
    }

    document.addEventListener("DOMContentLoaded", function () {
        enlazarEventosOV();
        enlazarEventosTR();

        document.getElementById("buscarOV").value = "";
        document.getElementById("filtroClienteOV").value = "";
        document.getElementById("filtroConsecutivoOV").value = "";
        document.getElementById("filtroRutaOV").value = "";
        document.getElementById("soloSeleccionadasOV").value = "todas";

        document.getElementById("buscarTR").value = "";
        document.getElementById("filtroSucursalTR").value = "";
        document.getElementById("filtroConsecutivoTR").value = "";
        document.getElementById("filtroFechaTR").value = "";
        document.getElementById("soloSeleccionadasTR").value = "todas";

        filtrarOV();
        filtrarTR();
    });

    window.addEventListener("pageshow", function () {
        filtrarOV();
        filtrarTR();
    });

    const inputNombreEmbarque = document.getElementById("nombreEmbarque");
