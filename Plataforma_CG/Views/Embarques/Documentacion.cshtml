</style>

<div class="docs-page">

    <div class="page-header">
        <div class="page-header-left">
            <div class="header-icon">
                <i class="bi bi-folder2-open"></i>
            </div>
            <div>
                <h1 class="page-title">Documentación de Embarques</h1>
                <div class="page-subtitle">
                    Configura si el embarque requiere Carta Porte y carga el documento correspondiente cuando aplique.
                </div>
            </div>
        </div>

        <div class="page-header-right">
            <span class="header-chip">
                <i class="bi bi-calendar3"></i>
                @DateTime.Now.ToShortDateString()
            </span>

            <a class="btn-top btn-top-light" href="@Url.Action("Embarque", "Embarques")">
                <i class="bi bi-arrow-left-circle"></i> Volver
            </a>
        </div>
    </div>

    <div class="summary-grid">
        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-truck"></i>
            </div>
            <div>
                <div class="summary-label">Embarques</div>
                <div class="summary-value">@totalEmbarques</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <div>
                <div class="summary-label">Pendientes</div>
                <div class="summary-value">@pendientes.Count</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-file-earmark-check"></i>
            </div>
            <div>
                <div class="summary-label">Con Carta Porte</div>
                <div class="summary-value">@conCartaPorte</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-dash-circle"></i>
            </div>
            <div>
                <div class="summary-label">No aplica</div>
                <div class="summary-value">@cartaPorteNoAplica</div>
            </div>
        </div>
    </div>

    <div class="docs-filter-panel">
        <div class="docs-filter-title">
            <i class="bi bi-funnel"></i>
            Filtros de búsqueda
        </div>

        <form method="get" asp-action="Documentacion" class="docs-filter-grid">
            <div>
                <label class="form-label-ui">Buscar embarque</label>
                <input type="text"
                       name="busqueda"
                       value="@busqueda"
                       class="input-text-ui"
                       placeholder="Ej. EMB-0001, 125, consecutivo..." />
            </div>

            <div>
                <label class="form-label-ui">Fecha inicio</label>
                <input type="date"
                       name="fechaInicio"
                       value="@fechaInicio"
                       class="input-date-ui" />
            </div>

            <div>
                <label class="form-label-ui">Fecha fin</label>
                <input type="date"
                       name="fechaFin"
                       value="@fechaFin"
                       class="input-date-ui" />
            </div>

            <button type="submit" class="btn-ui btn-primary-ui">
                <i class="bi bi-search"></i>
                Buscar
            </button>

            <a asp-action="Documentacion" class="btn-ui btn-secondary-ui">
                <i class="bi bi-arrow-clockwise"></i>
                Limpiar
            </a>
        </form>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        </div>
    }

    @if (Model == null)
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h4 class="mb-2">No hay información para mostrar</h4>
            <p class="mb-0">Intenta actualizar la página o revisar los filtros.</p>
        </div>
    }
    else
    {
        <div class="section-block">
            <div class="section-head">
                <div>
                    <h2 class="section-title">
                        <i class="bi bi-hourglass-split"></i>
                        Embarques pendientes
                    </h2>
                    <div class="section-subtitle">
                        Aquí se muestran los embarques que aún requieren validación logística.
                    </div>
                </div>

                <span class="header-chip">
                    <i class="bi bi-truck"></i>
                    @pendientes.Count pendiente(s)
                </span>
            </div>

            @if (!pendientes.Any())
            {
                <div class="mini-empty">
                    <i class="bi bi-check-circle me-2"></i>
                    No hay embarques pendientes por validar.
                </div>
            }
            else
            {
                <div class="docs-list">
                    @foreach (var e in pendientes)
                    {
                        var archivos = e.Archivos ?? new List<Plataforma_CG.Models.EmbarqueArchivo>();
                        var cartasPorte = archivos.Where(a => a.Tipo == "CARTA_PORTE").ToList();
                        var tieneCartaPorte = cartasPorte.Any();

                        var documentacionAprobada = e.DocumentacionAprobada == true;
                        var cardId = $"pendiente_{e.Id}";

                        var cartaPorteSinDefinir = e.RequiereCartaPorte == null;
                        var cartaPorteRequerida = e.RequiereCartaPorte == true;
                        var cartaPorteNoAplicaLocal = e.RequiereCartaPorte == false;

                        var cartaPorteOk = cartaPorteNoAplicaLocal || (cartaPorteRequerida && tieneCartaPorte);

                        var textoCartaPorte =
                        cartaPorteSinDefinir ? "Carta Porte sin definir" :
                        cartaPorteNoAplicaLocal ? "Carta Porte no aplica" :
                        tieneCartaPorte ? "Carta Porte cargada" :
                        "Carta Porte requerida";

                        <div class="embarque-card" id="@cardId">
                            <div class="embarque-head" onclick="toggleCard('@cardId')">
                                <div>
                                    <h3 class="embarque-title">
                                        <i class="bi bi-truck-front"></i>
                                        Embarque #@e.Consecutivo
                                    </h3>
                                    <div class="embarque-sub">
                                        ID: @e.Id · Fecha de creación: @e.FechaCreacion.ToString("yyyy-MM-dd HH:mm")
                                    </div>
                                </div>

                                <div class="head-badges">
                                    <span class="badge-soft @(cartaPorteOk ? "ok" : "pending")">
                                        <i class="bi bi-file-earmark-text"></i>
                                        @textoCartaPorte
                                    </span>

                                    <span class="badge-soft @(documentacionAprobada ? "ok" : "pending")">
                                        <i class="bi bi-folder-check"></i>
                                        Documentación @(documentacionAprobada ? "validada" : "pendiente")
                                    </span>

                                    <button type="button" class="toggle-btn" onclick="event.stopPropagation(); toggleCard('@cardId')">
                                        <i class="bi bi-chevron-down"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="embarque-body">
                                <form asp-action="CargarDocumentos" method="post" enctype="multipart/form-data">
                                    <input type="hidden" name="id" value="@e.Id" />

                                    <div class="porte-workflow">

                                        <div class="porte-panel">
                                            <div class="porte-panel-head">
                                                <div class="porte-panel-icon">
                                                    <i class="bi bi-ui-checks-grid"></i>
                                                </div>
                                                <div>
                                                    <h5 class="porte-panel-title">Decisión logística</h5>
                                                    <div class="porte-panel-sub">
                                                        Define si este embarque requiere Carta Porte.
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="porte-panel-body">
                                                <div class="porte-options">
                                                    <label class="porte-option">
                                                        <input type="radio"
                                                               name="requiereCartaPorte"
                                                               value="true"
                                                               required
                                                               @(e.RequiereCartaPorte == true ? "checked" : "") />

                                                        <div>
                                                            <strong>Sí requiere Carta Porte</strong>
                                                            <span>Usar cuando la unidad sea de planta o logística deba generar Carta Porte.</span>
                                                        </div>
                                                    </label>

                                                    <label class="porte-option">
                                                        <input type="radio"
                                                               name="requiereCartaPorte"
                                                               value="false"
                                                               required
                                                               @(e.RequiereCartaPorte == false ? "checked" : "") />

                                                        <div>
                                                            <strong>No aplica Carta Porte</strong>
                                                            <span>Usar cuando la unidad sea externa o no corresponda Carta Porte.</span>
                                                        </div>
                                                    </label>
                                                </div>

                                                @if (cartaPorteSinDefinir)
                                                {
                                                    <div class="porte-status pending">
                                                        <i class="bi bi-exclamation-triangle"></i>
                                                        Pendiente: selecciona si Carta Porte aplica o no aplica.
                                                    </div>
                                                }
                                                else if (cartaPorteRequerida && !tieneCartaPorte)
                                                {
                                                    <div class="porte-status pending">
                                                        <i class="bi bi-exclamation-triangle"></i>
                                                        Requiere Carta Porte. Debes cargar el archivo para validar.
                                                    </div>
                                                }
                                                else if (cartaPorteNoAplicaLocal)
                                                {
                                                    <div class="porte-status info">
                                                        <i class="bi bi-info-circle"></i>
                                                        Carta Porte marcada como No aplica.
                                                    </div>
                                                }
                                                else if (cartaPorteRequerida && tieneCartaPorte)
                                                {
                                                    <div class="porte-status ok">
                                                        <i class="bi bi-check-circle"></i>
                                                        Carta Porte requerida y cargada correctamente.
                                                    </div>
                                                }
                                        </div>
                                    </div>

                                    <div class="porte-upload-card">
                                        <div class="porte-panel-head">
                                            <div class="porte-panel-icon">
                                                <i class="bi bi-file-earmark-arrow-up"></i>
                                            </div>
                                            <div>
                                                <h5 class="porte-panel-title">Archivo Carta Porte</h5>
                                                <div class="porte-panel-sub">
                                                    Carga el PDF, XML o documento correspondiente si aplica.
                                                </div>
                                            </div>
                                        </div>

                                        <div class="porte-panel-body">
                                            <div class="porte-upload-area" id="uploadBox_cartaPorte_@e.Id">
                                                <label class="form-label-ui">Selecciona archivo</label>

                                                <input type="file"
                                                       name="cartaPorteArchivos"
                                                       multiple
                                                       class="input-file-ui"
                                                       accept=".pdf,.xml,.jpg,.jpeg,.png,.doc,.docx"
                                                       onchange="mostrarArchivoSeleccionado(this, 'uploadBox_cartaPorte_@e.Id', 'preview_cartaPorte_@e.Id', 'name_cartaPorte_@e.Id')" />

                                                <div class="hint-text">
                                                    Formatos permitidos: PDF, XML, JPG, PNG, DOC y DOCX.
                                                </div>

                                                <div class="selected-file-preview" id="preview_cartaPorte_@e.Id">
                                                    <div class="selected-file-label">Archivo seleccionado</div>
                                                    <div class="selected-file-name" id="name_cartaPorte_@e.Id"></div>
                                                </div>
                                            </div>

                                            <div class="porte-status @(cartaPorteOk ? "ok" : "pending")">
                                                <i class="bi @(cartaPorteOk ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
                                                @(
                                                                                        cartaPorteNoAplicaLocal
                                                                                        ? "Carta Porte marcada como No aplica."
                                                                                        : tieneCartaPorte
                                                                                        ? "Ya existe al menos una Carta Porte cargada."
                                                                                        : cartaPorteRequerida
                                                                                        ? "Carta Porte requerida. Debes cargar el archivo."
                                                                                        : "Primero indica si Carta Porte aplica o no aplica."
                                                                                        )
                                            </div>

                                    @if (tieneCartaPorte)
                                                {
                                                    <div class="porte-current-files">
                                                        <div class="form-label-ui mb-2">Archivos cargados</div>

                                                        <div class="porte-file-list">
                                                            @foreach (var archivo in cartasPorte)
                                                            {
                                                                <a href="@archivo.RutaArchivo" target="_blank" class="porte-file-link">
                                                                    <span>
                                                                        <i class="bi bi-file-earmark-text me-1"></i>
                                                                        Carta Porte #@archivo.Id
                                                                    </span>
                                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                                </a>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <div class="porte-actions">
                                        <button type="submit" class="btn-ui btn-primary-ui">
                                            <i class="bi bi-check2-circle"></i>
                                            Guardar validación logística
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="section-block">
            <div class="section-head">
                <div>
                    <h2 class="section-title">
                        <i class="bi bi-clock-history"></i>
                        Histórico de documentación logística
                    </h2>
                    <div class="section-subtitle">
                        Consulta embarques ya validados por documentación logística. No carga registros hasta seleccionar un rango de fechas.
                    </div>
                </div>

                <span class="header-chip" style="background:#fff;color:var(--primary);border-color:var(--border);">
                    <i class="bi bi-folder-check"></i>
                    @historialDocumentacion.Count registro(s)
                </span>
            </div>

            <div class="docs-filter-panel">
                <div class="docs-filter-title">
                    <i class="bi bi-funnel"></i>
                    Filtros de historial
                </div>

                <form method="get" asp-action="Documentacion" class="docs-filter-grid">
                    <input type="hidden" name="busqueda" value="@busqueda" />
                    <input type="hidden" name="fechaInicio" value="@fechaInicio" />
                    <input type="hidden" name="fechaFin" value="@fechaFin" />

                    <div>
                        <label class="form-label-ui">Buscar embarque</label>
                        <input type="text"
                               name="busquedaHistorial"
                               value="@busquedaHistorial"
                               class="input-text-ui"
                               placeholder="Ej. EMB-0001, 125, nombre..." />
                    </div>

                    <div>
                        <label class="form-label-ui">Fecha validación inicio</label>
                        <input type="date"
                               name="fechaInicioHistorial"
                               value="@fechaInicioHistorial"
                               class="input-date-ui" />
                    </div>

                    <div>
                        <label class="form-label-ui">Fecha validación fin</label>
                        <input type="date"
                               name="fechaFinHistorial"
                               value="@fechaFinHistorial"
                               class="input-date-ui" />
                    </div>

                    <button type="submit" class="btn-ui btn-primary-ui">
                        <i class="bi bi-search"></i>
                        Buscar historial
                    </button>

                    <a asp-action="Documentacion"
                       asp-route-busqueda="@busqueda"
                       asp-route-fechaInicio="@fechaInicio"
                       asp-route-fechaFin="@fechaFin"
                       class="btn-ui btn-secondary-ui">
                        <i class="bi bi-arrow-clockwise"></i>
                        Limpiar historial
                    </a>
                </form>
            </div>

            @if (!buscoHistorialDocumentacion)
            {
                <div class="empty-state">
                    <i class="bi bi-calendar-range"></i>
                    <h4 class="mb-2">Selecciona un rango de fechas</h4>
                    <p class="mb-0">
                        El historial de documentación logística no carga información hasta que indiques fecha inicio y fecha fin.
                    </p>
                </div>
            }
            else if (!historialDocumentacion.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-search"></i>
                    <h4 class="mb-2">No se encontraron registros</h4>
                    <p class="mb-0">
                        No existen embarques validados por documentación logística dentro del rango seleccionado.
                    </p>
                </div>
            }
            else
            {
                <div class="docs-list">
                    @foreach (var e in historialDocumentacion)
                    {
                        var cardId = $"hist_doc_logistica_{e.Id}";
                        var tieneCualquierDocumento = tiposLogistica.Any(t => e.Archivos.Any(a => a.Tipo == t.Tipo));

                        <div class="embarque-card" id="@cardId">
                            <div class="embarque-head" onclick="toggleCard('@cardId')">
                                <div>
                                    <h3 class="embarque-title">
                                        <i class="bi bi-folder-check"></i>
                                        Embarque #@e.Consecutivo
                                    </h3>
                                    <div class="embarque-sub">
                                        ID: @e.Id · Validado:
                                        @(e.FechaValidacionDocumentacion?.ToString("yyyy-MM-dd HH:mm") ?? "Sin fecha")
                                        · Usuario:
                                        @(e.UsuarioValidaDocumentacion ?? "Sistema")
                                    </div>
                                </div>

                                <div class="head-badges">
                                    <span class="badge-soft @(tieneCualquierDocumento ? "ok" : "pending")">
                                        <i class="bi bi-file-earmark-check"></i>
                                        @(tieneCualquierDocumento ? "Con documentos" : "Sin documentos")
                                    </span>

                                    <span class="badge-soft @(e.RequiereCartaPorte == false ? "ok" : "pending")">
                                        <i class="bi bi-truck"></i>
                                        Carta Porte @(e.RequiereCartaPorte == false ? "No aplica" : "Aplica")
                                    </span>

                                    <span class="badge-soft ok">
                                        <i class="bi bi-check-circle"></i>
                                        Validado
                                    </span>

                                    <button type="button" class="toggle-btn" onclick="event.stopPropagation(); toggleCard('@cardId')">
                                        <i class="bi bi-chevron-down"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="embarque-body">
                                <div class="docs-grid">
                                    @foreach (var tipo in tiposLogistica)
                                    {
                                        var archivos = e.Archivos.Where(a => a.Tipo == tipo.Tipo).ToList();
                                        var tieneArchivo = archivos.Any();

                                        <div class="doc-box @(tieneArchivo ? "doc-box-ok" : "")">
                                            <div class="doc-box-head">
                                                <div class="doc-icon">
                                                    <i class="bi @tipo.Icon"></i>
                                                </div>
                                                <div>
                                                    <h5 class="doc-title">@tipo.Label</h5>
                                                    <div class="doc-sub">@tipo.Sub</div>
                                                </div>
                                            </div>

                                            <div class="file-status @(tieneArchivo ? "ok" : "pending")">
                                                @(tieneArchivo ? $"{archivos.Count} archivo(s) cargado(s)." : "No se cargó este documento.")
                                            </div>

                                            @if (tieneArchivo)
                                            {
                                                <div class="mt-2">
                                                    @foreach (var archivo in archivos)
                                                    {
                                                        <a href="@archivo.RutaArchivo" target="_blank" class="file-link d-flex">
                                                            <i class="bi bi-box-arrow-up-right"></i>
                                                            Ver @tipo.Label #@archivo.Id
                                                        </a>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<script>
    function toggleCard(cardId) {
        const card = document.getElementById(cardId);
        if (card) {
            card.classList.toggle("active");
        }
    }

    function toggleSection(sectionId) {
        const section = document.getElementById(sectionId);
        if (section) {
            section.classList.toggle("collapsed");
        }
    }

    function mostrarArchivoSeleccionado(input, uploadBoxId, previewId, nameId) {
        const uploadBox = document.getElementById(uploadBoxId);
        const preview = document.getElementById(previewId);
        const name = document.getElementById(nameId);

        if (!uploadBox || !preview || !name) return;

        if (input.files && input.files.length > 0) {
            uploadBox.classList.add("has-selected-file");
            preview.classList.add("active");

            if (input.files.length === 1) {
                name.textContent = input.files[0].name;
            } else {
                name.textContent = input.files.length + " archivos seleccionados";
            }
        } else {
            uploadBox.classList.remove("has-selected-file");
            preview.classList.remove("active");
            name.textContent = "";
        }
    }
</script>