        function buildPalletWithLoad(pedido) {
            const g = new THREE.Group();
            g.userData = {
                tipo: 'pallet',
                id: pedido.id,
                overflow: false
            };

            const deck = new THREE.Mesh(
                new THREE.BoxGeometry(PALLET.L, PALLET.H, PALLET.A),
                new THREE.MeshStandardMaterial({ color: 0x8b6b4a, roughness: 0.9 })
            );

            deck.position.y = PALLET.H / 2;
            deck.castShadow = true;
            deck.receiveShadow = true;
            g.add(deck);

            const layout = getVisualLayout(pedido);

            const boxMat = new THREE.MeshStandardMaterial({
                color: new THREE.Color(pedido.color),
                roughness: 0.7
            });

            let colocadas = 0;

            const totalL = layout.cols * layout.boxL + Math.max(0, layout.cols - 1) * layout.gapX;
            const totalA = layout.rows * layout.boxA + Math.max(0, layout.rows - 1) * layout.gapZ;

            const startX = -totalL / 2 + layout.boxL / 2;
            const startZ = -totalA / 2 + layout.boxA / 2;

            for (let k = 0; k < layout.capas; k++) {
                for (let i = 0; i < layout.cols; i++) {
                    for (let j = 0; j < layout.rows; j++) {
                        if (colocadas >= layout.cajas) break;

                        const box = new THREE.Mesh(
                            new THREE.BoxGeometry(layout.boxL, layout.boxH, layout.boxA),
                            boxMat
                        );

                        const x0 = startX + i * (layout.boxL + layout.gapX);
                        const z0 = startZ + j * (layout.boxA + layout.gapZ);
                        const y0 = PALLET.H + layout.boxH / 2 + k * (layout.boxH + layout.gapY);

                        box.position.set(x0, y0, z0);
                        box.castShadow = true;
                        box.receiveShadow = true;
                        box.userData = {
                            nombre: pedido.nombre,
                            sku: pedido.sku
                        };

                        g.add(box);
                        colocadas++;
                    }
                }
            }

            g.traverse(o => {
                if (o.isMesh) {
                    o.castShadow = true;
                    o.receiveShadow = true;
                }
            });

            return g;
        }

          // ====== Autoacomodo 2 columnas ======
        let grupos = [];

        function disposePalletGroup(g) {
            if (!g) return;

            const geometries = new Set();
            const materials = new Set();

            g.traverse(o => {
                if (o.geometry) geometries.add(o.geometry);

                if (o.material) {
                    if (Array.isArray(o.material)) {
                        o.material.forEach(m => materials.add(m));
                    } else {
                        materials.add(o.material);
                    }
                }
            });

            scene.remove(g);

            geometries.forEach(geo => geo.dispose && geo.dispose());
            materials.forEach(mat => mat.dispose && mat.dispose());
        }

        function limpiarPallets() {
            tControls.detach();

            grupos.forEach(g => disposePalletGroup(g));
            grupos = [];
            lastValidTransforms.clear();
        }

        function getZPositions(maxCols, pasillo) {
            const totalA = maxCols * PALLET.A + Math.max(0, maxCols - 1) * pasillo;
            const startZ = -totalA / 2 + PALLET.A / 2;

            return Array.from({ length: maxCols }, (_, i) => {
                return startZ + i * (PALLET.A + pasillo);
            });
        }

        function acomodar() {
            limpiarPallets();

            const margenX = 0.10;
            const margenZ = 0.08;
            const pasillo = 0.05;
            const stepX = PALLET.L + 0.05;

            const maxCols = Math.max(
                1,
                Math.min(
                    2,
                    Math.floor((TRAILER.ancho - margenZ * 2 + pasillo) / (PALLET.A + pasillo))
                )
            );

            const zPositions = getZPositions(maxCols, pasillo);

            let slot = 0;
            let overflowSlot = 0;
            let usadoLong = 0;
            let pesoTotal = 0;
            let dentro = 0;
            let fuera = 0;

            for (const p of pedidos) {
                const g = buildPalletWithLoad(p);

                const col = slot % maxCols;
                const fila = Math.floor(slot / maxCols);

                const x_rel = -TRAILER.largo / 2 + margenX + PALLET.L / 2 + fila * stepX;
                const frenteMax_rel = TRAILER.largo / 2 - margenX - PALLET.L / 2;

                const x = rig.position.x + x_rel;
                const z = zPositions[col] || 0;

                if (x_rel > frenteMax_rel) {
                    const oCol = overflowSlot % maxCols;
                    const oFila = Math.floor(overflowSlot / maxCols);

                    g.userData.overflow = true;

                    g.position.set(
                        FIXED_BACK + PALLET.L / 2 + 0.2 + oFila * stepX,
                        DOCK_HEIGHT + PALLET.H / 2,
                        zPositions[oCol] || 0
                    );

                    g.traverse(o => {
                        if (o.isMesh && o.material?.color) {
                            o.material = o.material.clone();
                            o.material.color = new THREE.Color(0xff5555);

                            if ('transparent' in o.material) {
                                o.material.transparent = true;
                                o.material.opacity = 0.85;
                            }
                        }
                    });

                    fuera++;
                    overflowSlot++;
                } else {
                    g.userData.overflow = false;

                    g.position.set(
                        x,
                        DOCK_HEIGHT + PALLET.H / 2,
                        z
                    );

                    usadoLong = Math.max(
                        usadoLong,
                        x_rel + PALLET.L / 2 + TRAILER.largo / 2
                    );

                    pesoTotal += Number(p.peso || 0);
                    dentro++;
                }

                grupos.push(g);
                scene.add(g);

                rememberValidTransform(g);
                slot++;
            }

            const volumenTrailer = TRAILER.largo * TRAILER.ancho * TRAILER.alto;
            const volumenCargas = pedidos.reduce((s, p) => {
                return s + (PALLET.L * PALLET.A * PALLET.H + p.cajas * p.boxL * p.boxA * p.boxH);
            }, 0);

            const ocupacion = volumenTrailer > 0
                ? (volumenCargas / volumenTrailer) * 100
                : 0;

            stats.textContent =
                `Tarimas dentro: ${dentro} | Fuera por espacio: ${fuera} | Longitud usada aprox: ${fmt(usadoLong)} m / ${TRAILER.largo} m | ` +
                `Peso dentro: ${pesoTotal.toLocaleString()} kg | Volumen ocupado: ${ocupacion.toFixed(1)}%`;

            if (selectedId) {
                selectById(selectedId);
            }
        }


          // ====== Selección / movimiento ======
          function selectById(id){
            selectedId = id;
            selectedGroup = grupos.find(g => g.userData?.id === id) || null;
            if (selectedGroup) {
              tControls.attach(selectedGroup);
              clampInsideTrailer(selectedGroup);
            } else {
              tControls.detach();
            }
            const p = pedidos.find(x => x.id === id);
            fillLayoutForm(p);
            highlightSelection();
          }
          // Limitar dentro de la caja considerando rotación (footprint)
          function clampInsideTrailer(obj){
            const margen = 0.05;
            const theta = (obj.rotation.y % (Math.PI*2) + Math.PI*2) % (Math.PI*2);
            const c = Math.abs(Math.cos(theta)), s = Math.abs(Math.sin(theta));
            // footprint de la tarima rotada
            const halfFootL = (c*PALLET.L + s*PALLET.A)/2 + margen;
            const halfFootA = (c*PALLET.A + s*PALLET.L)/2 + margen;
            const centerX = rig.position.x; // Centro absoluto del tráiler
            const halfL = TRAILER.largo/2 - halfFootL;
            const halfA = TRAILER.ancho/2 - halfFootA;
            obj.position.x = Math.max(centerX - halfL, Math.min(centerX + halfL, obj.position.x));
            obj.position.z = Math.max(-halfA, Math.min(halfA, obj.position.z));
            obj.position.y = DOCK_HEIGHT + PALLET.H/2; // altura fija (suelo)
          }

                  function getPalletFootprint(obj) {
            const theta = (obj.rotation.y % (Math.PI * 2) + Math.PI * 2) % (Math.PI * 2);
            const c = Math.abs(Math.cos(theta));
            const s = Math.abs(Math.sin(theta));

            const halfL = (c * PALLET.L + s * PALLET.A) / 2 + PALLET_COLLISION_MARGIN;
            const halfA = (c * PALLET.A + s * PALLET.L) / 2 + PALLET_COLLISION_MARGIN;

            return {
                minX: obj.position.x - halfL,
                maxX: obj.position.x + halfL,
                minZ: obj.position.z - halfA,
                maxZ: obj.position.z + halfA
            };
        }

        function footprintsOverlap(a, b) {
            return !(
                a.maxX <= b.minX ||
                a.minX >= b.maxX ||
                a.maxZ <= b.minZ ||
                a.minZ >= b.maxZ
            );
        }

        function hasPalletCollision(obj) {
            if (!obj || obj.userData?.overflow) return false;

            const a = getPalletFootprint(obj);

            return grupos.some(other => {
                if (!other || other === obj) return false;
                if (other.userData?.overflow) return false;

                const b = getPalletFootprint(other);
                return footprintsOverlap(a, b);
            });
        }

        function rememberValidTransform(obj) {
            if (!obj?.userData?.id) return;

            lastValidTransforms.set(obj.userData.id, {
                x: obj.position.x,
                y: obj.position.y,
                z: obj.position.z,
                rotationY: obj.rotation.y
            });
        }

        function restoreLastValidTransform(obj) {
            if (!obj?.userData?.id) return;

            const last = lastValidTransforms.get(obj.userData.id);
            if (!last) return;

            obj.position.set(last.x, last.y, last.z);
            obj.rotation.y = last.rotationY;
        }

        function showCollisionHint() {
            info.textContent = 'No se puede colocar ahí: se encima con otra tarima.';

            clearTimeout(collisionWarnTimer);
            collisionWarnTimer = setTimeout(() => {
                info.textContent = 'Mapa de carga del tráiler';
            }, 1600);
        }

        function validateSelectedPosition(showMessage) {
            if (!selectedGroup) return;

            clampInsideTrailer(selectedGroup);

            if (hasPalletCollision(selectedGroup)) {
                restoreLastValidTransform(selectedGroup);

                if (showMessage) {
                    showCollisionHint();
                }

                return;
            }

            rememberValidTransform(selectedGroup);
        }

          // Hover / click 3D para seleccionar
          const raycaster = new THREE.Raycaster();
          const mouse = new THREE.Vector2(); let hovered = null;
          wrapper.addEventListener('pointermove', e=>{
            const rect = renderer.domElement.getBoundingClientRect();
            mouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
            mouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;
            raycaster.setFromCamera(mouse, camera);
            const hits = raycaster.intersectObjects(grupos.flatMap(g => g.children));
            const carga = hits.find(h => h.object.userData && (h.object.userData.nombre || h.object.userData.sku));
            if(carga){
              if(hovered && hovered!==carga.object){ hovered.material.emissive && hovered.material.emissive.setHex(0x000000); }
              hovered = carga.object; if(!hovered.material.emissive) hovered.material.emissive = new THREE.Color(0x000000);
              hovered.material.emissive.setHex(0x222222);
              const ud = hovered.userData;
              info.textContent = `${ud.nombre || 'Tarima'} — ${ud.sku || ''}`;
            } else {
              if(hovered){ hovered.material.emissive.setHex(0x000000); hovered=null; }
              info.textContent = 'Mapa de carga del tráiler';
            }
          });
          wrapper.addEventListener('pointerdown', e=>{
            const rect = renderer.domElement.getBoundingClientRect();
            mouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
            mouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;
            raycaster.setFromCamera(mouse, camera);
            const meshes = grupos.flatMap(g => g.children.filter(c => c.isMesh));
            const hits = raycaster.intersectObjects(meshes, true);
            if (hits.length){
              const target = hits[0].object;
              const g = grupos.find(gr => target === gr || gr.children.includes(target) || target.parent === gr);
              if (g) selectById(g.userData.id);
            }
          });
          // ====== Panel de layout ======
          function fillLayoutForm(p) {
            if (!p) { [inCapas, inCols, inRows, inCajas].forEach(i=> i.value = ''); return; }
            inCapas.value = p.capas; inCols.value = p.cols; inRows.value = p.rows; inCajas.value = p.cajas;
            updateCapasHint(p);
          }
        function updateCapasHint(p) {
            const interiorH = TRAILER.alto - FLOOR_THK - WALL_THK;
            const maxCapas = getMaxCapasByHeight(p);

            capasHint.textContent =
                `Altura útil ${fmt(interiorH)} m · Máx capas visuales por altura: ${maxCapas} · ` +
                `Si hay muchas cajas, el mapa las compacta visualmente para cuidar rendimiento.`;
        }
          function applyLayoutForm() {
            if (!selectedId) return;
            const idx = pedidos.findIndex(x => x.id === selectedId);
            if (idx < 0) return;
            let capas = Math.max(1, parseInt(inCapas.value || '1', 10));
            let cols = Math.max(1, parseInt(inCols.value || '1', 10));
            let rows = Math.max(1, parseInt(inRows.value || '1', 10));
            let cajas = Math.max(1, parseInt(inCajas.value || '1', 10));
            // Capar capas por altura útil
            const pTmp = pedidos[idx];
            const interiorH = TRAILER.alto - FLOOR_THK - WALL_THK;
            const maxCapasAltura = Math.max(1, Math.floor((interiorH - PALLET.H) / pTmp.boxH));
            if (capas > maxCapasAltura) capas = maxCapasAltura;
            const maxColocable = capas * cols * rows;
            if (cajas > maxColocable) cajas = maxColocable;
            const p = pedidos[idx];

            p.capas = capas;
            p.cols = cols;
            p.rows = rows;
            p.cajas = cajas;

        // No recalculamos peso aquí.
        // Este panel solo ajusta la representación visual del mapa.
        p.peso = Number(p.peso ?? 0);

            p.cargaH = Math.max(PALLET.H + p.capas * p.boxH, PALLET.H + 0.25);
            renderList(); acomodar(); selectById(p.id);
            updateCapasHint(p);
          }
          [inCapas, inCols, inRows, inCajas].forEach(inp => {
            inp.addEventListener('change', applyLayoutForm);
            inp.addEventListener('input', e => { e.target.value = e.target.value.replace(/[^\d]/g,''); });
          });
          // ====== Animación y resize ======
          function animate(){ requestAnimationFrame(animate); controls.update(); renderer.render(scene, camera); }
          animate();
          window.addEventListener('resize', ()=>{
            const w = wrapper.clientWidth, h = wrapper.clientHeight;
            camera.aspect = w/h; camera.updateProjectionMatrix(); renderer.setSize(w,h);
          });
          // ====== Dimensiones / presets ======
          selTipo.addEventListener('change', ()=>{
            if (selTipo.value !== 'custom') applyPreset(selTipo.value);
          });
          btnAplicarDims.addEventListener('click', ()=>{
            const L = Math.max(1, parseFloat(inLargo.value) || TRAILER.largo);
            const A = Math.max(1, parseFloat(inAncho.value) || TRAILER.ancho);
            const H = Math.max(1, parseFloat(inAlto.value) || TRAILER.alto);
            TRAILER = { largo:L, ancho:A, alto:H };
            dimsHint.textContent = `Usando ${L.toFixed(2)}×${A.toFixed(2)}×${H.toFixed(2)} m (L×A×H)`;
            // Re-construir caja y muelles por cambio de dimensiones
            ajustarPedidosAAlturaActual();
            renderList();

            buildTrailerRig();
            updateTruckPosition();
            buildDocks();
            acomodar();
            // reset cámara/controles suavemente (ajustado para seguir el rig desplazado)
            controls.target.set(rig.position.x, 0, 0);
            camera.position.set(rig.position.x + 18, 9, 16);
            controls.update();
          });
          // ====== Botones ======
          document.getElementById('btnAcomodar').addEventListener('click', acomodar);

        document.getElementById('btnReset').addEventListener('click', () => {
            selectedId = null;
            selectedGroup = null;

            pedidos = crearPedidosDesdeBase();
            ajustarPedidosAAlturaActual();

            renderList();
            acomodar();
            guardarOrdenMapaCargaDebounced();
        });


        document.getElementById('btnRotar').addEventListener('click', () => {
            if (!selectedGroup) return;

            rememberValidTransform(selectedGroup);

            selectedGroup.rotation.y += Math.PI / 2;
            clampInsideTrailer(selectedGroup);

            if (hasPalletCollision(selectedGroup)) {
                restoreLastValidTransform(selectedGroup);
                showCollisionHint();
                return;
            }

            rememberValidTransform(selectedGroup);
        });

          // ====== Inicial ======
          renderList();
          applyPreset(selTipo.value); // setea inputs según preset seleccionado
          btnAplicarDims.click(); // construye caja + muelles y acomoda pallets-
          if (pedidos.length) selectById(pedidos[0].id);
        });


    </script>
}