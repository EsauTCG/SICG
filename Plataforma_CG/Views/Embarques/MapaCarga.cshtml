@model Plataforma_CG.Models.Embarque

@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Mapa de Carga";
}

<style>
    html, body {
        width: 100%;
        min-height: 100%;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
    }

    .container,
    .container-fluid {
        max-width: 100% !important;
    }

    .mcg-layout {
        display: grid;
        grid-template-columns: clamp(280px, 26vw, 320px) minmax(0, 1fr);
        gap: 12px;
        width: 100%;
        max-width: 100%;
        min-height: calc(100vh - 120px);
        height: auto;
        box-sizing: border-box;
        align-items: stretch;
    }

    .mcg-panel {
        background: #111;
        color: #eee;
        border-radius: 10px;
        padding: 10px;
        overflow: auto;
        min-width: 0;
        width: 100%;
        box-sizing: border-box;
    }

        .mcg-panel h3 {
            margin: 6px 0 10px;
            font-size: 16px;
            font-weight: 600;
        }

    .mcg-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .mcg-item {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #1f1f1f;
        border: 1px solid #333;
        border-radius: 8px;
        padding: 8px;
        margin-bottom: 8px;
        cursor: grab;
        width: 100%;
        box-sizing: border-box;
    }

        .mcg-item:active {
            cursor: grabbing;
        }

        .mcg-item .tag {
            width: 12px;
            height: 12px;
            border-radius: 3px;
            display: inline-block;
            flex: 0 0 auto;
        }

        .mcg-item .meta {
            font-size: 12px;
            opacity: .85;
            min-width: 0;
            word-break: break-word;
        }

    .mcg-actions {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        width: 100%;
    }

        .mcg-actions button {
            background: #2a2a2a;
            color: #eee;
            border: 1px solid #3a3a3a;
            border-radius: 8px;
            padding: 6px 10px;
            cursor: pointer;
            box-sizing: border-box;
        }

            .mcg-actions button:hover {
                background: #333;
            }

    #btnAplicarDims {
        background: #2a2a2a;
        color: #eee;
        border: 1px solid #3a3a3a;
        border-radius: 8px;
        padding: 6px 10px;
        cursor: pointer;
        margin-top: 6px;
        width: 100%;
        box-sizing: border-box;
    }

        #btnAplicarDims:hover {
            background: #333;
        }

    #mapa3d-wrapper {
        position: relative;
        background: #202020;
        border-radius: 10px;
        overflow: hidden;
        min-width: 0;
        width: 100%;
        min-height: calc(100vh - 120px);
        height: calc(100vh - 120px);
        box-sizing: border-box;
    }

        #mapa3d-wrapper canvas {
            position: absolute;
            inset: 0;
            display: block;
            width: 100% !important;
            height: 100% !important;
        }

    #info, #stats {
        position: absolute;
        z-index: 10;
        color: #fff;
        background: rgba(0,0,0,.5);
        padding: 8px 10px;
        border-radius: 8px;
        font: 12px/1.2 system-ui, Arial;
        max-width: calc(100% - 20px);
        box-sizing: border-box;
    }

    #info {
        top: 10px;
        left: 10px;
    }

    #stats {
        bottom: 10px;
        left: 10px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        align-items: center;
        width: 100%;
    }

        .form-grid > * {
            min-width: 0;
        }

    .meta small {
        opacity: .8;
    }

    input,
    select,
    textarea,
    button {
        max-width: 100%;
        box-sizing: border-box;
    }

    @@media (max-width: 1400px) {
        .mcg-layout {
            grid-template-columns: 300px minmax(0, 1fr);
        }
    }

    @@media (max-width: 1200px) {
        .mcg-layout {
            grid-template-columns: 280px minmax(0, 1fr);
        }
    }

    @@media (max-width: 992px) {
        .mcg-layout {
            grid-template-columns: 1fr;
            min-height: auto;
        }

        .mcg-panel {
            max-height: none;
        }

        #mapa3d-wrapper {
            min-height: 65vh;
            height: 65vh;
        }
    }

    @@media (max-width: 768px) {
        .mcg-layout {
            gap: 10px;
        }

        .mcg-panel {
            padding: 8px;
        }

        .form-grid {
            grid-template-columns: 1fr;
        }

        .mcg-actions {
            flex-direction: column;
        }

            .mcg-actions button {
                width: 100%;
            }

        #btnAplicarDims {
            width: 100%;
        }

        #mapa3d-wrapper {
            min-height: 58vh;
            height: 58vh;
        }

        #info,
        #stats {
            font-size: 11px;
            padding: 6px 8px;
        }
    }

    @@media (max-width: 576px) {
        .mcg-layout {
            gap: 8px;
        }

        .mcg-panel {
            padding: 8px;
            border-radius: 8px;
        }

        .mcg-item {
            padding: 7px;
            gap: 6px;
        }

            .mcg-item .meta {
                font-size: 11px;
            }

        .mcg-panel h3 {
            font-size: 15px;
        }

        #mapa3d-wrapper {
            min-height: 50vh;
            height: 50vh;
            border-radius: 8px;
        }
    }

    .mcg-topbar {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        margin-bottom: 10px;
    }

    .mcg-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, #1f1f1f, #2b2b2b);
        color: #f5f5f5;
        border: 1px solid #3a3a3a;
        border-radius: 10px;
        padding: 9px 14px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.2s ease-in-out;
        box-shadow: 0 3px 10px rgba(0,0,0,.18);
    }

        .mcg-back-btn:hover {
            color: #fff;
            background: linear-gradient(135deg, #2a2a2a, #383838);
            border-color: #4a4a4a;
            transform: translateY(-1px);
            text-decoration: none;
        }

        .mcg-back-btn i {
            font-size: 15px;
        }

    @@media (max-width: 768px) {
        .mcg-back-btn {
            width: 100%;
            justify-content: center;
        }
    }

    .mcg-item-content {
        flex: 1 1 auto;
        min-width: 0;
    }

    .mcg-detail-toggle {
        margin-top: 7px;
        border: 1px solid #3a3a3a;
        background: #242424;
        color: #f5f5f5;
        border-radius: 7px;
        padding: 5px 8px;
        font-size: 11px;
        cursor: pointer;
    }

        .mcg-detail-toggle:hover {
            background: #303030;
        }

    .mcg-product-detail {
        display: none;
        margin-top: 8px;
        border-top: 1px solid #333;
        padding-top: 8px;
    }

        .mcg-product-detail.is-open {
            display: block;
        }

    .mcg-product-row {
        display: grid;
        grid-template-columns: minmax(70px, 1fr) 55px 70px;
        gap: 6px;
        align-items: center;
        font-size: 11px;
        padding: 4px 0;
        border-bottom: 1px dashed rgba(255,255,255,.12);
    }

        .mcg-product-row:last-child {
            border-bottom: 0;
        }

    .mcg-product-code {
        font-weight: 700;
        color: #fff;
        word-break: break-word;
    }

    .mcg-product-num {
        text-align: right;
        opacity: .9;
    }

    .mcg-product-empty {
        font-size: 11px;
        opacity: .75;
        margin-top: 6px;
    }

    .mcg-excel-btn {
        background: linear-gradient(135deg, #0f7a2f, #07551f) !important;
        color: #fff !important;
        border: 1px solid #0c6b2a !important;
        font-weight: 700;
    }

        .mcg-excel-btn:hover {
            background: linear-gradient(135deg, #12883a, #086425) !important;
            border-color: #12883a !important;
        }

</style>

<div class="mcg-layout">
    <div class="mcg-panel">

        <div class="mcg-topbar">
            <a asp-action="Embarque" class="mcg-back-btn">
                <i class="bi bi-arrow-left"></i>
                <span>Regresar al Embarque</span>
            </a>
        </div>

        <h3>Órdenes (arrastra para ordenar)</h3>
        <ul id="orderList" class="mcg-list"></ul>
        <div class="mcg-actions" style="margin-top:10px">
            <button id="btnAcomodar" type="button">Acomodar</button>
            <button id="btnRotar" type="button">Rotar seleccionada 90°</button>
            <button id="btnInterior" type="button">Ver interior</button>
            <button id="btnReset" type="button">Reset</button>

            <button id="btnExcelMapaCarga" type="button" class="mcg-excel-btn">
                <i class="bi bi-file-earmark-excel"></i>
                Descargar Excel
            </button>
        </div>
        <p style="margin-top:10px" class="meta">
            Unidad: metros. Peso en kg. Autoacomodo simple (2 columnas) y luego puedes mover cada tarima manualmente.
        </p>
        <!-- NUEVO: Tipo de camión y dimensiones -->
        <div class="mcg-panel" style="margin-top:10px; padding:10px; background:#151515;">
            <h3 style="margin-top:0">Tipo de camión y dimensiones</h3>
            <div class="form-grid" style="margin-bottom:8px">
                <label>Tipo</label>
                <select id="selTipo">
                    <option value="trailer53">Tráiler 53’ (≈16.15×2.45×2.70)</option>
                    <option value="trailer48">Tráiler 48’ (≈14.60×2.45×2.70)</option>
                    <option value="torton8m" selected>Torton ~8 m (≈8.00×2.45×2.65)</option>
                    <option value="custom">Personalizado</option>
                </select>
                <label>Largo interior (m)</label>
                <input id="inLargo" type="number" step="0.01" value="13.60" />
                <label>Ancho interior (m)</label>
                <input id="inAncho" type="number" step="0.01" value="2.45" />
                <label>Alto interior (m)</label>
                <input id="inAlto" type="number" step="0.01" value="2.70" />
            </div>
            <button id="btnAplicarDims" class="mcg-actions" style="margin-top:6px">Aplicar dimensiones</button>
            <div id="dimsHint" class="meta" style="margin-top:8px">Usando 13.60×2.45×2.70 m (L×A×H)</div>
        </div>
        <!-- Panel de Layout de la tarima seleccionada -->
        <div id="layoutBox" class="mcg-panel" style="margin-top:10px; padding:10px; background:#151515;">
            <h3 style="margin-top:0">Layout de la tarima (seleccionada)</h3>
            <div class="meta" style="margin-bottom:8px">
                Define <b>capas (camas)</b> y <b>cajas por capa</b> (Columnas × Filas).
            </div>
            <div class="form-grid">
                <label>Capas (camas)</label>
                <input id="inCapas" type="number" min="1" step="1" value="1" />
                <label>Columnas</label>
                <input id="inCols" type="number" min="1" step="1" value="1" />
                <label>Filas</label>
                <input id="inRows" type="number" min="1" step="1" value="1" />
                <label>Cajas totales</label>
                <input id="inCajas" type="number" min="1" step="1" value="1" />
            </div>
            <div class="meta" style="margin-top:8px">
                Máx. mostradas = <code>capas × columnas × filas</code>.<br />
                <small id="capasHint"></small>
            </div>
        </div>
    </div>
    <div id="mapa3d-wrapper">
        <div id="info">Mapa de carga del tráiler</div>
        <div id="stats"></div>
    </div>
</div>

@using System.Text.Json

@{
    var ordenesMapa = ((IEnumerable<dynamic>)ViewBag.OrdenesMapa ?? Enumerable.Empty<dynamic>())
        .Select(o => new
        {
            id = $"OV-{o.Id}",
            nombre = (string)(o.Cliente ?? o.Consecutivo ?? $"OV {o.Id}"),
            color = "#3b82f6",
            sku = (string)(o.Consecutivo ?? $"OV-{o.Id}"),
            cajas = Math.Max(1, (int)o.Cajas),
            peso = (decimal)o.Kilos,
            kgPorCaja = (int)o.Cajas > 0 ? ((decimal)o.Kilos / (int)o.Cajas) : 0m,
            boxL = 0.40,
            boxA = 0.30,
            boxH = 0.25,
            tipo = "OV",
            referencia = (string)(o.Consecutivo ?? ""),
            ruta = (string)(o.Ruta ?? ""),
            productos = (int)o.Productos,

            detalles = ((IEnumerable<dynamic>)o.Detalles)
                .Select(d => new
                {
                    id = 0,
                    transferenciaDetalleIdOriginal = (int?)null,
                    productoCodigo = (string)(d.ProductoCodigo ?? ""),
                    productoNombre = (string)(d.ProductoNombre ?? ""),
                    cajas = (int)d.Cajas,
                    kilos = (decimal)d.Kilos,
                    orden = 0
                })
                .ToList()
        });

    var transferenciasMapa = ((IEnumerable<dynamic>)ViewBag.TransferenciasMapa ?? Enumerable.Empty<dynamic>())
        .Select(t => new
        {
            id = $"TR-{t.Id}",
            nombre = (string)(t.Cliente ?? t.Consecutivo ?? $"TR {t.Id}"),
            color = "#f59e0b",
            sku = (string)(t.Consecutivo ?? $"TR-{t.Id}"),
            cajas = Math.Max(1, (int)Math.Round((decimal)t.Cajas, MidpointRounding.AwayFromZero)),
            peso = (decimal)t.Kilos,
            kgPorCaja = (decimal)t.Cajas > 0 ? ((decimal)t.Kilos / (decimal)t.Cajas) : 0m,
            boxL = 0.40,
            boxA = 0.30,
            boxH = 0.25,
            tipo = "TRANSFERENCIA",
            referencia = (string)(t.Consecutivo ?? ""),
            ruta = (string)(t.Ruta ?? ""),
            productos = (int)t.Productos,

            detalles = ((IEnumerable<dynamic>)t.Detalles)
                .Select(d => new
                {
                    id = (int)d.Id,
                    transferenciaDetalleIdOriginal = (int?)d.TransferenciaDetalleIdOriginal,
                    productoCodigo = (string)(d.ProductoCodigo ?? ""),
                    productoNombre = "",
                    cajas = (int)d.Cajas,
                    kilos = (decimal)d.Kilos,
                    orden = (int)d.Orden
                })
                .ToList()
        });

    var pedidosMapa = ordenesMapa.Concat(transferenciasMapa).ToList();

    var ordenGuardadoJson = (string)(ViewBag.MapaCargaOrdenJson ?? "");

    if (!string.IsNullOrWhiteSpace(ordenGuardadoJson))
    {
        try
        {
            var ordenGuardado = JsonSerializer.Deserialize<List<string>>(ordenGuardadoJson) ?? new List<string>();

            pedidosMapa = pedidosMapa
                .OrderBy(p =>
                {
                    var propId = p.GetType().GetProperty("id")?.GetValue(p)?.ToString();
                    var index = ordenGuardado.IndexOf(propId ?? "");

                    // Si no existe en el orden guardado, lo manda al final
                    return index >= 0 ? index : int.MaxValue;
                })
                .ThenBy(p =>
                {
                    var propId = p.GetType().GetProperty("id")?.GetValue(p)?.ToString();
                    return propId;
                })
                .ToList();
        }
        catch
        {
            // Si por alguna razón el JSON está mal, usa el orden normal
        }
    }

    var pedidosMapaJson = JsonSerializer.Serialize(pedidosMapa);
}

@section Scripts {
    <script src="https://unpkg.com/three@0.128.0/build/three.min.js" defer></script>
    <script src="https://unpkg.com/three@0.128.0/examples/js/controls/OrbitControls.js" defer></script>
    <script src="https://unpkg.com/three@0.128.0/examples/js/controls/TransformControls.js" defer></script>
    <script src="https://unpkg.com/three@0.128.0/examples/js/lights/RectAreaLightUniformsLib.js" defer></script>
    <script src="https://unpkg.com/three@0.128.0/examples/js/loaders/GLTFLoader.js" defer></script>
    <script>
        window.addEventListener('load', function () {
          // ====== Parámetros base ======
          let TRAILER = { largo: 13.60, ancho: 2.45, alto: 2.70 }; // se actualiza con los presets/inputs
          const FIXED_BACK = 13.60 / 2; // Posición fija absoluta del final del tráiler (puertas). Se basa en el largo inicial para no moverlo al crecer.
          const GROUND_Y = 0; // Suelo fijo en Y=0
          const DOCK_HEIGHT = 1.2; // Altura estándar del muelle/piso del tráiler sobre el suelo
          const FLOOR_THK = 0.08; // espesor del piso
          const WALL_THK = 0.05; // espesor paredes/techo
          const PALLET = { L: 1.20, A: 1.00, H: 0.144 }; // tarima aprox
          const PRESETS = {
            trailer53: { largo: 16.15, ancho: 2.45, alto: 2.70 },
            trailer48: { largo: 14.60, ancho: 2.45, alto: 2.70 },
            torton8m : { largo: 8.00, ancho: 2.45, alto: 2.65 },
          };
          // Órdenes con detalle de cajas y SKU
          const EMBARQUE_ID = @Model.Id;
          const PEDIDOS_BASE = @Html.Raw(pedidosMapaJson);
          // ====== UI ======
          const orderList = document.getElementById('orderList');
          const wrapper = document.getElementById('mapa3d-wrapper');
          const info = document.getElementById('info');
          const stats = document.getElementById('stats');
          // layout inputs
          const inCapas = document.getElementById('inCapas');
          const inCols = document.getElementById('inCols');
          const inRows = document.getElementById('inRows');
          const inCajas = document.getElementById('inCajas');
          const capasHint = document.getElementById('capasHint');
          // dimensiones inputs
          const selTipo = document.getElementById('selTipo');
          const inLargo = document.getElementById('inLargo');
          const inAncho = document.getElementById('inAncho');
          const inAlto = document.getElementById('inAlto');
          const btnAplicarDims = document.getElementById('btnAplicarDims');
          const dimsHint = document.getElementById('dimsHint');

                  let ordenSaveTimer = null;

        const MAX_VISUAL_BOXES_PER_PALLET = 140;
        const PALLET_COLLISION_MARGIN = 0.04;

        const lastValidTransforms = new Map();
        let collisionWarnTimer = null;

            const btnExcelMapaCarga = document.getElementById('btnExcelMapaCarga');

            if (btnExcelMapaCarga) {
                btnExcelMapaCarga.addEventListener('click', async function () {
                    try {
                        btnExcelMapaCarga.disabled = true;
                        btnExcelMapaCarga.innerHTML = '<i class="bi bi-hourglass-split"></i> Preparando Excel...';

                        // Guarda primero el orden actual de arriba hacia abajo
                        await guardarOrdenMapaCarga();

                        // Descarga el Excel ya con el orden guardado
                        window.location.href = `/Embarques/DescargarMapaCargaExcel/${EMBARQUE_ID}`;
                    } catch (error) {
                        console.error('Error descargando Excel:', error);
                        alert('No se pudo generar el Excel del mapa de carga.');
                    } finally {
                        setTimeout(() => {
                            btnExcelMapaCarga.disabled = false;
                            btnExcelMapaCarga.innerHTML = '<i class="bi bi-file-earmark-excel"></i> Descargar Excel';
                        }, 1500);
                    }
                });
            }

          function fmt(n){ return (Math.round(n*100)/100).toFixed(2); }
                  function getCurrentOrderIds() {
            return pedidos.map(p => p.id);
        }

        function guardarOrdenMapaCargaDebounced() {
            clearTimeout(ordenSaveTimer);

            ordenSaveTimer = setTimeout(() => {
                guardarOrdenMapaCarga();
            }, 450);
        }

        function getMaxCapasByHeight(p) {
            const interiorH = Math.max(0.30, TRAILER.alto - FLOOR_THK - WALL_THK);
            const usableLoadH = Math.max(0.10, interiorH - PALLET.H - 0.06);

            return Math.max(
                1,
                Math.floor(usableLoadH / Math.max(0.05, Number(p.boxH || 0.25)))
            );
        }

        function crearPedidoRuntime(p) {
            const defCols = Math.max(1, Math.floor(PALLET.L / Number(p.boxL || 0.40)));
            const defRows = Math.max(1, Math.floor(PALLET.A / Number(p.boxA || 0.30)));
            const porCapa = Math.max(1, defCols * defRows);

            const cajas = Math.max(1, parseInt(p.cajas || 1, 10));
            const capasNecesarias = Math.max(1, Math.ceil(cajas / porCapa));
            const maxCapasAltura = getMaxCapasByHeight(p);
            const capasCalc = Math.min(capasNecesarias, maxCapasAltura);

            return {
                ...p,
                peso: Number(p.peso ?? 0),
                cols: defCols,
                rows: defRows,
                capas: capasCalc,
                cargaL: PALLET.L,
                cargaA: PALLET.A,
                cargaH: Math.max(PALLET.H + capasCalc * Number(p.boxH || 0.25), PALLET.H + 0.25)
            };
        }

        function crearPedidosDesdeBase() {
            return PEDIDOS_BASE.map(p => crearPedidoRuntime(p));
        }

        function ajustarPedidosAAlturaActual() {
            pedidos = pedidos.map(p => {
                const maxCapasAltura = getMaxCapasByHeight(p);
                const capasActuales = Math.max(1, parseInt(p.capas || 1, 10));
                const capas = Math.min(capasActuales, maxCapasAltura);

                return {
                    ...p,
                    capas,
                    peso: Number(p.peso ?? 0),
                    cargaH: Math.max(PALLET.H + capas * Number(p.boxH || 0.25), PALLET.H + 0.25)
                };
            });
        }

        function getVisualLayout(p) {
            const cajasReales = Math.max(1, parseInt(p.cajas || 1, 10));

            // Para rendimiento: no dibujamos miles de cajas.
            // Los datos reales siguen iguales, solo compactamos la representación visual.
            const cajasVisuales = Math.min(cajasReales, MAX_VISUAL_BOXES_PER_PALLET);

            const capasPreferidas = Math.max(1, parseInt(p.capas || 1, 10));
            const maxCapas = getMaxCapasByHeight(p);
            const capas = Math.min(capasPreferidas, maxCapas, cajasVisuales);

            const porCapa = Math.max(1, Math.ceil(cajasVisuales / capas));

            const colsBase = Math.max(1, parseInt(p.cols || 1, 10));
            const rowsBase = Math.max(1, parseInt(p.rows || 1, 10));

            let cols = colsBase;
            let rows = rowsBase;

            if ((cols * rows) < porCapa) {
                const ratio = PALLET.L / PALLET.A;
                cols = Math.max(1, Math.ceil(Math.sqrt(porCapa * ratio)));
                rows = Math.max(1, Math.ceil(porCapa / cols));
            }

            const gapX = 0.02;
            const gapZ = 0.02;
            const gapY = 0.01;

            const usableL = Math.max(0.10, PALLET.L - gapX * (cols + 1));
            const usableA = Math.max(0.10, PALLET.A - gapZ * (rows + 1));

            const interiorH = Math.max(0.30, TRAILER.alto - FLOOR_THK - WALL_THK);
            const usableLoadH = Math.max(0.10, interiorH - PALLET.H - 0.06);

            const boxL = Math.max(0.04, usableL / cols);
            const boxA = Math.max(0.04, usableA / rows);
            const boxH = Math.max(
                0.04,
                (usableLoadH - gapY * Math.max(0, capas - 1)) / capas
            );

            return {
                cajas: cajasVisuales,
                cajasReales,
                capas,
                cols,
                rows,
                boxL,
                boxA,
                boxH,
                gapX,
                gapZ,
                gapY
            };
        }

