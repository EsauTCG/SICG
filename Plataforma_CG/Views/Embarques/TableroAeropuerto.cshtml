    function safe(v) {
        return v === null || v === undefined || v === "" ? "—" : v;
    }

        function escapeHtml(value) {
        return String(value)
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#039;");
    }

    function airportFlipValue(value) {
        const finalValue = safe(value);
        return `<span class="flip-text" data-final="${escapeHtml(finalValue)}">${escapeHtml(finalValue)}</span>`;
    }

    function airportFlipTemperature(value) {
        if (value === null || value === undefined || value === "") {
            return airportFlipValue("—");
        }

        return airportFlipValue(`${value}°C`);
    }

    function animarFlipTextos(scope) {
        const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-:/ .";
        const elementos = scope.querySelectorAll(".flip-text");

        elementos.forEach((el, index) => {
            const finalText = el.dataset.final || "—";
            const length = Math.max(finalText.length, 1);
            let ciclos = 0;
            const maxCiclos = 8 + Math.min(length, 12);

            el.classList.remove("finalized");
            el.classList.add("flipping");

            const intervalo = setInterval(() => {
                ciclos++;

                let temporal = "";

                for (let i = 0; i < length; i++) {
                    const finalChar = finalText[i] || " ";

                    if (finalChar === " " || finalChar === "—") {
                        temporal += finalChar;
                    } else if (ciclos > maxCiclos - Math.ceil(i / 2)) {
                        temporal += finalChar;
                    } else {
                        temporal += chars[Math.floor(Math.random() * chars.length)];
                    }
                }

                el.textContent = temporal;

                if (ciclos >= maxCiclos) {
                    clearInterval(intervalo);
                    el.textContent = finalText;
                    el.classList.remove("flipping");
                    el.classList.add("finalized");
                }
            }, 42 + (index % 4) * 8);
        });
    }

    function badgeMini(valor) {
        if (valor === "OK") {
            return `<span class="mini-ok">OK</span>`;
        }

        return `<span class="mini-pending">PEND.</span>`;
    }

    function showToast(titulo, mensaje) {
        const toast = document.getElementById("airportToast");
        const title = document.getElementById("airportToastTitle");
        const body = document.getElementById("airportToastBody");

        if (!toast || !title || !body) return;

        title.textContent = titulo;
        body.textContent = mensaje;

        toast.classList.remove("show");
        void toast.offsetWidth;
        toast.classList.add("show");
    }

    function animateNumber(id, newValue) {
        const el = document.getElementById(id);
        if (!el) return;

        const oldValue = Number(el.textContent || 0);

        if (oldValue === newValue) return;

        const duration = 600;
        const start = performance.now();

        const card = el.closest(".stat-card");
        if (card) {
            card.classList.remove("flash");
            void card.offsetWidth;
            card.classList.add("flash");

            setTimeout(() => card.classList.remove("flash"), 900);
        }

        function tick(now) {
            const progress = Math.min((now - start) / duration, 1);
            const value = Math.round(oldValue + (newValue - oldValue) * progress);

            el.textContent = value;

            if (progress < 1) {
                requestAnimationFrame(tick);
            }
        }

        requestAnimationFrame(tick);
    }

    function renderStats(data) {
        animateNumber("stTotal", data.length);
        animateNumber("stPendientes", data.filter(x => x.estatus === 1).length);
        animateNumber("stLiberados", data.filter(x => x.estatus === 7).length);
        animateNumber("stRuta", data.filter(x => x.estatus === 2).length);
        animateNumber("stRetrasados", data.filter(x => x.estatus === 4).length);
        animateNumber("stEntregados", data.filter(x => x.estatus === 5).length);
    }

    function crearFirma(x) {
        return JSON.stringify({
            id: x.id,
            consecutivo: x.consecutivo,
            ruta: x.ruta,
            cliente: x.cliente,
            pedido: x.pedido,
            placa: x.placa,
            temperatura: x.temperatura,
            fechaSalida: x.fechaSalida,
            fechaDestino: x.fechaDestino,
            fechaEntregado: x.fechaEntregado,
            calidad: x.calidad,
            documentacion: x.documentacion,
            estatus: x.estatus,
            estatusTexto: x.estatusTexto,
            estatusTipo: x.estatusTipo
        });
    }

    function renderTabla(data) {
        const tbody = document.getElementById("tbodyTablero");

        if (!data || data.length === 0) {
            tbody.innerHTML = `<tr><td colspan="14" class="empty">No hay embarques para mostrar.</td></tr>`;
            return;
        }

        const categorias = [
            { estatus: 5, titulo: "Entregados Recientes" },
            { estatus: 2, titulo: "En Ruta" },
            { estatus: 3, titulo: "Llegaron a Destino" },
            { estatus: 4, titulo: "Retrasados / Incidencias" },
            { estatus: 7, titulo: "Liberados para QR" },
            { estatus: 1, titulo: "Pendientes de Validación" },
            { estatus: 6, titulo: "Devueltos" }
            
        ];

        let html = "";

        categorias.forEach(cat => {
            const items = data
                .filter(x => x.estatus === cat.estatus)
                .sort((a, b) => String(b.fechaCreacion).localeCompare(String(a.fechaCreacion)));

            if (items.length === 0) return;

            html += `
                <tr class="board-category-row">
                    <td colspan="14">
                        <div class="board-category">
                            <span>${cat.titulo}</span>
                            <span class="board-category-count">${items.length} embarque(s)</span>
                        </div>
                    </td>
                </tr>
            `;

            html += items.map(x => {
                const firmaActual = crearFirma(x);
                const firmaAnterior = ultimoMapa.get(x.id);

                let claseAnimacion = "";

                if (!primeraCarga) {
                    if (!firmaAnterior) {
                        claseAnimacion = "row-new";
                    } else if (firmaAnterior !== firmaActual) {
                        claseAnimacion = "row-changed";
                    }
                }

                return `
                    <tr data-id="${x.id}" class="${claseAnimacion}">
                        <td><strong>${safe(x.consecutivo)}</strong></td>
                        <td>${safe(x.ruta)}</td>
                        <td>${safe(x.cliente)}</td>
                        <td>
                            <span class="doc-pill">OV:${x.totalOV ?? 0}</span>
                            <span class="doc-pill">TR:${x.totalTR ?? 0}</span>
                        </td>
                        <td>${safe(x.pedido)}</td>

                        <td>${airportFlipValue(x.fechaCreacion)}</td>
                        <td>${airportFlipValue(x.fechaSalida)}</td>
                        <td>${airportFlipValue(x.fechaDestino)}</td>
                        <td>${airportFlipValue(x.fechaEntregado)}</td>
                        <td>${badgeMini(x.calidad)}</td>
                        <td>${badgeMini(x.documentacion)}</td>
                        <td>
                            <span class="badge-status badge-animate st-${x.estatusTipo}">
                                ${safe(x.estatusTexto)}
                            </span>
                        </td>
                    </tr>
                `;
            }).join("");
        });

        tbody.innerHTML = html;
    }

    function detectarCambios(data) {
        if (primeraCarga) return;

        let nuevos = 0;
        let modificados = 0;

        data.forEach(x => {
            const firmaActual = crearFirma(x);
            const firmaAnterior = ultimoMapa.get(x.id);

            if (!firmaAnterior) {
                nuevos++;
            } else if (firmaAnterior !== firmaActual) {
                modificados++;
            }
        });

        if (nuevos > 0 || modificados > 0) {
            const partes = [];

            if (nuevos > 0) partes.push(`${nuevos} nuevo(s)`);
            if (modificados > 0) partes.push(`${modificados} actualizado(s)`);

            showToast("Movimiento detectado", `Se detectaron ${partes.join(" y ")} en el tablero.`);
        }
    }

    function actualizarMapa(data) {
        ultimoMapa.clear();

        data.forEach(x => {
            ultimoMapa.set(x.id, crearFirma(x));
        });
    }

    async function cargarDatos() {
        try {
            const resp = await fetch('@Url.Action("TableroAeropuertoData", "Embarques")', {
                cache: "no-store"
            });

            if (!resp.ok) {
                throw new Error("No se pudo cargar la información del tablero.");
            }

            const data = await resp.json();
            const nuevoHash = JSON.stringify(data);

            renderStats(data);

            if (nuevoHash !== ultimoHash) {
                detectarCambios(data);
                renderTabla(data);

                setTimeout(() => {
                    document
                        .querySelectorAll("#tbodyTablero tr.row-new, #tbodyTablero tr.row-changed")
                        .forEach(row => {
                            animarFlipTextos(row);
                        });
                }, 80);

                actualizarMapa(data);

                ultimoHash = nuevoHash;
                primeraCarga = false;
            }
        } catch (err) {
            console.error(err);
            showToast("Error de conexión", "No se pudo actualizar el tablero en este momento.");
        }
    }

    function iniciarAutoScroll() {
        const inner = document.getElementById("scrollInner");
        const container = document.getElementById("boardScroll");

        if (!inner || !container) return;

        container.addEventListener("mouseenter", () => {
            scrollActivo = false;
        });

        container.addEventListener("mouseleave", () => {
            scrollActivo = true;
        });

        function loop() {
            if (scrollActivo) {
                const maxScroll = inner.offsetHeight - container.offsetHeight;

                if (maxScroll > 20) {
                    scrollOffset -= 0.25;

                    if (-scrollOffset > maxScroll + 60) {
                        scrollOffset = 0;
                    }

                    inner.style.transform = `translateY(${scrollOffset}px)`;
                } else {
                    scrollOffset = 0;
                    inner.style.transform = "translateY(0)";
                }
            }

            requestAnimationFrame(loop);
        }

        requestAnimationFrame(loop);
    }

    document.addEventListener("DOMContentLoaded", function () {
        //updateClock();
        //setInterval(updateClock, 1000);

        cargarDatos();
        setInterval(cargarDatos, 8000);

        iniciarAutoScroll();
    });
</script>