</style>

<div class="caseta-page">

    <section class="caseta-hero">
        <div class="caseta-hero-content">
            <div class="caseta-title-wrap">
                <div class="caseta-hero-icon">
                    <i class="bi bi-shield-check"></i>
                </div>

                <div>
                    <h2>Control de Acceso - Caseta</h2>
                    <p>Escanea el QR, revisa documentos y registra la salida del embarque.</p>
                </div>
            </div>

            <div class="caseta-live-pill">
                <span class="caseta-live-dot"></span>
                Operación en tiempo real
            </div>
        </div>
    </section>

    <div class="caseta-grid">

        <!-- Panel QR -->
        <section class="caseta-card">
            <div class="caseta-card-header">
                <div>
                    <h3 class="caseta-card-title">
                        <i class="bi bi-qr-code-scan"></i>
                        Validación de QR
                    </h3>
                    <p class="caseta-hint">
                        Escanea el código o pega el token para validar el embarque.
                    </p>
                </div>
            </div>

            <div class="caseta-card-body">

                <div class="qr-shell">
                    <div class="qr-input-box">
                        <i class="bi bi-upc-scan"></i>
                        <input id="qrToken"
                               type="text"
                               class="form-control"
                               value="@ViewBag.Token"
                               autocomplete="off"
                               placeholder="Escanea o ingresa el token aquí..." />
                    </div>

                    <button id="btnValidarQR" class="btn-caseta-primary" type="button" onclick="validarQR()">
                        <i class="bi bi-check2-circle"></i>
                        Validar
                    </button>
                </div>

                <div id="qrErrorBox" class="alert alert-danger mt-3 mb-0" style="display:none;"></div>

                <!-- Resultado QR -->
                <div id="resultadoQR" class="qr-result qr-result-ok">

                    <div class="qr-summary">
                        <div class="qr-summary-icon">
                            <i class="bi bi-check2-circle"></i>
                        </div>

                        <div>
                            <h5>Embarque validado correctamente</h5>

                            <div class="qr-meta">
                                <span class="qr-meta-item">
                                    <i class="bi bi-truck"></i>
                                    Embarque: <span id="r-id">-</span>
                                </span>

                                <span class="qr-meta-item">
                                    <i class="bi bi-calendar-check"></i>
                                    QR: <span id="r-fecha">-</span>
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="qr-result-body">
                        <div class="section-mini-title">
                            <h5>
                                <i class="bi bi-list-check"></i>
                                Documentos incluidos
                            </h5>

                            <span id="ordenesCount" class="count-pill">0 registros</span>
                        </div>

                        <div class="table-wrap">
                            <table class="table caseta-table" id="tabla-ordenes">
                                <thead>
                                    <tr>
                                        <th>Tipo</th>
                                        <th>ID</th>
                                        <th>Cliente / Sucursal</th>
                                        <th>Consecutivo</th>
                                        <th>Ruta</th>
                                        <th>Presentación</th>
                                        <th>Entrega</th>
                                    </tr>
                                </thead>

                                <tbody></tbody>
                            </table>
                        </div>

                        <div id="acciones" class="acciones-salida"></div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Panel de embarques -->
        <section class="caseta-card">
            <div class="caseta-card-header">
                <div>
                    <h3 class="caseta-card-title">
                        <i class="bi bi-truck-front"></i>
                        Embarques activos
                    </h3>
                    <p class="caseta-hint">
                        Lista de embarques disponibles para seguimiento desde caseta.
                    </p>
                </div>

                <span class="count-pill">
                    @Model.Count() registro(s)
                </span>
            </div>

            <div class="caseta-card-body">
                @if (Model != null && Model.Any())
                {
                    <div class="table-wrap">
                        <table class="table caseta-table">
                            <thead>
                                <tr>
                                    <th>Embarque</th>
                                    <th>Fecha</th>
                                    <th>Estatus</th>
                                    <th>Salida</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var e in Model)
                                {
                                    var validacionesCompletas =
                                    e.CalidadAprobada == true &&
                                    e.DocumentacionAprobada == true &&
                                    e.DocumentacionCalidadAprobada == true;

                                    var estatusTexto =
                                    e.Estatus == 7 && !validacionesCompletas ? "Pendiente de validaciones" :
                                    e.Estatus == 1 ? "Pendiente de validaciones" :
                                    e.Estatus == 7 ? "Liberado para QR" :
                                    e.Estatus == 2 ? "En Ruta" :
                                    e.Estatus == 3 ? "En Destino" :
                                    e.Estatus == 4 ? "Retrasado" :
                                    e.Estatus == 5 ? "Entregado" :
                                    e.Estatus == 6 ? "Devuelto" :
                                    "Desconocido";

                                    var estatusClase =
                                    e.Estatus == 7 && !validacionesCompletas ? "status-pendiente" :
                                    e.Estatus == 1 ? "status-pendiente" :
                                    e.Estatus == 7 ? "status-liberado" :
                                    e.Estatus == 2 ? "status-ruta" :
                                    e.Estatus == 3 ? "status-destino" :
                                    e.Estatus == 4 ? "status-retrasado" :
                                    e.Estatus == 5 ? "status-entregado" :
                                    e.Estatus == 6 ? "status-devuelto" :
                                    "status-desconocido";

                                    <tr>
                                        <td data-label="Embarque">
                                            @(string.IsNullOrWhiteSpace(e.Consecutivo) ? $"EMB-{e.Id}" : e.Consecutivo)
                                        </td>

                                        <td data-label="Fecha">
                                            @e.FechaCreacion.ToString("yyyy-MM-dd HH:mm")
                                        </td>

                                        <td data-label="Estatus">
                                            <span class="status-badge @estatusClase">@estatusTexto</span>
                                        </td>

                                        <td data-label="Salida">
                                            @(e.FechaSalida?.ToString("yyyy-MM-dd HH:mm") ?? "-")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="bi bi-inbox"></i>
                        No hay embarques activos para mostrar.
                    </div>
                }
            </div>
        </section>

    </div>
</div>

@if (!string.IsNullOrEmpty(Context.Request.Query["alert"]))
{
    <div id="alertBox" class="alert text-center fw-bold caseta-alert-floating" style="display:none;"></div>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const type = "@Context.Request.Query["alert"]";
            const box = document.getElementById("alertBox");

            const mensajes = {
                "salida-ok": { msg: "Salida registrada correctamente.", clase: "alert-success" },
                "ya-salida": { msg: "Este embarque ya tenía registrada la salida.", clase: "alert-warning" },
                "notfound": { msg: "El embarque no existe.", clase: "alert-danger" },
               "no-calidad": { msg: "El embarque aún no cuenta con todas las validaciones requeridas.", clase: "alert-warning" }
            };

            if (mensajes[type]) {
                box.innerText = mensajes[type].msg;
                box.classList.add(mensajes[type].clase);
                box.style.display = "block";

                setTimeout(() => box.style.display = "none", 3500);
            }
        });
    </script>
}

@section Scripts {
    @* Si Bootstrap Icons ya lo tienes cargado en _Layout2.cshtml, elimina esta línea para no duplicarlo. *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const input = document.getElementById("qrToken");

            if (input) {
                input.focus();

                input.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        validarQR();
                    }
                });

                const token = input.value.trim();

                if (token.length > 0) {
                    validarQR();
                }
            }
        });

        function setLoadingQR(isLoading) {
            const btn = document.getElementById("btnValidarQR");

            if (!btn) return;

            if (isLoading) {
                btn.disabled = true;
                btn.innerHTML = `
                    <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                    Validando...
                `;
            } else {
                btn.disabled = false;
                btn.innerHTML = `
                    <i class="bi bi-check2-circle"></i>
                    Validar
                `;
            }
        }

        function validarQR() {
            const input = document.getElementById("qrToken");
            const token = input.value.trim();

            if (token.length === 0) {
                errorFeedback("Escanea o ingresa un token para validar.");
                input.focus();
                return;
            }

            setLoadingQR(true);

            fetch(`/Embarques/ValidarQR?token=${encodeURIComponent(token)}`)
                .then(async r => {
                    if (!r.ok) {
                        let msg = "El token no existe o no es válido.";

                        try {
                            const serverMsg = await r.text();
                            if (serverMsg && serverMsg.trim().length > 0) {
                                msg = serverMsg;
                            }
                        } catch { }

                        throw new Error(msg);
                    }

                    return r.json();
                })
                .then(data => {
                    successFeedback();
                    mostrarResultado(data);
                })
                .catch(err => {
                    errorFeedback(err.message || "No se pudo validar el QR.");
                })
                .finally(() => {
                    setLoadingQR(false);
                });
        }

        function escapeHtml(value) {
            if (value === null || value === undefined) return "-";

            return String(value)
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function agregarFilaDocumento(tbody, item) {
            const tr = document.createElement("tr");

            tr.innerHTML = `
                <td data-label="Tipo">
                    <span class="doc-type-badge ${item.tipoClase}">${item.tipo}</span>
                </td>
                <td data-label="ID">${escapeHtml(item.id)}</td>
                <td data-label="Cliente / Sucursal">${escapeHtml(item.clienteSucursal)}</td>
                <td data-label="Consecutivo">${escapeHtml(item.consecutivo)}</td>
                <td data-label="Ruta">${escapeHtml(item.ruta)}</td>
                <td data-label="Presentación">${escapeHtml(item.presentacion)}</td>
                <td data-label="Entrega">${escapeHtml(item.entrega)}</td>
            `;

            tbody.appendChild(tr);
        }

        function mostrarResultado(data) {
            const card = document.getElementById("resultadoQR");
            const tbody = document.querySelector("#tabla-ordenes tbody");
            const acciones = document.getElementById("acciones");
            const count = document.getElementById("ordenesCount");

            card.style.display = "block";
            card.classList.remove("qr-result-error");
            card.classList.add("qr-result-ok");

            document.getElementById("r-id").innerText = data.embarqueConsecutivo ?? "-";
            document.getElementById("r-fecha").innerText = data.qrGenerado ?? "-";

            tbody.innerHTML = "";

            let total = 0;

            if (data.ordenes && data.ordenes.length > 0) {
                data.ordenes.forEach(o => {
                    total++;

                    agregarFilaDocumento(tbody, {
                        tipo: "OV",
                        tipoClase: "doc-type-ov",
                        id: o.id,
                        clienteSucursal: o.cliente,
                        consecutivo: o.consecutivo,
                        ruta: o.ruta ?? "-",
                        presentacion: o.presentacion ?? "-",
                        entrega: o.fechaEntrega ?? "-"
                    });
                });
            }

            if (data.transferencias && data.transferencias.length > 0) {
                data.transferencias.forEach(t => {
                    total++;

                    agregarFilaDocumento(tbody, {
                        tipo: "TR",
                        tipoClase: "doc-type-tr",
                        id: t.id,
                        clienteSucursal: t.sucursal ?? "-",
                        consecutivo: t.consecutivo ?? "-",
                        ruta: "-",
                        presentacion: "-",
                        entrega: t.fechaSolicitud ?? "-"
                    });
                });
            }

            count.innerText = total === 1 ? "1 registro" : `${total} registros`;

            if (total === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td data-label="Aviso" colspan="7">
                            No se encontraron órdenes ni transferencias relacionadas.
                        </td>
                    </tr>
                `;
            }

            acciones.innerHTML = `
                <a href="/Embarques/RegistrarSalida/${encodeURIComponent(data.embarqueId)}" class="btn-salida">
                    <i class="bi bi-box-arrow-right"></i>
                    Registrar salida del embarque
                </a>
            `;

            setTimeout(() => {
                card.scrollIntoView({ behavior: "smooth", block: "start" });
            }, 100);
        }

        function successFeedback() {
            const box = document.getElementById("qrErrorBox");

            if (box) {
                box.style.display = "none";
                box.innerText = "";
            }
        }

        function errorFeedback(msg) {
            const box = document.getElementById("qrErrorBox");
            const card = document.getElementById("resultadoQR");

            if (box) {
                box.innerText = msg;
                box.style.display = "block";
            }

            if (card) {
                card.style.display = "none";
                card.classList.remove("qr-result-ok");
                card.classList.add("qr-result-error");
            }

            setTimeout(() => {
                if (box) {
                    box.style.display = "none";
                }
            }, 3500);
        }
    </script>
}