@{
    ViewData["Title"] = "Control Center Logística";
    Layout = "~/Views/Shared/_Layout2.cshtml";

    var embarques = ViewBag.Embarques as List<dynamic> ?? new List<dynamic>();
    var embarquesCompletados = ViewBag.EmbarquesCompletados as List<dynamic> ?? new List<dynamic>();

    var busqueda = Context.Request.Query["busqueda"].ToString();
    var fechaInicio = Context.Request.Query["fechaInicio"].ToString();
    var fechaFin = Context.Request.Query["fechaFin"].ToString();

    bool buscoCompletados = ViewBag.BuscoCompletados == true;

    var busquedaCompletados = Context.Request.Query["busquedaCompletados"].ToString();
    var fechaInicioCompletados = Context.Request.Query["fechaInicioCompletados"].ToString();
    var fechaFinCompletados = Context.Request.Query["fechaFinCompletados"].ToString();

    // Calcular KPIs
    int totalViajes = embarques.Count;
    int pendientes = embarques.Count(e => e.Estatus == 1);
    int liberadosQr = embarques.Count(e => e.Estatus == 7);
    int enRuta = embarques.Count(e => e.Estatus == 2);
    int enDestino = embarques.Count(e => e.Estatus == 3);
    int retrasados = embarques.Count(e => e.Estatus == 4);
    int entregados = embarques.Count(e => e.Estatus == 5);
}

<style>
    :root {
        --primary: #8B0000;
        --primary-dark: #5a0000;
        --primary-soft: #fdf1f1;
        --accent: #c82333;
        --bg: #f3f6fa;
        --panel: #ffffff;
        --panel-soft: #f8fafc;
        --border: #dfe5ec;
        --border-strong: #cfd7e1;
        --text: #1f2937;
        --muted: #6b7280;
        --success: #198754;
        --success-soft: #eaf7ef;
        --warning: #f59e0b;
        --warning-soft: #fff8e8;
        --danger: #dc3545;
        --danger-soft: #fdeeee;
        --info: #0d6efd;
        --info-soft: #edf4ff;
        --shadow-sm: 0 6px 18px rgba(15, 23, 42, 0.06);
        --shadow-md: 0 14px 34px rgba(15, 23, 42, 0.10);
        --radius-xl: 22px;
        --radius-lg: 18px;
        --radius-md: 14px;
        --transition: all .22s ease;
    }

    body {
        background: linear-gradient(180deg, #f8fafc 0%, #eef3f8 100%);
        color: var(--text);
    }

    .control-wrap {
        max-width: 1380px;
        margin: 0 auto;
        padding: 1.5rem 1rem 2.2rem;
    }

    .control-header {
        background: linear-gradient(135deg, #8B0000 0%, #5a0000 55%, #240000 100%);
        color: #fff;
        border-radius: var(--radius-xl);
        padding: 1.45rem 1.55rem;
        margin-bottom: 1.1rem;
        box-shadow: var(--shadow-md);
        position: relative;
        overflow: hidden;
    }

        .control-header::after {
            content: "";
            position: absolute;
            right: -45px;
            top: -45px;
            width: 190px;
            height: 190px;
            border-radius: 50%;
            background: rgba(255,255,255,.06);
        }

    .control-header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
    }

    .control-title-box {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .control-header-icon {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.16);
        display: grid;
        place-items: center;
        font-size: 1.45rem;
        flex-shrink: 0;
    }

    .control-header h2 {
        margin: 0;
        font-size: 1.65rem;
        font-weight: 800;
    }

    .control-header p {
        margin: .35rem 0 0;
        color: rgba(255,255,255,.88);
        font-size: .95rem;
    }

    .control-refresh-btn {
        border: none;
        border-radius: 999px;
        padding: .75rem 1rem;
        background: #fff;
        color: var(--primary);
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        transition: var(--transition);
    }

        .control-refresh-btn:hover {
            color: var(--primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 8px 18px rgba(0,0,0,.12);
        }

    .kpi-card {
        background: rgba(255,255,255,.86);
        backdrop-filter: blur(6px);
        border: 1px solid rgba(255,255,255,.96);
        border-radius: var(--radius-lg);
        padding: 1rem 1.1rem;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
        height: 100%;
        position: relative;
        overflow: hidden;
    }

        .kpi-card::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 5px;
            background: var(--primary);
            opacity: .9;
        }

        .kpi-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
            border-color: #f0cfcf;
        }

    .kpi-icon {
        width: 52px;
        height: 52px;
        border-radius: 15px;
        display: grid;
        place-items: center;
        font-size: 1.22rem;
        background: var(--primary-soft);
        color: var(--primary);
        flex-shrink: 0;
    }

        .kpi-icon.route {
            background: var(--info-soft);
            color: var(--info);
        }

        .kpi-icon.warning {
            background: var(--warning-soft);
            color: #9a6700;
        }

        .kpi-icon.success {
            background: var(--success-soft);
            color: var(--success);
        }

    .detail-label {
        color: var(--muted);
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .45px;
        font-weight: 800;
    }

    .detail-value {
        font-size: .95rem;
        font-weight: 700;
        color: var(--text);
        word-break: break-word;
    }

    .control-filter-panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        padding: 1.15rem;
        margin-bottom: 1.1rem;
        box-shadow: var(--shadow-sm);
    }

    .control-filter-title {
        font-size: 1rem;
        font-weight: 800;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: .55rem;
        color: var(--text);
    }

        .control-filter-title i {
            color: var(--primary);
        }

    .control-filter-grid {
        display: grid;
        grid-template-columns: minmax(240px, 1.4fr) repeat(2, minmax(170px, .8fr)) auto auto;
        gap: .8rem;
        align-items: end;
    }

    .control-filter-group label {
        display: block;
        font-size: .78rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .45px;
        margin-bottom: .4rem;
        font-weight: 800;
    }

    .control-input {
        width: 100%;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text);
        border-radius: 12px;
        padding: .72rem .85rem;
        outline: none;
        font-weight: 600;
        transition: var(--transition);
    }

        .control-input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(139,0,0,.10);
        }

    .control-filter-btn {
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: .72rem 1rem;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        text-decoration: none;
        cursor: pointer;
        white-space: nowrap;
        transition: var(--transition);
    }

        .control-filter-btn.primary {
            background: linear-gradient(to right, #8B0000, #5a0000);
            color: #fff;
            border-color: var(--primary);
        }

        .control-filter-btn.secondary {
            background: #fff;
            color: var(--text);
        }

        .control-filter-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 18px rgba(15,23,42,.08);
        }

    .embarque-card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        padding: 1.15rem;
        margin-bottom: 1rem;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

        .embarque-card::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 5px;
            background: var(--primary);
        }

        .embarque-card:hover {
            border-color: #f0cfcf;
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
        }

    .embarque-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
    }

    .embarque-id {
        font-size: 1.35rem;
        font-weight: 900;
        color: var(--primary);
        display: flex;
        align-items: center;
        gap: .45rem;
        flex-wrap: wrap;
    }

    .status-badge {
        padding: .52rem .9rem;
        border-radius: 999px;
        font-size: .82rem;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        white-space: nowrap;
        border: 1px solid transparent;
    }

        .status-badge i {
            font-size: .7rem;
        }

    .status-pendiente-validaciones {
        background: var(--warning-soft);
        color: #9a6700;
        border-color: #ffe4ad;
    }

    .status-liberado-qr {
        background: var(--success-soft);
        color: var(--success);
        border-color: #ccebd8;
    }

    .status-en-ruta {
        background: var(--info-soft);
        color: var(--info);
        border-color: #cfe2ff;
    }

    .status-en-destino {
        background: #f1edff;
        color: #6841c7;
        border-color: #ded4ff;
    }

    .status-retrasado {
        background: var(--danger-soft);
        color: var(--danger);
        border-color: #f6cfd4;
    }

    .status-entregado {
        background: var(--success-soft);
        color: var(--success);
        border-color: #ccebd8;
    }

    .status-devuelto {
        background: #eef1f4;
        color: #6c757d;
        border-color: #d8dee5;
    }

    .embarque-details {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: .9rem;
        margin-bottom: 1rem;
    }

    .detail-item {
        background: var(--panel-soft);
        border: 1px solid #e7ecf2;
        border-radius: 14px;
        padding: .82rem .9rem;
        display: flex;
        flex-direction: column;
        gap: .25rem;
    }

    .embarque-actions {
        display: flex;
        gap: .55rem;
        flex-wrap: wrap;
        padding-top: .15rem;
    }

    .action-btn {
        padding: .68rem .9rem;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text);
        font-size: .84rem;
        font-weight: 800;
        cursor: pointer;
        text-decoration: none;
        transition: var(--transition);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
    }

        .action-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 18px rgba(15,23,42,.08);
        }

        .action-btn.primary {
            background: var(--info-soft);
            border-color: #cfe2ff;
            color: var(--info);
        }

            .action-btn.primary:hover {
                background: var(--info);
                color: #fff;
            }

        .action-btn.success {
            background: var(--success-soft);
            border-color: #ccebd8;
            color: var(--success);
        }

            .action-btn.success:hover {
                background: var(--success);
                color: #fff;
            }

        .action-btn.warning {
            background: var(--warning-soft);
            border-color: #ffe4ad;
            color: #9a6700;
        }

            .action-btn.warning:hover {
                background: var(--warning);
                color: #fff;
            }

        .action-btn.danger {
            background: var(--danger-soft);
            border-color: #f6cfd4;
            color: var(--danger);
        }

            .action-btn.danger:hover {
                background: var(--danger);
                color: #fff;
            }

    .doc-badge {
        font-size: .68rem;
        padding: .28rem .55rem;
        border-radius: 999px;
        font-weight: 900;
        letter-spacing: .4px;
        border: 1px solid transparent;
    }

        .doc-badge.ov {
            background: var(--info-soft);
            color: var(--info);
            border-color: #cfe2ff;
        }

        .doc-badge.tr {
            background: var(--success-soft);
            color: var(--success);
            border-color: #ccebd8;
        }

        .doc-badge.mixto {
            background: var(--primary-soft);
            color: var(--primary);
            border-color: #f0cfcf;
        }

    .pedido-list {
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
        align-items: center;
        max-height: 82px;
        overflow-y: auto;
        padding-right: .2rem;
    }

    .pedido-chip {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .42rem .62rem;
        border-radius: 999px;
        font-size: .76rem;
        font-weight: 800;
        line-height: 1;
        border: 1px solid #e7ecf2;
        background: #fff;
        color: var(--text);
        white-space: nowrap;
    }

        .pedido-chip.ov {
            background: var(--info-soft);
            color: var(--info);
            border-color: #cfe2ff;
        }

        .pedido-chip.tr {
            background: var(--success-soft);
            color: var(--success);
            border-color: #ccebd8;
        }

    .pedido-chip-type {
        font-size: .66rem;
        padding: .22rem .4rem;
        border-radius: 999px;
        background: rgba(255,255,255,.75);
        color: inherit;
        letter-spacing: .35px;
    }

    .pedido-empty {
        color: var(--muted);
        font-size: .9rem;
        font-weight: 700;
    }

    .empty-state {
        text-align: center;
        padding: 3.2rem 1rem;
        background: var(--panel);
        border: 1px dashed var(--border-strong);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-sm);
    }

        .empty-state i {
            font-size: 3.8rem;
            color: var(--muted);
            opacity: .32;
            margin-bottom: 1rem;
        }

        .empty-state h3 {
            color: var(--text);
            font-size: 1.1rem;
            font-weight: 800;
        }

        .empty-state p {
            color: var(--muted);
        }

    .custom-modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.45);
        backdrop-filter: blur(8px);
        z-index: 9999;
        animation: fadeIn .22s ease;
        padding: 1rem;
    }

        .custom-modal.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

    .modal-content {
        background: var(--panel);
        border-radius: var(--radius-xl);
        padding: 1.8rem;
        max-width: 500px;
        width: 100%;
        border: 1px solid var(--border);
        box-shadow: 0 22px 60px rgba(15,23,42,.24);
        animation: slideUp .22s ease;
        position: relative;
    }

    .modal-header {
        margin-bottom: 1.3rem;
    }

    .modal-title {
        font-size: 1.35rem;
        font-weight: 900;
        color: var(--text);
        margin-bottom: .4rem;
    }

    .modal-subtitle {
        font-size: .95rem;
        color: var(--muted);
        margin: 0;
    }

    .modal-footer {
        display: flex;
        gap: .75rem;
        justify-content: flex-end;
        border-top: 1px solid var(--border);
        padding-top: 1rem;
    }

    .modal-btn {
        padding: .72rem 1.1rem;
        border-radius: 12px;
        border: none;
        font-size: .9rem;
        font-weight: 800;
        cursor: pointer;
        transition: var(--transition);
    }

        .modal-btn.cancel {
            background: #eef1f4;
            color: var(--text);
        }

            .modal-btn.cancel:hover {
                background: #dfe5ec;
            }

        .modal-btn.confirm {
            background: linear-gradient(to right, #8B0000, #5a0000);
            color: #fff;
        }

            .modal-btn.confirm:hover {
                transform: translateY(-1px);
                box-shadow: 0 8px 18px rgba(139,0,0,.20);
            }

    .modal-icon {
        width: 64px;
        height: 64px;
        margin: 0 auto 1rem;
        border-radius: 20px;
        display: grid;
        place-items: center;
        font-size: 1.75rem;
    }

        .modal-icon.success {
            background: var(--success-soft);
            color: var(--success);
        }

        .modal-icon.warning {
            background: var(--warning-soft);
            color: #9a6700;
        }

        .modal-icon.danger {
            background: var(--danger-soft);
            color: var(--danger);
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(18px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 992px) {
        .control-filter-grid {
            grid-template-columns: 1fr 1fr;
        }

        .embarque-header {
            flex-direction: column;
        }
    }

    @@media (max-width: 650px) {
        .control-wrap {
            padding: 1rem .65rem 1.5rem;
        }

        .control-header {
            padding: 1.1rem;
            border-radius: 18px;
        }

        .control-title-box {
            align-items: flex-start;
        }

        .control-header h2 {
            font-size: 1.25rem;
        }

        .control-header-icon {
            width: 50px;
            height: 50px;
            font-size: 1.2rem;
        }

        .control-refresh-btn,
        .control-filter-btn,
        .action-btn {
            width: 100%;
        }

        .control-filter-grid {
            grid-template-columns: 1fr;
        }

        .embarque-card {
            padding: 1rem;
        }

        .embarque-id {
            font-size: 1.15rem;
        }

        .status-badge {
            width: 100%;
            justify-content: center;
        }

        .modal-footer {
            flex-direction: column;
        }

        .modal-btn {
            width: 100%;
        }
    }

    /* ============================================================
       DARK MODE - CONTROL CENTER LOGÍSTICA
============================================================ */

body[data-theme="dark"] {
    --primary: #ef4444;
    --primary-dark: #991b1b;
    --primary-soft: rgba(127,29,29,0.24);
    --accent: #f87171;

    --bg: #0f172a;
    --panel: #111827;
    --panel-soft: #172033;
    --border: rgba(255,255,255,0.12);
    --border-strong: rgba(203,213,225,0.28);
    --text: #f9fafb;
    --muted: #cbd5e1;

    --success: #22c55e;
    --success-soft: rgba(22,101,52,0.26);
    --warning: #f59e0b;
    --warning-soft: rgba(180,83,9,0.22);
    --danger: #f87171;
    --danger-soft: rgba(153,27,27,0.30);
    --info: #60a5fa;
    --info-soft: rgba(30,64,175,0.24);

    --shadow-sm: 0 10px 26px rgba(0,0,0,.34);
    --shadow-md: 0 18px 42px rgba(0,0,0,.46);
}

/* Fondo general */
body[data-theme="dark"] {
    background: #0f172a !important;
    color: #e5e7eb !important;
}

body[data-theme="dark"] .layout-main-content {
    background: #0f172a !important;
}

body[data-theme="dark"] .layout-main-content .layout-container-fluid {
    background: transparent !important;
    box-shadow: none !important;
}

body[data-theme="dark"] .control-wrap {
    color: #e5e7eb !important;
}

/* Header */
body[data-theme="dark"] .control-header {
    background: linear-gradient(135deg, #7f1d1d 0%, #450a0a 55%, #111827 100%) !important;
    border: 1px solid rgba(248,113,113,0.22) !important;
    box-shadow: var(--shadow-md) !important;
}

body[data-theme="dark"] .control-header::after {
    background: rgba(255,255,255,.04) !important;
}

body[data-theme="dark"] .control-header-icon {
    background: rgba(255,255,255,.10) !important;
    border-color: rgba(255,255,255,.14) !important;
    color: #ffffff !important;
}

body[data-theme="dark"] .control-header h2 {
    color: #ffffff !important;
}

body[data-theme="dark"] .control-header p {
    color: #fecaca !important;
}

body[data-theme="dark"] .control-refresh-btn {
    background: #0b1220 !important;
    color: #fca5a5 !important;
    border: 1px solid rgba(248,113,113,0.35) !important;
}

body[data-theme="dark"] .control-refresh-btn:hover {
    background: rgba(248,113,113,0.14) !important;
    color: #ffffff !important;
    box-shadow: 0 10px 24px rgba(0,0,0,.34) !important;
}

/* KPIs */
body[data-theme="dark"] .kpi-card {
    background: rgba(17,24,39,.94) !important;
    border-color: rgba(255,255,255,0.12) !important;
    box-shadow: var(--shadow-sm) !important;
    color: #e5e7eb !important;
}

body[data-theme="dark"] .kpi-card:hover {
    border-color: rgba(248,113,113,0.35) !important;
    box-shadow: var(--shadow-md) !important;
}

body[data-theme="dark"] .kpi-card::before {
    background: #ef4444 !important;
}

body[data-theme="dark"] .kpi-card .h2 {
    color: #f9fafb !important;
}

body[data-theme="dark"] .kpi-icon {
    background: rgba(127,29,29,0.24) !important;
    color: #fca5a5 !important;
}

body[data-theme="dark"] .kpi-icon.route {
    background: rgba(30,64,175,0.24) !important;
    color: #bfdbfe !important;
}

body[data-theme="dark"] .kpi-icon.warning {
    background: rgba(180,83,9,0.22) !important;
    color: #fde68a !important;
}

body[data-theme="dark"] .kpi-icon.success {
    background: rgba(22,101,52,0.26) !important;
    color: #bbf7d0 !important;
}

/* Filtros */
