</style>

<div class="control-wrap">
    <!-- Header -->
    <div class="control-header">
        <div class="control-header-inner">
            <div class="control-title-box">
                <div class="control-header-icon">
                    <i class="fa-solid fa-gauge-high"></i>
                </div>

                <div>
                    <h2>Control Center · Logística</h2>
                    <p>Monitoreo en tiempo real de rutas, incidencias y entregas</p>
                </div>
            </div>

            <button type="button" class="control-refresh-btn" onclick="location.reload()">
                <i class="fa-solid fa-rotate-right"></i>
                Actualizar
            </button>
        </div>
    </div>

    <!-- KPIs -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="kpi-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="detail-label mb-2">Viajes activos</div>
                        <div class="h2 mb-0 fw-bold">@totalViajes</div>
                    </div>
                    <div class="kpi-icon">
                        <i class="fa-solid fa-truck-fast"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="detail-label mb-2">En ruta</div>
                        <div class="h2 mb-0 fw-bold" style="color: var(--accent-blue);">@enRuta</div>
                    </div>
                    <div class="kpi-icon route">
                        <i class="fa-solid fa-truck"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="detail-label mb-2">Incidencias</div>
                        <div class="h2 mb-0 fw-bold" style="color: var(--accent-yellow);">@retrasados</div>
                    </div>
                    <div class="kpi-icon warning">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="kpi-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="detail-label mb-2">Entregados hoy</div>
                        <div class="h2 mb-0 fw-bold" style="color: var(--accent-green);">@entregados</div>
                    </div>
                    <div class="kpi-icon success">
                        <i class="fa-solid fa-circle-check"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="control-filter-panel">
        <div class="control-filter-title">
            <i class="fa-solid fa-filter"></i>
            Filtros de búsqueda
        </div>

        <form method="get" asp-action="ControlCenter" class="control-filter-grid">
            <div class="control-filter-group">
                <label>Buscar embarque</label>
                <input type="text"
                       name="busqueda"
                       value="@busqueda"
                       class="control-input"
                       placeholder="Ej. EMB-0001, 125, consecutivo..." />
            </div>

            <div class="control-filter-group">
                <label>Fecha inicio</label>
                <input type="date"
                       name="fechaInicio"
                       value="@fechaInicio"
                       class="control-input" />
            </div>

            <div class="control-filter-group">
                <label>Fecha fin</label>
                <input type="date"
                       name="fechaFin"
                       value="@fechaFin"
                       class="control-input" />
            </div>

            <button type="submit" class="control-filter-btn primary">
                <i class="fa-solid fa-magnifying-glass"></i>
                Buscar
            </button>

            <a asp-action="ControlCenter" class="control-filter-btn secondary">
                <i class="fa-solid fa-rotate-left"></i>
                Limpiar
            </a>
        </form>
    </div>

    <!-- Lista de Embarques -->
    <div id="embarques-container">
        @if (embarques.Any())
        {
            foreach (var e in embarques)
            {
                string statusClass = e.Estatus switch
                {
                    1 => "status-pendiente-validaciones",
                    7 => "status-liberado-qr",
                    2 => "status-en-ruta",
                    3 => "status-en-destino",
                    4 => "status-retrasado",
                    5 => "status-entregado",
                    6 => "status-devuelto",
                    _ => ""
                };

                string statusText = e.Estatus switch
                {
                    1 => "Pendiente de validaciones",
                    7 => "Liberado para QR",
                    2 => "En Ruta",
                    3 => "En Destino",
                    4 => "Incidencia",
                    5 => "Entregado",
                    6 => "Devuelto",
                    _ => "Desconocido"
                };

                string statusIcon = e.Estatus switch
                {
                    1 => "fa-hourglass-half",
                    7 => "fa-qrcode",
                    2 => "fa-truck",
                    3 => "fa-location-dot",
                    4 => "fa-triangle-exclamation",
                    5 => "fa-circle-check",
                    6 => "fa-rotate-left",
                    _ => "fa-question"
                };

                <div class="embarque-card" data-embarque-id="@e.EmbarqueId" data-estatus="@e.Estatus">
                    <div class="embarque-header">
                        <div>
                            <div class="embarque-id">
                                #@e.EmbarqueConsecutivo

                                @if (e.TipoDocumento == "OV")
                                {
                                    <span class="doc-badge ov">OV</span>
                                }
                                else if (e.TipoDocumento == "TR")
                                {
                                    <span class="doc-badge tr">TR</span>
                                }
                                else
                                {
                                    <span class="doc-badge mixto">OV + TR</span>
                                }
                            </div>

                            <small style="color: var(--text-secondary);">
                                Ruta: @e.Ruta
                            </small>
                        </div>

                        <span class="status-badge @statusClass">
                            <i class="fa-solid @statusIcon"></i>
                            @statusText
                        </span>

                        @if (e.Estatus == 1)
                        {
                            <div style="margin-top:.55rem; display:flex; gap:.4rem; flex-wrap:wrap;">
                                <span class="doc-badge @(e.CalidadAprobada ? "tr" : "mixto")">
                                    Calidad: @(e.CalidadAprobada ? "OK" : "Pendiente")
                                </span>

                                <span class="doc-badge @(e.DocumentacionAprobada ? "tr" : "mixto")">
                                    Docs. Logística: @(e.DocumentacionAprobada ? "OK" : "Pendiente")
                                </span>

                                <span class="doc-badge @(e.DocumentacionCalidadAprobada ? "tr" : "mixto")">
                                    Docs. Calidad: @(e.DocumentacionCalidadAprobada ? "OK" : "Pendiente")
                                </span>
                            </div>
                        }

                    </div>


                    <div class="embarque-details">
                        <div class="detail-item">
                            <span class="detail-label">Cliente</span>
                            <span class="detail-value">@e.Cliente</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Presentacion</span>
                            <span class="detail-value">@e.Temperatura</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Pedidos / Transferencias</span>

                            @{
                                string pedidosTexto = Convert.ToString(e.Pedido) ?? "";

                                var pedidosLista = pedidosTexto
                                .Split("||", StringSplitOptions.RemoveEmptyEntries)
                                .Select(p => p.Trim())
                                .Where(p => !string.IsNullOrWhiteSpace(p))
                                .ToList();
                            }

                            @if (pedidosLista.Any())
                            {
                                <div class="pedido-list">
                                    @foreach (var pedido in pedidosLista)
                                    {
                                        bool esOv = pedido.StartsWith("OV ");
                                        bool esTr = pedido.StartsWith("TR ");

                                        string tipo = esOv ? "OV" : esTr ? "TR" : "DOC";
                                        string clase = esOv ? "ov" : esTr ? "tr" : "";
                                        string texto = esOv || esTr ? pedido.Substring(3) : pedido;

                                        <span class="pedido-chip @clase">
                                            <span class="pedido-chip-type">@tipo</span>
                                            @texto
                                        </span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="pedido-empty">Sin información</span>
                            }
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Salida</span>
                            <span class="detail-value">@(e.FechaSalida != null ? ((DateTime)e.FechaSalida).ToString("dd/MM HH:mm") : "N/A")</span>
                        </div>
                    </div>

                    <div class="embarque-actions">
                        @* EN RUTA *@
                        @if (e.Estatus == 2)
                        {
                            <button class="action-btn primary"
                                    onclick="mostrarModal(@e.EmbarqueId, 3, 'Confirmar llegada', '¿El embarque ha llegado a su destino?', 'success')">
                                <i class="fa-solid fa-location-dot"></i>
                                Llegó a destino
                            </button>

                            <button class="action-btn warning"
                                    onclick="mostrarModal(@e.EmbarqueId, 4, 'Marcar incidencia', '¿Deseas marcar una incidencia para este embarque?', 'warning')">
                                <i class="fa-solid fa-triangle-exclamation"></i>
                                Marcar incidencia
                            </button>

                            <button class="action-btn danger"
                                    onclick="mostrarModal(@e.EmbarqueId, 6, 'Marcar devolución', '¿Este embarque fue devuelto?', 'danger')">
                                <i class="fa-solid fa-rotate-left"></i>
                                Marcar devuelto
                            </button>
                        }

                        @* EN DESTINO *@
                        @if (e.Estatus == 3)
                        {
                            <button class="action-btn success"
                                    onclick="mostrarModal(@e.EmbarqueId, 5, 'Confirmar entrega', '¿Se ha completado la entrega?', 'success')">
                                <i class="fa-solid fa-check"></i>
                                Marcar entregado
                            </button>

                            <button class="action-btn warning"
                                    onclick="mostrarModal(@e.EmbarqueId, 4, 'Marcar incidencia', '¿Deseas marcar una incidencia para este embarque?', 'warning')">
                                <i class="fa-solid fa-triangle-exclamation"></i>
                                Marcar incidencia
                            </button>

                            <button class="action-btn danger"
                                    onclick="mostrarModal(@e.EmbarqueId, 6, 'Marcar devolución', '¿Este embarque fue devuelto?', 'danger')">
                                <i class="fa-solid fa-rotate-left"></i>
                                Marcar devuelto
                            </button>

                            <button class="action-btn warning"
                                    onclick="mostrarModal(@e.EmbarqueId, 2, 'Regresar a ruta', '¿Deseas regresar este embarque a En Ruta?', 'warning')">
                                <i class="fa-solid fa-arrow-left"></i>
                                Regresar a ruta
                            </button>
                        }

                        @* INCIDENCIA *@
                        @if (e.Estatus == 4)
                        {
                            <button class="action-btn primary"
                                    onclick="mostrarModal(@e.EmbarqueId, 2, 'Reanudar ruta', '¿El embarque está nuevamente en ruta?', 'success')">
                                <i class="fa-solid fa-truck"></i>
                                Volver a en ruta
                            </button>

                            <button class="action-btn primary"
                                    onclick="mostrarModal(@e.EmbarqueId, 3, 'Confirmar llegada', '¿El embarque ya llegó a destino?', 'success')">
                                <i class="fa-solid fa-location-dot"></i>
                                Llegó a destino
                            </button>

                            <button class="action-btn danger"
                                    onclick="mostrarModal(@e.EmbarqueId, 6, 'Marcar devolución', '¿Este embarque fue devuelto?', 'danger')">
                                <i class="fa-solid fa-rotate-left"></i>
                                Marcar devuelto
                            </button>
                        }

                        @* ENTREGADO *@
                        @if (e.Estatus == 5)
                        {
                            <button class="action-btn warning"
                                    onclick="mostrarModal(@e.EmbarqueId, 3, 'Corregir entrega', '¿Deseas regresar a En Destino?', 'warning')">
                                <i class="fa-solid fa-rotate-left"></i>
                                Corregir entrega
                            </button>
                        }

                        @* DEVUELTO *@
                        @if (e.Estatus == 6)
                        {
                            <button class="action-btn warning"
                                    onclick="mostrarModal(@e.EmbarqueId, 2, 'Corregir devolución', '¿Deseas regresar este embarque a En Ruta?', 'warning')">
                                <i class="fa-solid fa-truck"></i>
                                Corregir a ruta
                            </button>

                            <button class="action-btn warning"
                                    onclick="mostrarModal(@e.EmbarqueId, 3, 'Corregir devolución', '¿Deseas regresar este embarque a En Destino?', 'warning')">
                                <i class="fa-solid fa-location-dot"></i>
                                Corregir a destino
                            </button>
                        }

                        @if (!string.IsNullOrWhiteSpace(Convert.ToString(e.Token)))
                        {
                            <a href="@Url.Action("TrackingSIGO", "Embarques", new { token = e.Token })"
                               class="action-btn"
                               target="_blank">
                                <i class="fa-solid fa-eye"></i>
                                Ver tracking
                            </a>
                        }
                        else
                        {
                            <span class="action-btn disabled"
                                  style="opacity:.55; cursor:not-allowed; pointer-events:none;">
                                <i class="fa-solid fa-lock"></i>
                                Tracking no disponible
                            </span>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="fa-solid fa-inbox"></i>
                <h3>No hay embarques en tránsito</h3>
                <p style="color: var(--text-secondary);">Los embarques activos aparecerán aquí</p>
            </div>
        }
    </div>

    <div class="control-filter-panel" style="margin-top:1.6rem;">
        <div class="control-filter-title">
            <i class="fa-solid fa-box-archive"></i>
            Embarques completados

            @if (buscoCompletados)
            {
                <span class="doc-badge tr">@embarquesCompletados.Count resultado(s)</span>
            }
        </div>

        <form method="get" asp-action="ControlCenter" class="control-filter-grid">
            <input type="hidden" name="busqueda" value="@busqueda" />
            <input type="hidden" name="fechaInicio" value="@fechaInicio" />
            <input type="hidden" name="fechaFin" value="@fechaFin" />

            <div class="control-filter-group">
                <label>Buscar completado</label>
                <input type="text"
                       name="busquedaCompletados"
                       value="@busquedaCompletados"
                       class="control-input"
                       placeholder="Ej. EMB-0001, nombre o ID" />
            </div>

            <div class="control-filter-group">
                <label>Fecha entregado inicio</label>
                <input type="date"
                       name="fechaInicioCompletados"
                       value="@fechaInicioCompletados"
                       class="control-input" />
            </div>

            <div class="control-filter-group">
                <label>Fecha entregado fin</label>
                <input type="date"
                       name="fechaFinCompletados"
                       value="@fechaFinCompletados"
                       class="control-input" />
            </div>

            <button type="submit" class="control-filter-btn primary">
                <i class="fa-solid fa-magnifying-glass"></i>
                Buscar completados
            </button>

            <a asp-action="ControlCenter"
               asp-route-busqueda="@busqueda"
               asp-route-fechaInicio="@fechaInicio"
               asp-route-fechaFin="@fechaFin"
               class="control-filter-btn secondary">
                <i class="fa-solid fa-rotate-left"></i>
                Limpiar completados
            </a>
        </form>

        <div style="margin-top:.8rem; color:var(--muted); font-weight:700; font-size:.9rem;">
            <i class="fa-solid fa-circle-info"></i>
            Para cuidar el rendimiento, los completados no cargan hasta seleccionar fecha inicio y fecha fin.
        </div>
    </div>

    <div id="embarques-completados-container">
        @if (!buscoCompletados)
        {
            <div class="empty-state">
                <i class="fa-solid fa-calendar-days"></i>
                <h3>Selecciona un rango de fechas</h3>
                <p>Los embarques completados aparecerán aquí después de aplicar los filtros.</p>
            </div>
        }
        else if (!embarquesCompletados.Any())
        {
            <div class="empty-state">
                <i class="fa-solid fa-inbox"></i>
                <h3>No hay completados con esos filtros</h3>
                <p>Prueba con otro rango de fechas o con otra búsqueda.</p>
            </div>
        }
        else
        {
            foreach (var e in embarquesCompletados)
            {
                string pedidosTexto = Convert.ToString(e.Pedido) ?? "";

                var pedidosLista = pedidosTexto
                .Split("||", StringSplitOptions.RemoveEmptyEntries)
                .Select(p => p.Trim())
                .Where(p => !string.IsNullOrWhiteSpace(p))
                .ToList();

                string fechaCreacionTxt = e.FechaCreacion == null
                ? "Sin registro"
                : ((DateTime)e.FechaCreacion).ToString("dd/MM/yyyy HH:mm");

                string fechaSalidaTxt = e.FechaSalida == null
                ? "Sin registro"
                : ((DateTime)e.FechaSalida).ToString("dd/MM/yyyy HH:mm");

                string fechaDestinoTxt = e.FechaLlegadaDestino == null
                ? "Sin registro"
                : ((DateTime)e.FechaLlegadaDestino).ToString("dd/MM/yyyy HH:mm");

                string fechaEntregadoTxt = e.FechaEntregado == null
                ? "Sin registro"
                : ((DateTime)e.FechaEntregado).ToString("dd/MM/yyyy HH:mm");

                <div class="embarque-card"
                     data-embarque-id="@e.EmbarqueId"
                     data-estatus="@e.Estatus"
                     data-es-completado="true">

                    <div class="embarque-header">
                        <div>
                            <div class="embarque-id">
                                #@e.EmbarqueConsecutivo

                                @if (e.TipoDocumento == "OV")
                                {
                                    <span class="doc-badge ov">OV</span>
                                }
                                else if (e.TipoDocumento == "TR")
                                {
                                    <span class="doc-badge tr">TR</span>
                                }
                                else
                                {
                                    <span class="doc-badge mixto">OV + TR</span>
                                }
                            </div>

                            <small style="color: var(--text-secondary);">
                                Ruta: @e.Ruta
                            </small>

                            @if (!string.IsNullOrWhiteSpace(Convert.ToString(e.NombreEmbarque)))
                            {
                                <br />
                                <small style="color: var(--text-secondary); font-weight:700;">
                                    Nombre: @e.NombreEmbarque
                                </small>
                            }
                        </div>

                        <span class="status-badge status-entregado">
                            <i class="fa-solid fa-circle-check"></i>
                            Entregado
                        </span>
                    </div>

                    <div class="embarque-details">
                        <div class="detail-item">
                            <span class="detail-label">Cliente / destino</span>
                            <span class="detail-value">@e.Cliente</span>
                        </div>

                        <div class="detail-item">
                            <span class="detail-label">Presentación</span>
                            <span class="detail-value">@e.Temperatura</span>
                        </div>

                        <div class="detail-item">
                            <span class="detail-label">Fecha creación</span>
                            <span class="detail-value">@fechaCreacionTxt</span>
                        </div>

                        <div class="detail-item">
                            <span class="detail-label">Fecha salida</span>
                            <span class="detail-value">@fechaSalidaTxt</span>
                        </div>

                        <div class="detail-item">
                            <span class="detail-label">Fecha destino</span>
                            <span class="detail-value">@fechaDestinoTxt</span>
                        </div>

                        <div class="detail-item">
                            <span class="detail-label">Fecha entregado</span>
                            <span class="detail-value">@fechaEntregadoTxt</span>
                        </div>

                        <div class="detail-item">
                            <span class="detail-label">Pedidos / transferencias</span>

                            @if (pedidosLista.Any())
                            {
                                <div class="pedido-list">
                                    @foreach (var pedido in pedidosLista)
                                    {
                                        bool esOv = pedido.StartsWith("OV ");
                                        bool esTr = pedido.StartsWith("TR ");

                                        string tipo = esOv ? "OV" : esTr ? "TR" : "DOC";
                                        string clase = esOv ? "ov" : esTr ? "tr" : "";
                                        string texto = esOv || esTr ? pedido.Substring(3) : pedido;

                                        <span class="pedido-chip @clase">
                                            <span class="pedido-chip-type">@tipo</span>
                                            @texto
                                        </span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="pedido-empty">Sin información</span>
                            }
                        </div>
                    </div>

                    <div class="embarque-actions">
                        <button class="action-btn warning"
                                onclick="mostrarModal(@e.EmbarqueId, 3, 'Corregir entrega', '¿Deseas regresar este embarque a En Destino?', 'warning')">
                            <i class="fa-solid fa-rotate-left"></i>
                            Regresar a En Destino
                        </button>

                        @if (!string.IsNullOrWhiteSpace(Convert.ToString(e.Token)))
                        {
                            <a href="@Url.Action("TrackingSIGO", "Embarques", new { token = e.Token })"
                               class="action-btn primary"
                               target="_blank">
                                <i class="fa-solid fa-eye"></i>
                                Ver tracking
                            </a>
                        }
                    </div>
                </div>
            }
        }
    </div>

</div>

<!-- Modal personalizado -->
<div id="confirmModal" class="custom-modal">
    <div class="modal-content">
        <div class="modal-header text-center">
            <div class="modal-icon" id="modalIcon">
                <i class="fa-solid fa-question"></i>
            </div>
            <h3 class="modal-title" id="modalTitle">Confirmar acción</h3>
            <p class="modal-subtitle" id="modalSubtitle">¿Estás seguro de realizar esta acción?</p>
        </div>
        <div class="modal-footer">
            <button class="modal-btn cancel" onclick="cerrarModal()">
                Cancelar
            </button>
            <button class="modal-btn confirm" id="btnConfirmar">
                Confirmar
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let embarqueActual = null;
        let estatusNuevo = null;
        let procesandoCambio = false;

        function mostrarModal(embarqueId, nuevoEstatus, titulo, mensaje, tipo) {
            if (procesandoCambio) return;

            embarqueActual = embarqueId;
            estatusNuevo = nuevoEstatus;

            const modal = document.getElementById('confirmModal');
            const modalIcon = document.getElementById('modalIcon');
            const modalTitle = document.getElementById('modalTitle');
            const modalSubtitle = document.getElementById('modalSubtitle');
            const btnConfirmar = document.getElementById('btnConfirmar');

            const iconos = {
                success: 'fa-circle-check',
                warning: 'fa-triangle-exclamation',
                danger: 'fa-circle-exclamation'
            };

            modalIcon.className = `modal-icon ${tipo}`;
            modalIcon.innerHTML = `<i class="fa-solid ${iconos[tipo] || 'fa-question'}"></i>`;

            modalTitle.textContent = titulo;
            modalSubtitle.textContent = mensaje;

            // Asegurar que el botón quede limpio cada vez que se abre el modal
            btnConfirmar.disabled = false;
            btnConfirmar.textContent = 'Confirmar';

            modal.classList.add('active');
        }

        function cerrarModal() {
            const modal = document.getElementById('confirmModal');
            const btnConfirmar = document.getElementById('btnConfirmar');

            modal.classList.remove('active');

            embarqueActual = null;
            estatusNuevo = null;
            procesandoCambio = false;

            btnConfirmar.disabled = false;
            btnConfirmar.textContent = 'Confirmar';
        }

        document.getElementById('btnConfirmar').addEventListener('click', function () {
            if (!procesandoCambio && embarqueActual && estatusNuevo) {
                cambiarEstatus(embarqueActual, estatusNuevo);
            }
        });

        document.getElementById('confirmModal').addEventListener('click', function (e) {
            if (e.target === this && !procesandoCambio) {
                cerrarModal();
            }
        });

        async function cambiarEstatus(embarqueId, nuevoEstatus) {
            const btnConfirmar = document.getElementById('btnConfirmar');

            if (procesandoCambio) return;
            procesandoCambio = true;

            btnConfirmar.disabled = true;
            btnConfirmar.textContent = 'Procesando...';

            try {
                const response = await fetch('@Url.Action("ActualizarEstatus", "Embarques")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        embarqueId: embarqueId,
                        nuevoEstatus: nuevoEstatus
                    })
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }

                const data = await response.json();

            if (data.success) {
                const card = document.querySelector(`[data-embarque-id="${embarqueId}"]`);
                const vieneDeCompletados = card?.dataset.esCompletado === "true";

                if (vieneDeCompletados || nuevoEstatus === 5) {
                    cerrarModal();
                    window.location.reload();
                    return;
                }

                actualizarEmbarqueUI(embarqueId, nuevoEstatus);
                actualizarKPIs();
                cerrarModal();
            } else {
                    alert('Error: ' + (data.message || 'No se pudo actualizar el estatus.'));
                    procesandoCambio = false;
                    btnConfirmar.disabled = false;
                    btnConfirmar.textContent = 'Confirmar';
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Ocurrió un error al actualizar el estatus.');
                procesandoCambio = false;
                btnConfirmar.disabled = false;
                btnConfirmar.textContent = 'Confirmar';
            }
        }

        function actualizarEmbarqueUI(embarqueId, nuevoEstatus) {
            const card = document.querySelector(`[data-embarque-id="${embarqueId}"]`);
            if (!card) return;

            const badge = card.querySelector('.status-badge');

            const statusInfo = {
                1: { class: 'status-pendiente-validaciones', icon: 'fa-hourglass-half', text: 'Pendiente de validaciones' },
                7: { class: 'status-liberado-qr', icon: 'fa-qrcode', text: 'Liberado para QR' },
                2: { class: 'status-en-ruta', icon: 'fa-truck', text: 'En Ruta' },
                3: { class: 'status-en-destino', icon: 'fa-location-dot', text: 'En Destino' },
                4: { class: 'status-retrasado', icon: 'fa-triangle-exclamation', text: 'Incidencia' },
                5: { class: 'status-entregado', icon: 'fa-circle-check', text: 'Entregado' },
                6: { class: 'status-devuelto', icon: 'fa-rotate-left', text: 'Devuelto' }
            };

            const info = statusInfo[nuevoEstatus];

            if (info) {
                badge.className = `status-badge ${info.class}`;
                badge.innerHTML = `<i class="fa-solid ${info.icon}"></i> ${info.text}`;
            }

            const actionsDiv = card.querySelector('.embarque-actions');
            const trackingLink = actionsDiv.querySelector('a[href*="TrackingSIGO"]');
            const trackingBtn = trackingLink ? trackingLink.outerHTML : '';

            let newButtons = '';

            if (nuevoEstatus === 2) {
                newButtons = `
                    <button class="action-btn primary" onclick="mostrarModal(${embarqueId}, 3, 'Confirmar llegada', '¿El embarque ha llegado a su destino?', 'success')">
                        <i class="fa-solid fa-location-dot"></i>
                        Llegó a destino
                    </button>

                    <button class="action-btn warning" onclick="mostrarModal(${embarqueId}, 4, 'Marcar incidencia', '¿Deseas marcar una incidencia para este embarque?', 'warning')">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        Marcar incidencia
                    </button>

                    <button class="action-btn danger" onclick="mostrarModal(${embarqueId}, 6, 'Marcar devolución', '¿Este embarque fue devuelto?', 'danger')">
                        <i class="fa-solid fa-rotate-left"></i>
                        Marcar devuelto
                    </button>
                `;
            } else if (nuevoEstatus === 3) {
                newButtons = `
                    <button class="action-btn success" onclick="mostrarModal(${embarqueId}, 5, 'Confirmar entrega', '¿Se ha completado la entrega?', 'success')">
                        <i class="fa-solid fa-check"></i>
                        Marcar entregado
                    </button>

                    <button class="action-btn warning" onclick="mostrarModal(${embarqueId}, 4, 'Marcar incidencia', '¿Deseas marcar una incidencia para este embarque?', 'warning')">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        Marcar incidencia
                    </button>

                    <button class="action-btn danger" onclick="mostrarModal(${embarqueId}, 6, 'Marcar devolución', '¿Este embarque fue devuelto?', 'danger')">
                        <i class="fa-solid fa-rotate-left"></i>
                        Marcar devuelto
                    </button>

                    <button class="action-btn warning" onclick="mostrarModal(${embarqueId}, 2, 'Regresar a ruta', '¿Deseas regresar este embarque a En Ruta?', 'warning')">
                        <i class="fa-solid fa-arrow-left"></i>
                        Regresar a ruta
                    </button>
                `;
            } else if (nuevoEstatus === 4) {
                newButtons = `
                    <button class="action-btn primary" onclick="mostrarModal(${embarqueId}, 2, 'Reanudar ruta', '¿El embarque está nuevamente en ruta?', 'success')">
                        <i class="fa-solid fa-truck"></i>
                        Volver a en ruta
                    </button>

                    <button class="action-btn primary" onclick="mostrarModal(${embarqueId}, 3, 'Confirmar llegada', '¿El embarque ya llegó a destino?', 'success')">
                        <i class="fa-solid fa-location-dot"></i>
                        Llegó a destino
                    </button>

                    <button class="action-btn danger" onclick="mostrarModal(${embarqueId}, 6, 'Marcar devolución', '¿Este embarque fue devuelto?', 'danger')">
                        <i class="fa-solid fa-rotate-left"></i>
                        Marcar devuelto
                    </button>
                `;
            } else if (nuevoEstatus === 5) {
                newButtons = `
                    <button class="action-btn warning" onclick="mostrarModal(${embarqueId}, 3, 'Corregir entrega', '¿Deseas regresar a En Destino?', 'warning')">
                        <i class="fa-solid fa-rotate-left"></i>
                        Corregir entrega
                    </button>
                `;
            } else if (nuevoEstatus === 6) {
                newButtons = `
                    <button class="action-btn warning" onclick="mostrarModal(${embarqueId}, 2, 'Corregir devolución', '¿Deseas regresar este embarque a En Ruta?', 'warning')">
                        <i class="fa-solid fa-truck"></i>
                        Corregir a ruta
                    </button>

                    <button class="action-btn warning" onclick="mostrarModal(${embarqueId}, 3, 'Corregir devolución', '¿Deseas regresar este embarque a En Destino?', 'warning')">
                        <i class="fa-solid fa-location-dot"></i>
                        Corregir a destino
                    </button>
                `;
            }

            actionsDiv.innerHTML = newButtons + trackingBtn;
            card.dataset.estatus = nuevoEstatus;

            card.style.animation = 'none';

            setTimeout(() => {
                card.style.animation = 'slideUp 0.5s ease';
            }, 10);
        }

        function actualizarKPIs() {
            const cards = document.querySelectorAll('.embarque-card');

            let total = cards.length;
            let enRuta = 0;
            let retrasados = 0;
            let entregados = 0;

            cards.forEach(card => {
                const estatus = parseInt(card.dataset.estatus);

                if (estatus === 2) enRuta++;
                if (estatus === 4) retrasados++;
                if (estatus === 5) entregados++;
            });

            const kpiValues = document.querySelectorAll('.kpi-card .h2');
            if (kpiValues.length >= 4) {
                kpiValues[0].textContent = total;
                kpiValues[1].textContent = enRuta;
                kpiValues[2].textContent = retrasados;
                kpiValues[3].textContent = entregados;
            }
        }
    </script>
}