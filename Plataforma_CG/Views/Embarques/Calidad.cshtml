@model IEnumerable<Plataforma_CG.Models.Embarque>

@{
    ViewData["Title"] = "Calidad - Validación";
    Layout = "~/Views/Shared/_Layout2.cshtml";

    var pendientes = Model.Where(x => x.CalidadAprobada != true)
        .OrderByDescending(x => x.FechaCreacion)
        .ToList();

    var busqueda = Context.Request.Query["busqueda"].ToString();
    var fechaInicio = Context.Request.Query["fechaInicio"].ToString();
    var fechaFin = Context.Request.Query["fechaFin"].ToString();

    var historialCalidad = ViewBag.HistorialCalidad as List<Plataforma_CG.Models.Embarque>
        ?? new List<Plataforma_CG.Models.Embarque>();

    bool buscoHistorialCalidad = Convert.ToBoolean(ViewBag.BuscoHistorialCalidad ?? false);

    var busquedaHistorial = Context.Request.Query["busquedaHistorial"].ToString();
    var fechaInicioHistorial = Context.Request.Query["fechaInicioHistorial"].ToString();
    var fechaFinHistorial = Context.Request.Query["fechaFinHistorial"].ToString();

    var fotosCalidadHistorial =
        ViewBag.FotosCalidadHistorial as Dictionary<int, List<Plataforma_CG.Models.Embarque.EmbarqueCalidadFoto>>
        ?? new Dictionary<int, List<Plataforma_CG.Models.Embarque.EmbarqueCalidadFoto>>();

    var productosTemperaturaCalidad =
    ViewBag.ProductosTemperaturaCalidad
        as Dictionary<int, List<Plataforma_CG.Models.EmbarqueProductoTemperaturaItemVm>>
    ?? new Dictionary<int, List<Plataforma_CG.Models.EmbarqueProductoTemperaturaItemVm>>();
}

<style>
    :root {
        --primary: #8B0000;
        --primary-dark: #5a0000;
        --primary-soft: #fff1f1;
        --bg: #f3f6fa;
        --panel: #fff;
        --border: #dfe5ec;
        --text: #1f2937;
        --muted: #6b7280;
        --success: #198754;
        --warning: #f59e0b;
        --danger: #dc3545;
        --shadow-sm: 0 6px 18px rgba(15, 23, 42, 0.06);
        --shadow-md: 0 14px 34px rgba(15, 23, 42, 0.10);
        --radius-xl: 22px;
        --radius-lg: 18px;
        --radius-md: 14px;
        --transition: all .22s ease;
    }

    body {
        background: linear-gradient(180deg, #f8fafc 0%, #eef3f8 100%);
    }

    .quality-wrap {
        max-width: 1360px;
        margin: 2rem auto;
        padding: 0 1rem 2rem;
    }

    .quality-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 65%, #250000 100%);
        color: #fff;
        border-radius: var(--radius-xl);
        padding: 1.5rem;
        box-shadow: var(--shadow-md);
        margin-bottom: 1.2rem;
        position: relative;
        overflow: hidden;
    }

        .quality-header::after {
            content: "";
            position: absolute;
            right: -45px;
            top: -45px;
            width: 190px;
            height: 190px;
            border-radius: 50%;
            background: rgba(255,255,255,.07);
        }

    .quality-header-content {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .quality-title {
        display: flex;
        align-items: center;
        gap: .8rem;
        margin: 0;
        font-size: 1.75rem;
        font-weight: 900;
    }

    .quality-title-icon {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.18);
        display: grid;
        place-items: center;
        font-size: 1.45rem;
    }

    .quality-sub {
        margin: .45rem 0 0;
        color: rgba(255,255,255,.88);
        max-width: 780px;
    }

    .quality-date {
        padding: .6rem 1rem;
        border-radius: 999px;
        background: rgba(255,255,255,.13);
        border: 1px solid rgba(255,255,255,.18);
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
    }

    .quality-kpis {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 1rem;
        margin-bottom: 1.2rem;
    }

    .kpi-card {
        background: rgba(255,255,255,.85);
        border: 1px solid rgba(255,255,255,.9);
        box-shadow: var(--shadow-sm);
        border-radius: var(--radius-lg);
        padding: 1rem;
        display: flex;
        gap: .9rem;
        align-items: center;
    }

    .kpi-icon {
        width: 52px;
        height: 52px;
        border-radius: 15px;
        display: grid;
        place-items: center;
        background: var(--primary-soft);
        color: var(--primary);
        font-size: 1.25rem;
        flex-shrink: 0;
    }

    .kpi-label {
        color: var(--muted);
        font-size: .78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .4px;
    }

    .kpi-value {
        color: var(--primary);
        font-size: 1.7rem;
        font-weight: 900;
        line-height: 1;
    }

    .kpi-sub {
        color: var(--muted);
        font-size: .84rem;
        margin-top: .25rem;
    }

    .alert-sap {
        border: none;
        border-radius: 16px;
        box-shadow: var(--shadow-sm);
        padding: .95rem 1rem;
    }

    .empty-state {
        background: var(--panel);
        border: 1px dashed #cfd7e1;
        border-radius: var(--radius-xl);
        padding: 3rem 1.5rem;
        text-align: center;
        box-shadow: var(--shadow-sm);
    }

        .empty-state i {
            font-size: 3rem;
            color: var(--muted);
            opacity: .55;
            margin-bottom: .8rem;
        }

    .quality-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .embarque-card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        transition: var(--transition);
    }

        .embarque-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .embarque-summary {
        padding: 1.15rem 1.25rem;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        cursor: pointer;
        background: linear-gradient(180deg, #fff 0%, #fbfcfe 100%);
    }

    .embarque-id {
        color: var(--primary);
        font-weight: 900;
        font-size: 1.15rem;
        margin: 0 0 .65rem;
        display: flex;
        align-items: center;
        gap: .55rem;
    }

    .embarque-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .meta-pill {
        display: inline-flex;
        align-items: center;
        gap: .42rem;
        background: #f3f5f8;
        color: var(--text);
        border-radius: 999px;
        padding: .42rem .72rem;
        font-size: .82rem;
        font-weight: 800;
    }

        .meta-pill.pending {
            background: rgba(245,158,11,.15);
            color: #8a5a00;
        }

        .meta-pill.primary {
            background: var(--primary-soft);
            color: var(--primary);
        }

    .summary-right {
        display: flex;
        align-items: center;
        gap: .85rem;
        flex-shrink: 0;
    }

    .summary-count {
        text-align: right;
    }

        .summary-count small {
            display: block;
            color: var(--muted);
            font-size: .75rem;
            text-transform: uppercase;
            font-weight: 900;
            letter-spacing: .4px;
        }

        .summary-count strong {
            color: var(--text);
            font-size: .98rem;
        }

    .toggle-btn {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--primary);
        display: grid;
        place-items: center;
        transition: var(--transition);
        box-shadow: 0 4px 10px rgba(0,0,0,.04);
    }

    .embarque-card.active .toggle-btn {
        background: var(--primary);
        color: #fff;
        transform: rotate(180deg);
    }

    .embarque-detail {
        display: none;
        border-top: 1px solid var(--border);
        background: #f8fafc;
        padding: 1.15rem;
    }

    .embarque-card.active .embarque-detail {
        display: block;
        animation: fadeIn .22s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .validation-layout {
        display: grid;
        grid-template-columns: 330px minmax(0, 1fr);
        gap: 1rem;
        align-items: start;
    }

    .side-panel {
        position: sticky;
        top: 1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .quick-card,
    .docs-card,
    .form-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: 0 4px 12px rgba(0,0,0,.03);
        overflow: hidden;
    }

    .card-head {
        padding: .95rem 1rem;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, #fff 0%, #fafbfd 100%);
    }

    .card-title {
        margin: 0;
        font-size: 1rem;
        font-weight: 900;
        display: flex;
        align-items: center;
        gap: .5rem;
        color: var(--text);
    }

        .card-title i {
            color: var(--primary);
        }

    .card-sub {
        margin-top: .22rem;
        color: var(--muted);
        font-size: .84rem;
    }

    .card-body {
        padding: 1rem;
    }

    .quick-row {
        display: flex;
        justify-content: space-between;
        gap: .8rem;
        padding: .75rem 0;
        border-bottom: 1px solid #edf1f5;
    }

        .quick-row:last-child {
            border-bottom: 0;
        }

    .quick-label {
        color: var(--muted);
        font-size: .8rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .quick-value {
        font-weight: 900;
        color: var(--text);
        text-align: right;
    }

    .doc-buttons {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .65rem;
    }

    .doc-mini {
        border: 1px solid var(--border);
        border-radius: 15px;
        background: #f8fafc;
        padding: .85rem;
        text-align: center;
    }

        .doc-mini i {
            color: var(--primary);
            font-size: 1.25rem;
        }

        .doc-mini strong {
            display: block;
            font-size: 1.35rem;
            color: var(--primary);
            line-height: 1;
            margin-top: .35rem;
        }

        .doc-mini span {
            color: var(--muted);
            font-size: .8rem;
            font-weight: 800;
        }

    .table-wrap {
        width: 100%;
        overflow-x: auto;
        border-radius: 14px;
    }

    .tabla-soft {
        width: 100%;
        margin: 0;
        border-collapse: separate;
        border-spacing: 0;
        background: #fff;
    }

        .tabla-soft thead th {
            background: #f3f6f9;
            color: var(--text);
            font-weight: 900;
            white-space: nowrap;
            font-size: .86rem;
            padding: .82rem;
            border-bottom: 1px solid var(--border);
        }

        .tabla-soft td {
            padding: .78rem;
            border-bottom: 1px solid #edf1f5;
            font-size: .91rem;
            vertical-align: middle;
        }

        .tabla-soft tbody tr:hover {
            background: #fafbfd;
        }

    .accordion-quality {
        display: flex;
        flex-direction: column;
        gap: .85rem;
    }

    .quality-step {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: 0 4px 12px rgba(0,0,0,.03);
    }

    .step-head {
        width: 100%;
        border: none;
        background: #fff;
        padding: 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .8rem;
        cursor: pointer;
        text-align: left;
    }

    .step-head-left {
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .step-number {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        display: grid;
        place-items: center;
        background: var(--primary-soft);
        color: var(--primary);
        font-weight: 900;
        flex-shrink: 0;
    }

    .step-title {
        display: block;
        font-weight: 900;
        color: var(--text);
    }

    .step-desc {
        display: block;
        color: var(--muted);
        font-size: .83rem;
        margin-top: .1rem;
    }

    .step-chevron {
        color: var(--primary);
        transition: var(--transition);
    }

    .quality-step.open .step-chevron {
        transform: rotate(180deg);
    }

    .step-body {
        display: none;
        padding: 0 1rem 1rem;
        border-top: 1px solid #edf1f5;
    }

    .quality-step.open .step-body {
        display: block;
        animation: fadeIn .18s ease;
    }

    .form-label {
        font-weight: 800;
        color: var(--text);
        margin-bottom: .42rem;
        font-size: .93rem;
    }

    .form-control,
    .form-select {
        border-radius: 13px;
        border: 1.5px solid var(--border);
        min-height: 48px;
        transition: var(--transition);
    }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 .22rem rgba(139,0,0,.10);
        }

    textarea.form-control {
        min-height: 112px;
    }

    .input-hint {
        color: var(--muted);
        font-size: .82rem;
        margin-top: .35rem;
    }

    .upload-box {
        border: 2px dashed #d7dce2;
        border-radius: 18px;
        padding: 1rem;
        background: linear-gradient(180deg, #fcfcfd 0%, #f9fafb 100%);
        transition: var(--transition);
    }

        .upload-box.has-files {
            border-color: var(--success);
            background: #f1fff6;
        }

    .upload-help {
        color: var(--muted);
        font-size: .88rem;
        margin-top: .5rem;
    }

    .file-list {
        margin-top: .8rem;
        display: flex;
        flex-direction: column;
        gap: .5rem;
    }

    .file-item {
        background: #fff;
        border-radius: 12px;
        padding: .65rem .8rem;
        font-size: .88rem;
        color: var(--text);
        font-weight: 700;
        border: 1px solid #dcefe2;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .file-item i {
            color: var(--success);
        }

    .pending-box {
        background: linear-gradient(180deg, #fff8e8 0%, #fffdf8 100%);
        border: 1px solid #f5dfaa;
        border-radius: 16px;
        padding: 1rem;
        color: #7a5200;
    }

    .form-actions-sticky {
        position: sticky;
        bottom: 0;
        margin-top: 1rem;
        background: rgba(248,250,252,.92);
        backdrop-filter: blur(8px);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: .85rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .8rem;
        flex-wrap: wrap;
        box-shadow: 0 -8px 20px rgba(15,23,42,.06);
    }

    .action-note {
        color: var(--muted);
        font-size: .86rem;
        font-weight: 700;
    }

    .btn-sap {
        min-width: 190px;
        height: 48px;
        border-radius: 14px;
        font-weight: 900;
        border: none;
        transition: var(--transition);
        box-shadow: 0 8px 18px rgba(0,0,0,.06);
    }

    .btn-sap-success {
        background: linear-gradient(to right, #198754, #157347);
        color: #fff;
    }

        .btn-sap-success:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 22px rgba(25,135,84,.22);
            color: #fff;
        }

    .btn-sap-outline {
        border: 1px solid var(--border);
        background: #fff;
        color: var(--primary);
    }

        .btn-sap-outline:hover {
            background: var(--primary-soft);
            color: var(--primary);
        }

    @@media (max-width: 1100px) {
        .validation-layout {
            grid-template-columns: 1fr;
        }

        .side-panel {
            position: static;
        }
    }

    @@media (max-width: 768px) {
        .quality-wrap {
            padding: 0 .6rem 1.5rem;
        }

        .quality-header {
            padding: 1.1rem;
            border-radius: 18px;
        }

        .quality-title {
            font-size: 1.28rem;
        }

        .embarque-summary {
            flex-direction: column;
            align-items: stretch;
        }

        .summary-right {
            justify-content: space-between;
        }

        .summary-count {
            text-align: left;
        }

        .doc-buttons {
            grid-template-columns: 1fr;
        }

        .btn-sap {
            width: 100%;
        }

        .form-actions-sticky {
            align-items: stretch;
        }
    }

    .quality-filter-panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-sm);
        padding: 1rem;
        margin-bottom: 1.2rem;
    }

    .quality-filter-title {
        font-size: 1rem;
        font-weight: 900;
        display: flex;
        align-items: center;
        gap: .55rem;
        margin-bottom: .85rem;
        color: var(--text);
    }

    .quality-filter-grid {
        display: grid;
        grid-template-columns: minmax(240px, 1.4fr) repeat(2, minmax(180px, .8fr)) auto auto;
        gap: .8rem;
        align-items: end;
    }

    .quality-filter-group label {
        font-size: .82rem;
        font-weight: 900;
        color: var(--muted);
        text-transform: uppercase;
        margin-bottom: .35rem;
        display: block;
    }

    .quality-filter-input {
        width: 100%;
        border-radius: 13px;
        border: 1.5px solid var(--border);
        min-height: 48px;
        padding: .65rem .85rem;
        outline: none;
        background: #fff;
    }

        .quality-filter-input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 .22rem rgba(139,0,0,.10);
        }

    .quality-filter-btn {
        height: 48px;
        border-radius: 14px;
        padding: 0 1rem;
        border: none;
        font-weight: 900;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        text-decoration: none;
        white-space: nowrap;
    }

        .quality-filter-btn.primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: #fff;
        }

        .quality-filter-btn.secondary {
            background: #fff;
            color: var(--primary);
            border: 1px solid var(--border);
        }

    /* Mejoras responsive extra */
    @@media (max-width: 992px) {
        .quality-filter-grid {
            grid-template-columns: 1fr 1fr;
        }

        .validation-layout {
            grid-template-columns: 1fr !important;
        }

        .side-panel {
            position: static !important;
        }
    }

    @@media (max-width: 768px) {
        .quality-wrap {
            margin: 1rem auto !important;
            padding: 0 .65rem 1.5rem !important;
        }

        .quality-header-content {
            align-items: stretch !important;
        }

        .quality-title {
            align-items: flex-start;
            line-height: 1.15;
        }

        .quality-title-icon {
            width: 46px;
            height: 46px;
            font-size: 1.15rem;
            flex-shrink: 0;
        }

        .quality-sub {
            font-size: .9rem;
        }

        .quality-date {
            width: 100%;
            justify-content: center;
        }

        .quality-filter-grid {
            grid-template-columns: 1fr;
        }

        .quality-filter-btn {
            width: 100%;
        }

        .quality-kpis {
            grid-template-columns: 1fr !important;
        }

        .embarque-summary {
            padding: 1rem !important;
        }

        .embarque-id {
            font-size: 1rem !important;
            word-break: break-word;
        }

        .embarque-meta {
            display: grid !important;
            grid-template-columns: 1fr;
            width: 100%;
        }

        .meta-pill {
            width: 100%;
            justify-content: flex-start;
            white-space: normal;
        }

        .summary-right {
            width: 100%;
            gap: .7rem;
        }

        .toggle-btn {
            width: 42px;
            height: 42px;
            flex-shrink: 0;
        }

        .embarque-detail {
            padding: .85rem !important;
        }

        .card-body {
            padding: .85rem !important;
        }

        .quick-row {
            flex-direction: column;
            gap: .25rem;
        }

        .quick-value {
            text-align: left !important;
            word-break: break-word;
        }

        .step-head {
            align-items: flex-start !important;
        }

        .step-head-left {
            align-items: flex-start !important;
        }

        .step-title {
            font-size: .95rem;
        }

        .step-desc {
            font-size: .78rem;
        }

        .form-actions-sticky {
            position: static !important;
            margin-top: 1rem;
        }

        .action-note {
            width: 100%;
            text-align: center;
        }
    }

    @@media (max-width: 520px) {
        .quality-header {
            padding: 1rem !important;
        }

        .quality-title {
            font-size: 1.12rem !important;
        }

        .kpi-card {
            align-items: flex-start;
        }

        .kpi-icon {
            width: 44px;
            height: 44px;
            font-size: 1rem;
        }

        .kpi-value {
            font-size: 1.35rem;
        }

        .doc-buttons {
            grid-template-columns: 1fr !important;
        }

        .tabla-soft {
            min-width: 560px !important;
        }
    }

    /* FIX MOBILE: Órdenes, transferencias y documentos */
    @@media (max-width: 768px) {
        .docs-card {
            width: 100%;
        }

            .docs-card .card-body {
                padding: .85rem !important;
            }

        .doc-buttons {
            display: grid !important;
            grid-template-columns: 1fr 1fr !important;
            gap: .7rem !important;
        }

        .doc-mini {
            padding: .8rem .55rem !important;
            min-width: 0;
        }

