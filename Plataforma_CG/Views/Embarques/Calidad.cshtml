</style>

<div class="quality-wrap">

    <div class="quality-header">
        <div class="quality-header-content">
            <div>
                <h2 class="quality-title">
                    <span class="quality-title-icon">
                        <i class="bi bi-shield-check"></i>
                    </span>
                    Validación de Calidad
                </h2>
                <p class="quality-sub">
                    Revisa los embarques pendientes, valida condiciones de unidad, temperaturas, producto y evidencia antes de liberar el QR para caseta.
                </p>
            </div>

            <div class="quality-date">
                <i class="bi bi-calendar3"></i>
                @DateTime.Now.ToString("dd/MM/yyyy")
            </div>
        </div>
    </div>

    <div class="quality-kpis">
        <div class="kpi-card">
            <div class="kpi-icon">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <div>
                <div class="kpi-label">Pendientes</div>
                <div class="kpi-value">@pendientes.Count</div>
                <div class="kpi-sub">Embarques listos para revisión</div>
            </div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon">
                <i class="bi bi-check2-square"></i>
            </div>
            <div>
                <div class="kpi-label">Flujo</div>
                <div class="kpi-value" style="font-size:1.05rem;">Checklist</div>
                <div class="kpi-sub">Captura guiada por secciones</div>
            </div>
        </div>
    </div>

    <div class="quality-filter-panel">
        <div class="quality-filter-title">
            <i class="bi bi-funnel"></i>
            Filtros de búsqueda
        </div>

        <form method="get" asp-action="Calidad" class="quality-filter-grid">
            <div class="quality-filter-group">
                <label>Buscar embarque</label>
                <input type="text"
                       name="busqueda"
                       value="@busqueda"
                       class="quality-filter-input"
                       placeholder="Ej. EMB-0001, 125, consecutivo..." />
            </div>

            <div class="quality-filter-group">
                <label>Fecha inicio</label>
                <input type="date"
                       name="fechaInicio"
                       value="@fechaInicio"
                       class="quality-filter-input" />
            </div>

            <div class="quality-filter-group">
                <label>Fecha fin</label>
                <input type="date"
                       name="fechaFin"
                       value="@fechaFin"
                       class="quality-filter-input" />
            </div>

            <input type="hidden" name="busquedaHistorial" value="@busquedaHistorial" />
            <input type="hidden" name="fechaInicioHistorial" value="@fechaInicioHistorial" />
            <input type="hidden" name="fechaFinHistorial" value="@fechaFinHistorial" />

            <button type="submit" class="quality-filter-btn primary">
                <i class="bi bi-search"></i>
                Buscar
            </button>

            <a asp-action="Calidad" class="quality-filter-btn secondary">
                <i class="bi bi-arrow-clockwise"></i>
                Limpiar
            </a>
        </form>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-sap">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-sap">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        </div>
    }

    @if (!pendientes.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h4>No hay embarques pendientes de validar</h4>
            <p class="text-muted mb-0">Cuando existan nuevos embarques por revisar, aparecerán aquí.</p>
        </div>
    }
    else
    {
        <div class="quality-list">
            @foreach (var e in pendientes)
            {
                var cardId = $"card_{e.Id}";
                var filesId = $"files_{e.Id}";
                var uploadId = $"upload_{e.Id}";
                var formId = $"form_{e.Id}";

                var docsMap = ViewBag.EmbarquesDocumentos as Dictionary<int, object>;
                dynamic docs = docsMap != null && docsMap.ContainsKey(e.Id) ? docsMap[e.Id] : null;

                IEnumerable<dynamic> ordenes = docs?.OrdenesVenta ?? Enumerable.Empty<dynamic>();
                IEnumerable<dynamic> transferencias = docs?.Transferencias ?? Enumerable.Empty<dynamic>();

                var totalOV = ordenes.Count();
                var totalTR = transferencias.Count();

                var productosTemperatura = productosTemperaturaCalidad.ContainsKey(e.Id)
                ? productosTemperaturaCalidad[e.Id]
                : new List<Plataforma_CG.Models.EmbarqueProductoTemperaturaItemVm>();

                var totalSkuTemperatura = productosTemperatura.Count;
                var skuTemperaturaCapturados = productosTemperatura.Count(x => x.Temperatura.HasValue);

                var gruposDocumentos = productosTemperatura
                .GroupBy(x => new
                {
                    x.TipoDocumento,
                    x.DocumentoId,
                    x.DocumentoConsecutivo,
                    x.DocumentoCliente
                })
                .Select(g => new
                {
                    TipoDocumento = g.Key.TipoDocumento,
                    DocumentoId = g.Key.DocumentoId,
                    DocumentoConsecutivo = g.Key.DocumentoConsecutivo,
                    DocumentoCliente = g.Key.DocumentoCliente,
                    Items = g.OrderBy(x => x.ProductoCodigo).ThenBy(x => x.ProductoNombre).ToList(),
                    TotalSku = g.Count(),
                    Capturados = g.Count(x => x.Temperatura.HasValue),
                    TotalCajas = g.Sum(x => x.Cajas),
                    TotalKilos = g.Sum(x => x.Kilos)
                })
                .OrderBy(g => g.TipoDocumento == "OV" ? 0 : 1)
                .ThenBy(g => g.DocumentoConsecutivo)
                .ToList();

                <div class="embarque-card" id="@cardId">
                    <div class="embarque-summary" onclick="toggleCard('@cardId')">
                        <div>
                            @{
                                var consecutivoEmbarque = !string.IsNullOrWhiteSpace(e.Consecutivo)
                                ? e.Consecutivo
                                : $"EMB-{e.Id}";

                                var tieneNombreEmbarque = !string.IsNullOrWhiteSpace(e.NombreEmbarque);

                                var nombreEmbarqueTexto = tieneNombreEmbarque
                                ? e.NombreEmbarque.Trim()
                                : "Sin nombre asignado";

                                var nombreEmbarqueClase = tieneNombreEmbarque
                                ? "embarque-name-chip"
                                : "embarque-name-chip empty";
                            }

                            <h4 class="embarque-id embarque-title-with-name">
                                <span class="embarque-title-main">
                                    <i class="bi bi-truck-front"></i>
                                    Embarque #@consecutivoEmbarque
                                </span>

                                <span class="@nombreEmbarqueClase">
                                    <i class="bi bi-tag"></i>
                                    @nombreEmbarqueTexto
                                </span>
                            </h4>

                            <div class="embarque-meta">
                                <span class="meta-pill pending">
                                    <i class="bi bi-hourglass-split"></i>
                                    Pendiente de validación
                                </span>

                                <span class="meta-pill primary">
                                    <i class="bi bi-calendar-event"></i>
                                    @e.FechaCreacion.ToString("yyyy-MM-dd HH:mm")
                                </span>

                                <span class="meta-pill">
                                    <i class="bi bi-hash"></i>
                                    ID: @e.Id
                                </span>
                            </div>
                        </div>

                        <div class="summary-right">
                            <div class="summary-count">
                                <small>Documentos</small>
                                <strong>@totalOV OV / @totalTR TR</strong>
                            </div>

                            <button type="button" class="toggle-btn" onclick="event.stopPropagation(); toggleCard('@cardId')">
                                <i class="bi bi-chevron-down"></i>
                            </button>
                        </div>
                    </div>

                    <div class="embarque-detail">
                        <div class="validation-layout">

                            <aside class="side-panel">
                                <div class="quick-card">
                                    <div class="card-head">
                                        <h5 class="card-title">
                                            <i class="bi bi-info-circle"></i>
                                            Resumen rápido
                                        </h5>
                                        <div class="card-sub">Datos principales del embarque seleccionado</div>
                                    </div>

                                    <div class="card-body">
                                        <div class="quick-row">
                                            <div class="quick-label">Consecutivo</div>
                                            <div class="quick-value">@e.Consecutivo</div>
                                        </div>

                                        <div class="quick-row">
                                            <div class="quick-label">Fecha</div>
                                            <div class="quick-value">@e.FechaCreacion.ToString("yyyy-MM-dd HH:mm")</div>
                                        </div>

                                        <div class="quick-row">
                                            <div class="quick-label">Órdenes</div>
                                            <div class="quick-value">@totalOV</div>
                                        </div>

                                        <div class="quick-row">
                                            <div class="quick-label">Transferencias</div>
                                            <div class="quick-value">@totalTR</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="docs-card">
                                    <div class="card-head">
                                        <h5 class="card-title">
                                            <i class="bi bi-folder2-open"></i>
                                            Documentos
                                        </h5>
                                        <div class="card-sub">Resumen del contenido del embarque</div>
                                    </div>

                                    <div class="card-body">
                                        <div class="doc-buttons">
                                            <div class="doc-mini">
                                                <i class="bi bi-box-seam"></i>
                                                <strong>@totalOV</strong>
                                                <span>OV</span>
                                            </div>

                                            <div class="doc-mini">
                                                <i class="bi bi-arrow-left-right"></i>
                                                <strong>@totalTR</strong>
                                                <span>TR</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </aside>

                            <main>
                                @if (ordenes.Any())
                                {
                                    <div class="form-card mb-3">
                                        <div class="card-head">
                                            <h5 class="card-title">
                                                <i class="bi bi-box-seam"></i>
                                                Órdenes de Venta Incluidas
                                            </h5>
                                            <div class="card-sub">@totalOV registro(s) integrados a este embarque</div>
                                        </div>

                                        <div class="card-body">
                                            <div class="table-wrap">
                                                <table class="tabla-soft">
                                                    <thead>
                                                        <tr>
                                                            <th>Consecutivo</th>
                                                            <th>Cliente</th>
                                                            <th>Ruta</th>
                                                            <th>Fecha Entrega</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>

                                                        @foreach (var ov in ordenes)
                                                        {
                                                            <tr>
                                                                <td data-label="Consecutivo">@ov.Consecutivo</td>
                                                                <td data-label="Cliente">@ov.NombreCliente</td>
                                                                <td data-label="Ruta">@(ov.Ruta ?? "-")</td>
                                                                <td data-label="Fecha Entrega">
                                                                    @(ov.FechaEntrega != null
                                                                        ? Convert.ToDateTime(ov.FechaEntrega).ToString("yyyy-MM-dd")
                                                                        : "-")
                                                                </td>
                                                            </tr>
                                                        }

                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                }

                                @if (transferencias.Any())
                                {
                                    <div class="form-card mb-3">
                                        <div class="card-head">
                                            <h5 class="card-title">
                                                <i class="bi bi-arrow-left-right"></i>
                                                Transferencias Incluidas
                                            </h5>
                                            <div class="card-sub">@totalTR registro(s) relacionados a este embarque</div>
                                        </div>

                                        <div class="card-body">
                                            <div class="table-wrap">
                                                <table class="tabla-soft">
                                                    <thead>
                                                        <tr>
                                                            <th>Consecutivo</th>
                                                            <th>Sucursal</th>
                                                            <th>Fecha Solicitud</th>
                                                            <th>Solicitó</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var tr in transferencias)
                                                        {
                                                            <tr>
                                                                <td data-label="Consecutivo">@tr.Consecutivo</td>
                                                                <td data-label="Sucursal">@(tr.Sucursal ?? "-")</td>
                                                                <td data-label="Fecha Solicitud">
                                                                    @(tr.FechaSolicitud != null
                                                                        ? Convert.ToDateTime(tr.FechaSolicitud).ToString("yyyy-MM-dd")
                                                                        : "-")
                                                                </td>
                                                                <td data-label="Solicitó">@(tr.UsuarioSolicita ?? "-")</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                }

                                <form id="@formId"
                                      asp-action="RegistrarCalidad"
                                      method="post"
                                      enctype="multipart/form-data"
                                      class="form-calidad-validacion"
                                      data-embarque-id="@e.Id"
                                      novalidate>

                                    <input type="hidden" name="id" value="@e.Id" />

                                    <div class="validation-client-box" data-validation-box>
                                        <strong>
                                            <i class="bi bi-exclamation-triangle-fill"></i>
                                            No se puede validar el embarque
                                        </strong>
                                        <ul data-validation-list></ul>
                                    </div>

                                    <div class="accordion-quality">

                                        <section class="quality-step open">
                                            <button type="button" class="step-head" onclick="toggleStep(this)">
                                                <span class="step-head-left">
                                                    <span class="step-number">1</span>
                                                    <span>
                                                        <span class="step-title">Salida</span>
                                                        <span class="step-desc">Tipo de salida del embarque</span>
                                                    </span>
                                                </span>
                                                <i class="bi bi-chevron-down step-chevron"></i>
                                            </button>

                                            <div class="step-body">
                                                <div class="row g-3 mt-1">
                                                    <div class="col-md-4">
                                                        <label class="form-label">Tipo de salida</label>
                                                        <select name="salidaTipo"
                                                                class="form-select"
                                                                data-required-message="Selecciona el tipo de salida.">
                                                            <option value="">Selecciona</option>
                                                            <option value="TIF 776">TIF 776</option>
                                                            <option value="TIF 805">TIF 805</option>
                                                            <option value="NO TIF">NO TIF</option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                        </section>

                                        <section class="quality-step">
                                            <button type="button" class="step-head" onclick="toggleStep(this)">
                                                <span class="step-head-left">
                                                    <span class="step-number">2</span>
                                                    <span>
                                                        <span class="step-title">Transporte</span>
                                                        <span class="step-desc">Placa, temperatura programada y condiciones de unidad</span>
                                                    </span>
                                                </span>
                                                <i class="bi bi-chevron-down step-chevron"></i>
                                            </button>

                                            <div class="step-body">
                                                <div class="row g-3 mt-1">
                                                    <div class="col-md-4">
                                                        <label class="form-label">Placa</label>
                                                        <input type="text"
                                                               name="placaTransporte"
                                                               class="form-control"
                                                               placeholder="Ej. 45-AT-9K"
                                                               data-required-message="Captura la placa del transporte." />
                                                    </div>

                                                    <div class="col-md-4">
                                                        <label class="form-label">Temperatura de programación</label>
                                                        <input type="number"
                                                               step="0.1"
                                                               name="temperaturaProgramacion"
                                                               class="form-control"
                                                               placeholder="Ej. 4.0"
                                                               data-required-message="Captura la temperatura de programación." />
                                                        <div class="input-hint">Captura el valor en °C</div>
                                                    </div>

                                                    <div class="col-md-4">
                                                        <label class="form-label">Condiciones de unidad</label>
                                                        <select name="estadoUnidad"
                                                                class="form-select"
                                                                data-required-message="Selecciona las condiciones de la unidad.">
                                                            <option value="">Selecciona</option>
                                                            <option value="BUENO">Bueno</option>
                                                            <option value="REGULAR">Regular</option>
                                                            <option value="MALO">Malo</option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                        </section>

                                        <section class="quality-step">
                                            <button type="button" class="step-head" onclick="toggleStep(this)">
                                                <span class="step-head-left">
                                                    <span class="step-number">3</span>
                                                    <span>
                                                        <span class="step-title">Tiempos de embarque</span>
                                                        <span class="step-desc">Inicio y término de carga</span>
                                                    </span>
                                                </span>
                                                <i class="bi bi-chevron-down step-chevron"></i>
                                            </button>

                                            <div class="step-body">
                                                <div class="row g-3 mt-1">
                                                    <div class="col-md-6">
                                                        <label class="form-label">Hora de inicio de embarque</label>
                                                        <input type="datetime-local"
                                                               name="horaInicioEmbarque"
                                                               class="form-control"
                                                               data-required-message="Captura la hora de inicio de embarque." />
                                                    </div>

                                                    <div class="col-md-6">
                                                        <label class="form-label">Hora de término de embarque</label>
                                                        <input type="datetime-local"
                                                               name="horaTerminoEmbarque"
                                                               class="form-control"
                                                               data-required-message="Captura la hora de término de embarque." />
                                                    </div>
                                                </div>
                                            </div>
                                        </section>

                                        <section class="quality-step">
                                            <button type="button" class="step-head" onclick="toggleStep(this)">
                                                <span class="step-head-left">
                                                    <span class="step-number">4</span>
                                                    <span>
                                                        <span class="step-title">Temperaturas</span>
                                                        <span class="step-desc">Temperatura de unidad al inicio y término</span>
                                                    </span>
                                                </span>
                                                <i class="bi bi-chevron-down step-chevron"></i>
                                            </button>

                                            <div class="step-body">
                                                <div class="row g-3 mt-1">
                                                    <div class="col-md-6">
                                                        <label class="form-label">Temperatura de unidad inicio</label>
                                                        <input type="number"
                                                               step="0.1"
                                                               name="temperaturaUnidadInicio"
                                                               class="form-control"
                                                               placeholder="Ej. 3.8"
                                                               data-required-message="Captura la temperatura de unidad al inicio." />
                                                    </div>

                                                    <div class="col-md-6">
                                                        <label class="form-label">Temperatura de unidad término</label>
                                                        <input type="number"
                                                               step="0.1"
                                                               name="temperaturaUnidadTermino"
                                                               class="form-control"
                                                               placeholder="Ej. 4.2"
                                                               data-required-message="Captura la temperatura de unidad al término." />
                                                    </div>
                                                </div>
                                            </div>
                                        </section>

                                        <section class="quality-step">
                                            <button type="button" class="step-head" onclick="toggleStep(this)">
                                                <span class="step-head-left">
                                                    <span class="step-number">5</span>
                                                    <span>
                                                        <span class="step-title">Producto</span>
                                                        <span class="step-desc">Condición del producto que se carga</span>
                                                    </span>
                                                </span>
                                                <i class="bi bi-chevron-down step-chevron"></i>
                                            </button>

                                            <div class="step-body">
                                                <div class="row g-3 mt-1">
                                                    <div class="col-md-6">
                                                        <label class="form-label">Condiciones del producto que se carga</label>
                                                        <select name="estadoProductos"
                                                                class="form-select"
                                                                data-required-message="Selecciona las condiciones del producto.">
                                                            <option value="">Selecciona</option>
                                                            <option value="BUENO">Bueno</option>
                                                            <option value="REGULAR">Regular</option>
                                                            <option value="MALO">Malo</option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                        </section>

                                        <section class="quality-step">
                                            <button type="button" class="step-head" onclick="toggleStep(this)">
                                                <span class="step-head-left">
                                                    <span class="step-number">6</span>
                                                    <span>
                                                        <span class="step-title">Equipos de medición</span>
                                                        <span class="step-desc">Termograficador y termómetro utilizado</span>
                                                    </span>
                                                </span>
                                                <i class="bi bi-chevron-down step-chevron"></i>
                                            </button>

                                            <div class="step-body">
                                                <div class="row g-3 mt-1">
                                                    <div class="col-md-6">
                                                        <label class="form-label">Código de termograficador</label>
                                                        <input type="text"
                                                               name="codigoTermograficador"
                                                               class="form-control"
                                                               placeholder="Código"
                                                               data-required-message="Captura el código de termograficador." />
                                                    </div>

                                                    <div class="col-md-6">
                                                        <label class="form-label">N° de termómetro utilizado</label>
                                                        <input type="text"
                                                               name="numeroTermometro"
                                                               class="form-control"
                                                               placeholder="Número"
                                                               data-required-message="Captura el número de termómetro utilizado." />
                                                    </div>
                                                </div>
                                            </div>
                                        </section>

                                        <section class="quality-step">
                                            <button type="button" class="step-head" onclick="toggleStep(this)">
                                                <span class="step-head-left">
                                                    <span class="step-number">7</span>
                                                    <span>
                                                        <span class="step-title">Observaciones y acciones</span>
                                                        <span class="step-desc">Hallazgos, comentarios y acciones correctivas</span>
                                                    </span>
                                                </span>
                                                <i class="bi bi-chevron-down step-chevron"></i>
                                            </button>

                                            <div class="step-body">
                                                <div class="row g-3 mt-1">
                                                    <div class="col-12">
                                                        <label class="form-label">Acciones correctivas</label>
                                                        <textarea name="accionesCorrectivasCalidad"
                                                          class="form-control"
                                                          rows="3"
                                                          placeholder="Acciones correctivas aplicadas..."
                                                          data-required-message="Captura las acciones correctivas. Si no aplica, escribe N/A."></textarea>
                                                    </div>

                                                    <div class="col-12">
                                                        <label class="form-label">Observaciones de calidad</label>
                                                        <textarea name="observacionesCalidad"
                                                          class="form-control"
                                                          rows="4"
                                                          placeholder="Agrega comentarios de la inspección, hallazgos o detalles relevantes..."
                                                          data-required-message="Captura las observaciones de calidad. Si no aplica, escribe N/A."></textarea>
                                                    </div>
                                                </div>
                                            </div>
                                        </section>

                                        <section class="quality-step">
                                            <button type="button" class="step-head" onclick="toggleStep(this)">
                                                <span class="step-head-left">
                                                    <span class="step-number">8</span>
                                                    <span>
                                                        <span class="step-title">Evidencia fotográfica</span>
                                                        <span class="step-desc">Fotografías del embarque o condiciones inspeccionadas</span>
                                                    </span>
                                                </span>
                                                <i class="bi bi-chevron-down step-chevron"></i>
                                            </button>

                                            <div class="step-body">
                                                <div class="row g-3 mt-1">
                                                    <div class="col-12">
                                                        <label class="form-label">Fotografías</label>

                                                        <div class="upload-box" id="@uploadId">
                                                            <input type="file"
                                                                   name="fotosCalidad"
                                                                   class="form-control"
                                                                   accept="image/*"
                                                                   capture="environment"
                                                                   multiple
                                                                   data-required-message="Agrega al menos una fotografía de evidencia."
                                                                   onchange="mostrarArchivos(this, '@filesId', '@uploadId')" />

                                                            <div class="upload-help">
                                                                Puedes subir varias fotografías o tomarlas directamente desde el celular.
                                                            </div>

                                                            <div class="file-list" id="@filesId"></div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </section>

                                        <section class="quality-step">
                                            <button type="button" class="step-head" onclick="toggleStep(this)">
                                                <span class="step-head-left">
                                                    <span class="step-number">9</span>
                                                    <span>
                                                        <span class="step-title">Temperatura por SKU</span>
                                                        <span class="step-desc">
                                                            Captura individual por producto. Guardado parcial:
                                                            @skuTemperaturaCapturados/@totalSkuTemperatura SKU(s).
                                                        </span>
                                                    </span>
                                                </span>
                                                <i class="bi bi-chevron-down step-chevron"></i>
                                            </button>

                                            <div class="step-body">
                                                @if (productosTemperatura.Any())
                                                {
                                                    <div class="sku-temp-summary mt-3">
                                                        <div>
                                                            <strong>Avance de captura</strong>
                                                            <div class="input-hint">
                                                                Puedes guardar uno o varios SKU sin validar todavía el embarque.
                                                            </div>
                                                        </div>

                                                        <span class="sku-temp-badge">
                                                            @skuTemperaturaCapturados / @totalSkuTemperatura capturados
                                                        </span>
                                                    </div>

                                                    <div class="sku-doc-groups mt-3">
                                                        @foreach (var doc in gruposDocumentos)
                                                        {
                                                            var tipoCss = doc.TipoDocumento == "OV" ? "ov" : "tr";
                                                            var tipoTexto = doc.TipoDocumento == "OV" ? "Orden de Venta" : "Transferencia";
                                                            var clienteTexto = string.IsNullOrWhiteSpace(doc.DocumentoCliente)
                                                            ? (doc.TipoDocumento == "OV" ? "Cliente no disponible" : "Sucursal no disponible")
                                                            : doc.DocumentoCliente;

                                                            <div class="sku-doc-card @tipoCss">
                                                                <div class="sku-doc-head">
                                                                    <div class="sku-doc-head-main">
                                                                        <div class="sku-doc-type-row">
                                                                            <span class="sku-doc-type-badge">@tipoTexto</span>
                                                                            <span class="sku-doc-progress-chip">
                                                                                @doc.Capturados / @doc.TotalSku SKU(s) capturados
                                                                            </span>
                                                                        </div>

                                                                        <h5 class="sku-doc-title">@doc.DocumentoConsecutivo</h5>

                                                                        <div class="sku-doc-client">
                                                                            <i class="bi bi-building"></i>
                                                                            <span>@clienteTexto</span>
                                                                        </div>
                                                                    </div>

                                                                    <div class="sku-doc-metrics">
                                                                        <div class="sku-doc-metric">
                                                                            <small>SKU</small>
                                                                            <strong>@doc.TotalSku</strong>
                                                                        </div>
                                                                        <div class="sku-doc-metric">
                                                                            <small>Cajas</small>
                                                                            <strong>@doc.TotalCajas</strong>
                                                                        </div>
                                                                        <div class="sku-doc-metric">
                                                                            <small>Kilos</small>
                                                                            <strong>@doc.TotalKilos.ToString("N2")</strong>
                                                                        </div>
                                                                    </div>
                                                                </div>

                                                                <div class="table-wrap mt-3">
                                                                    <table class="tabla-soft sku-temp-table">
                                                                        <thead>
                                                                            <tr>
                                                                                <th>SKU</th>
                                                                                <th>Producto</th>
                                                                                <th>Almacén</th>
                                                                                <th>Cajas</th>
                                                                                <th>Kilos</th>
                                                                                <th>Temperatura °C</th>
                                                                                <th>Observaciones</th>
                                                                                <th>Última captura</th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            @foreach (var p in doc.Items)
                                                                            {
                                                                                var skuKey = $"{p.TipoDocumento}|{p.DocumentoId}|{p.OrigenDetalleId}|{p.ProductoCodigo}|{p.Almacen}";
                                                                                var tempValue = p.Temperatura.HasValue
                                                                                ? p.Temperatura.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)
                                                                                : "";

                                                                                <tr data-sku-row>
                                                                                    <td data-label="SKU">
                                                                                        <strong>@p.ProductoCodigo</strong>
                                                                                    </td>

                                                                                    <td data-label="Producto">
                                                                                        @(string.IsNullOrWhiteSpace(p.ProductoNombre) ? "-" : p.ProductoNombre)
                                                                                    </td>

                                                                                    <td data-label="Almacén">
                                                                                        @(string.IsNullOrWhiteSpace(p.Almacen) ? "-" : p.Almacen)
                                                                                    </td>

                                                                                    <td data-label="Cajas">
                                                                                        @p.Cajas
                                                                                    </td>

                                                                                    <td data-label="Kilos">
                                                                                        @p.Kilos.ToString("N2")
                                                                                    </td>

                                                                                    <td data-label="Temperatura °C">
                                                                                        <input type="number"
                                                                                               step="0.1"
                                                                                               class="form-control temp-sku-input"
                                                                                               value="@tempValue"
                                                                                               placeholder="Ej. 4.0"
                                                                                               data-sku-key="@skuKey"
                                                                                               data-tipo-documento="@p.TipoDocumento"
                                                                                               data-documento-id="@p.DocumentoId"
                                                                                               data-origen-detalle-id="@p.OrigenDetalleId"
                                                                                               data-producto-codigo="@p.ProductoCodigo"
                                                                                               data-almacen="@p.Almacen"
                                                                                               data-required-message="Captura la temperatura del SKU @p.ProductoCodigo del documento @p.DocumentoConsecutivo." />
                                                                                    </td>

                                                                                    <td data-label="Observaciones">
                                                                                        <input type="text"
                                                                                               class="form-control temp-sku-obs"
                                                                                               value="@(p.Observaciones ?? "")"
                                                                                               placeholder="Opcional" />
                                                                                    </td>

                                                                                    <td data-label="Última captura">
                                                                                        @if (p.FechaUltimaCaptura.HasValue)
                                                                                        {
                                                                                            <span class="sku-captured">
                                                                                                <i class="bi bi-check-circle-fill"></i>
                                                                                                @p.FechaUltimaCaptura.Value.ToString("yyyy-MM-dd HH:mm")
                                                                                            </span>
                                                                                            <br />
                                                                                            <small>@(p.UsuarioUltimaCaptura ?? "Sistema")</small>
                                                                                        }
                                                                                        else
                                                                                        {
                                                                                            <span class="sku-pending">
                                                                                                <i class="bi bi-hourglass-split"></i>
                                                                                                Pendiente
                                                                                            </span>
                                                                                        }
                                                                                    </td>
                                                                                </tr>
                                                                            }
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="pending-box mt-3">
                                                        No se encontraron SKUs ligados a las órdenes o transferencias de este embarque.
                                                    </div>
                                                }
                                            </div>
                                        </section>

@*                                         <section class="quality-step">
                                            <button type="button" class="step-head" onclick="toggleStep(this)">
                                                <span class="step-head-left">
                                                    <span class="step-number">9</span>
                                                    <span>
                                                        <span class="step-title">Datos pendientes</span>
                                                        <span class="step-desc">Información que aún falta ligar desde BD</span>
                                                    </span>
                                                </span>
                                                <i class="bi bi-chevron-down step-chevron"></i>
                                            </button>

                                            <div class="step-body">
                                                <div class="pending-box mt-3">
                                                    <strong>Falta definir origen en BD para:</strong><br />
                                                    Datos del producto: Hora de liberación, Temperatura °C, SKU, Lote,
                                                    N° de cajas por tarima, Fecha de producción y Fecha de caducidad.
                                                </div>
                                            </div>
                                        </section> *@
                                    </div>

                                    <div class="form-actions-sticky">
                                        <div class="action-note">
                                            <i class="bi bi-info-circle me-1"></i>
                                            Revisa la información antes de liberar este embarque.
                                            <br />
                                            <span class="sku-save-status" data-sku-status></span>
                                        </div>

                                        <div class="d-flex gap-2 flex-wrap">
                                            <button type="button"
                                                    class="btn btn-sap btn-sap-outline"
                                                    onclick="guardarTemperaturasSku(this.closest('form'), false)">
                                                <i class="bi bi-save me-1"></i>
                                                Guardar temperaturas
                                            </button>

                                            <button type="submit" class="btn btn-sap btn-sap-success">
                                                <i class="bi bi-check2-circle me-1"></i>
                                                Validar Calidad
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </main>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="quality-history-divider">
        <div class="quality-history-title">
            <i class="bi bi-clock-history"></i>
            Historial de formularios validados
        </div>
    </div>

    <div class="quality-filter-panel">
        <div class="quality-filter-title">
            <i class="bi bi-funnel"></i>
            Filtros de historial
        </div>

        <form method="get" asp-action="Calidad" class="quality-filter-grid">
            <input type="hidden" name="busqueda" value="@busqueda" />
            <input type="hidden" name="fechaInicio" value="@fechaInicio" />
            <input type="hidden" name="fechaFin" value="@fechaFin" />

            <div class="quality-filter-group">
                <label>Buscar formulario</label>
                <input type="text"
                       name="busquedaHistorial"
                       value="@busquedaHistorial"
                       class="quality-filter-input"
                       placeholder="Ej. EMB-0001, 125, nombre..." />
            </div>

            <div class="quality-filter-group">
                <label>Fecha validación inicio</label>
                <input type="date"
                       name="fechaInicioHistorial"
                       value="@fechaInicioHistorial"
                       class="quality-filter-input" />
            </div>

            <div class="quality-filter-group">
                <label>Fecha validación fin</label>
                <input type="date"
                       name="fechaFinHistorial"
                       value="@fechaFinHistorial"
                       class="quality-filter-input" />
            </div>

