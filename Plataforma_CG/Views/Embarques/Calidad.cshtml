</div>

@section Scripts {
    <script>
        function toggleCard(cardId) {
            const card = document.getElementById(cardId);

            if (!card) return;

            card.classList.toggle("active");
        }

        function toggleStep(button) {
            const step = button.closest(".quality-step");

            if (!step) return;

            step.classList.toggle("open");
        }

        function mostrarArchivos(input, targetId, uploadId) {
            const contenedor = document.getElementById(targetId);
            const uploadBox = document.getElementById(uploadId);

            if (!contenedor || !uploadBox) return;

            contenedor.innerHTML = "";

            if (input.files && input.files.length > 0) {
                uploadBox.classList.add("has-files");
                uploadBox.classList.remove("is-invalid");
                input.classList.remove("is-invalid");

                Array.from(input.files).forEach(file => {
                    const item = document.createElement("div");
                    item.className = "file-item";
                    item.innerHTML = `<i class="bi bi-check-circle-fill"></i> ${file.name}`;
                    contenedor.appendChild(item);
                });
            } else {
                uploadBox.classList.remove("has-files");
            }
        }

        function limpiarErroresFormulario(form) {
            form.querySelectorAll(".is-invalid").forEach(el => {
                el.classList.remove("is-invalid");
            });

            form.querySelectorAll(".quality-step.step-error").forEach(step => {
                step.classList.remove("step-error");
            });

            const box = form.querySelector("[data-validation-box]");
            const list = form.querySelector("[data-validation-list]");

            if (box) box.classList.remove("show");
            if (list) list.innerHTML = "";
        }

        function abrirSeccionConError(campo) {
            const step = campo.closest(".quality-step");

            if (!step) return;

            step.classList.add("open");
            step.classList.add("step-error");
        }

        function marcarCampoInvalido(campo) {
            campo.classList.add("is-invalid");

            const uploadBox = campo.closest(".upload-box");

            if (uploadBox) {
                uploadBox.classList.add("is-invalid");
            }

            abrirSeccionConError(campo);
        }

        function obtenerValorCampo(campo) {
            if (!campo) return "";

            if (campo.type === "file") {
                return campo.files && campo.files.length > 0 ? "OK" : "";
            }

            return (campo.value || "").trim();
        }

        function validarFormularioCalidad(form) {
            limpiarErroresFormulario(form);

            const errores = [];
            const campos = form.querySelectorAll("[data-required-message]");

            campos.forEach(campo => {
                const valor = obtenerValorCampo(campo);

                if (!valor) {
                    const mensaje = campo.getAttribute("data-required-message") || "Completa este campo.";
                    errores.push(mensaje);
                    marcarCampoInvalido(campo);
                }
            });

            const horaInicio = form.querySelector("[name='horaInicioEmbarque']");
            const horaTermino = form.querySelector("[name='horaTerminoEmbarque']");

            if (horaInicio && horaTermino && horaInicio.value && horaTermino.value) {
                const inicio = new Date(horaInicio.value);
                const termino = new Date(horaTermino.value);

                if (termino < inicio) {
                    errores.push("La hora de término de embarque no puede ser menor que la hora de inicio.");
                    marcarCampoInvalido(horaInicio);
                    marcarCampoInvalido(horaTermino);
                }
            }

            if (errores.length > 0) {
                const box = form.querySelector("[data-validation-box]");
                const list = form.querySelector("[data-validation-list]");

                if (list) {
                    list.innerHTML = "";

                    errores.forEach(error => {
                        const li = document.createElement("li");
                        li.textContent = error;
                        list.appendChild(li);
                    });
                }

                if (box) {
                    box.classList.add("show");
                    box.scrollIntoView({
                        behavior: "smooth",
                        block: "center"
                    });
                }

                const primerCampoInvalido = form.querySelector(".is-invalid");

                if (primerCampoInvalido) {
                    setTimeout(() => primerCampoInvalido.focus(), 250);
                }

                return false;
            }

            return true;
        }

                function parseNullableDecimal(value) {
            value = (value || "").toString().trim().replace(",", ".");

            if (!value) return null;

            const number = Number(value);

            return Number.isFinite(number) ? number : null;
        }

        function recolectarTemperaturasSku(form) {
            const filas = form.querySelectorAll("[data-sku-row]");
            const items = [];

            filas.forEach(row => {
                const inputTemp = row.querySelector(".temp-sku-input");
                const inputObs = row.querySelector(".temp-sku-obs");

                if (!inputTemp) return;

                items.push({
                    tipoDocumento: inputTemp.dataset.tipoDocumento || "",
                    documentoId: Number(inputTemp.dataset.documentoId || 0),
                    origenDetalleId: Number(inputTemp.dataset.origenDetalleId || 0),
                    productoCodigo: inputTemp.dataset.productoCodigo || "",
                    almacen: inputTemp.dataset.almacen || "",
                    temperatura: parseNullableDecimal(inputTemp.value),
                    observaciones: inputObs ? inputObs.value : ""
                });
            });

            return items;
        }

        async function guardarTemperaturasSku(form, desdeSubmit) {
            if (!form) return false;

            const embarqueId = Number(form.dataset.embarqueId || 0);
            const status = form.querySelector("[data-sku-status]");
            const btnGuardar = form.querySelector("button[onclick*='guardarTemperaturasSku']");
            const items = recolectarTemperaturasSku(form);

            if (!embarqueId) {
                if (status) status.textContent = "No se encontró el ID del embarque.";
                return false;
            }

            try {
                if (btnGuardar) {
                    btnGuardar.disabled = true;
                    btnGuardar.innerHTML = '<i class="bi bi-hourglass-split me-1"></i> Guardando...';
                }

                if (status) {
                    status.textContent = "Guardando temperaturas por SKU...";
                }

                const response = await fetch("/Embarques/GuardarTemperaturasSku", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        embarqueId,
                        items
                    })
                });

                const result = await response.json();

                if (!result.success) {
                    if (status) status.textContent = result.message || "No se pudieron guardar las temperaturas.";
                    alert(result.message || "No se pudieron guardar las temperaturas.");
                    return false;
                }

                if (status) {
                    status.textContent = result.message || "Temperaturas guardadas correctamente.";
                }

                if (!desdeSubmit) {
                    alert(result.message || "Temperaturas guardadas correctamente.");
                }

                return true;
            } catch (error) {
                console.error(error);

                if (status) {
                    status.textContent = "Error al guardar temperaturas por SKU.";
                }

                alert("Error al guardar temperaturas por SKU.");
                return false;
            } finally {
                if (btnGuardar) {
                    btnGuardar.disabled = false;
                    btnGuardar.innerHTML = '<i class="bi bi-save me-1"></i> Guardar temperaturas';
                }
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".form-calidad-validacion").forEach(form => {
                form.addEventListener("submit", async function (event) {
                    if (form.dataset.enviandoDespuesDeGuardar === "1") {
                        return;
                    }

                    const esValido = validarFormularioCalidad(form);

                    if (!esValido) {
                        event.preventDefault();
                        event.stopPropagation();
                        return false;
                    }

                    event.preventDefault();
                    event.stopPropagation();

                    const guardadoOk = await guardarTemperaturasSku(form, true);

                    if (!guardadoOk) {
                        return false;
                    }

                    form.dataset.enviandoDespuesDeGuardar = "1";
                    form.submit();
                });

                form.querySelectorAll("[data-required-message]").forEach(campo => {
                    campo.addEventListener("input", function () {
                        if (obtenerValorCampo(campo)) {
                            campo.classList.remove("is-invalid");

                            const uploadBox = campo.closest(".upload-box");

                            if (uploadBox) {
                                uploadBox.classList.remove("is-invalid");
                            }
                        }
                    });

                    campo.addEventListener("change", function () {
                        if (obtenerValorCampo(campo)) {
                            campo.classList.remove("is-invalid");

                            const uploadBox = campo.closest(".upload-box");

                            if (uploadBox) {
                                uploadBox.classList.remove("is-invalid");
                            }
                        }
                    });
                });
            });
        });

        function abrirFotoCalidadDesdeBoton(btn) {
            const url = btn.dataset.photoUrl;
            const title = btn.dataset.photoTitle || "Evidencia fotográfica";

            const modalEl = document.getElementById("modalFotoCalidad");
            const img = document.getElementById("modalFotoCalidadImg");
            const titulo = document.getElementById("modalFotoCalidadTitulo");
            const abrirOriginal = document.getElementById("modalFotoCalidadAbrir");

            if (!url || !modalEl || !img || !titulo || !abrirOriginal) return;

            img.src = url;
            titulo.textContent = title;
            abrirOriginal.href = url;

            const modal = new bootstrap.Modal(modalEl);
            modal.show();
        }

    </script>
}