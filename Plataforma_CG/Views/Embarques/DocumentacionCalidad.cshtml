        gap: .35rem;
        max-width: 380px;
        padding: .34rem .65rem;
        border-radius: 999px;
        background: var(--primary-soft);
        border: 1px solid rgba(139,0,0,.16);
        color: var(--primary);
        font-size: .82rem;
