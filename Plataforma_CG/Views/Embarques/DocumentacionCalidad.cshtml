        }

    .doc-box-ok {
        border-color: #cfead7;
        box-shadow: 0 0 0 4px rgba(25,135,84,.05);
    }

    body[data-theme="dark"] .docs-group-head {
        background: #111827 !important;
        border-color: rgba(255,255,255,0.12) !important;
        box-shadow: var(--shadow-sm) !important;
    }

        body[data-theme="dark"] .docs-group-head h4 {
            color: #f9fafb !important;
        }

            body[data-theme="dark"] .docs-group-head h4 i {
                color: #fca5a5 !important;
