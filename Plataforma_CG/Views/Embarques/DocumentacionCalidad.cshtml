        }

    @@media (max-width: 576px) {
        .embarque-name-chip

    {
        width: 100%;
        max-width: 100%;
        justify-content: flex-start;
    }

    }

    /* Dark mode */
    body[data-theme="dark"] .embarque-name-chip {
        background: rgba(127,29,29,0.24) !important;
        border-color: rgba(248,113,113,0.35) !important;
        color: #fecaca !important;
    }

        body[data-theme="dark"] .embarque-name-chip.empty {
            background: #0b1220 !important;
            border-color: rgba(203,213,225,0.28) !important;
            color: #cbd5e1 !important;
        }

</style>

<div class="docs-page">

    <div class="page-header">
        <div class="page-header-left">
            <div class="header-icon">
                <i class="bi bi-shield-check"></i>
            </div>
            <div>
                <h1 class="page-title">Documentación de Calidad</h1>
                <div class="page-subtitle">
                    Carga y consulta cartas, avisos y hojas de trabajo requeridas por el área de calidad.
                </div>
            </div>
        </div>

        <div class="page-header-right">
            <span class="header-chip">
                <i class="bi bi-calendar3"></i>
                @DateTime.Now.ToShortDateString()
            </span>

            <a class="btn-top btn-top-light" href="@Url.Action("Documentacion", "Embarques")">
                <i class="bi bi-folder2-open"></i> Documentación logística
            </a>
        </div>
    </div>

    <div class="summary-grid">
        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-truck"></i>
            </div>
            <div>
                <div class="summary-label">Embarques</div>
                <div class="summary-value">@totalEmbarques</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-folder2-open"></i>
            </div>
            <div>
                <div class="summary-label">Con documentos</div>
                <div class="summary-value">@totalConDocsCalidad</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <div>
                <div class="summary-label">Pendientes</div>
                <div class="summary-value">@totalPendientes</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-icon">
                <i class="bi bi-folder-check"></i>
            </div>
            <div>
                <div class="summary-label">Validados</div>
                <div class="summary-value">@totalValidados</div>
            </div>
        </div>
    </div>

    <div class="docs-filter-panel">
        <div class="docs-filter-title">
            <i class="bi bi-funnel"></i>
            Filtros de búsqueda
        </div>

        <form method="get" asp-action="DocumentacionCalidad" class="docs-filter-grid">
            <div>
                <label class="form-label-ui">Buscar embarque</label>
                <input type="text"
                       name="busqueda"
                       value="@busqueda"
                       class="input-text-ui"
                       placeholder="Ej. EMB-0001, 125, consecutivo..." />
            </div>

            <div>
                <label class="form-label-ui">Fecha inicio</label>
                <input type="date"
                       name="fechaInicio"
                       value="@fechaInicio"
                       class="input-date-ui" />
            </div>

            <div>
                <label class="form-label-ui">Fecha fin</label>
                <input type="date"
                       name="fechaFin"
                       value="@fechaFin"
                       class="input-date-ui" />
            </div>

            <button type="submit" class="btn-ui btn-primary-ui">
                <i class="bi bi-search"></i>
                Buscar
            </button>

            <a asp-action="DocumentacionCalidad" class="btn-ui btn-secondary-ui">
                <i class="bi bi-arrow-clockwise"></i>
                Limpiar
            </a>
        </form>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        </div>
    }

    @if (Model == null)
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h4 class="mb-2">No hay información para mostrar</h4>
            <p class="mb-0">Intenta actualizar la página o revisar los filtros.</p>
        </div>
    }
    else
    {
        <div class="section-block">
            <div class="section-head">
                <div>
                    <h2 class="section-title">
                        <i class="bi bi-hourglass-split"></i>
                        Embarques pendientes
                    </h2>
                    <div class="section-subtitle">
                        Aquí se muestran los embarques que todavía no tienen validada la documentación de calidad.
                    </div>
                </div>

                <span class="header-chip" style="background:#fff;color:var(--primary);border-color:var(--border);">
                    <i class="bi bi-truck"></i>
                    @pendientes.Count pendiente(s)
                </span>
            </div>

            @if (!pendientes.Any())
            {
                <div class="mini-empty">
                    <i class="bi bi-check-circle me-2"></i>
                    No hay embarques pendientes por validar en calidad.
                </div>
            }
            else
            {
                <div class="docs-list">
                    @foreach (var e in pendientes)
                    {
                        var cardId = $"calidad_pendiente_{e.Id}";
                        var documentacionCalidadAprobada = e.DocumentacionCalidadAprobada == true;
                        var tieneCualquierDocumento = tiposCalidad.Any(t => e.Archivos.Any(a => a.Tipo == t.Tipo));

                        <div class="embarque-card" id="@cardId">
                            <div class="embarque-head" onclick="toggleCard('@cardId')">
                                <div>
                                    @{
                                        var consecutivoEmbarque = !string.IsNullOrWhiteSpace(e.Consecutivo)
                                        ? e.Consecutivo
                                        : $"EMB-{e.Id}";

                                        var tieneNombreEmbarque = !string.IsNullOrWhiteSpace(e.NombreEmbarque);

                                        var nombreEmbarqueTexto = tieneNombreEmbarque
                                        ? e.NombreEmbarque.Trim()
                                        : "Sin nombre asignado";

                                        var nombreEmbarqueClase = tieneNombreEmbarque
                                        ? "embarque-name-chip"
                                        : "embarque-name-chip empty";
                                    }

                                    <h3 class="embarque-title embarque-title-with-name">
                                        <span class="embarque-title-main">
                                            <i class="bi bi-truck-front"></i>
                                            Embarque #@consecutivoEmbarque
                                        </span>

                                        <span class="@nombreEmbarqueClase">
                                            <i class="bi bi-tag"></i>
                                            @nombreEmbarqueTexto
                                        </span>
                                    </h3>
                                    <div class="embarque-sub">
                                        ID: @e.Id · Fecha de creación: @e.FechaCreacion.ToString("yyyy-MM-dd HH:mm")
                                    </div>
                                </div>

                                <div class="head-badges">
                                    <span class="badge-soft @(tieneCualquierDocumento ? "ok" : "pending")">
                                        <i class="bi bi-file-earmark-arrow-up"></i>
                                        @(tieneCualquierDocumento ? "Con documentos" : "Sin documentos")
                                    </span>

                                    <span class="badge-soft @(documentacionCalidadAprobada ? "ok" : "pending")">
                                        <i class="bi bi-folder-check"></i>
                                        Calidad @(documentacionCalidadAprobada ? "validada" : "pendiente")
                                    </span>

                                    <button type="button" class="toggle-btn" onclick="event.stopPropagation(); toggleCard('@cardId')">
                                        <i class="bi bi-chevron-down"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="embarque-body">
                                <form asp-action="CargarDocumentosCalidad" method="post" enctype="multipart/form-data">
                                    <input type="hidden" name="id" value="@e.Id" />

                                    @foreach (var grupo in tiposCalidad.GroupBy(x => x.Grupo))
                                    {
                                        var grupoIcon = grupo.Key == "Expediente de calidad"
                                        ? "bi-folder2-open"
                                        : "bi-archive";

                                        <div class="docs-group">
                                            <div class="docs-group-head">
                                                <div>
                                                    <h4>
                                                        <i class="bi @grupoIcon"></i>
                                                        @grupo.Key
                                                    </h4>
                                                    <p>
                                                        @(grupo.Key == "Expediente de calidad"
                                                            ? "Carga los documentos correspondientes al expediente documental del embarque."
                                                            : "Carga estos documentos solo cuando apliquen para el embarque.")
                                                    </p>
                                                </div>

                                                <span>
                                                    @grupo.Count() tipo(s)
                                                </span>
                                            </div>

                                            <div class="docs-grid">
                                                @foreach (var tipo in grupo)
                                                {
                                                    var archivos = e.Archivos.Where(a => a.Tipo == tipo.Tipo).ToList();
                                                    var tieneArchivo = archivos.Any();
                                                    var uploadBoxId = $"uploadBox_{tipo.Tipo}_{e.Id}";
                                                    var previewId = $"preview_{tipo.Tipo}_{e.Id}";
                                                    var nameId = $"name_{tipo.Tipo}_{e.Id}";

                                                    <div class="doc-box @(tieneArchivo ? "doc-box-ok" : "")">
                                                        <div class="doc-box-head">
                                                            <div class="doc-icon">
                                                                <i class="bi @tipo.Icon"></i>
                                                            </div>
                                                            <div>
                                                                <h5 class="doc-title">@tipo.Label</h5>
                                                                <div class="doc-sub">@tipo.Sub</div>
                                                            </div>
                                                        </div>

                                                        <div class="upload-box" id="@uploadBoxId">
                                                            <label class="form-label-ui">Selecciona archivo</label>

                                                            <input type="file"
                                                                   name="@tipo.Name"
                                                                   multiple
                                                                   class="input-file-ui"
                                                                   accept=".pdf,.xml,.jpg,.jpeg,.png,.doc,.docx,.xlsx,.xls"
                                                                   onchange="mostrarArchivoSeleccionado(this, '@uploadBoxId', '@previewId', '@nameId')" />

                                                            <div class="hint-text">
                                                                Formatos permitidos: PDF, XML, JPG, PNG, DOC, DOCX, XLS y XLSX.
                                                            </div>

                                                            <div class="selected-file-preview" id="@previewId">
                                                                <div class="selected-file-label">Archivo seleccionado</div>
                                                                <div class="selected-file-name" id="@nameId"></div>
                                                            </div>
                                                        </div>

                                                        <div class="file-status @(tieneArchivo ? "ok" : "pending")">
                                                            @(tieneArchivo ? $"{archivos.Count} archivo(s) cargado(s)." : "Sin archivo cargado. Este tipo es opcional.")
                                                        </div>

                                                        @if (tieneArchivo)
                                                        {
                                                            <div class="mt-2">
                                                                @foreach (var archivo in archivos)
                                                                {
                                                                    <a href="@archivo.RutaArchivo" target="_blank" class="file-link d-flex">
                                                                        <i class="bi bi-box-arrow-up-right"></i>
                                                                        Ver @tipo.Label #@archivo.Id
                                                                    </a>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }

                                    <div class="actions-bar">
                                        <button type="submit" class="btn-ui btn-primary-ui">
                                            <i class="bi bi-save"></i>
                                            Guardar y validar documentación de calidad
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="section-block">
            <div class="section-head">
                <div>
                    <h2 class="section-title">
                        <i class="bi bi-clock-history"></i>
                        Histórico de documentación de calidad
                    </h2>
                    <div class="section-subtitle">
                        Consulta embarques ya validados por documentación de calidad. No carga registros hasta seleccionar un rango de fechas.
                    </div>
                </div>

                <span class="header-chip" style="background:#fff;color:var(--primary);border-color:var(--border);">
                    <i class="bi bi-folder-check"></i>
                    @historialDocumentacionCalidad.Count registro(s)
                </span>
            </div>

            <div class="docs-filter-panel">
                <div class="docs-filter-title">
                    <i class="bi bi-funnel"></i>
                    Filtros de historial
                </div>

                <form method="get" asp-action="DocumentacionCalidad" class="docs-filter-grid">
                    <input type="hidden" name="busqueda" value="@busqueda" />
                    <input type="hidden" name="fechaInicio" value="@fechaInicio" />
                    <input type="hidden" name="fechaFin" value="@fechaFin" />

                    <div>
                        <label class="form-label-ui">Buscar embarque</label>
                        <input type="text"
                               name="busquedaHistorial"
                               value="@busquedaHistorial"
                               class="input-text-ui"
                               placeholder="Ej. EMB-0001, 125, nombre..." />
                    </div>

                    <div>
                        <label class="form-label-ui">Fecha validación inicio</label>
                        <input type="date"
                               name="fechaInicioHistorial"
                               value="@fechaInicioHistorial"
                               class="input-date-ui" />
                    </div>

                    <div>
                        <label class="form-label-ui">Fecha validación fin</label>
                        <input type="date"
                               name="fechaFinHistorial"
                               value="@fechaFinHistorial"
                               class="input-date-ui" />
                    </div>

                    <button type="submit" class="btn-ui btn-primary-ui">
                        <i class="bi bi-search"></i>
                        Buscar historial
                    </button>

                    <a asp-action="DocumentacionCalidad"
                       asp-route-busqueda="@busqueda"
                       asp-route-fechaInicio="@fechaInicio"
                       asp-route-fechaFin="@fechaFin"
                       class="btn-ui btn-secondary-ui">
                        <i class="bi bi-arrow-clockwise"></i>
                        Limpiar historial
                    </a>
                </form>
            </div>

            @if (!buscoHistorialDocumentacionCalidad)
            {
                <div class="empty-state">
                    <i class="bi bi-calendar-range"></i>
                    <h4 class="mb-2">Selecciona un rango de fechas</h4>
                    <p class="mb-0">
                        El historial de documentación de calidad no carga información hasta que indiques fecha inicio y fecha fin.
                    </p>
                </div>
            }
            else if (!historialDocumentacionCalidad.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-search"></i>
                    <h4 class="mb-2">No se encontraron registros</h4>
                    <p class="mb-0">
                        No existen embarques validados por documentación de calidad dentro del rango seleccionado.
                    </p>
                </div>
            }
            else
            {
                <div class="docs-list">
                    @foreach (var e in historialDocumentacionCalidad)
                    {
                        var cardId = $"hist_doc_calidad_{e.Id}";
                        var tieneCualquierDocumento = tiposCalidad.Any(t => e.Archivos.Any(a => a.Tipo == t.Tipo));

                        <div class="embarque-card" id="@cardId">
                            <div class="embarque-head" onclick="toggleCard('@cardId')">
                                <div>
                                    @{
                                        var consecutivoEmbarqueHistorial = !string.IsNullOrWhiteSpace(e.Consecutivo)
                                        ? e.Consecutivo
                                        : $"EMB-{e.Id}";

                                        var tieneNombreEmbarqueHistorial = !string.IsNullOrWhiteSpace(e.NombreEmbarque);

                                        var nombreEmbarqueTextoHistorial = tieneNombreEmbarqueHistorial
                                        ? e.NombreEmbarque.Trim()
                                        : "Sin nombre asignado";

                                        var nombreEmbarqueClaseHistorial = tieneNombreEmbarqueHistorial
                                        ? "embarque-name-chip"
                                        : "embarque-name-chip empty";
                                    }

                                    <h3 class="embarque-title embarque-title-with-name">
                                        <span class="embarque-title-main">
                                            <i class="bi bi-folder-check"></i>
                                            Embarque #@consecutivoEmbarqueHistorial
                                        </span>

                                        <span class="@nombreEmbarqueClaseHistorial">
                                            <i class="bi bi-tag"></i>
                                            @nombreEmbarqueTextoHistorial
                                        </span>
                                    </h3>
                                    <div class="embarque-sub">
                                        ID: @e.Id · Validado:
                                        @(e.FechaValidacionDocumentacionCalidad?.ToString("yyyy-MM-dd HH:mm") ?? "Sin fecha")
                                        · Usuario:
                                        @(e.UsuarioValidaDocumentacionCalidad ?? "Sistema")
                                    </div>
                                </div>

                                <div class="head-badges">
                                    <span class="badge-soft @(tieneCualquierDocumento ? "ok" : "pending")">
                                        <i class="bi bi-file-earmark-check"></i>
                                        @(tieneCualquierDocumento ? "Con documentos" : "Sin documentos")
                                    </span>

                                    <span class="badge-soft ok">
                                        <i class="bi bi-check-circle"></i>
                                        Validado
                                    </span>

                                    <button type="button" class="toggle-btn" onclick="event.stopPropagation(); toggleCard('@cardId')">
                                        <i class="bi bi-chevron-down"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="embarque-body">
                                @foreach (var grupo in tiposCalidad.GroupBy(x => x.Grupo))
                                {
                                    var grupoIcon = grupo.Key == "Expediente de calidad"
                                    ? "bi-folder2-open"
                                    : "bi-archive";

                                    <div class="docs-group">
                                        <div class="docs-group-head">
                                            <div>
                                                <h4>
                                                    <i class="bi @grupoIcon"></i>
                                                    @grupo.Key
                                                </h4>
                                                <p>
                                                    @(grupo.Key == "Expediente de calidad"
                                                                                        ? "Documentos cargados como parte del expediente de calidad."
                                                                                        : "Documentos poco frecuentes cargados para este embarque.")
                                </p>
                            </div>

                                            <span>
                                                @grupo.Count() tipo(s)
                                            </span>
                                        </div>

                                        <div class="docs-grid">
                            @foreach (var tipo in grupo)
                                            {
                                                var archivos = e.Archivos.Where(a => a.Tipo == tipo.Tipo).ToList();
                                                var tieneArchivo = archivos.Any();

                                                <div class="doc-box @(tieneArchivo ? "doc-box-ok" : "")">
                                                    <div class="doc-box-head">
                                                        <div class="doc-icon">
                                                            <i class="bi @tipo.Icon"></i>
                                                        </div>
                                                        <div>
                                                            <h5 class="doc-title">@tipo.Label</h5>
                                                            <div class="doc-sub">@tipo.Sub</div>
                                                        </div>
                                                    </div>

                                                    <div class="file-status @(tieneArchivo ? "ok" : "pending")">
                                                        @(tieneArchivo ? $"{archivos.Count} archivo(s) cargado(s)." : "No se cargó este documento.")
                                                    </div>

                                                    @if (tieneArchivo)
                                                    {
                                                        <div class="mt-2">
                                                            @foreach (var archivo in archivos)
                                                            {
                                                                <a href="@archivo.RutaArchivo" target="_blank" class="file-link d-flex">
                                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                                    Ver @tipo.Label #@archivo.Id
                                                                </a>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<script>
    function toggleCard(cardId) {
        const card = document.getElementById(cardId);
        if (!card) return;
        card.classList.toggle("active");
    }

    function mostrarArchivoSeleccionado(input, uploadBoxId, previewId, nameId) {
        const uploadBox = document.getElementById(uploadBoxId);
        const preview = document.getElementById(previewId);
        const nameBox = document.getElementById(nameId);

        if (!uploadBox || !preview || !nameBox) return;

        if (input.files && input.files.length > 0) {
            uploadBox.classList.add("has-selected-file");
            preview.classList.add("active");

            const nombres = Array.from(input.files).map(f => f.name);
            nameBox.textContent = nombres.join(", ");
        } else {
            uploadBox.classList.remove("has-selected-file");
            preview.classList.remove("active");
            nameBox.textContent = "";
        }
    }
</script>