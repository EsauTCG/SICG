@section Scripts {
    <script>
        let currentGrupoId = @(grupo?.GrupoId ?? 0);
        let currentSku = '@(skuSeleccionado ?? "")';

        $(document).ready(function () {

            // Click en Grupo
            $(document).on('click', '.grupo-item', function (e) {
                if ($(e.target).closest('.btn-actions-grupo').length > 0) {
                    return;
                }

                e.preventDefault();

                const grupoId = $(this).data('grupo-id');
                const masterSku = $(this).data('master-sku');

                if (grupoId === currentGrupoId) return;

                currentGrupoId = grupoId;
                currentSku = masterSku;

                $('.grupo-item').removeClass('active');
                $(this).addClass('active');

                cargarGrupoItems(grupoId, masterSku);
            });

            // Click en SKU
            $(document).on('click', '.sku-item', function (e) {
                if ($(e.target).closest('.btn-actions-sku').length > 0) {
                    return;
                }

                e.preventDefault();

                const sku = $(this).data('sku');

                if (sku === currentSku) return;

                currentSku = sku;

                $('.sku-item').removeClass('active');
                $(this).addClass('active');

                cargarConversiones(sku);
            });

        });

        function cargarGrupoItems(grupoId, masterSku) {
            $('#gruposLoading').show();

            $.ajax({
                url: '@Url.Action("GetGrupoItems", "SkuConversion")',
                type: 'GET',
                data: { grupoId: grupoId },
                success: function (data) {
                    $('.items-container').remove();

                    if (data.items && data.items.length > 0) {
                        let itemsHtml = '<ul class="list-group list-group-flush mt-2 items-container">';

                        data.items.forEach(function (item) {
                            const paddingLeft = 10 + (item.nivel * 15);
                            const activeClass = item.sku === currentSku ? 'active' : '';
                            const inactiveClass = !item.activo ? 'inactive' : '';
                            const isMaster = item.tipoRelacion === 'Master';
                            const masterBadge = isMaster ? '<span class="badge bg-primary ms-2">Master</span>' : '';
                            const inactiveBadge = !item.activo ? '<span class="badge badge-inactive ms-1">Inactivo</span>' : '';

                            let actionButtons = `
                                <button class="btn-edit-sku"
                                        onclick="abrirModalEditarSku(${grupoId}, '${item.sku}', event)"
                                        title="Editar SKU">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            `;

                            if (!item.activo) {
                                actionButtons += `
                                    <button class="btn-reactivate-sku"
                                            onclick="confirmarReactivarSku(${grupoId}, '${item.sku}', ${isMaster}, event)"
                                            title="Reactivar ${isMaster ? 'Master SKU y Grupo' : 'SKU'}">
                                        <i class="bi bi-arrow-clockwise"></i>
                                    </button>
                                `;
                            } else {
                                actionButtons += `
                                    <button class="btn-deactivate-sku"
                                            onclick="confirmarDesactivarSku(${grupoId}, '${item.sku}', ${isMaster}, event)"
                                            title="Desactivar ${isMaster ? 'Master SKU y Grupo' : 'SKU'}">
                                        <i class="bi bi-dash-circle"></i>
                                    </button>
                                `;
                            }

                            actionButtons += `
                                <button class="btn-delete-sku"
                                        onclick="confirmarEliminarSku(${grupoId}, '${item.sku}', ${isMaster}, event)"
                                        title="Eliminar permanentemente">
                                    <i class="bi bi-x"></i>
                                </button>
                            `;

                            itemsHtml += `
                                <a class="list-group-item list-group-item-action sku-item ${activeClass} ${inactiveClass}"
                                   style="padding-left:${paddingLeft}px;"
                                   data-sku="${item.sku}"
                                   data-nivel="${item.nivel}"
                                   data-is-master="${isMaster}"
                                   data-activo="${item.activo}"
                                   href="javascript:void(0);">
                                    ${item.sku}
                                    ${masterBadge}
                                    ${inactiveBadge}
                                    <div class="btn-actions-sku">
                                        ${actionButtons}
                                    </div>
                                </a>
                            `;
                        });

                        itemsHtml += '</ul>';
                        $('.grupo-item.active').append(itemsHtml);
                    }

                    cargarConversiones(masterSku);
                    actualizarEstadoBotones();
                },
                error: function () {
                    alert('Error al cargar los items del grupo');
                },
                complete: function () {
                    $('#gruposLoading').hide();
                }
            });
        }


        function cargarConversiones(sku) {
            $('#conversionesLoading').show();
            $('#skuTitle').text(sku);

            $.ajax({
                url: '@Url.Action("GetConversiones", "SkuConversion")',
                type: 'GET',
                data: { sku: sku },
                success: function (data) {
                    let html = '';

                    if (data && data.length > 0) {
                        data.forEach(function (c) {
                            const prioridad = c.prioridad !== null ? c.prioridad : 'Base';
                            const estadoBadge = c.activo
                                ? '<span class="badge rounded-pill bg-success"><i class="bi bi-check-circle"></i> Activo</span>'
                                : '<span class="badge rounded-pill bg-secondary"><i class="bi bi-x-circle"></i> Inactivo</span>';
                            const inactiveRowClass = !c.activo ? 'inactive-row' : '';

                            let actionButtons = `
                                <button class="btn-edit-conversion"
                                        onclick="abrirModalEditarConversion(${c.id})"
                                        title="Editar conversión">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            `;

                            if (!c.activo) {
                                actionButtons += `
                                    <button class="btn-reactivate-conversion"
                                            onclick="confirmarReactivarConversion(${c.id}, '${c.skuOrigen}', '${c.skuDestino}')"
                                            title="Reactivar conversión">
                                        <i class="bi bi-arrow-clockwise"></i>
                                    </button>
                                `;
                            } else {
                                actionButtons += `
                                    <button class="btn-deactivate-conversion"
                                            onclick="confirmarDesactivarConversion(${c.id}, '${c.skuOrigen}', '${c.skuDestino}')"
                                            title="Desactivar conversión">
                                        <i class="bi bi-dash-circle"></i>
                                    </button>
                                `;
                            }

                            actionButtons += `
                                <button class="btn-delete-conversion"
                                        onclick="confirmarEliminarConversion(${c.id}, '${c.skuOrigen}', '${c.skuDestino}')"
                                        title="Eliminar permanentemente">
                                    <i class="bi bi-trash"></i>
                                </button>
                            `;

                            html += `
                                <tr class="${inactiveRowClass}">
                                    <td>${prioridad}</td>
                                    <td>${c.skuOrigen}</td>
                                    <td class="text-center">→</td>
                                    <td><strong>${c.skuDestino}</strong></td>
                                    <td>${estadoBadge}</td>
                                    <td>
                                        <div class="btn-actions-conversion">
                                            ${actionButtons}
                                        </div>
                                    </td>
                                </tr>
                            `;
                        });
                    } else {
                        html = `
                            <tr>
                                <td colspan="6" class="text-center text-muted">
                                    <i class="bi bi-info-circle"></i> No hay conversiones disponibles
                                </td>
                            </tr>
                        `;
                    }

                    $('#conversionesBody').html(html);
                    actualizarEstadoBotones();
                },
                error: function () {
                    alert('Error al cargar las conversiones');
                },
                complete: function () {
                    $('#conversionesLoading').hide();
                }
            });
        }


        function actualizarEstadoBotones() {
            if (currentGrupoId > 0) {
                $('#btnNuevoSku').prop('disabled', false);
            } else {
                $('#btnNuevoSku').prop('disabled', true);
            }

            if (currentSku) {
                $('#btnNuevaConversion').prop('disabled', false);
            } else {
                $('#btnNuevaConversion').prop('disabled', true);
            }
        }

        $('#modalNuevoSku').on('show.bs.modal', function () {
            var grupoNombre = $('.grupo-item.active strong').text();
            $('#skuGrupoNombre').val(grupoNombre);
            $('#skuGrupoId').val(currentGrupoId);
        });

        $('#modalNuevaConversion').on('show.bs.modal', function () {
            $('#conversionOrigen').val(currentSku);
        });

