        function guardarSku() {
            const grupoId = $('#skuGrupoId').val();
            const sku = $('#skuCodigo').val().trim();
            const tipoRelacion = $('#skuTipoRelacion').val();
            const nivel = parseInt($('#skuNivel').val());
            const orden = parseInt($('#skuOrden').val());

            if (!sku || !tipoRelacion) {
                alert('Por favor complete los campos requeridos');
                return;
            }

            // 🔥 VALIDACIONES EN FRONTEND
            if (tipoRelacion === 'Master' && nivel !== 0) {
                alert('El Master SKU debe tener Nivel 0');
                return;
            }

            if (tipoRelacion === 'Derivado' && nivel === 0) {
                alert('Un SKU Derivado debe tener Nivel mayor a 0');
                return;
            }

            const data = {
                GrupoId: parseInt(grupoId),
                Sku: sku,
                TipoRelacion: tipoRelacion,
                Nivel: nivel,
                Orden: orden
                // 🔥 NO enviamos ParentSku, se asigna automáticamente en el servidor
            };

            $.ajax({
                url: '@Url.Action("CrearSkuItem", "SkuConversion")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (response) {
                    if (response.success) {
                        alert(response.message);
                        $('#modalNuevoSku').modal('hide');
                        $('#formNuevoSku')[0].reset();

                        cargarGrupoItems(currentGrupoId, currentSku);
                    } else {
                        alert('Error: ' + response.message);
