@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "SKU Conversion";

    var items = ViewBag.Items as IEnumerable<Plataforma_CG.Models.SkuGrupoItem>;
    var skuSeleccionado = ViewBag.SkuSeleccionado as string;
    var grupos = ViewBag.Grupos as IEnumerable<Plataforma_CG.Models.SkuGrupo>;
    var grupo = ViewBag.GrupoSeleccionado as Plataforma_CG.Models.SkuGrupo;
    var conversiones = ViewBag.Conversiones as IEnumerable<Plataforma_CG.Models.SkuConversion>;
}


<style>
    :root {
        --brand: linear-gradient(90deg, #8B0000 0%, #5a0000 50%, #1a0000 100%);
        --surface: #fff;
        --bg: linear-gradient(135deg, #f1f3f6 0%, #e9edf2 45%, #e8dada 100%);
        --line: #e5e7eb;
        --text: #1f2a35;
        --muted: #64748b;
        --radius: 12px;
        --shadow: 0 10px 24px rgba(0,0,0,.06);
        --shadow-sm: 0 6px 16px rgba(0,0,0,.06);
        --focus: 0 0 0 .2rem rgba(139,0,0,.25);
    }

    body {
        background: var(--bg) !important;
        color: var(--text);
    }

    .shell {
        max-width: 1300px;
        margin: 1rem auto 2rem;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .titlebar {
        background: linear-gradient(#f6f8fb,#eef2f7);
        border-bottom: 1px solid var(--line);
        padding: .9rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        flex-wrap: wrap;
    }

        .titlebar h5 {
            margin: 0;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: .5rem;
            color: var(--text);
        }

            .titlebar h5 i {
                color: #8B0000;
            }

        .titlebar .sub {
            margin: 0;
            font-size: .9rem;
            color: var(--muted);
        }

    .content-pad {
        padding: 1rem;
    }

    .chip-soft {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .35rem .6rem;
        border-radius: 999px;
        background: #f8fafc;
        border: 1px solid var(--line);
        color: #111;
        font-weight: 600;
        box-shadow: var(--shadow-sm);
    }

    .panel {
        margin-top: 1rem;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 10px;
        box-shadow: var(--shadow-sm);
    }

    .panel-head {
        background: linear-gradient(#f7f9fc,#eef2f7);
        border-bottom: 1px solid var(--line);
        padding: .7rem .9rem;
        font-weight: 700;
        color: #2b3642;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .5rem;
        margin-bottom: 0;
    }

        .panel-head i {
            color: #8B0000;
        }

        .panel-head .panel-title {
            display: flex;
            align-items: center;
            gap: .5rem;
            flex: 1;
        }

        .panel-head .panel-actions {
            display: flex;
            align-items: center;
            gap: .35rem;
        }

    .btn-icon-action {
        width: 28px;
        height: 28px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        border: 1px solid rgba(0,0,0,.08);
        background: #fff;
        color: #64748b;
        transition: all .15s ease;
        cursor: pointer;
        font-size: .85rem;
    }

        .btn-icon-action:hover {
            transform: translateY(-1px);
            box-shadow: 0 3px 8px rgba(0,0,0,.12);
        }

        .btn-icon-action.btn-primary-icon {
            background: #3b82f6;
            color: #fff;
            border-color: #2563eb;
        }

            .btn-icon-action.btn-primary-icon:hover {
                background: #2563eb;
                box-shadow: 0 3px 12px rgba(59,130,246,.4);
            }

        .btn-icon-action.btn-success-icon {
            background: #16a34a;
            color: #fff;
            border-color: #15803d;
        }

            .btn-icon-action.btn-success-icon:hover {
                background: #15803d;
                box-shadow: 0 3px 12px rgba(22,163,74,.4);
            }

        .btn-icon-action.btn-warning-icon {
            background: #f59e0b;
            color: #fff;
            border-color: #d97706;
        }

            .btn-icon-action.btn-warning-icon:hover {
                background: #d97706;
                box-shadow: 0 3px 12px rgba(245,158,11,.4);
            }

        .btn-icon-action:disabled {
            opacity: .4;
            cursor: not-allowed;
            transform: none !important;
            box-shadow: none !important;
        }

    .table-wrap {
        padding: .5rem .75rem .75rem;
        padding-top: 0;
        margin-top: 0;
        max-height: 65vh;
        overflow: auto;
        position: relative;
    }

    .table-hover tbody tr:hover {
        background: #fafcff;
    }

    /* 🔥 GRUPOS ACTIVOS */
    .list-group-item.grupo-item {
        border-left: 3px solid transparent;
        transition: all 0.2s ease;
        margin-bottom: 0.5rem;
        border-radius: 8px !important;
        position: relative;
        padding-right: 130px !important; /* 🔥 MÁS ESPACIO PARA 4 BOTONES */
    }

        .list-group-item.grupo-item:hover {
            background: #D6D6D6 !important;
            border-left-color: #8B0000;
            transform: translateX(2px);
        }

        .list-group-item.grupo-item.active {
            background: linear-gradient(90deg, #8B0000 0%, #5a0000 100%) !important;
            border-color: #5a0000 !important;
            color: #fff !important;
            border-left-color: #fff;
        }

            .list-group-item.grupo-item.active small {
                color: #D6D6D6 !important;
            }

        /* 🔥 GRUPOS INACTIVOS - Estilo diferenciado */
        .list-group-item.grupo-item.inactive {
            background: repeating-linear-gradient( 45deg, #f9fafb, #f9fafb 10px, #f3f4f6 10px, #f3f4f6 20px ) !important;
            border-left: 3px solid #9ca3af !important;
            opacity: 0.7;
            color: #6b7280 !important;
        }

            .list-group-item.grupo-item.inactive:hover {
                background: repeating-linear-gradient( 45deg, #f3f4f6, #f3f4f6 10px, #e5e7eb 10px, #e5e7eb 20px ) !important;
                opacity: 0.85;
            }

            .list-group-item.grupo-item.inactive strong {
                color: #9ca3af !important;
            }

            .list-group-item.grupo-item.inactive small {
                color: #9ca3af !important;
            }

    /* Contenedor de botones de acción */
    .btn-actions-grupo {
        position: absolute;
        right: 8px;
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        gap: 4px;
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .list-group-item.grupo-item:hover .btn-actions-grupo {
        opacity: 1;
    }

    /* 🔥 Botón de editar (azul) */
    .btn-edit-grupo {
        width: 24px;
        height: 24px;
        padding: 0;
        border: none;
        background: rgba(59, 130, 246, 0.9);
        color: white;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
    }

        .btn-edit-grupo:hover {
            background: rgba(37, 99, 235, 1);
            transform: scale(1.1);
        }

    /* 🔥 Botón de reactivar (verde) */
    .btn-reactivate-grupo {
        width: 24px;
        height: 24px;
        padding: 0;
        border: none;
        background: rgba(22, 163, 74, 0.9);
        color: white;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
    }

        .btn-reactivate-grupo:hover {
            background: rgba(21, 128, 61, 1);
            transform: scale(1.1);
        }

    /* Botón de desactivar (naranja) */
    .btn-deactivate-grupo {
        width: 24px;
        height: 24px;
        padding: 0;
        border: none;
        background: rgba(245, 158, 11, 0.9);
        color: white;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
    }

        .btn-deactivate-grupo:hover {
            background: rgba(217, 119, 6, 1);
            transform: scale(1.1);
        }

    /* Botón de eliminar (rojo) */
    .btn-delete-grupo {
        width: 24px;
        height: 24px;
        padding: 0;
        border: none;
        background: rgba(220, 38, 38, 0.9);
        color: white;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
    }

        .btn-delete-grupo:hover {
            background: rgba(185, 28, 28, 1);
            transform: scale(1.1);
        }

    .list-group-item.grupo-item.active .btn-edit-grupo {
        background: rgba(255, 255, 255, 0.85);
        color: #3b82f6;
    }

        .list-group-item.grupo-item.active .btn-edit-grupo:hover {
            background: rgba(255, 255, 255, 1);
        }

    .list-group-item.grupo-item.active .btn-deactivate-grupo {
        background: rgba(255, 255, 255, 0.85);
        color: #f59e0b;
    }

        .list-group-item.grupo-item.active .btn-deactivate-grupo:hover {
            background: rgba(255, 255, 255, 1);
        }

    .list-group-item.grupo-item.active .btn-delete-grupo {
        background: rgba(255, 255, 255, 0.9);
        color: #8B0000;
    }

        .list-group-item.grupo-item.active .btn-delete-grupo:hover {
            background: rgba(255, 255, 255, 1);
        }

    /* SKU Items */
    .items-container {
        margin-top: 0.75rem !important;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 6px;
        padding: 0.25rem 0;
    }

    /* 🔥 SKU ACTIVOS */
    .list-group-item.sku-item {
        background: rgba(255, 255, 255, 0.9) !important;
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
        border-left: 2px solid transparent;
        color: #1f2a35 !important;
        margin: 0.15rem 0.5rem;
        border-radius: 6px !important;
        transition: all 0.15s ease;
        font-size: 0.9rem;
        position: relative;
        padding-right: 120px !important; /* 🔥 MÁS ESPACIO PARA 4 BOTONES */
    }

    .grupo-item.active .list-group-item.sku-item {
        background: #E3E3E3 !important;
        border-color: #e5e7eb !important;
        color: #404040 !important;
    }

    .list-group-item.sku-item:hover {
        background: #E0E0E0 !important;
        border-left-color: #f59e0b;
        transform: translateX(3px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .list-group-item.sku-item.active {
        font-weight: 900;
    }

        .list-group-item.sku-item.active .badge {
            background: rgba(117, 117, 117) !important;
            color: #FFFFFF !important;
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

    /* 🔥 SKU INACTIVOS - Estilo diferenciado */
    .list-group-item.sku-item.inactive {
        background: repeating-linear-gradient( 45deg, rgba(249, 250, 251, 0.8), rgba(249, 250, 251, 0.8) 8px, rgba(243, 244, 246, 0.8) 8px, rgba(243, 244, 246, 0.8) 16px ) !important;
        border-left: 2px solid #d1d5db !important;
        opacity: 0.6;
        color: #9ca3af !important;
    }

        .list-group-item.sku-item.inactive:hover {
            opacity: 0.8;
        }

        .list-group-item.sku-item.inactive .badge {
            background: #9ca3af !important;
            opacity: 0.7;
        }

    /* Contenedor de botones de acción para SKUs */
    .btn-actions-sku {
        position: absolute;
        right: 6px;
        top: 50%;
        transform: translateY(-50%);
        display: flex;
        gap: 3px;
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .list-group-item.sku-item:hover .btn-actions-sku {
        opacity: 1;
    }

    /* 🔥 Botón de editar SKU */
    .btn-edit-sku {
        width: 22px;
        height: 22px;
        padding: 0;
        border: none;
        background: rgba(59, 130, 246, 0.8);
        color: white;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
    }

        .btn-edit-sku:hover {
            background: rgba(37, 99, 235, 1);
            transform: scale(1.1);
        }

    /* 🔥 Botón de reactivar SKU */
    .btn-reactivate-sku {
        width: 22px;
        height: 22px;
        padding: 0;
        border: none;
        background: rgba(22, 163, 74, 0.8);
        color: white;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
    }

        .btn-reactivate-sku:hover {
            background: rgba(21, 128, 61, 1);
            transform: scale(1.1);
        }

    /* Botón de desactivar SKU */
    .btn-deactivate-sku {
        width: 22px;
        height: 22px;
        padding: 0;
        border: none;
        background: rgba(245, 158, 11, 0.8);
        color: white;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
    }

        .btn-deactivate-sku:hover {
            background: rgba(217, 119, 6, 1);
            transform: scale(1.1);
        }

    /* Botón de eliminar SKU */
    .btn-delete-sku {
        width: 22px;
        height: 22px;
        padding: 0;
        border: none;
        background: rgba(220, 38, 38, 0.8);
        color: white;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
    }

        .btn-delete-sku:hover {
            background: rgba(185, 28, 28, 1);
            transform: scale(1.1);
        }

    /* Botones en tabla de conversiones */
    .btn-actions-conversion {
        display: flex;
        gap: 4px;
        justify-content: center;
    }

    .btn-edit-conversion,
    .btn-reactivate-conversion,
    .btn-deactivate-conversion,
    .btn-delete-conversion {
        padding: 2px 6px;
        font-size: 0.70rem;
        border-radius: 4px;
        border: none;
        color: white;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 2px;
    }

    .btn-edit-conversion {
        background: #3b82f6;
    }

        .btn-edit-conversion:hover {
            background: #2563eb;
            transform: scale(1.05);
        }

    .btn-reactivate-conversion {
        background: #16a34a;
    }

        .btn-reactivate-conversion:hover {
            background: #15803d;
            transform: scale(1.05);
        }

    .btn-deactivate-conversion {
        background: #f59e0b;
    }

        .btn-deactivate-conversion:hover {
            background: #d97706;
            transform: scale(1.05);
        }

    .btn-delete-conversion {
        background: #dc2626;
    }

        .btn-delete-conversion:hover {
            background: #b91c1c;
            transform: scale(1.05);
        }

    /* 🔥 Filas inactivas en la tabla */
    tr.inactive-row {
        background: repeating-linear-gradient( 90deg, rgba(249, 250, 251, 0.5), rgba(249, 250, 251, 0.5) 10px, rgba(243, 244, 246, 0.5) 10px, rgba(243, 244, 246, 0.5) 20px ) !important;
        opacity: 0.7;
        color: #9ca3af !important;
    }

        tr.inactive-row:hover {
            opacity: 0.9;
        }

    .loading-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255,255,255,0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
    }

    .spinner-border-custom {
        border: 3px solid #f3f3f3;
        border-top: 3px solid #8B0000;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .items-container {
        animation: slideDown 0.2s ease-out;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            max-height: 0;
        }

        to {
            opacity: 1;
            max-height: 500px;
        }
    }

    /* 🔥 Badge para elementos inactivos */
    .badge-inactive {
        background: #9ca3af !important;
        color: white !important;
        font-size: 0.7rem;
        padding: 0.2rem 0.4rem;
    }
</style>

<div class="shell">

    <div class="titlebar">
        <div>
            <h5><i class="bi bi-arrow-left-right"></i> SKU Conversion</h5>
            <p class="sub">Catálogo de equivalencias y conversiones por grupo</p>
        </div>

        <span class="chip-soft">
            <i class="bi bi-diagram-3"></i> Catálogo interno
        </span>
    </div>

    <div class="content-pad">

        <div class="row">

            <!-- ===================== -->
            <!-- GRUPOS SKU (IZQUIERDA) -->
            <!-- ===================== -->
            <div class="col-md-4">
                <div class="panel">
                    <div class="panel-head">
                        <div class="panel-title">
                            <i class="bi bi-collection"></i> Grupos SKU
                        </div>
                        <div class="panel-actions">
                            <button class="btn-icon-action btn-primary-icon"
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalNuevoGrupo"
                                    title="Nuevo Grupo">
                                <i class="bi bi-folder-plus"></i>
                            </button>
                            <button class="btn-icon-action btn-success-icon"
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalNuevoSku"
                                    id="btnNuevoSku"
                                    disabled
                                    title="Nuevo SKU en grupo">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    </div>

                    <div class="table-wrap" style="position: relative;">
                        <div id="gruposLoading" class="loading-overlay" style="display: none;">
                            <div class="spinner-border-custom"></div>
                        </div>
                        <ul class="list-group list-group-flush" id="gruposList">

                            @foreach (var g in grupos ?? Enumerable.Empty<Plataforma_CG.Models.SkuGrupo>())
                            {
                                var grupoActivo = grupo != null && g.GrupoId == grupo.GrupoId ? "active" : "";
                                var inactiveClass = !g.Activo ? "inactive" : "";

                                <a class="list-group-item list-group-item-action grupo-item @grupoActivo @inactiveClass"
                                   data-grupo-id="@g.GrupoId"
                                   data-master-sku="@g.MasterSku"
                                   data-activo="@g.Activo.ToString().ToLower()"
                                   href="javascript:void(0);">

                                    <strong>@g.MasterSku</strong>
                                    @if (!g.Activo)
                                    {
                                        <span class="badge badge-inactive ms-1">Inactivo</span>
                                    }
                                    <br />
                                    <small class="text-muted">@g.NombreGrupo</small>

                                    <div class="btn-actions-grupo">
                                        <button class="btn-edit-grupo"
                                                onclick="abrirModalEditarGrupo(@g.GrupoId, event)"
                                                title="Editar grupo">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        @if (!g.Activo)
                                        {
                                            <button class="btn-reactivate-grupo"
                                                    onclick="confirmarReactivarGrupo(@g.GrupoId, '@g.MasterSku', event)"
                                                    title="Reactivar grupo">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn-deactivate-grupo"
                                                    onclick="confirmarDesactivarGrupo(@g.GrupoId, '@g.MasterSku', event)"
                                                    title="Desactivar grupo">
                                                <i class="bi bi-dash-circle"></i>
                                            </button>
                                        }
                                        <button class="btn-delete-grupo"
                                                onclick="confirmarEliminarGrupo(@g.GrupoId, '@g.MasterSku', event)"
                                                title="Eliminar permanentemente">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>

                                    @if (grupo != null && g.GrupoId == grupo.GrupoId)
                                    {
                                        <ul class="list-group list-group-flush mt-2 items-container">
                                            @foreach (var i in items ?? Enumerable.Empty<Plataforma_CG.Models.SkuGrupoItem>())
                                            {
                                                var skuActivo = i.Sku == skuSeleccionado ? "active" : "";
                                                var skuInactive = !i.Activo ? "inactive" : "";
                                                var isMaster = i.TipoRelacion == "Master";

                                                <a class="list-group-item list-group-item-action sku-item @skuActivo @skuInactive"
                                                   style="padding-left:@(10 + i.Nivel * 15)px;"
                                                   data-sku="@i.Sku"
                                                   data-nivel="@i.Nivel"
                                                   data-is-master="@(isMaster ? "true" : "false")"
                                                   data-activo="@i.Activo.ToString().ToLower()"
                                                   href="javascript:void(0);">
                                                    @i.Sku

                                                    @if (isMaster)
                                                    {
                                                        <span class="badge bg-primary ms-2">Master</span>
                                                    }
                                                    @if (!i.Activo)
                                                    {
                                                        <span class="badge badge-inactive ms-1">Inactivo</span>
                                                    }

                                                    <div class="btn-actions-sku">
                                                        <button class="btn-edit-sku"
                                                                onclick="abrirModalEditarSku(@g.GrupoId, '@i.Sku', event)"
                                                                title="Editar SKU">
                                                            <i class="bi bi-pencil"></i>
                                                        </button>
                                                        @if (!i.Activo)
                                                        {
                                                            <button class="btn-reactivate-sku"
                                                                    onclick="confirmarReactivarSku(@g.GrupoId, '@i.Sku', @(isMaster ? "true" : "false"), event)"
                                                                    title="Reactivar @(isMaster ? "Master SKU y Grupo" : "SKU")">
                                                                <i class="bi bi-arrow-clockwise"></i>
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <button class="btn-deactivate-sku"
                                                                    onclick="confirmarDesactivarSku(@g.GrupoId, '@i.Sku', @(isMaster ? "true" : "false"), event)"
                                                                    title="Desactivar @(isMaster ? "Master SKU y Grupo" : "SKU")">
                                                                <i class="bi bi-dash-circle"></i>
                                                            </button>
                                                        }
                                                        <button class="btn-delete-sku"
                                                                onclick="confirmarEliminarSku(@g.GrupoId, '@i.Sku', @(isMaster ? "true" : "false"), event)"
                                                                title="Eliminar permanentemente">
                                                            <i class="bi bi-x"></i>
                                                        </button>
                                                    </div>
                                                </a>
                                            }
                                        </ul>
                                    }
                                </a>
                            }

                        </ul>
                    </div>

                </div>
            </div>

            <!-- ===================== -->
            <!-- DETALLE (DERECHA) -->
            <!-- ===================== -->
            <div class="col-md-8">
                <div class="panel">
                    <div class="panel-head">
                        <div class="panel-title">
                            <i class="bi bi-arrow-left-right"></i>
                            Conversiones – <span id="skuTitle">@(skuSeleccionado ?? grupo?.MasterSku ?? "—")</span>
                        </div>
                        <div class="panel-actions">
                            <button class="btn-icon-action btn-warning-icon"
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalNuevaConversion"
                                    id="btnNuevaConversion"
                                    disabled
                                    title="Nueva Conversión">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    </div>

                    <div class="table-wrap" style="position: relative;">
                        <div id="conversionesLoading" class="loading-overlay" style="display: none;">
                            <div class="spinner-border-custom"></div>
                        </div>
                        <table class="table table-bordered table-hover mb-0">
                            <thead class="text-white" style="background:#8B0000;">
                                <tr>
                                    <th style="width:100px;">Prioridad</th>
                                    <th>Origen</th>
                                    <th style="width:40px;"></th>
                                    <th>Destino</th>
                                    <th style="width:100px;">Estado</th>
                                    <th style="width:180px;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="conversionesBody">
                                @foreach (var c in conversiones ?? Enumerable.Empty<Plataforma_CG.Models.SkuConversion>())
                                {
                                    var inactiveRowClass = !c.Activo ? "inactive-row" : "";
                                    <tr class="@inactiveRowClass">
                                        <td>@(c.Prioridad.HasValue? c.Prioridad.ToString() : "Base")</td>
                                        <td>@c.SkuOrigen</td>
                                        <td class="text-center">→</td>
                                        <td><strong>@c.SkuDestino</strong></td>
                                        <td>
                                            @if (c.Activo)
                                            {
                                                <span class="badge rounded-pill bg-success">
                                                    <i class="bi bi-check-circle"></i> Activo
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill bg-secondary">
                                                    <i class="bi bi-x-circle"></i> Inactivo
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-actions-conversion">
                                                <button class="btn-edit-conversion"
                                                        onclick="abrirModalEditarConversion(@c.Id)"
                                                        title="Editar conversión">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                @if (!c.Activo)
                                                {
                                                    <button class="btn-reactivate-conversion"
                                                            onclick="confirmarReactivarConversion(@c.Id, '@c.SkuOrigen', '@c.SkuDestino')"
                                                            title="Reactivar conversión">
                                                        <i class="bi bi-arrow-clockwise"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn-deactivate-conversion"
                                                            onclick="confirmarDesactivarConversion(@c.Id, '@c.SkuOrigen', '@c.SkuDestino')"
                                                            title="Desactivar conversión">
                                                        <i class="bi bi-dash-circle"></i>
                                                    </button>
                                                }
                                                <button class="btn-delete-conversion"
                                                        onclick="confirmarEliminarConversion(@c.Id, '@c.SkuOrigen', '@c.SkuDestino')"
                                                        title="Eliminar permanentemente">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>


