    function obtenerDatosGraficas(dataHueso, dataRecorte, dataGrasa) {
        const OBJETIVO_HUESO_TOTAL = 5.5;

        let kgEntHueso = 0;
        let kgSalHueso = 0;

        let listaHuesos = Array.isArray(dataHueso)
            ? dataHueso
            : (dataHueso?.data || []);

        if (listaHuesos.length > 0) {
            listaHuesos.forEach(h => {
                kgEntHueso += parseFloat(h.kgEntrada || 0);
                kgSalHueso += parseFloat(h.kgSalida || 0);
            });
        }

        let particHueso = kgEntHueso > 0
            ? (kgSalHueso / kgEntHueso) * 100
            : 0;

        const objRecorte = parseFloat(dataRecorte?.porcObjetivo || 0);
        const particRecorte = parseFloat(dataRecorte?.porcPartic || 0);
        const kgEntRecorte = parseFloat(dataRecorte?.kgEntrada || 0);
        const kgSalRecorte = parseFloat(dataRecorte?.kgSalida || 0);

        const objGrasa = parseFloat(dataGrasa?.porcObjetivo || 0);
        const particGrasa = parseFloat(dataGrasa?.porcPartic || 0);
        const kgEntGrasa = parseFloat(dataGrasa?.kgEntrada || 0);
        const kgSalGrasa = parseFloat(dataGrasa?.kgSalida || 0);

        const diferencias = [
            +(particHueso - OBJETIVO_HUESO_TOTAL).toFixed(2),
            +(particRecorte - objRecorte).toFixed(2),
            +(particGrasa - objGrasa).toFixed(2)
        ];

        return {
            labels: ['Huesos (Total)', 'Recorte', 'Grasa'],
            objetivo: [OBJETIVO_HUESO_TOTAL, objRecorte, objGrasa],
            real: [
                +particHueso.toFixed(2),
                +particRecorte.toFixed(2),
                +particGrasa.toFixed(2)
            ],
            kilosEntrada: [
                +kgEntHueso.toFixed(2),
                +kgEntRecorte.toFixed(2),
                +kgEntGrasa.toFixed(2)
            ],
            kilosSalida: [
                +kgSalHueso.toFixed(2),
                +kgSalRecorte.toFixed(2),
                +kgSalGrasa.toFixed(2)
            ],
            diferencias: diferencias
        };
    }

    function formatearNumero(valor, decimales = 2) {
        return (parseFloat(valor) || 0).toFixed(decimales);
    }

    function formatearKilos(valor) {
        return (parseFloat(valor) || 0).toFixed(2);
    }

    function obtenerClaseDiferencia(valor) {
        const abs = Math.abs(parseFloat(valor) || 0);

        if (abs <= 1) return "kpi-status-ok";
        if (abs <= 3) return "kpi-status-warn";
        return "kpi-status-bad";
    }

    function obtenerTextoEstatus(valor) {
        const abs = Math.abs(parseFloat(valor) || 0);

        if (abs <= 1) return { texto: "En objetivo", clase: "kpi-status-ok" };
        if (abs <= 3) return { texto: "En rango", clase: "kpi-status-warn" };
        return { texto: "Fuera de rango", clase: "kpi-status-bad" };
    }

