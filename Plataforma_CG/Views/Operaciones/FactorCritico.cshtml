    function obtenerPruebasDesdeTabla() {
        const pruebas = [];

        document.querySelectorAll("#lista-registros-body tr").forEach(fila => {
            const idTD = fila.querySelector("td strong");
            const loteSpan = fila.querySelector(".txt-lote");

            if (idTD && loteSpan) {
                const id = idTD.innerText.replace('#', '').trim();
                const lote = loteSpan.innerText.trim();

                pruebas.push({ id, lote });
            }
        });

        return pruebas;
    }

    function obtenerLotesUnicosDesdeTabla() {
        const pruebas = obtenerPruebasDesdeTabla();
        const mapa = new Map();

        pruebas.forEach(p => {
            if (!mapa.has(p.lote)) {
                mapa.set(p.lote, p.lote);
            }
        });

        return Array.from(mapa.values());
    }

