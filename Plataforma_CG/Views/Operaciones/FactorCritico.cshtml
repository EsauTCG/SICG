    function normalizarObjetivoTotal(obj, objetivoFijo = null) {
        let objetivo = parseFloat(obj?.porcObjetivo || 0);

        if (objetivoFijo !== null) {
            objetivo = objetivoFijo;
        }

        return {
            ...obj,
            porcObjetivo: objetivo,
            porcPartic: parseFloat(obj?.porcPartic || 0),
            kgEntrada: parseFloat(obj?.kgEntrada || 0),
            kgSalida: parseFloat(obj?.kgSalida || 0),
            difPorc: +(parseFloat(obj?.porcPartic || 0) - objetivo).toFixed(2)
        };
    }

    function cargarReportePorLote(lote) {
        if (!lote) {
            document.getElementById("contenedor-reporte").style.display = "none";
            return;
        }

        document.getElementById("contenedor-reporte").style.display = "block";
        document.getElementById("lblLoteReporte").innerText = `${lote} | Total por lote`;

        document.getElementById("resumen-hueso").innerHTML = "<tr><td colspan='6'>Cargando.</td></tr>";
        document.getElementById("resumen-recorte").innerHTML = "<tr><td colspan='2'>Cargando.</td></tr>";
        document.getElementById("resumen-grasa").innerHTML = "<tr><td colspan='2'>Cargando.</td></tr>";

        [
            "kpiHuesoEntrada", "kpiHuesoSalida", "kpiHuesoReal", "kpiHuesoObjetivo", "kpiHuesoDif",
            "kpiRecorteReal", "kpiRecorteDif", "kpiRecorteStatus",
            "kpiGrasaReal", "kpiGrasaDif", "kpiGrasaStatus"
        ].forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                el.innerText = "Cargando.";
                el.className = "";
            }
        });

        fetch(`/tif/resumen/lote?lote=${encodeURIComponent(lote)}`)
            .then(r => r.json())
            .then(data => {

                let htmlHueso = "";
                let tEnt = 0, tSal = 0;

                if (Array.isArray(data.hueso) && data.hueso.length > 0) {
                    data.hueso.forEach(h => {
                        const kgEntrada = parseFloat(h.kgEntrada || 0);
                        const kgSalida = parseFloat(h.kgSalida || 0);
                        const porcObjetivo = parseFloat(h.porcObjetivo || 0);
                        const porcPartic = parseFloat(h.porcPartic || 0);
                        const difPorc = parseFloat(h.difPorc || 0);

                        tEnt += kgEntrada;
                        tSal += kgSalida;

                        let colorDif = difPorc < 0 ? '#dc3545' : '#198754';

                        htmlHueso += `
                            <tr>
                                <td style="color:#555; font-weight:600;">${h.nombreHueso}</td>
                                <td><span class="badge-sap">${porcObjetivo}%</span></td>
                                <td>${porcPartic}%</td>
                                <td style="color:${colorDif}; font-weight:bold;">${difPorc}%</td>
                                <td>${kgEntrada}</td>
                                <td>${kgSalida}</td>
                            </tr>`;
                    });

                        htmlHueso += `
                            <tr style="font-weight:bold; background:#fdfdfd;">
                                <td colspan="4" style="text-align:right;">TOTAL</td>
                                <td>${formatearKilos(tEnt)} kg</td>
                                <td>${formatearKilos(tSal)} kg</td>
                            </tr>`;
                } else {
                    htmlHueso = "<tr><td colspan='6' style='text-align:center;'>Sin datos capturados</td></tr>";
                }

                document.getElementById("resumen-hueso").innerHTML = htmlHueso;

                // ✅ TOTAL POR LOTE:
                // NO se deben sumar los objetivos de Recorte ni de Grasa.
                // Se toma un solo objetivo base.
                let rBase = data.recorte || {};
                let gBase = data.grasa || {};

                let r = {
                    porcObjetivo: parseFloat(rBase.porcObjetivo || 0),
                    porcPartic: parseFloat(rBase.porcPartic || 0),
                    kgEntrada: parseFloat(rBase.kgEntrada || 0),
                    kgSalida: parseFloat(rBase.kgSalida || 0),
                    difPorc: 0
                };

                let g = {
                    // Si backend no manda objetivo, por defecto grasa usa 6.5
                    porcObjetivo: parseFloat(gBase.porcObjetivo || 6.5),
                    porcPartic: parseFloat(gBase.porcPartic || 0),
                    kgEntrada: parseFloat(gBase.kgEntrada || 0),
                    kgSalida: parseFloat(gBase.kgSalida || 0),
                    difPorc: 0
                };

                // ✅ recalcular diferencia con objetivo NO sumado
                r.difPorc = +(r.porcPartic - r.porcObjetivo).toFixed(2);
                g.difPorc = +(g.porcPartic - g.porcObjetivo).toFixed(2);

                // ✅ pintar KPIs ya con los datos corregidos
                pintarIndicadoresReporte(data.hueso || [], r, g);

                let rColorDif = r.difPorc < 0 ? '#dc3545' : '#198754';
                document.getElementById("resumen-recorte").innerHTML = `
                    <tr><td>% Objetivo</td><td><span class="badge-sap">${r.porcObjetivo}%</span></td></tr>
                    <tr><td>% Participación</td><td>${r.porcPartic}%</td></tr>
                    <tr><td>% Diferencia</td><td style="color:${rColorDif}; font-weight:bold;">${r.difPorc}%</td></tr>
                    <tr><td>Kg Entrada</td><td><strong>${r.kgEntrada} kg</strong></td></tr>
                    <tr><td>Kg Salida</td><td><strong>${r.kgSalida} kg</strong></td></tr>
                `;

                let gColorDif = g.difPorc < 0 ? '#dc3545' : '#198754';
                document.getElementById("resumen-grasa").innerHTML = `
                    <tr><td>% Objetivo</td><td><span class="badge-sap">${g.porcObjetivo}%</span></td></tr>
                    <tr><td>% Participación</td><td>${g.porcPartic}%</td></tr>
                    <tr><td>% Diferencia</td><td style="color:${gColorDif}; font-weight:bold;">${g.difPorc}%</td></tr>
                    <tr><td>Kg Entrada</td><td><strong>${g.kgEntrada} kg</strong></td></tr>
                    <tr><td>Kg Salida</td><td><strong>${g.kgSalida} kg</strong></td></tr>
                `;
            })
            .catch(err => {
                console.error("Error resumen lote:", err);

                document.getElementById("resumen-hueso").innerHTML =
                    "<tr><td colspan='6' style='text-align:center; color:red;'>No se pudo cargar la información.</td></tr>";

                document.getElementById("resumen-recorte").innerHTML =
                    "<tr><td colspan='2' style='text-align:center; color:red;'>No se pudo cargar.</td></tr>";

                document.getElementById("resumen-grasa").innerHTML =
                    "<tr><td colspan='2' style='text-align:center; color:red;'>No se pudo cargar.</td></tr>";
            });
    }

    function cargarGraficaPorLote(lote) {
        if (!lote) {
            document.getElementById("contenedor-grafica").style.display = "none";
            destruirGraficasReporte();
            return;
        }

        document.getElementById("contenedor-grafica").style.display = "block";

        fetch(`/tif/resumen/lote?lote=${encodeURIComponent(lote)}`)
            .then(r => r.json())
            .then(data => {
                dibujarGraficaReporte(data.hueso || [], data.recorte || null, data.grasa || null);
            })
            .catch(error => {
                console.error(error);
                document.getElementById("contenedor-grafica").style.display = "none";
                alert("No se pudo cargar la gráfica por lote.");
            });
    }

        function crearFetchConTimeout(ms = 30000) {
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort("timeout"), ms);

        return {
            controller,
            signal: controller.signal,
            clear: () => clearTimeout(timeoutId)
        };
    }

    function crearErrorApp(mensaje, status = 0, code = "") {
        const err = new Error(mensaje || "Ocurrió un error inesperado.");
        err.status = status;
        err.code = code;
        return err;
    }

    function obtenerMensajeUsuario(error) {
        if (!error) {
            return "Ocurrió un error inesperado.";
        }

        if (error.code === "SESSION_EXPIRED" || error.status === 401 || error.status === 403) {
            return "Tu sesión expiró o no tienes autorización. Vuelve a iniciar sesión para continuar.";
        }

        if (error.code === "TIMEOUT" || error.status === 504) {
            return "La solicitud tardó demasiado en responder. Puede ser lentitud de la red local o que la API interna TIF no respondió a tiempo.";
        }

        if (error.code === "API_UNAVAILABLE" || error.status === 503) {
            return "No se pudo establecer comunicación con la API interna TIF. Puede estar detenida, caída o inaccesible desde el servidor.";
        }

        if (error.code === "NETWORK_ERROR") {
            return "No se pudo conectar con el servidor de la aplicación. Revisa la red local o la disponibilidad del servidor.";
        }

        if (error.status === 500) {
            return error.message || "El servidor devolvió un error interno inesperado.";
        }

        if (error.name === "AbortError") {
            return "La operación fue cancelada.";
        }

        return error.message || "Ocurrió un error inesperado.";
    }

    function ponerErrorEnTabla(tbody, colspan, mensaje) {
        tbody.innerHTML = `
            <tr>
                <td colspan="${colspan}" style="text-align:center; color:red; font-weight:600;">
                    ${mensaje}
                </td>
            </tr>`;
    }

    function ponerMensajeEnSelect(select, mensaje) {
        select.innerHTML = `<option value="">${mensaje}</option>`;
    }

    async function fetchTifJson(url, opciones = {}) {
        const timeout = crearFetchConTimeout(30000);
        const signalExterna = opciones.signal || null;

        if (signalExterna) {
            if (signalExterna.aborted) {
                timeout.controller.abort("externo");
            } else {
                signalExterna.addEventListener("abort", () => {
                    timeout.controller.abort("externo");
                }, { once: true });
            }
        }

        try {
            const res = await fetch(url, {
                credentials: "same-origin",
                ...opciones,
                signal: timeout.signal
            });

            if (res.redirected || res.status === 401 || res.status === 403) {
                throw crearErrorApp(
                    "Tu sesión expiró o ya no está autorizada.",
                    res.status,
                    "SESSION_EXPIRED"
                );
            }

            if (!res.ok) {
                const txt = await res.text();

                if (res.status === 503) {
                    throw crearErrorApp(
                        txt || "No se pudo establecer comunicación con la API interna TIF.",
                        503,
                        "API_UNAVAILABLE"
                    );
                }

                if (res.status === 504) {
                    throw crearErrorApp(
                        txt || "La API interna TIF tardó demasiado en responder.",
                        504,
                        "TIMEOUT"
                    );
                }

                throw crearErrorApp(
                    txt || `Error del servidor (${res.status})`,
                    res.status,
                    "HTTP_ERROR"
                );
            }

            return await res.json();

        } catch (error) {
            if (error.name === "AbortError") {
                if (signalExterna && signalExterna.aborted) {
                    throw error;
                }

                throw crearErrorApp(
                    "La solicitud tardó demasiado. Puede ser lentitud de red local o API interna sin respuesta.",
                    504,
                    "TIMEOUT"
                );
            }

            if (error instanceof TypeError) {
                throw crearErrorApp(
                    "No se pudo conectar con el servidor de la aplicación.",
                    0,
                    "NETWORK_ERROR"
                );
            }

            throw error;

        } finally {
            timeout.clear();
        }
    }

