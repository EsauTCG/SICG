<script src="~/lib/chartjs/chart.umd.min.js"></script>

<script>

    function getCsrfToken() {
        const el = document.querySelector('#csrf-form input[name="__RequestVerificationToken"]');
        return el ? el.value : "";
    }

    let idPruebaActual = 0;
    let idPruebaReporteActual = 0;
    let recetasCargadas = [];
    let graficasReporte = {
        barras: null,
        distribucion: null,
        radar: null,
        kilos: null,
        diferencia: null,
        cumplimiento: null
    };

    let huesoDrafts = {};
    let abortHuesoController = null;
    let guardandoHueso = false;

    function guardarDraftHuesoFila(tr) {
        if (!tr) return;

        const fkHueso = parseInt(tr.dataset.fkhueso) || 0;
        if (!fkHueso) return;

        const key = claveDraftHueso(idPruebaActual, fkHueso);

        const inputEntrada = tr.querySelector('.kg-entrada');
        const inputSalida = tr.querySelector('.kg-salida');

        huesoDrafts[key] = {
            kgEntrada: inputEntrada ? inputEntrada.value : "",
            kgSalida: inputSalida ? inputSalida.value : ""
        };
    }

    function activarCapturaHuesoOptimizada() {
        const tbody = document.getElementById("tabla-hueso");
        if (!tbody) return;

        tbody.oninput = function (e) {
            if (e.target.classList.contains("kg-entrada") || e.target.classList.contains("kg-salida")) {
                guardarDraftHuesoFila(e.target.closest("tr"));
            }
        };
    }

    function limpiarHuesoUI() {
        const tbody = document.getElementById("tabla-hueso");
        if (tbody) tbody.innerHTML = "";

        if (abortHuesoController) {
            abortHuesoController.abort();
            abortHuesoController = null;
        }
    }

    async function fetchTifJson(url, opciones = {}) {
        const res = await fetch(url, {
            credentials: "same-origin",
            ...opciones
        });

        if (res.redirected || res.status === 401 || res.status === 403) {
            alert("Tu sesión expiró o ya no está autorizada. Recarga la página e inicia sesión nuevamente.");
            throw new Error("Sesión expirada");
        }

        if (!res.ok) {
            const txt = await res.text();
            throw new Error(txt || "Error del servidor");
        }

        return await res.json();
    }

    async function fetchTifText(url, opciones = {}) {
        const res = await fetch(url, {
            credentials: "same-origin",
            ...opciones
        });

        if (res.redirected || res.status === 401 || res.status === 403) {
            alert("Tu sesión expiró o ya no está autorizada. Recarga la página e inicia sesión nuevamente.");
            throw new Error("Sesión expirada");
        }

        if (!res.ok) {
            const txt = await res.text();
            throw new Error(txt || "Error del servidor");
        }

        return await res.text();
    }

    document.addEventListener('DOMContentLoaded', () => {
        cargarPruebas();
        cargarRecetas();
    });

    async function cargarPruebas() {
        const tbody = document.getElementById("lista-registros-body");
        tbody.innerHTML = "<tr><td colspan='5' style='text-align:center;'>Cargando registros...</td></tr>";

        try {
            const data = await fetchTifJson(`/tif/pruebas/listar`);

            tbody.innerHTML = "";

            if (!data || data.length === 0) {
                tbody.innerHTML = "<tr><td colspan='5' style='text-align:center; color:#999;'>No hay pruebas registradas.</td></tr>";
                return;
            }

            data.forEach(r => {
                tbody.innerHTML += `
                    <tr>
                        <td><strong>#${r.id}</strong></td>
                        <td>
                            <div style="display:flex; flex-direction:column; gap:4px;">
                                <span class="txt-lote" style="font-weight: 700; color: var(--primary);">${r.lote}</span>
                                <span class="badge-sap" style="width:fit-content;">Prueba #${r.id}</span>
                            </div>
                        </td>
                        <td><span class="badge-sap">${r.fecha}</span> <span style="font-size:0.9em; color:#999">${r.hora.split('.')[0]}</span></td>
                        <td>${r.realiza}</td>
                        <td style="text-align: right;">
                            <button class="tbtn" style="height: 28px; font-size: 0.8rem;" onclick="abrirPruebaHueso(${r.id}, '${r.lote}')">Hueso</button>
                            <button class="tbtn" style="height: 28px; font-size: 0.8rem;" onclick="abrirPruebaRecorte(${r.id}, '${r.lote}')">Recorte</button>
                            <button class="tbtn" style="height: 28px; font-size: 0.8rem;" onclick="abrirPruebaGrasa(${r.id}, '${r.lote}')">Grasa</button>
                        </td>
                    </tr>
                `;
            });

        } catch (error) {
            console.error("Error al cargar pruebas:", error);
            ponerErrorEnTabla(tbody, 5, obtenerMensajeUsuario(error));
        }
    }

    async function cargarRecetas() {
        try {
            recetasCargadas = await fetchTifJson(`/tif/recetas`);
        } catch (error) {
            console.error("Error al cargar recetas:", obtenerMensajeUsuario(error), error);
            recetasCargadas = [];
        }
    }

    async function abrirModalNuevaPrueba() {
        document.getElementById("modalNuevaPrueba").style.display = "flex";

        const selectLote = document.getElementById("txtNuevoLote");
        const btnConfirmar = document.getElementById("btnConfirmarPrueba");

        selectLote.innerHTML = "<option value=''>Consultando lotes...</option>";
        btnConfirmar.disabled = true;

        try {
            const lotes = await fetchTifJson(`/tif/lotes`);

            selectLote.innerHTML = "";

            if (lotes && lotes.length > 0) {
                selectLote.innerHTML = "<option value=''>-- Seleccione un Lote --</option>";

                lotes.forEach(lote => {
                    selectLote.innerHTML += `<option value="${lote}">${lote}</option>`;
                });

                selectLote.onchange = function () {
                    btnConfirmar.disabled = !this.value;
                };
            } else {
                ponerMensajeEnSelect(selectLote, "No hay lotes disponibles");
            }

        } catch (error) {
            console.error("Error al cargar lotes:", error);
            ponerMensajeEnSelect(selectLote, obtenerMensajeUsuario(error));
            btnConfirmar.disabled = true;
        }
    }

    function confirmarNuevaPrueba() {
        const lote = document.getElementById("txtNuevoLote").value;
        const btn = document.getElementById("btnConfirmarPrueba");
        const select = document.getElementById("txtNuevoLote");

        if (!lote) return;

        // 🔒 evita doble click / spam
        btn.innerText = "Creando...";
        btn.disabled = true;
        select.disabled = true;

        fetch(`/tif/pruebas`, {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "RequestVerificationToken": getCsrfToken()
            },
            body: JSON.stringify({ lote })
        })
        .then(res => res.text())
        .then(txt => {
            const ok = (txt || "").trim().toLowerCase() === "true";

            if (ok) {
                // ✅ Cierra modal y refresca para que entre tu condición "en proceso"
                cerrarModal("modalNuevaPrueba");
                cargarPruebas();

                // (opcional) limpia selección para la próxima vez
                select.value = "";
            } else {
                alert("No se pudo crear la prueba (servidor respondió false).");
                btn.disabled = false;
            }
        })
        .catch(err => {
            console.error(err);
            alert("Error al insertar prueba.");
            btn.disabled = false;
        })
        .finally(() => {
            // ✅ sólo resetea texto; habilitar depende del resultado (arriba)
            btn.innerText = "Crear Prueba";
            select.disabled = false;
        });
    }

    function abrirPruebaGrasa(idPrueba, lote) {
        idPruebaActual = idPrueba;
        document.getElementById("modalGrasa").style.display = "flex";
        document.getElementById("lote-Grasa").innerText = lote;
        document.getElementById("badge-prueba-grasa").innerText = `Prueba #${idPrueba}`;
        const tbody = document.getElementById("tabla-Grasa");
        tbody.innerHTML = "<tr><td colspan='5'>Cargando...</td></tr>";

        fetch(`/tif/grasa?pruebaid=${idPrueba}`)
            .then(res => res.json())
            .then(data => {
                let g = (data && data.id) ? data : { id: 0, porcObjetivo: 6.5, kgEntrada: 0, kgSalida: 0, porcPartic: 0, difPorc: 0 };
                let colorDif = obtenerColorSemaforo(g.difPorc || 0);
                tbody.innerHTML = `
                    <tr data-id="${g.id}">
                        <td><span class="badge-sap">${g.porcObjetivo}%</span></td>
                        <td>${g.porcPartic}%</td>
                        <td style="color:${colorDif}; font-weight:bold;">${g.difPorc}%</td>
                            <td><input type="number" class="sap-input kg-entrada" id="txtGrasaEnt" value="${(parseFloat(g.kgEntrada) || 0) === 0 ? '' : g.kgEntrada}" placeholder="0"></td>
                            <td><input type="number" class="sap-input kg-salida" id="txtGrasaSal" value="${(parseFloat(g.kgSalida) || 0) === 0 ? '' : g.kgSalida}" placeholder="0"></td>
                    </tr>`;
            }).catch(() => { tbody.innerHTML = "<tr><td colspan='5'>No se pudo cargar la información.</td></tr>"; });
    }

    function guardarGrasa() {
        const btn = document.getElementById("btnGuardarGrasa");
        btn.innerText = "..."; btn.disabled = true;

        const bodyData = {
            id: 0, fk_Prueba: idPruebaActual, porcObjetivo: 0,
            kgEntrada: parseFloat(document.getElementById("txtGrasaEnt")?.value) || 0,
            kgSalida: parseFloat(document.getElementById("txtGrasaSal")?.value) || 0,
            porcPartic: 0, difPorc: 0
        };

        fetch(`/tif/grasa`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "RequestVerificationToken": getCsrfToken()
          },
          body: JSON.stringify(bodyData)
        })
        .then(res => res.text())
        .then(res => {
            if(res.toLowerCase() === 'true') {
                btn.innerText = "Ok!"; btn.style.background = "green";
                abrirPruebaGrasa(idPruebaActual, document.getElementById("lote-Grasa").innerText);
                setTimeout(() => { btn.innerText = "Guardar"; btn.style.background = ""; btn.disabled = false; }, 2000);
            } else { alert("Error: El servidor rechazó los datos."); btn.innerText = "Guardar"; btn.disabled = false; }
        })
        .catch(error => { console.error(error); alert("Hubo un problema de red."); btn.innerText = "Guardar"; btn.disabled = false; });
    }

    function abrirPruebaRecorte(idPrueba, lote) {
        idPruebaActual = idPrueba;
        document.getElementById("modalRecorte").style.display = "flex";
        document.getElementById("lote-Recorte").innerText = lote;
        document.getElementById("badge-prueba-recorte").innerText = `Prueba #${idPrueba}`;
        const tbody = document.getElementById("tabla-Recorte");
        tbody.innerHTML = "<tr><td colspan='6'>Cargando...</td></tr>";

        fetch(`/tif/recorte?pruebaid=${idPrueba}`)
            .then(res => res.json())
            .then(data => {
                let r = (data && data.id) ? data : { id: 0, fk_Receta: 0, porcObjetivo: 0, kgEntrada: 0, kgSalida: 0, porcPartic: 0, difPorc: 0 };

                let idRecetaGuardada = (r.fk_Receta || r.Fk_Receta || r.idReceta || r.recetaId || 0).toString();

                let opciones = recetasCargadas.map(rec => {
                    let seleccionado = (rec.id.toString() === idRecetaGuardada) ? "selected" : "";
                    return `<option value="${rec.id}" ${seleccionado}>${rec.nombre} (${rec.objetivo}%)</option>`;
                }).join('');

                let colorDif = obtenerColorSemaforo(r.difPorc || 0);

                tbody.innerHTML = `
                    <tr data-id="${r.id}">
                        <td><select class="sap-input receta-select" onchange="actualizarObjetivoRecorte(this)"><option value="0">Seleccione...</option>${opciones}</select></td>
                        <td><span class="badge-sap">${r.porcObjetivo}%</span></td>
                        <td>${r.porcPartic}%</td>
                        <td style="color:${colorDif}; font-weight:bold;">${r.difPorc}%</td>
                            <td><input type="number" class="sap-input kg-entrada" id="txtRecorteEnt" value="${(parseFloat(r.kgEntrada) || 0) === 0 ? '' : r.kgEntrada}" placeholder="0"></td>
                            <td><input type="number" class="sap-input kg-salida" id="txtRecorteSal" value="${(parseFloat(r.kgSalida) || 0) === 0 ? '' : r.kgSalida}" placeholder="0"></td>
                    </tr>`;


                const selectElement = tbody.querySelector('.receta-select');
                if(selectElement && selectElement.value !== "0") {
                    actualizarObjetivoRecorte(selectElement);
                }
            }).catch(() => { tbody.innerHTML = "<tr><td colspan='6'>No se pudo cargar la información.</td></tr>"; });
    }

    function actualizarObjetivoRecorte(select) {
        const idSeleccionado = select.value.toString();
        const receta = recetasCargadas.find(r => r.id.toString() === idSeleccionado);
        const tr = select.closest('tr');
        const spanObjetivo = tr.querySelector('.badge-sap');

        if (receta) {
            spanObjetivo.innerText = `${receta.objetivo}%`;
        } else {
            spanObjetivo.innerText = `0%`;
        }
    }

    function guardarRecorte() {
        const btn = document.getElementById("btnGuardarRecorte");
        btn.innerText = "..."; btn.disabled = true;

        const idReceta = parseInt(document.querySelector('.receta-select')?.value) || 0;
        const objText = document.querySelector('#tabla-Recorte .badge-sap')?.innerText.replace('%', '') || "0";

        const bodyData = {
            id: 0,
            fk_Prueba: idPruebaActual,
            fk_Receta: idReceta,
            porcObjetivo: parseFloat(objText),
            kgEntrada: parseFloat(document.getElementById("txtRecorteEnt")?.value) || 0,
            kgSalida: parseFloat(document.getElementById("txtRecorteSal")?.value) || 0,
