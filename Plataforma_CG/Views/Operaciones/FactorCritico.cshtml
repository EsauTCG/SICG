            difPorc: 0
        };

        fetch(`/tif/recorte`, {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "RequestVerificationToken": getCsrfToken()
            },
            body: JSON.stringify(bodyData)
        })
        .then(res => res.text())
        .then(res => {
            if(res.toLowerCase() === 'true') {
                btn.innerText = "Ok!"; btn.style.background = "green";
                abrirPruebaRecorte(idPruebaActual, document.getElementById("lote-Recorte").innerText);
                setTimeout(() => { btn.innerText = "Guardar"; btn.style.background = ""; btn.disabled = false; }, 2000);
            } else { alert("Error: El servidor rechazó los datos."); btn.innerText = "Guardar"; btn.disabled = false; }
        })
        .catch(error => { console.error(error); alert("Hubo un problema de red."); btn.innerText = "Guardar"; btn.disabled = false; });
    }

        function numeroHueso(valor) {
        const n = parseFloat(valor);
        return Number.isFinite(n) ? n : 0;
    }

    function valoresIgualesHueso(a, b) {
        return Math.abs(numeroHueso(a) - numeroHueso(b)) < 0.0001;
    }

    async function obtenerMapaHuesoServidor(idPrueba) {
        const data = await fetchTifJson(`/tif/hueso?pruebaid=${idPrueba}&_=${Date.now()}`);

        const mapa = new Map();

        if (!Array.isArray(data)) return mapa;

        data.forEach(h => {
            const fkHueso = parseInt(h.fk_Hueso) || 0;
            const id = parseInt(h.id) || 0;

            if (!fkHueso) return;

            // Si hay duplicados por error viejo, nos quedamos con el primer Id real.
            if (!mapa.has(fkHueso)) {
                mapa.set(fkHueso, h);
                return;
            }

            const actual = mapa.get(fkHueso);
            const idActual = parseInt(actual?.id) || 0;

            if (idActual <= 0 && id > 0) {
                mapa.set(fkHueso, h);
            }
        });

        return mapa;
    }

    async function guardarTodosHueso() {
        if (guardandoHueso) return;

        const btn = document.getElementById("btnGuardarTodosHueso");
        const modal = document.getElementById("modalHueso");
        const scrollBody = modal.querySelector(".modal-body-scroll");
        const scrollActual = scrollBody.scrollTop;

        const filas = Array.from(document.querySelectorAll('#tabla-hueso tr[data-fkhueso]'));

        if (filas.length === 0) {
            alert("No hay filas de hueso para guardar.");
            return;
        }

        guardarDraftsHuesoEnMemoria();

        guardandoHueso = true;
        btn.disabled = true;
        btn.innerText = "Guardando...";
        mostrarLoader("Guardando registros de hueso, por favor espere...");

        const errores = [];
        const huesosGuardados = [];

        try {
            const mapaServidor = await obtenerMapaHuesoServidor(idPruebaActual);

            const filasParaGuardar = filas.filter(tr => {
                const fkHueso = parseInt(tr.dataset.fkhueso) || 0;
                if (!fkHueso) return false;

                const kgEntrada = numeroHueso(tr.querySelector('.kg-entrada')?.value);
                const kgSalida = numeroHueso(tr.querySelector('.kg-salida')?.value);

                if (kgEntrada <= 0 && kgSalida <= 0) return false;

                const existente = mapaServidor.get(fkHueso);
                const idExistente = parseInt(existente?.id) || 0;

                if (idExistente > 0) {
                    tr.dataset.id = idExistente;

                    const sinCambios =
                        valoresIgualesHueso(kgEntrada, existente.kgEntrada) &&
                        valoresIgualesHueso(kgSalida, existente.kgSalida);

                    // Si ya existe y no cambió nada, no lo vuelvas a mandar.
                    if (sinCambios) return false;
                }

                return true;
            });

            if (filasParaGuardar.length === 0) {
                alert("No hay cambios nuevos para guardar.");
                return;
            }

            for (const tr of filasParaGuardar) {
                const fkHueso = parseInt(tr.dataset.fkhueso) || 0;

                const porcObjetivoTexto =
                    tr.querySelector('.badge-sap')?.innerText
                        ?.replace('%', '')
                        ?.trim() || "0";

                const bodyData = {
                    id: parseInt(tr.dataset.id) || 0,
                    fk_Prueba: idPruebaActual,
                    fk_Hueso: fkHueso,
                    porcObjetivo: numeroHueso(porcObjetivoTexto),
                    kgEntrada: numeroHueso(tr.querySelector('.kg-entrada')?.value),
                    kgSalida: numeroHueso(tr.querySelector('.kg-salida')?.value),
                    porcPartic: 0,
                    difPorc: 0
                };

                try {
                    const txt = await fetchTifText(`/tif/hueso`, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "RequestVerificationToken": getCsrfToken()
                        },
                        body: JSON.stringify(bodyData)
                    });

                    const ok = (txt || "").trim().toLowerCase() === "true";

                    if (!ok) {
                        errores.push(`Hueso ${fkHueso}: el servidor respondió "${txt}"`);
                    } else {
                        huesosGuardados.push(fkHueso);
                    }
                } catch (errorFila) {
                    console.error("Error guardando hueso:", fkHueso, errorFila);
                    errores.push(`Hueso ${fkHueso}: ${errorFila.message || "error de conexión"}`);
                }
            }

            huesosGuardados.forEach(fkHueso => {
                limpiarDraftHuesoFila(idPruebaActual, fkHueso);
            });

            if (errores.length > 0) {
                alert(
                    "Algunos registros no se pudieron guardar.\n\n" +
                    errores.join("\n") +
                    "\n\nLos datos capturados se mantienen en pantalla para que puedas intentar de nuevo."
                );
                return;
            }

            btn.innerText = "¡Guardado!";
            btn.style.background = "green";

            abrirPruebaHueso(
                idPruebaActual,
                document.getElementById("lote-hueso").innerText,
                scrollActual
            );

        } catch (error) {
            console.error(error);

            alert(
                obtenerMensajeUsuario(error) +
                "\n\nLos datos capturados se mantienen en pantalla para que puedas intentar de nuevo."
            );

        } finally {
            ocultarLoader();

            setTimeout(() => {
                btn.innerText = "Guardar todos";
                btn.style.background = "";
                btn.disabled = false;
                guardandoHueso = false;
            }, 800);
        }
    }

    function claveDraftHueso(idPrueba, fkHueso) {
        return `${idPrueba}_${fkHueso}`;
    }

    function guardarDraftsHuesoEnMemoria() {
        const filas = document.querySelectorAll('#tabla-hueso tr[data-fkhueso]');

        filas.forEach(tr => {
            const fkHueso = parseInt(tr.dataset.fkhueso) || 0;
            if (!fkHueso) return;

            const key = claveDraftHueso(idPruebaActual, fkHueso);

            const inputEntrada = tr.querySelector('.kg-entrada');
            const inputSalida = tr.querySelector('.kg-salida');

            huesoDrafts[key] = {
                kgEntrada: inputEntrada ? inputEntrada.value : "",
                kgSalida: inputSalida ? inputSalida.value : ""
            };
        });
    }

    function obtenerDraftHueso(idPrueba, fkHueso) {
        const key = claveDraftHueso(idPrueba, fkHueso);
        return huesoDrafts[key] || null;
    }

    function limpiarDraftHuesoFila(idPrueba, fkHueso) {
        const key = claveDraftHueso(idPrueba, fkHueso);
        delete huesoDrafts[key];
    }

    function limpiarDraftsHuesoPrueba(idPrueba) {
        Object.keys(huesoDrafts).forEach(key => {
            if (key.startsWith(`${idPrueba}_`)) {
                delete huesoDrafts[key];
            }
        });
    }

    function abrirPruebaHueso(idPrueba, lote, scrollGuardado = 0) {
        idPruebaActual = idPrueba;

        const modal = document.getElementById("modalHueso");
        const scrollBody = modal.querySelector(".modal-body-scroll");
        const tbody = document.getElementById("tabla-hueso");

        modal.style.display = "flex";
        document.getElementById("lote-hueso").innerText = lote;
        document.getElementById("badge-prueba-hueso").innerText = `Prueba #${idPrueba}`;

        tbody.innerHTML = "<tr><td colspan='7'>Cargando...</td></tr>";

        if (abortHuesoController) {
            abortHuesoController.abort();
        }

        abortHuesoController = new AbortController();

        fetchTifJson(`/tif/hueso?pruebaid=${idPrueba}`, {
            signal: abortHuesoController.signal
        })
            .then(data => {
                if (!Array.isArray(data) || data.length === 0) {
                    data = [{
                        id: 0,
                        fk_Hueso: 1,
                        nombreHueso: "Nuevo Hueso",
                        porcObjetivo: 0,
                        kgEntrada: 0,
                        kgSalida: 0,
                        porcPartic: 0,
                        difPorc: 0
                    }];
                }

                const html = data.map(h => {
                    const draft = obtenerDraftHueso(idPrueba, h.fk_Hueso);

                const kgEntradaMostrar = draft
                    ? draft.kgEntrada
                    : ((parseFloat(h.kgEntrada) || 0) === 0 ? "" : h.kgEntrada);

                const kgSalidaMostrar = draft
                    ? draft.kgSalida
                    : ((parseFloat(h.kgSalida) || 0) === 0 ? "" : h.kgSalida);

                    const tieneConfirmado = (parseFloat(h.kgEntrada) || 0) > 0;
                    const colorDif = obtenerColorSemaforo(h.difPorc || 0);

                    return `
                        <tr data-id="${h.id}" data-fkhueso="${h.fk_Hueso}" data-porcobjetivo="${h.porcObjetivo}">
                            <td>${h.nombreHueso}</td>
                            <td><span class="badge-sap">${h.porcObjetivo}%</span></td>
                            <td class="td-partic">${h.porcPartic}%</td>
                            <td class="td-dif" style="color:${colorDif}; font-weight:bold;">${h.difPorc}%</td>
                            <td>
                                <input
                                    type="number"
                                    class="sap-input kg-entrada"
                                    value="${kgEntradaMostrar ?? ''}"
                                    placeholder="0"
                                    ${tieneConfirmado ? "disabled" : ""}
                                >
                            </td>
                            <td>
                                <input
                                    type="number"
                                    class="sap-input kg-salida"
                                    value="${kgSalidaMostrar ?? ''}"
                                    placeholder="0"
                                >
                            </td>
                            <td>
                                <button class="tbtn primary" style="height:28px;" onclick="guardarFilaHueso(this)">Guardar</button>
                            </td>
                        </tr>`;
                }).join("");

                tbody.innerHTML = html;

                activarCapturaHuesoOptimizada();

                requestAnimationFrame(() => {
                    scrollBody.scrollTop = scrollGuardado;
                });
            })
            .catch(error => {
                if (error.name === "AbortError") return;

                console.error("Error al cargar hueso:", error);
                tbody.innerHTML = `
                    <tr>
                        <td colspan="7" style="text-align:center; color:red; font-weight:600;">
                            ${obtenerMensajeUsuario(error)}
                        </td>
                    </tr>`;
            });
    }

    async function guardarFilaHueso(btn) {
        if (guardandoHueso) return;

        const tr = btn.closest('tr');
        const modal = document.getElementById("modalHueso");
        const scrollBody = modal.querySelector(".modal-body-scroll");
        const scrollActual = scrollBody.scrollTop;

        guardarDraftHuesoFila(tr);

        const fkHueso = parseInt(tr.dataset.fkhueso) || 0;

        if (!fkHueso) {
            alert("No se pudo identificar el tipo de hueso.");
            return;
        }

        guardandoHueso = true;
        btn.innerText = "Guardando...";
        btn.disabled = true;

        try {
            const mapaServidor = await obtenerMapaHuesoServidor(idPruebaActual);
            const existente = mapaServidor.get(fkHueso);
            const idExistente = parseInt(existente?.id) || 0;

            if (idExistente > 0) {
                tr.dataset.id = idExistente;
            }

            const porcObjetivoTexto =
                tr.querySelector('.badge-sap')?.innerText
                    ?.replace('%', '')
                    ?.trim() || "0";

            const bodyData = {
                id: parseInt(tr.dataset.id) || 0,
                fk_Prueba: idPruebaActual,
                fk_Hueso: fkHueso,
                porcObjetivo: numeroHueso(porcObjetivoTexto),
                kgEntrada: numeroHueso(tr.querySelector('.kg-entrada')?.value),
                kgSalida: numeroHueso(tr.querySelector('.kg-salida')?.value),
                porcPartic: 0,
                difPorc: 0
            };

            const res = await fetchTifText(`/tif/hueso`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": getCsrfToken()
                },
                body: JSON.stringify(bodyData)
            });

            if ((res || "").trim().toLowerCase() === "true") {
                limpiarDraftHuesoFila(idPruebaActual, fkHueso);

                btn.innerText = "Guardado";
                btn.style.background = "green";

                abrirPruebaHueso(
                    idPruebaActual,
                    document.getElementById("lote-hueso").innerText,
                    scrollActual
                );
            } else {
                alert("El servidor rechazó los datos.");
                btn.innerText = "Guardar";
                btn.disabled = false;
            }

        } catch (error) {
            console.error(error);
            alert("Error al guardar. Si la página estuvo abierta mucho tiempo, recarga e inicia sesión de nuevo.");
            btn.innerText = "Guardar";
            btn.disabled = false;

        } finally {
            setTimeout(() => {
                guardandoHueso = false;
            }, 500);
        }
    }

    function cerrarModal(idModal) {
