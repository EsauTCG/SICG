        </div>
    </div>
</div>

<!-- Toast Error Impresión -->
<div id="toastImpresionError" class="toast toast-error">
    <div class="toast-icon"></div>
    <div class="toast-content">
        <div class="toast-title">Error de impresión</div>
        <div class="toast-message">
            No se pudo imprimir la etiqueta
        </div>
        <div class="toast-actions">
            <button class="toast-btn retry" onclick="reintentarImpresion()">
                Reimprimir
            </button>
            <button class="toast-btn close" onclick="ocultarToastImpresion()">
                Cerrar
            </button>
        </div>
    </div>
</div>

<!-- Loading Global -->
