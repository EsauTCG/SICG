<!--CONFIRMACION DE CAPTURA-->
<div id="modalConfirmarCaptura" class="modal modal-confirm-captura" style="display:none;">
    <div class="confirm-header">
        <div class="confirm-icon">⚠️</div>
        <div>
            <h4>Confirmar captura</h4>
            <p>Revisa la información antes de registrar la entrada.</p>
        </div>
    </div>

    <div class="confirm-summary">
        <div class="confirm-item">
            <span>Lote</span>
            <strong id="confirmLote">—</strong>
        </div>

        <div class="confirm-item">
            <span>Producto</span>
            <strong id="confirmProducto">—</strong>
        </div>

        <div class="confirm-item">
            <span>SKU</span>
            <strong id="confirmSku">—</strong>
        </div>

        <div class="confirm-item peso">
            <span>Peso a capturar</span>
            <strong id="confirmPeso">0.000 kg</strong>
        </div>

        <div class="confirm-item tara">
            <span>Tara</span>
            <strong id="confirmTara">0.000 kg</strong>
        </div>
    </div>

    <div class="confirm-warning">
        Esta acción registrará la captura y enviará la impresión correspondiente.
    </div>

    <div class="confirm-actions">
        <button type="button" class="btn btn-cancelar-confirm" onclick="cerrarConfirmacionCaptura()">
            Cancelar
        </button>

        <button type="button" class="btn btn-confirmar-captura" id="btnConfirmarCaptura" onclick="confirmarCapturaEntrada()">
            Confirmar captura
        </button>
    </div>
</div>



