    /* ===== KPIs + TIEMPO REAL ARRIBA ===== */

    .kpis-con-tiempo-real {
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(480px, .85fr);
        gap: 16px;
        align-items: stretch;
        height: 320px;
    }

    .kpis-main {
        display: grid;
        grid-template-columns: minmax(0, 1.75fr) minmax(220px, .75fr);
        gap: 14px;
        min-width: 0;
        height: 320px;
        align-items: stretch;
    }

        .kpis-main > .kpi {
            min-width: 0;
        }

    /* Peso */
    #kpiPeso {
        grid-column: auto !important; /* CLAVE: cancela el span 2 viejo */
        height: 100%;
        width: 100%;
        display: grid;
        place-items: center;
        align-content: center;
        background: #f5f9ff;
        border: none;
        text-align: center;
        overflow: hidden;
    }

        #kpiPeso::after {
            display: none !important;
        }

    .kpis-con-tiempo-real #kpiPeso .value {
        font-size: clamp(68px, 7vw, 110px);
        line-height: 1;
    }

    /* Imagen del producto */
    .kpi-producto-preview {
        grid-column: auto !important;
        height: 100%;
        width: 100%;
        padding: 10px;
        display: flex;
        align-items: stretch;
        justify-content: center;
        background: #f8fafc;
        overflow: hidden;
    }

        .kpi-producto-preview img {
            width: 100%;
            height: 100%;
            max-height: none;
            object-fit: contain;
            object-position: center;
            display: block;
            border-radius: 10px;
            border: 2px solid #aaa;
            background: #fff;
        }

    /* Tabla tiempo real */
    .panel-tiempo-real {
        width:100%;
        height: 320px;
        max-height: 320px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

        .panel-tiempo-real .header {
            background: var(--brand-grad);
            color: #fff;
            border-bottom: none;
            font-size: 15px;
            padding: 12px 16px;
            flex: 0 0 auto;
        }

    .tabla-tiempo-real-wrapper {
        flex: 1 1 auto;
        overflow-y: auto;
        overflow-x: auto;
        background: #fff;
    }

    .tabla-tiempo-real {
        width: max-content;
        min-width: 100%;
        font-size: 13px;
    }

        .tabla-tiempo-real th,
        .tabla-tiempo-real td {
            padding: 8px 10px;
            white-space: nowrap;
        }

        .tabla-tiempo-real th {
            position: sticky;
            top: 0;
            z-index: 3;
            background: #f5f5f5;
        }

        .tabla-tiempo-real tbody tr {
            transition: background .2s ease;
        }

            .tabla-tiempo-real tbody tr:hover {
                background: #f8f8f8;
            }

    /* Responsive */
    @@media (max-width: 1200px) {
        .kpis-con-tiempo-real {
            grid-template-columns: 1fr;
            height: auto;
        }

        .kpis-main {
            grid-template-columns: 2fr 1fr;
            height: 260px;
        }

        .kpi-producto-preview {
            height: 100%;
            min-height: 0;
        }

            .kpi-producto-preview img {
                max-height: none;
            }

        .panel-tiempo-real {
            height: 300px;
            max-height: 300px;
        }
    }

    @@media (max-width: 768px) {
        .kpis-main {
            grid-template-columns: 1fr;
        }

        .kpi-producto-preview {
            min-height: 150px;
        }

        .panel-tiempo-real {
            height: 260px;
            max-height: 260px;
        }
    }

    .panel-tiempo-real {
        max-height: 320px;
    }

    .tabla-tiempo-real tbody tr {
        transition: background .2s ease;
    }

        .tabla-tiempo-real tbody tr:hover {
            background: #f8f8f8;
        }

    /* ===== CONFIGURACIÓN RÁPIDA EN 2 x 2 ===== */

    .two-col > .panel:nth-child(2) .cards {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
        width: 100%;
    }

    .two-col > .panel:nth-child(2) .Contra {
        display: contents;
    }

    .two-col > .panel:nth-child(2) .card {
        width: 100%;
        min-height: 105px;
        padding: 14px;
    }

        .two-col > .panel:nth-child(2) .card .row {
            height: 100%;
            display: grid;
            grid-template-rows: auto auto;
            gap: 10px;
            align-items: center;
            justify-items: center;
            text-align: center;
        }

        .two-col > .panel:nth-child(2) .card .btn,
        .two-col > .panel:nth-child(2) .card .btn-secondary,
        .two-col > .panel:nth-child(2) .card .btn-toggle-peso {
            width: 100%;
            max-width: 220px;
            min-height: 40px;
            justify-content: center;
            border-radius: 10px;
