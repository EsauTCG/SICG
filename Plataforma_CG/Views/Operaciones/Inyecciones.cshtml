    }

    .filtros-reportes-left {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }

    .fechas-reportes {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        align-items: flex-end;
    }

        .fechas-reportes label {
            margin: 0;
            min-width: 180px;
        }

    .acciones-reportes-left {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .acciones-reportes-right {
        display: flex;
        justify-content: flex-end;
        align-items: flex-end;
        margin-left: auto;
    }

        .acciones-reportes-right .btn,
        .acciones-reportes-left .btn {
            min-width: 170px;
            justify-content: center;
        }

    @@media (max-width: 768px) {
        .filtros-reportes-top {
            flex-direction: column;
            align-items: stretch;
        }

        .filtros-reportes-left,
        .acciones-reportes-right,
