    @@media (max-width: 768px) {
        .two-col > .panel:nth-child(2) .cards {
            grid-template-columns: 1fr;
        }
    }

    /* =========================================
       DARK MODE - MÓDULO INYECCIONES
    ========================================= */

    body[data-theme="dark"] {
        --bg: #0b1120;
        --panel: #111827;
        --text: #f9fafb;
        --muted: #9ca3af;
        --border: #374151;
        --badge: #1f2937;
        --shadow: 0 10px 24px rgba(0,0,0,.35);
    }

        /* Fondo y contenedores principales */
        body[data-theme="dark"] .layout,
        body[data-theme="dark"] .contents,
        body[data-theme="dark"] .toolbar,
        body[data-theme="dark"] .panel,
        body[data-theme="dark"] .kpi,
        body[data-theme="dark"] .card {
            background: var(--panel) !important;
            color: var(--text) !important;
            border-color: var(--border) !important;
        }

        /* Layout principal */
        body[data-theme="dark"] .layout {
            border-color: #7f1d1d !important;
        }

        /* Toolbar */
        body[data-theme="dark"] .toolbar {
            border-bottom-color: var(--border) !important;
        }

        body[data-theme="dark"] label,
        body[data-theme="dark"] .panel .header,
        body[data-theme="dark"] .panel .form-grid.readonly .field label,
        body[data-theme="dark"] .kpi .title,
        body[data-theme="dark"] .card .meta,
        body[data-theme="dark"] .programacion-info {
            color: var(--muted) !important;
        }

            /* Programación actual */
            body[data-theme="dark"] #programacionActual,
            body[data-theme="dark"] .programacion-info .badge,
            body[data-theme="dark"] .badge {
                background: #1f2937 !important;
                color: #fca5a5 !important;
                border: 1px solid #374151 !important;
            }

        /* Inputs */
        body[data-theme="dark"] input,
        body[data-theme="dark"] select,
        body[data-theme="dark"] textarea,
        body[data-theme="dark"] .form-control,
        body[data-theme="dark"] .form-select {
            background: #0f172a !important;
            color: #f9fafb !important;
            border-color: #4b5563 !important;
        }

            body[data-theme="dark"] input::placeholder,
            body[data-theme="dark"] textarea::placeholder {
                color: #9ca3af !important;
            }

            body[data-theme="dark"] input:focus,
            body[data-theme="dark"] select:focus,
            body[data-theme="dark"] textarea:focus {
                border-color: #991b1b !important;
                box-shadow: 0 0 0 2px rgba(153,27,27,.25) !important;
            }

        /* Datos readonly */
        body[data-theme="dark"] .panel .form-grid.readonly input[disabled],
        body[data-theme="dark"] .field input[disabled] {
            background: transparent !important;
            color: #f9fafb !important;
            border-bottom-color: #374151 !important;
        }

        /* KPIs */
        body[data-theme="dark"] #kpiPeso .title {
            color: #fca5a5 !important;
        }

        body[data-theme="dark"] #kpiPeso .value {
            color: #ef4444 !important;
        }

        body[data-theme="dark"] #kpiPorcentaje .title,
        body[data-theme="dark"] #kpiVelocidad .title {
            color: #f9fafb !important;
        }

        /* Botones */
        body[data-theme="dark"] .btn.ghost,
        body[data-theme="dark"] .btn.report,
        body[data-theme="dark"] .tool-btn-secondary {
            background: #1f2937 !important;
            color: #f9fafb !important;
            border-color: #374151 !important;
        }

            body[data-theme="dark"] .btn.ghost:hover,
            body[data-theme="dark"] .btn.report:hover {
                background: #374151 !important;
            }

        /* Cards productos / taras */
        body[data-theme="dark"] .product-card,
        body[data-theme="dark"] .product-card-large,
        body[data-theme="dark"] .tara-item,
        body[data-theme="dark"] .comparacion-container {
            background: #111827 !important;
            color: #f9fafb !important;
            border-color: #374151 !important;
        }

            body[data-theme="dark"] .product-card span,
            body[data-theme="dark"] .product-card-large span {
                color: #f9fafb !important;
            }

            body[data-theme="dark"] .product-card small,
            body[data-theme="dark"] .product-card-large small {
                color: #9ca3af !important;
            }

            body[data-theme="dark"] .product-card:hover,
            body[data-theme="dark"] .product-card-large:hover,
            body[data-theme="dark"] .tara-item:hover {
                background: #1f2937 !important;
            }

        /* Tablas */
        body[data-theme="dark"] .table,
        body[data-theme="dark"] .tabla-reporte,
        body[data-theme="dark"] #tablaComparacion {
            background: #111827 !important;
            color: #f9fafb !important;
        }

            body[data-theme="dark"] .table th,
            body[data-theme="dark"] .table td,
            body[data-theme="dark"] .tabla-reporte th,
            body[data-theme="dark"] .tabla-reporte td,
            body[data-theme="dark"] #tablaComparacion th,
            body[data-theme="dark"] #tablaComparacion td {
                background: #111827 !important;
                color: #f9fafb !important;
                border-color: #374151 !important;
            }

            body[data-theme="dark"] .tabla-reporte th,
            body[data-theme="dark"] #tablaComparacion th {
                background: #1f2937 !important;
                color: #fca5a5 !important;
            }

            body[data-theme="dark"] .tabla-reporte tr:hover {
                filter: brightness(1.15);
            }

        /* Filas de alerta en tablas */
