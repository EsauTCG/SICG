            width: 100%;
        }

        .fechas-reportes {
            flex-direction: column;
            width: 100%;
        }

            .fechas-reportes label {
                width: 100%;
                min-width: unset;
            }

        .acciones-reportes-left .btn,
        .acciones-reportes-right .btn {
