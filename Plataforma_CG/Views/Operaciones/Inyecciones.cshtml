        }
    }

    .modal-confirm-captura {
        width: 460px;
        max-width: 94vw;
        height: auto;
        max-height: none;
        padding: 0;
        overflow: hidden;
        border-radius: 18px;
        border: 1px solid rgba(139, 0, 0, .18);
    }

    .confirm-header {
        display: flex;
        gap: 14px;
        align-items: center;
        padding: 18px 20px;
        background: var(--brand-grad);
        color: #fff;
    }

    .confirm-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: rgba(255,255,255,.16);
        display: grid;
        place-items: center;
        font-size: 26px;
    }

    .confirm-header h4 {
        margin: 0;
        font-size: 20px;
        color: #fff;
    }

    .confirm-header p {
        margin: 4px 0 0 0;
        font-size: 13px;
        opacity: .9;
    }

    .confirm-summary {
        padding: 18px 20px;
        display: grid;
        gap: 10px;
        background: #fff;
    }

    .confirm-item {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        padding: 11px 12px;
        border-radius: 12px;
        background: #f7f8fa;
        border: 1px solid #e3e7ee;
    }

        .confirm-item span {
            color: #6b7a90;
            font-size: 13px;
            font-weight: 700;
        }

        .confirm-item strong {
