    }

    .product-card {
        transition: all 0.3s ease;
        opacity: 1;
    }

        .product-card.oculto {
            display: none !important;
        }

    #searchProducto::placeholder {
        color: #aaa;
    }

    .product-card:hover {
        transform: translateY(-5px);
