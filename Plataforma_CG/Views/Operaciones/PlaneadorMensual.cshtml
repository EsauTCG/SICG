@model List<SubClasMensualModel>
@using Plataforma_CG.Models.Operaciones.Planeacion

<div class="card border-danger">
    <div class="card-header bg-danger text-white">
        Plantilla mensual por clasificación
    </div>

    <div class="card-body">
        <table class="table table-bordered text-center">
            <thead class="table-danger">
                <tr>
                    <th>Clasificación</th>
                    <th>Cantidad</th>
                    <th>Kg Promedio</th>
                    <th>Peso Total</th>
                    <th>Porcentaje</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var clas in Model)
                {
                    
                    <tr class="table-secondary subclas-row">
                        <td><b>@clas.Nombre</b></td>

                        <td>
                            <input type="number"
                                   class="form-control cantidad"
                                   value="@clas.Canales"
                                   readonly>
                        </td>

                        <td>
                            <input type="number"
                                   step="0.01"
                                   class="form-control peso-promedio"
                                   value="@clas.PesoPromedio.ToString("0.00")"
                                   readonly>
                        </td>

                        <td>
                            <input type="number"
                                   step="0.01"
                                   class="form-control peso-total"
                                   value="@clas.PesoTotal.ToString("0.00")"
                                   readonly>
                        </td>
                        <td>
                            <input type="number"
                                   class="form-control porcentaje"
                                   value="100"
                                   readonly>
                        </td>

                    </tr>

                    
                    @foreach (var c in clas.DetalleMensual)
                    {
                        <tr class="detalle-row"
                            data-id="@c.Id"
                            data-fecha="@c.Fecha"
                            data-sku="@clas.SkuClasificacion">

                            <td class="ps-4">
                                └ @c.NombreClasificacion
                            </td>

                            <td>
                                <input type="number"
                                       class="form-control cantidad"
                                       value="@c.Canales"
                                       min="0">
                            </td>

                            <td>
                                <input type="number"
                                       step="0.01"
                                       class="form-control peso-promedio"
                                       value="@c.PesoPromedio">
                            </td>

                            <td>
                                <input type="number"
                                       step="0.01"
                                       class="form-control peso-total"
                                       value="@c.PesoTotal"
                                       readonly
                                       disabled>
                            </td>
                            <td>
                                <input type="number"
                                       step="0.01"
                                       class="form-control porcentaje"
                                       value="@c.Porcentaje"
                                       readonly>
                            </td>

                        </tr>
                    }
                }
            </tbody>

        </table>

        <div class="text-end">
            <button class="btn btn-danger" onclick="guardarPlantillaMensual()">
                💾 Guardar plantilla
            </button>
        </div>
    </div>
</div>
