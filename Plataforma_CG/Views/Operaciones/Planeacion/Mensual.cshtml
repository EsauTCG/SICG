        // ================= TABLAS =================
            function ajustarSemanaAlMes(fechaInicio, fechaFin, mes, anio) {

            const inicioMes = new Date(anio, mes - 1, 1);
            const finMes = new Date(anio, mes, 0); // último día del mes

            const inicioValido = fechaInicio < inicioMes ? inicioMes : fechaInicio;
            const finValido = fechaFin > finMes ? finMes : fechaFin;

            return {
                inicio: inicioValido,
                fin: finValido
            };
        }
            async function obtenerTotalSemanal(fechaInicio, fechaFin, clasificacion) {

            const fechain = fechaInicio.toISOString().split('T')[0];
            const fechafin = fechaFin.toISOString().split('T')[0];

            const response = await fetch(`ObtenerSemanal?fechain=${fechain}&fechafin=${fechafin}&clas=${clasificacion}`);

            if (!response.ok) {
                console.error("Error al obtener semanal");
                return 0;
            }

            return await response.json();
        }
            async function cargarTotalesSemanas(semanas, clasificaciones) {

        const promesas = [];

        for (let semana of semanas) {

            const inicioOriginal = new Date(semana.dataset.fechaInicio);
            const finOriginal = new Date(semana.dataset.fechaFin);

            const fechasAjustadas = ajustarSemanaAlMes(
                inicioOriginal,
                finOriginal,
                mesSel,
                anioSel
            );

            for (let clasificacion of clasificaciones) {

                const promesa = obtenerTotalSemanal(
                    fechasAjustadas.inicio,
                    fechasAjustadas.fin,
                    clasificacion
                ).then(lista => {

                    // 🔥 encontrar el card correcto
                    const cards = semana.querySelectorAll(".card");

                    cards.forEach(card => {

                        const nombre = card.querySelector(".fw-bold")?.innerText.trim();

                        if (nombre !== clasificacion) return;

                        const filas = card.querySelectorAll("tbody tr");

                        // 🔥 MAPEAR RESPUESTA DEL BACKEND
                        const mapa = {};

                        if (Array.isArray(lista)) {
                            lista.forEach(item => {
                                const key = (item.subClasificacion || item.SubClasificacion || "").trim();
                                mapa[key] = item.canales ?? item.Canales ?? 0;
                            });
                        }

                        let total = 0;

                        filas.forEach(fila => {

                            const sub = fila.querySelector(".nomClas")?.innerText.trim();

                            const input = fila.querySelector(".input-subclas-semana");

                            let valor = mapa[sub] ?? 0;

                            input.value = valor;

                            total += valor;
                        });

                        // 🔥 actualizar total semanal
                        const totalInput = card.querySelector(".total-semana");
                        if (totalInput) {
                            totalInput.value = total;
                        }

                        // 🔥 recalcular porcentajes visuales
                        filas.forEach(fila => {

                            const inputFila = fila.querySelector(".input-subclas-semana");
                            const valor = parseInt(inputFila.value) || 0;

                            const porcentaje = total > 0
                                ? (valor / total) * 100
                                : 0;

                            const celda = fila.querySelector(".porcentaje-est");

                            if (celda) {
                                celda.innerText = porcentaje.toFixed(2) + "%";
                            }
                        });

                    });

                });

                promesas.push(promesa);
            }
        }

        await Promise.all(promesas);
    }




            async function renderTablasEnSemanas() {

            if (!ResumenMensualGlobal.length) return;

            const semanas = document.querySelectorAll(".registro");

            for (const semana of semanas) {

                const contenedor = semana.querySelector(".tabla-distribucion-semana");
                if (!contenedor) continue;

                let html = "";

                ResumenMensualGlobal.forEach(clas => {

                    html += `
                        <div class="card p-2 shadow-sm" style="min-width:170px; max-width:200px; font-size:11px;">
                                <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="fw-bold text-danger">
                ${clas.clasificacion}
            </span>

            <button class="btn btn-sm btn-outline-primary"
                onclick="abrirModalDistribucion(
                    '${clas.clasificacion}',
                    this
                )">
                📅
            </button>
        </div>


                            <input type="number"
                                   id="input-${clas.clasificacion}-${semana.dataset.numero}"
                                   class="form-control form-control-sm mb-2 total-semana"
                                   placeholder="Total semana"
                                   >

                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
        <th>Sub</th>
        <th>% Est.</th>
        <th>Canales</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${clas.detalle?.map(det => `
                                        <tr data-porcentaje="${det.porcentaje}">
                                            <td class="nomClas">${det.nombreClasificacion}</td>
                                                <td class="porcentaje-est">0%</td>
    <td>
        <input type="number"
               class="form-control form-control-sm input-subclas-semana"
               value="0"
               oninput="recalcularSemana(this)">
    </td>
                                        </tr>
                                    `).join("") || ""}
                                </tbody>
                            </table>
                        </div>
                    `;
                });

                contenedor.innerHTML = html;
            }
            const clasificaciones = ResumenMensualGlobal.map(c => c.clasificacion);

            // ⚠️ IMPORTANTE: llamar una sola vez después de renderizar todo
            await cargarTotalesSemanas(semanas,clasificaciones);
        }
                    function recalcularSemana(input){

        const card = input.closest(".card");
        if(!card) return;

        const inputs = card.querySelectorAll(".input-subclas-semana");
        const filas = card.querySelectorAll("tbody tr");

        let total = 0;

        inputs.forEach(i=>{
            total += parseInt(i.value) || 0;
        });

        // ✅ actualizar total arriba
        const totalInput = card.querySelector(".total-semana");
        if(totalInput){
            totalInput.value = total;
        }

        // ✅ recalcular porcentajes
        filas.forEach(fila => {

            const inputFila = fila.querySelector(".input-subclas-semana");
            const valor = parseInt(inputFila.value) || 0;

            let porcentaje = total > 0
                ? (valor / total) * 100
                : 0;

            const celda = fila.querySelector(".porcentaje-est");
            if(celda){
                celda.innerText = porcentaje.toFixed(2) + "%";
            }
        });
    }

