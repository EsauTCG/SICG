        async function guardarSemana(btn) {

        const registro = btn.closest(".registro");

        const fechaInicio = registro.dataset.fechaInicio;
        const fechaFin = registro.dataset.fechaFin;

        const cards = registro.querySelectorAll(".card");

        let clasificaciones = [];

        cards.forEach(card => {

            const filas = card.querySelectorAll("tbody tr");

            filas.forEach(fila => {

                const subclasificacion =
                    fila.querySelector(".nomClas")?.innerText.trim() || "";

                const canales =
                    parseInt(fila.querySelector(".input-subclas-semana")?.value) || 0;

                // ✅ puedes decidir si guardar ceros o no
                clasificaciones.push({
                    clasificacion: subclasificacion,   // 👈 IMPORTANTE
                    totalCanales: canales
                });

            });
        });

        const payload = {
            fechaInicioSemana: fechaInicio,
            fechaFinSemana: fechaFin,
            clasificaciones: clasificaciones // 👈 nombre correcto
        };

        console.log("Payload correcto:", payload);

        try {

            const res = await fetch("/Operaciones/GuardarDistribucionSemanal", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            });

            if (!res.ok) throw new Error("Error al guardar");

            alert("✅ Semana guardada correctamente");

        } catch (error) {

            console.error("Error:", error);
            alert("❌ Error al guardar");

        }
    }

        function calcularDistribucion(input) {

            const total = parseFloat(input.value) || 0;
            const card = input.closest(".card");
            const filas = card.querySelectorAll("tbody tr");

            filas.forEach(fila => {
                const porcentaje = parseFloat(fila.dataset.porcentaje) || 0;
                const resultado = (total * porcentaje) / 100;
                fila.querySelector(".canales-calc").innerText =
                    Math.round(resultado);
            });
        }
