    const badgeInfo = BADGE_MAP[mod.nombre] || null;

    const modLink = document.createElement("a");
    modLink.classList.add("layout-dropdown-btn");
    modLink.href = mod.url || "#";

    const iconWrap = document.createElement("div");
    iconWrap.className = "sb-icon-wrap";
    iconWrap.innerHTML = `<i class="${iconClass}"></i>`;
    modLink.appendChild(iconWrap);

    const labelSpan = document.createElement("span");
    labelSpan.className = "sb-item-label";
    labelSpan.textContent = mod.nombre || "";
    modLink.appendChild(labelSpan);

    if (badgeInfo) {
        const badge = document.createElement("span");
        badge.className = "sb-badge " + (badgeInfo.cls || "");
        badge.textContent = badgeInfo.text;
        modLink.appendChild(badge);
    }

    const subModulos = mod.subModulos || mod.submodulos || [];

    if (Array.isArray(subModulos) && subModulos.length > 0) {
        modLink.href = "#";

        const arrow = document.createElement("i");
        arrow.classList.add("fas", "fa-chevron-down", "layout-arrow");
        modLink.appendChild(arrow);

        const subContainer = document.createElement("div");
        subContainer.classList.add("layout-dropdown-container");

        subModulos.forEach(sub => {
            const subLink = document.createElement("a");
            subLink.href = sub.url || "#";

            const subIcon = sub.icono || "fas fa-caret-right";
            subLink.innerHTML = `<i class="${subIcon} me-1"></i>${sub.nombre || ""}`;

            subContainer.appendChild(subLink);
        });

        modItem.appendChild(modLink);
        modItem.appendChild(subContainer);
    } else {
        modItem.appendChild(modLink);
    }

    return modItem;
}

const grouped = {};

modulos.forEach(mod => {
    const section = getSectionForMod(mod);

    if (!grouped[section]) {
        grouped[section] = [];
    }

    grouped[section].push(mod);
});

const sectionNames = [
    ...SECTION_ORDER.filter(section => grouped[section]?.length),
    ...Object.keys(grouped)
        .filter(section => !SECTION_ORDER.includes(section))
        .sort((a, b) => a.localeCompare(b))
];

sectionNames.forEach((section, index) => {
    const items = grouped[section];

    if (index > 0) {
        const div = document.createElement("div");
        div.className = "sb-divider";
        contenedor.appendChild(div);
    }

    const lbl = document.createElement("div");
    lbl.className = "sb-section-label";
    lbl.textContent = section.toUpperCase();
    contenedor.appendChild(lbl);

    items.forEach(mod => {
        contenedor.appendChild(crearLayoutItemModulo(mod));
    });
});

                // Activar dropdowns
                document.querySelectorAll('.layout-dropdown-btn').forEach(btn => {
                    btn.addEventListener('click', e => {
                        const item = btn.parentElement;
                        const hasSub = item.querySelector('.layout-dropdown-container');
                        if (hasSub) {
                            e.preventDefault();
                            document.querySelectorAll('.layout-menu-item').forEach(it => {
                                if (it !== item) it.classList.remove('layout-open');
                            });
                            item.classList.toggle('layout-open');
                        }
                    });
                });

                // Búsqueda en tiempo real
                const searchInput = document.getElementById("sb-search-input");
                if (searchInput) {
                    searchInput.addEventListener("input", function () {
                        const q = this.value.trim().toLowerCase();
                        document.querySelectorAll(".layout-menu-item").forEach(item => {
                            const label = item.querySelector(".sb-item-label");
                            const text = label ? label.textContent.toLowerCase() : "";
                            const subTexts = Array.from(item.querySelectorAll(".layout-dropdown-container a"))
                                .map(a => a.textContent.toLowerCase()).join(" ");
                            const match = !q || text.includes(q) || subTexts.includes(q);
                            item.style.display = match ? "" : "none";
                            if (q && subTexts.includes(q)) item.classList.add("layout-open");
                            else if (!q) item.classList.remove("layout-open");
                        });
                        document.querySelectorAll(".sb-section-label").forEach(lbl => {
                            let next = lbl.nextElementSibling;
                            let hasVisible = false;
                            while (next && !next.classList.contains("sb-section-label") && !next.classList.contains("sb-divider")) {
                                if (next.classList.contains("layout-menu-item") && next.style.display !== "none") hasVisible = true;
                                next = next.nextElementSibling;
                            }
                            lbl.style.display = hasVisible ? "" : "none";
                        });
                    });
                }

            } catch (e) {
                console.error("Error cargando el sidebar dinámico:", e);
            }
        });

        // ========================================
        // CHAT FLOTANTE INTERNO
        // ========================================
        (function initLayoutInternalChat() {
            const fab = document.getElementById("layout-chat-fab");
            const panel = document.getElementById("layout-chat-panel");
            const closeBtn = document.getElementById("layout-chat-close-btn");
            const areaSelect = document.getElementById("layout-chat-area");
            const areaLabel = document.getElementById("layout-chat-area-label");
            const messages = document.getElementById("layout-chat-messages");
            const txt = document.getElementById("layout-chat-text");
            const btnSend = document.getElementById("layout-chat-send");
            if (!fab || !panel) return;
            let currentConversationId = null, pollTimer = null, currentAreaName = "";

            function togglePanel(show) { show ? panel.classList.remove("d-none") : panel.classList.add("d-none"); }
            fab.addEventListener("click", () => togglePanel(panel.classList.contains("d-none")));
            closeBtn.addEventListener("click", () => togglePanel(false));

            async function cargarAreas() {
                try {
                    const res = await fetch("/Chat/Areas");
                    if (!res.ok) throw new Error();
                    const data = await res.json();
                    areaSelect.innerHTML = `<option value="">-- Selecciona área --</option>`;
                    data.forEach(a => { const opt = document.createElement("option"); opt.value = a.idArea; opt.textContent = a.nombre; areaSelect.appendChild(opt); });
                } catch { areaSelect.innerHTML = `<option value="">(Error al cargar áreas)</option>`; }
            }
            cargarAreas();

            areaSelect.addEventListener("change", async () => {
                if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
                currentConversationId = null; messages.innerHTML = "";
                const val = areaSelect.value;
                if (!val) { areaLabel.textContent = "Selecciona un área para comenzar"; txt.value = ""; txt.disabled = true; btnSend.disabled = true; messages.innerHTML = `<div class="text-muted small text-center mt-2">Selecciona un área para iniciar.</div>`; return; }
                currentAreaName = areaSelect.options[areaSelect.selectedIndex].text;
                try {
                    const res = await fetch("/Chat/NuevaConversacion", { method:"POST", headers:{"Content-Type":"application/json"}, body: JSON.stringify({ idArea: parseInt(val,10) }) });
                    const data = await res.json();
                    if (!res.ok || !data.ok) throw new Error(data.mensaje || "Error");
                    currentConversationId = data.idConversacion; areaLabel.textContent = `Conversando con: ${currentAreaName}`; txt.disabled = false; btnSend.disabled = false;
                    await cargarMensajes(); pollTimer = setInterval(cargarMensajes, 5000);
                } catch (e) { alert(e.message || "Error"); areaSelect.value = ""; areaLabel.textContent = "Selecciona un área"; txt.disabled = true; btnSend.disabled = true; }
            });

            function renderMensajes(lista) {
                messages.innerHTML = "";
                if (!lista || !lista.length) { messages.innerHTML = `<div class="text-muted small text-center mt-2">No hay mensajes aún 👋</div>`; return; }
                lista.forEach(m => {
                    const w = document.createElement("div"); w.classList.add("layout-chat-msg", m.esMio ? "layout-me" : "layout-other");
                    const b = document.createElement("div"); b.classList.add("layout-bubble");
                    const h = new Date(m.fecha).toLocaleTimeString("es-MX",{hour:"2-digit",minute:"2-digit"});
                    b.innerHTML = `<div>${m.texto}</div><span class="layout-meta">${m.esMio?"Tú":"Área "+currentAreaName} · ${h}</span>`;
                    w.appendChild(b); messages.appendChild(w);
                });
                messages.scrollTop = messages.scrollHeight;
            }

            async function cargarMensajes() {
                if (!currentConversationId) return;
                try { const res = await fetch(`/Chat/Mensajes/${currentConversationId}`); if (!res.ok) throw new Error(); const data = await res.json(); if (!data.ok) throw new Error(); renderMensajes(data.mensajes); } catch {}
            }

            btnSend.addEventListener("click", async () => {
                if (!currentConversationId) return; const raw = txt.value.trim(); if (!raw) return;
                try { const res = await fetch("/Chat/Enviar",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({idConversacion:currentConversationId,texto:raw})}); const data = await res.json(); if (!res.ok || !data.ok) throw new Error(data.mensaje||"Error"); txt.value=""; txt.focus(); await cargarMensajes(); } catch(e) { alert(e.message||"No se pudo enviar."); }
            });
            txt.addEventListener("keydown", e => { if (e.key==="Enter" && !e.shiftKey) { e.preventDefault(); btnSend.click(); } });
        })();

        // ========================================
        // MANUAL DE USUARIO
        // ========================================
        (function initLayoutUserManual() {
            const btn = document.getElementById("layout-manual-fab");
            const modalEl = document.getElementById("layoutManualModal");
            if (!btn || !modalEl) return;
            const modal = new bootstrap.Modal(modalEl);
            const titleEl = document.getElementById("layoutManualTitle");
            btn.addEventListener("click", () => {
                if (!window.manualConfig) {
                    titleEl.textContent = "Manual no disponible";
                    document.getElementById("manualSections").innerHTML = `<div class="alert alert-warning m-4">Por el momento este módulo aún no cuenta con manual de usuario disponible.</div>`;
                    modal.show(); return;
                }
                titleEl.textContent = window.manualConfig.title || "Manual de Usuario - SIGO";
                generarManualLibro();
                modal.show();
                setTimeout(() => { initManualListeners(); }, 300);
            });
        })();

        function generarManualLibro() {
            const tocNav = document.getElementById('manualToc');
            const sectionsContainer = document.getElementById('manualSections');
            if (!window.manualConfig || !window.manualConfig.sections) return;
            tocNav.innerHTML = ''; sectionsContainer.innerHTML = '';
            window.manualConfig.sections.forEach((section, index) => {
                const tocItem = document.createElement('div');
                tocItem.className = 'manual-toc-item';
                tocItem.setAttribute('data-section', section.id);
                tocItem.innerHTML = `<i class="fas ${section.icon}"></i><span>${section.title}</span>`;
                tocItem.onclick = () => scrollToManualSection(section.id);
                tocNav.appendChild(tocItem);
                const sectionDiv = document.createElement('section');
                sectionDiv.className = 'manual-section'; sectionDiv.id = section.id;
                let stepsHTML = '';
                section.steps.forEach(step => {
                    stepsHTML += `<div class="manual-step"><h4 class="manual-step-title"><i class="fas fa-chevron-right"></i>${step.title}</h4><p class="manual-step-text">${step.text}</p>${renderManualMedia(step)}</div>`;
                });
                sectionDiv.innerHTML = `<div class="manual-section-header"><div class="manual-section-number">${index+1}</div><h2 class="manual-section-title">${section.title}</h2></div><div class="manual-section-content">${stepsHTML}</div>`;
                sectionsContainer.appendChild(sectionDiv);
            });
        }

        function initManualListeners() {
            const contentArea = document.getElementById('manualContent');
            const scrollTopBtn = document.getElementById('manualScrollTopBtn');
            const progressBar = document.getElementById('manualProgressBar');
            if (!contentArea) return;
            contentArea.addEventListener('scroll', () => {
                updateActiveManualTocItem();
                scrollTopBtn.classList.toggle('show', contentArea.scrollTop > 300);
                progressBar.style.width = ((contentArea.scrollTop / (contentArea.scrollHeight - contentArea.clientHeight)) * 100) + '%';
            });
        }

        function updateActiveManualTocItem() {
            const sections = document.querySelectorAll('.manual-section');
            const tocItems = document.querySelectorAll('.manual-toc-item');
            let currentSection = null;
            sections.forEach(s => { if (s.getBoundingClientRect().top <= 150) currentSection = s.id; });
            tocItems.forEach(i => i.classList.toggle('active', i.getAttribute('data-section') === currentSection));
        }

        function scrollToManualSection(sectionId) {
            const section = document.getElementById(sectionId);
            const contentArea = document.getElementById('manualContent');
            if (section && contentArea) {
                contentArea.scrollTo({ top: section.offsetTop - 20, behavior: 'smooth' });
                if (window.innerWidth < 992) toggleManualSidebar();
            }
        }

        function scrollManualToTop() { document.getElementById('manualContent').scrollTo({ top: 0, behavior: 'smooth' }); }

        function toggleManualSidebar() {
            const sidebar = document.getElementById('manualSidebar');
            const overlay = document.querySelector('.manual-overlay');
            if (sidebar && overlay) { sidebar.classList.toggle('show'); overlay.classList.toggle('show'); }
        }

        function renderManualMedia(step) {
            if (step.video) return `<video class="manual-step-video" controls preload="metadata"><source src="${step.video}" type="video/mp4">Tu navegador no soporta video HTML5.</video>`;
            if (step.image) return `<img src="${step.image}" alt="${step.title||''}" class="manual-step-image">`;
            return "";
        }

         // ========================================
            // MODO OSCURO GLOBAL - PRUEBA
            // ========================================
            (function initGlobalThemeSwitch() {
                const body = document.body;
                const btn = document.getElementById('theme-toggle-btn');
                const icon = document.getElementById('theme-toggle-icon');

                if (!body || !btn || !icon) return;

                function setSwitchIcon(theme) {
                    icon.classList.remove('fa-sun', 'fa-moon');

                    if (theme === 'dark') {
                        icon.classList.add('fa-moon');
                        btn.title = 'Cambiar a modo claro';
                        btn.setAttribute('aria-label', 'Cambiar a modo claro');
                    } else {
                        icon.classList.add('fa-sun');
                        btn.title = 'Cambiar a modo oscuro';
                        btn.setAttribute('aria-label', 'Cambiar a modo oscuro');
                    }
                }

                function applyTheme(theme) {
                    body.setAttribute('data-theme', theme);
                    localStorage.setItem('sigoTheme', theme);
                    setSwitchIcon(theme);
                }

                const savedTheme = localStorage.getItem('sigoTheme') || 'light';
                applyTheme(savedTheme);

                btn.addEventListener('click', function () {
                    const currentTheme = body.getAttribute('data-theme') || 'light';
                    const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';

                    applyTheme(nextTheme);
                });
            })();

            window.SIGO_SESSION = {
                loginUrl: '@Url.Action("Index", "Home")',
                estadoSesionUrl: '@Url.Action("EstadoSesion", "Acceso")'
            };

            function getVistaActualUrl() {
                return window.location.pathname + window.location.search + window.location.hash;
            }

                (function () {
                    if (window.__sigoSessionWatcherInstalled) {
                        return;
                    }

                    window.__sigoSessionWatcherInstalled = true;

                    const loginUrl = window.SIGO_SESSION.loginUrl;
                    const estadoSesionUrl = window.SIGO_SESSION.estadoSesionUrl;

                    let redirigiendo = false;

                    function construirLoginUrl(redirectUrl) {
                        const vistaActual = getVistaActualUrl();

                        // Aunque el servidor mande redirectUrl, preferimos reconstruirlo desde la vista visible.
                        // Así evitamos regresar a endpoints tipo /api, /Chat/Mensajes, /Tif/Listar, etc.
                        return loginUrl
                            + '?expirada=1&returnUrl='
                            + encodeURIComponent(vistaActual);
                    }

                    function mostrarAvisoYRedirigir(redirectUrl) {
                        if (redirigiendo) return;
                        redirigiendo = true;

                        const destino = construirLoginUrl(redirectUrl);

                        let aviso = document.getElementById('sigo-session-expired-overlay');

                        if (!aviso) {
                            aviso = document.createElement('div');
                            aviso.id = 'sigo-session-expired-overlay';
                            aviso.innerHTML = `
                                <div class="sigo-session-expired-card">
                                    <div class="sigo-session-expired-icon">
                                        <i class="fas fa-clock"></i>
                                    </div>
                                    <h3>Sesión expirada</h3>
                                    <p>Tu sesión terminó por inactividad. Te enviaremos al inicio de sesión para continuar trabajando.</p>
                                    <div class="sigo-session-expired-loader"></div>
                                </div>
                            `;
                            document.body.appendChild(aviso);
                        }

                        setTimeout(function () {
                            window.location.href = destino;
                        }, 900);
                    }

                    function revisarRespuesta(response) {
                        if (!response) return response;

                        if (response.status === 401) {
                            response.clone().json()
                                .then(function (data) {
                                    if (data && data.sessionExpired) {
                                        mostrarAvisoYRedirigir(data.redirectUrl);
                                    } else {
                                        mostrarAvisoYRedirigir(null);
                                    }
                                })
                                .catch(function () {
                                    mostrarAvisoYRedirigir(null);
                                });
                        }

                        return response;
                    }

                    // Intercepta fetch global
                    if (window.fetch) {
                        const fetchOriginal = window.fetch;

                        window.fetch = function (input, init) {
                            init = init || {};
                            init.headers = init.headers || {};
                        if (init.headers instanceof Headers) {
                            if (!init.headers.has('X-Requested-With')) {
                                init.headers.set('X-Requested-With', 'XMLHttpRequest');
                            }

                            if (!init.headers.has('Accept')) {
                                init.headers.set('Accept', 'application/json');
                            }

                            init.headers.set('X-SIGO-Current-Url', getVistaActualUrl());
                        } else if (Array.isArray(init.headers)) {
                            init.headers.push(['X-Requested-With', 'XMLHttpRequest']);
                            init.headers.push(['Accept', 'application/json']);
                            init.headers.push(['X-SIGO-Current-Url', getVistaActualUrl()]);
                        } else {
                            init.headers['X-Requested-With'] = init.headers['X-Requested-With'] || 'XMLHttpRequest';
                            init.headers['Accept'] = init.headers['Accept'] || 'application/json';
                            init.headers['X-SIGO-Current-Url'] = getVistaActualUrl();
                        }

                            return fetchOriginal(input, init)
                                .then(function (response) {
                                    return revisarRespuesta(response);
                                });
                        };
                    }

                    // Intercepta jQuery AJAX
                    if (window.jQuery) {
                        $(document).ajaxSend(function (event, jqxhr) {
                            jqxhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
                            jqxhr.setRequestHeader('Accept', 'application/json');
                            jqxhr.setRequestHeader('X-SIGO-Current-Url', getVistaActualUrl());
                        });

                        $(document).ajaxError(function (event, jqxhr) {
                            if (jqxhr.status === 401) {
                                let redirectUrl = null;

                                try {
                                    const data = JSON.parse(jqxhr.responseText);
                                    if (data && data.sessionExpired) {
                                        redirectUrl = data.redirectUrl;
                                    }
                                } catch (e) {
                                    redirectUrl = null;
                                }

                                mostrarAvisoYRedirigir(redirectUrl);
                            }
                        });
                    }

                    // Revisión silenciosa cada minuto
                    async function revisarSesionActual() {
                        if (redirigiendo) return;

                        try {
                            const response = await fetch(estadoSesionUrl, {
                                method: 'GET',
                                cache: 'no-store',
                                headers: {
                                    'Accept': 'application/json',
                                    'X-Requested-With': 'XMLHttpRequest',
                                    'X-SIGO-Current-Url': getVistaActualUrl()
                                }
                            });

                            if (response.status === 401) {
                                let redirectUrl = null;

                                try {
                                    const data = await response.json();
                                    if (data && data.sessionExpired) {
                                        redirectUrl = data.redirectUrl;
                                    }
                                } catch (e) {
                                    redirectUrl = null;
                                }

                                mostrarAvisoYRedirigir(redirectUrl);
                            }
                        } catch (e) {
                            // Si se cae la red o el servidor tarda, no redirigimos.
                            // Solo redirigimos cuando el servidor confirma 401.
                        }
                    }

                    setInterval(revisarSesionActual, 30000);
                })();

    </script>

    @RenderSection("Scripts", required: false)

