            z-index: 999999;
            background: rgba(10, 0, 0, .72);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 18px;
        }

        .sigo-session-expired-card {
            width: min(430px, 100%);
            background: linear-gradient(180deg, #ffffff, #f8fafc);
            border-radius: 18px;
            padding: 30px 26px;
            text-align: center;
            box-shadow: 0 24px 70px rgba(0,0,0,.35);
            border: 1px solid rgba(139,0,0,.16);
            animation: sigoSessionIn .22s ease-out;
        }

        .sigo-session-expired-icon {
            width: 66px;
            height: 66px;
            border-radius: 50%;
            margin: 0 auto 16px;
            display: grid;
            place-items: center;
            background: rgba(139,0,0,.10);
            color: #8B0000;
            font-size: 28px;
        }

        .sigo-session-expired-card h3 {
            margin: 0 0 8px;
            color: #1f2937;
            font-weight: 900;
        }

        .sigo-session-expired-card p {
            margin: 0;
            color: #6b7280;
            font-size: .95rem;
            line-height: 1.45;
        }

        .sigo-session-expired-loader {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: 4px solid rgba(139,0,0,.15);
            border-top-color: #8B0000;
            margin: 20px auto 0;
            animation: sigoSessionSpin .8s linear infinite;
        }

        @@keyframes sigoSessionSpin {
            to

        {
            transform: rotate(360deg);
        }

        }

        @@keyframes sigoSessionIn {
            from

        {
            opacity: 0;
            transform: translateY(12px) scale(.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        }

        body[data-theme="dark"] .sigo-session-expired-card {
            background: linear-gradient(180deg, #1f2937, #111827);
            border-color: rgba(255,255,255,.12);
        }

            body[data-theme="dark"] .sigo-session-expired-card h3 {
                color: #f9fafb;
            }

            body[data-theme="dark"] .sigo-session-expired-card p {
                color: #cbd5e1;
            }

