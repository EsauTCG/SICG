/* ========================================
   MODO OSCURO GLOBAL
======================================== */
:root {
    --app-bg: #f3f6fa;
    --app-panel: #ffffff;
    --app-panel-soft: #f8fafc;
    --app-text: #1f2937;
    --app-muted: #6b7280;
    --app-border: #dfe5ec;
    --app-shadow: 0 6px 16px rgba(0,0,0,.10);
}

body[data-theme="dark"] {
    --app-bg: #111827;
    --app-panel: #1f2937;
    --app-panel-soft: #273244;
    --app-text: #f9fafb;
    --app-muted: #cbd5e1;
    --app-border: #374151;
    --app-shadow: 0 8px 22px rgba(0,0,0,.35);

    --layout-bg: #111827;
    --layout-panel: #1f2937;
    --layout-line: #374151;
}

body[data-theme="dark"] .layout-main-content {
    background: var(--app-bg) !important;
    color: var(--app-text) !important;
}

body[data-theme="dark"] .layout-main-content .layout-container-fluid {
    background: var(--app-panel) !important;
    color: var(--app-text) !important;
    border: 1px solid var(--app-border);
}

body[data-theme="dark"] .layout-footer {
    background: #0f172a !important;
    color: var(--app-muted) !important;
    border-top-color: var(--app-border) !important;
}

body[data-theme="dark"] .card,
body[data-theme="dark"] .modal-content,
body[data-theme="dark"] .dropdown-menu,
body[data-theme="dark"] .table,
body[data-theme="dark"] .form-control,
body[data-theme="dark"] .form-select {
    background-color: var(--app-panel) !important;
    color: var(--app-text) !important;
    border-color: var(--app-border) !important;
}

body[data-theme="dark"] .text-muted,
body[data-theme="dark"] small,
body[data-theme="dark"] label {
    color: var(--app-muted) !important;
}

body[data-theme="dark"] input,
body[data-theme="dark"] select,
body[data-theme="dark"] textarea {
    background-color: #0f172a !important;
    color: var(--app-text) !important;
    border-color: var(--app-border) !important;
}

body[data-theme="dark"] input::placeholder,
body[data-theme="dark"] textarea::placeholder {
    color: #94a3b8 !important;
}

/* Switch del header */
.theme-switch-btn {
    width: 54px;
    height: 30px;
    border: 1px solid rgba(255,255,255,.45);
    border-radius: 999px;
    background: rgba(255,255,255,.14);
    padding: 3px;
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    transition: all .25s ease;
}

.theme-switch-btn:hover {
    background: rgba(255,255,255,.22);
}

.theme-switch-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #fff;
    color: #8B0000;
    display: grid;
    place-items: center;
    font-size: 12px;
    transition: all .25s ease;
    box-shadow: 0 3px 8px rgba(0,0,0,.22);
}

body[data-theme="dark"] .theme-switch-thumb {
    transform: translateX(24px);
    background: #111827;
    color: #facc15;
        }


        body[data-theme="dark"] .bg-white,
        body[data-theme="dark"] .bg-light,
        body[data-theme="dark"] .alert-light,
        body[data-theme="dark"] .list-group-item,
        body[data-theme="dark"] .accordion-item,
        body[data-theme="dark"] .accordion-button,
        body[data-theme="dark"] .table-responsive,
        body[data-theme="dark"] .table-responsive-ui,
        body[data-theme="dark"] .card-body,
        body[data-theme="dark"] .card-header,
        body[data-theme="dark"] .modal-body,
        body[data-theme="dark"] .modal-footer {
            background-color: var(--app-panel) !important;
            color: var(--app-text) !important;
            border-color: var(--app-border) !important;
        }

        body[data-theme="dark"] .table th,
        body[data-theme="dark"] .table td,
        body[data-theme="dark"] table th,
        body[data-theme="dark"] table td {
            color: var(--app-text) !important;
            border-color: var(--app-border) !important;
        }

        body[data-theme="dark"] thead,
        body[data-theme="dark"] .table thead th {
            background-color: #0f172a !important;
            color: var(--app-text) !important;
        }

        body[data-theme="dark"] .btn-outline-secondary {
            color: var(--app-text) !important;
            border-color: var(--app-border) !important;
        }

            body[data-theme="dark"] .btn-outline-secondary:hover {
                background-color: #374151 !important;
