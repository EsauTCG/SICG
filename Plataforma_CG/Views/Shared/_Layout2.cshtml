<!DOCTYPE html>
<html lang="es">
<head>
    @* @RenderSection("Scripts", required: false) *@
    @RenderSection("Styles", required: false)
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SIGO | Sistema Integral De Gestión Operativa</title>
    <link rel="icon" type="image/png" href="~/images/ico_sigo.ico" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/fonts/fonts.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/fonts/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
   @*  <link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" /> *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>

        @@font-face {
            font-family: "SAP72";
            src: url("/fonts/sap/72-Regular-full.woff2") format("woff2");
            font-weight: 200;
            font-style: normal;
            font-display: swap;
        }

        /* ========================================
           VARIABLES CSS DEL LAYOUT
        ======================================== */
       :root {
    --layout-brand: linear-gradient(90deg, #8B0000 0%, #5a0000 50%, #1a0000 100%);
    --layout-brand-solid: #8B0000;
    --layout-brand-hover: rgba(255,255,255,.12);

    --layout-navbar-height: 64px;
    --layout-sidebar-width: clamp(210px, 16vw, 250px);

    --layout-txt: #fff;
    --layout-bg: #f0f2f5;
    --layout-panel: #fff;
    --layout-line: #d8dce3;
    --layout-radius: 8px;
    --layout-shadow: 0 6px 16px rgba(0,0,0,.1);

    --manual-brand: #8B0000;
    --manual-brand-light: #a50000;
    --manual-sidebar-width: clamp(220px, 17vw, 280px);

    --sidebar-font-size: clamp(10.8px, 0.72vw, 12.2px);
    --sidebar-icon-size: clamp(11.5px, 0.78vw, 13.5px);
    --sidebar-item-padding-y: clamp(5px, 0.45vw, 7px);
    --sidebar-item-padding-x: clamp(8px, 0.7vw, 11px);
    --sidebar-gap: 6px;
}

        /* ========================================
           ESTILOS GENERALES
        ======================================== */
        .layout-body {
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            font-family: "SAP72", Inter, system-ui, "Segoe UI", Roboto, Arial, sans-serif;
        }

        /* ========================================
           NAVBAR
        ======================================== */
        .layout-navbar {
            background: var(--layout-brand) !important;
            height: var(--layout-navbar-height) !important;
            position: fixed;
            top: 0; left: 0; right: 0;
            width: 100%;
            z-index: 1020;
            padding: 0 !important;
            display: flex;
            align-items: center;
        }

        .layout-navbar-container {
            width: 100%;
            height: 100%;
            padding: 0 18px !important;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        body.Operaciones.PlaneadorProduccion .layout-main-content .layout-container-fluid {
            max-width: none !important;
            background: transparent !important;
            padding: 0 !important;
            border-radius: 0 !important;
            box-shadow: none !important;
        }

        .layout-navbar-brand {
    display: flex !important;
    align-items: center !important;
    height: 100%;
    margin: 0 0 0 23px !important;
    padding: 0 !important;
    flex-shrink: 0;
    text-decoration: none !important;
    color: #fff !important;
    font-weight: 800;
}

        .layout-logo-navbar {
            display: block;
            height: 40px !important;
            width: auto !important;
            max-width: 170px !important;
            object-fit: contain;
            margin: 0 !important; padding: 0 !important;
        }

        .layout-navbar-tools {
            display: flex;
            align-items: center;
            gap: .75rem;
            flex-shrink: 0;
            margin-left: auto;
        }

        .layout-vr {
            width: 1px;
            height: 24px;
            opacity: .35;
            background-color: rgba(255,255,255,.35);
        }

        .layout-clock {
            display: flex;
            flex-direction: column;
            line-height: 1.05;
            text-align: right;
            white-space: nowrap;
            color: #fff;
        }

        .layout-clock #layout-clock-time { font-weight: 700; letter-spacing: .3px; }
        .layout-clock #layout-clock-date { font-size: .8rem; opacity: .85; }

        .layout-btn-about {
            --bs-btn-color: #fff;
            --bs-btn-border-color: rgba(255,255,255,.45);
            --bs-btn-hover-color: #fff;
            --bs-btn-hover-bg: rgba(255,255,255,.12);
            --bs-btn-hover-border-color: rgba(255,255,255,.6);
            --bs-btn-active-bg: rgba(255,255,255,.2);
        }

        /* ========================================
           SIDEBAR MEJORADO
        ======================================== */
        .layout-sidebar {
            width: var(--layout-sidebar-width);
            font-family: "Poppins", sans-serif;
            background: linear-gradient(180deg, #1a0000 0%, #0e0000 100%);
            color: var(--layout-txt);
            position: fixed;
            top: var(--layout-navbar-height);
            left: 0;
            bottom: 0;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: transform .25s ease;
            z-index: 999;
            border-right: 1px solid rgba(255,255,255,0.06);
            font-size: var(--sidebar-font-size);
        }


        /* Poppins únicamente dentro del sidebar */
        .layout-sidebar a,
        .layout-sidebar button,
        .layout-sidebar input,
        .layout-sidebar select,
        .layout-sidebar textarea {
            font-family: "Poppins", sans-serif !important;
        }

        .layout-sidebar.layout-hidden { transform: translateX(-100%); }

        .layout-sidebar-hover-zone {
            position: fixed;
            top: var(--layout-navbar-height);
            left: 0;
            width: 10px;
            height: calc(100vh - var(--layout-navbar-height));
            z-index: 998;
        }

        /* --- Cabecera usuario mejorada --- */
        .sb-user-section {
            flex-shrink: 0;
            padding: 14px 12px 10px;
            background: linear-gradient(180deg, rgba(139,0,0,0.40), rgba(139,0,0,0.12));
            border-bottom: 1px solid rgba(255,255,255,0.08);
            position: relative;
        }

        .sb-user-card {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.10);
            border-radius: 12px;
            padding: 10px 12px;
        }

        .sb-avatar {
            width: clamp(36px, 2.8vw, 44px);
            height: clamp(36px, 2.8vw, 44px);
            border-radius: 50%;
            flex-shrink: 0;
            object-fit: contain;
            border: 2px solid rgba(255,140,120,0.28);
            background: rgba(139,0,0,0.5);
        }

        .sb-user-info { flex: 1; min-width: 0; }

        .sb-user-name {
    font-size: 11.5px !important;
    font-weight: 700;
    white-space: normal !important;
    overflow: visible !important;
    text-overflow: unset !important;
    line-height: 1.1;
    display: -webkit-box !important;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}

        .sb-user-greeting {
            font-size: 9.5px !important;
            color: rgba(255,255,255,0.55);
            line-height: 1.1;
            margin-top: 1px;
            display: block;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .sb-user-status {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: #5dcaa5;
            flex-shrink: 0;
            box-shadow: 0 0 5px rgba(93,202,165,0.55);
        }

        /* --- Botón PIN --- */
        #layout-pin-btn {
            position: absolute;
            top: 8px; right: 8px;
            background: transparent;
            border: none;
            color: rgba(255,255,255,0.45);
            cursor: pointer;
            font-size: 12px;
            padding: 5px 6px;
            border-radius: 6px;
            transition: color .2s, background .2s, transform .25s;
            z-index: 10;
            line-height: 1;
        }

        #layout-pin-btn:hover { color: #fff; background: rgba(255,255,255,.12); }
        #layout-pin-btn.pinned { color: #ffd2c7 !important; transform: rotate(45deg); }

        /* --- Búsqueda --- */
        .sb-search {
            flex-shrink: 0;
            margin: 8px 10px 0;
            background: rgba(255,255,255,0.055);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 7px;
            padding: 6px 10px;
        }

        .sb-search-icon { color: rgba(255,255,255,0.30); font-size: 11px; flex-shrink: 0; }

       .sb-search-input {
    background: transparent !important;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    appearance: none;
    -webkit-appearance: none;
    font-size: clamp(11px, 0.85vw, 12.5px);
    color: rgba(255,255,255,0.7);
    width: 100%;
    font-family: inherit;
}

        .sb-search-input::placeholder { color: rgba(255,255,255,0.28); }

        /* --- Etiqueta de sección --- */
        .sb-section-label {
            font-size: clamp(9px, 0.68vw, 10px);
            font-weight: 800;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.28);
            padding: 10px 10px 4px;
            flex-shrink: 0;
        }

        /* --- Nav scrolleable --- */
        .layout-sidebar-nav {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 6px 8px;
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,0.10) transparent;
        }

        .layout-sidebar-nav::-webkit-scrollbar { width: 4px; }
        .layout-sidebar-nav::-webkit-scrollbar-track { background: transparent; }
        .layout-sidebar-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 4px; }

        /* --- Items del menú --- */
        .layout-menu-item {
            display: flex;
            flex-direction: column;
            margin-bottom: 2px;
        }

        .layout-sidebar a,
        .layout-sidebar .layout-dropdown-btn {
            color: rgba(255,255,255,0.78) !important;
            text-decoration: none !important;
            padding: var(--sidebar-item-padding-y) var(--sidebar-item-padding-x) !important;
            border-radius: 9px !important;
            display: flex !important;
            align-items: center !important;
            gap: var(--sidebar-gap) !important;
            transition: background .18s ease, border-color .18s ease !important;
            cursor: pointer !important;
            font-size: var(--sidebar-font-size) !important;
            font-weight: 700 !important;
            line-height: 1.3 !important;
            min-height: clamp(38px, 3vw, 46px);
            width: 100%;
            white-space: normal;
            word-break: break-word;
            overflow-wrap: anywhere;
            border: 1px solid transparent !important;
        }

        .layout-sidebar a:hover,
        .layout-sidebar .layout-dropdown-btn:hover {
            background: rgba(255,255,255,0.07) !important;
            border-color: rgba(255,255,255,0.08) !important;
            color: #fff !important;
        }

        .layout-sidebar a.layout-active,
        .layout-menu-item.layout-open > .layout-dropdown-btn {
            background: rgba(139,0,0,0.50) !important;
            border-color: rgba(255,100,80,0.18) !important;
            color: #fff !important;
        }

        /* Icono con fondo */
        .sb-icon-wrap {
            width: clamp(26px, 1.8vw, 30px);
            height: clamp(26px, 1.8vw, 30px);
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.08);
            flex-shrink: 0;
            transition: background .18s, border-color .18s;
        }

        .layout-sidebar a:hover .sb-icon-wrap,
        .layout-sidebar .layout-dropdown-btn:hover .sb-icon-wrap {
            background: rgba(255,255,255,0.11);
            border-color: rgba(255,255,255,0.13);
        }

        .layout-menu-item.layout-open > .layout-dropdown-btn .sb-icon-wrap,
        .layout-sidebar a.layout-active .sb-icon-wrap {
            background: rgba(139,0,0,0.65);
            border-color: rgba(255,120,100,0.25);
        }

        .layout-sidebar a i,
        .layout-sidebar .layout-dropdown-btn i {
            font-size: var(--sidebar-icon-size) !important;
            color: rgba(255,255,255,0.65);
            transition: color .18s;
            width: auto !important;
            min-width: auto !important;
            text-align: center;
        }

        .layout-sidebar a:hover i,
        .layout-sidebar .layout-dropdown-btn:hover i,
        .layout-menu-item.layout-open > .layout-dropdown-btn i,
        .layout-sidebar a.layout-active i {
            color: #ffd2c7 !important;
        }

        .sb-item-label {
            flex: 1;
            min-width: 0;
            white-space: normal;
            overflow-wrap: anywhere;
            word-break: break-word;
        }

        /* Badge */
        .sb-badge {
            background: rgba(139,0,0,0.85);
            border: 1px solid rgba(255,120,100,0.22);
            border-radius: 999px;
            padding: 1px 7px;
            font-size: clamp(9px, 0.65vw, 10px);
            font-weight: 800;
            color: #ffd2c7;
            flex-shrink: 0;
            line-height: 1.6;
        }

        .sb-badge.sb-badge-new {
            background: rgba(93,202,165,0.18);
            color: #5dcaa5;
            border-color: rgba(93,202,165,0.25);
        }

        /* Flecha */
        .layout-sidebar .layout-menu-item > .layout-dropdown-btn .layout-arrow {
            transition: transform .2s ease;
            margin-left: auto;
            font-size: clamp(9px, 0.7vw, 10px) !important;
            width: auto !important;
            min-width: auto !important;
            color: rgba(255,255,255,0.35) !important;
            flex-shrink: 0;
        }

        .layout-sidebar .layout-menu-item.layout-open > .layout-dropdown-btn .layout-arrow {
            transform: rotate(180deg);
            color: rgba(255,255,255,0.65) !important;
        }

        /* Submenú */
        .layout-dropdown-container {
            max-height: 0;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: max-height .3s ease;
            margin: 2px 0 4px 10px;
            border-left: 2px solid rgba(255,255,255,0.10);
            border-radius: 0 0 0 6px;
        }

        .layout-sidebar .layout-menu-item.layout-open > .layout-dropdown-container {
            max-height: 900px;
        }

        .layout-sidebar .layout-dropdown-container a {
            padding: clamp(7px, 0.6vw, 9px) clamp(10px, 0.9vw, 14px) clamp(7px, 0.6vw, 9px) clamp(14px, 1.1vw, 18px) !important;
            font-size: clamp(11px, 0.85vw, 13px) !important;
            font-weight: 600 !important;
            line-height: 1.3 !important;
            min-height: clamp(34px, 2.6vw, 40px);
            border-radius: 7px !important;
            color: rgba(255,255,255,0.60) !important;
            border: 1px solid transparent !important;
        }

        .layout-sidebar .layout-dropdown-container a:hover {
            background: rgba(255,255,255,0.07) !important;
            color: rgba(255,255,255,0.92) !important;
        }

        .layout-sidebar .layout-dropdown-container a i {
            color: rgba(255,255,255,0.35) !important;
        }

        .layout-sidebar .layout-dropdown-container a:hover i {
            color: #ffd2c7 !important;
        }

        /* Divisor */
        .sb-divider {
            height: 1px;
            background: rgba(255,255,255,0.06);
            margin: 4px 8px;
        }

        /* Footer logout */
        .sb-footer {
            flex-shrink: 0;
            padding: 8px 8px 10px;
            border-top: 1px solid rgba(255,255,255,0.07);
        }

        .sb-footer a {
            color: rgba(255,130,120,0.75) !important;
            background: rgba(255,50,50,0.07) !important;
            border: 1px solid rgba(255,50,50,0.10) !important;
            border-radius: 9px !important;
            padding: 9px 12px !important;
            font-weight: 700 !important;
            transition: background .18s, border-color .18s, color .18s !important;
        }

        .sb-footer a:hover {
            background: rgba(255,50,50,0.14) !important;
            border-color: rgba(255,50,50,0.20) !important;
            color: rgba(255,160,150,0.95) !important;
        }

        .sb-footer a i { color: rgba(255,130,120,0.75) !important; }
        .sb-footer a:hover i { color: rgba(255,160,150,0.95) !important; }

        /* ========================================
           BOTÓN FLOTANTE TOGGLE
        ======================================== */
        .layout-toggle-sidebar-btn {
            position: fixed;
            top: 50%; left: 0;
            transform: translateY(-50%);
            width: 28px; height: 60px;
            border: none;
            background: var(--layout-brand-solid);
            color: #fff;
            box-shadow: var(--layout-shadow);
            display: none;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 1200;
            transition: opacity .2s ease;
            border-top-right-radius: 30px;
            border-bottom-right-radius: 30px;
            opacity: .85;
        }

        .layout-toggle-sidebar-btn:hover { opacity: 1; }
        .layout-toggle-sidebar-btn i { pointer-events: none; transition: transform .2s ease; font-size: 14px; }
        .layout-sidebar.layout-hidden ~ .layout-toggle-sidebar-btn { display: flex; }

        /* ========================================
           MAIN CONTENT
        ======================================== */
        .layout-main-content {
            transition: margin-left .3s ease;
            margin-left: 0;
            padding: calc(var(--layout-navbar-height) + 20px) 20px 40px;
            background: var(--layout-bg);
            min-height: 100vh;
        }

        .layout-main-content.layout-sidebar-open {
            margin-left: var(--layout-sidebar-width);
        }

        .layout-main-content .layout-container-fluid {
            max-width: 1500px;
            margin: 0 auto;
            background: var(--layout-panel);
            border-radius: var(--layout-radius);
            padding: 1.5rem;
            box-shadow: var(--layout-shadow);
        }

        /* ========================================
           FOOTER
        ======================================== */
        .layout-footer {
            background: #f5f5f5;
            padding: 1rem 0;
            text-align: center;
            border-top: 1px solid #e0e0e0;
        }

        /* ========================================
           CHAT FLOTANTE INTERNO
        ======================================== */
        .layout-chat-fab {
            position: fixed;
            right: 24px; bottom: 24px;
            width: 56px; height: 56px;
            border-radius: 50%; border: none;
            background: radial-gradient(circle at 30% 30%, #ffefef, #8B0000);
            color: #fff;
            box-shadow: 0 10px 24px rgba(0,0,0,.25);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; z-index: 1600;
            transition: transform .15s ease, box-shadow .15s ease;
        }

        .layout-chat-fab:hover { transform: translateY(-2px); box-shadow: 0 14px 30px rgba(0,0,0,.3); }
        .layout-chat-fab i { font-size: 22px; }

        .layout-chat-panel {
            position: fixed;
            right: 24px; bottom: 90px;
            width: 360px; max-height: 520px;
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 18px 40px rgba(15,23,42,.30);
            border: 1px solid rgba(148,163,184,.6);
            display: flex; flex-direction: column;
            overflow: hidden; z-index: 1600;
        }

        .layout-chat-panel-header { padding: .6rem .8rem; background: linear-gradient(135deg, #8B0000, #5a0000); color: #fff; display: flex; align-items: center; gap: .5rem; }
        .layout-chat-panel-header .layout-chat-title { font-size: .95rem; font-weight: 700; flex: 1; line-height: 1.1; }
        .layout-chat-panel-header small { display: block; font-size: .7rem; opacity: .8; }
        .layout-chat-panel-header button { border: none; background: transparent; color: #fff; opacity: .8; }
        .layout-chat-panel-header button:hover { opacity: 1; }
        .layout-chat-panel-body { padding: .6rem .7rem .3rem; display: flex; flex-direction: column; gap: .4rem; border-bottom: 1px solid #e2e8f0; background: #f8fafc; }
        .layout-chat-area-select { display: flex; flex-direction: column; gap: .25rem; }
        .layout-chat-area-select label { font-size: .75rem; color: #64748b; font-weight: 600; text-transform: uppercase; }
        .layout-chat-area-select select { font-size: .85rem; padding: .2rem .35rem; border-radius: 6px; border: 1px solid #cbd5e1; }
        .layout-chat-hint { font-size: .72rem; color: #64748b; }
        .layout-chat-messages { flex: 1; padding: .5rem .7rem; overflow-y: auto; background: #fff; font-size: .85rem; }
        .layout-chat-msg { margin-bottom: .35rem; display: flex; }
        .layout-chat-msg.layout-me { justify-content: flex-end; }
        .layout-chat-msg .layout-bubble { max-width: 80%; padding: .35rem .55rem; border-radius: 12px; box-shadow: 0 2px 6px rgba(15,23,42,.12); }
        .layout-chat-msg.layout-me .layout-bubble { background: #8B0000; color: #fff; border-bottom-right-radius: 2px; }
        .layout-chat-msg.layout-other .layout-bubble { background: #e2e8f0; color: #111827; border-bottom-left-radius: 2px; }
        .layout-chat-msg .layout-meta { display: block; font-size: .65rem; opacity: .7; margin-top: 2px; }
        .layout-chat-input { padding: .4rem .5rem; display: flex; align-items: center; gap: .35rem; background: #f8fafc; }
        .layout-chat-input textarea { resize: none; flex: 1; border-radius: 8px; border: 1px solid #cbd5e1; padding: .3rem .4rem; font-size: .85rem; max-height: 80px; min-height: 34px; }
        .layout-chat-input button { border-radius: 999px; padding-inline: .75rem; font-size: .85rem; display: inline-flex; align-items: center; gap: .25rem; }

        #font { font-family: "Orbitron", sans-serif !important; font-optical-sizing: auto; font-style: normal; }

        /* ========================================
           MODALES — ABOUT Y REPORTE
        ======================================== */
        #layoutAboutModal.modal, #layoutAboutModal.modal * { box-sizing: border-box !important; }
        #reporteModal.modal, #reporteModal.modal * { box-sizing: border-box !important; }

        #layoutAboutModal.modal {
            display: none !important; position: fixed !important;
            top: 0 !important; left: 0 !important; right: 0 !important; bottom: 0 !important;
            z-index: 1055 !important; width: 100% !important; height: 100% !important;
            overflow-x: hidden !important; overflow-y: auto !important;
            background: transparent !important; transform: none !important;
            padding: 0 !important; margin: 0 !important; border: none !important; border-radius: 0 !important; box-shadow: none !important;
        }

        #reporteModal.modal {
            display: none !important; position: fixed !important;
            top: 0 !important; left: 0 !important; right: 0 !important; bottom: 0 !important;
