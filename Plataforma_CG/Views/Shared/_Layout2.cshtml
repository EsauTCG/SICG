            .sb-user-card {
                  padding: 7px 8px !important;
    gap: 7px !important;
                border-radius: 9px;
            }

            .sb-avatar {
                width: 28px !important;
                height: 28px !important;
            }

            .sb-user-name {
                font-size: 11.5px !important;
            }

            .sb-user-greeting {
