    <script>

        // ========================================
        // SIDEBAR — PIN + HOVER + TOGGLE
        // ========================================
        const layoutSidebar   = document.querySelector('.layout-sidebar');
        const layoutMain      = document.querySelector('.layout-main-content');
        const layoutHover     = document.querySelector('.layout-sidebar-hover-zone');
        const layoutToggleBtn = document.getElementById('layout-toggle-sidebar-btn');
        const layoutToggleIcon = layoutToggleBtn.querySelector('i');
        const layoutPinBtn    = document.getElementById('layout-pin-btn');

        let sidebarPinned = localStorage.getItem('sidebarPinned') === 'true';

        function applyPinState() {
            if (sidebarPinned) {
                layoutSidebar.classList.remove('layout-hidden');
                layoutMain.classList.add('layout-sidebar-open');
                layoutToggleIcon.classList.replace('fa-chevron-right', 'fa-chevron-left');
                layoutPinBtn.classList.add('pinned');
                layoutPinBtn.title = 'Desfijar sidebar';
            } else {
                layoutPinBtn.classList.remove('pinned');
                layoutPinBtn.title = 'Fijar sidebar';
            }
        }

        applyPinState();

        layoutPinBtn.addEventListener('click', () => {
            sidebarPinned = !sidebarPinned;
            localStorage.setItem('sidebarPinned', sidebarPinned);
            applyPinState();
        });

        // layoutHover.addEventListener('mouseenter', () => {
        //     if (sidebarPinned) return;
        //     layoutSidebar.classList.remove('layout-hidden');
        //     layoutMain.classList.add('layout-sidebar-open');
        //     layoutToggleIcon.classList.replace('fa-chevron-right', 'fa-chevron-left');
        // });

        layoutSidebar.addEventListener('mouseleave', () => {
            if (sidebarPinned) return;
            layoutSidebar.classList.add('layout-hidden');
            layoutMain.classList.remove('layout-sidebar-open');
            layoutToggleIcon.classList.replace('fa-chevron-left', 'fa-chevron-right');
        });

        layoutToggleBtn.addEventListener('click', () => {
            if (sidebarPinned) return;
            layoutSidebar.classList.remove('layout-hidden');
            layoutMain.classList.add('layout-sidebar-open');
            layoutToggleIcon.classList.replace('fa-chevron-right', 'fa-chevron-left');
        });

        // ========================================
        // RELOJ
        // ========================================
        (function initLayoutLiveClock() {
            const elTime = document.getElementById('layout-clock-time');
            const elDate = document.getElementById('layout-clock-date');
            if (!elTime || !elDate) return;
            function tick() {
                const now = new Date();
                elTime.textContent = new Intl.DateTimeFormat('es-MX', { hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:true, timeZone:'America/Mexico_City' }).format(now);
                elDate.textContent = new Intl.DateTimeFormat('es-MX', { weekday:'short', year:'numeric', month:'short', day:'2-digit', timeZone:'America/Mexico_City' }).format(now);
            }
            tick();
            setInterval(tick, 1000);
        })();

        // ========================================
        // SALUDO DINÁMICO
        // ========================================
        (function initDynamicGreeting() {
            const greetingEl = document.getElementById('dynamic-greeting');
            const messageEl  = document.getElementById('dynamic-message');
            if (!greetingEl || !messageEl) return;
            const hora = new Date().getHours();
            const saludo = hora >= 5 && hora < 12 ? 'Buenos días' : hora >= 12 && hora < 19 ? 'Buenas tardes' : 'Buenas noches';
            const msgs = hora >= 5 && hora < 12
                ? ['¡Que tengas un excelente día!','¡Mucho éxito hoy!','¡Listo para conquistar el día!','¡A darle con todo!']
                : hora >= 12 && hora < 19
                ? ['¡Sigue así!','¡Vas muy bien!','¡Ánimo con la tarde!','¡A terminar fuerte!']
                : ['¡Buen trabajo hoy!','¡A descansar!','¡Casi terminas!','¡Gran esfuerzo!'];
            greetingEl.textContent = saludo;
            messageEl.textContent  = msgs[Math.floor(Math.random() * msgs.length)];
