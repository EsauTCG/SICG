@model Plataforma_CG.Models.LoginViewModel
@{
    ViewData["Title"] = "Inicio";
    Layout = null; // ✅ ya no usa _Layout (no sale la barra)
}

<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] - SIGO</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        html, body {
            height: 100%;
        }

        body {
            margin: 0;
        }

        /* HERO FULL */
        .cg-hero {
            height: 100vh;
            min-height: 100svh;
            position: relative;
            display: flex;
            flex-direction: column;
            background: #e7e8ea;
            overflow: hidden;
            font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        }

            .cg-hero::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(1200px 700px at 0% 40%, rgba(250, 148, 122, .55), rgba(250, 148, 122, 0) 55%), radial-gradient(900px 520px at 35% 35%, rgba(255,255,255,.45), rgba(255,255,255,0) 60%), linear-gradient(90deg, rgba(252, 160, 135, .55) 0%, rgba(231,232,234,1) 42%, rgba(231,232,234,1) 100%);
                z-index: 0;
            }

            .cg-hero::after {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(180deg, rgba(255,255,255,.16), rgba(255,255,255,0));
                z-index: 0;
                pointer-events: none;
            }

        /* Header flotante (sin franja) */
        .cg-topnav {
            position: absolute;
            top: 16px;
            left: 0;
            right: 0;
            z-index: 3;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 26px;
            gap: 18px;
        }

        .cg-logo-wrap {
            display: flex;
            align-items: center;
            text-decoration: none;
            user-select: none;
        }

        .cg-logo {
            height: 44px;
            width: auto;
            filter: drop-shadow(0 10px 18px rgba(0,0,0,.18));
        }

        .cg-navlinks {
            display: flex;
            gap: 18px;
            justify-content: center;
            flex: 1;
        }

            .cg-navlinks a {
                text-decoration: none;
                color: rgba(0,0,0,.60);
                font-weight: 800;
                font-size: .95rem;
            }

                .cg-navlinks a:hover {
                    color: rgba(0,0,0,.82);
                }

        .cg-login-pill {
            border: 0;
            border-radius: 999px;
            padding: 10px 16px;
            font-weight: 900;
            background: rgba(255,255,255,.72);
            color: rgba(0,0,0,.78);
            border: 1px solid rgba(0,0,0,.08);
            backdrop-filter: blur(10px);
            box-shadow: 0 14px 34px rgba(0,0,0,.12);
            cursor: pointer;
            transition: transform .15s ease, background .15s ease;
            white-space: nowrap;
        }

            .cg-login-pill:hover {
                background: rgba(255,255,255,.88);
            }

            .cg-login-pill:active {
                transform: translateY(1px);
            }

        /* Stage layout */
        .cg-stage {
            position: relative;
            z-index: 2;
            flex: 1;
            display: grid;
            grid-template-columns: 1.1fr 1.35fr;
            align-items: center;
            gap: 20px;
            padding: 90px 60px 70px;
        }

        /* Copy */
        .cg-copy {
            max-width: 560px;
            padding-left: 10px;
        }

        .cg-kicker {
            font-weight: 900;
            letter-spacing: .18em;
            font-size: .78rem;
            text-transform: uppercase;
            color: rgba(0,0,0,.55);
            margin-bottom: 16px;
        }

        .cg-title {
            font-family: ui-serif, Georgia, "Times New Roman", Times, serif;
            font-weight: 400;
            font-size: clamp(2.4rem, 5.2vw, 5.2rem);
            line-height: .95;
            letter-spacing: .01em;
            margin: 0 0 14px;
            color: rgba(0,0,0,.82);
            text-transform: uppercase;
        }

        .cg-price {
            font-family: ui-serif, Georgia, "Times New Roman", Times, serif;
            font-size: clamp(1.8rem, 2.4vw, 2.4rem);
            color: rgba(0,0,0,.65);
            margin-bottom: 14px;
        }

        .cg-desc {
            max-width: 52ch;
            color: rgba(0,0,0,.58);
            font-weight: 600;
            font-size: 1rem;
            line-height: 1.55;
            margin: 0 0 22px;
        }

        .cg-btn {
            border: 0;
            border-radius: 999px;
            padding: 12px 18px;
            font-weight: 900;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: transform .18s ease, filter .18s ease, box-shadow .18s ease, background .18s ease;
            user-select: none;
        }

            .cg-btn:active {
                transform: translateY(1px);
            }

        .cg-btn-primary {
            background: rgba(19, 115, 90, .92);
            color: #fff;
            box-shadow: 0 10px 24px rgba(0,0,0,.14);
        }

            .cg-btn-primary:hover {
                filter: brightness(1.05);
                color: #fff;
            }

        /* Visual */
        .cg-visual {
            position: relative;
            height: 100%;
            min-height: 520px;
            display: grid;
            align-items: center;
            justify-items: end;
            padding-right: 10px;
        }

        .cg-glow {
            position: absolute;
            right: 120px;
            top: 50%;
            transform: translateY(-50%);
            width: 560px;
            height: 560px;
            background: radial-gradient(circle at 40% 40%, rgba(255,255,255,.55), rgba(255,255,255,0) 65%);
            z-index: 0;
            pointer-events: none;
        }

        .cg-product-wrap {
            position: relative;
            width: min(860px, 100%);
            height: 520px;
            z-index: 1;
        }

        .cg-img {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            height: 520px;
            width: auto;
            object-fit: contain;
            filter: drop-shadow(0 24px 40px rgba(0,0,0,.20));
            transition: opacity .35s ease, transform .55s ease;
            will-change: transform, opacity;
        }

        .cg-img-main {
            right: 170px;
            z-index: 2;
            opacity: 1;
        }

        .cg-img-next {
            right: -140px;
            z-index: 1;
            opacity: .95;
            filter: drop-shadow(0 20px 34px rgba(0,0,0,.18));
            transform: translateY(-50%) scale(.96);
        }

        .cg-caption {
            position: absolute;
            bottom: 46px;
            right: 200px;
            z-index: 2;
            font-weight: 900;
            letter-spacing: .14em;
            text-transform: uppercase;
            font-size: .78rem;
            color: rgba(0,0,0,.55);
            text-align: center;
            width: 320px;
            pointer-events: none;
        }

        /* Controls bottom */
        .cg-controls {
            position: absolute;
            left: 50%;
            bottom: 20px;
            transform: translateX(-50%);
            z-index: 3;
            display: flex;
            align-items: center;
            gap: 14px;
            background: rgba(255,255,255,.35);
            border: 1px solid rgba(0,0,0,.08);
            backdrop-filter: blur(10px);
            border-radius: 999px;
            padding: 10px 14px;
            box-shadow: 0 14px 34px rgba(0,0,0,.10);
        }

        .cg-arrow {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            border: 1px solid rgba(0,0,0,.10);
            background: rgba(255,255,255,.55);
            font-size: 1.6rem;
            line-height: 1;
            display: grid;
            place-items: center;
            cursor: pointer;
            user-select: none;
        }

            .cg-arrow:hover {
                background: rgba(255,255,255,.75);
            }

        .cg-dots {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .cg-dot {
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: rgba(0,0,0,.22);
            border: 0;
            cursor: pointer;
        }

            .cg-dot.active {
                background: rgba(0,0,0,.55);
                transform: scale(1.25);
            }

        .cg-out {
            opacity: 0;
            transform: translateY(-50%) translateX(-20px);
        }

        .cg-in {
            opacity: 1;
            transform: translateY(-50%) translateX(0);
        }

        /* Modal (glass) */
        .cg-modal {
            border-radius: 18px;
            border: 1px solid rgba(255,255,255,.25);
            background: rgba(255,255,255,.78);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            overflow: hidden;
        }

        .cg-login {
            display: flex;
            flex-wrap: wrap;
        }

        .cg-login-left {
            flex: 1 1 45%;
            min-height: 340px;
            position: relative;
            background: linear-gradient(180deg, rgba(139,0,0,.95), rgba(74,0,0,.95));
            overflow: hidden;
        }

            .cg-login-left::before {
                content: "";
                position: absolute;
                inset: 0;
                background: url('@Url.Content("~/images/sigo-anim.webp")') center/cover no-repeat;
                opacity: .20;
                filter: saturate(1.1) contrast(1.05);
            }

            .cg-login-left::after {
                content: "";
                position: absolute;
                inset: 0;
                background: url('@Url.Content("~/images/logo_sigo_cg2_1.png")') center/contain no-repeat;
                opacity: .55;
            }

        .cg-social {
            position: absolute;
            left: 18px;
            bottom: 18px;
            display: flex;
            gap: 14px;
            z-index: 2;
        }

            .cg-social a {
                color: #fff;
                font-size: 1.3rem;
                opacity: .92;
            }

        .cg-login-right {
            flex: 1 1 55%;
            padding: 36px 34px;
            background: rgba(255,255,255,.90);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }

        .cg-login-logo {
            width: 72px;
            height: 72px;
            display: block;
            margin: 0 auto 12px;
        }

        .cg-login-right .input-group-text {
            background: #000;
            border: none;
            color: #fff;
        }

        .cg-login-btn {
            background: linear-gradient(90deg, #000, #6f0000);
            border: none;
            color: #fff;
            font-weight: 900;
            padding: .65rem;
            box-shadow: 0 10px 24px rgba(0,0,0,.14);
        }

        @@media (max-width: 1100px) {
            .cg-stage {
                grid-template-columns: 1fr;
                padding: 90px 22px 80px;
            }

            .cg-visual {
                justify-items: center;
                padding-right: 0;
                min-height: 440px;
            }

            .cg-product-wrap {
                height: 440px;
            }

            .cg-img {
                height: 440px;
            }

            .cg-img-main {
                right: 50%;
                transform: translate(50%, -50%);
            }

            .cg-img-next {
                right: -110px;
            }

            .cg-caption {
                right: 50%;
                transform: translateX(50%);
            }
        }
        @@media (max-width: 576px) {
            .cg-navlinks {
                display: none;
            }

            .cg-logo {
                height: 38px;
            }

            .cg-product-wrap {
                height: 360px;
            }

            .cg-img {
                height: 360px;
            }

            .cg-img-next {
                display: none;
            }
        }
    </style>
</head>

<body>
    <section class="cg-hero">

        <header class="cg-topnav">
            <a class="cg-logo-wrap" href="@Url.Action("Index", "Home")" aria-label="SIGO">
                <img class="cg-logo" src="@Url.Content("~/images/logo_sigo_cg2_1.png")" alt="SIGO">
            </a>

            <nav class="cg-navlinks">
                <a href="@Url.Action("Index", "Home")">Inicio</a>
                <a href="#menu">Menú</a>
                <a href="@Url.Action("Nosotros", "Home")">About</a>
            </nav>

            <button class="cg-login-pill" type="button" id="btnOpenLogin">
                <i class="fas fa-user me-2"></i> Iniciar Sesión
            </button>
        </header>

        <div class="cg-stage">
            <div class="cg-copy">
                <div class="cg-kicker" id="kicker">PRODUCTO DESTACADO</div>
                <h1 class="cg-title" id="title">Cortes Premium</h1>
                <div class="cg-price" id="price">$ 20</div>
                <p class="cg-desc" id="desc">Calidad, trazabilidad y confianza en cada entrega.</p>

                <a class="cg-btn cg-btn-primary" id="ctaLink" href="@Url.Action("Index", "Home")">Ver más</a>
            </div>

            <div class="cg-visual">
                <div class="cg-glow" aria-hidden="true"></div>

                <div class="cg-product-wrap">
                    <img id="imgMain" class="cg-img cg-img-main"
                         src="@Url.Content("~/images/produccion.png")"
                         alt="Producto principal" loading="lazy" decoding="async" />

                    <img id="imgNext" class="cg-img cg-img-next"
                         src="@Url.Content("~/images/banner-cow.jpg")"
                         alt="Siguiente producto" loading="lazy" decoding="async" />
                </div>

                <div class="cg-caption" id="caption">CORTES PREMIUM, NUEVO PRODUCTO</div>
            </div>
        </div>

        <div class="cg-controls">
            <button class="cg-arrow" id="btnPrev" type="button" aria-label="Anterior">‹</button>
            <div class="cg-dots" id="dots" aria-label="Indicadores"></div>
            <button class="cg-arrow" id="btnNext" type="button" aria-label="Siguiente">›</button>
        </div>
    </section>

    <!-- Modal Login -->
    <div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content cg-modal">
                <div class="modal-body p-0">
                    <div class="cg-login">
                        <div class="cg-login-left">
                            <div class="cg-social">
                                <a href="https://www.youtube.com/watch?v=VTn435mJVw8" target="_blank" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                                <a href="https://www.instagram.com/carnesg.mx/" target="_blank" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                                <a href="https://www.facebook.com/Carnesg.mx" target="_blank" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                            </div>
                        </div>

                        <div class="cg-login-right">
                            <img src="https://cdn-icons-png.flaticon.com/512/709/709722.png" alt="Logo" class="cg-login-logo" />
                            <h3 class="text-center mb-3" id="loginModalLabel">Bienvenido(a)</h3>

                            <form id="loginForm">
                                <input type="hidden" name="ReturnUrl" value="@ViewBag.ReturnUrl" />

                                <div class="mb-3 input-group">
                                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                                    <input type="text" name="Usuario" class="form-control" placeholder="Usuario o correo electrónico" autocomplete="username" required />
                                </div>

                                <div class="mb-3 input-group">
                                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                    <input type="password" name="Password" class="form-control" placeholder="Contraseña" autocomplete="current-password" required />
                                </div>

                                <div id="loginError" class="alert alert-danger d-none"></div>

                                <button type="submit" class="btn cg-login-btn w-100 mb-2">
                                    <i class="fas fa-sign-in-alt me-2"></i> Iniciar Sesión
                                </button>
                            </form>

                            <p class="small text-center mb-0">¿No tienes cuenta? <a href="@Url.Action("Registrar", "Acceso")">Regístrate aquí</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- JS -->
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/js/all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            const slides = [
                {
                    kicker: "PRODUCTO DESTACADO",
                    title: "Cortes Premium",
                    price: "$ 20",
                    desc: "Calidad, trazabilidad y confianza en cada entrega.",
                    caption: "CORTES PREMIUM, NUEVO PRODUCTO",
                    mainImg: "@Url.Content("~/images/produccion.png")",
                    nextImg: "@Url.Content("~/images/banner-cow.jpg")",
                    ctaText: "Ver más",
                    ctaHref: "@Url.Action("Index", "Home")"
                },
                {
                    kicker: "PRODUCCIÓN",
                    title: "Proceso Riguroso",
                    price: "$ 35",
                    desc: "Cumplimos estrictos controles de higiene y calidad en cada etapa.",
                    caption: "PRODUCCIÓN RIGUROSA, CONTROL TOTAL",
                    mainImg: "@Url.Content("~/images/banner-cow.jpg")",
                    nextImg: "@Url.Content("~/images/distribucion.jpg")",
                    ctaText: "Conócenos",
                    ctaHref: "@Url.Action("Nosotros", "Home")"
                },
                {
                    kicker: "LOGÍSTICA",
                    title: "Distribución",
                    price: "$ 18",
                    desc: "Servicio rápido y seguro a nivel nacional, con trazabilidad de entrega.",
                    caption: "DISTRIBUCIÓN, COBERTURA NACIONAL",
                    mainImg: "@Url.Content("~/images/distribucion.jpg")",
                    nextImg: "@Url.Content("~/images/produccion.png")",
                    ctaText: "Ver cobertura",
                    ctaHref: "@Url.Action("Index", "Home")"
                }
            ];

            let idx = 0;
            let timer = null;
            const AUTOPLAY_MS = 6500;

            const elK = document.getElementById("kicker");
            const elT = document.getElementById("title");
            const elP = document.getElementById("price");
            const elD = document.getElementById("desc");
            const elC = document.getElementById("caption");
            const imgMain = document.getElementById("imgMain");
            const imgNext = document.getElementById("imgNext");
            const ctaLink = document.getElementById("ctaLink");

            const btnPrev = document.getElementById("btnPrev");
            const btnNext = document.getElementById("btnNext");
            const dots = document.getElementById("dots");

            function buildDots() {
                dots.innerHTML = "";
                slides.forEach((_, i) => {
                    const b = document.createElement("button");
                    b.className = "cg-dot" + (i === idx ? " active" : "");
                    b.type = "button";
                    b.addEventListener("click", () => go(i));
                    dots.appendChild(b);
                });
            }

            function setActiveDot() {
                dots.querySelectorAll(".cg-dot").forEach((d, i) => d.classList.toggle("active", i === idx));
            }

            function render(i) {
                const s = slides[i];
                elK.textContent = s.kicker;
                elT.textContent = s.title;
                elP.textContent = s.price;
                elD.textContent = s.desc;
                elC.textContent = s.caption;
                ctaLink.textContent = s.ctaText;
                ctaLink.href = s.ctaHref;

                imgMain.classList.add("cg-out");
                imgNext.classList.add("cg-out");

                setTimeout(() => {
                    imgMain.src = s.mainImg;
                    imgNext.src = s.nextImg;

                    imgMain.classList.remove("cg-out");
                    imgNext.classList.remove("cg-out");
                    imgMain.classList.add("cg-in");
                    imgNext.classList.add("cg-in");

                    setTimeout(() => {
                        imgMain.classList.remove("cg-in");
                        imgNext.classList.remove("cg-in");
                    }, 380);
                }, 160);

                setActiveDot();
            }

            function go(newIdx) {
                idx = (newIdx + slides.length) % slides.length;
                render(idx);
                restart();
            }
            function next() { go(idx + 1); }
            function prev() { go(idx - 1); }

            function start() { stop(); timer = setInterval(next, AUTOPLAY_MS); }
            function stop() { if (timer) clearInterval(timer); timer = null; }
            function restart() { start(); }

            btnNext.addEventListener("click", next);
            btnPrev.addEventListener("click", prev);

            buildDots();
            render(idx);
            start();

            // ✅ Modal abrir
            const btnOpen = document.getElementById("btnOpenLogin");
            const modalEl = document.getElementById("loginModal");
            if (btnOpen && modalEl && window.bootstrap && bootstrap.Modal) {
                btnOpen.addEventListener("click", () => bootstrap.Modal.getOrCreateInstance(modalEl).show());
            }

            // ✅ Login Ajax
            const formEl = document.getElementById("loginForm");
            if (formEl) {
                formEl.addEventListener("submit", function (e) {
                    e.preventDefault();

                    const form = e.target;
                    const data = { Usuario: form.Usuario.value, Password: form.Password.value };

                    let url = '@Url.Action("Login", "Acceso")';
                    fetch(url, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(data)
                    })
                    .then(r => r.json())
                    .then(res => {
                        const errorBox = document.getElementById("loginError");
                        if (res.success) window.location.href = res.redirectUrl;
                        else {
                            errorBox.textContent = res.message || "Usuario o contraseña incorrectos.";
                            errorBox.classList.remove("d-none");
                        }
                    })
                    .catch(() => {
                        const errorBox = document.getElementById("loginError");
                        errorBox.textContent = "Error inesperado al intentar iniciar sesión.";
                        errorBox.classList.remove("d-none");
                    });
                });
            }
        })();
    </script>
</body>
</html>
