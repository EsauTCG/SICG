function validarSKUsCapturados(mostrarMensaje = true) {
    const malas = [];

    $("#productosBody tr").each(function (i) {
        const $row = $(this);

        const $productoInput = $row.find(".productoInput");
        const texto = ($productoInput.val() || "").trim();
        const codigo = ($row.find(".productoCodigo").val() || "").trim();

        const peso = parseFloat($row.find(".peso").val()) || 0;
        const cajas = parseFloat($row.find(".cajas").val()) || 0;
        const precio = parseFloat($row.find(".precio").val()) || 0;

        limpiarMarcaSkuInvalido($row);

        const tieneCaptura = texto || codigo || peso > 0 || cajas > 0 || precio > 0;

        if (tieneCaptura && !codigo) {
            malas.push(i + 1);
            marcarSkuInvalido($row, "SKU no válido. Selecciona un producto existente desde la lista.");
        }
    });

    if (malas.length) {
        const msg = `Hay productos sin SKU válido en las filas: ${malas.join(", ")}.\n\nSelecciona el producto desde la lista de búsqueda.`;

        if (mostrarMensaje) {
            if (typeof showToast === "function") {
                showToast(msg, "warning", 8000);
            } else {
                alert(msg);
            }
        }

        const first = $("#productosBody tr.sku-invalido .productoInput").first();
        if (first.length) first.focus();

        return false;
    }

    return true;
}

