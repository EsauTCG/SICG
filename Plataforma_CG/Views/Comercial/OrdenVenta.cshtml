        // Totales tabla - versión ligera para mobile.
        // Importante: aquí NO se renombran inputs; eso se hace en actualizarIndices()
        // solo cuando agregas/elimininas filas o antes de guardar.
        function actualizarTotales() {
        const tbody = document.getElementById('productosBody');
        if (!tbody) return;

        let totalPeso = 0;
        let totalImporte = 0;

        for (let i = 0; i < tbody.rows.length; i++) {
        const row = tbody.rows[i];
        const pesoInput = row.querySelector('input[name$=".Peso"], .peso');
        const precioInput = row.querySelector('input[name$=".Precio"], .precio');
        const subtotalInput = row.querySelector('.subtotal');

        const peso = parseFloat(pesoInput?.value) || 0;
        const precio = parseFloat(precioInput?.value) || 0;
        const subtotal = peso * precio;

        if (subtotalInput) subtotalInput.value = fmt(subtotal);

        totalPeso += peso;
        totalImporte += subtotal;

        if (row.cells && row.cells[0]) row.cells[0].textContent = i + 1;
        }

        const totalPesoEl = document.getElementById('totalPeso');
        const totalImporteEl = document.getElementById('totalImporte');
        if (totalPesoEl) totalPesoEl.textContent = totalPeso.toFixed(2);
        if (totalImporteEl) totalImporteEl.textContent = '$' + fmt(totalImporte);
        }

        let ovTotalesRaf = null;
        function scheduleActualizarTotales() {
        if (ovTotalesRaf) return;

        ovTotalesRaf = requestAnimationFrame(function () {
        ovTotalesRaf = null;
        actualizarTotales();
        });
        }

        document.addEventListener('input', function (e) {
        if (e.target.matches('input[name$=".Peso"], input[name$=".Precio"], .peso, .precio, .cajas')) {
        scheduleActualizarTotales();
        }
        }, { passive: true });
        document.addEventListener('DOMContentLoaded', () => {
        $('.productoInput').each(function () { initProductoAutocomplete(this); });
        actualizarTotales();
        lastFechaEntrega = $('#FechaEntrega').val() || null;
        setHeadersPresupuesto();
        toggleColumnasPresupuesto();
        });

        // ==========================
        // Carga masiva por textarea SKU
        // ==========================
        let articuloIndex = $('#productosBody tr').length;

        function _forceBackdropCleanup() {
        setTimeout(() => {
        $('.modal-backdrop').remove();
        $('body').removeClass('modal-open').css('padding-right', '');
        }, 50);
        }

        function fixScroll() {
        $('body').removeClass('modal-open').css({
        overflow: '',
