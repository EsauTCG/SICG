        $('#btnAgregarArticulos').off('click').on('click', function () {
        const $modalEl = $('#modalCargaMasiva');
        const modal = bootstrap.Modal.getInstance($modalEl[0]);

        const btnText = $('#btnText');
        const btnSpinner = $('#btnSpinner');

        $modalEl.one('hidden.bs.modal', async () => {
