        function renderPaginacion(total, page, pageSize) {
        total = Number(total || 0);
        page = Number(page || 1);
        pageSize = Number(pageSize || 25);

        const totalPages = Math.max(1, Math.ceil(total / pageSize));
        const prevDis = page <= 1 ? "disabled" : "";
        const nextDis = page >= totalPages ? "disabled" : "";

        $("#clPaginacion").html(`
        <div class="d-flex align-items-center gap-2">
        <button class="btn btn-sm btn-outline-secondary" id="clPrev" ${prevDis}>
        <i class="bi bi-chevron-left"></i>
        </button>
        <span>Página <b>${page}</b> de <b>${totalPages}</b> — <span class="text-muted">${total} resultado(s)</span></span>
        <button class="btn btn-sm btn-outline-secondary" id="clNext" ${nextDis}>
        <i class="bi bi-chevron-right"></i>
        </button>
        </div>
        `);

        $("#clPrev").off("click").on("click", () => {
        if (clState.page > 1) {
        clState.page--;
        cargarClientesModal();
        }
        });

        $("#clNext").off("click").on("click", () => {
        const tp = Math.max(1, Math.ceil(clState.total / clState.pageSize));
        if (clState.page < tp) {
        clState.page++;
        cargarClientesModal();
        }
        });
        }

        async function cargarClientesModal() {
