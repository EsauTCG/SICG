        async function cargarArticulosMasivosProtected(myToken) {
        const cardCode = $("#clienteHidden").val();
        if (!cardCode) { alert("Selecciona un cliente primero."); return; }

        window.modoCargaMasiva = true;
        try {
        if (typeof limpiarFilasVacias === 'function') limpiarFilasVacias();

        const codigos = [...new Set(
        $("#articulosMasivos").val()
        .trim().toUpperCase()
        .split(/\r?\n/)
        .map(c => c.trim())
        .filter(c => c !== "")
        )];

        if (codigos.length === 0) { alert("No hay SKUs para agregar."); return; }

        const promesas = codigos.map(code =>
        $.getJSON('/Comercial/ObtenerPrecioArticuloCliente', { cardCode, itemCode: code }).catch(_ => null)
        );
        const productos = (await Promise.all(promesas)).filter(p => p && p.itemCode);

        const omitidos = [];
        for (const p of productos) {
        if (myToken !== loadToken) return;
        if (existeSKU(p.itemCode)) { omitidos.push(normCode(p.itemCode)); continue; }
        await agregarFilaArticuloConPresupuesto(p, cardCode); // bloquea si no hay presupuesto (solo si aplica)
        }

        if (typeof limpiarFilasVacias === 'function') limpiarFilasVacias();
        actualizarTotales();

        if (omitidos.length > 0) {
        if (typeof showToast === 'function') {
        showToast(`Estos SKUs ya estaban agregados y se omitieron:\n${omitidos.join(', ')}`, 'warning', 7000);
        } else {
        alert(`Estos SKUs ya estaban agregados y se omitieron:\n\n${omitidos.join(', ')}`);
        }
        }

        $("#articulosMasivos").val("");
        } finally {
        window.modoCargaMasiva = false;
        }
        }

        // ✅ ESTA FUNCIÓN AHORA BLOQUEA/OMITE SKUs SIN PRESUPUESTO (solo si aplica) y REGRESA LA FILA o null
        async function agregarFilaArticuloConPresupuesto(producto, cardCode) {
        const codigoUpper = normCode(producto.itemCode);
        if (!codigoUpper) return null;
        if (existeSKU(codigoUpper)) return null;

        const fechaEntrega = $("#FechaEntrega").val();
        if (!fechaEntrega) {
        showToast("Selecciona Fecha de entrega antes de cargar productos.", "warning", 6500);
        return null;
        }

        let presVal = 0;
        const owner = getOwnerForPresupuesto();

        if (clienteRequierePresupuesto()) {
        // Validar presupuesto antes de insertar.
        // Si el cliente requiere presupuesto, el filtro sigue activo.
        const [anioStr, mesStr] = fechaEntrega.split("-");
        const anioN = parseInt(anioStr, 10);
        const mesN = parseInt(mesStr, 10);

        let presObj = null;
        try {
        presObj = await obtenerPresupuestoProducto(owner, cardCode, codigoUpper, mesN, anioN);
        } catch (_) { presObj = null; }

        presVal = presupuestoAsignadoDe(presObj);

        if (presVal <= 0) {
        showToast(`SKU ${codigoUpper} omitido: no tiene presupuesto asignado (${owner.label}).`, "warning", 7000);
        return null;
        }

        }

        const tbody = $('#productosBody');
        const $row = $('<tr data-origen="servidor"></tr>');

        const precio = producto.precio || 0;
        const kilosCaja = producto.kilosCaja || 1;
        $row.data('kilosCaja', kilosCaja);

        const sku = codigoUpper;
        const nombreRaw = (producto.itemName || "").toString().toUpperCase();
        const nombreLimpio = nombreRaw.replace(new RegExp(`\\s*\\(${sku}\\)\\s*$`, "i"), "").trim();
        const nombreConcatenado = `${sku} - ${nombreLimpio}`;

        $row.html(`
        <td>${articuloIndex + 1}</td>
        <td>
        <input type="hidden" name="Productos[${articuloIndex}].ProductoCodigo" class="productoCodigo" value="${sku}" />
        <input type="hidden" name="Productos[${articuloIndex}].ProductoNombre" value="${nombreLimpio}" />
        ${nombreConcatenado}
        </td>
        <td><input name="Productos[${articuloIndex}].Presupuesto" class="form-control presupuesto" type="text" step="0.01" value="${Number(presVal).toFixed(2)}" readonly /></td>
        <td><input name="Productos[${articuloIndex}].VariacionPresupuesto" class="form-control variacionPresupuesto" type="text" step="0.01" value="0" readonly /></td>
        <td><input name="Productos[${articuloIndex}].Peso" class="form-control peso" type="number" step="0.01" value="${Number(kilosCaja).toFixed(2)}" /></td>
        <td><input name="Productos[${articuloIndex}].Precio" class="form-control precio" type="number" step="0.01" value="${Number(precio).toFixed(2)}" /></td>
        <td><input name="Productos[${articuloIndex}].Cajas" class="form-control cajas" type="number" min="0"  step="1" value="1" /></td>
        <td><input class="form-control subtotal" type="text" value="${(Number(precio) * Number(kilosCaja)).toFixed(2)}" readonly /></td>
        <td><button type="button" class="btn btn-sm btn-info btn-inventario" data-codigo="${producto.itemCode || ""}" data-nombre="${(producto.itemName || "").toUpperCase()}"><i class="bi bi-boxes me-1"></i> Ver</button></td>
        <td><a href="#" class="action-link ov-delete-link" onclick="eliminarProducto(this); return false;"><i class="bi bi-trash"></i></a></td>
        `);

        tbody.append($row);

        const $inputVariacion = $row.find('.variacionPresupuesto');
        if (!aplicaPresupuesto()) {
        $inputVariacion.val("0.00").data("base", 0);
        $row.removeClass("table-danger");
        } else {
        try {
        const map = await getDisponiblesMap(owner, cardCode, fechaEntrega);
        const disp = parseFloat(map[codigoUpper]?.presupuestoDisponible ?? 0);
        $inputVariacion.val(disp.toFixed(2)).data("base", disp);
        } catch {
        $inputVariacion.val("0.00").data("base", 0);
        }
        }

        $row.find('.peso').on('input', function () {
        const r = $(this).closest('tr');
        const peso = parseFloat($(this).val()) || 0;
        const precioAct = parseFloat(r.find('.precio').val()) || 0;
        const kx = parseFloat(r.data('kilosCaja')) || 1;

        r.find('.cajas').val((peso / kx).toFixed(0));
        r.find('.subtotal').val((peso * precioAct).toFixed(2));
        actualizarTotales();
        recalcularDisponibleFila(r);
        });

        $row.find('.cajas').on('input', function () {
        const r = $(this).closest('tr');
        const cajas = parseFloat($(this).val()) || 0;
        const precioAct = parseFloat(r.find('.precio').val()) || 0;
        const kx = parseFloat(r.data('kilosCaja')) || 1;

        r.find('.peso').val((cajas * kx).toFixed(2));
        r.find('.subtotal').val((cajas * kx * precioAct).toFixed(2));
        actualizarTotales();
        recalcularDisponibleFila(r);
