}

@@media (max-width: 1200px) {
    .ov-steps {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .module-titlebar.ov-hero {
        align-items: stretch !important;
    }

    .toolbar.ov-hero-actions {
        justify-content: flex-start !important;
    }
}

