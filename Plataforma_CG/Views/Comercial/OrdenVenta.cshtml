        function wireCajasPeso(row) {
        const $row = $(row);
        const $peso = $row.find('.peso');
        const $cajas = $row.find('.cajas');
        const $precio = $row.find('.precio');
        const $sub = $row.find('.subtotal');

        $peso.off('input.wcp').on('input.wcp', function () {
        const kx = parseFloat($row.data('kilosCaja')) || 1;
        const peso = parseFloat($peso.val()) || 0;
        const precio = parseFloat($precio.val()) || 0;

        $cajas.val((kx ? (peso / kx) : 0).toFixed(0));
        $sub.val((peso * precio).toFixed(2));
        actualizarTotales();

        recalcularDisponibleFila($row); // ✅ AQUI
        });

        $cajas.off('input.wcp').on('input.wcp', function () {
        const kx = parseFloat($row.data('kilosCaja')) || 1;
        const cajas = parseFloat($cajas.val()) || 0;
        const precio = parseFloat($precio.val()) || 0;

        const peso = cajas * kx;
        $peso.val(peso.toFixed(2));
        $sub.val((peso * precio).toFixed(2));
        actualizarTotales();

        recalcularDisponibleFila($row); // ✅ AQUI
        });

        $precio.off('input.wcp').on('input.wcp', function () {
        const peso = parseFloat($peso.val()) || 0;
        const precio = parseFloat($precio.val()) || 0;
        $sub.val((peso * precio).toFixed(2));
        actualizarTotales();
        });
        }


