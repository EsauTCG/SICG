        function getOwnerForPresupuesto() {
        const mode = presupuestoMode();

        // Si el usuario eligió "Cliente", normal
        if (mode === "cli") {
        return { mode, id: ($("#clienteHidden").val() || ""), label: "Cliente" };
        }

        // Si es "Vendedor" pero NO hay vendedorId (cliente sin canal),
        // hacemos fallback automático a Cliente para que todo cargue.
        const vendId = ($("#VendedorId").val() || "").toString().trim();
        if (!vendId) {
        const card = ($("#clienteHidden").val() || "");
        return { mode: "cli", id: card, label: "Cliente" };
        }

        return { mode: "vend", id: vendId, label: "Vendedor" };
        }
