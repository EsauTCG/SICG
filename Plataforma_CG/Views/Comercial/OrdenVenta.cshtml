        function filasConPrecioCero() {
        const malas = [];
        $("#productosBody tr").each(function (i) {
        const $row = $(this);
        const codigo = ($row.find(".productoCodigo").val() || "").trim();
        const peso = parseFloat($row.find(".peso").val()) || 0;
        const cajas = parseFloat($row.find(".cajas").val()) || 0;
        const $precio = $row.find(".precio");
        const precio = parseFloat($precio.val());

        $precio.removeClass("is-invalid");

        if (codigo && (peso > 0 || cajas > 0)) {
        if (!isFinite(precio) || precio <= 0) {
        malas.push(i + 1);
        $precio.addClass("is-invalid");
        }
        }
        });
        return malas;
        }

        // Rebajar disponible según KG.
