    <script>
        /* ============================================================
           FIX FINAL RESPONSIVO SIDEBAR - ORDEN DE VENTA
           Optimizado: sin setInterval constante; usa requestAnimationFrame
           solo cuando cambia tamaño/sidebar/layout.
        ============================================================ */
        (function () {
            const page = document.querySelector('.ov-page');
            if (!page) return;

            const sidebar = document.querySelector('.layout-sidebar, .sidebar');
            const main = page.closest('.layout-main-content')
                || document.querySelector('.layout-main-content, .content-wrapper, main')
                || document.body;

            if (!sidebar || !main) return;

            let lastPush = -1;
            let lastWidth = -1;
            let rafId = null;
            let trackingUntil = 0;

            function applyOrdenVentaSidebar() {
                if (window.innerWidth < 992) {
                    document.body.classList.remove('ov-sidebar-final-ready');
                    document.documentElement.style.setProperty('--ov-sidebar-push', '0px');
                    document.documentElement.style.setProperty('--ov-page-width', '100%');
                    lastPush = 0;
                    lastWidth = 0;
                    return;
                }

                const sidebarStyle = window.getComputedStyle(sidebar);
                const sidebarRect = sidebar.getBoundingClientRect();
                const mainRect = main.getBoundingClientRect();

                const sidebarVisible =
                    sidebarStyle.display !== 'none' &&
                    sidebarStyle.visibility !== 'hidden' &&
                    sidebarRect.width > 0 &&
                    sidebarRect.right > 0;

                let sidebarRight = sidebarVisible ? Math.round(sidebarRect.right) : 0;

                // Si solo queda una pestaña pequeña del sidebar cerrado, no se empuja.
                if (sidebarRight < 90) sidebarRight = 0;

                const mainLeft = Math.max(0, Math.round(mainRect.left));
                const push = Math.max(0, sidebarRight - mainLeft);
                const pageLeft = mainLeft + push;
                const width = Math.max(320, Math.round(window.innerWidth - pageLeft - 12));

                if (push === lastPush && width === lastWidth) return;

                lastPush = push;
                lastWidth = width;

                document.body.classList.add('ov-sidebar-final-ready');
                document.documentElement.style.setProperty('--ov-sidebar-push', push + 'px');
                document.documentElement.style.setProperty('--ov-page-width', width + 'px');
            }

            function scheduleSidebarApply(durationMs) {
                if (durationMs) {
                    trackingUntil = Math.max(trackingUntil, performance.now() + durationMs);
                }

                if (rafId) return;

                const tick = function (now) {
                    rafId = null;
                    applyOrdenVentaSidebar();

                    if (trackingUntil && now < trackingUntil) {
                        rafId = requestAnimationFrame(tick);
                    } else {
                        trackingUntil = 0;
                    }
                };

                rafId = requestAnimationFrame(tick);
            }

            scheduleSidebarApply(250);

            window.addEventListener('resize', function () {
                scheduleSidebarApply(500);
            }, { passive: true });

            if (window.ResizeObserver) {
                const resizeObserver = new ResizeObserver(function () {
                    scheduleSidebarApply(350);
                });
                resizeObserver.observe(sidebar);
                resizeObserver.observe(main);
            }

            const mutationObserver = new MutationObserver(function () {
                scheduleSidebarApply(450);
            });
            mutationObserver.observe(sidebar, {
                attributes: true,
                attributeFilter: ['class', 'style', 'aria-expanded']
            });
            mutationObserver.observe(document.body, {
                attributes: true,
                attributeFilter: ['class', 'style']
            });

            sidebar.addEventListener('transitionstart', function () { scheduleSidebarApply(700); });
            sidebar.addEventListener('transitionrun', function () { scheduleSidebarApply(700); });
            sidebar.addEventListener('transitionend', function () { scheduleSidebarApply(200); });

            document.addEventListener('click', function (e) {
                if (e.target.closest('[data-bs-toggle], .sidebar-toggle, .layout-menu-toggle, .hamburger, .menu-toggle')) {
                    scheduleSidebarApply(700);
                }
            }, true);
        })();
    </script>



    <script>
        // UX visual: mantiene marcadores del flujo sin tocar la lógica del pedido.
        // Optimizado para mobile: no recorre la tabla en intervalos; solo se actualiza por eventos.
        (function () {
            let stepsRaf = null;

            function hasValue(selector) {
                const el = document.querySelector(selector);
                return !!(el && String(el.value || "").trim());
            }

            function setStepState(id, ok) {
                const el = document.getElementById(id);
                if (!el) return;
                el.style.borderColor = ok ? "rgba(22,101,52,.35)" : "";
                el.style.background = ok ? "rgba(220,252,231,.70)" : "";
            }

            function refreshExecutiveSteps() {
                setStepState("ovStepCliente", hasValue("#clienteHidden"));
                setStepState("ovStepEntrega", hasValue("#Serie") && hasValue("#FechaEntrega") && hasValue("#rutaSelect"));

                let hasProduct = false;
                const rows = document.querySelectorAll("#productosBody tr");
                for (let i = 0; i < rows.length; i++) {
                    const row = rows[i];
                    const sku = row.querySelector(".productoCodigo")?.value || row.querySelector(".productoInput")?.value || "";
                    const peso = parseFloat(row.querySelector(".peso")?.value || "0") || 0;
                    if (sku.trim() && peso > 0) {
                        hasProduct = true;
                        break;
                    }
                }

                setStepState("ovStepProductos", hasProduct);
                setStepState("ovStepGuardar", hasProduct && hasValue("#clienteHidden") && hasValue("#FechaEntrega"));
            }

            function scheduleRefreshExecutiveSteps() {
                if (stepsRaf) return;

                stepsRaf = requestAnimationFrame(function () {
                    stepsRaf = null;
                    refreshExecutiveSteps();
                });
            }

            document.addEventListener("input", scheduleRefreshExecutiveSteps, true);
            document.addEventListener("change", scheduleRefreshExecutiveSteps, true);
            document.addEventListener("DOMContentLoaded", refreshExecutiveSteps);
        })();
    </script>


    <script>
        /* ============================================================
           FIX: PRODUCTOS POR FECHA EXACTA DE ENTREGA
           Problema corregido:
           - Si el usuario selecciona cliente con fecha de hoy (ej. 29)
             y después cambia la fecha a 30, la vista anterior solo
             recalculaba presupuesto/disponible.
           - Ahora, cuando cambia #FechaEntrega, se vuelve a ejecutar
             cargarProductos() para traer los productos correspondientes
             a esa fecha exacta.
           - Se conserva la lógica original del código enviado:
             cargarProductos, runWithLoading, clearDisponiblesCache,
             presupuesto/disponible y filas data-origen="servidor".
        ============================================================ */
        (function () {
            if (window.__ovFixProductosPorFechaExacta) return;
            window.__ovFixProductosPorFechaExacta = true;

            let ovFechaExactaTimer = null;
            let ovUltimaKeyProductosFecha = "";

            function ovSafeVal(selector) {
                return String($(selector).val() || "").trim();
            }

            function ovCurrentProductosFechaKey() {
                const cardCode = ovSafeVal("#clienteHidden");
                const fecha = ovSafeVal("#FechaEntrega");
                const serie = ovSafeVal("#Serie");

                if (!cardCode || !fecha) return "";
                return `${cardCode}|${fecha}|${serie}`;
            }

            function ovRegistrarCargaProductosFecha() {
                const key = ovCurrentProductosFechaKey();
                if (key) ovUltimaKeyProductosFecha = key;
            }

            /*
               Envolvemos cargarProductos para saber qué cliente/fecha/serie
               ya quedó cargado. Esto evita dobles recargas cuando la lógica
               original ya hizo la carga por cambio de mes.
            */
            if (typeof window.cargarProductos === "function" && !window.cargarProductos.__ovFechaExactaWrapped) {
                const ovOriginalCargarProductos = window.cargarProductos;

                const ovWrappedCargarProductos = async function () {
                    const r = await ovOriginalCargarProductos.apply(this, arguments);
                    ovRegistrarCargaProductosFecha();
                    return r;
                };

                ovWrappedCargarProductos.__ovFechaExactaWrapped = true;
                window.cargarProductos = ovWrappedCargarProductos;
            }

            async function ovRecargarProductosPorFechaExacta(motivo) {
                const key = ovCurrentProductosFechaKey();
                if (!key) return;

                /*
                   Si la carga original ya dejó productos para esta misma fecha,
                   no hacemos nada.
                */
                if (key === ovUltimaKeyProductosFecha) return;

                try {
                    if (typeof clearDisponiblesCache === "function") {
                        clearDisponiblesCache();
                    }

                    const fnCargar = window.cargarProductos || (typeof cargarProductos === "function" ? cargarProductos : null);
                    if (typeof fnCargar !== "function") return;

                    if (typeof runWithLoading === "function") {
                        await runWithLoading("Cargando productos por fecha de entrega...", async function (myToken) {
                            await fnCargar(myToken);
                        });
                    } else {
                        await fnCargar();
                    }

                    ovRegistrarCargaProductosFecha();
                } catch (err) {
                    console.error("Error al recargar productos por fecha exacta:", err);
                    if (typeof showToast === "function") {
                        showToast("No se pudieron cargar los productos de la fecha seleccionada.", "warning", 6500);
                    }
                }
            }

            /*
               Este es el ajuste clave:
               antes, si cambiabas de 29 a 30 dentro del mismo mes, solo se
               recalculaba presupuesto/disponible. Ahora también se refresca
               la lista de productos de esa fecha.
            */
            $(document).on("change.ovFechaExactaProductos", "#FechaEntrega", function () {
                clearTimeout(ovFechaExactaTimer);

                ovFechaExactaTimer = setTimeout(function () {
                    ovRecargarProductosPorFechaExacta("cambio-fecha");
                }, 500);
            });

            /*
               Cuando cambia cliente o serie, invalidamos la llave para que
               la siguiente carga no se bloquee por cache local visual.
               No forzamos carga aquí para no duplicar la lógica original
               que ya carga al seleccionar cliente.
            */
            $(document).on("change.ovFechaExactaClienteSerie", "#clienteHidden, #Serie", function () {
                ovUltimaKeyProductosFecha = "";
            });

            /*
               Al abrir con datos precargados, registramos estado inicial.
            */
            $(function () {
                setTimeout(ovRegistrarCargaProductosFecha, 800);
            });
        })();
    </script>


