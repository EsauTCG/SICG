        async function cargarComplementoClienteSAP(cardCode) {
        if (!cardCode) return;

        try {
        const data = await $.getJSON('/Comercial/ObtenerComplementoCliente', { cardCode });

        if (!data) return;

        pintarTotales({
        saldo: data.saldo ?? 0,
        saldoVencido: data.saldoVencido ?? 0,
        sumpedidos: data.sumpedidos ?? 0,
        credito: data.credito ?? 0
        });
        } catch (e) {
        console.warn("Error cargando complemento SAP:", e);
        }
        }



        function recalcularDisponibleFila($row) {
        if (!aplicaPresupuesto()) {
        $row.removeClass("table-danger");
        return;
        }

        const pres = parseFloat(($row.find(".presupuesto").val() || "0").replace(/,/g, "")) || 0;
        if (pres <= 0) {
        $row.removeClass("table-danger");
        return;
        }

        const kg = parseFloat($row.find(".peso").val()) || 0;
        const $disp = $row.find(".variacionPresupuesto");

        const rawBase = $disp.data("base");
        if (rawBase === undefined || rawBase === null || rawBase === "") return;

        let base = parseFloat(rawBase);
        if (!isFinite(base)) base = 0;

        const nuevo = base - kg;
        $disp.val(fmt(nuevo));

        if (nuevo < 0) $row.addClass("table-danger");
        else $row.removeClass("table-danger");
        }

