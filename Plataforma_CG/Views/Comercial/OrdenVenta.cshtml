    /* ============================================================
       FIX FINAL RESPONSIVO SIDEBAR - ORDEN DE VENTA
       Funciona en pantallas grandes y chicas:
       - Si el layout ya empujó el contenido, NO duplica margen.
       - Si el sidebar se encimó, empuja solo lo faltante.
       - El ancho se calcula en px para no esconderse a la derecha.
    ============================================================ */
    @@media (min-width: 992px) {
        body.ov-sidebar-final-ready {
            overflow-x: hidden !important;
        }

        body.ov-sidebar-final-ready .ov-page {
            margin-left: var(--ov-sidebar-push, 0px) !important;
            width: var(--ov-page-width, 100%) !important;
            max-width: var(--ov-page-width, 100%) !important;
            transform: none !important;
            box-sizing: border-box !important;
            overflow-x: hidden !important;
            transition:
                margin-left .12s ease-out,
                width .12s ease-out,
                max-width .12s ease-out !important;
        }

        body.ov-sidebar-final-ready .ov-page .shell,
        body.ov-sidebar-final-ready .ov-page .content {
            width: 100% !important;
            max-width: 100% !important;
            box-sizing: border-box !important;
        }

        body.ov-sidebar-final-ready .table-responsive {
            max-width: 100% !important;
            overflow-x: auto !important;
        }
    }


/* ============================================================
   UX EJECUTIVO - CAPTURA DE PEDIDOS SIMPLE E INTUITIVA
   Conserva IDs/clases funcionales existentes.
============================================================ */
:root {
    --ov-bg: #f3f4f6;
    --ov-surface: #ffffff;
    --ov-surface-soft: #f9fafb;
    --ov-ink: #111827;
    --ov-muted: #6b7280;
    --ov-border: #e5e7eb;
    --ov-brand: #8B0000;
    --ov-brand-2: #5c0000;
    --ov-brand-soft: #fff1f2;
    --ov-success: #166534;
    --ov-warning: #92400e;
    --ov-radius-lg: 18px;
    --ov-radius-md: 14px;
    --ov-radius-sm: 10px;
    --ov-shadow: 0 18px 44px rgba(17, 24, 39, .10);
    --ov-shadow-sm: 0 10px 24px rgba(17, 24, 39, .08);
}

html,
body,
body,
main,
.main,
.body-content,
.container,
.container-fluid,
.legacy-border,
.ov-page {
    background: var(--ov-bg) !important;
    color: var(--ov-ink) !important;
}

.ov-page {
    padding: 14px 18px 86px !important;
}

.ov-page .shell {
    max-width: 1780px !important;
    margin: 0 auto !important;
}

.module-titlebar.ov-hero {
    border-radius: var(--ov-radius-lg) var(--ov-radius-lg) 0 0 !important;
    background:
        radial-gradient(circle at top right, rgba(255,255,255,.22), transparent 28%),
        linear-gradient(135deg, #991b1b 0%, #7f1d1d 48%, #450a0a 100%) !important;
    border: 0 !important;
    padding: 18px 20px !important;
    box-shadow: var(--ov-shadow) !important;
}

.ov-hero-copy {
    display: grid;
    gap: 2px;
}

.ov-kicker {
    color: #fecaca;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .12em;
}

.module-title {
    font-size: clamp(1.35rem, 1.2vw + 1rem, 2rem) !important;
    color: #ffffff !important;
    line-height: 1.05 !important;
}

.module-subtitle {
    color: rgba(255,255,255,.84) !important;
    font-size: 13px !important;
}

.toolbar.ov-hero-actions,
.module-titlebar .toolbar {
    background: transparent !important;
    border: 0 !important;
    padding: 0 !important;
    gap: 10px !important;
}

.tbtn {
    min-height: 42px !important;
    height: auto !important;
    border-radius: 999px !important;
    padding: 0 16px !important;
    font-weight: 800 !important;
    box-shadow: 0 10px 20px rgba(0,0,0,.12) !important;
}

.tbtn.primary {
    background: #ffffff !important;
    color: #7f1d1d !important;
    border-color: rgba(255,255,255,.72) !important;
}

.tbtn.primary:hover {
    color: #450a0a !important;
    background: #fff7ed !important;
}

.tbtn.ghost {
    background: rgba(255,255,255,.12) !important;
    color: #ffffff !important;
    border-color: rgba(255,255,255,.30) !important;
}

.tbtn.ghost:hover {
    background: rgba(255,255,255,.20) !important;
    color: #ffffff !important;
}

.ov-steps {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    background: #ffffff;
    border: 1px solid var(--ov-border);
    border-top: 0;
    padding: 12px;
    box-shadow: var(--ov-shadow-sm);
}

.ov-step {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    background: var(--ov-surface-soft);
    border: 1px solid var(--ov-border);
    border-radius: var(--ov-radius-md);
    padding: 12px;
}

.ov-step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
