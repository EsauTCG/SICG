<div class="container-fluid legacy-border ov-page">
    <div class="shell">
        <!-- Title bar -->
        <div class="module-titlebar ov-hero">
            <div class="ov-hero-copy">
                <div class="ov-kicker">Pedido de venta</div>
                <h5 class="module-title"><i class="bi bi-bag-check"></i> Nueva Orden</h5>
                <p class="module-subtitle">Captura rápida: selecciona cliente, define entrega, agrega productos y guarda.</p>
            </div>

            <!-- Toolbar -->
            <div class="toolbar ov-hero-actions" role="toolbar" aria-label="Acciones principales">
                <button type="submit" form="formOV" name="accion" value="salir" class="tbtn primary" title="Guardar y salir">
                    <i class="bi bi-check2-circle"></i><span>Guardar y salir</span>
                </button>
                <button type="submit" form="formOV" name="accion" value="nuevo" class="tbtn primary" title="Guardar y crear nueva orden">
                    <i class="bi bi-plus-circle"></i><span>Guardar y nuevo</span>
                </button>
                <a href="/Home/inicio" class="tbtn ghost" title="Cancelar captura">
                    <i class="bi bi-x-lg"></i><span>Cancelar</span>
                </a>
            </div>
        </div>

        <div class="ov-steps" aria-label="Flujo de captura">
            <div class="ov-step" id="ovStepCliente">
                <span class="ov-step-number">1</span>
                <span class="ov-step-text">
                    <span class="ov-step-title">Cliente</span>
                    <span class="ov-step-help">Busca y selecciona</span>
                </span>
            </div>
            <div class="ov-step" id="ovStepEntrega">
                <span class="ov-step-number">2</span>
                <span class="ov-step-text">
                    <span class="ov-step-title">Entrega</span>
                    <span class="ov-step-help">Serie, fecha y dirección</span>
                </span>
            </div>
            <div class="ov-step" id="ovStepProductos">
                <span class="ov-step-number">3</span>
                <span class="ov-step-text">
                    <span class="ov-step-title">Productos</span>
                    <span class="ov-step-help">SKU, kilos, cajas y precio</span>
                </span>
            </div>
            <div class="ov-step" id="ovStepGuardar">
                <span class="ov-step-number">4</span>
                <span class="ov-step-text">
                    <span class="ov-step-title">Guardar</span>
                    <span class="ov-step-help">Revisa totales y confirma</span>
                </span>
            </div>
        </div>

        <div class="content">
            <form id="formOV" asp-action="GuardarPedido" method="post">
                <!-- Encabezado -->
                <div class="ov-guidance">
                    <div class="ov-guidance-main">
                        <i class="bi bi-lightning-charge-fill"></i>
                        <span>Captura guiada: llena de izquierda a derecha. Los campos de crédito y presupuesto se actualizan al elegir cliente.</span>
                    </div>
                    <small><i class="bi bi-info-circle me-1"></i>Los campos en gris son informativos.</small>
                </div>

                <div class="row g-3 ov-capture-grid">
                    <div class="col-12 col-xl-7">
                        <div class="panel h-100">
                            <div class="panel-head">
                                <span class="ov-card-title"><span class="ov-num">1</span><span><i class="bi bi-person-badge"></i> Selecciona el cliente</span></span>
                            </div>
                            <div class="panel-body">
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label class="form-label">Cliente</label>
                                        <div class="input-group">
                                            <input id="clienteInput" class="form-control" placeholder="Escribe nombre o código del cliente" autocomplete="off" />
                                            <button type="button" class="btn btn-outline-primary" id="btnBuscarCliente">
                                                <i class="bi bi-search"></i> Buscar
                                            </button>
                                        </div>

                                        <input type="hidden" id="clienteHidden" name="Cliente" />
                                        <input type="hidden" id="EsCanalCedis" name="EsCanalCedis" value="false" />
                                        <input type="hidden" id="ClienteAplicaPresupuesto" name="ClienteAplicaPresupuesto" value="1" />

                                        <div class="ov-client-hint">
                                            <i class="bi bi-hand-index-thumb"></i>
                                            <span>Escribe mínimo 2 letras, selecciona una opción o usa el botón Buscar.</span>
                                        </div>
                                    </div>

                                    <div class="col-12 col-md-4 ov-field-readonly">
                                        <label class="form-label">Vendedor</label>
                                        <input asp-for="Vendedor" id="Vendedor" class="form-control" readonly />
                                        <input type="hidden" id="VendedorId" name="VendedorId" />
                                    </div>

                                    <div class="col-12 col-md-4">
                                        <label class="form-label">Dirección de entrega</label>
                                        <select id="rutaSelect" name="Ruta" class="form-select">
                                            <option value="">Selecciona Dirección</option>
                                        </select>
                                    </div>

                                    <div class="col-12 col-md-4">
                                        <label class="form-label">Presentación</label>
                                        <select asp-for="Presentacion" id="Presentacion" class="form-select">
                                            <option value="">Selecciona Presentación</option>
                                            <option value="COMBO">COMBO</option>
                                            <option value="FRESCO">FRESCO</option>
                                            <option value="CONGELADO">CONGELADO</option>
                                            <option value="CAJA GENERICA">CAJA GENERICA</option>
                                            <option value="FRESCO-COMBO">FRESCO-COMBO</option>
                                            <option value="NINGUNO">NINGUNO</option>
                                        </select>
                                        <!-- Checkbox de muestra con alineacion flex -->
                                        <div class="d-flex align-items-center mt-3">
                                            <input type="checkbox" class="form-check-input m-0" id="chkEsMuestra" name="esMuestra" value="true">
                                            <label class="form-check-label ms-2" for="chkEsMuestra">¿Es orden de muestra?</label>
                                        </div>
                                    </div>


                                    <!-- Modo presupuesto oculto: se conserva para la lógica existente -->
                                    <div class="col-12 col-md-3 d-none">
                                        <label class="form-label">Modo Presupuesto</label>

                                        <div class="btn-group w-100" role="group" aria-label="Modo de presupuesto">
                                            <input type="radio" class="btn-check" name="presModo" id="modoVend">
                                            <label class="btn btn-outline-secondary" for="modoVend">
                                                <i class="bi bi-person-badge me-1"></i> Vend.
                                            </label>

                                            <input type="radio" class="btn-check" name="presModo" id="modoCli">
                                            <label class="btn btn-outline-secondary" for="modoCli">
                                                <i class="bi bi-building me-1"></i> Cli.
                                            </label>
                                        </div>

                                        <div class="help mt-1">Por defecto se usa vendedor.</div>
                                    </div>

                                    <div class="col-12 col-md-5">
                                        <button type="button" class="btn btn-outline-secondary w-100" data-bs-toggle="modal" data-bs-target="#modalPropiedades">
                                            <i class="bi bi-journal-text me-1"></i> Ver documentación del cliente
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-xl-5">
                        <div class="panel h-100">
                            <div class="panel-head">
                                <span class="ov-card-title"><span class="ov-num">2</span><span><i class="bi bi-truck"></i> Datos de entrega</span></span>
                            </div>
                            <div class="panel-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-6 ov-field-readonly">
                                        <label class="form-label">Consecutivo</label>
                                        <input asp-for="Consecutivo" class="form-control" readonly />
                                    </div>

                                    <div class="col-12 col-md-6">
                                        <label class="form-label">Serie</label>
                                        <select asp-for="Serie" asp-items="Model.Series" id="Serie" class="form-select">
                                            <option value="">Selecciona serie</option>
                                        </select>
                                        @if (Model.Series == null || !Model.Series.Any())
                                        {
                                            <div class="text-danger small mt-1">
                                                No tienes series asignadas. Solicita a Sistemas que te liguen una serie en Configuración de Usuarios.
                                            </div>
                                        }
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label">Fecha para embarcar</label>
                                        <input asp-for="FechaEntrega" id="FechaEntrega" type="date" class="form-control" />
                                        <div class="help">No se permiten fechas pasadas.</div>
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label">Observación</label>
                                        <textarea asp-for="Observacion" class="form-control" rows="2" placeholder="Notas de entrega, horario, referencia, contacto, etc."></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Resumen de crédito -->
                <div class="row g-3 ov-credit-row">
                    <div class="col-12 col-sm-6 col-xl-3">
                        <div class="ov-metric ov-field-readonly">
                            <label class="form-label"><i class="bi bi-wallet2 me-1"></i> Saldo</label>
                            <input id="saldoInput" asp-for="Saldo" class="form-control" readonly />
                        </div>
                    </div>
                    <div class="col-12 col-sm-6 col-xl-3">
                        <div class="ov-metric ov-field-readonly">
                            <label class="form-label"><i class="bi bi-exclamation-triangle me-1"></i> Saldo vencido</label>
                            <input id="saldoVencidoInput" asp-for="SaldoVencido" class="form-control" readonly />
                        </div>
                    </div>
                    <div class="col-12 col-sm-6 col-xl-3">
                        <div class="ov-metric ov-field-readonly">
                            <label class="form-label"><i class="bi bi-box-arrow-up-right me-1"></i> Otros pedidos</label>
                            <input id="otrosPedidosInput" asp-for="OtrosPedidos" class="form-control" readonly />
                        </div>
                    </div>
                    <div class="col-12 col-sm-6 col-xl-3">
                        <div class="ov-metric ov-field-readonly">
                            <label class="form-label"><i class="bi bi-shield-check me-1"></i> Crédito disponible</label>
                            <input id="creditoInput" asp-for="Credito" class="form-control" readonly />
                        </div>
                    </div>
                </div>

                <!-- Productos -->
                <div class="panel ov-products-panel">
                    <div class="panel-head ov-panel-head-split">
                        <span class="ov-panel-title">
                            <span class="ov-card-title"><span class="ov-num">3</span><span><i class="bi bi-box-seam"></i> Agrega productos al pedido</span></span>
                        </span>
                        <span class="ov-mini-note"><i class="bi bi-keyboard me-1"></i>Producto + kilos + cajas + precio</span>
                    </div>

                    <div class="ov-products-tip">
                        <i class="bi bi-magic"></i>
                        <span>Captura un producto por renglón. El importe se calcula solo y el disponible se valida según presupuesto.</span>
                    </div>

                    <div class="panel-body p-0">
                        <div class="table-responsive table-sticky pt-0 px-2 pb-2" style="max-height:58vh; overflow-y:auto;">
