        // ✅ validar presupuesto primero
        let presObj = null;
        try {
        presObj = await obtenerPresupuestoProducto(owner, cardCode, codigoUpper, mes, anio);
        } catch (_) { presObj = null; }

        const presVal = presupuestoAsignadoDe(presObj);

       if (presVal <= 0 && clienteRequierePresupuesto()) {
        showToast(`No puedes agregar el SKU ${codigoUpper}: no tiene presupuesto asignado (${owner.label}).`, "warning", 7000);
        resetProductoRow($row);
        setTimeout(() => $(element).trigger("focus"), 150);
        return;
        }

        if (presVal <= 0 && !clienteRequierePresupuesto()) {
        presupuestoInput.val("0.00");
        variacionInput.val("0.00").data("base", 0);
        $row.removeClass("table-danger");
        } else {
        presupuestoInput.val(presVal.toFixed(2));
        variacionInput.val("0.00").data("base", 0);
        }

        // Precio + kilosCaja
        $.getJSON('/Comercial/ObtenerPrecioArticuloCliente', { cardCode, itemCode: codigoUpper }, function (data) {
        const precio = parseFloat(data?.precio || 0);
        const kilosCaja = parseFloat(data?.kilosCaja || 0);

        precioInput.val(precio.toFixed(2));
        $row.data("kilosCaja", kilosCaja > 0 ? kilosCaja : 1);

        const pesoInicial = kilosCaja > 0 ? kilosCaja : 0;
        const cajasInicial = kilosCaja > 0 ? 1 : 0;

        pesoInput.val(pesoInicial.toFixed(2));
        cajasInput.val(cajasInicial);

        const importe = (pesoInicial * precio) || 0;
        $row.find(".subtotal").val(importe.toFixed(2));
        actualizarTotales();

        setDisponibleEnFila($row, fechaEntrega);
        }).fail(function () {
        precioInput.val("0.00");
        $row.data("kilosCaja", 1);
        pesoInput.val("0.00");
        cajasInput.val("0");
        $row.find(".subtotal").val("0.00");
        actualizarTotales();
        setDisponibleEnFila($row, fechaEntrega);
        });
