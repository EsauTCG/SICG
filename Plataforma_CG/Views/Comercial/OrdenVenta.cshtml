    color: #991b1b !important;
    font-weight: 900 !important;
    text-decoration: none !important;
}

a.action-link:hover,
.ov-delete-link:hover {
    background: #fee2e2;
}

.ov-actionbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 14px;
}

.ov-actionbar-left,
.ov-actionbar-right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
}

.ov-big-action {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 46px !important;
    padding: 0 18px !important;
}

.ov-total-panel {
    margin-top: 14px !important;
}

.ov-total-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(180px, 1fr));
    gap: 12px;
}

.ov-total-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    background: #f9fafb;
    border: 1px solid var(--ov-border);
    border-radius: var(--ov-radius-md);
    padding: 14px 16px;
}

.ov-total-label {
    color: var(--ov-muted);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: .05em;
    font-weight: 900;
}

.ov-total-value {
    color: var(--ov-ink);
    font-size: clamp(1.25rem, 1vw + 1rem, 1.8rem);
    font-weight: 950;
}

.ov-total-value.money {
    color: var(--ov-success);
}

.ov-excel-card {
    background: #f8fafc !important;
    border: 1px dashed #94a3b8 !important;
    border-radius: var(--ov-radius-md) !important;
    box-shadow: none !important;
}

.ov-save-footer {
    position: sticky;
    bottom: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 16px;
    padding: 12px;
    background: rgba(255,255,255,.94);
    border: 1px solid var(--ov-border);
    border-radius: var(--ov-radius-lg);
    box-shadow: 0 -8px 28px rgba(17,24,39,.10);
    backdrop-filter: blur(8px);
}

.ov-save-summary {
    display: flex;
    flex-direction: column;
    gap: 2px;
    color: var(--ov-muted);
    font-size: 12px;
    font-weight: 700;
}

.ov-save-summary strong {
    color: var(--ov-ink);
    font-size: 15px;
}

.ov-save-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: flex-end;
}

.ov-save-actions .btn {
    min-width: 150px;
}

body[data-theme="dark"] {
    --ov-bg: #0f172a;
    --ov-surface: #111827;
    --ov-surface-soft: #172033;
    --ov-ink: #f9fafb;
    --ov-muted: #cbd5e1;
    --ov-border: rgba(255,255,255,.12);
    --ov-brand: #ef4444;
    --ov-brand-2: #991b1b;
    --ov-brand-soft: rgba(248,113,113,.12);
}

body[data-theme="dark"] .ov-steps,
body[data-theme="dark"] .content,
body[data-theme="dark"] .panel,
body[data-theme="dark"] .panel-body,
body[data-theme="dark"] .modal-body,
body[data-theme="dark"] .ov-save-footer {
    background: #111827 !important;
    border-color: rgba(255,255,255,.12) !important;
    color: #f9fafb !important;
}

body[data-theme="dark"] .ov-step,
body[data-theme="dark"] .ov-metric,
body[data-theme="dark"] .ov-total-card,
body[data-theme="dark"] .ov-excel-card {
    background: #172033 !important;
    border-color: rgba(255,255,255,.12) !important;
}

body[data-theme="dark"] .panel-head {
    background: #172033 !important;
    color: #f9fafb !important;
    border-color: rgba(255,255,255,.12) !important;
}

body[data-theme="dark"] .ov-step-title,
body[data-theme="dark"] .ov-total-value,
body[data-theme="dark"] .ov-save-summary strong {
    color: #f9fafb !important;
}

body[data-theme="dark"] .ov-guidance {
    background: rgba(146,64,14,.20);
    border-color: rgba(251,146,60,.28);
}

body[data-theme="dark"] .ov-products-tip {
