        function presupuestoAsignadoDe(pres) {
        if (!pres) return 0;
        if (pres.enPresupuesto === false || pres.tienePresupuesto === false) return 0;
        const v = (pres.presupuestoAsignado != null) ? parseFloat(pres.presupuestoAsignado) : 0;
        return isFinite(v) ? v : 0;
        }

