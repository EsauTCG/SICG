        // ✅ Cache: depende de modo + ownerId + fecha
        const dispCache = {};
        function dispKey(cardCode, fecha, serie) {
        return `${(cardCode || "").toUpperCase()}|${fecha || ""}|${(serie || "").toUpperCase()}`;
        }

        async function getDisponiblesMap(owner, cardCodeFallback, fechaEntrega) {
        const serie = ($("#Serie").val() || "").toString().trim().toUpperCase();
        const cardCode = (cardCodeFallback || "").toString().trim().toUpperCase();

        const key = dispKey(cardCode, fechaEntrega, serie);
        if (dispCache[key]) return dispCache[key];

        const lista = await obtenerDisponiblesLista(owner, cardCode, fechaEntrega).catch(() => []);
        const map = {};
        (lista || []).forEach(p => {
        const code = (p.productoCodigo || p.itemCode || p.codigo || "").toString().trim().toUpperCase();
        if (code) map[code] = p;
        });

        dispCache[key] = map;
        return map;
        }


        function clearDisponiblesCache() {
        for (const k in dispCache) delete dispCache[k];
        }

        // Guarda base en data('base')
        async function setDisponibleEnFila($row, fechaEntrega) {
        if (!aplicaPresupuesto()) {
        $row.find(".variacionPresupuesto").val("0.00").data("base", 0);
        $row.removeClass("table-danger");
        return;
        }

        const prodCode = ($row.find(".productoCodigo").val() || "").toUpperCase();
        const $varInput = $row.find(".variacionPresupuesto");

        if (!prodCode) {
        $varInput.val("0.00").data("base", 0);
        return;
        }

        const owner = getOwnerForPresupuesto();
        const cardCodeFallback = $("#clienteHidden").val();

        const map = await getDisponiblesMap(owner, cardCodeFallback, fechaEntrega);
        const val = parseFloat(map[prodCode]?.presupuestoDisponible ?? 0);

        $varInput
        .val(fmt(val))
        .data("base", val);

        recalcularDisponibleFila($row);
        }

        // ===========================
        // ✅ BLOQUEO: NO permitir SKU sin presupuesto (solo si aplica)
