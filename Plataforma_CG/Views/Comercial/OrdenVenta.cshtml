        const total = Number(r?.total ?? items.length);

        clState.total = total;
        clState.items = items;

        if (!items.length) {
        $rows.html(`<tr><td colspan="4" class="text-center text-muted p-4">Sin resultados.</td></tr>`);
        renderPaginacion(total, page, pageSize);
        return;
