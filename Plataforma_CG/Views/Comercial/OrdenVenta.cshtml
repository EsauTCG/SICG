<!-- Contenedor global de toasts -->
<div aria-live="polite" aria-atomic="true"
     class="position-fixed top-0 end-0 p-3" style="z-index:1080">
    <div id="appToasts"></div>
</div>


@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @{
        var success = TempData["Success"] as string;
        var error = TempData["Error"] as string;
    }


    <script>
        // Función para mostrar toasts (una sola vez en tu proyecto)
        function showToast(message, variant = 'success', delayMs = 5000) {
        const id = 't' + Date.now();
        const html = `
        <div id="${id}" class="toast text-bg-${variant} border-0" role="alert"
        aria-live="assertive" aria-atomic="true" data-bs-delay="${delayMs}">
        <div class="d-flex">
        <div class="toast-body">${message}</div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto"
        data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        </div>`;
        const container = document.getElementById('appToasts') || (() => {
        const wrap = document.createElement('div');
        wrap.className = 'position-fixed top-0 end-0 p-3';
        wrap.style.zIndex = '1080';
        wrap.setAttribute('aria-live', 'polite');
        wrap.setAttribute('aria-atomic', 'true');
        wrap.innerHTML = `<div id="appToasts"></div>`;
        document.body.appendChild(wrap);
        return document.getElementById('appToasts');
        })();
        container.insertAdjacentHTML('beforeend', html);
        const el = document.getElementById(id);
        new bootstrap.Toast(el).show();
        }

        document.addEventListener('DOMContentLoaded', function () {
        // Mostrar éxito si viene de TempData (con el folio)
        @if (!string.IsNullOrEmpty(success))
        {
            @:showToast('@success'.replace(/\\/g, '\\\\').replace(/'/g, "\\'"), 'success', 6000);
        }
        // Mostrar error si existiera
        @if (!string.IsNullOrEmpty(error))
        {
            @:showToast('@error'.replace(/\\/g, '\\\\').replace(/'/g, "\\'"), 'danger', 8000);
        }
        });


    </script>

    <script>
        /* ===========================
        LOADING & UTILIDADES
        =========================== */
        let isLoading = false;
        let isUiLocked = false;
        let loadToken = 0;

        function setLoading(state, message = "Cargando...", options) {
        const lockForm = !!(options && options.lockForm);
        isLoading = !!state;
        isUiLocked = !!state && lockForm;

        const $spinner = $("#loadingSpinner");
        $spinner.find("p").text(message);
        $spinner.toggleClass("is-active", !!state);

        // En mobile NO bloqueamos toda la pantalla para cargas normales.
        // Solo se deshabilita el formulario si se llama explícitamente con { lockForm: true }.
        const $form = $("form[asp-action='GuardarPedido'], #formOV");
        $form.find(":input").prop("disabled", !!state && lockForm);

        $("body").css("pointer-events", "");
        $spinner.css("pointer-events", "auto");
        }

        async function runWithLoading(message, fn, options) {
        // options: { lockForm: bool, showOverlay: bool }
        const myToken = ++loadToken;
        const showOverlay = options?.showOverlay ?? true;
        const lockForm = options?.lockForm ?? false;

        if (showOverlay) setLoading(true, message, { lockForm });
        try {
        const result = await fn(myToken);
        if (myToken === loadToken && showOverlay) setLoading(false);
        return result;
        } catch (err) {
        if (myToken === loadToken && showOverlay) setLoading(false);
        throw err;
        }
        }

        // Solo bloquear clics/inputs cuando realmente se solicite lockForm.
        $(document).on("click", "a, button", function (e) {
        if (isUiLocked) { e.preventDefault(); e.stopPropagation(); return false; }
        });
        $(document).on("input change", ":input", function (e) {
        if (isUiLocked) { e.preventDefault(); e.stopPropagation(); return false; }
        });
    </script>

    <!-- JS funcional ajustado -->

    <script>
        /* ===========================
        HELPERS, CACHE, VALIDACIONES,
        AUTOCOMPLETE, CARGA MASIVA, ETC.
        =========================== */

        function normCode(v) { return (v ?? "").toString().trim().toUpperCase(); }
        function fmt(n) { return Number(n ?? 0).toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
        const isNumber = v => v !== null && v !== undefined && v !== "" && !isNaN(Number(v));

        const API = {
        modoGet: '@Url.Action("ObtenerModoPresupuesto", "Comercial")',
        modoSet: '@Url.Action("GuardarModoPresupuesto", "Comercial")'
        };

        function antiForgeryToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        function apiGetModoPresupuesto() {
        return $.getJSON(API.modoGet); // debe regresar { modo: "VENDEDOR" } o { modo: "CLIENTE" }
        }

        function apiSetModoPresupuesto(modo) {
        return $.ajax({
        url: API.modoSet,
        method: "POST",
        data: {
        modo: modo, // "VENDEDOR" o "CLIENTE"
        __RequestVerificationToken: antiForgeryToken()
        }
        });
        }

        // ===========================
        // ✅ REGLAS "NO APLICA PRESUPUESTO"
        // ===========================
        // const SERIES_MATRIZ = ["MATRIZ"]; // <-- AJUSTA si tu Serie Matriz tiene otros valores
        const SERIES_MATRIZ = ["PLANTA1", "TIF"];

        function pickBool(v) {
        if (typeof v === "boolean") return v;
        if (v == null) return false;
        const s = v.toString().trim().toLowerCase();
        return (s === "true" || s === "1" || s === "si" || s === "sí" || s === "yes" || s === "y");
        }

        function pickBoolDefaultTrue(v) {
        if (v === undefined || v === null || v === "") return true;
        return pickBool(v);
        }

        // Una orden marcada como muestra entra libre, sin presupuesto ni disponible.
        function esOrdenMuestra() {
        return $("#chkEsMuestra").is(":checked");
        }

        function isCanalCedis() {
        return pickBool($("#EsCanalCedis").val());
        }

        // function esSerieMatriz(){
        //     const s = ($("#Serie").val() || "").toString().trim().toUpperCase();
        //     return SERIES_MATRIZ.includes(s);
        // }



        function esSerieMatriz() {
        const val = ($("#Serie").val() || "").toString().trim().toUpperCase();
        const txt = ($("#Serie option:selected").text() || "").toString().trim().toUpperCase();

        return SERIES_MATRIZ.includes(val) || SERIES_MATRIZ.includes(txt);
        }


        // ✅ Si es Canal CEDIS y Serie NO es MATRIZ => NO aplica presupuesto/disponible
        function aplicaPresupuesto() {
        // Regla prioritaria: las órdenes de muestra nunca aplican presupuesto.
        if (esOrdenMuestra()) return false;

        const clienteAplica = pickBoolDefaultTrue($("#ClienteAplicaPresupuesto").val());
        const matriz = esSerieMatriz();

        // Solo aplica presupuesto cuando:
        // 1. NO es orden de muestra
        // 2. El cliente aplica presupuesto
        // 3. La serie seleccionada es de matriz
        return clienteAplica && matriz;
        }

        function toggleColumnasPresupuesto() {
        const mostrar = aplicaPresupuesto();

        // Columnas de la tabla de productos:
        // 3 = Presupuesto
        // 4 = Disponible
        const selectorCols = `
        table.table thead th:nth-child(3),
        table.table thead th:nth-child(4),
        #productosBody tr td:nth-child(3),
        #productosBody tr td:nth-child(4)
        `;

        if (mostrar) {
        $(selectorCols).show();
        } else {
        $(selectorCols).hide();

        $("#productosBody tr").each(function () {
        const $row = $(this);
        $row.removeClass("table-danger");
        $row.find(".presupuesto").val("0.00");
        $row.find(".variacionPresupuesto").val("0.00").data("base", 0);
        });
        }

        actualizarTotales();
        }


        function syncNoAplicaState() {
        if (aplicaPresupuesto()) {
        toggleColumnasPresupuesto();
        return;
        }

        $("#productosBody tr").each(function () {
        const $row = $(this);
        $row.removeClass("table-danger");
        $row.find(".presupuesto").val("0.00");
        $row.find(".variacionPresupuesto").val("0.00").data("base", 0);
        });

        toggleColumnasPresupuesto();
        actualizarTotales();
        }

        // Al marcar Muestra, limpia y desactiva inmediatamente toda la lógica de presupuesto.
        // Al desmarcarla, vuelve a cargar presupuesto solamente cuando corresponda.
