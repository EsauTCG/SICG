        function pintarTotales(data) {
        const pick = (o, k) => (o && o[k] != null && isNumber(o[k])) ? Number(o[k]) : 0;

        const saldo = pick(data, 'saldo') || pick(data, 'Saldo') || pick(data, 'balance');
        const saldoVencido = pick(data, 'saldoVencido') || pick(data, 'SaldoVencido') || pick(data, 'overdue');
        const otrosPedidos = pick(data, 'sumpedidos') || pick(data, 'SumPedidos') || pick(data, 'otrosPedidos');
        const credito = pick(data, 'credito') || pick(data, 'Credito') || pick(data, 'credit');

        $('#saldoInput').val(fmt(saldo));
        $('#saldoVencidoInput').val(fmt(saldoVencido));
        $('#otrosPedidosInput').val(fmt(otrosPedidos));
        $('#creditoInput').val(fmt(credito));

        $("input[name='Saldo']").val(fmt(saldo));
        $("input[name='SaldoVencido']").val(fmt(saldoVencido));
        $("input[name='OtrosPedidos']").val(fmt(otrosPedidos));
        $("input[name='Credito']").val(fmt(credito));
        }

        function existeSKU(codigo) {
        const objetivo = normCode(codigo);
        let found = false;
        $("#productosBody .productoCodigo").each(function () {
        if (normCode($(this).val()) === objetivo) { found = true; return false; }
        });
        return found;
        }
        function existeSKUEnOtraFila(codigo, $rowActual) {
        const objetivo = normCode(codigo);
        let found = false;
        $("#productosBody tr").each(function () {
        if (this === $rowActual[0]) return;
        const code = normCode($(this).find(".productoCodigo").val());
        if (code && code === objetivo) { found = true; return false; }
        });
        return found;
        }

        // Cuenta filas válidas: con código y (peso > 0 o cajas > 0)
        function contarProductosValidos() {
        let n = 0;
        $("#productosBody tr").each(function () {
        const codigo = ($(this).find(".productoCodigo").val() || "").trim();
        const peso = parseFloat($(this).find(".peso").val()) || 0;
        const cajas = parseFloat($(this).find(".cajas").val()) || 0;
        if (codigo && (peso > 0 || cajas > 0)) n++;
        });
        return n;
