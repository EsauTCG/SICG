    .ov-total-grid {
        grid-template-columns: 1fr;
    }

    #clienteInput {
        font-size: 15px !important;
    }

    #btnBuscarCliente {
        min-width: 110px;
    }

    .table {
        min-width: 1060px !important;
    }

