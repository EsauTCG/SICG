        // Helper para intentar varios endpoints y caer al default
        async function tryGetJSON(endpoints) {
        for (const ep of endpoints) {
        try {
        return await $.getJSON(ep.url, ep.data);
        } catch (err) {
        const st = err?.status;
        if (st && st !== 404) console.warn("tryGetJSON falló:", ep.url, st);
        }
        }
        return null;
        }

        // ✅ obtener presupuesto por modo (si hay endpoints por vendedor, los usa; si no, fallback a cliente)
        async function obtenerPresupuestoProducto(owner, cardCodeFallback, productoCodigo, mes, anio) {
        const serie = ($("#Serie").val() || "").toString().trim();

        if (owner.mode === "vend" && owner.id) {
        return await tryGetJSON([
        { url: "/Comercial/ObtenerPresupuestoProductoVendedor", data: { vendedorId: owner.id, cardCode: cardCodeFallback, productoCodigo, mes, anio, serie } },
        // { url: "/Comercial/ObtenerPresupuestoProductoPorVendedor", data: { vendedorId: owner.id, productoCodigo, mes, anio, serie } },
        { url: "/Comercial/ObtenerPresupuestoProducto", data: { cardCode: cardCodeFallback, productoCodigo, mes, anio, serie } }
        ]);
        }

        const cardCode = owner.id || cardCodeFallback;
        return await tryGetJSON([
        { url: "/Comercial/ObtenerPresupuestoProducto", data: { cardCode, productoCodigo, mes, anio, serie } }
        ]);
        }



