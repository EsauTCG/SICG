        // =======================
        // CARGA MASIVA DESDE EXCEL
        // =======================
        let _excelRowsMasivos = [];

        $('#archivoExcelMasivo').on('change', function (e) {
        const file = e.target.files[0];
        _excelRowsMasivos = [];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function (ev) {
        const data = new Uint8Array(ev.target.result);
        const workbook = XLSX.read(data, { type: 'array' });

        const sheetName = workbook.SheetNames[0];
        const sheet = workbook.Sheets[sheetName];
        const rows = XLSX.utils.sheet_to_json(sheet, { header: 1 });

        if (!rows || rows.length < 2) {
        alert('El archivo no tiene datos (o falta encabezado).');
        return;
        }

        for (let i = 1; i < rows.length; i++) {
        const r = rows[i];
        if (!r || r.length === 0) continue;

        const sku = (r[0] || '').toString().trim().toUpperCase();
        const kg = Number(r[1] || 0);
        const cajas = Number(r[2] || 0);
        const precio = Number(r[3] || 0);

        if (!sku) continue;
        _excelRowsMasivos.push({ sku, kg, cajas, precio });
        }

        if (_excelRowsMasivos.length === 0) alert('No se encontraron filas válidas en el Excel.');
        else alert(`Se leyeron ${_excelRowsMasivos.length} renglones desde el Excel.`);
        };
        reader.readAsArrayBuffer(file);
        });

        $('#btnProcesarExcelMasivo').on('click', async function () {
        if (!_excelRowsMasivos.length) { alert('Primero selecciona un archivo Excel válido.'); return; }

        const cardCode = $("#clienteHidden").val();
        if (!cardCode) { alert("Selecciona un cliente primero."); return; }

        await runWithLoading("Cargando artículos desde Excel...", async (myToken) => {
        await cargarArticulosDesdeExcelProtected(myToken, cardCode, _excelRowsMasivos);
        }, { lockForm: false, showOverlay: true });
        });

        async function cargarArticulosDesdeExcelProtected(myToken, cardCode, rowsExcel) {
        window.modoCargaMasiva = true;
        try {
        if (typeof limpiarFilasVacias === 'function') limpiarFilasVacias();

        const únicos = [];
        const vistos = new Set();
        for (const r of rowsExcel) {
        if (!r.sku) continue;
        if (vistos.has(r.sku)) continue;
        vistos.add(r.sku);
        únicos.push(r);
        }
        if (!únicos.length) { alert('No hay SKUs válidos para cargar.'); return; }

        const promesas = únicos.map(r =>
        $.getJSON('/Comercial/ObtenerPrecioArticuloCliente', { cardCode, itemCode: r.sku })
        .then(p => ({ ok: true, sku: r.sku, fila: r, sap: p }))
        .catch(() => ({ ok: false, sku: r.sku, fila: r, sap: null }))
        );

        const resultados = await Promise.all(promesas);

        const omitidos = [];
        const noEncontrados = [];
        const sinPresupuesto = [];

        for (const res of resultados) {
        if (myToken !== loadToken) return;

        const { sku, fila, sap } = res;

        if (existeSKU(sku)) { omitidos.push(sku); continue; }
        if (!res.ok || !sap || !sap.itemCode) { noEncontrados.push(sku); continue; }

        const $row = await agregarFilaArticuloConPresupuesto(sap, cardCode);
        if (!$row) {
        if (clienteRequierePresupuesto()) sinPresupuesto.push(sku);
        else omitidos.push(sku);
        continue;
        }

        if ($row) {
        if (isFinite(fila.precio) && fila.precio > 0) {
        $row.find('.precio').val(fila.precio.toFixed(2));
        }

        const kilosCaja = parseFloat($row.data('kilosCaja')) || parseFloat(sap.kilosCaja || 0) || 1;

        let kg = isFinite(fila.kg) ? fila.kg : 0;
        let cajas = isFinite(fila.cajas) ? fila.cajas : 0;

        if (kg > 0 && cajas <= 0) cajas = Math.round(kg / kilosCaja);
        else if (cajas > 0 && kg <= 0) kg = cajas * kilosCaja;

        $row.find('.peso').val(kg.toFixed(2));
        $row.find('.cajas').val(cajas.toString());

        const precioFinal = parseFloat($row.find('.precio').val()) || 0;
        const subtotal = kg * precioFinal;
        $row.find('.subtotal').val(subtotal.toFixed(2));

        $row.find('.peso').trigger('input');
        }
        }

        if (typeof limpiarFilasVacias === 'function') limpiarFilasVacias();
        actualizarTotales();

        let msg = 'Carga desde Excel finalizada.\n\n';
        if (omitidos.length) msg += `SKUs omitidos (ya estaban en la tabla): ${omitidos.join(', ')}\n`;
        if (noEncontrados.length) msg += `SKUs no encontrados en SAP: ${noEncontrados.join(', ')}\n`;
        if (sinPresupuesto.length) msg += `SKUs sin presupuesto (omitidos): ${sinPresupuesto.join(', ')}\n`;
        alert(msg);
        } finally {
        window.modoCargaMasiva = false;
        }
        }

        // ==========================
        // Productos por cliente/fecha (Soporta canal y no-canal)
        // ==========================
        async function cargarProductos(myTokenFromCaller = null) {
        const cardCode = ($("#clienteHidden").val() || "").trim();
        const fecha = ensureFechaEntrega();
        const $tbody = $("#productosBody");

        if (!cardCode || !fecha) return;

        const localToken = myTokenFromCaller ?? ++loadToken;
        if (myTokenFromCaller == null) {
        setLoading(true, `Cargando productos y presupuestos del cliente ${cardCode}...`);
        }

        try {
        $tbody.find("tr[data-origen='servidor']").remove();

        $tbody.find("tr").each(function () {
        const $row = $(this);
        const codigo = ($row.find(".productoCodigo").val() || "").trim();
        const peso = parseFloat($row.find(".peso").val() || "0") || 0;
        const precio = parseFloat($row.find(".precio").val() || "0") || 0;
        const subRaw = ($row.find(".subtotal").val() || "0").toString().replace(/[^\d.-]/g, "");
        const subtotal = parseFloat(subRaw) || 0;

        if (!codigo && peso === 0 && precio === 0 && subtotal === 0) {
        $row.remove();
        }
        });

        if (localToken !== loadToken) return;

        const toArray = (raw) => {
        if (!raw) return [];
        if (Array.isArray(raw)) return raw;
        return raw.items || raw.Data || raw.data || raw.Items || raw.Datos || [];
        };

        const owner = getOwnerForPresupuesto();
        let productos = [];

        const construirProductosDesdeCodigos = async (codigos) => {
        const MAX_AUTO = 150;
        const codigosTop = codigos.slice(0, MAX_AUTO);

        if (codigosTop.length === 0) return [];

        const prom = codigosTop.map(code =>
        $.getJSON("/Comercial/ObtenerPrecioArticuloCliente", { cardCode, itemCode: code })
        .then(p => ({
        productoCodigo: normCode(p?.itemCode || code),
        productoNombre: (p?.itemName || "").toString(),
        kilosCaja: parseFloat(p?.kilosCaja || 1) || 1,
        precio: parseFloat(p?.precio || 0) || 0
        }))
        .catch(() => ({
        productoCodigo: normCode(code),
        productoNombre: "",
        kilosCaja: 1,
        precio: 0
        }))
        );

        const arr = await Promise.all(prom);

        if (codigos.length > MAX_AUTO && typeof showToast === "function") {
        showToast(`Se encontraron ${codigos.length} SKUs. Se cargaron automáticamente los primeros ${MAX_AUTO}.`, "warning", 7000);
        }

        return arr;
        };

        const cargarDesdeDisponible = async () => {
        let listaDisp = [];
        try {
        listaDisp = await obtenerDisponiblesLista(owner, cardCode, fecha);
        } catch (_) {
        listaDisp = [];
        }

        const codigos = [...new Set(
        (listaDisp || [])
        .map(p => normCode(p.productoCodigo || p.itemCode || p.codigo || p.ProductoCodigo || p.ItemCode || ""))
        .filter(Boolean)
        )];

        return await construirProductosDesdeCodigos(codigos);
        };

        const cargarDesdeCliente = async () => {
        const raw = await tryGetJSON([
        { url: "/Comercial/ObtenerProductosPorClienteFecha", data: { cardCode, fechaEntrega: fecha } },
        { url: "/Comercial/ObtenerProductosPorCliente", data: { cardCode } }
        ]);

        if (localToken !== loadToken) return [];
        return toArray(raw);
        };

        // PRIORIDAD SEGUN MODO
        if (owner.mode === "vend" && owner.id && aplicaPresupuesto()) {
        productos = await cargarDesdeDisponible();

        if ((!productos || productos.length === 0)) {
        productos = await cargarDesdeCliente();
        }
        } else {
        productos = await cargarDesdeCliente();

        if ((!productos || productos.length === 0) && aplicaPresupuesto()) {
        productos = await cargarDesdeDisponible();
        }
        }

        if (localToken !== loadToken) return;

        (productos || []).forEach((prod) => {
        const sku = normCode(prod.productoCodigo || prod.itemCode || prod.codigo || "");
        if (!sku) return;
        if (existeSKU(sku)) return;

        const nombreRaw = (prod.productoNombre || prod.itemName || "").toString().toUpperCase();
        const nombreLimpio = nombreRaw.replace(new RegExp(`\\s*\\(${sku}\\)\\s*$`, "i"), "").trim();
        const nombreConcatenado = nombreLimpio ? `${sku} - ${nombreLimpio}` : sku;

        const kilosCaja = parseFloat(prod.kilosCaja || 1) || 1;
        const precio = parseFloat(prod.precio || 0) || 0;

        const idx = $tbody.find("tr").length;

        const fila = $(`
        <tr data-origen="servidor">
        <td>${idx + 1}</td>
        <td>
        <input type="hidden" name="Productos[${idx}].ProductoCodigo" class="productoCodigo" value="${sku}" />
        <input type="hidden" name="Productos[${idx}].ProductoNombre" value="${nombreLimpio}" />
        ${nombreConcatenado}
        </td>
        <td><input name="Productos[${idx}].Presupuesto" class="form-control presupuesto" type="text" value="0.00" readonly /></td>
        <td><input name="Productos[${idx}].VariacionPresupuesto" class="form-control variacionPresupuesto" type="text" value="0.00" readonly /></td>
        <td><input name="Productos[${idx}].Peso" class="form-control peso" type="number" step="0.01" value="${kilosCaja.toFixed(2)}" /></td>
        <td><input name="Productos[${idx}].Precio" class="form-control precio" type="number" step="0.01" value="${precio.toFixed(2)}" /></td>
        <td><input name="Productos[${idx}].Cajas" class="form-control cajas" type="number" min="0" step="1" value="1" /></td>
        <td><input class="form-control subtotal" type="text" value="${(kilosCaja * precio).toFixed(2)}" readonly /></td>
        <td>
        <button type="button" class="btn btn-sm btn-info btn-inventario"
        data-codigo="${sku}" data-nombre="${nombreLimpio}">
        <i class="bi bi-boxes me-1"></i> Ver
        </button>
        </td>
        <td><a href="#" class="action-link ov-delete-link" onclick="eliminarProducto(this); return false;"><i class="bi bi-trash"></i></a></td>
        </tr>
        `);

        $tbody.append(fila);
        fila.data("kilosCaja", kilosCaja);

        fila.find(".peso").on("input", function () {
        const peso = parseFloat($(this).val()) || 0;
        fila.find(".cajas").val((peso / kilosCaja).toFixed(0));
        fila.find(".subtotal").val((peso * (parseFloat(fila.find(".precio").val()) || 0)).toFixed(2));
        scheduleActualizarTotales();
        });

        fila.find(".cajas").on("input", function () {
        const cajas = parseFloat($(this).val()) || 0;
        const p = (cajas * kilosCaja);
        fila.find(".peso").val(p.toFixed(2));
        fila.find(".subtotal").val((p * (parseFloat(fila.find(".precio").val()) || 0)).toFixed(2));
        scheduleActualizarTotales();
        });

        fila.find(".precio").on("input", function () {
        const peso = parseFloat(fila.find(".peso").val()) || 0;
        fila.find(".subtotal").val((peso * (parseFloat($(this).val()) || 0)).toFixed(2));
        scheduleActualizarTotales();
        });
        });

        if ($tbody.find("tr").length === 0) {
        agregarProducto();
        actualizarTotales();
        if (typeof articuloIndex !== "undefined") articuloIndex = $tbody.find("tr").length;
        return;
        }

        actualizarIndices();
        actualizarTotales();

        if (localToken !== loadToken) return;

        if (!aplicaPresupuesto()) {
        $("#productosBody tr").each(function () {
        $(this).removeClass("table-danger");
        $(this).find(".presupuesto").val("0.00");
        $(this).find(".variacionPresupuesto").val("0.00").data("base", 0);
        });
        toggleColumnasPresupuesto();
        if (typeof articuloIndex !== "undefined") articuloIndex = $("#productosBody tr").length;
        return;
        }

        const [anioStr, mesStr] = fecha.split("-");
        const anio = parseInt(anioStr, 10);
        const mes = parseInt(mesStr, 10);

        const llamadasPres = [];
        $("#productosBody tr").each(function () {
        const $row = $(this);
        const productoCodigo = normCode($row.find(".productoCodigo").val());
        if (!productoCodigo) return;

        llamadasPres.push(
        obtenerPresupuestoProducto(owner, cardCode, productoCodigo, mes, anio)
        .then(pres => {
        if (localToken !== loadToken) return;
        const val = presupuestoAsignadoDe(pres);
        $row.find(".presupuesto").val(fmt(val));
        })
        .catch(() => {
        if (localToken !== loadToken) return;
        $row.find(".presupuesto").val("0.00");
        })
        );
        });

        await Promise.all(llamadasPres);
        if (localToken !== loadToken) return;

        const map = await getDisponiblesMap(owner, cardCode, fecha);
        if (localToken !== loadToken) return;

        $("#productosBody tr").each(function () {
        const $row = $(this);
        const code = normCode($row.find(".productoCodigo").val());
        if (!code) return;

        const val = parseFloat(map[code]?.presupuestoDisponible ?? 0);
        $row.find(".variacionPresupuesto").val(fmt(val)).data("base", val);

        if (val < 0) $row.addClass("table-danger");
        else $row.removeClass("table-danger");
        });

        actualizarTotales();
        toggleColumnasPresupuesto();

        if (typeof articuloIndex !== "undefined") articuloIndex = $("#productosBody tr").length;

        } catch (err) {
        console.error("cargarProductos() error:", err);
        if (typeof showToast === "function") {
        showToast("Error al cargar productos. Revisa consola / endpoints.", "danger", 8000);
        }
        if ($("#productosBody tr").length === 0) agregarProducto();
        } finally {
        if (myTokenFromCaller == null && localToken === loadToken) setLoading(false);
        }
        }







        // Fecha Entrega -> recálculo/recarga
        let lastFechaEntrega = null;
        function sameMonthYear(a, b) {
        if (!a || !b) return false;

        const [anioA, mesA] = a.split("-");
        const [anioB, mesB] = b.split("-");

        return parseInt(anioA, 10) === parseInt(anioB, 10)
        && parseInt(mesA, 10) === parseInt(mesB, 10);
        }

        $("#FechaEntrega").on("change", async function () {
        const nueva = $(this).val();
        const cardCode = $("#clienteHidden").val();
        clearDisponiblesCache();
        if (!nueva || !cardCode) { lastFechaEntrega = nueva; return; }

        if (lastFechaEntrega && !sameMonthYear(lastFechaEntrega, nueva)) {
        await runWithLoading("Cambiando fecha de entrega (nuevo mes)...", async (myToken) => {
        const $tbody = $("#productosBody");
        $tbody.empty();
        articuloIndex = 0;
        agregarProducto();
        await cargarProductos(myToken);
        });
        lastFechaEntrega = nueva;
        return;
        }

        // Si no aplica presupuesto, solo actualiza productos (sin cálculos)
        if (!aplicaPresupuesto()) {
        await runWithLoading("Actualizando por nueva fecha...", async (myToken) => {
        await cargarProductos(myToken);
        syncNoAplicaState();
        });
        lastFechaEntrega = nueva;
        return;
        }

        await runWithLoading("Actualizando presupuesto por nueva fecha...", async (myToken) => {
        const [anioStr, mesStr] = nueva.split("-");
        const anio = parseInt(anioStr, 10);
        const mes = parseInt(mesStr, 10);
        const owner = getOwnerForPresupuesto();

        const filas = $("#productosBody tr"), llamadas = [];
        filas.each(function () {
        const row = $(this);
        const productoCodigo = (row.find(".productoCodigo").val() || "").toUpperCase();
        if (!productoCodigo) return;

        const p = obtenerPresupuestoProducto(owner, cardCode, productoCodigo, mes, anio)
        .then(presupuesto => {
        if (myToken !== loadToken) return;
        const presupuestoInput = row.find(".presupuesto");
        const variacionInput = row.find(".variacionPresupuesto");
        const val = presupuestoAsignadoDe(presupuesto);
        presupuestoInput.val(fmt(val));
        variacionInput.val("0.00").data("base", 0);
        })
        .catch(() => {
        if (myToken !== loadToken) return;
        row.find(".presupuesto").val("0.00");
        row.find(".variacionPresupuesto").val("0.00").data("base", 0);
        });

        llamadas.push(p);
        });

        await Promise.all(llamadas);
        if (myToken !== loadToken) return;

        await cargarPresupuestoDisponibleProtegido(myToken);
        });

        lastFechaEntrega = nueva;
        });


