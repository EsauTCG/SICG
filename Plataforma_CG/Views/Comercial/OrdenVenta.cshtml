        $(document).on('input', '.peso, .cajas', function () {
        const $row = $(this).closest('tr');

        if (!aplicaPresupuesto()) {
        $row.removeClass("table-danger");
        return;
        }

        const pres = parseFloat(($row.find(".presupuesto").val() || "0").replace(/,/g, "")) || 0;
        if (pres <= 0) {
        $row.removeClass("table-danger");
        return;
        }

        const kg = parseFloat($row.find('.peso').val()) || 0;
        const $disp = $row.find('.variacionPresupuesto');

        let base = parseFloat($disp.data('base'));
        if (!isFinite(base)) base = 0;

        const dispFinal = base - kg;
        $disp.val(fmt(dispFinal));

        if (dispFinal < 0) $row.addClass('table-danger');
        else $row.removeClass('table-danger');
        });

