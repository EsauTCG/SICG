        function buildSkuNombre(codigoUpper, texto) {
        const sku = (codigoUpper || "").toString().trim().toUpperCase();
        const s = (texto || "").toString().trim().toUpperCase();

        if (!sku) return { nombre: "", texto: "" };
        if (!s) return { nombre: "", texto: sku };

        // Caso: "SKU (NOMBRE)"
        const pref = `${sku} (`;
        if (s.startsWith(pref) && s.endsWith(")")) {
        const nombre = s.substring(pref.length, s.length - 1).trim();
        return { nombre, texto: nombre ? `${sku} - ${nombre}` : sku };
        }

        // Caso: "NOMBRE (SKU)" al final
        const nombre2 = s.replace(new RegExp(`\\s*\\(\\s*${sku}\\s*\\)\\s*$`, "i"), "").trim();
        const nombre = (nombre2 === sku) ? "" : nombre2;

        return { nombre, texto: nombre ? `${sku} - ${nombre}` : sku };
        }

        // ==========================
        // Autocomplete Producto ✅ BLOQUEA si NO hay presupuesto (solo si aplica)
        // ==========================
        function initProductoAutocomplete(element) {
        $(element).autocomplete({
        source: function (request, response) {
        $.ajax({
        url: '/Comercial/BuscarProductosAutocomplete',
        data: { term: request.term },
        success: function (data) {
        response($.map(data, function (item) {
        return { label: (item.label || "").toUpperCase(), value: item.value };
        }));
        },
        error: function () { response([]); }
        });
        },
        minLength: 2,
        select: function (event, ui) {
        event.preventDefault();

        const $row = $(element).closest("tr");

        const precioInput = $row.find("input[name$='.Precio']");
        const cajasInput = $row.find("input[name$='.Cajas']");
        const pesoInput = $row.find("input[name$='.Peso']");
        const presupuestoInput = $row.find("input[name$='.Presupuesto']");
        const variacionInput = $row.find("input[name$='.VariacionPresupuesto']");

        const codigoOriginal = ui.item.value || "";
        const codigoUpper = normCode(ui.item.value);
        const label = (ui.item.label || "").toString().toUpperCase();

        if (existeSKUEnOtraFila(codigoOriginal, $row)) {
        alert(`El SKU ${codigoUpper} ya está agregado en otra fila.`);
        $(element).val("");
        $row.find(".productoCodigo").val("");
        $row.find("input[name$='.ProductoNombre']").val("");
        return false;
        }

        const parsed = buildSkuNombre(codigoUpper, label);
        const nombreLimpio = parsed.nombre || label;

        // ✅ Pintado inmediato (visible + hidden)
        $(element).val(nombreLimpio);
        $row.find(".productoCodigo").val(codigoUpper);
        $row.find("input[name$='.ProductoNombre']").val(nombreLimpio);        
        limpiarMarcaSkuInvalido($row);
        // Inventario
        const $btnInv = $row.find('.btn-inventario');
        $btnInv.attr('data-codigo', codigoOriginal);
        $btnInv.attr('data-nombre', nombreLimpio);

        const cardCode = $("#clienteHidden").val();
        const fechaEntrega = $("#FechaEntrega").val();

        if (!cardCode || !fechaEntrega) {
        showToast("Selecciona Cliente y Fecha de entrega antes de agregar productos.", "warning", 6500);
        resetProductoRow($row);
        setTimeout(() => $(element).trigger("focus"), 150);
        return false;
        }

        (async () => {
        // ✅ Si NO aplica presupuesto: NO bloquear por presupuesto, y no recalcular disponible
        if (!aplicaPresupuesto()) {
        presupuestoInput.val("0.00");
        variacionInput.val("0.00").data("base", 0);
        $row.removeClass("table-danger");

        // Precio + kilosCaja
        $.getJSON('/Comercial/ObtenerPrecioArticuloCliente', { cardCode, itemCode: codigoUpper }, function (data) {
        const precio = parseFloat(data?.precio || 0);
