        // ✅ Bloquear disponible negativo solo cuando el cliente requiere presupuesto
   function filasConDisponibleNoPositivo() {
    if (!aplicaPresupuesto()) return [];

        const malas = [];

        $("#productosBody tr").each(function (i) {
        const $row = $(this);

        const codigo = normCode($row.find(".productoCodigo").val());
        const peso = parseFloat($row.find(".peso").val()) || 0;
        const cajas = parseFloat($row.find(".cajas").val()) || 0;

        if (!codigo || (peso <= 0 && cajas <= 0)) return;

        const pres = parseFloat(($row.find(".presupuesto").val() || "0").replace(/,/g, "")) || 0;
        const disp = parseFloat(($row.find(".variacionPresupuesto").val() || "0").replace(/,/g, "")) || 0;

        // Si el SKU no tiene presupuesto, lo bloquea filasSinPresupuesto().
        if (pres <= 0) return;

        if (disp < 0) {
        malas.push(i + 1);
        $row.addClass("table-danger");
        } else {
        $row.removeClass("table-danger");
        }
        });

        return malas;
        }


                $("form").on("submit", function (e) {
            if (isLoading) { e.preventDefault(); alert("Espera a que termine la carga antes de guardar."); return false; }

            var esMuestra = document.getElementById('chkEsMuestra') && document.getElementById('chkEsMuestra').checked;

            if (!esMuestra) {
                const tSaldo = valNum('#saldoInput');
                const tSaldoVencido = valNum('#saldoVencidoInput');
                const tOtros = valNum('#otrosPedidosInput');
                const tCredito = valNum('#creditoInput');

                if ([tSaldo, tSaldoVencido, tOtros, tCredito].every(x => x === 0)) {
                    e.preventDefault();
                    alert("No se pudo obtener información de SAP (todos los totales están en 0). Intenta de nuevo o verifica la conexión.");
                    return false;
                }
            }


        // Las muestras avanzan sin validar presupuesto ni disponible.
        if (!esMuestra) {
        const sinPres = filasSinPresupuesto();
        if (sinPres.length > 0) {
        e.preventDefault();
        alert(`No puedes guardar: hay productos sin presupuesto asignado en las filas: ${sinPres.join(', ')}.`);
        return false;
        }

        const sinDisp = filasConDisponibleNoPositivo();
        if (sinDisp.length > 0) {
        e.preventDefault();
        alert(`No puedes guardar: el Disponible quedó en 0 o menor en las filas: ${sinDisp.join(', ')}.\n\nAjusta KG/Cajas o quita el producto.`);
        return false;
        }
        }

        const malas = filasConPrecioCero();
        if (malas.length > 0) {
        e.preventDefault();
        alert(`Por favor corrige:\n\n- Hay precio en 0 o vacío en las filas: ${malas.join(', ')}.`);
        return false;
        }
        });

