    html,
    body {
        background: #e9edf2 !important;
        overflow-x: hidden !important;
    }

    body,
    main,
    .main,
    .body-content,
    .container,
    .container-fluid,
    .legacy-border,
    .ov-page {
        background: #e9edf2 !important;
    }

    .ov-page {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        transform: none !important;
        padding: 8px 12px !important;
        box-sizing: border-box !important;
        overflow-x: hidden !important;
    }

        .ov-page .shell {
            width: 100% !important;
            max-width: 1850px !important;
            margin: 8px auto !important;
            padding: 0 !important;
            box-sizing: border-box !important;
        }

        .ov-page .content {
            width: 100% !important;
            max-width: 100% !important;
            box-sizing: border-box !important;
        }

    .content {
        background: #f0dede !important;
        border-color: #c79d9d !important;
    }

    .panel,
    .modal-content,
    .bg-light {
        background: #fffafa !important;
        border: 1px solid #c79d9d !important;
        border-radius: 0 !important;
    }

    .panel-body,
    .modal-body {
        background: #fffafa !important;
    }

    .toolbar,
    .modal-footer {
        background: #f1dede !important;
        border-color: #c79d9d !important;
    }

    .form-control,
    .form-select,
    .input-group-text,
    input,
    select,
    textarea {
        background: #fffafa !important;
        border: 1px solid #b48787 !important;
        color: #421414 !important;
        border-radius: 0 !important;
    }

    .table-responsive {
        background: #fffafa !important;
        overflow-x: auto !important;
        -webkit-overflow-scrolling: touch !important;
    }

    .table {
        min-width: 1200px !important;
        background: #fffafa !important;
    }

        .table tbody td {
            background: #fffafa !important;
            border-color: #d8bcbc !important;
        }

    .table-striped tbody tr:nth-of-type(even) td {
        background: #f9eded !important;
    }

    .table-hover tbody tr:hover td {
        background: #f4dddd !important;
    }

    /* CELULAR */
    @@media (max-width: 768px) {
        .ov-page {
            padding: 0 !important;
        }

            .ov-page .shell {
                width: 100% !important;
                max-width: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
            }

        .module-titlebar {
            display: block !important;
            border-radius: 0 !important;
        }

        .toolbar {
            display: grid !important;
            grid-template-columns: 1fr !important;
            gap: 6px !important;
            width: 100% !important;
        }

        .tbtn,
        .btn,
        .form-control,
        .form-select {
            width: 100% !important;
            font-size: 12px !important;
        }

        .content {
            padding: 6px !important;
        }

        .table-responsive,
        .table-responsive.table-sticky {
            width: 100% !important;
            max-height: 65vh !important;
            overflow-x: auto !important;
        }

        .table {
            min-width: 1050px !important;
            font-size: 10px !important;
        }

            .table th,
            .table td {
                font-size: 10px !important;
                padding: 4px 3px !important;
                white-space: nowrap !important;
            }

        .d-flex.justify-content-between {
            display: grid !important;
            grid-template-columns: 1fr !important;
            gap: 8px !important;
        }
    }

    /* ============================================================
       DARK MODE - NUEVA ORDEN DE VENTA
    ============================================================ */

body[data-theme="dark"] {
    --brand-solid: #dc2626;
    --brand-dark: #450a0a;
    --brand-mid: #991b1b;
    --brand-soft: rgba(127, 29, 29, 0.22);
    --brand-soft-2: rgba(127, 29, 29, 0.32);
    --brand-line: rgba(248, 113, 113, 0.35);

    --brand-text: #f9fafb;
    --panel: #111827;
    --panel-soft: #172033;
    --muted: #cbd5e1;
    --line: rgba(255, 255, 255, 0.12);
    --line-dark: rgba(248, 113, 113, 0.45);

    --shadow: 0 14px 32px rgba(0, 0, 0, 0.42);
