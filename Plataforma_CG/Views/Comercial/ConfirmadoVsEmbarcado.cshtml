@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewBag.Title = "Confirmado Vs Embarcado";
}

<style>
    :root {
        --bg: #f0dede;
        --panel: #f8eeee;
        --line: #c79d9d;
        --line-dark: #8f4c4c;
        --text: #3b1717;
        --brand: #8B0000;
        --brand-dark: #5c0000;
        --brand-mid: #8b0000;
        --brand-light: #b30000;
        --shadow: 0 1px 0 rgba(255,255,255,.55) inset;
    }

    body {
        font-family: Tahoma, Verdana, Arial, sans-serif;
        background: transparent !important;
    }

    .window {
        width: 100%;
        border: 1px solid #7e4a4a;
        background: var(--panel);
        box-shadow: 0 0 0 1px rgba(255,255,255,.45) inset, 0 8px 18px rgba(70,12,12,.14);
        overflow: hidden;
    }

    .titlebar {
        height: 36px;
        /* display: flex; */
        display: none !important;
        align-items: center;
        justify-content: space-between;
        padding: 0 12px;
        background: linear-gradient(180deg,#c00000 0%,#8b0000 60%,#5c0000 100%);
        border-bottom: 1px solid #5c0000;
        color: #fff;
        font-size: 14px;
        font-weight: bold;
    }

    .actions {
        display: flex;
        gap: 6px;
    }

    .win-btn {
        width: 16px;
        height: 16px;
        border: 1px solid #7c4848;
        background: linear-gradient(#fff6f6,#ead0d0);
    }

    .content {
        padding: 12px 14px;
        background: var(--bg);
    }

    .section {
        border: 1px solid var(--line);
        background: #fff;
        margin-bottom: 14px;
    }

    .section-title {
        padding: 8px 10px;
        font-size: 13px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
    }

    .section-body {
        padding: 12px;
        background: #fffafa;
    }

    .filters {
        display: grid;
        grid-template-columns: 1.5fr 1fr 170px 1fr 1fr 180px auto;
        gap: 12px;
        align-items: end;
    }

    .form-label {
        display: block;
        color: #5c1a1a;
        font-size: 13px;
        margin-bottom: 5px;
        font-weight: bold;
    }

    .form-control, .form-select {
        border: 1px solid #b48787 !important;
        background: #fffdfd !important;
        color: #421414 !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        font-size: 13px !important;
        height: 36px !important;
    }

        .form-control:focus, .form-select:focus {
            border-color: #8b0000 !important;
            box-shadow: 0 0 0 .18rem rgba(139,0,0,.14) !important;
        }

    /* Multiselect tipo estatus */
    .cg-multiselect {
        position: relative;
        width: 100%;
    }

    .cg-ms-button {
        width: 100%;
        height: 36px;
        border: 1px solid #b48787;
        background: #fffdfd;
        color: #421414;
        border-radius: 0;
        padding: 0 8px;
        font-size: 13px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        box-shadow: none;
    }

    .cg-ms-arrow {
        color: #8b0000;
        margin-left: 8px;
        font-size: 12px;
    }

    .cg-ms-panel {
        display: none;
        position: absolute;
        top: 38px;
        left: 0;
        width: 230px;
        max-width: 92vw;
        background: #fffafa;
        border: 1px solid #c79d9d;
        box-shadow: 0 4px 10px rgba(70,12,12,.25);
        z-index: 9999;
        padding: 8px;
    }

    .cg-multiselect.open .cg-ms-panel {
        display: block;
    }

    .cg-ms-search {
        width: 100%;
        height: 30px !important;
        border: 1px solid #c79d9d !important;
        background: #fff !important;
        color: #421414 !important;
        padding: 4px 8px !important;
        font-size: 12px !important;
        margin-bottom: 8px;
    }

    .cg-ms-options {
        max-height: 220px;
        overflow-y: auto;
    }

    .cg-ms-item {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 6px 4px;
        margin: 0;
        color: #4b1f1f;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        user-select: none;
    }

    .cg-ms-item:hover {
        background: #f4dddd;
    }

    .cg-ms-item input {
        width: 15px;
        height: 15px;
        accent-color: #8b0000;
        cursor: pointer;
    }

    .cg-ms-empty {
        padding: 6px 4px;
        color: #7a4b4b;
        font-size: 12px;
    }

    .btn-main {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
        height: 36px;
        padding: 0 14px;
        font-weight: 700;
        border-radius: 0;
        font-size: 13px;
        border: 1px solid #7a2d2d;
        color: #fff;
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
        cursor: pointer;
    }

    .btn-light {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
        height: 36px;
        padding: 0 14px;
        font-weight: 700;
        border-radius: 0;
        font-size: 13px;
        border: 1px solid #b48787;
        color: #4b1f1f;
        background: linear-gradient(#fffefe,#ecd7d7);
        cursor: pointer;
    }

    .btn-excel {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
        height: 36px;
        padding: 0 14px;
        font-weight: 700;
        border-radius: 0;
        font-size: 13px;
        border: 1px solid #146c43;
        color: #fff;
        background: linear-gradient(180deg,#198754 0%, #146c43 100%);
        cursor: pointer;
    }

    .kpis {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
        width: 100%;
    }

    .kpi-card {
        min-width: 170px;
        border: 1px solid #d8bcbc;
        background: linear-gradient(#fffefe,#f3e4e4);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.7);
        padding: 10px 12px;
        text-align: center;
    }

    .kpi-title {
        font-size: 12px;
        color: #7a0000;
        font-weight: 700;
        margin-bottom: 4px;
        text-transform: uppercase;
        text-align: center;
    }

    .kpi-value {
        font-size: 18px;
        font-weight: 700;
        color: #401515;
        font-variant-numeric: tabular-nums;
        text-align: center;
    }

    .table-card {
        background: var(--panel);
        border: 1px solid var(--line);
        overflow: hidden;
    }

    .table-responsive-sticky {
        max-height: 84vh;
        overflow: auto;
        border-top: 1px solid #d9b8b8;
        background: #fffafa;
    }

    #tbl-surtidos {
        width: 100%;
        min-width: 1400px;
        table-layout: fixed;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 13px !important;
        margin-bottom: 0;
        background: #fffafa;
    }

        /* ── SORTABLE HEADERS ── */
        #tbl-surtidos thead th {
            position: sticky;
            top: -1px;
            z-index: 20;
            background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
            color: #fff !important;
            border-top: 1px solid #c46a6a !important;
            border-right: 1px solid #8e3b3b !important;
            border-bottom: 1px solid #5c0000 !important;
            padding: 0 !important;
            font-weight: 700 !important;
            font-size: 13px !important;
            white-space: nowrap;
        }

    /* Wrapper inside every <th> */
    .th-inner {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 4px;
        padding: 8px 6px;
        user-select: none;
        cursor: default;
    }

        .th-inner.sortable {
            cursor: pointer;
        }

            .th-inner.sortable:hover {
                background: rgba(255,255,255,0.10);
            }

    /* Sort arrow */
    .sort-arrow {
        display: inline-flex;
        flex-direction: column;
        gap: 1px;
        flex-shrink: 0;
        opacity: 0.45;
        transition: opacity 0.15s;
    }

        .sort-arrow .arr-up,
        .sort-arrow .arr-dn {
            width: 0;
            height: 0;
            border-left: 4px solid transparent;
            border-right: 4px solid transparent;
        }

        .sort-arrow .arr-up {
            border-bottom: 5px solid #fff;
        }

        .sort-arrow .arr-dn {
            border-top: 5px solid #fff;
        }

    /* Active state */
    th.sort-asc .sort-arrow,
    th.sort-desc .sort-arrow {
        opacity: 1;
    }

        th.sort-asc .sort-arrow .arr-dn {
            opacity: 0.3;
        }

        th.sort-desc .sort-arrow .arr-up {
            opacity: 0.3;
        }

    /* Text-end headers */
    #tbl-surtidos thead th.text-end .th-inner {
        justify-content: flex-end;
    }

    #tbl-surtidos thead th.text-center .th-inner {
        justify-content: center;
        cursor: default;
    }

    /* ── GOLD COLUMNS ── */
    #tbl-surtidos thead th:nth-child(9),
    #tbl-surtidos thead th:nth-child(10),
    #tbl-surtidos thead th:nth-child(11),
    #tbl-surtidos thead th:nth-child(12) {
        background: linear-gradient(180deg,#dcb000 0%,#c79c00 55%,#a88000 100%) !important;
        color: #fff !important;
        border-right: 1px solid #916f00 !important;
        border-bottom: 1px solid #7b5f00 !important;
        border-top: 1px solid #e7c84e !important;
    }

        #tbl-surtidos thead th:nth-child(9) .sort-arrow .arr-up,
        #tbl-surtidos thead th:nth-child(9) .sort-arrow .arr-dn,
        #tbl-surtidos thead th:nth-child(10) .sort-arrow .arr-up,
        #tbl-surtidos thead th:nth-child(10) .sort-arrow .arr-dn,
        #tbl-surtidos thead th:nth-child(11) .sort-arrow .arr-up,
        #tbl-surtidos thead th:nth-child(11) .sort-arrow .arr-dn,
        #tbl-surtidos thead th:nth-child(12) .sort-arrow .arr-up,
        #tbl-surtidos thead th:nth-child(12) .sort-arrow .arr-dn {
            border-bottom-color: #fff;
            border-top-color: #fff;
        }

    /* ── BODY CELLS ── */
    #tbl-surtidos tbody td {
        background: #fffafa !important;
        border-right: 1px solid #d8bcbc !important;
        border-bottom: 1px solid #d8bcbc !important;
        padding: 8px 6px !important;
        color: #111 !important;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        vertical-align: middle;
    }

    #tbl-surtidos tbody tr:nth-of-type(even) > * {
        background-color: #f9eded !important;
    }

    #tbl-surtidos tbody tr:hover > * {
        background: #f4dddd !important;
    }

    #tbl-surtidos tbody tr.is-open > * {
        background: #f4dddd !important;
    }

    /* column widths */
    #tbl-surtidos th:nth-child(1), #tbl-surtidos td:nth-child(1) { width: 38px; }
    #tbl-surtidos th:nth-child(2), #tbl-surtidos td:nth-child(2) { width: 60px; }
    #tbl-surtidos th:nth-child(3), #tbl-surtidos td:nth-child(3) { width: 85px; }
    #tbl-surtidos th:nth-child(4), #tbl-surtidos td:nth-child(4) { width: 120px; }
    #tbl-surtidos th:nth-child(5), #tbl-surtidos td:nth-child(5) { width: 260px; }
    #tbl-surtidos th:nth-child(6), #tbl-surtidos td:nth-child(6) { width: 115px; }
    #tbl-surtidos th:nth-child(7), #tbl-surtidos td:nth-child(7) { width: 100px; }
    #tbl-surtidos th:nth-child(8), #tbl-surtidos td:nth-child(8) { width: 105px; }
    #tbl-surtidos th:nth-child(9), #tbl-surtidos td:nth-child(9) { width: 100px; }
    #tbl-surtidos th:nth-child(10), #tbl-surtidos td:nth-child(10) { width: 105px; }
    #tbl-surtidos th:nth-child(11), #tbl-surtidos td:nth-child(11) { width: 90px; }
    #tbl-surtidos th:nth-child(12), #tbl-surtidos td:nth-child(12) { width: 90px; }

    /* gold body cells */
    #tbl-surtidos thead th:nth-child(9),
    #tbl-surtidos tbody td:nth-child(9),
    #tbl-surtidos thead th:nth-child(10),
    #tbl-surtidos tbody td:nth-child(10) {
        background-color: #fff4cc !important;
        color: #401515 !important;
    }

    .text-end {
        text-align: right !important;
        font-variant-numeric: tabular-nums;
    }

    .text-center {
        text-align: center !important;
    }

    .toggle-btn {
        width: 24px;
        height: 24px;
        border-radius: 0;
        padding: 0;
        border: 1px solid #b48787;
        background: linear-gradient(#fffefe,#ecd7d7);
        color: #6b1f1f;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    tr.detail-row td {
        background: #f7eaea !important;
        padding: .60rem .70rem !important;
        border-bottom: 1px solid #d8bcbc;
    }

    .detail-box {
        border: 1px solid #d8bcbc;
        border-left: 4px solid #8b0000;
        background: #fffafa;
        overflow: hidden;
    }

    .detail-head {
        padding: 8px 10px;
        font-size: 13px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
    }

    .detail-table-wrap {
        overflow: auto;
        background: #fffafa;
    }

    .detail-table {
        width: 100%;
        min-width: 960px;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 13px;
        margin: 0;
    }

        .detail-table th {
            position: sticky;
            top: 0;
            z-index: 1;
            background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
            color: #fff;
            border-bottom: 1px solid #5c0000;
            border-right: 1px solid #8e3b3b;
            padding: 8px 6px;
            white-space: nowrap;
            font-size: 13px;
        }

        .detail-table td {
            background: #fffafa;
            border-bottom: 1px solid #d8bcbc;
            border-right: 1px solid #d8bcbc;
            padding: 8px 6px;
            white-space: nowrap;
            color: #111;
        }

            .detail-table th:first-child,
            .detail-table td:first-child {
                border-left: 1px solid #d8bcbc;
            }

            .detail-table th:nth-child(2),
            .detail-table td:nth-child(2) {
                width: 340px !important;
                min-width: 340px !important;
                max-width: 340px !important;
            }

    .td-wrap {
        white-space: normal !important;
        word-break: break-word !important;
        line-height: 1.15;
    }

    .detail-table th:nth-child(8) {
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
        color: #fff !important;
        border-right: 1px solid #8e3b3b !important;
        border-bottom: 1px solid #5c0000 !important;
        border-top: 1px solid #c46a6a !important;
    }

    .detail-table tbody td:nth-child(8) {
        background: #fffafa !important;
        color: #111 !important;
        font-weight: 400 !important;
    }

    .detail-table tbody tr:nth-of-type(even) td:nth-child(8) {
        background: #f9eded !important;
    }

    .statusbar {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 8px 10px;
        font-size: 12px;
        color: #4a1a1a;
        border-top: 1px solid #b88c8c;
        background: linear-gradient(#f6e9e9,#ead5d5);
        flex-wrap: wrap;
    }

    /* GAP colors */
    .gap-ok {
        background: #198754 !important;
        color: #fff !important;
        font-weight: 700 !important;
    }

    .gap-warn {
        background: #ffc107 !important;
        color: #111 !important;
        font-weight: 700 !important;
    }

    .gap-bad {
        background: #dc3545 !important;
        color: #fff !important;
        font-weight: 700 !important;
    }

    .gap-empty {
        background: transparent !important;
        color: #401515 !important;
        font-weight: 700 !important;
    }

    #tbl-surtidos tbody td.gap-ok, .detail-table td.gap-ok, .kpi-value.gap-ok {
        background: #198754 !important;
        color: #fff !important;
        font-weight: 700 !important;
    }

    #tbl-surtidos tbody td.gap-warn, .detail-table td.gap-warn, .kpi-value.gap-warn {
        background: #ffc107 !important;
        color: #111 !important;
        font-weight: 700 !important;
    }

    #tbl-surtidos tbody td.gap-bad, .detail-table td.gap-bad, .kpi-value.gap-bad {
        background: #dc3545 !important;
        color: #fff !important;
        font-weight: 700 !important;
    }

    #tbl-surtidos tbody td.gap-empty, .detail-table td.gap-empty, .kpi-value.gap-empty {
        background: transparent !important;
        color: #401515 !important;
        font-weight: 700 !important;
    }

    @@media (max-width: 992px) {
        .filters {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 768px) {
        .filters {
            grid-template-columns: 1fr;
        }

        #tbl-surtidos {
            min-width: 1380px !important;
        }
    }

    /* FONDO GRIS + ESTILO ROSITA */
    html,
    body {
        width: 100% !important;
        max-width: 100% !important;
        overflow-x: hidden !important;
        background: #e9edf2 !important;
    }

    body,
    main,
    .main,
    .body-content,
    .container,
    .container-fluid,
    .container-sm,
    .container-md,
    .container-lg,
    .container-xl,
    .container-xxl,
    .pb-3 {
        background: #e9edf2 !important;
        box-shadow: none !important;
        border: none !important;
    }

    .window {
        width: calc(100vw - 48px) !important;
        max-width: none !important;
        margin-left: 50% !important;
        transform: translateX(-50%) !important;
        background: #f8eeee !important;
        border: 1px solid #7e4a4a !important;
    }

    .content {
        background: #f0dede !important;
    }

    .section,
    .table-card,
    .detail-box {
        background: #fffafa !important;
        border: 1px solid #c79d9d !important;
    }

    .section-body,
    .table-responsive-sticky,
    .detail-table-wrap {
        background: #fffafa !important;
    }

    .kpi-card {
        background: linear-gradient(#fffefe,#f3e4e4) !important;
        border: 1px solid #d8bcbc !important;
    }

    #tbl-surtidos,
    .detail-table {
        background: #fffafa !important;
    }

        #tbl-surtidos tbody td,
        .detail-table td {
            background: #fffafa !important;
            border-color: #d8bcbc !important;
        }

        #tbl-surtidos tbody tr:nth-of-type(even) > *,
        .detail-table tbody tr:nth-of-type(even) > * {
            background: #f9eded !important;
        }

        #tbl-surtidos tbody tr:hover > *,
        .detail-table tbody tr:hover > * {
            background: #f4dddd !important;
        }

        /* Mantener columnas amarillas */
        #tbl-surtidos thead th:nth-child(9),
        #tbl-surtidos thead th:nth-child(10),
        #tbl-surtidos thead th:nth-child(11),
        #tbl-surtidos thead th:nth-child(12) {
            background: linear-gradient(180deg,#dcb000 0%,#c79c00 55%,#a88000 100%) !important;
            color: #fff !important;
        }

        #tbl-surtidos tbody td:nth-child(9),
        #tbl-surtidos tbody td:nth-child(10) {
            background: #fff4cc !important;
            color: #401515 !important;
        }

        /* No tapar colores GAP */
        #tbl-surtidos tbody td.gap-ok,
        .detail-table td.gap-ok,
        .kpi-value.gap-ok {
            background: #198754 !important;
            color: #fff !important;
        }

        #tbl-surtidos tbody td.gap-warn,
        .detail-table td.gap-warn,
        .kpi-value.gap-warn {
            background: #ffc107 !important;
            color: #111 !important;
        }

        #tbl-surtidos tbody td.gap-bad,
        .detail-table td.gap-bad,
        .kpi-value.gap-bad {
            background: #dc3545 !important;
            color: #fff !important;
        }

        #tbl-surtidos tbody td.gap-empty,
        .detail-table td.gap-empty,
        .kpi-value.gap-empty {
            background: #fffafa !important;
            color: #401515 !important;
        }

    /* RESPONSIVO CELULAR */
    @@media (max-width: 768px) {
        .window {
            width: 100% !important;
            max-width: 100% !important;
            margin: 0 !important;
            transform: none !important;
            border-left: none !important;
            border-right: none !important;
        }

        .content {
            padding: 6px !important;
        }

        .section-body {
            padding: 8px !important;
        }

        .filters {
            grid-template-columns: 1fr !important;
            gap: 8px !important;
        }

            .filters > div:last-child {
                display: grid !important;
                grid-template-columns: 1fr !important;
                gap: 6px !important;
            }

        .btn-main,
        .btn-excel,
        .btn-light {
            width: 100% !important;
            font-size: 12px !important;
        }

        .kpis {
            display: grid !important;
            grid-template-columns: 1fr 1fr !important;
            gap: 8px !important;
        }

        .kpi-card {
            min-width: 0 !important;
            padding: 8px !important;
        }

        .kpi-title {
            font-size: 10px !important;
        }

        .kpi-value {
            font-size: 14px !important;
        }

        .table-responsive-sticky {
            width: 100% !important;
            overflow-x: auto !important;
            -webkit-overflow-scrolling: touch !important;
            max-height: 65vh !important;
        }

        #tbl-surtidos {
