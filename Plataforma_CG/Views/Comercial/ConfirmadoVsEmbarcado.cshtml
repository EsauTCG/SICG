@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <script>
        (() => {
        const URL_RESUMEN        = '/Comercial/ObtenerSurtidosMeatResumen';
        const URL_DETALLE        = '/Comercial/ObtenerSurtidosMeatDetalle';
        const URL_DETALLE_EXCEL  = '/Comercial/ObtenerSurtidosMeatDetalleExcel';
        const URL_SERIES         = '/Comercial/ObtenerSeriesSurtidosMeat';

        const $frm          = document.getElementById('frm-filtros');
        const $cliente      = document.getElementById('txt-cliente');
        const $folio        = document.getElementById('txt-folio');
        const $msSerie      = document.getElementById('ms-serie');
        const $btnSerie     = document.getElementById('btn-serie');
        const $lblSerie     = document.getElementById('lbl-serie');
        const $buscarSerie  = document.getElementById('txt-buscar-serie');
        const $lstSerie     = document.getElementById('lst-serie');
        const $fechaInicio  = document.getElementById('txt-fecha-inicio');
        const $fechaFin     = document.getElementById('txt-fecha-fin');
        const $tipo         = document.getElementById('sel-tipo');
        const $btnLimpiar   = document.getElementById('btn-limpiar');
        const $btnExcel     = document.getElementById('btn-excel');
        const $tbody        = document.getElementById('tbody-surtidos');

        const $kpiKgPedidos     = document.getElementById('kpi-kg-pedidos');
        const $kpiCajasPedidas  = document.getElementById('kpi-cajas-pedidas');
        const $kpiKgSurtidos    = document.getElementById('kpi-kg-surtidos');
        const $kpiCajasSurtidas = document.getElementById('kpi-cajas-surtidas');
        const $kpiGapKg         = document.getElementById('kpi-gap-kg');
        const $kpiGapCajas      = document.getElementById('kpi-gap-cajas');

        const nf    = new Intl.NumberFormat(undefined, { maximumFractionDigits: 0 });
        const nfPct = new Intl.NumberFormat(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 2 });

        let resumenActual  = [];
        let detalleCache   = {};
        let seriesCatalogo = [];
        let seriesSeleccionadas = new Set();

        /* ── sort state ── */
        let sortCol = null;   // key string  e.g. 'serie', 'kgPedidos'
        let sortDir = 'asc';  // 'asc' | 'desc'

        /* ═══════════════════════════ HELPERS ═══════════════════════════ */
        function num(v)  { return nf.format(Number(v || 0)); }

        function pct(v)  { return nfPct.format(Number(v || 0)) + '%'; }

        function pctGap(v) {
        const n = Number(v);
        if (!isFinite(n) || n === 0) return '-';
        return pct(n);
        }

        function getGapClass(v) {
        const n = Number(v);
        if (!isFinite(n) || n === 0) return 'gap-empty';
        if (n >= 100)          return 'gap-ok';
        if (n >= 97 && n < 100) return 'gap-warn';
        return 'gap-bad';
        }

        function setKpiCardGapClass(kpiValueElement, gapValue) {
        const card = kpiValueElement?.closest('.kpi-card');
        if (!card) return;

        card.classList.remove('kpi-gap-ok', 'kpi-gap-warn', 'kpi-gap-bad', 'kpi-gap-empty');
        card.classList.add(`kpi-${getGapClass(gapValue)}`);
        }

        function getGapKgValue(item)   { return item?.gapKg   ?? item?.gapKG    ?? 0; }
        function getGapCajaValue(item) { return item?.gapCaja ?? item?.gapCajas ?? 0; }

        function escapeHtml(v) {
        return String(v ?? '')
        .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
        .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
        }

        function formatFecha(v) {
        if (!v) return '';
        const d = new Date(v);
        if (isNaN(d)) return '';
        return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
        }

        function getDetalleKey(folio, tipo, serie) { return `${tipo||''}__${serie||''}__${folio||''}`; }

        function getSerieValue(item) { return item?.serie ?? item?.Serie ?? ''; }

        function getSeriesParam() {
        return Array.from(seriesSeleccionadas).join(',');
        }

        /* ── value accessor for sort ── */
        function getSortValue(item, col) {
        switch (col) {
        case 'tipo':          return (item.tipo         || '').toLowerCase();
        case 'serie':         return getSerieValue(item).toLowerCase();
        case 'folio':         return (item.folio        || '').toLowerCase();
        case 'cliente':       return (item.cliente      || '').toLowerCase();
        case 'fecha':         return item.fecha          || '';
        case 'kgPedidos':     return Number(item.kgPedidos     || 0);
        case 'cajasPedidas':  return Number(item.cajasPedidas  || 0);
        case 'kgSurtidos':    return Number(item.kgSurtidos    || 0);
        case 'cajasSurtidas': return Number(item.cajasSurtidas || 0);
        case 'gapKg':         return Number(getGapKgValue(item));
        case 'gapCaja':       return Number(getGapCajaValue(item));
        default:              return '';
        }
        }

        /* ═══════════════════════════ SORT ═══════════════════════════ */
        function applySortUI() {
        document.querySelectorAll('#tbl-surtidos thead th[data-col]').forEach(th => {
        th.classList.remove('sort-asc','sort-desc');
        if (th.dataset.col === sortCol) {
        th.classList.add(sortDir === 'asc' ? 'sort-asc' : 'sort-desc');
        }
        });
        }

        function sortedData() {
        if (!sortCol) return resumenActual;
        return [...resumenActual].sort((a, b) => {
        const va = getSortValue(a, sortCol);
        const vb = getSortValue(b, sortCol);
        if (va < vb) return sortDir === 'asc' ? -1 :  1;
        if (va > vb) return sortDir === 'asc' ?  1 : -1;
        return 0;
        });
        }

        /* Wire up header clicks */
        document.querySelectorAll('#tbl-surtidos thead th[data-col]').forEach(th => {
        th.querySelector('.th-inner').addEventListener('click', () => {
        const col = th.dataset.col;
        if (sortCol === col) {
        sortDir = sortDir === 'asc' ? 'desc' : 'asc';
        } else {
        sortCol = col;
        sortDir = 'asc';
        }
        applySortUI();
        rerenderRows();
        });
        });

        /* ═══════════════════════════ RENDER ═══════════════════════════ */
        function setLoading() {
        $tbody.innerHTML = `<tr><td colspan="12" class="text-center text-muted">Cargando...</td></tr>`;
        }

        function setEmpty(msg) {
        resumenActual = [];
        detalleCache  = {};
        $tbody.innerHTML = `<tr><td colspan="12" class="text-center text-muted">${escapeHtml(msg)}</td></tr>`;
        }

        function buildResumenRow(item, displayIndex) {
        const tr = document.createElement('tr');
        tr.dataset.folio = item.folio || '';
        tr.dataset.tipo  = item.tipo  || '';
        tr.dataset.serie = getSerieValue(item);

        const gapKg   = getGapKgValue(item);
        const gapCaja = getGapCajaValue(item);

        tr.innerHTML = `
        <td class="text-center">
        <div style="display:flex; align-items:center; justify-content:center; gap:6px;">
        <span>${displayIndex + 1}</span>
        <button type="button" class="toggle-btn js-expand" data-open="0">+</button>
        </div>
        </td>
        <td>${escapeHtml(item.tipo    || '')}</td>
        <td>${escapeHtml(getSerieValue(item))}</td>
        <td>${escapeHtml(item.folio   || '')}</td>
        <td>${escapeHtml(item.cliente || '')}</td>
        <td>${escapeHtml(formatFecha(item.fecha))}</td>
        <td class="text-end">${num(item.kgPedidos)}</td>
        <td class="text-end">${num(item.cajasPedidas)}</td>
        <td class="text-end">${num(item.kgSurtidos)}</td>
        <td class="text-end">${num(item.cajasSurtidas)}</td>
        <td class="text-end ${getGapClass(gapKg)}">${pctGap(gapKg)}</td>
        <td class="text-end ${getGapClass(gapCaja)}">${pctGap(gapCaja)}</td>
        `;
        return tr;
        }

        /* Re-renders only the rows (keeps KPIs) */
        function rerenderRows() {
        // Close any open detail rows first
        $tbody.querySelectorAll('tr.detail-row').forEach(r => r.remove());
        $tbody.querySelectorAll('tr[data-folio]').forEach(r => {
        r.classList.remove('is-open');
        const btn = r.querySelector('.js-expand');
        if (btn) { btn.textContent = '+'; btn.dataset.open = '0'; }
        });

        const ordered = sortedData();
        $tbody.innerHTML = '';
        ordered.forEach((item, idx) => $tbody.appendChild(buildResumenRow(item, idx)));
        }

        function renderResumen(data) {
        resumenActual = Array.isArray(data) ? data : [];
        detalleCache  = {};

        if (!data || !data.length) {
        setEmpty('Sin datos.');
        renderKpis([]);
        return;
        }

        applySortUI();
        rerenderRows();
        renderKpis(data);
        }

        function renderKpis(data) {
        const totalKgPedidos     = data.reduce((a,b) => a + Number(b.kgPedidos     || 0), 0);
        const totalCajasPedidas  = data.reduce((a,b) => a + Number(b.cajasPedidas  || 0), 0);
        const totalKgSurtidos    = data.reduce((a,b) => a + Number(b.kgSurtidos    || 0), 0);
        const totalCajasSurtidas = data.reduce((a,b) => a + Number(b.cajasSurtidas || 0), 0);

        const gapKg    = totalKgPedidos    > 0 ? (totalKgSurtidos    * 100) / totalKgPedidos    : 0;
        const gapCajas = totalCajasPedidas > 0 ? (totalCajasSurtidas * 100) / totalCajasPedidas : 0;

        $kpiKgPedidos.textContent     = num(totalKgPedidos);
        $kpiCajasPedidas.textContent  = num(totalCajasPedidas);
        $kpiKgSurtidos.textContent    = num(totalKgSurtidos);
        $kpiCajasSurtidas.textContent = num(totalCajasSurtidas);

        $kpiGapKg.textContent    = pctGap(gapKg);
        $kpiGapKg.className      = `kpi-value ${getGapClass(gapKg)}`;
        $kpiGapCajas.textContent = pctGap(gapCajas);
        $kpiGapCajas.className   = `kpi-value ${getGapClass(gapCajas)}`;

        setKpiCardGapClass($kpiGapKg, gapKg);
        setKpiCardGapClass($kpiGapCajas, gapCajas);
        }

        /* ═══════════════════════════ DETAIL ═══════════════════════════ */
        function buildDetailShell(folio, tipo, serie) {
        const tr = document.createElement('tr');
        tr.className      = 'detail-row';
        tr.dataset.folio  = folio;
        tr.dataset.tipo   = tipo;
        tr.dataset.serie  = serie;

        tr.innerHTML = `
        <td colspan="12">
        <div class="detail-box">
        <div class="detail-head">Detalle: ${escapeHtml(folio)} ${serie ? '| Serie: ' + escapeHtml(serie) : ''}</div>
        <div class="detail-table-wrap">
        <table class="detail-table">
        <thead>
        <tr>
        <th>SKU</th>
        <th>Producto</th>
        <th class="text-end">Kg Pedidos</th>
        <th class="text-end">Cajas Pedidas</th>
        <th class="text-end">Kg Surtidos</th>
        <th class="text-end">Cajas Surtidas</th>
        <th class="text-end">GAP Kg</th>
        <th class="text-end">GAP Caja</th>
        </tr>
        </thead>
        <tbody>
        <tr><td colspan="8" class="text-center text-muted">Cargando detalle...</td></tr>
        </tbody>
        </table>
        </div>
        </div>
        </td>
        `;
        return tr;
        }

        function renderDetailRows(items) {
        return items.map(x => {
        const gapKg   = x?.gapKg   ?? x?.gapKG    ?? 0;
        const gapCaja = x?.gapCaja ?? x?.gapCajas ?? 0;
        return `<tr>
        <td>${escapeHtml(x.sku     || '')}</td>
        <td class="td-wrap">${escapeHtml(x.producto || '')}</td>
        <td class="text-end">${num(x.kgPedidos)}</td>
        <td class="text-end">${num(x.cajasPedidas)}</td>
        <td class="text-end">${num(x.kgSurtidos)}</td>
        <td class="text-end">${num(x.cajasSurtidas)}</td>
        <td class="text-end ${getGapClass(gapKg)}">${pctGap(gapKg)}</td>
        <td class="text-end ${getGapClass(gapCaja)}">${pctGap(gapCaja)}</td>
        </tr>`;
        }).join('');
        }

        async function cargarDetalle(trMaster) {
        const folio = trMaster.dataset.folio;
        const tipo  = trMaster.dataset.tipo;
        const serie = trMaster.dataset.serie || '';
        const btn   = trMaster.querySelector('.js-expand');
        const key   = getDetalleKey(folio, tipo, serie);

        if (btn.dataset.open === '1') {
        const next = trMaster.nextElementSibling;
        if (next && next.classList.contains('detail-row')) next.remove();
        trMaster.classList.remove('is-open');
        btn.textContent   = '+';
        btn.dataset.open  = '0';
        return;
        }

        const shell = buildDetailShell(folio, tipo, serie);
        trMaster.insertAdjacentElement('afterend', shell);
        trMaster.classList.add('is-open');
        btn.textContent  = '−';
        btn.dataset.open = '1';

        const tbody = shell.querySelector('tbody');

        if (detalleCache[key]?.length) {
        tbody.innerHTML = renderDetailRows(detalleCache[key]);
        return;
        }

        try {
        const params = new URLSearchParams({ folio, tipo, serie });
        const res    = await fetch(`${URL_DETALLE}?${params}`, { headers:{ 'X-Requested-With':'XMLHttpRequest' } });
        const json   = await res.json();

        if (!json || !Array.isArray(json) || !json.length) {
        detalleCache[key] = [];
        tbody.innerHTML = `<tr><td colspan="8" class="text-center text-muted">Sin detalle.</td></tr>`;
        return;
        }

        detalleCache[key] = json;
        tbody.innerHTML   = renderDetailRows(json);
        } catch {
        tbody.innerHTML = `<tr><td colspan="8" class="text-center text-danger">Error al cargar detalle.</td></tr>`;
        }
        }

      /* ═══════════════════════════ MULTISELECT SERIE ═══════════════════════════ */
function normalizarSerie(x) {
    if (typeof x === 'string') return x.trim();
    return String(x?.serie ?? x?.Serie ?? '').trim();
}

function actualizarLabelSeries() {
    const arr = Array.from(seriesSeleccionadas);

    if (!arr.length) {
        $lblSerie.textContent = 'Todas';
        return;
    }

    $lblSerie.textContent = arr.length <= 2 ? arr.join(', ') : `${arr.length} seleccionadas`;
}

function renderSerieOptions() {
    const texto = ($buscarSerie.value || '').trim().toLowerCase();
    const filtradas = seriesCatalogo.filter(s => !texto || s.toLowerCase().includes(texto));

    if (!filtradas.length) {
        $lstSerie.innerHTML = `<div class="cg-ms-empty">Sin series.</div>`;
        return;
    }

    $lstSerie.innerHTML = filtradas.map(s => {
        const checked = seriesSeleccionadas.has(s) ? 'checked' : '';

        return `<label class="cg-ms-item">
            <input type="checkbox" value="${escapeHtml(s)}" ${checked} />
            <span>${escapeHtml(s)}</span>
        </label>`;
    }).join('');
}

async function cargarSeries() {
    try {
        const res = await fetch(URL_SERIES, {
            headers:{ 'X-Requested-With':'XMLHttpRequest' }
        });

        const raw = await res.text();

let json;
try {
    json = JSON.parse(raw);
} catch {
    console.error('Respuesta no JSON de ObtenerSeriesSurtidosMeat:', raw);
    throw new Error(raw);
}
        const arr = Array.isArray(json) ? json.map(normalizarSerie).filter(Boolean) : [];

        seriesCatalogo = Array.from(new Set(arr)).sort((a,b) => a.localeCompare(b));
    } catch(e) {
        console.warn('No fue posible cargar series.', e);
        seriesCatalogo = [];
    }

    renderSerieOptions();
    actualizarLabelSeries();
}

$btnSerie.addEventListener('click', e => {
    e.preventDefault();
    e.stopPropagation();

    $msSerie.classList.toggle('open');

    if ($msSerie.classList.contains('open')) {
        setTimeout(() => $buscarSerie.focus(), 0);
    }
});

document.addEventListener('click', e => {
    if (!$msSerie.contains(e.target)) {
        $msSerie.classList.remove('open');
    }
});

$buscarSerie.addEventListener('click', e => e.stopPropagation());
$buscarSerie.addEventListener('input', renderSerieOptions);

$lstSerie.addEventListener('change', e => {
    const chk = e.target.closest('input[type="checkbox"]');

    if (!chk) return;

    if (chk.checked) {
        seriesSeleccionadas.add(chk.value);
    } else {
        seriesSeleccionadas.delete(chk.value);
    }

    actualizarLabelSeries();
});

        /* ═══════════════════════════ FETCH RESUMEN ═══════════════════════════ */
        async function cargarResumen() {
        setLoading();
        const params = new URLSearchParams({
        cliente:     $cliente.value      || '',
        folio:       $folio.value        || '',
        serie:       getSeriesParam(),
        fechaInicio: $fechaInicio.value  || '',
        fechaFin:    $fechaFin.value     || '',
        tipo:        $tipo.value         || ''
        });

        try {
        const res  = await fetch(`${URL_RESUMEN}?${params}`, { headers:{ 'X-Requested-With':'XMLHttpRequest' } });
        const raw = await res.text();

let json;
try {
    json = JSON.parse(raw);
} catch {
    console.error('Respuesta no JSON de ObtenerSurtidosMeatResumen:', raw);
    throw new Error(raw);
}

        if (!json || !Array.isArray(json)) {
        setEmpty('No fue posible cargar la información.');
        renderKpis([]);
        return;
        }
        renderResumen(json);
        } catch(e) {
        console.error(e);
        setEmpty('Error al cargar la información.');
        renderKpis([]);
        }
        }

        /* ═══════════════════════════ EXCEL ═══════════════════════════ */
        async function exportarExcel() {
        const params = new URLSearchParams({
        cliente:     $cliente.value     || '',
        folio:       $folio.value       || '',
        serie:       getSeriesParam(),
        fechaInicio: $fechaInicio.value || '',
        fechaFin:    $fechaFin.value    || '',
        tipo:        $tipo.value        || ''
        });

        try {
        const [resResumen, resDetalle] = await Promise.all([
        fetch(`${URL_RESUMEN}?${params}`,       { headers:{ 'X-Requested-With':'XMLHttpRequest' } }),
        fetch(`${URL_DETALLE_EXCEL}?${params}`, { headers:{ 'X-Requested-With':'XMLHttpRequest' } })
        ]);

        const resumenJson = await resResumen.json();
        const detalleJson = await resDetalle.json();

        if (!Array.isArray(resumenJson) || !resumenJson.length) { alert('No hay datos para exportar.'); return; }

        const resumenRows = resumenJson.map(x => ({
        Tipo: x.tipo||'', Serie: getSerieValue(x), Folio: x.folio||'', Cliente: x.cliente||'', Fecha: formatFecha(x.fecha),
        KgPedidos: Number(x.kgPedidos||0), CajasPedidas: Number(x.cajasPedidas||0),
        KgSurtidos: Number(x.kgSurtidos||0), CajasSurtidas: Number(x.cajasSurtidas||0),
        GAPKg: Number(x.gapKg||0), GAPCajas: Number(x.gapCaja ?? x.gapCajas ?? 0)
        }));

        const detalleRows = Array.isArray(detalleJson) ? detalleJson.map(x => ({
        Tipo: x.tipo||'', Serie: getSerieValue(x), Folio: x.folio||'', Cliente: x.cliente||'', Fecha: formatFecha(x.fecha),
        SKU: x.sku||'', Producto: x.producto||'',
        KgPedidos: Number(x.kgPedidos||0), CajasPedidas: Number(x.cajasPedidas||0),
        KgSurtidos: Number(x.kgSurtidos||0), CajasSurtidas: Number(x.cajasSurtidas||0),
        GAPKg: Number(x.gapKg||0), GAPCaja: Number(x.gapCaja||0)
        })) : [];

        const wb = XLSX.utils.book_new();
        const wsR = XLSX.utils.json_to_sheet(resumenRows);
        wsR['!cols'] = [{wch:10},{wch:12},{wch:18},{wch:35},{wch:14},{wch:14},{wch:16},{wch:14},{wch:16},{wch:10},{wch:12}];
        XLSX.utils.book_append_sheet(wb, wsR, 'Resumen');

        const wsD = XLSX.utils.json_to_sheet(detalleRows.length ? detalleRows : [{Mensaje:'Sin detalle.'}]);
        wsD['!cols'] = detalleRows.length
        ? [{wch:10},{wch:12},{wch:18},{wch:35},{wch:14},{wch:16},{wch:40},{wch:14},{wch:16},{wch:14},{wch:16},{wch:10},{wch:10}]
        : [{wch:40}];
        XLSX.utils.book_append_sheet(wb, wsD, 'Detalle');

        const hoy = new Date();
        const ts  = `${hoy.getFullYear()}${String(hoy.getMonth()+1).padStart(2,'0')}${String(hoy.getDate()).padStart(2,'0')}`;
        XLSX.writeFile(wb, `ConfirmadoVsSurtido_${ts}.xlsx`);
        } catch { alert('Ocurrió un error al exportar el Excel.'); }
        }

        /* ═══════════════════════════ INIT ═══════════════════════════ */
        function ponerFechaHoy() {
        const hoy = new Date();
        const ts  = `${hoy.getFullYear()}-${String(hoy.getMonth()+1).padStart(2,'0')}-${String(hoy.getDate()).padStart(2,'0')}`;
        $fechaInicio.value = ts;
        $fechaFin.value    = ts;
        }

        $frm.addEventListener('submit', async e => { e.preventDefault(); await cargarResumen(); });

        $btnLimpiar.addEventListener('click', async () => {
        $cliente.value = ''; $folio.value = ''; $tipo.value = '';
        seriesSeleccionadas.clear();
        renderSerieOptions();
        actualizarLabelSeries();
        ponerFechaHoy();
        await cargarResumen();
        });

        $btnExcel.addEventListener('click', () => exportarExcel());

        $tbody.addEventListener('click', async e => {
        const btn = e.target.closest('.js-expand');
        if (!btn) return;
        await cargarDetalle(btn.closest('tr'));
        });

        async function init() {
        ponerFechaHoy();
        await cargarSeries();
        await cargarResumen();
        }

       

        init();
        })();
    </script>
}
