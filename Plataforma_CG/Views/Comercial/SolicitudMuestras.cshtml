                </div>
            `;
        }

                function createProductionCard(req, isHistory = false) {
            const total = totalBoxes(req), linked = linkedLabels(req), pct = total ? Math.round(linked/total*100) : 0;
            let btnLiberar = '';
            if (!isHistory && linked === total && total > 0) {
                btnLiberar = `<div style="margin-top: 10px; border-top: 1px dashed var(--line); padding-top: 10px; text-align: right;">
                                <button type="button" class="success" onclick="liberarProduccion('${req.id}')">Finalizar Produccion (Enviar a Almacen)</button>
                              </div>`;
            }
            return `
                <div class="card" style="margin-bottom: 10px;">
                <div class="request-title" style="border:none;">
                    <div><h4>${req.id} · ${req.client}</h4><span class="mini">Proceso: ${formatDate(req.planning.processDate)} · ${req.planning.shift} · ${req.planning.line}</span></div>
                    ${badge(requestStatus(req))}
                </div>
                <div class="timeline">
                    <span class="step on"><i class="dot"></i>Solicitud</span>
                    <span class="step on"><i class="dot"></i>Planeada</span>
                    <span class="step ${linked>0?'on':''}"><i class="dot"></i>Produccion</span>
                    <span class="step ${linked===total?'on':''}"><i class="dot"></i>Completa</span>
                </div>
                <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
                <p class="mini">${linked}/${total} etiquetas ligadas.</p>
                <div class="items-list">
                    ${req.items.map(item => `
                        <div class="item-line">
                            <strong>Trabajar: ${item.workSku || item.sku} · ${item.product}</strong>
                            <small>Pedido: ${item.sku} · Cajas: ${item.boxes} · Ligadas: ${(item.labels||[]).length}<br>${item.spec}</small>
                        </div>
                    `).join('')}
                </div>
                <div class="label-grid" style="margin-top:10px;">
                    ${req.items.flatMap(item => (item.labels||[]).map((label,idx)=>labelCard(req,item,label,idx, isHistory))).join('') || '<div class="empty" style="grid-column: 1/-1;">Sin etiquetas ligadas aun.</div>'}
                </div>
                ${btnLiberar}
                </div>
            `;
        }
        

        function createTrackingRow(req, isHistory = false) {
            const total = totalBoxes(req), linked = linkedLabels(req), pct = total ? Math.round(linked/total*100) : 0;
            const labels = req.items.map(item=>`
                <b>Trabaja: ${item.workSku || item.sku}</b> ${item.product}<br>
                <span class="mini">Pide: ${item.sku} · ${item.spec}</span><br>
                <div style="margin-top:2px;">
                    ${(item.labels||[]).map(l=>`<span class="badge gray" style="margin-bottom:2px;">${l.code}</span>`).join(' ') || '<span class="badge pending">Sin etiqueta</span>'}
                </div>
            `).join('<hr style="border:0;border-top:1px solid #d8bcbc; margin: 4px 0;">');

            const selectHtml = isHistory
                ? `<b>${req.location}</b>`
                : `<select class="location-select" data-id="${req.id}">
                    ${['Comercial','Planeación','Producción','Almacén Refrigerado','Embarques','Surtido al cliente','Entregado a cliente'].map(loc=>`<option ${req.location===loc?'selected':''}>${loc}</option>`).join('')}
                    </select>`;

            return `
                <tr>
                <td><b>${req.id}</b><br><span class="mini">${formatDate(req.createdAt)}</span></td>
                <td>${req.client}<br><span class="mini">Vende: ${req.seller}</span></td>
                <td>${req.route}<br><span class="mini">${req.destination}</span></td>
                <td style="text-align:left;">${labels}</td>
                <td><b style="font-size:12px; color: #8b0000;">${linked}/${total}</b><div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div></td>
                <td>${selectHtml}</td>
                <td>${badge(requestStatus(req))}</td>
                </tr>
            `;
        }

               function labelCard(req, item, label, index, isHistory = false) {
            const fechaProc = formatDateTime(label.processedAt);
            const especie = req.species || 'Sin definir';
            const temp = item.temp || 'REFRIGERADO';

            const safeClient = (req.client || '').replace(/"/g, '&quot;');
            const safeProduct = (item.product || '').replace(/"/g, '&quot;');
            const safeSpec = (item.spec || '').replace(/"/g, '&quot;');
            const safeSeller = (req.seller || '').replace(/"/g, '&quot;');

            // Si es historial, no dibujamos el checkbox
            const checkboxHtml = isHistory ? '' : `
                <input type="checkbox" class="print-cb no-print" value="${label.code}" checked title="Seleccionar para imprimir"
                    data-req="${req.id}"
                    data-client="${safeClient}"
                    data-seller="${safeSeller}"
                    data-skureq="${item.sku}"
                    data-skuwork="${item.workSku || item.sku}"
                    data-product="${safeProduct}"
                    data-species="${especie}"
                    data-spec="${safeSpec}"
                    data-date="${fechaProc}"
                    data-op="${label.operator || ''}"
                    data-chain="${label.code}"
                    data-temp="${temp}"
                    style="position: absolute; top: 12px; right: 12px; width: 18px; height: 18px; cursor: pointer; z-index: 10;">
            `;

            return `
                <div class="label-card" style="position: relative; background: var(--panel-2); border: 1px solid var(--line); padding: 10px;">

                    ${checkboxHtml}

                    <div style="border-bottom: 2px solid var(--line); padding-bottom: 6px; margin-bottom: 8px; padding-right: 30px;">
                        <h4 style="margin: 0; font-size: 15px; color: #5c1a1a; font-weight: bold;">${label.code}</h4>
                    </div>

                    <div class="lc-body" style="background: #fff; padding: 8px; border: 1px solid var(--line); font-size: 11px; line-height: 1.5; text-align: left; color: #111;">
                        <b>Solicitud:</b> ${req.id}<br>
                        <b>Cliente:</b> ${req.client}<br>
                        <b>Especie:</b> ${especie}<br>
                        <b>SKU solicitado:</b> ${item.sku} · ${item.product}<br>
                        <b>SKU a trabajar:</b> <span style="font-weight: 900; color: #8b0000; font-size: 13px;">${item.workSku || item.sku}</span><br>
                        <b>Especificación:</b> ${item.spec}<br>
                        <b>Procesado:</b> ${fechaProc}<br>
                        <b>Operario:</b> ${label.operator || ''}<br>
                        <b>Etiqueta:</b> ${label.code}
                    </div>
                </div>
            `;
        }

        window.generarReporteGeneral = function() {
            if (!requests.length) { toast('No hay datos para generar el reporte.'); return; }

            const cargarImagen = (src) => new Promise((resolve) => {
                const img = new Image();
                img.crossOrigin = 'Anonymous';
                img.onload = () => resolve(img);
                img.onerror = () => resolve(null);
                img.src = src;
            });

            async function descargarPDF() {
                toast('Generando reporte PDF...');
                const { jsPDF } = window.jspdf;
                const doc = new jsPDF('landscape', 'mm', 'letter');
                const pageW = doc.internal.pageSize.getWidth();
                const pageH = doc.internal.pageSize.getHeight();
                const mg = 12;
                let y = mg;

                const logoCG = await cargarImagen('/images/LOGO_CARNESG.jpg');
                const logoTIF = await cargarImagen('/images/logoTIF.png');

                function header() {
                    if (logoCG) doc.addImage(logoCG, 'JPEG', mg, 8, 30, 12);
                    if (logoTIF) doc.addImage(logoTIF, 'PNG', pageW - mg - 16, 8, 16, 12);

                    doc.setFontSize(16);
                    doc.setTextColor(139, 0, 0);
                    doc.setFont('helvetica', 'bold');
                    doc.text('REPORTE GENERAL DE MUESTRAS', pageW / 2, 14, { align: 'center' });

                    doc.setFontSize(8);
                    doc.setTextColor(100);
                    doc.setFont('helvetica', 'normal');
                    doc.text('Sistema Integral de Gestión Operativa (SIGO) - Comercial', pageW / 2, 18, { align: 'center' });
                    doc.text('Generado: ' + new Date().toLocaleString('es-MX'), pageW / 2, 22, { align: 'center' });

                    doc.setDrawColor(139, 0, 0);
                    doc.setLineWidth(0.5);
                    doc.line(mg, 26, pageW - mg, 26);
                    y = 32;
                }

                function footer() {
                    doc.setFontSize(7);
                    doc.setTextColor(120);
                    doc.setFont('helvetica', 'normal');
                    doc.text('CARNES G S.A. DE C.V. - TIF 776 | Carretera Estatal N212 San Juan de los Lagos, Jal.', pageW / 2, pageH - 6, { align: 'center' });
                }

                header();

                // Cálculos del resumen
                const total = requests.length;
                const pendientes = requests.filter(r => requestStatus(r) === 'Pendiente').length;
                const planeadas = requests.filter(r => requestStatus(r) === 'Planeada').length;
                const produccion = requests.filter(r => r.planning && requestStatus(r) !== 'Pendiente' && requestStatus(r) !== 'Planeada' && requestStatus(r) !== 'Cancelada').length;
                const completadas = requests.filter(r => requestStatus(r) === 'En almacén' || requestStatus(r) === 'Surtido al cliente').length;
                const totalCajas = requests.reduce((s, r) => s + totalBoxes(r), 0);
                const totalEtqs = requests.reduce((s, r) => s + linkedLabels(r), 0);

                doc.setFontSize(10);
                doc.setTextColor(139, 0, 0);
                doc.setFont('helvetica', 'bold');
                doc.text('Resumen Operativo', mg, y);
                y += 4;

                const resumen = [
                    ['Total Solicitudes', '' + total, 'En Producción', '' + produccion],
                    ['Pendientes de Planeación', '' + pendientes, 'Completadas / Surtidas', '' + completadas],
                    ['Planeadas (Espera)', '' + planeadas, 'Cajas Totales / Etiquetas', totalEtqs + ' / ' + totalCajas]
                ];

                doc.autoTable({
                    startY: y,
                    body: resumen,
                    theme: 'plain',
                    styles: { fontSize: 8, cellPadding: 1.5 },
                    columnStyles: {
                        0: { fontStyle: 'bold', textColor: [0, 0, 0], cellWidth: 40 },
                        1: { cellWidth: 20, textColor: [139, 0, 0], fontStyle: 'bold' },
                        2: { fontStyle: 'bold', textColor: [0, 0, 0], cellWidth: 40 },
                        3: { cellWidth: 30, textColor: [139, 0, 0], fontStyle: 'bold' }
                    },
                    margin: { left: mg }
                });
                y = doc.lastAutoTable.finalY + 8;

                const estados = [
                    { label: 'PENDIENTES', filter: r => requestStatus(r) === 'Pendiente' },
                    { label: 'PLANEADAS', filter: r => requestStatus(r) === 'Planeada' },
                    { label: 'EN PRODUCCIÓN', filter: r => r.planning && (requestStatus(r) === 'Producción parcial' || requestStatus(r) === 'Cumplido producción') },
                    { label: 'EN ALMACÉN', filter: r => requestStatus(r) === 'En almacén' },
                    { label: 'SURTIDAS / ENTREGADAS', filter: r => requestStatus(r) === 'Surtido al cliente' },
                    { label: 'CANCELADAS', filter: r => requestStatus(r) === 'Cancelada' }
                ];

                estados.forEach(e => {
                    const items = requests.filter(e.filter);
                    if (!items.length) return;

                    if (y > pageH - 40) { doc.addPage(); y = mg + 5; header(); }

                    const rows = items.map(r => [
                        r.id,
                        r.client,
                        r.seller,
                        r.species || '-',
                        r.route + ' / ' + r.destination,
                        formatDate(r.requestedDate),
                        r.items.map(i => i.sku + ' (' + i.boxes + ' cjs)' + (i.workSku && i.workSku !== i.sku ? ' -> Trab: ' + i.workSku : '')).join('\n'),
                        linkedLabels(r) + '/' + totalBoxes(r)
                    ]);

                    doc.autoTable({
                        startY: y,
                        head: [[e.label, 'Cliente', 'Vendedor', 'Esp.', 'Ruta / Destino', 'Fecha Req.', 'Artículos (Cajas)', 'Avance']],
                        body: rows,
                        theme: 'grid',
                        tableLineColor: [200, 200, 200],
                        tableLineWidth: 0.1,
                        headStyles: { fillColor: [139, 0, 0], textColor: [255, 255, 255], fontStyle: 'bold', fontSize: 7, halign: 'center' },
                        bodyStyles: { fontSize: 7, cellPadding: 2, textColor: [30, 30, 30], valign: 'middle' },
                        alternateRowStyles: { fillColor: [249, 245, 245] },
                        columnStyles: {
                            0: { cellWidth: 20, fontStyle: 'bold', textColor: [139, 0, 0] },
                            1: { cellWidth: 42 },
                            2: { cellWidth: 26 },
                            3: { cellWidth: 10, halign: 'center' },
                            4: { cellWidth: 38 },
                            5: { cellWidth: 18, halign: 'center' },
                            6: { cellWidth: 50 },
                            7: { cellWidth: 14, halign: 'center', fontStyle: 'bold' }
                        },
                        margin: { left: mg, right: mg },
                        didParseCell: function(data) {
                            if (data.section === 'head' && data.row.index === 0 && data.column.index === 0) {
                                data.cell.styles.halign = 'left';
                            }
                        }
                    });
                    y = doc.lastAutoTable.finalY + 8;
                });

                const totalPages = doc.internal.getNumberOfPages();
                for (let j = 1; j <= totalPages; j++) {
                    doc.setPage(j);
                    footer();
                    doc.setFontSize(7);
                    doc.setTextColor(120);
                    doc.text('Página ' + j + ' de ' + totalPages, pageW - mg, pageH - 6, { align: 'right' });
                }

                doc.save('Reporte_Muestras_' + new Date().toISOString().slice(0, 10) + '.pdf');
            }

            // Descarga o usa la librería jsPDF
            if (typeof window.jspdf === 'undefined' || typeof window.jspdf.jsPDF === 'undefined') {
                toast('Preparando motor PDF...');
                const s1 = document.createElement('script');
                s1.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
                s1.onload = function() {
                    const s2 = document.createElement('script');
                    s2.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js';
                    s2.onload = descargarPDF;
                    document.head.appendChild(s2);
                };
                document.head.appendChild(s1);
            } else {
                descargarPDF();
            }
        }

