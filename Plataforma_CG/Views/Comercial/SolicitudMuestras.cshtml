@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Solicitud y Trazabilidad de Muestras";
    var usuarioLogueado = User.Identity?.Name ?? "";
}

<style>
    /* FORZAR PANTALLA COMPLETA SIN DAÑAR EL MENÚ PRINCIPAL */
    html, body {
        background: #f0dede !important;
        overflow-x: hidden;
    }

    .container,
    .container-fluid,
    .pb-3,
    main {
        max-width: 100% !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
        padding-bottom: 0 !important;
    }

    :root {
        --bg: #f0dede;
        --panel: #f8eeee;
        --panel-2: #f1dede;
        --line: #c79d9d;
        --text: #3b1717;
        --white: #ffffff;
        --vino-border: #9a5a5a;
        --font: Tahoma, sans-serif;
    }

    /* CONTENEDOR PRINCIPAL */
    .app-shell {
        width: 100%;
        max-width: 100%;
        margin: 0;
        padding: 0;
        font-family: var(--font);
        font-size: 11px;
        color: var(--text);
        background: var(--bg) !important;
        min-height: calc(100vh - 60px);
        display: flex;
        flex-direction: column;
    }

        .app-shell * {
            box-sizing: border-box;
        }

    /* HEADER */
    .module-header {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #4a0000;
        flex-shrink: 0;
        padding: 10px 10px 0 10px;
        box-shadow: 0 4px 8px rgba(0,0,0,.15);
        z-index: 100;
        position: sticky;
        top: 60;
    }

    .header-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 10px;
    }

    .brand {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .brand-mark {
        width: 34px;
        height: 34px;
        display: grid;
        place-items: center;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.18);
        font-weight: bold;
        font-size: 14px;
        color: #fff;
        border-radius: 2px;
    }

    .brand h1 {
        font-size: 14px;
        margin: 0;
        font-weight: bold;
        color: #fff;
    }

    .brand small {
        display: block;
        color: #f4d7d7;
        font-size: 10px;
        font-weight: normal;
        margin-top: 2px;
    }

    .header-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .module-tabs {
        display: flex;
        gap: 5px;
        overflow-x: auto;
        scrollbar-width: none;
        padding: 0 10px;
        margin-top: 5px;
        position: relative;
        bottom: -1px;
    }

        .module-tabs::-webkit-scrollbar {
            display: none;
        }

    .nav-btn {
        background: rgba(0,0,0,0.15);
        border: 1px solid rgba(255,255,255,0.1);
        border-bottom: none;
        color: #f4d7d7;
        padding: 10px 18px;
        font-weight: bold;
        font-size: 12px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        border-radius: 8px 8px 0 0;
        white-space: nowrap;
        transition: all 0.25s ease;
    }

        .nav-btn:hover {
            background: rgba(255,255,255,0.15);
            color: #fff;
        }

        .nav-btn.active {
            background: var(--bg) !important;
            color: #5c1a1a !important;
            border-color: transparent !important;
            padding-top: 12px;
            box-shadow: 0 -4px 10px rgba(0,0,0,0.05);
        }

        /* Píldora numérica de las pestañas */
        .nav-btn .pill {
            background: rgba(255,255,255,0.2);
            color: #fff;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            font-size: 11px;
            transition: 0.3s;
        }

        .nav-btn.active .pill {
            background: #8b0000;
            color: #fff !important;
        }

    /* AREA DE CONTENIDO PRINCIPAL */
    .module-main {
        flex: 1;
        padding: 10px;
        background: var(--bg);
        min-width: 0;
    }

    /* BOTONES */
    .app-shell button:not(.nav-btn), .app-shell .btn,
    .modal-custom button:not(.nav-btn), .modal-custom .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        height: 26px;
        padding: 0 12px;
        border: 1px solid transparent;
        border-radius: 0;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        color: #fff !important;
        font-size: 11px;
        font-weight: bold;
        line-height: 1;
        text-decoration: none;
        white-space: nowrap;
        cursor: pointer;
        border-color: #7a2d2d;
    }

        .app-shell button:not(.nav-btn):hover, .app-shell .btn:hover,
        .modal-custom button:not(.nav-btn):hover, .modal-custom .btn:hover {
            filter: brightness(1.1);
            color: #fff !important;
        }

        .app-shell button.secondary, .app-shell .btn.secondary,
        .modal-custom button.secondary, .modal-custom .btn.secondary {
            background: linear-gradient(#fffefe, #ecd7d7) !important;
            border-color: var(--vino-border) !important;
            color: #4a1111 !important;
        }

            .app-shell button.secondary:hover, .app-shell .btn.secondary:hover,
            .modal-custom button.secondary:hover, .modal-custom .btn.secondary:hover {
                background: #fff !important;
                color: #111 !important;
            }

        .app-shell button.ghost, .app-shell .btn.ghost,
        .modal-custom button.ghost, .modal-custom .btn.ghost {
            background: transparent;
            color: #8b0000 !important;
            border: 1px dashed #c79d9d;
        }

            .app-shell button.ghost:hover, .app-shell .btn.ghost:hover,
            .modal-custom button.ghost:hover, .modal-custom .btn.ghost:hover {
                background: #fffafa;
                color: #5c0000 !important;
                border-color: #8b0000;
            }

    .app-shell button.success, .modal-custom button.success {
        background: linear-gradient(180deg, #27ae60 0%, #1f9a54 55%, #198754 100%) !important;
        border-color: #157347 !important;
    }

    .app-shell button.danger, .modal-custom button.danger {
        background: linear-gradient(180deg, #dc3545 0%, #c82333 55%, #bd2130 100%) !important;
        border-color: #b02a37 !important;
    }

    /* TARJETAS Y CONTENEDORES */
    .grid {
        display: grid;
        gap: 10px;
        min-width: 0;
    }

        .grid.cols-4 {
            grid-template-columns: repeat(4,minmax(0,1fr));
            margin: 0 0 10px;
        }

        .grid.cols-3 {
            grid-template-columns: repeat(3,minmax(0,1fr));
        }

        .grid.cols-2 {
            grid-template-columns: repeat(2,minmax(0,1fr));
        }

    .app-shell .card, .modal-custom .card {
        background: var(--panel) !important;
        border: 1px solid var(--line) !important;
        border-radius: 0 !important;
        padding: 12px;
        color: var(--text) !important;
        min-width: 0;
    }

    .form-subtitle {
        font-size: 12px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        padding: 4px 8px;
        margin: 0 0 10px 0;
        border-bottom: 1px solid #6b1f1f;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .kpi {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-height: 70px;
        background: var(--white) !important;
        border: 1px solid var(--line);
        padding: 10px;
    }

        .kpi small {
            color: #5c1a1a;
            font-weight: bold;
            text-transform: uppercase;
            font-size: 10px;
        }

        .kpi strong {
            font-size: 18px;
            line-height: 1;
            color: #8b0000;
        }

        .kpi .hint {
            font-size: 10px;
            color: #666;
        }

    .section {
        display: none;
        animation: fadeIn 0.2s ease;
    }

        .section.active {
            display: block;
        }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(3px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .section-header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        margin: 10px 0 8px;
        gap: 10px;
        flex-wrap: wrap;
    }

        .section-header h3 {
            margin: 0;
            font-size: 13px;
            font-weight: bold;
            color: #5c1a1a;
        }

        .section-header p {
            margin: 4px 0 0;
            color: #444;
            font-size: 11px;
        }

    /* FORMULARIOS */
    .app-shell label, .modal-custom label {
        display: block;
        color: #5c1a1a !important;
        font-weight: bold;
        font-size: 11px;
        margin-bottom: 4px;
    }

    .app-shell input, .app-shell select, .app-shell textarea,
    .modal-custom input, .modal-custom select, .modal-custom textarea {
        width: 100%;
        border-radius: 0;
        border: 1px solid #b48787 !important;
        background: #fffdfd !important;
        color: #421414 !important;
        font-size: 11px;
        min-height: 26px;
        padding: 2px 6px;
        outline: none;
    }

    .app-shell textarea, .modal-custom textarea {
        min-height: 50px;
        resize: vertical;
        line-height: 1.3;
    }

        .app-shell input:focus, .app-shell select:focus, .app-shell textarea:focus,
        .modal-custom input:focus, .modal-custom select:focus, .modal-custom textarea:focus {
            border-color: #8b0000 !important;
            background: #fff !important;
        }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(3,minmax(0,1fr));
        gap: 10px;
        margin-bottom: 10px;
        background: var(--panel-2);
        padding: 10px;
        border: 1px solid var(--line);
    }

        .form-grid.two {
            grid-template-columns: repeat(2,minmax(0,1fr));
        }

        .form-grid .full {
            grid-column: 1/-1;
        }

    /* TABLAS */
    .app-shell .table-wrap, .modal-custom .table-wrap {
        width: 100%;
        overflow: visible;
        background: #fffafa !important;
        border: 1px solid var(--line);
    }

    .app-shell table, .modal-custom table {
        width: 100%;
        border-collapse: separate !important;
        border-spacing: 0 !important;
        font-size: 10px;
        background: #fffafa !important;
    }

    .app-shell th, .app-shell td, .modal-custom th, .modal-custom td {
        padding: 6px 8px; /* Un poco más de aire */
        text-align: center;
        vertical-align: middle;
        border-bottom: 1px solid #d8bcbc !important;
        border-right: 1px solid #d8bcbc !important;
        color: #111 !important;
    }

    .app-shell th, .modal-custom th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        color: #fff !important;
        font-weight: bold;
        font-size: 11px;
        border-right: 1px solid #8e3b3b !important;
        border-bottom: 1px solid #ffb3b3 !important;
        white-space: nowrap; /* Evita que los títulos se partan a la mitad */
    }

    .app-shell tbody tr:nth-child(even) td, .modal-custom tbody tr:nth-child(even) td {
        background: #f9eded !important;
    }

    .app-shell tbody tr:hover td, .modal-custom tbody tr:hover td {
        background: #f4dddd !important;
    }

    .app-shell td:first-child, .app-shell th:first-child,
    .modal-custom td:first-child, .modal-custom th:first-child {
        border-left: 1px solid #d8bcbc;
    }

    .app-shell th:first-child, .modal-custom th:first-child {
        border-left: 1px solid #8e3b3b !important;
    }

    /* BADGES Y ESTADOS */
    .app-shell .badge, .modal-custom .badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 2px 6px;
        border-radius: 2px;
        font-size: 9px;
        font-weight: bold;
        border: 1px solid transparent;
        text-decoration: none;
    }

        .app-shell .badge.pending, .modal-custom .badge.pending {
            background: #fff7ed;
            color: #9a3412 !important;
            border-color: #fed7aa;
        }

        .app-shell .badge.planned, .modal-custom .badge.planned {
            background: #eff6ff;
            color: #1d4ed8 !important;
            border-color: #bfdbfe;
        }

        .app-shell .badge.progress, .modal-custom .badge.progress {
            background: #fef9c3;
            color: #854d0e !important;
            border-color: #fde68a;
        }

        .app-shell .badge.done, .modal-custom .badge.done {
            background: #dcfce7;
            color: #166534 !important;
            border-color: #bbf7d0;
        }

        .app-shell .badge.gray, .modal-custom .badge.gray {
            background: #333;
            color: #fff !important;
            border-color: #111;
        }

    /* BADGES Y ESTADOS */
    .app-shell .badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 2px 6px;
        border-radius: 2px;
        font-size: 9px;
        font-weight: bold;
        border: 1px solid transparent;
    }

        .app-shell .badge.pending {
            background: #fff7ed;
            color: #9a3412;
            border-color: #fed7aa;
        }

        .app-shell .badge.planned {
            background: #eff6ff;
            color: #1d4ed8;
            border-color: #bfdbfe;
        }

        .app-shell .badge.progress {
            background: #fef9c3;
            color: #854d0e;
            border-color: #fde68a;
        }

        .app-shell .badge.done {
            background: #dcfce7;
            color: #166534;
            border-color: #bbf7d0;
        }

        .app-shell .badge.gray {
            background: #333;
            color: #fff;
            border-color: #111;
        }

    .request-card {
        display: grid;
        grid-template-columns: 1.2fr .9fr;
        gap: 10px;
        align-items: start;
        border-left: 4px solid #8b0000 !important;
        background: var(--white) !important;
    }

    .request-title {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 10px;
        margin-bottom: 8px;
        border-bottom: 1px solid var(--line);
        padding-bottom: 6px;
    }

        .request-title h4 {
            margin: 0;
            font-size: 13px;
            color: #8b0000;
            font-weight: bold;
        }

    .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-top: 6px;
    }

        .meta span {
            background: var(--panel-2);
            color: #5c1a1a;
            border: 1px solid var(--line);
            padding: 2px 6px;
            font-size: 10px;
        }

    .items-list {
        display: grid;
        gap: 6px;
        margin-top: 8px;
    }

    .item-line {
        border: 1px solid var(--line);
        padding: 6px 8px;
        background: #fffdfd;
    }

        .item-line strong {
            display: block;
            margin-bottom: 2px;
            color: #111;
            font-size: 11px;
        }

        .item-line small {
            color: #444;
            font-size: 10px;
        }

    .progress-bar {
        height: 8px;
        background: var(--panel-2);
        border: 1px solid var(--line);
        margin-top: 5px;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg,#5c0000,#b30000);
        width: 0%;
        transition: .25s ease;
    }

    .mini {
        font-size: 10px;
        color: #444;
    }

    .split-panel {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 10px;
        align-items: start;
    }

    .scan-panel {
        position: sticky;
        top: 10px;
        background: var(--white) !important;
    }

    .label-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(220px,1fr));
        gap: 10px;
    }

    .label-card {
        background: var(--panel-2);
        border: 1px solid var(--line);
        padding: 10px;
    }

        .label-card h4 {
            margin: 0 0 6px;
            font-size: 12px;
            color: #5c1a1a;
            font-weight: bold;
        }

        .label-card img {
            display: block;
            margin: 6px 0;
            border: 1px solid var(--line);
            padding: 4px;
            background: #fff;
        }

    .label-data {
        font-size: 10px;
        color: #111;
        line-height: 1.4;
    }

        .label-data b {
            color: #5c1a1a;
        }

    .empty {
        border: 1px dashed var(--line);
        padding: 20px;
        text-align: center;
        color: #5c1a1a;
        background: var(--panel-2);
        font-size: 11px;
        font-weight: bold;
    }

    .timeline {
        display: flex;
        gap: 6px;
        align-items: center;
        flex-wrap: wrap;
        background: var(--panel-2);
        padding: 6px 10px;
        border: 1px solid var(--line);
        margin-bottom: 10px;
    }

    .step {
        display: flex;
        align-items: center;
        gap: 4px;
        color: #666;
        font-size: 10px;
        font-weight: bold;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #ccc;
        border: 1px solid #999;
    }

    .step.on {
        color: #8b0000;
    }

        .step.on .dot {
            background: #8b0000;
            border-color: #5c0000;
        }

    /* MODALES Y TOAST */
    .toast {
        position: fixed;
        right: 18px;
        bottom: 18px;
        background: #3b1717;
        color: white;
        padding: 10px 14px;
        border: 1px solid #8b0000;
        opacity: 0;
        transform: translateY(16px);
        transition: .25s ease;
        z-index: 2000;
        font-size: 11px;
        font-weight: bold;
    }

        .toast.show {
            opacity: 1;
            transform: translateY(0);
        }

    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.6);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 20px;
        z-index: 1900;
    }

        .modal-backdrop-custom.show {
            display: flex;
        }

    .modal-custom {
        background: var(--bg);
        border: 1px solid #8b0000;
        max-width: 1000px;
        width: 100%;
        max-height: 90vh;
        overflow: auto;
        padding: 0;
        box-shadow: 0 10px 30px rgba(0,0,0,.3);
    }

    .modal-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 6px 10px;
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
        border-bottom: 1px solid #5c0000;
        color: #fff;
    }

        .modal-head h3 {
            margin: 0;
            color: #fff;
            font-size: 12px;
            font-weight: bold;
        }

    .modal-custom > textarea {
        border: 0 !important;
        background: #fffafa !important;
        width: 100%;
        min-height: 400px;
        font-family: Consolas,monospace;
        color: #111 !important;
        padding: 10px;
    }

    .print-only {
        display: none;
    }


    /* VALIDACIÓN DE ETIQUETAS CONTRA MEAT */
    .scan-validation-box {
        min-height: 54px;
        padding: 8px 9px;
        border: 1px solid var(--line);
        background: #fffafa;
        color: #5c1a1a;
        font-size: 10px;
        line-height: 1.45;
    }

        .scan-validation-box strong {
            display: block;
            margin-bottom: 2px;
            font-size: 11px;
        }

        .scan-validation-box.idle {
            border-left: 4px solid #9a5a5a;
        }

        .scan-validation-box.loading {
            border-left: 4px solid #d39b20;
            background: #fff8e8;
            color: #765000;
        }

        .scan-validation-box.ok {
            border-left: 4px solid #198754;
            background: #ecf9f1;
            color: #145c36;
        }

        .scan-validation-box.error {
            border-left: 4px solid #bd2130;
            background: #fff0f1;
            color: #8b101c;
        }

    #scanLabel {
        text-transform: uppercase;
        font-family: Consolas, "Courier New", monospace;
        font-weight: bold;
        letter-spacing: .03em;
    }

        #scanLabel.scan-invalid {
            border-color: #bd2130 !important;
            background: #fff0f1 !important;
        }

        #scanLabel.scan-valid {
            border-color: #198754 !important;
            background: #ecf9f1 !important;
        }


    /* =========================================================
                       TRACKING AUTOMÁTICO DE ETIQUETAS EN MEAT: TIF + P1
                       ========================================================= */
    .meat-location-list {
        display: grid;
        gap: 5px;
        min-width: 245px;
    }

    .meat-location-card {
        padding: 7px 8px;
        border: 1px solid #c79d9d;
        background: #fffdfd;
        text-align: left;
        line-height: 1.28;
    }

        .meat-location-card strong,
        .meat-location-card span,
        .meat-location-card small {
            display: block;
        }

        .meat-location-card strong {
            color: #5c1a1a;
            font-size: 10px;
            overflow-wrap: anywhere;
        }

        .meat-location-card span {
            margin-top: 2px;
            color: #222;
            font-size: 10px;
            font-weight: bold;
        }

        .meat-location-card small {
            margin-top: 3px;
            color: #555;
            font-size: 9px;
            overflow-wrap: anywhere;
        }

        .meat-location-card.sold {
            border-left: 4px solid #198754;
            background: #eefbf4;
        }

        .meat-location-card.stock {
            border-left: 4px solid #0d6efd;
            background: #f0f6ff;
        }

        .meat-location-card.warning {
            border-left: 4px solid #d97706;
            background: #fff8eb;
        }

        .meat-location-card.missing {
            border-left: 4px solid #b42318;
            background: #fff1f0;
        }

        .meat-location-card.loading {
            border-left: 4px solid #777;
