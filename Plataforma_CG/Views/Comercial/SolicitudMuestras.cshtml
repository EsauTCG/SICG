            }, 1000);
        }

        // FUNCIONES DE ACTUALIZACION DE PANTALLA
        function renderRequestList(){
            const pendientes = requests.filter(r => requestStatus(r) === 'Pendiente');
            histSolicitud = requests.filter(r => requestStatus(r) !== 'Pendiente');
            let html = pendientes.map(r => createRequestCard(r)).join('');
            if(qs('#requestList')) qs('#requestList').innerHTML = html || '<div class="empty">No hay solicitudes nuevas.</div>';
            if(qs('#btnHistSolicitudes')) qs('#btnHistSolicitudes').innerHTML = `Ver historial (${histSolicitud.length})`;
        }

        function renderPlanning(){
            const pendientes = requests.filter(r => requestStatus(r) === 'Pendiente');
            histPlaneacion = requests.filter(r => requestStatus(r) !== 'Pendiente' && requestStatus(r) !== 'Cancelada');
            if(qs('#planningList')) qs('#planningList').innerHTML = pendientes.length ? pendientes.map(r => createPlanningCard(r, false)).join('') : '<div class="empty">No hay solicitudes pendientes de planeacion.</div>';
            if(qs('#btnHistPlaneacion')) qs('#btnHistPlaneacion').innerHTML = `Ver historial (${histPlaneacion.length})`;
        }

        function renderProduction() {
            const prodList = requests.filter(r => r.planning);
            const activos = prodList.filter(r => {
                const st = requestStatus(r);
                return st === 'Planeada' || st === 'Producción parcial' || st === 'Cumplido producción';
            });
            histProduccion = prodList.filter(r => {
                const st = requestStatus(r);
                return st === 'En almacén' || st === 'Surtido al cliente';
            });
            if(qs('#productionList')) qs('#productionList').innerHTML = activos.length ? activos.map(r => createProductionCard(r, false)).join('') : '<div class="empty">No hay muestras en produccion activa.</div>';
            if(qs('#btnHistProduccion')) qs('#btnHistProduccion').innerHTML = `Ver historial (${histProduccion.length})`;
        }

        function renderTracking(){
            const q = (qs('#trackSearch')?.value || '').toLowerCase();
            const filter = qs('#trackStatus')?.value || '';
            const dateFrom = qs('#trackDateFrom')?.value || '';
            const dateTo = qs('#trackDateTo')?.value || '';

            let list = requests.filter(req => {
                if(requestStatus(req) === 'Cancelada') return false;
                const hay = [req.id,req.client,req.seller,req.species,req.route,req.destination, ...req.items.flatMap(i=>[i.sku,i.workSku,i.product,i.spec,...(i.labels||[]).map(l=>l.code)])].join(' ').toLowerCase();
                const status = requestStatus(req);
                const reqDate = (req.createdAt || '').substring(0, 10);
                return (!q || hay.includes(q))
                    && (!filter || status === filter)
                    && (!dateFrom || reqDate >= dateFrom)
                    && (!dateTo || reqDate <= dateTo);
            });

            const activos = list.filter(r => requestStatus(r) !== 'Surtido al cliente' && r.location !== 'Entregado a cliente');
            histTracking = list.filter(r => requestStatus(r) === 'Surtido al cliente' || r.location === 'Entregado a cliente');

            if(qs('#trackingBody')) qs('#trackingBody').innerHTML = activos.length ? activos.map(r => createTrackingRow(r, false)).join('') : '<tr><td colspan="8" class="empty">No hay resultados activos con esos filtros.</td></tr>';
            if(qs('#btnHistTracking')) qs('#btnHistTracking').innerHTML = `Ver Entregadas (${histTracking.length})`;
        }

        window.abrirHistorial = function(tab) {
            const limite = 100;
            const container = qs('#historialContentContainer');
            const title = qs('#historialTitle');
            container.className = 'grid cols-1';

            if(tab === 'solicitud') {
                title.textContent = 'Historial de Solicitudes (últimos ' + limite + ')';
                const lista = histSolicitud.slice(0, limite);
                container.innerHTML = lista.length ? lista.map(req => createRequestCard(req)).join('') : '<div class="empty">No hay historial.</div>';
            }
            else if(tab === 'planeacion') {
                title.textContent = 'Historial de Planeacion (últimos ' + limite + ')';
                const lista = histPlaneacion.slice(0, limite);
                container.innerHTML = lista.length ? lista.map(req => createPlanningCard(req, true)).join('') : '<div class="empty">No hay historial.</div>';
            }
            else if(tab === 'produccion') {
                title.textContent = 'Historial de Produccion (últimos ' + limite + ')';
                const lista = histProduccion.slice(0, limite);
                container.innerHTML = lista.length ? lista.map(req => createProductionCard(req, true)).join('') : '<div class="empty">No hay historial.</div>';
            }
            else if(tab === 'tracking') {
                title.textContent = 'Historial de Tracking (últimos ' + limite + ')';
                container.className = 'table-wrap card';
                const lista = histTracking.slice(0, limite);
                let html = `<table style="margin:0; width:100%; border:none;">
                    <thead><tr><th>Folio</th><th>Cliente</th><th>Ruta / destino</th><th>SKU y etiquetas</th><th>Cumplimiento</th><th>Ubicacion</th><th>Estatus</th></tr></thead><tbody>`;
                html += lista.length ? lista.map(req => createTrackingRow(req, true)).join('') : '<tr><td colspan="7" class="empty">No hay historial.</td></tr>';
                html += `</tbody></table>`;
                container.innerHTML = html;
            }
            qs('#modalHistorial').classList.add('show');
        }

        function renderScanSelectors() {
            const reqSelect = qs('#scanRequest');
            if(!reqSelect) return;

            const planned = requests.filter(r => {
                if (!r.planning || requestStatus(r) === 'Surtido al cliente' || requestStatus(r) === 'En almacén') return false;
                return linkedLabels(r) < totalBoxes(r);
            });

            if (planned.length === 0) {
                reqSelect.innerHTML = '<option value="">No hay muestras pendientes de etiquetas</option>';
            } else {
                reqSelect.innerHTML = planned.map(r => `<option value="${r.id}">${r.id} · ${r.client}</option>`).join('');
            }

            updateItemSelector();
            if(qs('#scanLabel')) qs('#scanLabel').value = nextDestCode();
        }

        function updateItemSelector() {
            const reqSelect = qs('#scanRequest');
            const itemSelect = qs('#scanItem');
            if(!reqSelect || !itemSelect) return;

            const req = requests.find(r => r.id === reqSelect.value);
            if (!req) { itemSelect.innerHTML = '<option value="">Seleccione una solicitud...</option>'; return; }

            const validItems = req.items.filter(item => {
                const left = Number(item.boxes) - (item.labels?.length || 0);
                return left > 0;
            });

            if (validItems.length === 0) {
                itemSelect.innerHTML = '<option value="" disabled>✓ Todos los SKUs completados</option>';
            } else {
                itemSelect.innerHTML = validItems.map(item => {
                    const left = Number(item.boxes) - (item.labels?.length || 0);
                    return `<option value="${item.uid}">Trabajar ${item.workSku || item.sku} · faltan ${left} caja(s)</option>`;
                }).join('');
            }
        }

        window.cancelarSolicitud = async function(id) {
            const motivo = prompt(`Escriba el motivo de cancelacion para ${id}:`);
            if (!motivo) return;

            try {
                const response = await fetch(`@Url.Action("CancelarSolicitud", "Comercial")?id=${id}&motivo=${encodeURIComponent(motivo)}`, { method: 'POST' });
                const data = await response.json();
                if (data.ok) {
                    toast('Solicitud cancelada.');
                    loadData();
                } else {
                    toast('Error: ' + data.mensaje);
                }
            } catch (err) {
                toast('No hay conexion al servidor.');
            }
        };

        window.liberarProduccion = async function(reqId) {
            const req = requests.find(r => r.id === reqId);
            if (!req) return;

            try {
                const response = await fetch(`@Url.Action("ActualizarUbicacion", "Comercial")?solicitudId=${reqId}&ubicacion=Almacén Refrigerado`, { method: 'POST' });
                const data = await response.json();
                if (data.ok) {
                    toast(`Produccion finalizada. Enviado a almacen.`);
                    loadData();
                } else {
                    toast("Error del servidor: " + data.mensaje);
                }
            } catch(err) {
                console.warn("Backend no disponible...");
                req.location = 'Almacén Refrigerado';
                renderAll();
                toast(`Finalizado en modo local.`);
            }
        };

        function renderAll(){
            renderKpis();
            renderRequestList();
            renderPlanning();
            renderScanSelectors();
            renderProduction();
            renderTracking();
        }

        document.addEventListener('click', e => {
            const nav = e.target.closest('.nav-btn');
            if (nav && nav.style.display !== 'none') {
                qsa('.nav-btn').forEach(b=>b.classList.remove('active')); nav.classList.add('active');
                qsa('.section').forEach(s=>s.classList.remove('active')); qs('#'+nav.dataset.section).classList.add('active');
                if(nav.dataset.section === 'produccion') renderProduction();
            }

            if(e.target.classList.contains('remove-item')){
                e.target.closest('tr').remove();
                if(!qs('#itemsBody tr')) addItem();
            }

            if(e.target.id === 'modalHistorial') qs('#modalHistorial').classList.remove('show');
            if(e.target.id === 'modalAdminPermisos') qs('#modalAdminPermisos').classList.remove('show');


            if (!e.target.closest('.sku-wrapper')) {
                qsa('.sku-dropdown.show').forEach(d => d.classList.remove('show'));
            }

            // Abrir/Cerrar buscador de SKU
            const skuDisplay = e.target.closest('.sku-display');
            if (skuDisplay) {
                e.stopPropagation();
                qsa('.sku-dropdown.show').forEach(d => d.classList.remove('show'));

                const wrapper = skuDisplay.closest('.sku-wrapper');
                const dropdown = wrapper.querySelector('.sku-dropdown');
                const search = wrapper.querySelector('.sku-search');
                const items = wrapper.querySelectorAll('.sku-options li');

                dropdown.classList.toggle('show');
                if (dropdown.classList.contains('show')) {
                    search.value = '';
                    const esPlaneacion = !!wrapper.closest('.planning-form');
                    items.forEach(li => {
                        if (esPlaneacion) {
                            const codigo = (li.dataset.codigo || '').toUpperCase();
                            li.classList.toggle('hidden', !codigo.includes('PR'));
                        } else {
                            li.classList.remove('hidden');
                        }
                    });
                    search.focus();
                }
            }

            // Seleccionar opcion de SKU
            const skuLi = e.target.closest('.sku-options li');
            if (skuLi) {
                const wrapper = skuLi.closest('.sku-wrapper');
                wrapper.querySelector('.sku-display').textContent = skuLi.dataset.codigo;
                wrapper.querySelector('.item-sku').value = skuLi.dataset.codigo;

                const fila = wrapper.closest('tr');
                if (fila) {
                    const productInput = fila.querySelector('.item-product');
                    if(productInput) productInput.value = skuLi.dataset.nombre;
                }

                wrapper.querySelector('.sku-dropdown').classList.remove('show');
            }
        });

        document.addEventListener('input', e => {
            // Filtro para los buscadores de SKU
            if (e.target.classList.contains('sku-search')) {
                const term = e.target.value.toLowerCase();
                const wrapper = e.target.closest('.sku-wrapper');
                wrapper.querySelectorAll('.sku-options li').forEach(li => {
                    li.classList.toggle('hidden', !li.textContent.toLowerCase().includes(term));
                });
            }
        });

        //  EVENTOS AISLADOS Y FORMULARIOS
        if(qs('#addItemBtn')) qs('#addItemBtn').addEventListener('click', ()=>{ addItem(); });
        if(qs('#scanRequest')) qs('#scanRequest').addEventListener('change', updateItemSelector);


        if(qs('#trackingBody')){
            qs('#trackingBody').addEventListener('change', async e => {
                if(e.target.classList.contains('location-select')){
                    const req = requests.find(r=>r.id===e.target.dataset.id); if(!req) return;
                    const nuevaLoc = e.target.value;

                    try {
                        const response = await fetch(`@Url.Action("ActualizarUbicacion", "Comercial")?solicitudId=${req.id}&ubicacion=${encodeURIComponent(nuevaLoc)}`, { method: 'POST' });
                        const data = await response.json();
                        if(data.ok) {
                            toast(`${req.id} actualizado a: ${nuevaLoc}.`);
                            loadData();
                        } else {
                            toast("Error del servidor: " + data.mensaje);
                            e.target.value = req.location;
                        }
                    } catch(err) {
                        console.warn("Backend no disponible...");
                        req.location = nuevaLoc;
                        req.items.forEach(item => (item.labels||[]).forEach(label => label.location = nuevaLoc));
                        req.stage = requestStatus(req);
                        renderAll();
                        toast(`Actualizado localmente.`);
                    }
                }
            });
        }

        if(qs('#trackSearch')) qs('#trackSearch').addEventListener('input', renderTracking);
        if(qs('#trackStatus')) qs('#trackStatus').addEventListener('change', renderTracking);
        if(qs('#trackDateFrom')) qs('#trackDateFrom').addEventListener('change', renderTracking);
        if(qs('#trackDateTo')) qs('#trackDateTo').addEventListener('change', renderTracking);

        if(qs('#requestForm')) {
            qs('#requestForm').addEventListener('submit', async e => {
                e.preventDefault();
                const btn = e.target.querySelector('button[type="submit"]');
                const fd = new FormData(e.target);
                const items = collectItems();

                if(!selectedOVId){ toast('Debes seleccionar una Orden de Venta de muestra primero.'); return; }
                if(!items.length){ toast('Agrega al menos un SKU con cajas solicitadas.'); return; }
                if(!fd.get('client')){ toast('Selecciona un cliente válido de la lista.'); return; }

                btn.disabled = true; btn.textContent = 'Guardando...';

                const req = {
                    id: "",
                    createdAt: new Date().toISOString(),
                    seller: fd.get('seller'),
                    client: fd.get('client'),
                    species: fd.get('species'),
                    requestedDate: fd.get('requestedDate'),
                    route: fd.get('route'),
                    destination: fd.get('destination'),
                    priority: fd.get('priority'),
                    notes: fd.get('notes'),
                    createdBy: '@User.Identity?.Name',
                    planning: null, stage: 'Planeación pendiente', location: 'Comercial', items: items,
                    ordenVentaId: selectedOVId
                };

                try {
                    const response = await fetch('@Url.Action("CrearSolicitud", "Comercial")', {
                        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(req)
                    });
                    const data = await response.json();
                    if(data.ok) {
                        selectedOVId = null;
                        const ovSelect = document.getElementById('ovMuestraSelect');
                        if(ovSelect) ovSelect.value = '';
                        // Re-lock form
                        const lockedDiv = document.getElementById('formContentLocked');
                        if (lockedDiv) lockedDiv.classList.add('form-locked-overlay');
                        const btnSubmit = document.getElementById('btnSubmitSolicitud');
                        if (btnSubmit) btnSubmit.disabled = true;
                        toast(`Solicitud creada.`); e.target.reset(); setDefaultDates(); clearItems(); loadData(); loadOVMuestras();
                    } else { toast("Error: " + data.mensaje); }
                } catch(err) {
                    console.warn("Backend no disponible...");
                    requests.unshift(req); e.target.reset(); setDefaultDates(); clearItems(); renderAll(); toast(`Creada localmente.`);
                } finally { btn.disabled = false; btn.textContent = 'Crear solicitud de muestra'; }
            });
        }

        document.addEventListener('submit', async e => {
            const form = e.target.closest('.planning-form');
            if(form){
                e.preventDefault();
                const req = requests.find(r=>r.id === form.dataset.id); if(!req) return;
                const fd = new FormData(form);

                const btn = form.querySelector('button[type="submit"]');
                if(btn){ btn.disabled = true; btn.textContent = 'Procesando...'; }

                req.items.forEach(item => { item.workSku = (fd.get(`workSku-${item.uid}`) || '').trim(); });
                req.planning = {processDate:fd.get('processDate'), shift:fd.get('shift'), line:fd.get('line'), planner:fd.get('planner'), releasedAt:new Date().toISOString()};
                req.stage = 'Planeada'; req.location = 'Planeación';

                try {
                    const response = await fetch('@Url.Action("GuardarPlaneacion", "Comercial")', {
                        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(req)
                    });
                    const data = await response.json();
                    if(data.ok) { toast(`Liberada a produccion.`); loadData(); } else { toast("Error: " + data.mensaje); }
                } catch(err) {
                    console.warn("Backend no disponible..."); renderAll(); toast(`Liberada localmente.`);
                } finally { if(btn){ btn.disabled = false; btn.textContent = 'Guardar SKU y liberar a produccion'; } }
            }
        });

        if(qs('#scanForm')) {
            qs('#scanForm').addEventListener('submit', async e => {
                e.preventDefault();
                const btn = e.target.querySelector('button[type="submit"]');
                const req = requests.find(r=>r.id === qs('#scanRequest').value);
                const item = req?.items.find(i=>i.uid === qs('#scanItem').value);

                if(!req || !item){ toast('Selecciona solicitud y SKU valido.'); return; }
                if((item.labels||[]).length >= Number(item.boxes)){ toast('SKU ya completado.'); return; }

                const code = qs('#scanLabel').value.trim().toUpperCase();

                const duplicadoCode = requests.some(r=>r.items.some(i=>(i.labels||[]).some(l=>l.code===code)));
                if(duplicadoCode){ toast('Etiqueta DEST ya usada.'); return; }

                btn.disabled = true; btn.textContent = 'Ligando...';

                const nuevaEtiqueta = {
                    code: code, externalChain: code,
                    operator: qs('#operatorName').value.trim(), processedAt: new Date().toISOString(), location: 'Producción'
                };

                try {
                    const response = await fetch(`@Url.Action("LigarEtiqueta", "Comercial")?solicitudId=${req.id}&itemUid=${item.uid}`, {
                        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(nuevaEtiqueta)
                    });
                    const data = await response.json();
                    if(data.ok) { toast(`Ligada.`); loadData(); } else { toast("Error: " + data.mensaje); }
                } catch(err) {
                    console.warn("Backend no disponible...");
                    item.labels = item.labels || []; item.labels.push(nuevaEtiqueta);
                    req.location = 'Producción'; req.stage = requestStatus(req); renderAll(); toast(`Ligada localmente.`);
                } finally { btn.disabled = false; btn.textContent = 'Ligar etiqueta'; }
            });
        }

        document.addEventListener('scroll', e => {
            if (e.target.closest('.sku-dropdown')) return;
            qsa('.sku-dropdown.show').forEach(d => d.classList.remove('show'));
        }, true);


        async function aplicarPermisos() {
            const nav = qs('#mainTabs');
            if (!nav) return;

            const userRole = (nav.dataset.userRole || 'Vendedor').trim();
            if (userRole === 'Admin') {
                const btnPermisos = qs('#btnAdminPermisos');
                if (btnPermisos) btnPermisos.style.display = 'inline-flex';
            }

            await aplicarPermisosDinamicos();
        }

        async function aplicarPermisosDinamicos() {
            try {
                const nav = qs('#mainTabs');
                const rol = nav ? nav.dataset.userRole : '';
                const r = await fetch('@Url.Action("ObtenerPermisosVistaSolicitudMuestras", "Comercial")?perfil=' + encodeURIComponent(rol));
                const permisos = await r.json();
                if (!permisos || typeof permisos !== 'object') return;

                const map = { solicitud: 'vendedor', planeacion: 'planeacion', produccion: 'produccion', tracking: 'tracking' };
                const tabs = qsa('.nav-btn');

                tabs.forEach(tab => {
                    const section = tab.dataset.section;
                    const key = map[section];
                    if (!key || permisos[key] === undefined) return;

                    if (permisos[key] === true) {
                        tab.style.display = 'inline-flex';
                    } else {
                        tab.style.display = 'none';
                    }
                });

                const visible = qsa('.nav-btn').filter(t => t.style.display !== 'none');
                const active = qs('.nav-btn.active');
                if (visible.length > 0 && (!active || active.style.display === 'none')) {
                    visible[0].click();
                }
                if (visible.length === 0) {
                    qsa('.section').forEach(s => s.classList.remove('active'));
                }
            } catch (e) {
                console.warn('Permisos dinámicos no disponibles', e);
            }
        }

        async function abrirAdminPermisos() {
            try {
                const res = await fetch('@Url.Action("ObtenerPerfilesMuestras", "Comercial")');
                const data = await res.json();
                if (!data.ok) { toast('Error al cargar perfiles'); return; }

                const perfiles = data.data || [];
                const tbody = qs('#tbodyPermisosMuestras');
                if (!tbody) return;

                let html = '';
                perfiles.forEach(p => {
                    html += `<tr>
                        <td><strong>${p.nombre}</strong></td>
                        <td class="text-center"><input type="checkbox" class="chk-permiso-muestra" data-perfil="${p.id}" data-modulo="SOLICITUD_MUESTRAS_VENDEDOR" ${p.vendedor ? 'checked' : ''}></td>
                        <td class="text-center"><input type="checkbox" class="chk-permiso-muestra" data-perfil="${p.id}" data-modulo="SOLICITUD_MUESTRAS_PLANEACION" ${p.planeacion ? 'checked' : ''}></td>
                        <td class="text-center"><input type="checkbox" class="chk-permiso-muestra" data-perfil="${p.id}" data-modulo="SOLICITUD_MUESTRAS_PRODUCCION" ${p.produccion ? 'checked' : ''}></td>
                    </tr>`;
                });
                tbody.innerHTML = html;

                qsa('.chk-permiso-muestra').forEach(chk => {
                    chk.addEventListener('change', async function() {
                        const perfilId = this.dataset.perfil;
                        const claveModulo = this.dataset.modulo;
                        const activo = this.checked;

                        try {
                            const r = await fetch('@Url.Action("GuardarPermisoMuestras", "Comercial")', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ perfilId: parseInt(perfilId), claveModulo, activo })
                            });
                            const result = await r.json();
                            if (!result.ok) { toast('Error: ' + result.mensaje); this.checked = !activo; }
                        } catch (e) { toast('Error de conexión'); this.checked = !activo; }
                    });
                });

                qs('#modalAdminPermisos').classList.add('show');
            } catch (e) { toast('Error al cargar'); }
        }

        async function arrancarSistema() {
            try { await fetch('@Url.Action("AsegurarModulosMuestras", "Comercial")'); } catch (e) {}
            await aplicarPermisos();
            setDefaultDates();
            await loadArticulos();
            await loadData();
        }
        arrancarSistema();

    </script>
}
