            <h3 id="historialTitle">Historial de Solicitudes</h3>

            <!-- CONTENEDOR CON FLEX PARA ALINEAR EL CONTADOR Y LOS BOTONES -->
            <div style="display: flex; align-items: center; gap: 15px;">
                <span id="printCounter" style="display: none; font-size: 12px; color: #fff; font-weight: normal; background: rgba(0,0,0,0.2); padding: 4px 8px; border-radius: 4px;"></span>
                <button type="button" class="secondary" id="btnImprimirHistorial" style="display:none;" onclick="imprimirEtiquetas(true)"> Imprimir seleccionadas</button>
                <button type="button" class="secondary" onclick="document.getElementById('modalHistorial').classList.remove('show')">Cerrar</button>
            </div>

        </div>
        <div style="padding: 10px; min-height: 50vh;">
            <div id="historialContentContainer" class="grid cols-1"></div>
        </div>
