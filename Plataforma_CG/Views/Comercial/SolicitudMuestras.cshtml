                    const linked = linkedLabels(req);
                    const pct = total ? Math.round(linked / total * 100) : 0;

                    const labelsHtml = req.items.map(item => `
                        <b>Trabaja: ${escapeTrackingHtml(item.workSku || item.sku)}</b>
                        ${escapeTrackingHtml(item.product || '')}<br>
                        <span class="mini">
                            Pide: ${escapeTrackingHtml(item.sku || '')} ·
                            ${escapeTrackingHtml(item.spec || '')}
                        </span><br>
                        <div style="margin-top:3px;">
                            ${(item.labels || []).map(label => {
                                const codigo = obtenerCodigoEtiquetaTracking(label);
                                const info = obtenerTrackingEtiqueta(label);

                                let detalle = '';
                                if (info?.estado === 'VENDIDA') {
                                    detalle =
