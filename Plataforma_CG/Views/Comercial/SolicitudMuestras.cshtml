                    <div class="form-grid two" style="margin-bottom:0; background:transparent; padding:0; border:none;">
                    <div><label>Proceso</label><input type="date" name="processDate" ${dis} required value="${req.planning?.processDate || todayPlus(2)}"></div>
                    <div><label>Turno</label><select name="shift" ${dis}><option ${req.planning?.shift==='Turno 1'?'selected':''}>Turno 1</option><option ${req.planning?.shift==='Turno 2'?'selected':''}>Turno 2</option></select></div>
                    <div><label>Linea</label><select name="line" ${dis}><option ${req.planning?.line==='Linea Empaque 01'?'selected':''}>Linea Empaque 01</option><option ${req.planning?.line==='Linea Corte 01'?'selected':''}>Linea Corte 01</option></select></div>
                    <div><label>Planeador</label><input name="planner" ${dis} readonly required value="${req.planning?.planner || '@usuarioLogueado'}" style="background-color: #f0f0f0; color: #666; cursor: not-allowed;"></div>
                    </div>
                    ${btnHtml}
