<div id="loadingOverlay" style="position:fixed; inset:0; z-index:9999; background:rgba(255,253,253,0.85); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:16px; transition: opacity 0.3s;">
    <div class="spinner-muestras"></div>
    <div style="color:#5c1a1a; font-weight:700; font-size:14px;">Personalizando experiencia...</div>
</div>
<style>
.spinner-muestras{width:48px;height:48px;border:5px solid #f0dede;border-top-color:#8b0000;border-radius:50%;animation:spinMuestras .8s linear infinite}
@@keyframes spinMuestras{to{transform:rotate(360deg)}}
