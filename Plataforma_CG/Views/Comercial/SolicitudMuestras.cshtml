            const safeClient = (req.client || '').replace(/"/g, '&quot;');
            const safeProduct = (item.product || '').replace(/"/g, '&quot;');
            const safeSpec = (item.spec || '').replace(/"/g, '&quot;');
            const safeSeller = (req.seller || '').replace(/"/g, '&quot;');
            const safeNotes = (req.notes || '').replace(/"/g, '&quot;');

            // REVISAR LA MEMORIA
            let isChecked = isHistory ? false : true; // Estado por defecto
            if (estadoCheckboxes.has(label.code)) {
                isChecked = estadoCheckboxes.get(label.code); // Forzar el que eligió el usuario
            }

            const checkboxHtml = `
                <input type="checkbox" class="print-cb no-print" value="${label.code}" ${isChecked ? 'checked' : ''} title="Seleccionar para imprimir"
                    data-req="${req.id}" data-client="${safeClient}" data-seller="${safeSeller}"
                    data-skureq="${item.sku}" data-skuwork="${item.workSku || item.sku}"
                    data-product="${safeProduct}" data-species="${especie}" data-spec="${safeSpec}"
                    data-date="${fechaProc}" data-op="${label.operator || ''}" data-chain="${label.code}" data-temp="${temp}" data-peso="${label.pesoReal != null ? label.pesoReal : ''}"
                    data-notes="${safeNotes}"
                    style="position: absolute; top: 12px; right: 12px; width: 18px; height: 18px; cursor: pointer; z-index: 10;">
            `;

            return `
                <div class="label-card" style="position: relative; background: var(--panel-2); border: 1px solid var(--line); padding: 10px;">
                    ${checkboxHtml}
                    <div style="border-bottom: 2px solid var(--line); padding-bottom: 6px; margin-bottom: 8px; padding-right: 30px;">
                        <h4 style="margin: 0; font-size: 15px; color: #5c1a1a; font-weight: bold;">${label.code}</h4>
                    </div>
                    <div class="lc-body" style="background: #fff; padding: 8px; border: 1px solid var(--line); font-size: 11px; line-height: 1.5; text-align: left; color: #111;">
                        <b>Solicitud:</b> ${req.id}<br>
                        <b>Cliente:</b> ${req.client}<br>
                        ${req.notes ? `<b>Destinatario:</b> ${escapeTrackingHtml(req.notes)}<br>` : ''}
                        <b>Especie:</b> ${especie}<br>
                        <b>SKU solicitado:</b> ${item.sku} · ${item.product}<br>
                        <b>SKU a trabajar:</b> <span style="font-weight: 900; color: #8b0000; font-size: 13px;">${item.workSku || item.sku}</span><br>
                        <b>Especificación:</b> ${item.spec}<br>
                        <b>Procesado:</b> ${fechaProc}<br>
                        <b>Operario:</b> ${label.operator || ''}<br>
                        <b>Etiqueta:</b> ${label.code}<br>
                        ${label.pesoReal != null ? `<b>Peso:</b> ${Number(label.pesoReal).toLocaleString('es-MX', { minimumFractionDigits: 3, maximumFractionDigits: 3 })} kg` : ''}
                    </div>
                </div>
            `;
        }

                window.generarReporteGeneral = function() {
                    if (!requests.length) { toast('No hay datos para generar el reporte.'); return; }

                    const cargarImagen = (src) => new Promise((resolve) => {
                        const img = new Image();
                        img.crossOrigin = 'Anonymous';
                        img.onload = () => resolve(img);
                        img.onerror = () => resolve(null);
                        img.src = src;
                    });

                    async function descargarPDF() {
                        toast('Generando reporte PDF...');
                        const { jsPDF } = window.jspdf;
                        const doc = new jsPDF('landscape', 'mm', 'letter');
                        const pageW = doc.internal.pageSize.getWidth();
                        const pageH = doc.internal.pageSize.getHeight();
                        const mg = 12;
                        let y = mg;

                        const logoCG = await cargarImagen('/images/LOGO_CARNESG.jpg');
                        const logoTIF = await cargarImagen('/images/logoTIF.png');

                        function header() {
                            if (logoCG) doc.addImage(logoCG, 'JPEG', mg, 8, 30, 12);
                            if (logoTIF) doc.addImage(logoTIF, 'PNG', pageW - mg - 16, 8, 16, 12);

                            doc.setFontSize(16);
                            doc.setTextColor(139, 0, 0);
                            doc.setFont('helvetica', 'bold');
                            doc.text('REPORTE GENERAL DE MUESTRAS', pageW / 2, 14, { align: 'center' });

                            doc.setFontSize(8);
                            doc.setTextColor(100);
                            doc.setFont('helvetica', 'normal');
                            doc.text('Sistema Integral de Gestión Operativa (SIGO) - Comercial', pageW / 2, 18, { align: 'center' });
                            doc.text('Generado: ' + new Date().toLocaleString('es-MX'), pageW / 2, 22, { align: 'center' });

                            doc.setDrawColor(139, 0, 0);
                            doc.setLineWidth(0.5);
                            doc.line(mg, 26, pageW - mg, 26);
                            y = 32;
                        }

                        function footer() {
                            doc.setFontSize(7);
                            doc.setTextColor(120);
                            doc.setFont('helvetica', 'normal');
                            doc.text('CARNES G S.A. DE C.V. - TIF 776 | Carretera Estatal N212 San Juan de los Lagos, Jal.', pageW / 2, pageH - 6, { align: 'center' });
                        }

                        header();

                        // Cálculos del resumen
                        const total = requests.length;
                        const pendientes = requests.filter(r => requestStatus(r) === 'Pendiente').length;
                        const planeadas = requests.filter(r => requestStatus(r) === 'Planeada').length;
                        const produccion = requests.filter(r => r.planning && requestStatus(r) !== 'Pendiente' && requestStatus(r) !== 'Planeada' && requestStatus(r) !== 'Cancelada').length;
                        const completadas = requests.filter(r => requestStatus(r) === 'En almacén' || requestStatus(r) === 'Surtido al cliente').length;
                        const totalCajas = requests.reduce((s, r) => s + totalBoxes(r), 0);
                        const totalEtqs = requests.reduce((s, r) => s + linkedLabels(r), 0);

                        doc.setFontSize(10);
                        doc.setTextColor(139, 0, 0);
                        doc.setFont('helvetica', 'bold');
                        doc.text('Resumen Operativo', mg, y);
                        y += 4;

                        const resumen = [
                            ['Total Solicitudes', '' + total, 'En Producción', '' + produccion],
                            ['Pendientes de Planeación', '' + pendientes, 'Completadas / Surtidas', '' + completadas],
                            ['Planeadas (Espera)', '' + planeadas, 'Cajas Totales / Etiquetas', totalEtqs + ' / ' + totalCajas]
                        ];

                        doc.autoTable({
                            startY: y,
                            body: resumen,
                            theme: 'plain',
                            styles: { fontSize: 8, cellPadding: 1.5 },
                            columnStyles: {
                                0: { fontStyle: 'bold', textColor: [0, 0, 0], cellWidth: 40 },
                                1: { cellWidth: 20, textColor: [139, 0, 0], fontStyle: 'bold' },
                                2: { fontStyle: 'bold', textColor: [0, 0, 0], cellWidth: 40 },
                                3: { cellWidth: 30, textColor: [139, 0, 0], fontStyle: 'bold' }
                            },
                            margin: { left: mg }
                        });
                        y = doc.lastAutoTable.finalY + 8;

                        const estados = [
                            { label: 'PENDIENTES', filter: r => requestStatus(r) === 'Pendiente' },
                            { label: 'PLANEADAS', filter: r => requestStatus(r) === 'Planeada' },
                            { label: 'EN PRODUCCIÓN', filter: r => r.planning && (requestStatus(r) === 'Producción parcial' || requestStatus(r) === 'Cumplido producción') },
                            { label: 'EN ALMACÉN', filter: r => requestStatus(r) === 'En almacén' },
                            { label: 'SURTIDAS / ENTREGADAS', filter: r => requestStatus(r) === 'Surtido al cliente' },
                            { label: 'CANCELADAS', filter: r => requestStatus(r) === 'Cancelada' }
                        ];

                        estados.forEach(e => {
                            const items = requests.filter(e.filter);
                            if (!items.length) return;

                            if (y > pageH - 40) { doc.addPage(); y = mg + 5; header(); }

                            const rows = items.map(r => [
                                r.id,
                                r.client,
                                r.seller,
                                r.species || '-',
                                r.route + ' / ' + r.destination,
                                formatDate(r.requestedDate),
                                r.items.map(i => i.sku + ' (' + i.boxes + ' cjs)' + (i.workSku && i.workSku !== i.sku ? ' -> Trab: ' + i.workSku : '')).join('\n'),
                                linkedLabels(r) + '/' + totalBoxes(r)
                            ]);

                            doc.autoTable({
                                startY: y,
                                head: [[e.label, 'Cliente', 'Vendedor', 'Esp.', 'Ruta / Destino', 'Fecha Req.', 'Artículos (Cajas)', 'Avance']],
                                body: rows,
                                theme: 'grid',
                                tableLineColor: [200, 200, 200],
                                tableLineWidth: 0.1,
                                headStyles: { fillColor: [139, 0, 0], textColor: [255, 255, 255], fontStyle: 'bold', fontSize: 7, halign: 'center' },
                                bodyStyles: { fontSize: 7, cellPadding: 2, textColor: [30, 30, 30], valign: 'middle' },
                                alternateRowStyles: { fillColor: [249, 245, 245] },
                                columnStyles: {
                                    0: { cellWidth: 20, fontStyle: 'bold', textColor: [139, 0, 0] },
                                    1: { cellWidth: 42 },
                                    2: { cellWidth: 26 },
                                    3: { cellWidth: 10, halign: 'center' },
                                    4: { cellWidth: 38 },
                                    5: { cellWidth: 18, halign: 'center' },
                                    6: { cellWidth: 50 },
                                    7: { cellWidth: 14, halign: 'center', fontStyle: 'bold' }
                                },
                                margin: { left: mg, right: mg },
                                didParseCell: function(data) {
                                    if (data.section === 'head' && data.row.index === 0 && data.column.index === 0) {
                                        data.cell.styles.halign = 'left';
                                    }
                                }
                            });
                            y = doc.lastAutoTable.finalY + 8;
                        });

                        const totalPages = doc.internal.getNumberOfPages();
                        for (let j = 1; j <= totalPages; j++) {
                            doc.setPage(j);
                            footer();
                            doc.setFontSize(7);
                            doc.setTextColor(120);
                            doc.text('Página ' + j + ' de ' + totalPages, pageW - mg, pageH - 6, { align: 'right' });
                        }

                        doc.save('Reporte_Muestras_' + new Date().toISOString().slice(0, 10) + '.pdf');
                    }

                    // Descarga o usa la librería jsPDF
                    if (typeof window.jspdf === 'undefined' || typeof window.jspdf.jsPDF === 'undefined') {
                        toast('Preparando motor PDF...');
                        const s1 = document.createElement('script');
                        s1.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
                        s1.onload = function() {
                            const s2 = document.createElement('script');
                            s2.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js';
                            s2.onload = descargarPDF;
                            document.head.appendChild(s2);
                        };
                        document.head.appendChild(s1);
                    } else {
                        descargarPDF();
                    }
                }

                                window.imprimirEtiquetas = async function(esHistorial = false) {
            // Solo toma los checkboxes de la pantalla que estás viendo
            const contenedor = esHistorial ? '#historialContentContainer' : '#productionList';
            const checkboxes = document.querySelectorAll(`${contenedor} .print-cb:checked`);

            if (checkboxes.length === 0) {
                toast('Selecciona al menos una etiqueta marcando su casilla.');
                return;
            }

            const ip = (document.getElementById('printerIp')?.value || '').trim();
            if (!ip) {
                toast('Ingresa la IP de la impresora Zebra.');
                return;
            }
            localStorage.setItem('printerIpMuestras', ip);

            const etiquetas = [];
            checkboxes.forEach(cb => {
                const d = cb.dataset;
                etiquetas.push({
                    solicitudId: d.req || '', seller: d.seller || '', client: d.client || '',
                    product: d.product || '', species: d.species || '', spec: d.spec || '',
                    lote: cb.value || '', skuRequerido: d.skureq || '', skuTrabajo: d.skuwork || '',
                    fechaProduccion: d.date || '', operario: d.op || '', temperatura: d.temp || '',
                    peso: d.peso || '', notes: d.notes || ''
                });
            });

            try {
                const resp = await fetch(`@Url.Action("ImprimirEtiquetaMuestra", "Comercial")?ip=${encodeURIComponent(ip)}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(etiquetas)
                });
                const data = await resp.json();
                toast(data.mensaje || (data.ok ? 'Impreso correctamente.' : 'Error al imprimir.'));
            } catch (err) {
                toast('Error al conectar con el servidor: ' + err.message);
            }
        }
                // FUNCIONES DE ACTUALIZACION DE PANTALLA
                function renderRequestList(){
                    const pendientes = requests.filter(r => requestStatus(r) === 'Pendiente');
                    histSolicitud = requests.filter(r => requestStatus(r) !== 'Pendiente');
                    let html = pendientes.map(r => createRequestCard(r)).join('');
                    if(qs('#requestList')) qs('#requestList').innerHTML = html || '<div class="empty">No hay solicitudes nuevas.</div>';
                    if(qs('#btnHistSolicitudes')) qs('#btnHistSolicitudes').innerHTML = `Ver historial (${histSolicitud.length})`;
                }

                function renderPlanning(){
                    const pendientes = requests.filter(r => requestStatus(r) === 'Pendiente');
                    histPlaneacion = requests.filter(r => requestStatus(r) !== 'Pendiente' && requestStatus(r) !== 'Cancelada');
                    if(qs('#planningList')) qs('#planningList').innerHTML = pendientes.length ? pendientes.map(r => createPlanningCard(r, false)).join('') : '<div class="empty">No hay solicitudes pendientes de planeacion.</div>';
                    if(qs('#btnHistPlaneacion')) qs('#btnHistPlaneacion').innerHTML = `Ver historial (${histPlaneacion.length})`;
                }

                    function renderProduction() {
        let prodList = requests.filter(r => r.planning);

        // Filtro dinamico por sub-permisos
        prodList = prodList.filter(r => {
            const esp = r.planning.especificacion;
            if (esp === 'Producto de linea' && !subPermisosProduccion.linea) return false;
            if (esp === 'Nuevo' && !subPermisosProduccion.nuevo) return false;
            return true;
        });

        const activos = prodList.filter(r => {
            const st = requestStatus(r);
            return st === 'Planeada' || st === 'Producción parcial' || st === 'Cumplido producción';
        });
                    histProduccion = prodList.filter(r => {
                        const st = requestStatus(r);
                        return st === 'En almacén'
                            || st === 'Surtido parcial'
                            || st === 'Surtido al cliente';
                    });
                    if(qs('#productionList')) qs('#productionList').innerHTML = activos.length ? activos.map(r => createProductionCard(r, false)).join('') : '<div class="empty">No hay muestras en produccion activa.</div>';
                    if(qs('#btnHistProduccion')) qs('#btnHistProduccion').innerHTML = `Ver historial (${histProduccion.length})`;
                }

                function renderTracking() {
                    const q = (qs('#trackSearch')?.value || '').toLowerCase();
                    const filter = qs('#trackStatus')?.value || '';
                    const dateFrom = qs('#trackDateFrom')?.value || '';
                    const dateTo = qs('#trackDateTo')?.value || '';

                    const list = requests.filter(req => {
                        const status = estadoTrackingSolicitud(req);

                        if (status === 'Cancelada')
                            return false;

                        const textoEtiquetas = obtenerEtiquetasSolicitud(req)
                            .map(label => {
                                const codigo = obtenerCodigoEtiquetaTracking(label);
                                const info = obtenerTrackingEtiqueta(label);

                                return [
                                    codigo,
                                    info?.almacen,
                                    info?.planta,
                                    info?.cliente,
                                    info?.folio,
                                    info?.estado
                                ].filter(Boolean).join(' ');
                            });

                        const hay = [
                            req.id,
                            req.ovConsecutivo,
                            req.client,
                            req.seller,
                            req.species,
                            req.route,
                            req.destination,
                            ...req.items.flatMap(item => [
                                item.sku,
                                item.workSku,
                                item.product,
                                item.spec
                            ]),
                            ...textoEtiquetas
                        ].join(' ').toLowerCase();

                        const reqDate = (req.createdAt || '').substring(0, 10);

                        return (!q || hay.includes(q))
                            && (!filter || status === filter)
                            && (!dateFrom || reqDate >= dateFrom)
                            && (!dateTo || reqDate <= dateTo);
                    });

                    const activos = list.filter(req =>
                        estadoTrackingSolicitud(req) !== 'Surtido al cliente'
                    );

                    histTracking = list.filter(req =>
                        estadoTrackingSolicitud(req) === 'Surtido al cliente'
                    );

                    if (qs('#trackingBody')) {
                        qs('#trackingBody').innerHTML = activos.length
                            ? activos.map(req => createTrackingRow(req, false)).join('')
                            : '<tr><td colspan="9" class="empty">No hay resultados activos con esos filtros.</td></tr>';
                    }

                    if (qs('#btnHistTracking')) {
                        qs('#btnHistTracking').innerHTML =
                            `Ver Entregadas (${histTracking.length})`;
                    }
                }

