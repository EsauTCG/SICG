                ` + '</sty' + 'le><div class="print-container">';

            checkboxes.forEach(cb => {
                const d = cb.dataset;
                htmlContent += `
                    <div class="label-print">
                        <div class="lp-header">
                            Elaborado por: CARNES G S.A. DE C.V. TIF 776<br>
                            CARRETERA ESTATAL N212 A SAN SEBASTIAN EL ALAMO KILOMETRO 21+540<br>
                            MARGEN DERECHO. SAN JUAN DE LOS LAGOS JAL CP 47000
                        </div>

                        <div class="lp-sku-title">Producto / Clasificación:</div>
