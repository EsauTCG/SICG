                    </td>
                    <td style="vertical-align: top; white-space: nowrap; width: 80px;">
                        <span class="badge gray" style="font-size: 10px;">${escapeTrackingHtml(req.ovConsecutivo || 'S/OV')}</span>
                    </td>
                    <td style="vertical-align: top; text-align: left; min-width: 150px;">
                        <b style="color: #111;">${escapeTrackingHtml(req.client)}</b><br>
                        <span class="mini" style="display: inline-block; margin-top: 4px; padding: 2px 4px; background: #eee; border-radius: 2px;">
                            <i class="bi bi-person-badge"></i> Vende: <b>${escapeTrackingHtml(req.seller)}</b>
                        </span>
                    </td>
                    <td style="vertical-align: top; text-align: left; min-width: 140px;">
                        <span style="color: #8b0000; font-weight: bold;"><i class="bi bi-truck"></i> ${escapeTrackingHtml(req.route)}</span><br>
                        <span class="mini" style="color: #444;">
                            <i class="bi bi-geo-alt-fill"></i> ${escapeTrackingHtml(req.destination)}
                        </span>
                    </td>
                    <td style="text-align:left; vertical-align: top; min-width: 300px; padding: 8px;">
                        ${labelsHtml}
                    </td>
                    <td style="vertical-align: top; width: 110px;">
                        <div style="background: #f8eeee; padding: 6px; border-radius: 4px; border: 1px solid var(--line);">
                            <b style="font-size:14px; color:#8b0000; display: block; text-align: center; margin-bottom: 4px;">
                                ${linked} / ${total}
