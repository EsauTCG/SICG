                                <input type="date" id="editRequestedDate" value="${(req.requestedDate||'').substring(0,10)}">
                            </div>

                            <div>
                                <label>Ruta logística</label>
                                <input id="editRoute" value="${req.route||''}" placeholder="Ej. Ruta Altos Norte">
