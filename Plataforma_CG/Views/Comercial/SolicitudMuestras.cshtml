                                    detalle = `Inactiva sin venta comprobada · ${info.planta || ''}`;
                                }

                                return `
                                    <span class="badge gray" style="margin-bottom:2px;">
                                        ${escapeTrackingHtml(codigo)}
                                    </span>
                                    ${detalle
                                        ? `<span class="tracking-summary-line">${escapeTrackingHtml(detalle)}</span>`
                                        : ''}
                                `;
                            }).join('') || '<span class="badge pending">Sin etiqueta</span>'}
                        </div>
