@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Solicitud y Trazabilidad de Muestras";
    var usuarioLogueado = User.Identity?.Name ?? "";
}

<style>

    :root {
        --bg: #f0dede;
        --panel: #f8eeee;
        --panel-2: #f1dede;
        --line: #c79d9d;
        --text: #3b1717;
        --white: #ffffff;
        --vino-border: #9a5a5a;
        --font: Tahoma, sans-serif;
    }

    /* CONTENEDOR PRINCIPAL */
    .app-shell {
        width: 100%;
        max-width: 100%;
        margin: 0;
        padding: 0;
        font-family: var(--font);
        font-size: 11px;
        color: var(--text);
        background: var(--bg) !important;
        min-height: 80vh;
        display: flex;
        flex-direction: column;
    }

        .app-shell * {
            box-sizing: border-box;
        }

    /* HEADER */
    .module-header {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #4a0000;
        flex-shrink: 0;
        padding: 10px 10px 0 10px;
        box-shadow: 0 4px 8px rgba(0,0,0,.15);
        z-index: 100;
        position: sticky;
        top: 0;
    }

    .header-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 10px;
    }

    .brand {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .brand-mark {
        width: 34px;
        height: 34px;
        display: grid;
        place-items: center;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.18);
        font-weight: bold;
        font-size: 14px;
        color: #fff;
        border-radius: 2px;
    }

    .brand h1 {
        font-size: 14px;
        margin: 0;
        font-weight: bold;
        color: #fff;
    }

    .brand small {
        display: block;
        color: #f4d7d7;
        font-size: 10px;
        font-weight: normal;
        margin-top: 2px;
    }

    .header-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .module-tabs {
        display: flex;
        gap: 5px;
        overflow-x: auto;
        scrollbar-width: none;
        padding: 0 10px;
        margin-top: 5px;
        position: relative;
        bottom: -1px;
    }

        .module-tabs::-webkit-scrollbar {
            display: none;
        }

    .nav-btn {
        background: rgba(0,0,0,0.15);
        border: 1px solid rgba(255,255,255,0.1);
        border-bottom: none;
        color: #f4d7d7;
        padding: 10px 18px;
        font-weight: bold;
        font-size: 12px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        border-radius: 8px 8px 0 0;
        white-space: nowrap;
        transition: all 0.25s ease;
    }

        .nav-btn:hover {
            background: rgba(255,255,255,0.15);
            color: #fff;
        }

        .nav-btn.active {
            background: var(--bg) !important;
            color: #5c1a1a !important;
            border-color: transparent !important;
            padding-top: 12px;
            box-shadow: 0 -4px 10px rgba(0,0,0,0.05);
        }

        /* Píldora numérica de las pestañas */
        .nav-btn .pill {
            background: rgba(255,255,255,0.2);
            color: #fff;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            font-size: 11px;
            transition: 0.3s;
        }

        .nav-btn.active .pill {
            background: #8b0000;
            color: #fff !important;
        }

    /* AREA DE CONTENIDO PRINCIPAL */
    .module-main {
        flex: 1;
        padding: 10px;
        background: var(--bg);
        min-width: 0;
    }

    /* BOTONES */
    .app-shell button:not(.nav-btn), .app-shell .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        height: 26px;
        padding: 0 12px;
        border: 1px solid transparent;
        border-radius: 0;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        color: #fff !important;
        font-size: 11px;
        font-weight: bold;
        line-height: 1;
        text-decoration: none;
        white-space: nowrap;
        cursor: pointer;
        border-color: #7a2d2d;
    }

        .app-shell button:not(.nav-btn):hover, .app-shell .btn:hover {
            filter: brightness(1.1);
            color: #fff !important;
        }

        .app-shell button.secondary, .app-shell .btn.secondary {
            background: linear-gradient(#fffefe, #ecd7d7) !important;
            border-color: var(--vino-border) !important;
            color: #4a1111 !important;
        }

            .app-shell button.secondary:hover, .app-shell .btn.secondary:hover {
                background: #fff !important;
                color: #111 !important;
            }

        .app-shell button.ghost, .app-shell .btn.ghost {
            background: transparent;
            color: #8b0000 !important;
            border: 1px dashed #c79d9d;
        }

            .app-shell button.ghost:hover, .app-shell .btn.ghost:hover {
                background: #fffafa;
                color: #5c0000 !important;
                border-color: #8b0000;
            }

    .app-shell button.success {
        background: linear-gradient(180deg, #27ae60 0%, #1f9a54 55%, #198754 100%) !important;
        border-color: #157347 !important;
    }

    .app-shell button.danger {
        background: linear-gradient(180deg, #dc3545 0%, #c82333 55%, #bd2130 100%) !important;
        border-color: #b02a37 !important;
    }

    /* TARJETAS Y CONTENEDORES */
    .grid {
        display: grid;
        gap: 10px;
        min-width: 0;
    }

        .grid.cols-4 {
            grid-template-columns: repeat(4,minmax(0,1fr));
            margin: 0 0 10px;
        }

        .grid.cols-3 {
            grid-template-columns: repeat(3,minmax(0,1fr));
        }

        .grid.cols-2 {
            grid-template-columns: repeat(2,minmax(0,1fr));
        }

    .app-shell .card {
        background: var(--panel) !important;
        border: 1px solid var(--line) !important;
        border-radius: 0 !important;
        padding: 12px;
        color: var(--text) !important;
        min-width: 0;
    }

    .form-subtitle {
        font-size: 12px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        padding: 4px 8px;
        margin: 0 0 10px 0;
        border-bottom: 1px solid #6b1f1f;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .kpi {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-height: 70px;
        background: var(--white) !important;
        border: 1px solid var(--line);
        padding: 10px;
    }

        .kpi small {
            color: #5c1a1a;
            font-weight: bold;
            text-transform: uppercase;
            font-size: 10px;
        }

        .kpi strong {
            font-size: 18px;
            line-height: 1;
            color: #8b0000;
        }

        .kpi .hint {
            font-size: 10px;
            color: #666;
        }

    .section {
        display: none;
        animation: fadeIn 0.2s ease;
    }

        .section.active {
            display: block;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(3px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .section-header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        margin: 10px 0 8px;
        gap: 10px;
        flex-wrap: wrap;
    }

        .section-header h3 {
            margin: 0;
            font-size: 13px;
            font-weight: bold;
            color: #5c1a1a;
        }

        .section-header p {
            margin: 4px 0 0;
            color: #444;
            font-size: 11px;
        }

    /* FORMULARIOS */
    .app-shell label {
        display: block;
        color: #5c1a1a !important;
        font-weight: bold;
        font-size: 11px;
        margin-bottom: 4px;
    }

    .app-shell input, .app-shell select, .app-shell textarea {
        width: 100%;
        border-radius: 0;
        border: 1px solid #b48787 !important;
        background: #fffdfd !important;
        color: #421414 !important;
        font-size: 11px;
        min-height: 26px;
        padding: 2px 6px;
        outline: none;
    }

    .app-shell textarea {
        min-height: 50px;
        resize: vertical;
        line-height: 1.3;
    }

        .app-shell input:focus, .app-shell select:focus, .app-shell textarea:focus {
            border-color: #8b0000 !important;
            background: #fff !important;
        }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(3,minmax(0,1fr));
        gap: 10px;
        margin-bottom: 10px;
        background: var(--panel-2);
        padding: 10px;
        border: 1px solid var(--line);
    }

        .form-grid.two {
            grid-template-columns: repeat(2,minmax(0,1fr));
        }

        .form-grid .full {
            grid-column: 1/-1;
        }

    /* TABLAS */
    .app-shell .table-wrap {
        width: 100%;
        overflow: visible;
        background: #fffafa !important;
        border: 1px solid var(--line);
    }

    .app-shell table {
        width: 100%;
        border-collapse: separate !important;
        border-spacing: 0 !important;
        font-size: 10px;
        background: #fffafa !important;
    }

    .app-shell th, .app-shell td {
        padding: 4px 5px;
        text-align: center;
        vertical-align: middle;
        border-bottom: 1px solid #d8bcbc !important;
        border-right: 1px solid #d8bcbc !important;
        color: #111 !important;
    }

    .app-shell th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        color: #fff !important;
        font-weight: normal;
        border-right: 1px solid #8e3b3b !important;
        border-bottom: 1px solid #ffb3b3 !important;
    }

    .app-shell tbody tr:nth-child(even) td {
        background: #f9eded !important;
    }

    .app-shell tbody tr:hover td {
        background: #f4dddd !important;
    }

    .app-shell td:first-child, .app-shell th:first-child {
        border-left: 1px solid #d8bcbc;
    }

    .app-shell th:first-child {
        border-left: 1px solid #8e3b3b !important;
    }

    /* BADGES Y ESTADOS */
    .app-shell .badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 2px 6px;
        border-radius: 2px;
        font-size: 9px;
        font-weight: bold;
        border: 1px solid transparent;
    }

        .app-shell .badge.pending {
            background: #fff7ed;
            color: #9a3412;
            border-color: #fed7aa;
        }

        .app-shell .badge.planned {
            background: #eff6ff;
            color: #1d4ed8;
            border-color: #bfdbfe;
        }

        .app-shell .badge.progress {
            background: #fef9c3;
            color: #854d0e;
            border-color: #fde68a;
        }

        .app-shell .badge.done {
            background: #dcfce7;
            color: #166534;
            border-color: #bbf7d0;
        }

        .app-shell .badge.gray {
            background: #333;
            color: #fff;
            border-color: #111;
        }

    .request-card {
        display: grid;
        grid-template-columns: 1.2fr .9fr;
        gap: 10px;
        align-items: start;
        border-left: 4px solid #8b0000 !important;
        background: var(--white) !important;
    }

    .request-title {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 10px;
        margin-bottom: 8px;
        border-bottom: 1px solid var(--line);
        padding-bottom: 6px;
    }

        .request-title h4 {
            margin: 0;
            font-size: 13px;
            color: #8b0000;
            font-weight: bold;
        }

    .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-top: 6px;
    }

        .meta span {
            background: var(--panel-2);
            color: #5c1a1a;
            border: 1px solid var(--line);
            padding: 2px 6px;
            font-size: 10px;
        }

    .items-list {
        display: grid;
        gap: 6px;
        margin-top: 8px;
    }

    .item-line {
        border: 1px solid var(--line);
        padding: 6px 8px;
        background: #fffdfd;
    }

        .item-line strong {
            display: block;
            margin-bottom: 2px;
            color: #111;
            font-size: 11px;
        }

        .item-line small {
            color: #444;
            font-size: 10px;
        }

    .progress-bar {
        height: 8px;
        background: var(--panel-2);
        border: 1px solid var(--line);
        margin-top: 5px;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg,#5c0000,#b30000);
        width: 0%;
        transition: .25s ease;
    }

    .mini {
        font-size: 10px;
        color: #444;
    }

    .split-panel {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 10px;
        align-items: start;
    }

    .scan-panel {
        position: sticky;
        top: 10px;
        background: var(--white) !important;
    }

    .label-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(220px,1fr));
        gap: 10px;
    }

    .label-card {
        background: var(--panel-2);
        border: 1px solid var(--line);
        padding: 10px;
    }

        .label-card h4 {
            margin: 0 0 6px;
            font-size: 12px;
            color: #5c1a1a;
            font-weight: bold;
        }

        .label-card img {
            display: block;
            margin: 6px 0;
            border: 1px solid var(--line);
            padding: 4px;
            background: #fff;
        }

    .label-data {
        font-size: 10px;
        color: #111;
        line-height: 1.4;
    }

        .label-data b {
            color: #5c1a1a;
        }

    .empty {
        border: 1px dashed var(--line);
        padding: 20px;
        text-align: center;
        color: #5c1a1a;
        background: var(--panel-2);
        font-size: 11px;
        font-weight: bold;
    }

    .timeline {
        display: flex;
        gap: 6px;
        align-items: center;
        flex-wrap: wrap;
        background: var(--panel-2);
        padding: 6px 10px;
        border: 1px solid var(--line);
        margin-bottom: 10px;
    }

    .step {
        display: flex;
        align-items: center;
        gap: 4px;
        color: #666;
        font-size: 10px;
        font-weight: bold;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #ccc;
        border: 1px solid #999;
    }

    .step.on {
        color: #8b0000;
    }

        .step.on .dot {
            background: #8b0000;
            border-color: #5c0000;
        }

    /* MODALES Y TOAST */
    .toast {
        position: fixed;
        right: 18px;
        bottom: 18px;
        background: #3b1717;
        color: white;
        padding: 10px 14px;
        border: 1px solid #8b0000;
        opacity: 0;
        transform: translateY(16px);
        transition: .25s ease;
        z-index: 2000;
        font-size: 11px;
        font-weight: bold;
    }

        .toast.show {
            opacity: 1;
            transform: translateY(0);
        }

    .modal-backdrop-custom {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.6);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 20px;
        z-index: 1900;
    }

        .modal-backdrop-custom.show {
            display: flex;
        }

    .modal-custom {
        background: var(--bg);
        border: 1px solid #8b0000;
        max-width: 1000px;
        width: 100%;
        max-height: 90vh;
        overflow: auto;
        padding: 0;
        box-shadow: 0 10px 30px rgba(0,0,0,.3);
    }

    .modal-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 6px 10px;
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
        border-bottom: 1px solid #5c0000;
        color: #fff;
    }

        .modal-head h3 {
            margin: 0;
            color: #fff;
            font-size: 12px;
            font-weight: bold;
        }

    .modal-custom > textarea {
        border: 0 !important;
        background: #fffafa !important;
        width: 100%;
        min-height: 400px;
        font-family: Consolas,monospace;
        color: #111 !important;
        padding: 10px;
    }

    .print-only {
        display: none;
    }

    /* RESPONSIVE */
    @@media (max-width: 900px) {
        .header-top {
            flex-direction: column;
            align-items: stretch;
            gap: 10px;
        }

        .nav-btn {
            font-size: 10px;
            padding: 6px 10px;
            flex: 1;
            justify-content: center;
        }

        .grid.cols-4 {
            grid-template-columns: 1fr 1fr;
        }

        .form-grid {
            grid-template-columns: 1fr !important;
        }

        .split-panel {
            grid-template-columns: 1fr;
        }

        .request-card {
            grid-template-columns: 1fr;
        }
    }

    /* ESTILOS PARA LAS ETIQUETAS EN PANTALLA */
    .position-relative {
        position: relative;
    }

    .print-cb {
        position: absolute;
        top: 12px;
        right: 12px;
        transform: scale(1.4);
        cursor: pointer;
        z-index: 10;
        accent-color: #8b0000;
    }

    .lc-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid var(--line);
        padding-bottom: 5px;
        margin-bottom: 8px;
        padding-right: 25px;
    }

        .lc-header h4 {
            margin: 0;
            font-size: 16px;
            color: #5c1a1a;
            font-weight: 900;
        }

    .lc-row {
        display: flex;
        padding: 3px 0;
        border-bottom: 1px solid #f0dede;
        font-size: 11px;
    }

    .lc-lbl {
        width: 35%;
        font-weight: bold;
        color: #5c1a1a;
        text-transform: uppercase;
        font-size: 10px;
    }

    .lc-val {
        width: 65%;
        color: #111;
    }

    .sku-hl {
        font-weight: 900;
        color: #8b0000;
        font-size: 13px;
    }

    .lc-footer {
        margin-top: 10px;
        text-align: center;
        font-family: Consolas, monospace;
        font-size: 10px;
        background: #fff;
        padding: 5px;
        border: 1px dashed var(--line);
        font-weight: bold;
    }

    /* BUSCADOR  */
    .custom-select-wrapper {
        position: relative;
        width: 100%;
    }

    .custom-select-display {
        border: 1px solid #b48787;
        background: #fffdfd;
        padding: 4px 25px 4px 8px;
        cursor: pointer;
        min-height: 26px;
        display: flex;
        align-items: center;
        color: #421414;
        position: relative;
    }

        .custom-select-display::after {
            content: '▼';
            position: absolute;
            right: 8px;
            font-size: 8px;
            color: #666;
        }

    .custom-select-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #fff;
        border: 1px solid #b48787;
        border-top: none;
        z-index: 1000;
        box-shadow: 0 4px 6px rgba(0,0,0,0.15);
        display: none;
    }

        .custom-select-dropdown.show {
            display: block;
        }

    .custom-select-search {
        width: calc(100% - 12px) !important;
        margin: 6px !important;
        padding: 4px 6px !important;
        border: 1px solid #000 !important;
        border-radius: 2px !important;
        outline: none;
        min-height: 24px !important;
    }

    .custom-select-options {
        list-style: none;
        margin: 0;
        padding: 0;
        max-height: 200px;
        overflow-y: auto;
    }

        .custom-select-options li {
            padding: 8px 10px;
            cursor: pointer;
            color: #111;
            border-bottom: 1px solid #f0f0f0;
        }

            .custom-select-options li:hover {
                background: #5591f5;
                color: #fff;
            }

            .custom-select-options li.hidden {
                display: none;
            }

            .form-locked-overlay {
                position: relative;
            }
            .form-locked-overlay::after {
                content: 'Selecciona una OV de muestra para comenzar';
                position: absolute;
                top: 0; left: 0; right: 0; bottom: 0;
                background: rgba(255,255,255,0.7);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 14px;
                font-weight: bold;
                color: #888;
                z-index: 5;
                pointer-events: none;
            }
</style>

<div class="app-shell" id="appShellMain">
    <header class="module-header no-print">
        <div class="header-top">
            <div class="brand">
                <div class="brand-mark">SM</div>
                <div>
                    <h1>Solicitud de Muestras</h1>
                    <small>Producción · Etiquetas · Tracking</small>
                </div>
            </div>
            <div class="header-actions">
                <button type="button" class="secondary" onclick="generarReporteGeneral()">Reporte general PDF</button>
                <button type="button" class="secondary" id="btnAdminPermisos" onclick="abrirAdminPermisos()" style="display:none;">⚙ Permisos</button>
            </div>
        </div>

        @{
            var perfilUsuario = ViewData["Perfil"]?.ToString() ?? "Vendedor";
        }

        <nav class="module-tabs" id="mainTabs" data-user-role="@perfilUsuario">
            <button type="button" class="nav-btn active" style="display: none;" data-section="solicitud" data-auth="Vendedor,Admin,Solicitud"><span class="pill">1</span> Solicitud vendedor</button>
            <button type="button" class="nav-btn" style="display: none;" data-section="planeacion" data-auth="Planeador,Admin,Planeacion"><span class="pill">2</span> Planeación</button>
            <button type="button" class="nav-btn" style="display: none;" data-section="produccion" data-auth="Produccion,Admin,Produccion"><span class="pill">3</span> Producción / Etiquetas</button>
            <button type="button" class="nav-btn" style="display: none;" data-section="tracking" data-auth="Vendedor,Planeador,Produccion,Admin,Solicitud,Planeacion,Produccion,Tracking"><span class="pill">4</span> Tracking</button>
        </nav>
    </header>

    <main class="module-main">
        <div class="grid cols-4 no-print" id="kpis"></div>

        <section id="solicitud" class="section active">
            <div class="card">
                <form id="requestForm">
                    <div class="form-subtitle" style="background: #fff3cd; border-left: 4px solid #ffc107; padding: 10px 15px; margin-bottom: 15px; border-radius: 4px;">
                        <i class="bi bi-link-45deg"></i> <strong>Cargar desde Orden de Venta (muestra) *</strong>
                        <div style="display:flex; gap:10px; align-items:center; margin-top:8px;">
                            <select id="ovMuestraSelect" required style="flex:1; padding:6px 10px; border:1px solid #ccc; border-radius:4px;">
                                <option value="">Selecciona una OV de muestra...</option>
                            </select>
                            <button type="button" id="btnCargarOV" class="btn btn-sm btn-outline-primary" disabled>
                                <i class="bi bi-download"></i> Cargar datos
                            </button>
                        </div>
                        <small class="text-muted">Debes seleccionar una OV para crear la solicitud.</small>
                    </div>

                    <div class="form-subtitle">1. Datos Generales de la Solicitud</div>
                    <div id="formContentLocked" class="form-locked-overlay">
                    <div class="form-grid">
                        <div>
                            <label>Solicita / Vendedor</label>
                            <input required name="seller" readonly value="@User.Identity?.Name" style="background-color: #f0f0f0; color: #666; cursor: not-allowed;" />
                        </div>
                        <div>
                            <label>Cliente</label>
                            <input required name="client" id="clientHidden" readonly placeholder="Se carga desde la OV" style="background-color: #f0f0f0; color: #666; cursor: not-allowed; width: 100%;" />
                        </div>
                        <div>
                            <label>Especie / clasificación</label>
                            <select required name="species">
                                <option value="NOV">NOV</option>
                                <option value="VG">VG</option>
                            </select>
                        </div>
                        <div>
                            <label>Fecha requerida</label>
                            <input required type="date" name="requestedDate" />
                        </div>
                    </div>

                    <div class="form-subtitle">2. Información Logística y Observaciones</div>
                    <div class="form-grid">
                        <div>
                            <label>Ruta logística</label>
                            <input required name="route" placeholder="Ej. Ruta Altos Norte, Ruta Guadalajara, etc." />
                        </div>
                        <div>
                            <label>Destino</label>
                            <input required name="destination" placeholder="Ej. CEDIS Zapopan" />
                        </div>
                        <div>
                            <label>Prioridad</label>
                            <select name="priority">
                                <option>Alta</option>
                                <option>Media</option>
                                <option>Baja</option>
                            </select>
                        </div>
                        <div class="full">
                            <label>Requerimiento general / observaciones</label>
                            <textarea name="notes" placeholder="Ej. Cliente pidió muestras para evaluación de empaque, color, marmoleo y gramaje."></textarea>
                        </div>
                    </div>

                    <div class="section-header">
                        <div>
                            <h3>3. Artículos (SKUs) solicitados</h3>
                        </div>
                    </div>

                    <div class="table-wrap">
                        <table id="itemsTable">
                            <thead>
                                <tr>
                                    <th>SKU</th>
                                    <th>Producto</th>
                                    <th>Especificación / requerimiento</th>
                                    <th>Cajas</th>
                                    <th>Temperatura</th>
                                    <th>Acción</th>
                                </tr>
                            </thead>
                            <tbody id="itemsBody"></tbody>
                        </table>
                    </div>

                    </div>

                    <div class="header-actions" style="margin-top:10px; justify-content: flex-end;">
                        <button type="submit" class="success" id="btnSubmitSolicitud" disabled>Crear solicitud de muestra</button>
                    </div>
                </form>
            </div>

            <div class="section-header" style="margin-top: 20px;">
                <div>
                    <h3>Solicitudes Nuevas (Pendientes)</h3>
                    <p>Vista de requerimientos que no han sido planeados.</p>
                </div>
                <button type="button" class="secondary" id="btnHistSolicitudes" onclick="abrirHistorial('solicitud')">
                    Ver historial (0)
                </button>
            </div>
            <div id="requestList" class="grid"></div>
        </section>

        <section id="planeacion" class="section">
            <div class="section-header">
                <div>
                    <h3>Planeación de producción (Nuevas)</h3>
                    <p>Defina el SKU a trabajar, turno y fecha para enviarlo a producción.</p>
                </div>
                <button type="button" class="secondary" id="btnHistPlaneacion" onclick="abrirHistorial('planeacion')">
                    Ver historial (0)
                </button>
            </div>
            <div id="planningList" class="grid"></div>
        </section>

        <section id="produccion" class="section">
            <div class="section-header print-title">
                <div>
                    <h3>Producción y Ligado de Etiquetas</h3>                    <p class="no-print">Escanee la etiqueta y líguela al SKU y solicitud correspondiente.</p>
                </div>
                <div class="header-actions no-print">
                    <button class="secondary" type="button" id="btnHistProduccion" onclick="abrirHistorial('produccion')">Ver historial (0)</button>
                    <button class="secondary" type="button" onclick="imprimirEtiquetas()">Imprimir etiquetas generadas</button>
                </div>
            </div>
            <div class="split-panel">
                <div class="card scan-panel no-print">
                    <div class="form-subtitle" style="margin: -12px -12px 10px -12px;">Escaneo / ligado</div>
                    <form id="scanForm" class="grid">
                        <div>
                            <label>Solicitud liberada</label>
                            <select id="scanRequest" required></select>
                        </div>
                        <div>
                            <label>SKU / especificación</label>
                            <select id="scanItem" required></select>
                        </div>
                        <div>
                            <label>Etiqueta DEST escaneada</label>
                            <input id="scanLabel" required placeholder="Ej. DEST000001" />
                        </div>
                        <div>
                            <label>Operario</label>
                            <input id="operatorName" readonly required value="@usuarioLogueado" style="background-color: #f0f0f0; color: #666; cursor: not-allowed;" />
                        </div>
                        <button class="success" type="submit" style="margin-top: 5px;">Ligar etiqueta</button>
                    </form>
                </div>
                <div>
                    <div class="section-header" style="margin-top: 0;">
                        <div><h3 style="margin:0;">Muestras en producción activa</h3></div>
                    </div>
                    <div class="grid" id="productionList"></div>
                </div>
            </div>
        </section>

        <section id="tracking" class="section">
            <div class="card no-print" style="margin-bottom: 15px;">
                <div class="form-grid two" style="margin-bottom:0; border:none; padding:0; background:transparent;">
                    <div>
                        <label>Buscar folio, cliente, vendedor, SKU o etiqueta</label>
                        <input id="trackSearch" placeholder="Ej. SM-2026-0001, RD021, DEST000001" />
                    </div>
                    <div>
                        <label>Filtrar por estatus</label>
                        <select id="trackStatus">
                            <option value="">Todos activos</option>
                            <option>Pendiente</option>
                            <option>Planeada</option>
                            <option>Producción parcial</option>
                            <option>Cumplido producción</option>
                            <option>En almacén</option>
                        </select>
                    </div>
                    <div>
                        <label>Fecha desde</label>
                        <input type="date" id="trackDateFrom" />
                    </div>
                    <div>
                        <label>Fecha hasta</label>
                        <input type="date" id="trackDateTo" />
                    </div>
                </div>
            </div>

            <div class="section-header">
                <div>
                    <h3>Panel de seguimiento activo</h3>
                    <p>Controle la ubicación de la muestra. Las surtidas pasan al historial.</p>
                </div>
                <button type="button" class="secondary" id="btnHistTracking" onclick="abrirHistorial('tracking')">
                    Ver Entregadas (0)
                </button>
            </div>
            <div class="table-wrap">
                <table id="trackingTable">
                    <thead>
                        <tr>
                            <th>Folio</th>
                            <th>Cliente</th>
                            <th>Ruta / destino</th>
                            <th>SKU y etiquetas</th>
                            <th>Cumplimiento</th>
                            <th>Ubicación</th>
                            <th>Estatus</th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody id="trackingBody"></tbody>
                </table>
            </div>
        </section>
    </main>
</div>

<div class="modal-backdrop-custom" id="modalHistorial">
    <div class="modal-custom">
        <div class="modal-head" style="position: sticky; top: 0; z-index: 10;">
            <h3 id="historialTitle">Historial de Solicitudes</h3>
            <button type="button" class="secondary" onclick="document.getElementById('modalHistorial').classList.remove('show')">Cerrar</button>
        </div>
        <div style="padding: 10px; min-height: 50vh;">
            <div id="historialContentContainer" class="grid cols-1"></div>
        </div>
    </div>
</div>

<div class="modal-backdrop-custom" id="modalAdminPermisos">
    <div class="modal-custom" style="max-width: 700px;">
        <div class="modal-head" style="position: sticky; top: 0; z-index: 10;">
            <h3>Configurar permisos del módulo</h3>
            <button type="button" class="secondary" onclick="document.getElementById('modalAdminPermisos').classList.remove('show')">Cerrar</button>
        </div>
        <div style="padding: 10px;">
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--bg);">
                        <th style="text-align:left;padding:8px;">Perfil</th>
                        <th style="text-align:center;padding:8px;">Vendedor</th>
                        <th style="text-align:center;padding:8px;">Planeación</th>
                        <th style="text-align:center;padding:8px;">Producción</th>
                    </tr>
                </thead>
                <tbody id="tbodyPermisosMuestras"></tbody>
            </table>
        </div>
    </div>
</div>

<div class="toast" id="toast"></div>

@section Scripts {
    <script>
        const qs = selector => document.querySelector(selector);
        const qsa = selector => Array.from(document.querySelectorAll(selector));

        console.log("Modulo de muestras cargado y blindado.");

        let requests = [];
        let histSolicitud = [];
        let histPlaneacion = [];
        let histProduccion = [];
        let histTracking = [];
        let articulosSap = [];
        let articulosOptionsHTML = '';
        let selectedOVId = null;

        async function loadArticulos() {
            try {
                const response = await fetch('@Url.Action("ObtenerArticulosSap", "Comercial")');
                if (!response.ok) {
                    console.error("Error HTTP al cargar artículos SAP:", response.status);
                    return;
                }
                const data = await response.json();

                if (Array.isArray(data) && data.length > 0) {
                    articulosSap = data;
                    articulosOptionsHTML = articulosSap.map(a => {
                        const cod = a.Codigo || a.codigo || a.ProductoCodigo || a.productoCodigo || 'SC';
                        const nom = a.Nombre || a.nombre || a.ProductoNombre || a.productoNombre || 'Sin nombre';
                        return `<li data-codigo="${cod}" data-nombre="${nom}">${cod} - ${nom}</li>`;
                    }).join('');

                    if(qs('.sku-options')) qsa('.sku-options').forEach(ul => ul.innerHTML = articulosOptionsHTML);
                } else {
                    console.warn("La respuesta de artículos SAP está vacía o no es un arreglo.", data);
                }
            } catch (e) {
                console.error("Error al cargar artículos SAP", e);
            }
        }

               async function loadData() {
            try {
                const perfil = '@perfilUsuario';
                const usuario = '@User.Identity?.Name';
                let url = '@Url.Action("ObtenerSolicitudes", "Comercial")';

                // Si es vendedor, solo mostrar sus propias solicitudes
                if (perfil === 'Vendedor') {
                    url += '?vendedor=' + encodeURIComponent(usuario);
                }

                const response = await fetch(url);
                if (response.ok) {
                    const data = await response.json();
                    requests = Array.isArray(data) ? data : [];
                    renderAll();
                } else {
                    toast('Error al leer datos del servidor.');
                }
            } catch (error) {
                console.error(error);
                toast('Sin conexion al backend.');
            }
        }
                // Cargar OV de muestra disponibles para el vendedor
        async function loadOVMuestras() {
            try {
                const response = await fetch('@Url.Action("ObtenerOVMuestras", "Comercial")');
                if (!response.ok) return;
                const data = await response.json();
                const select = document.getElementById('ovMuestraSelect');
                const btn = document.getElementById('btnCargarOV');

                if (!Array.isArray(data) || data.length === 0) {
                    select.innerHTML = '<option value="">No hay OV de muestra disponibles</option>';
                    return;
                }

                select.innerHTML = '<option value="">Selecciona una OV de muestra (opcional)...</option>';
                data.forEach(ov => {
                    const opt = document.createElement('option');
                    opt.value = JSON.stringify(ov);
                    opt.textContent = `${ov.consecutivo} - ${ov.clienteNombre || ov.cliente} - ${ov.ruta || 'Sin ruta'}`;
                    select.appendChild(opt);
                });

                select.addEventListener('change', function() {
                    btn.disabled = !this.value;
                });

                btn.addEventListener('click', function() {
                    if (!select.value) return;
                    const ov = JSON.parse(select.value);
                    selectedOVId = ov.id;

                    // Desbloquear formulario
                    const lockedDiv = document.getElementById('formContentLocked');
                    if (lockedDiv) lockedDiv.classList.remove('form-locked-overlay');
                    const btnSubmit = document.getElementById('btnSubmitSolicitud');
                    if (btnSubmit) btnSubmit.disabled = false;

                    // Llenar cliente
                    document.getElementById('clientHidden').value = ov.clienteNombre ? `${ov.cliente} - ${ov.clienteNombre}` : ov.cliente || '';

                    // Ruta y destino se dejan en blanco para que el usuario los llen
                    const routeInput = document.querySelector('[name="route"]');
                    if (routeInput) routeInput.value = '';

                    const destInput = document.querySelector('[name="destination"]');
                    if (destInput) destInput.value = '';

                    // Llenar observaciones
                    const notesInput = document.querySelector('[name="notes"]');
                    if (notesInput) notesInput.value = ov.observacion ? `OV ${ov.consecutivo}: ${ov.observacion}` : `OV ${ov.consecutivo}`;

                    // Llenar fecha requerida
                    const fechaInput = document.querySelector('[name="requestedDate"]');
                    if (fechaInput && ov.fechaEntrega) {
                        fechaInput.value = ov.fechaEntrega.slice(0, 10);
                    }

                    // Bloquear campos que no se deben editar
                    const lockStyle = 'background-color: #f0f0f0; color: #666; cursor: not-allowed;';
                    if (notesInput) { notesInput.readOnly = false; notesInput.style.cssText = ''; }
                    if (fechaInput) { fechaInput.readOnly = true; fechaInput.style.cssText = lockStyle; }
                    const priorityInput = document.querySelector('[name="priority"]');
                    if (priorityInput) { priorityInput.disabled = false; priorityInput.style.cssText = ''; }

                    // Bloquear botones de eliminar y campos en la tabla de items
                    setTimeout(() => {
                        document.querySelectorAll('#itemsBody input:not(.item-temp), #itemsBody textarea:not(.item-spec), #itemsBody select:not(.item-temp)').forEach(el => {
                            el.readOnly = true;
                            el.disabled = true;
                            el.style.cssText = lockStyle;
                        });
                        document.querySelectorAll('#itemsBody .btn-ghost, #itemsBody .btn-danger, #itemsBody button').forEach(el => {
                            el.disabled = true;
                            el.style.display = 'none';
                        });
                    }, 500);

                    // Cargar productos de la OV
                    cargarProductosOV(ov.id);

                    toast('Datos de OV cargados en el formulario.');
                });
            } catch (error) {
                console.error('Error cargando OV de muestra', error);
            }
        }

        // Cargar productos de una OV específica
        async function cargarProductosOV(ovId) {
            try {
                const response = await fetch('@Url.Action("ObtenerProductosOV", "Comercial")?ovId=' + ovId);
                if (!response.ok) return;
                const productos = await response.json();

                // Limpiar tabla actual
                const tbody = document.getElementById('itemsBody');
                if (tbody) tbody.innerHTML = '';

                const lockStyle = 'background-color: #f0f0f0; color: #666; cursor: not-allowed;';

                if (Array.isArray(productos)) {
                    productos.forEach(p => {
                        addItem({
                            sku: p.productoCodigo || '',
                            product: p.productoNombre || '',
                            spec: '',
                            boxes: p.cajas || 1,
                            temp: 'Refrigerado 0-4 °C'
                        });
                    });

                    // Bloquear todos los campos de la tabla de items
                    setTimeout(() => {
                        document.querySelectorAll('#itemsBody input:not(.item-temp), #itemsBody textarea:not(.item-spec), #itemsBody select:not(.item-temp)').forEach(el => {
                            el.readOnly = true;
                            el.disabled = true;
                            el.style.cssText = lockStyle;
                        });
                        document.querySelectorAll('#itemsBody .btn-ghost, #itemsBody .btn-danger, #itemsBody button').forEach(el => {
                            el.disabled = true;
                            el.style.display = 'none';
                        });
                    }, 300);
                }
            } catch (error) {
                console.error('Error cargando productos OV', error);
            }
        }

        // Ejecutar al cargar la página
        loadOVMuestras();


        function uid(){ return 'it-' + crypto.randomUUID().slice(0,8); }
        function todayPlus(days){ const d = new Date(); d.setDate(d.getDate()+days); return d.toISOString().slice(0,10); }
        function formatDate(value){ if(!value) return 'Sin definir'; const d = new Date(value); return Number.isNaN(d.getTime()) ? value : d.toLocaleDateString('es-MX', {year:'numeric', month:'short', day:'2-digit'}); }
        function formatDateTime(value){ if(!value) return 'Sin definir'; const d = new Date(value); return Number.isNaN(d.getTime()) ? value : d.toLocaleString('es-MX', {dateStyle:'medium', timeStyle:'short'}); }
        function totalBoxes(req){ return req.items.reduce((sum,item)=>sum+Number(item.boxes||0),0); }
        function linkedLabels(req){ return req.items.reduce((sum,item)=>sum+(item.labels?.length||0),0); }

        function requestStatus(req){
            const total = totalBoxes(req), linked = linkedLabels(req);
            if(req.stage === 'Surtido al cliente' || req.location === 'Surtido al cliente') return 'Surtido al cliente';
            if(req.location === 'Almacén Refrigerado' && linked === total && total>0) return 'En almacén';
            if(req.stage === 'Cancelada') return 'Cancelada';
            if(linked === total && total>0) return 'Cumplido producción';
            if(linked > 0) return 'Producción parcial';
            if(req.planning) return 'Planeada';
            return 'Pendiente';
        }

        function statusClass(status){
            if(status.includes('Cumplido') || status.includes('Surtido')) return 'done';
            if(status.includes('parcial')) return 'progress';
            if(status.includes('Planeada') || status.includes('almacén')) return 'planned';
            if(status.includes('Cancelada')) return 'danger';
            return 'pending';
        }

        function nextRequestId(){
            const max = requests.map(r => Number((r.id?.match(/(\d+)$/)||[0,0])[1])).reduce((a,b)=>Math.max(a,b),0);
            return `SM-${new Date().getFullYear()}-${String(max+1).padStart(4,'0')}`;
        }

        function nextDestCode(){
            const all = requests.flatMap(r => r.items.flatMap(i => i.labels || [])).map(l => Number((l.code?.match(/(\d+)$/)||[0,0])[1]));
            const max = all.length ? Math.max(...all) : 0;
            return 'DEST' + String(max+1).padStart(6,'0');
        }

        function toast(message){
            const box = qs('#toast'); box.textContent = message; box.classList.add('show');
            setTimeout(()=>box.classList.remove('show'), 2600);
        }

        function badge(text){ return `<span class="badge ${statusClass(text)}">${text}</span>`; }
        function setDefaultDates(){ if(qs('[name="requestedDate"]')) qs('[name="requestedDate"]').value = todayPlus(5); }

        function itemRowTemplate(item={sku:'', product:'', spec:'', boxes:1, temp:'Refrigerado 0-4 °C'}){
            return `
            <tr>
                <td style="min-width: 120px;">
                    <input class="item-sku" required value="${item.sku||''}" readonly style="background-color: #f0f0f0; color: #666; cursor: not-allowed; width:100%;" />
                </td>
                <td><input class="item-product" required value="${item.product||''}" placeholder="Se llena solo" readonly style="background-color: #f0f0f0; color: #666; cursor: not-allowed;" /></td>
                <td><textarea class="item-spec" required placeholder="Ej. Caja 12 kg...">${item.spec||''}</textarea></td>
                <td><input type="number" min="1" class="item-boxes" required value="${item.boxes||1}" /></td>
                <td>
                    <select class="item-temp">
                        <option ${item.temp==='Refrigerado 0-4 °C'?'selected':''}>Refrigerado 0-4 °C</option>
                        <option ${item.temp==='Congelado -18 °C'?'selected':''}>Congelado -18 °C</option>
                        <option ${item.temp==='Ambiente'?'selected':''}>Ambiente</option>
                    </select>
                </td>
                <td style="text-align:center;">
                    <button type="button" class="danger remove-item">Eliminar</button>
                </td>
            </tr>
            `;
        }

        function addItem(item){ if(qs('#itemsBody')) qs('#itemsBody').insertAdjacentHTML('beforeend', itemRowTemplate(item)); }

        function clearItems(){
            if(qs('#itemsBody')){
                qs('#itemsBody').innerHTML = '';
                addItem();
            }
        }

        function collectItems(){
            return qsa('#itemsBody tr').map(row => ({
                uid:uid(), sku:row.querySelector('.item-sku').value.trim(), product:row.querySelector('.item-product').value.trim(),
                spec:row.querySelector('.item-spec').value.trim(), boxes:Number(row.querySelector('.item-boxes').value), temp:row.querySelector('.item-temp').value, labels:[]
            })).filter(i => i.sku && i.spec && i.boxes>0);
        }

        function renderKpis(){
            const total = requests.length;
            const pendingPlan = requests.filter(r=>!r.planning && requestStatus(r) !== 'Cancelada').length;
            const boxes = requests.reduce((s,r)=>s+totalBoxes(r),0);
            const linked = requests.reduce((s,r)=>s+linkedLabels(r),0);

            if(qs('#kpis')) qs('#kpis').innerHTML = `
            <div class="kpi"><small>Solicitudes Totales</small><strong>${total}</strong><span class="hint">folios en sistema</span></div>
            <div class="kpi"><small>Pendientes Planeacion</small><strong>${pendingPlan}</strong><span class="hint">por asignar a produccion</span></div>
            <div class="kpi"><small>Cajas Muestras</small><strong>${boxes}</strong><span class="hint">cajas solicitadas</span></div>
            <div class="kpi"><small>Etiquetas Generadas</small><strong>${linked}/${boxes}</strong><span class="hint">avance total produccion</span></div>
            `;
        }

        function createRequestCard(req) {
            const status = requestStatus(req), total = totalBoxes(req), linked = linkedLabels(req), pct = total ? Math.round(linked/total*100) : 0;
            let btnEnviar = '';
            let btnCancelar = '';
            if (!req.planning && status === 'Pendiente') {
                btnCancelar = `<button type="button" class="ghost" style="margin-top:10px; width:100%;" onclick="cancelarSolicitud('${req.id}')">Cancelar solicitud</button>`;
            }
            return `
                <div class="card request-card">
                <div>
                    <div class="request-title">
