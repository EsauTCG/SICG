                                                <ul class="custom-select-options sku-options">${articulosOptionsHTML}</ul>
                                            </div>
                                            <input type="hidden" class="item-sku" data-required-sku="true" name="workSku-${item.uid}" value="${item.workSku || ''}">
                                        </div>`}
                                </div>
                                `).join('')}
