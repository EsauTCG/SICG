                            </div>
                            ${btnEnviar}${btnEditar}${btnCancelar}
                        </div>
                        <div>
                            <b style="color: #5c1a1a; font-size: 11px;">Cumplimiento</b>
                            <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
                            <p class="mini">${linked} de ${total} cajas ligadas.</p>
                            <p class="mini" style="margin-top: 10px;"><b>Observaciones:</b><br>${req.notes || 'Ninguna'}</p>
                        </div>
                        </div>
                    `;
                }

                function createPlanningCard(req, isHistory = false) {
                    const dis = isHistory ? 'disabled' : '';
                    const btnHtml = isHistory ? '' : `<button class="success" type="submit" style="margin-top: 5px;">Guardar SKU y liberar a produccion</button>`;
                    return `
                        <div class="card request-card">
                        <div>
                            <div class="request-title">
                            <div><h4>${req.id} · ${req.client}</h4><span class="mini">Especie ${req.species || 'Sin definir'} · Destino ${req.destination}</span></div>
                            ${badge(requestStatus(req))}
                            </div>
                            <div class="items-list">
                            ${req.items.map(item=>`
                                <div class="item-line"><strong>Solicitado: ${item.sku} · ${item.product}</strong><small>${item.boxes} caja(s) · ${item.spec}</small></div>
                            `).join('')}
                            </div>
                        </div>
                        <form class="planning-form grid" data-id="${req.id}" style="background: var(--panel-2); padding: 8px; border: 1px solid var(--line);">
                            <div>
                            <label>SKU asignado para producir <span style="color:#b30000;">*</span></label>
                            <div class="items-list" style="margin-top:0;">
                                ${req.items.map(item=>`
