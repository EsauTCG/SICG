<div class="toast" id="toast"></div>

@section Scripts {
    <script>
                const qs = selector => document.querySelector(selector);
                const qsa = selector => Array.from(document.querySelectorAll(selector));

                console.log("Modulo de muestras cargado y blindado.");

                let requests = [];
                let histSolicitud = [];
                let histPlaneacion = [];
                let histProduccion = [];
                let histTracking = [];
                let articulosSap = [];
                let articulosOptionsHTML = '';
                let selectedOVId = null;
                const ovMuestrasDisponibles = new Map();

                // Tracking real consultado en CadenaMeatTIF y CadenaMeatP1.
                let trackingMeat = new Map();
                let trackingMeatCargando = false;
                let subPermisosProduccion = { linea: true, nuevo: true };
                let estadoCheckboxes = new Map();

                async function loadArticulos() {
                    try {
                        const response = await fetch('@Url.Action("ObtenerArticulosSap", "Comercial")');
                        if (!response.ok) {
                            console.error("Error HTTP al cargar artículos SAP:", response.status);
                            return;
                        }
                        const data = await response.json();

                        if (Array.isArray(data) && data.length > 0) {
                            articulosSap = data;
                            articulosOptionsHTML = articulosSap.map(a => {
                                const cod = a.Codigo || a.codigo || a.ProductoCodigo || a.productoCodigo || 'SC';
                                const nom = a.Nombre || a.nombre || a.ProductoNombre || a.productoNombre || 'Sin nombre';
                                return `<li data-codigo="${cod}" data-nombre="${nom}">${cod} - ${nom}</li>`;
                            }).join('');

                            if(qs('.sku-options')) qsa('.sku-options').forEach(ul => ul.innerHTML = articulosOptionsHTML);
                        } else {
                            console.warn("La respuesta de artículos SAP está vacía o no es un arreglo.", data);
                        }
                    } catch (e) {
                        console.error("Error al cargar artículos SAP", e);
                    }
                }

                async function loadData() {
                    try {
                        const perfil = '@perfilUsuario';
                        const usuario = '@User.Identity?.Name';
                        let url = '@Url.Action("ObtenerSolicitudes", "Comercial")';

                        if (perfil === 'Vendedor') {
                            url += '?vendedor=' + encodeURIComponent(usuario) + '&soloMias=true';
                        }

                        const response = await fetch(url);

                        if (!response.ok) {
                            toast('Error al leer datos del servidor.');
                            return;
                        }

                        const data = await response.json();
                        requests = Array.isArray(data) ? data : [];

                        renderAll();

                        cargarTrackingMeat();
                    } catch (error) {
                        console.error(error);
                        toast('Sin conexión al backend.');
                    }
                }

                        // Cargar OV de muestra disponibles para el vendedor
                function bloquearProductosCargadosDesdeOV() {
                    const lockStyle =
                        'background-color:#f0f0f0; color:#666; cursor:not-allowed;';

                    document.querySelectorAll(
                        '#itemsBody .item-sku, #itemsBody .item-product, #itemsBody .item-boxes'
                    ).forEach(el => {
                        el.readOnly = true;
                        el.disabled = true;
                        el.style.cssText = lockStyle;
                    });

                    document.querySelectorAll('#itemsBody .remove-item').forEach(el => {
                        el.disabled = true;
                        el.style.display = 'none';
                    });

                    // Estos dos campos sí quedan disponibles para completar la muestra.
                    document.querySelectorAll('#itemsBody .item-spec, #itemsBody .item-temp')
                        .forEach(el => {
                            el.disabled = false;
                            el.readOnly = false;
                        });
                }

                function resetEstadoOVMuestra() {
                    selectedOVId = null;

                    const select = document.getElementById('ovMuestraSelect');
                    const btnCargar = document.getElementById('btnCargarOV');
                    const clientHidden = document.getElementById('clientHidden');
                    const clientDisplay = document.getElementById('clientDisplay');
                    const destHidden = document.getElementById('destinatarioHidden');
                    const destBtnText = document.getElementById('destinatarioBtnText');
                    const lockedDiv = document.getElementById('formContentLocked');
                    const btnSubmit = document.getElementById('btnSubmitSolicitud');

                    if (select) select.value = '';
                    if (btnCargar) btnCargar.disabled = true;
                    if (clientHidden) clientHidden.value = '';
                    if (clientDisplay) clientDisplay.value = '';
                    if (destHidden) destHidden.value = '';
                    if (destBtnText) { destBtnText.textContent = 'Seleccionar cliente...'; destBtnText.style.color = '#888'; }
                    if (lockedDiv) lockedDiv.classList.add('form-locked-overlay');
                    if (btnSubmit) btnSubmit.disabled = true;
                }

                async function cargarProductosOV(ovId) {
                    const response = await fetch(
                        '@Url.Action("ObtenerProductosOV", "Comercial")'
                        + '?ovId='
                        + encodeURIComponent(ovId),
                        {
                            method: 'GET',
                            headers: { 'Accept': 'application/json' },
                            cache: 'no-store'
                        }
                    );

                    let productos = null;

                    try {
                        productos = await response.json();
                    } catch {
                        throw new Error(
                            `El servidor respondió HTTP ${response.status} sin JSON válido.`
                        );
                    }

                    if (!response.ok) {
                        throw new Error(
                            productos?.mensaje || `Error HTTP ${response.status} al consultar productos.`
                        );
                    }

                    if (!Array.isArray(productos)) {
                        throw new Error(
                            productos?.mensaje || 'La respuesta de productos de la OV no es válida.'
                        );
                    }

                    if (productos.length === 0) {
                        throw new Error('La Orden de Venta seleccionada no contiene productos activos.');
                    }

                    const tbody = document.getElementById('itemsBody');
                    if (tbody) tbody.innerHTML = '';

                    productos.forEach(p => {
                        addItem({
                            sku: p.productoCodigo || p.ProductoCodigo || '',
                            product: p.productoNombre || p.ProductoNombre || '',
                            spec: '',
                            boxes: Number(p.cajas ?? p.Cajas ?? 1) || 1,
                            temp: 'Refrigerado 0-4 °C'
                        });
                    });

                    bloquearProductosCargadosDesdeOV();
                    return true;
                }

                async function loadOVMuestras() {
                    const select = document.getElementById('ovMuestraSelect');
                    const btn = document.getElementById('btnCargarOV');

                    if (!select || !btn) return;

                    selectedOVId = null;
                    ovMuestrasDisponibles.clear();
                    btn.disabled = true;
                    select.disabled = true;
                    select.innerHTML = '<option value="">Cargando OV de muestra...</option>';

                    try {
                        const response = await fetch(
                            '@Url.Action("ObtenerOVMuestras", "Comercial")',
                            {
                                method: 'GET',
                                headers: { 'Accept': 'application/json' },
                                cache: 'no-store'
                            }
                        );

                        let data = null;

                        try {
                            data = await response.json();
                        } catch {
                            throw new Error(
                                `El servidor respondió HTTP ${response.status} sin JSON válido.`
                            );
                        }

                        if (!response.ok) {
                            throw new Error(
                                data?.mensaje || `Error HTTP ${response.status} al consultar las OV.`
                            );
                        }

                        if (!Array.isArray(data)) {
                            throw new Error(
                                data?.mensaje || 'La respuesta de OV de muestra no es válida.'
                            );
                        }

                        select.innerHTML =
                            '<option value="">Selecciona una OV de muestra...</option>';

                        data.forEach(ov => {
                            const id = String(ov.id ?? ov.Id ?? '').trim();
                            if (!id) return;

                            ovMuestrasDisponibles.set(id, ov);

                            const consecutivo = ov.consecutivo ?? ov.Consecutivo ?? 'SIN FOLIO';
                            const cliente = ov.cliente ?? ov.Cliente ?? '';
                            const clienteNombre =
                                ov.clienteNombre ?? ov.ClienteNombre ?? cliente;
                            const ruta = ov.ruta ?? ov.Ruta ?? 'Sin ruta';

                            const opt = document.createElement('option');
                            opt.value = id;
                            opt.textContent =
                                `${consecutivo} - ${clienteNombre || cliente} - ${ruta}`;

                            select.appendChild(opt);
                        });

                        if (ovMuestrasDisponibles.size === 0) {
                            select.innerHTML =
                                '<option value="">No hay OV de muestra disponibles</option>';
                        }
                    } catch (error) {
                        console.error('Error cargando OV de muestra:', error);
                        select.innerHTML =
                            '<option value="">No fue posible cargar las OV de muestra</option>';
                        toast(error.message || 'No fue posible cargar las OV de muestra.');
                    } finally {
                        select.disabled = false;
                    }

                    // Asignación directa: reemplaza el manejador anterior y evita duplicados.
                    select.onchange = function () {
                        selectedOVId = null;
                        btn.disabled = !this.value;
                    };

                    btn.onclick = async function () {
                        const ovId = String(select.value || '').trim();
                        const ov = ovMuestrasDisponibles.get(ovId);

                        if (!ovId || !ov) {
                            toast('Selecciona una OV de muestra válida.');
                            return;
                        }

                        const originalText = btn.innerHTML;

                        try {
                            btn.disabled = true;
                            btn.innerHTML =
                                '<i class="bi bi-hourglass-split"></i> Cargando...';

                            // Primero validamos y cargamos productos.
                            await cargarProductosOV(ovId);

                            selectedOVId = Number(ovId);

                            const clienteCodigo =
                                String(ov.cliente ?? ov.Cliente ?? '').trim();
                            const clienteNombre =
                                String(
                                    ov.clienteNombre
                                    ?? ov.ClienteNombre
                                    ?? clienteCodigo
                                ).trim();

                            const clientHidden =
                                document.getElementById('clientHidden');
                            const clientDisplay =
                                document.getElementById('clientDisplay');

                            if (clientHidden) {
                                // Al backend se envía únicamente el código SAP.
                                clientHidden.value = clienteCodigo;
                            }

                            if (clientDisplay) {
                                clientDisplay.value = clienteNombre
                                    ? `${clienteCodigo} - ${clienteNombre}`
                                    : clienteCodigo;
                            }

                            const routeInput =
                                document.querySelector('[name="route"]');
                            if (routeInput) routeInput.value = '';

                            const destInput =
                                document.querySelector('[name="destination"]');
                            if (destInput) destInput.value = '';

                            const notesInput =
                                document.querySelector('[name="notes"]');
                            const consecutivo =
                                ov.consecutivo ?? ov.Consecutivo ?? '';

                            if (notesInput) {
                                const observacion =
                                    ov.observacion ?? ov.Observacion ?? '';

                                notesInput.value = observacion
                                    ? `OV ${consecutivo}: ${observacion}`
                                    : `OV ${consecutivo}`;

                                notesInput.readOnly = false;
                                notesInput.style.cssText = '';
                            }

                            const fechaInput =
                                document.querySelector('[name="requestedDate"]');
                            const fechaEntrega =
                                ov.fechaEntrega ?? ov.FechaEntrega ?? '';

                            if (fechaInput && fechaEntrega) {
                                fechaInput.value =
                                    String(fechaEntrega).slice(0, 10);
                                fechaInput.readOnly = true;
                                fechaInput.style.cssText =
                                    'background-color:#f0f0f0; color:#666; cursor:not-allowed;';
                            }

                            const priorityInput =
                                document.querySelector('[name="priority"]');
                            if (priorityInput) {
                                priorityInput.disabled = false;
                                priorityInput.style.cssText = '';
                            }

                            const lockedDiv =
                                document.getElementById('formContentLocked');
                            if (lockedDiv) {
                                lockedDiv.classList.remove('form-locked-overlay');
                            }

                            const btnSubmit =
                                document.getElementById('btnSubmitSolicitud');
                            if (btnSubmit) btnSubmit.disabled = false;

                            toast('Datos y productos de la OV cargados correctamente.');
                        } catch (error) {
                            console.error('Error cargando datos de la OV:', error);
                            resetEstadoOVMuestra();
                            toast(error.message || 'No fue posible cargar la OV.');
                        } finally {
                            btn.innerHTML = originalText;
                            btn.disabled = !select.value;
                        }
                    };
                }

                // Ejecutar al cargar la página
                loadOVMuestras();


                function uid(){ return 'it-' + crypto.randomUUID().slice(0,8); }
                function todayPlus(days){ const d = new Date(); d.setDate(d.getDate()+days); return d.toISOString().slice(0,10); }
                function formatDate(value){ if(!value) return 'Sin definir'; const d = new Date(value); return Number.isNaN(d.getTime()) ? value : d.toLocaleDateString('es-MX', {year:'numeric', month:'short', day:'2-digit'}); }
                function formatDateTime(value){ if(!value) return 'Sin definir'; const d = new Date(value); return Number.isNaN(d.getTime()) ? value : d.toLocaleString('es-MX', {dateStyle:'medium', timeStyle:'short'}); }
                function totalBoxes(req){ return req.items.reduce((sum,item)=>sum+Number(item.boxes||0),0); }
                function linkedLabels(req){ return req.items.reduce((sum,item)=>sum+(item.labels?.length||0),0); }

                function normalizarEtiquetaTracking(valor) {
                    return String(valor || '')
                        .replace(/\u0000/g, '')
                        .replace(/\s+/g, '')
                        .trim()
                        .toUpperCase();
                }

                function escapeTrackingHtml(valor) {
                    return String(valor ?? '')
                        .replace(/&/g, '&amp;')
                        .replace(/</g, '&lt;')
                        .replace(/>/g, '&gt;')
                        .replace(/"/g, '&quot;')
                        .replace(/'/g, '&#039;');
                }

                function obtenerCodigoEtiquetaTracking(label) {
                    return normalizarEtiquetaTracking(
                        label?.externalChain ||
                        label?.ExternalChain ||
                        label?.code ||
                        label?.Code
                    );
                }

                function obtenerEtiquetasSolicitud(req) {
                    return (req?.items || [])
                        .flatMap(item => item?.labels || [])
                        .filter(Boolean);
                }

                function obtenerTodosLosCodigosTracking() {
                    return Array.from(new Set(
                        requests
                            .flatMap(req => obtenerEtiquetasSolicitud(req))
                            .map(obtenerCodigoEtiquetaTracking)
                            .filter(Boolean)
                    ));
                }

                function obtenerTrackingEtiqueta(label) {
                    const codigo = obtenerCodigoEtiquetaTracking(label);
                    return codigo ? trackingMeat.get(codigo) || null : null;
                }

                async function cargarTrackingMeat(etiquetasForzadas = null) {
                    const esRecargaParcial = Array.isArray(etiquetasForzadas);

                    const etiquetas = Array.from(new Set(
                        (esRecargaParcial ? etiquetasForzadas : obtenerTodosLosCodigosTracking())
                            .map(normalizarEtiquetaTracking)
                            .filter(Boolean)
                    ));

                    if (!etiquetas.length) {
                        if (!esRecargaParcial) trackingMeat.clear();
                        return;
                    }

                    trackingMeatCargando = true;

                    try {
                       const parametros = new URLSearchParams();

        etiquetas.forEach(etiqueta => {
            parametros.append('etiquetas', etiqueta);
        });

        const urlTracking =
            '@Url.Action("ObtenerTrackingEtiquetasMeat", "Comercial")'
            + '?'
            + parametros.toString();

        const response = await fetch(urlTracking, {
            method: 'GET',
            headers: {
                'Accept': 'application/json'
            },
            cache: 'no-store'
        });

                        let data = null;
                        try {
                            data = await response.json();
                        } catch {
                            data = {
                                ok: false,
                                mensaje: `El servidor respondió HTTP ${response.status} sin JSON válido.`
                            };
                        }

                        if (!response.ok || !data?.ok) {
                            throw new Error(data?.mensaje || 'No fue posible consultar MEAT.');
                        }

                        if (!esRecargaParcial)
                            trackingMeat.clear();

                        const resultados = Array.isArray(data.etiquetas)
                            ? data.etiquetas
                            : [];

                        resultados.forEach(info => {
                            const codigo = normalizarEtiquetaTracking(info.etiqueta);
                            if (codigo) trackingMeat.set(codigo, info);
                        });

                        if (Array.isArray(data.advertencias) && data.advertencias.length) {
                            console.warn('Advertencias del tracking MEAT:', data.advertencias);
                            toast(data.advertencias.join(' '));
                        }
                    } catch (error) {
                        console.error('Error consultando tracking MEAT:', error);
                        toast('No fue posible actualizar la ubicación real de las etiquetas.');
                    } finally {
                        trackingMeatCargando = false;
                        renderTracking();
                    }
                }

                function requestStatusBase(req) {
                    const total = totalBoxes(req);
                    const linked = linkedLabels(req);

                    if (req.stage === 'Surtido al cliente'
                        || req.location === 'Surtido al cliente'
                        || req.location === 'Entregado a cliente') {
                        return 'Surtido al cliente';
                    }

                    if (req.location === 'Almacén Refrigerado'
                        && linked === total
                        && total > 0) {
                        return 'En almacén';
                    }

                    if (req.stage === 'Cancelada')
                        return 'Cancelada';

                    if (linked === total && total > 0)
                        return 'Cumplido producción';

                    if (linked > 0)
                        return 'Producción parcial';

                    if (req.planning)
                        return 'Planeada';

                    return 'Pendiente';
                }

                function estadoTrackingSolicitud(req) {
                    const labels = obtenerEtiquetasSolicitud(req);

                    if (!labels.length)
                        return requestStatusBase(req);

                    const datos = labels
                        .map(obtenerTrackingEtiqueta)
                        .filter(Boolean);

                    // No se cambia el estado si todavía no existe una respuesta
                    // para todas las etiquetas de la solicitud.
                    if (datos.length !== labels.length)
                        return requestStatusBase(req);

                    const vendidas = datos.filter(x => x.estado === 'VENDIDA').length;
                    const enAlmacen = datos.filter(x => x.estado === 'EN_ALMACEN').length;

                    if (vendidas === labels.length)
                        return 'Surtido al cliente';

                    if (vendidas > 0)
                        return 'Surtido parcial';

                    if (enAlmacen === labels.length)
                        return 'En almacén';

                    return requestStatusBase(req);
                }

                function requestStatus(req) {
                    return estadoTrackingSolicitud(req);
                }

                function renderUbicacionEtiquetaTracking(label) {
                    const codigo = obtenerCodigoEtiquetaTracking(label);
                    const info = obtenerTrackingEtiqueta(label);

                    if (trackingMeatCargando && !info) {
                        return `
                            <div class="meat-location-card loading">
                                <strong>${escapeTrackingHtml(codigo)}</strong>
                                <span>Consultando MEAT...</span>
                            </div>`;
                    }

                    if (!info || !info.encontrado) {
                        return `
                            <div class="meat-location-card missing">
                                <strong>${escapeTrackingHtml(codigo)}</strong>
                                <span>No encontrada</span>
                                <small>No existe coincidencia en TIF ni en P1.</small>
                            </div>`;
                    }

                    if (info.estado === 'VENDIDA') {
                        return `
                            <div class="meat-location-card sold">
                                <strong>${escapeTrackingHtml(codigo)}</strong>
                                <span>VENDIDA · Planta ${escapeTrackingHtml(info.planta || '')}</span>
                                <small>
                                    Almacén: ${escapeTrackingHtml(info.almacen || 'No identificado')}<br>
                                    Cliente: ${escapeTrackingHtml(info.cliente || 'No identificado')}<br>
                                    Folio: ${escapeTrackingHtml(info.folio || 'No identificado')}
                                    ${info.transferida ? '<br>La etiqueta tiene antecedente en ambas plantas.' : ''}
                                </small>
                            </div>`;
                    }

                    if (info.estado === 'EN_ALMACEN') {
                        return `
                            <div class="meat-location-card stock">
                                <strong>${escapeTrackingHtml(codigo)}</strong>
                                <span>${escapeTrackingHtml(info.almacen || 'Almacén no identificado')}</span>
                                <small>
                                    Planta ${escapeTrackingHtml(info.planta || '')}
                                    ${info.transferida ? '<br>Transferida entre TIF y P1.' : ''}
                                </small>
                            </div>`;
                    }

                    return `
                        <div class="meat-location-card warning">
                            <strong>${escapeTrackingHtml(codigo)}</strong>
                            <span>Registro inactivo sin venta comprobada</span>
                            <small>
                                ${escapeTrackingHtml(info.almacen || 'Sin almacén identificado')} ·
                                Planta ${escapeTrackingHtml(info.planta || '')}
                                ${info.transferida ? '<br>Aparece en ambas plantas.' : ''}
                            </small>
                        </div>`;
                }

                window.refrescarTrackingSolicitud = async function (solicitudId, boton) {
                    const req = requests.find(x => x.id === solicitudId);
                    if (!req) return;

                    const etiquetas = obtenerEtiquetasSolicitud(req)
                        .map(obtenerCodigoEtiquetaTracking)
                        .filter(Boolean);

                    if (!etiquetas.length) {
                        toast('Esta solicitud todavía no tiene etiquetas ligadas.');
                        return;
                    }

                    const textoOriginal = boton?.textContent || 'Actualizar';

                    try {
                        if (boton) {
                            boton.disabled = true;
                            boton.textContent = 'Consultando...';
                        }

                        await cargarTrackingMeat(etiquetas);
                        renderTracking();
                        toast(`Tracking de ${solicitudId} actualizado.`);
                    } finally {
                        if (boton) {
                            boton.disabled = false;
                            boton.textContent = textoOriginal;
                        }
                    }
                };

                function statusClass(status) {
                    if (status.includes('Surtido parcial'))
                        return 'progress';

                    if (status.includes('Cumplido')
                        || status.includes('Surtido al cliente')) {
                        return 'done';
                    }

                    if (status.includes('parcial'))
                        return 'progress';

                    if (status.includes('Planeada')
                        || status.includes('almacén')) {
                        return 'planned';
                    }

                    if (status.includes('Cancelada'))
                        return 'danger';

                    return 'pending';
                }

                function nextRequestId(){
                    const max = requests.map(r => Number((r.id?.match(/(\d+)$/)||[0,0])[1])).reduce((a,b)=>Math.max(a,b),0);
                    return `SM-${new Date().getFullYear()}-${String(max+1).padStart(4,'0')}`;
                }

                function normalizeMeatLabelCode(value) {
                    return String(value || '')
                        .replace(/\u0000/g, '')
                        .replace(/\s+/g, '')
                        .trim()
                        .toUpperCase();
                }

                const nomenclaturasEtiquetaPorPlanta = Object.freeze({
                    P1: Object.freeze(['DEST', 'RETT', 'RETR', 'DESH', 'COMP']),
                    TIF: Object.freeze(['DEST', 'RETT', 'COMT'])
                });

                function obtenerNomenclaturasPermitidas(planta) {
                    const plantaNormalizada = String(planta || '').trim().toUpperCase();
                    return nomenclaturasEtiquetaPorPlanta[plantaNormalizada] || [];
                }

                function obtenerTipoEtiqueta(codigo, planta) {
                    const codigoNormalizado = normalizeMeatLabelCode(codigo);
                    const nomenclaturas = obtenerNomenclaturasPermitidas(planta);

                    return nomenclaturas.find(prefijo =>
                        codigoNormalizado.startsWith(prefijo)
                    ) || '';
                }

                function validarFormatoEtiquetaPorPlanta(codigo, planta) {
                    const codigoNormalizado = normalizeMeatLabelCode(codigo);
                    const plantaNormalizada = String(planta || '').trim().toUpperCase();
                    const nomenclaturas = obtenerNomenclaturasPermitidas(plantaNormalizada);
                    const tipoEtiqueta = obtenerTipoEtiqueta(codigoNormalizado, plantaNormalizada);

                    if (!nomenclaturas.length) {
                        return {
                            valido: false,
                            tipoEtiqueta: '',
                            mensaje: 'Seleccione una planta válida: P1 o TIF.'
                        };
                    }

                    if (!tipoEtiqueta) {
                        return {
                            valido: false,
                            tipoEtiqueta: '',
                            mensaje:
                                `La etiqueta ${codigoNormalizado} no pertenece a una nomenclatura válida ` +
                                `para ${plantaNormalizada}.`
                        };
                    }

                    const contenidoEtiqueta = codigoNormalizado.substring(tipoEtiqueta.length);

                    if (!contenidoEtiqueta || !/^[0-9A-Z_-]+$/i.test(contenidoEtiqueta)) {
                        return {
                            valido: false,
                            tipoEtiqueta,
                            mensaje:
                                `La etiqueta ${codigoNormalizado} debe contener letras, números, ` +
                                `guion o guion bajo después de ${tipoEtiqueta}.`
                        };
                    }

                    return {
                        valido: true,
                        tipoEtiqueta,
                        mensaje: ''
                    };
                }

                function actualizarAyudaEtiquetaPorPlanta() {
                    const planta = String(qs('#scanPlant')?.value || '')
                        .trim()
                        .toUpperCase();

                    const input = qs('#scanLabel');
                    const titulo = qs('#scanLabelTitle');
                    const ayuda = qs('#scanLabelHelp');
                    const nomenclaturas = obtenerNomenclaturasPermitidas(planta);

                    if (!planta || !nomenclaturas.length) {
                        if (titulo) titulo.textContent = 'Etiqueta de producción escaneada';

                        if (input) {
                            input.placeholder =
                                'Seleccione la planta y escanee la etiqueta';
                        }

                        if (ayuda) {
                            ayuda.textContent =
                                'P1: DEST, RETT, RETR, DESH, COMP · TIF: DEST, RETT, COMT';
                        }

                        return;
                    }

                    const textoNomenclaturas = nomenclaturas.join(', ');

                    if (titulo) {
                        titulo.textContent = `Etiqueta de ${planta} escaneada`;
                    }

                    if (input) {
                        input.placeholder = `Permitidas: ${textoNomenclaturas}`;
                    }

                    if (ayuda) {
                        ayuda.textContent =
                            `Nomenclaturas permitidas para ${planta}: ${textoNomenclaturas}`;
                    }
                }

                function setScanValidation(message, state = 'idle', title = '') {
                    const box = qs('#scanValidationBox');
                    if (!box) return;

                    box.classList.remove('idle', 'loading', 'ok', 'error');
                    box.classList.add(state || 'idle');
                    box.innerHTML = `<strong>${title || (state === 'ok' ? 'Etiqueta validada' : state === 'error' ? 'Etiqueta rechazada' : state === 'loading' ? 'Validando etiqueta' : 'Validación pendiente')}</strong>${message || ''}`;
                }

                function clearScanLabel(focus = false) {
                    const input = qs('#scanLabel');
                    if (!input) return;

                    input.value = '';
                    input.classList.remove('scan-invalid', 'scan-valid');

                    if (focus) {
                        setTimeout(() => input.focus(), 80);
                    }
                }

                function updateScanContext(clearLabel = true) {
                    const req = requests.find(r => r.id === qs('#scanRequest')?.value);
                    const item = req?.items.find(i => i.uid === qs('#scanItem')?.value);
                    const plant = qs('#scanPlant')?.value || '';

                    if (clearLabel) clearScanLabel(false);

                    if (!req || !item) {
                        setScanValidation(
                            'Seleccione una solicitud y un SKU pendiente de etiquetas.',
                            'idle'
                        );
                        return;
                    }

                    const sku = String(item.workSku || '').trim().toUpperCase();
                    const faltantes = Math.max(0, Number(item.boxes || 0) - (item.labels?.length || 0));
                    const origen = plant
                        ? (plant === 'P1' ? 'CadenaMeatP1' : 'CadenaMeatTIF')
                        : 'seleccione P1 o TIF';

                    setScanValidation(
                        `SKU planeado: <b>${sku || 'SIN SKU PLANEADO'}</b><br>` +
                        `Cajas pendientes: <b>${faltantes}</b><br>` +
                        `Origen de validación: <b>${origen}</b>`,
                        sku ? 'idle' : 'error',
                        sku ? 'Listo para escanear' : 'Planeación incompleta'
                    );
                }

                function toast(message){
                    const box = qs('#toast'); box.textContent = message; box.classList.add('show');
                    setTimeout(()=>box.classList.remove('show'), 2600);
                }

                function badge(text){ return `<span class="badge ${statusClass(text)}">${text}</span>`; }
                function setDefaultDates(){ if(qs('[name="requestedDate"]')) qs('[name="requestedDate"]').value = todayPlus(5); }

                function itemRowTemplate(item={sku:'', product:'', spec:'', boxes:1, temp:'Refrigerado 0-4 °C'}){
                    return `
                    <tr>
                        <td style="min-width: 120px;">
                            <input class="item-sku" required value="${item.sku||''}" readonly style="background-color: #f0f0f0; color: #666; cursor: not-allowed; width:100%;" />
                        </td>
                        <td><input class="item-product" required value="${item.product||''}" placeholder="Se llena solo" readonly style="background-color: #f0f0f0; color: #666; cursor: not-allowed;" /></td>
                        <td><textarea class="item-spec" required placeholder="Ej. Caja 12 kg...">${item.spec||''}</textarea></td>
                        <td><input type="number" min="1" class="item-boxes" required value="${item.boxes||1}" /></td>
                        <td>
                            <select class="item-temp">
                                <option ${item.temp==='Refrigerado 0-4 °C'?'selected':''}>Refrigerado 0-4 °C</option>
                                <option ${item.temp==='Congelado -18 °C'?'selected':''}>Congelado -18 °C</option>
                                <option ${item.temp==='Ambiente'?'selected':''}>Ambiente</option>
                            </select>
                        </td>
                        <td style="text-align:center;">
                            <button type="button" class="danger remove-item">Eliminar</button>
                        </td>
                    </tr>
                    `;
                }

                function addItem(item){ if(qs('#itemsBody')) qs('#itemsBody').insertAdjacentHTML('beforeend', itemRowTemplate(item)); }

                function clearItems(){
                    if(qs('#itemsBody')){
                        qs('#itemsBody').innerHTML = '';
                        addItem();
                    }
                }

                function collectItems(){
                    return qsa('#itemsBody tr').map(row => ({
                        uid:uid(), sku:row.querySelector('.item-sku').value.trim(), product:row.querySelector('.item-product').value.trim(),
                        spec:row.querySelector('.item-spec').value.trim(), boxes:Number(row.querySelector('.item-boxes').value), temp:row.querySelector('.item-temp').value, labels:[]
                    })).filter(i => i.sku && i.spec && i.boxes>0);
                }

                function renderKpis(){
                    const total = requests.length;
                    const pendingPlan = requests.filter(r=>!r.planning && requestStatus(r) !== 'Cancelada').length;
                    const boxes = requests.reduce((s,r)=>s+totalBoxes(r),0);
                    const linked = requests.reduce((s,r)=>s+linkedLabels(r),0);

                    if(qs('#kpis')) qs('#kpis').innerHTML = `
                    <div class="kpi"><small>Solicitudes Totales</small><strong>${total}</strong><span class="hint">folios en sistema</span></div>
                    <div class="kpi"><small>Pendientes Planeacion</small><strong>${pendingPlan}</strong><span class="hint">por asignar a produccion</span></div>
                    <div class="kpi"><small>Cajas Muestras</small><strong>${boxes}</strong><span class="hint">cajas solicitadas</span></div>
                    <div class="kpi"><small>Etiquetas Generadas</small><strong>${linked}/${boxes}</strong><span class="hint">avance total produccion</span></div>
                    `;
                }

                function createRequestCard(req) {
                    const status = requestStatus(req), total = totalBoxes(req), linked = linkedLabels(req), pct = total ? Math.round(linked/total*100) : 0;
                    let btnEnviar = '';
                    let btnCancelar = '';
                    let btnEditar = '';
                    if (!req.planning && status === 'Pendiente') {
                        btnCancelar = `<button type="button" class="ghost" style="margin-top:10px; width:100%;" onclick="cancelarSolicitud('${req.id}')">Cancelar solicitud</button>`;
                        btnEditar = `<button type="button" class="secondary" style="margin-top:10px; width:100%;" onclick="editarSolicitud('${req.id}')">Editar solicitud</button>`;
                    }
                    return `
                        <div class="card request-card">
                        <div>
                            <div class="request-title">
                            <div><h4>${req.id} · ${req.client}</h4><span class="mini">Solicito: ${req.seller} · Creada: ${formatDate(req.createdAt)}</span></div>
                            ${badge(status)}
                            </div>
                            <div class="meta">
                            <span>Especie: ${req.species || 'Sin definir'}</span><span>Ruta: ${req.route}</span>
                            <span>Destino: ${req.destination}</span><span>Req: ${formatDate(req.requestedDate)}</span>
                            </div>
                            <div class="items-list">
                            ${req.items.map(item=>`
                                <div class="item-line">
                                    <strong>${item.sku} · ${item.product} · ${item.boxes} caja(s)</strong><small>${item.spec}<br>${item.temp}</small>
                                </div>
