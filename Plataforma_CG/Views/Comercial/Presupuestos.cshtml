@using Plataforma_CG.ViewModels
@model Plataforma_CG.ViewModels.PedidoViewModel
@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Presupuestos";
}

<style>
    :root {
        --brand: linear-gradient(90deg, #8B0000 0%, #5a0000 50%, #1a0000 100%);
        --bg: linear-gradient(135deg, #f1f3f6 0%, #e9edf2 45%, #e8dada 100%);
        --panel: #fff;
        --bar: #e6e9ef;
        --bar-2: #dde2ea;
        --line: #d8dce3;
        --text: #20262e;
        --muted: #636d7b;
        --accent: #2d6cdf;
        --radius: 8px;
        --shadow: 0 1px 0 rgba(0,0,0,.04),0 12px 24px rgba(0,0,0,.06);
        --shadow-sm: 0 6px 16px rgba(0,0,0,.05);
        --focus: 0 0 0 .2rem rgba(45,108,223,.25);
        --font: system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial,"Noto Sans","Apple Color Emoji","Segoe UI Emoji";
    }

    body {
        background: var(--bg) !important;
        font-family: var(--font);
        color: var(--text);
    }

    .legacy-border {
        border: none !important;
        background: transparent !important;
        padding: 0 !important;
    }

    /* MÁS ANCHO Y FLUIDO */
    .shell {
        width: 96%;
        max-width: 1800px;
        margin: 1.25rem auto;
        background: var(--panel);
        border-radius: var(--radius);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .module-titlebar {
        background: linear-gradient(#eef1f6,#e7ebf2);
        border-bottom: 1px solid var(--bar-2);
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .module-title {
        display: flex;
        align-items: center;
        gap: .6rem;
        margin: 0;
        font-weight: 700;
        letter-spacing: .2px;
    }

        .module-title i {
            font-size: 1.1rem;
            color: var(--brand);
        }

    .module-subtitle {
        margin: 0;
        color: var(--muted);
        font-size: .9rem;
    }

    .toolbar {
        background: var(--bar);
        border-bottom: 1px solid var(--bar-2);
        padding: .4rem .6rem;
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
    }

    .tbtn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        height: 34px;
        padding: 0 .6rem;
        border: 1px solid var(--line);
        border-radius: 6px;
        background: #fff;
        color: #1e2a35;
        font-size: .9rem;
        line-height: 1;
        transition: .15s ease;
    }

        .tbtn:hover {
            background: #f8fafc;
            border-color: #cfd6e2;
        }

        .tbtn:active {
            background: #edf1f7;
            transform: translateY(.5px);
        }

        .tbtn.primary {
            background: var(--brand);
            color: #fff;
            border-color: transparent;
        }

            .tbtn.primary:hover {
                filter: brightness(1.05);
            }

        .tbtn.ghost {
            background: #fff;
            color: #1e2a35;
        }

    .toolbar .sep {
        width: 1px;
        height: 24px;
        background: var(--line);
        margin: 0 .25rem;
        align-self: center;
    }

    .content {
        padding: 1.25rem 1.25rem 1rem;
    }

    .panel {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 6px;
        box-shadow: var(--shadow-sm);
    }

    .panel-head {
        background: linear-gradient(#f6f8fb,#eef2f7);
        border-bottom: 1px solid var(--line);
        padding: .6rem .8rem;
        font-weight: 600;
        color: #2b3642;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

        .panel-head i {
            color: var(--brand);
        }

    .panel-body {
        padding: .9rem;
    }

    .form-control, .form-select {
        border-radius: 6px;
        border-color: #cfd6e2;
        font-size: .95rem;
    }

        .form-control:focus, .form-select:focus {
            box-shadow: var(--focus);
            border-color: var(--accent);
            outline: none;
        }

    .help {
        color: var(--muted);
        font-size: .85rem;
    }

    .kpi {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .35rem .6rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: #f6f8fb;
        color: #2b3642;
        font-weight: 600;
        font-size: .85rem;
    }

    .table thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #f3f6fb;
        border-bottom: 1px solid var(--line);
        color: #2b3642;
        font-weight: 700;
    }

    .table-sm > :not(caption) > * > * {
        padding: .5rem .6rem;
    }

    .table-hover tbody tr:hover {
        background: #f9fbff;
    }

    .table-striped tbody tr:nth-of-type(odd) {
        background: #fff;
    }

    .table-striped tbody tr:nth-of-type(even) {
        background: #fafcff;
    }

    .text-end {
        text-align: right;
    }

    /* Altura cómoda para tablas */
    .table-responsive.p-2 {
        max-height: 70vh;
        overflow: auto;
    }

    #articulosMensuales .panel .table-responsive {
        max-height: 72vh;
    }

    .btn-reflejo {
        background-color: var(--brand);
        color: #fff;
        border: 1px solid transparent;
    }

        .btn-reflejo:hover {
            filter: brightness(1.06);
        }

    .modal-header {
        background: linear-gradient(#e9edf4,#e1e6ef);
        border-bottom: 1px solid var(--bar-2);
        color: #1f2a35;
    }

        .modal-header .modal-title {
            font-weight: 700;
        }

    .modal-footer {
        background: #f6f8fb;
        border-top: 1px solid var(--bar-2);
    }

    .empty {
        text-align: center;
        color: var(--muted);
        padding: 1.2rem .5rem;
    }

        .empty i {
            display: block;
            color: var(--brand);
            font-size: 1.6rem;
            margin-bottom: .4rem;
        }

    #loadingSpinner {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 2000;
        backdrop-filter: blur(1.5px);
        background: rgba(255,255,255,.72);
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }

    *:focus-visible {
        outline: none;
        box-shadow: var(--focus);
        border-radius: 6px;
    }

    /* Modales grandes */
    #modalTablaGrande .modal-dialog {
        max-width: 98vw !important;
    }

    #modalTablaGrande .modal-body .table-responsive {
        max-height: calc(100vh - 220px);
    }

    #presupuestosModal .modal-dialog {
        max-width: 95vw;
    }

    @@media (max-width: 1400px) {
        .shell

    {
        width: 98%;
        max-width: 1600px;
    }

    }
</style>

<div class="container-fluid mt-4 legacy-border">
    <div class="shell">
        <div class="module-titlebar">
            <div>
                <h5 class="module-title"><i class="bi bi-diagram-3"></i> Presupuestos</h5>
                <p class="module-subtitle">Consulta ventas por cliente o vendedor y guarda el presupuesto mensual.</p>
            </div>

            <!-- TOOLBAR con acciones separadas (izq) y principales (der) -->
            <div class="toolbar w-100 d-flex align-items-center" role="toolbar" aria-label="Acciones rápidas" style="gap:.4rem">
                <!-- IZQUIERDA -->
                <div class="d-flex flex-wrap align-items-center" style="gap:.4rem">
                    <button type="button" class="tbtn" id="btnConsultar" title="Consultar ventas del cliente">
                        <i class="bi bi-search"></i><span>Consultar</span>
                    </button>
                    <button type="button" class="tbtn" id="btnDetalle" title="Gráfica de ventas">
                        <i class="bi bi-graph-up"></i><span>Gráfica</span>
                    </button>
                    <button type="button" class="tbtn" id="btnVerPresupuestos" title="Histórico de presupuestos">
                        <i class="bi bi-clock-history"></i><span>Histórico</span>
                    </button>
                </div>

                <!-- separador flexible -->
                <div class="ms-auto"></div>

                <!-- DERECHA -->
                <div class="d-flex align-items-center" style="gap:.4rem">
                    <button type="button" id="btnAbrirModalGuardar" class="tbtn primary" title="Guardar presupuesto">
                        <i class="bi bi-save"></i><span>Guardar</span>
                    </button>
                    <button type="button" class="tbtn ghost" onclick="window.location='/Home/inicio'" title="Cancelar">
                        <i class="bi bi-x-lg"></i><span>Cancelar</span>
                    </button>
                </div>
            </div>
        </div>

        <div class="content">
            @* MENSAJES ARRIBA DEL FORM *@
            @if (TempData["Ok"] is string okMsg)
            {
                <div class="alert alert-success shadow-sm mb-3" role="alert">
                    <i class="bi bi-check-circle me-2"></i> @okMsg
                </div>
            }
            @if (TempData["Error"] is string errMsg)
            {
                <div class="alert alert-warning shadow-sm mb-3" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i> @errMsg
                </div>
            }

            @* Duplicados *@
            @if (TempData["DupListText"] is string dupTxt && !string.IsNullOrWhiteSpace(dupTxt))
            {
                <div class="alert alert-warning shadow-sm mb-3" role="alert">
                    <div class="d-flex justify-content-between align-items-start w-100">
                        <div class="me-3">
                            <i class="bi bi-exclamation-octagon me-2"></i>
                            Se encontraron renglones ya presupuestados para el periodo seleccionado.
                            <details class="mt-2">
                                <summary class="fw-semibold">Ver detalle</summary>
                                <pre class="mb-0 mt-2" style="white-space:pre-wrap;">@dupTxt</pre>
                            </details>
                        </div>
                        @{
                            var dupMes = TempData["DupMes"] as string;
                            var dupAnio = TempData["DupAnio"] as string;
                        }
                        @if (!string.IsNullOrEmpty(dupMes) && !string.IsNullOrEmpty(dupAnio))
                        {
                            <button type="button"
                                    class="btn btn-outline-secondary btn-sm"
                                    onclick="(window.abrirHistoricoDeMes||function(){})(@dupMes, @dupAnio)">
                                <i class="bi bi-clock-history me-1"></i> Ver histórico @dupMes/@dupAnio
                            </button>
                        }
                    </div>
                </div>
            }

            <form id="frmPresupuesto"
                  asp-controller="Comercial"
                  asp-action="GuardarPresupuesto"
                  method="post"
                  data-check-url="/Comercial/ObtenerPresupuestos"
                  data-open-historico-fn="abrirHistoricoDeMes">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <!-- Columna: Cliente (individual) -->
                    <div class="col-lg-4">
                        <div class="panel h-100">
                            <div class="panel-head"><i class="bi bi-person-badge"></i> Cliente</div>
                            <div class="panel-body">
                                <label class="form-label fw-semibold mb-1">Cliente (individual)</label>
                                <input type="text" id="clienteInput" class="form-control form-control-lg" placeholder="Escribe para buscar..." />
                                <div class="help mt-1">Escribe 2 letras o más y selecciona.</div>
                                <input type="hidden" id="clienteId" name="Cliente" />

                                <div class="mt-3">
                                    <label class="form-label fw-semibold mb-1">Meses para cálculo de objetivo</label>
                                    <select id="filtroMesesObjetivo" class="form-select form-select-sm">
                                        <option value="0">Ninguno</option>
                                        <option value="4">Últimos 4 meses</option>
                                        <option value="8">Últimos 8 meses</option>
                                        <option value="12" selected>Últimos 12 meses</option>
                                    </select>
                                    <div class="help mt-1">Promedio simple por SKU en la ventana seleccionada.</div>
                                </div>

                                <div id="customRangeDiv" class="mt-3" style="display:none;">
                                    <label class="form-label fw-semibold">Días personalizados</label>
                                    <input type="number" id="diasPersonalizados" name="DiasPersonalizados" class="form-control" placeholder="Número de días" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Columna: Trabajo por vendedor/canal -->
                    <div class="col-lg-8">
                        <div class="panel h-100">
                            <div class="panel-head"><i class="bi bi-people"></i> vendedor / canal y clasificación</div>
                            <div class="panel-body">
                                <div class="kpi mb-2">
                                    <i class="bi bi-info-circle"></i>
                                    Usa un cliente o filtra por <strong>Canal</strong> y/o <strong>múltiples vendedores</strong>.
                                </div>

                                <div class="row g-3 mt-1">
                                    <div class="col-md-3">
                                        <label class="form-label fw-semibold">Canal</label>
                                        <select id="selCanal" class="form-select">
                                            <option value="">Todos los canales</option>
                                        </select>
                                        <div class="help">Filtra clientes por canal comercial.</div>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label fw-semibold">Clasificación (cliente)</label>
                                        <select id="selClasif" class="form-select">
                                            <option value="">Todas</option>
                                        </select>
                                        <div class="form-text">Deja vacío para incluir todas.</div>
                                    </div>

                                    <div class="col-md-5">
                                        <label class="form-label fw-semibold">Vendedor(es)</label>
                                        <select id="selVendedor" class="form-select" multiple></select>
                                        <div class="form-text">Puedes elegir varios. Deja vacío para traer por canal.</div>
                                    </div>
                                </div>

                                <!-- Clientes: checklist con buscador -->
                                <div class="mt-3">
                                    <label class="form-label fw-semibold">Clientes</label>
                                    <div class="d-flex flex-wrap gap-2 mb-2 align-items-center">
                                        <div class="input-group" style="max-width: 380px;">
                                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                                            <input type="search" id="buscaCliente" class="form-control" placeholder="Buscar en la lista…">
                                        </div>
                                        <button type="button" id="btnCargarClientes" class="btn btn-outline-secondary btn-sm">Cargar clientes</button>
                                        <div class="ms-auto d-flex gap-2">
                                            <button type="button" id="btnCliTodo" class="btn btn-outline-secondary btn-sm">Seleccionar todo</button>
                                            <button type="button" id="btnCliNada" class="btn btn-outline-secondary btn-sm">Limpiar</button>
                                        </div>
                                    </div>
                                    <div id="wrapClientes" class="border rounded p-2" style="max-height: 260px; overflow: auto;">
                                        <div id="listaClientes" class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-1"></div>
                                        <div id="estadoClientes" class="text-muted small mt-2"></div>
                                    </div>
                                    <div class="small text-muted mt-1" id="cliCount"></div>
                                </div>

                                <!-- Toolbar de Presupuestos -->
                                <div class="mt-3 d-flex flex-wrap gap-2 align-items-center">
                                    <button type="button" id="btnConsultarVarios" class="btn btn-outline-secondary">
                                        Presupuestar Ventas
                                    </button>
                                    <button type="button" id="btnGraficaVarios" class="btn btn-outline-secondary">
                                        Ver gráfica (selección)
                                    </button>

                                    <button type="button" id="btnExportarExcel" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-file-earmark-spreadsheet"></i> Exportar  Excel
                                    </button>

                                    <input type="file" id="fileImportPresupuesto" accept=".xlsx,.xls" class="d-none">

                                    <button type="button" id="btnImportarExcel" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-upload"></i> Importar  Excel
                                    </button>

                                    <span id="selCount2" class="text-muted small ms-1"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Reporte mensual -->
                <div id="articulosMensuales" class="mt-3" style="display:none;">
                    <div class="d-flex justify-content-end mb-2">
                        <button type="button" id="btnTablaGrande" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrows-fullscreen"></i> Vista Previa
                        </button>
                    </div>

                    <div id="tablaMensualWrapper">
                        <div class="panel">
                            <div class="panel-head"><i class="bi bi-calendar3"></i> Ventas mensuales por SKU</div>

                            <!-- Filtros -->
                            <div class="p-2 border-bottom d-flex flex-wrap gap-2 align-items-center">
                                <select id="selMaster" class="form-select" multiple style="min-width:260px"></select>

                                <div class="input-group" style="max-width:260px;">
                                    <span class="input-group-text"><i class="bi bi-filter"></i></span>
                                    <input id="filtroSku" class="form-control" placeholder="SKU contiene…">
                                </div>

                                <div class="input-group" style="max-width:260px;">
                                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                                    <input id="filtroCliente" class="form-control" placeholder="Cliente contiene…">
                                </div>
                            </div>

                            <div id="emptyMensual" class="empty" style="display:none;">
                                <i class="bi bi-inboxes"></i>
                                <div>Aún no hay datos. Consulta un cliente o selecciona clientes de un vendedor/canal.</div>
                            </div>
                            <div class="panel-body p-0">
                                <div class="table-responsive p-2" style="border-top:1px solid var(--line);">
                                    <table class="table table-sm table-hover table-striped align-middle mb-0">
                                        <thead id="theadMensual"></thead>
                                        <tbody id="tbodyMensual"></tbody>
                                    </table>
                                </div>

                                <!-- Totales -->
                                <div id="totalesBar" class="d-flex justify-content-end gap-4 align-items-center p-2 border-top" style="background:#f6f8fb;">
                                    <div class="fw-semibold">Total Objetivo: <span id="totObjetivoBar" class="ms-1"></span></div>
                                    <div class="fw-semibold">Total Presupuesto: <span id="totPresupuestoBar" class="ms-1"></span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="hiddenFieldsAnchor"></div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL Guardar Presupuesto -->
<div class="modal fade" id="modalGuardarPresupuesto" tabindex="-1" aria-labelledby="modalGuardarPresupuestoLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-bold" id="modalGuardarPresupuestoLabel">Guardar presupuesto</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p class="fw-semibold mb-2">Selecciona el mes y año:</p>
                <div class="d-flex gap-2">
                    <select id="modalMes" class="form-select">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                        }
                    </select>
                    <input type="number" id="modalAnio" class="form-control" min="@DateTime.Now.Year" max="2100" value="@DateTime.Now.Year" />
                </div>
                <div class="form-text mt-2">Solo a partir del <strong>siguiente mes</strong>.</div>
            </div>
            <div class="modal-footer">
                <button type="button" id="btnGuardarModal" class="btn btn-outline-secondary btn-sm">Guardar</button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL Gráfica -->
<div class="modal fade" id="detalleModal" tabindex="-1" aria-labelledby="detalleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered" style="max-width:95%;">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-bold" id="detalleModalLabel">Ventas por Mes y SKU</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body p-3" style="height:600px;">
                <div class="d-flex flex-wrap gap-2 align-items-end mb-3">
                    <div class="me-3">
                        <label class="form-label mb-1">Rango de meses</label>
                        <div class="d-flex gap-2">
                            <input type="month" id="mesDesde" class="form-control form-control-sm">
                            <input type="month" id="mesHasta" class="form-control form-control-sm">
                            <button id="btnAplicarMeses" class="btn btn-outline-secondary btn-sm">Aplicar</button>
                        </div>
                    </div>
                    <div class="ms-auto d-flex gap-2 flex-wrap">
                        <div class="btn-group btn-group-sm" role="group" aria-label="SKUs">
                            <button id="btnSelectAllSku" class="btn btn-outline-primary">SKUs: Todos</button>
                            <button id="btnClearAllSku" class="btn btn-outline-secondary">SKUs: Ninguno</button>
                        </div>
                        <div class="btn-group btn-group-sm" role="group" aria-label="Clientes">
                            <button id="btnSelectAllCli" class="btn btn-outline-primary">Clientes: Todos</button>
                            <button id="btnClearAllCli" class="btn btn-outline-secondary">Clientes: Ninguno</button>
                        </div>
                    </div>
                </div>

                <div class="row g-2 mb-2">
                    <div class="col-12 col-lg-6">
                        <div class="border rounded p-2" style="max-height:170px; overflow:auto; font-size:.92rem;">
                            <div class="fw-semibold small mb-1">SKUs</div>
                            <div id="skuChecklist"></div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6">
                        <div class="border rounded p-2" style="max-height:170px; overflow:auto; font-size:.92rem;">
                            <div class="fw-semibold small mb-1">Clientes seleccionados</div>
                            <div id="clienteChecklist" class="text-muted small">(solo cuando el origen es por vendedor/canal)</div>
                        </div>
                    </div>
                </div>

                <div style="width:100%; height:calc(100% - 220px);">
                    <canvas id="graficaDetalle" style="width:100%; height:100%;"></canvas>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL Comentario -->
<div class="modal fade" id="comentarioModal" tabindex="-1" aria-labelledby="comentarioModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-3">
            <div class="modal-header">
                <h6 class="modal-title fw-bold" id="comentarioModalLabel">Agregar comentario</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
