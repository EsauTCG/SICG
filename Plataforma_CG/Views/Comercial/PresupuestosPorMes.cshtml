/* =========================================================
   KPIS CON COLOR OPERATIVO
   Presupuestos / Producción / Venta / Inventarios
   ========================================================= */

.kpis-bar {
    gap: 10px !important;
}

.kpis-main {
    gap: 10px !important;
    align-items: stretch !important;
}

.kpi-card,
.sp-kpi-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.30) !important;
    border-radius: 12px !important;
    min-height: 74px;
    box-shadow: 0 10px 20px rgba(50, 8, 8, .13) !important;
    isolation: isolate;
}

.kpi-card::after,
.sp-kpi-card::after {
    content: "";
    position: absolute;
    right: -28px;
    bottom: -38px;
    width: 105px;
    height: 105px;
    border-radius: 999px;
    background: rgba(255,255,255,.14);
    pointer-events: none;
    z-index: -1;
}

.kpi-card::before,
.sp-kpi-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,.10), rgba(255,255,255,0) 55%);
    pointer-events: none;
    z-index: -1;
}

.kpi-card .kpi-title,
.kpi-card .kpi-value,
.sp-kpi-card .sp-kpi-title,
.sp-kpi-card .sp-kpi-value {
    position: relative;
    z-index: 1;
}

.kpi-card .kpi-title,
.sp-kpi-card .sp-kpi-title {
    color: rgba(255,255,255,.92) !important;
    text-shadow: 0 1px 4px rgba(0,0,0,.20);
    letter-spacing: .05em;
}

.kpi-card .kpi-value,
.sp-kpi-card .sp-kpi-value {
    color: #fff !important;
    text-shadow: 0 2px 9px rgba(0,0,0,.25);
    font-weight: 900 !important;
}

/* Producción */
.kpi-planprod {
    background: linear-gradient(135deg, #5c0000 0%, #8b0000 58%, #3a0809 100%) !important;
}

.kpi-producido {
    background: linear-gradient(135deg, #146c43 0%, #198754 58%, #0f5132 100%) !important;
}

.kpi-tendprod {
    background: linear-gradient(135deg, #084298 0%, #0d6efd 58%, #06245c 100%) !important;
}

/* Venta */
.kpi-planventa,
.sp-kpi-presupuesto {
    background: linear-gradient(135deg, #6b0d10 0%, #a3161a 58%, #4a0507 100%) !important;
}

.kpi-surtido {
    background: linear-gradient(135deg, #0f766e 0%, #14a199 58%, #064e3b 100%) !important;
}

.kpi-ventareal,
.sp-kpi-venta {
    background: linear-gradient(135deg, #157f49 0%, #22a65a 58%, #0f5132 100%) !important;
}

.kpi-devoluciones {
    background: linear-gradient(135deg, #991b1b 0%, #dc3545 58%, #5c090b 100%) !important;
}

.kpi-tendventa,
.sp-kpi-tendencia {
    background: linear-gradient(135deg, #b7791f 0%, #d99a28 58%, #7c3f04 100%) !important;
}

.kpi-pedidos {
    background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 58%, #172554 100%) !important;
}

/* Inventarios */
.kpi-invini {
    background: linear-gradient(135deg, #475569 0%, #64748b 58%, #1e293b 100%) !important;
}

.kpi-invact {
    background: linear-gradient(135deg, #0e7490 0%, #0891b2 58%, #164e63 100%) !important;
}

.kpi-tendinv {
    background: linear-gradient(135deg, #c2410c 0%, #f97316 58%, #7c2d12 100%) !important;
}

.kpi-variacion {
    background: linear-gradient(135deg, #581c87 0%, #7e22ce 58%, #3b0764 100%) !important;
}

.kpi-disponible {
    background: linear-gradient(135deg, #14532d 0%, #16a34a 58%, #052e16 100%) !important;
}

.sp-kpi-cumplimiento {
    background: linear-gradient(135deg, #4a1111 0%, #8b0000 58%, #2b0909 100%) !important;
}

.sp-kpi-cumplimiento .sp-kpi-value.sp-cump-ok {
    color: #dcfce7 !important;
    background: transparent !important;
}

.sp-kpi-cumplimiento .sp-kpi-value.sp-cump-warn {
    color: #fff3cd !important;
    background: transparent !important;
}

.sp-kpi-cumplimiento .sp-kpi-value.sp-cump-bad {
    color: #ffd6d6 !important;
    background: transparent !important;
}

@@media (max-width: 1200px) {
    .kpi-card {
        min-width: 135px !important;
    }
}

@@media (max-width: 768px) {
    .kpi-card,
    .sp-kpi-card {
        min-width: 145px !important;
        min-height: 78px !important;
    }

    .kpi-card .kpi-value,
    .sp-kpi-card .sp-kpi-value {
        font-size: 1.15rem !important;
    }
}

