      <button class="btn btn-sm btn-outline-secondary" id="pg-prev">&laquo;</button>
      <span id="pg-info" class="text-muted small">0–0 de 0</span>
      <button class="btn btn-sm btn-outline-secondary" id="pg-next">&raquo;</button>
    `;

    document.querySelector('.table-responsive-sticky')?.after($pager);

    $pgSize = $pager.querySelector('#pg-size');
    $pgPrev = $pager.querySelector('#pg-prev');
    $pgNext = $pager.querySelector('#pg-next');
    $pgInfo = $pager.querySelector('#pg-info');

    $pgSize.addEventListener('change', () => {
      state.pageSize = +$pgSize.value;
      state.page = 1;
      scheduleRender();
    });

    $pgPrev.addEventListener('click', () => {
      if (state.page > 1) {
        state.page--;
        scheduleRender();
      }
    });

    $pgNext.addEventListener('click', () => {
      if (state.page < state.maxPage) {
        state.page++;
        scheduleRender();
      }
    });
  }

  function getValoresSeleccionados(selector) {
    return Array.from(document.querySelectorAll(selector))
      .filter(c => c.checked)
      .map(c => c.value);
  }

  function initMultiDropdown(rootId, checkClass) {
    const root = document.getElementById(rootId);
    if (!root) return;

    const label = root.querySelector('.multi-label');
    const checks = root.querySelectorAll('.' + checkClass);

    function refresh() {
      const texts = [];
      checks.forEach(ch => {
        if (ch.checked) texts.push(ch.getAttribute('data-text') || ch.value);
      });

      if (!label) return;

      if (!texts.length) label.textContent = '(Todos)';
      else if (texts.length <= 3) label.textContent = texts.join(', ');
      else label.textContent = texts.length + ' seleccionados';

      const btn = root.querySelector('button.btn-select-like');
      if (btn) {
        if (texts.length > 0) btn.classList.add('has-selection');
        else btn.classList.remove('has-selection');
      }

      state.page = 1;
      scheduleRender(0);
    }

    checks.forEach(ch => {
      if (ch.dataset.boundMulti !== '1') {
        ch.addEventListener('change', refresh);
        ch.dataset.boundMulti = '1';
      }
    });

    refresh();
  }

  function setMultiLabel(rootId, itemSelector) {
    const root = document.getElementById(rootId);
    if (!root) return;

    const label = root.querySelector('.multi-label');
    const btn = root.querySelector('button.btn-select-like');
    const sel = Array.from(document.querySelectorAll(itemSelector)).filter(c => c.checked);

    if (label) {
      if (!sel.length) label.textContent = '(Todos)';
      else if (sel.length <= 3) label.textContent = sel.map(c => c.getAttribute('data-text') || c.value).join(', ');
      else label.textContent = sel.length + ' seleccionados';
    }

    if (btn) {
      if (sel.length) btn.classList.add('has-selection');
      else btn.classList.remove('has-selection');
    }
  }

