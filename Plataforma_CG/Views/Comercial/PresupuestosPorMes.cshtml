  async function openPedidosInline(panelId, params) {
    const panel = document.getElementById(panelId);
    if (!panel) return;

    const body = panel.querySelector('.ped-side-body');
    if (!body) return;

    body.innerHTML = `<div class="ped-loading">Consultando pedidos...</div>`;

    try {
      const rows = await fetchPedidosDetalle(params);
      renderPedidosPanel(panelId, params, rows);
    } catch (err) {
      console.error(err);
      body.innerHTML = `<div class="ped-error">Error al consultar pedidos.</div>`;
    }
  }

