  const $totPlanProd   = document.getElementById('tot-planprod');
  const $totProducido  = document.getElementById('tot-producido');
  const $totTendProd   = document.getElementById('tot-tendprod');
  const $totAlcProd    = document.getElementById('tot-alcprod');
  const $totPres       = document.getElementById('tot-pres');
  const $totKg         = document.getElementById('tot-kg');
  const $totSurtido    = document.getElementById('tot-surtido');
  const $totVentaReal  = document.getElementById('tot-vr');
  const $totDev        = document.getElementById('tot-dev');
  const $totTend       = document.getElementById('tot-tend');
  const $totAlc        = document.getElementById('tot-alc');
  const $totInvIni     = document.getElementById('tot-invini');
  const $totInvAct     = document.getElementById('tot-invact');
  const $totTendInv    = document.getElementById('tot-tendinv');
  const $totVar        = document.getElementById('tot-var');

  const $pmKpis        = document.getElementById('pm-kpis');
  const $pmPres        = document.getElementById('pm-kpi-pres');
  const $pmPed         = document.getElementById('pm-kpi-ped');
  const $pmSur         = document.getElementById('pm-kpi-sur');
  const $pmVr          = document.getElementById('pm-kpi-vr');
  const $pmDev         = document.getElementById('pm-kpi-dev');
  const $pmDis         = document.getElementById('pm-kpi-dis');
  const $pmTen         = document.getElementById('pm-kpi-ten');

  const $btnCsv        = document.getElementById('btn-csv');
  const $btnXlsx       = document.getElementById('btn-xlsx');
  const $btnLimpiar    = document.getElementById('btn-limpiar');

  let $pager, $pgSize, $pgPrev, $pgNext, $pgInfo;

  let raw = [];
  let data = [];
  let grouped = [];
  let view = [];
  let expanded = new Set();

  const $scrollBox = document.querySelector('.table-responsive-sticky');
  let pendingRestore = null;

  let state = {
    page: 1,
    pageSize: 100,
    maxPage: 1,
    sort: { column: null, direction: null }
  };

  const nfInt = new Intl.NumberFormat(undefined, { maximumFractionDigits: 0 });
  const nfPct = new Intl.NumberFormat(undefined, { maximumFractionDigits: 2, minimumFractionDigits: 2 });
  const num = (n) => nfInt.format(Math.round(Number(n || 0)));
  const pct = (n) => (isFinite(Number(n)) ? nfPct.format(Number(n)) : "—");

  function csvEscape(v) {
    const s = String(v ?? "");
    if (/[",\r\n]/.test(s)) return `"${s.replace(/"/g, '""')}"`;
    return s;
  }

  function toNumber(v) {
    if (v == null) return 0;
    if (typeof v === 'number') return isFinite(v) ? v : 0;
    const s = String(v).trim();
    if (!s) return 0;
    const cleaned = s.replace(/[^0-9.-]+/g, '');
    const n = Number(cleaned);
    return isFinite(n) ? n : 0;
  }

  function pickNumber(obj, ...keys) {
    for (const k of keys) {
      if (obj && Object.prototype.hasOwnProperty.call(obj, k) && obj[k] != null) {
        return toNumber(obj[k]);
      }
    }
    return 0;
  }

  function escapeHtml(s) {
    return String(s ?? '').replace(/[&<>"']/g, c => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;'
    }[c]));
  }

  function trimestreToMes(tri) {
    const t = Number(tri);
    if (t === 1) return ["1", "2", "3"];
    if (t === 2) return ["4", "5", "6"];
    if (t === 3) return ["7", "8", "9"];
    if (t === 4) return ["10", "11", "12"];
    return [];
  }

  function progressClass(p) {
    const v = Number(p);
    if (!isFinite(v)) return 'progress-danger';
    if (v >= 100) return 'progress-success';
    if (v >= 80) return 'progress-warning';
    return 'progress-danger';
  }

  async function cargarModoVendedorActual() {
  if (MODO_VENDEDOR_CARGADO) return;

  try {
    const resp = await fetch('/Comercial/UsuarioVendedorActual', { cache: 'no-store' });
    if (!resp.ok) throw new Error('HTTP ' + resp.status);

    const info = await resp.json();

    ES_VENDEDOR = !!info.esVendedor;
    VENDEDOR_IDS_ACTUALES = Array.isArray(info.vendedorIds) ? info.vendedorIds : [];
    MODO_VENDEDOR_CARGADO = true;

    aplicarModoVendedor();
  } catch (e) {
    console.error('No se pudo cargar UsuarioVendedorActual:', e);
    ES_VENDEDOR = false;
    VENDEDOR_IDS_ACTUALES = [];
    MODO_VENDEDOR_CARGADO = true;
  }
}

            function aplicarModoVendedor() {
            if (!ES_VENDEDOR) return;

            document.getElementById('filtro-origen')?.classList.add('d-none');
            document.getElementById('filtro-canal')?.classList.add('d-none');
            document.getElementById('filtro-vendedores')?.classList.add('d-none');
            document.getElementById('filtro-sp-vendedores')?.classList.add('d-none');

            document.querySelectorAll('.multi-check-origen,.multi-check-canal').forEach(ch => {
            ch.checked = false;
            });

            if ($txtVendedores) {
            $txtVendedores.value = '';
            }

            const spVen = document.getElementById('sp-vendedores');
            if (spVen) {
            spVen.value = '';
            }
            }

  let renderTimer;
  const scheduleRender = (delay = 120) => {
    if (renderTimer) clearTimeout(renderTimer);
    renderTimer = setTimeout(render, delay);
  };

  function ensurePager() {
    if ($pager) return;

    $pager = document.createElement('div');
    $pager.className = "d-flex align-items-center gap-2 my-2 pe-2";
    $pager.innerHTML = `
      <div class="ms-auto"></div>
      <div class="small text-muted">Filas por página:</div>
      <select id="pg-size" class="form-select form-select-sm" style="width:auto;">
        <option>50</option>
        <option selected>100</option>
        <option>200</option>
        <option>500</option>
