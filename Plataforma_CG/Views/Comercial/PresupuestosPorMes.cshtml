  let ES_VENDEDOR = false;
let VENDEDOR_IDS_ACTUALES = [];
let MODO_VENDEDOR_CARGADO = false;

  const $form              = document.getElementById('filtros');
  const $selMes            = document.getElementById('sel-mes');
