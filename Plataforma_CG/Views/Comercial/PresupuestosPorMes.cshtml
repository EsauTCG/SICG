@using System.Linq
@model Plataforma_CG.Models.PresupuestoConsumoDto
@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<style>
    :root {
        --bg: #f0dede;
        --panel: #f8eeee;
        --panel-2: #f1dede;
        --line: #c79d9d;
        --line-dark: #8f4c4c;
        --text: #3b1717;
        --muted: #6a3a3a;
        --title: #ffffff;
        --white: #ffffff;
        --danger: #c00000;
        --warning: #f3b6b6;
        --ok: #f7e3e3;
        --shadow: 0 1px 0 rgba(255,255,255,.55) inset;
        --brand: #8B0000;
        --vino-1: #5c0000;
        --vino-2: #7a0000;
        --vino-3: #980000;
        --vino-4: #b30000;
        --vino-5: #d10000;
        --vino-soft: #f8e7e7;
        --vino-soft-2: #f2d9d9;
        --vino-border: #9a5a5a;
        --vino-text: #ffffff;
        --vino-text-dark: #4a1111;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0 !important;
        padding: 0 !important;
        font-family: Tahoma, Verdana, Arial, sans-serif;
        background: transparent !important;
        color: var(--text);
        text-align: left !important;
    }

    .container, .container-fluid {
        max-width: 100% !important;
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .window {
        width: 100%;
        max-width: 100%;
        margin: 0 !important;
        border: 1px solid #7e4a4a;
        background: var(--panel);
        box-shadow: 0 0 0 1px rgba(255,255,255,.45) inset, 0 8px 18px rgba(70, 12, 12, 0.14);
        overflow: hidden;
        padding: 0 !important;
    }

    .window > *:first-child,
    .titlebar {
        margin-top: 0 !important;
    }

    .titlebar {
        height: 34px;
        /* display: flex; */
         display: none !important;
        align-items: center;
        justify-content: space-between;
        padding: 0 10px;
        background: linear-gradient(180deg, #c00000 0%, #8b0000 60%, #5c0000 100%);
        border-bottom: 1px solid #5c0000;
        color: #fff;
        font-size: 13px;
        font-weight: bold;
    }

    .titlebar .actions {
        display: flex;
        gap: 6px;
    }

    .win-btn {
        width: 16px;
        height: 16px;
        border: 1px solid #7c4848;
        background: linear-gradient(#fff6f6, #ead0d0);
    }

    .toolbar {
        display: none;
        align-items: center;
        gap: 4px;
        padding: 4px 6px;
        background: linear-gradient(#fff6f6, #ecd8d8);
        border-bottom: 1px solid var(--line);
        font-size: 12px;
        flex-wrap: wrap;
    }

    .tool-btn, .tab {
        border: 1px solid transparent;
        padding: 4px 8px;
        user-select: none;
    }

    .tool-btn {
        min-width: 72px;
        text-align: center;
        background: linear-gradient(#fffefe, #ecd7d7);
        border: 1px solid var(--vino-border);
        box-shadow: var(--shadow);
        cursor: pointer;
        color: var(--vino-text-dark);
        height: 28px;
        font-size: 12px;
        font-weight: 700;
    }

    .tool-btn:hover,
    .tab:hover,
    .pm-btn:hover {
        filter: brightness(0.98);
    }

    .content {
        padding: 8px;
        background: var(--bg);
    }

    .tabs {
        display: flex;
        gap: 4px;
        margin-bottom: 6px;
        flex-wrap: wrap;
    }

    .tab {
        font-size: 12px;
        background: linear-gradient(#f7e7e7, #ead1d1);
        border: 1px solid #caa0a0;
        border-bottom: none;
        padding: 7px 12px;
        color: #5c1a1a;
    }

    .tab.active {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        font-weight: bold;
        color: #fff;
        border-color: #7a2d2d;
    }

    .workspace {
        border: 1px solid var(--line);
        background: var(--panel);
        padding: 8px;
    }

    .section {
        border: 1px solid var(--line);
        background: var(--white);
        margin-bottom: 10px;
    }

    .section-title {
        padding: 6px 8px;
        font-size: 12px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
        
    }

    .section-body {
        padding: 8px;
        background: #fffafa;
    }

    .text-end {
        text-align: right !important;
        font-variant-numeric: tabular-nums;
    }

    .text-center {
        text-align: center !important;
    }

    input, select, .form-control, .form-select, .form-control-sm {
        border: 1px solid #b48787 !important;
        background: #fffdfd !important;
        color: #421414 !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        font-size: 12px !important;
    }

    .form-control:focus,
    .form-select:focus,
    .form-control-sm:focus {
        border-color: #8b0000 !important;
        box-shadow: 0 0 0 0.18rem rgba(139, 0, 0, 0.14) !important;
    }

    .form-label {
        display: block;
        color: #5c1a1a;
        font-size: 12px;
        margin-bottom: 4px;
        font-weight: bold;
    }

    .dropdown-menu {
        font-size: 12px !important;
        border-radius: 0 !important;
        border: 1px solid #b48787 !important;
        background: #fffafa !important;
    }

    .btn-select-like {
        display: flex !important;
        align-items: center;
        justify-content: space-between;
        background: #fff !important;
        cursor: pointer;
        height: 36px !important;
        border: 1px solid #b48787 !important;
        padding: 3px 8px !important;
        color: #421414 !important;
        border-radius: 0 !important;
        width: 100%;
        text-align: left;
    }

    .btn-select-like.has-selection {
        background: #fff3cd !important;
        border-color: #d4a017 !important;
        font-weight: 700 !important;
    }

    .btn-select-like::after {
        content: "▼";
        font-size: 10px;
        color: #7a3a3a;
    }

    /* FILTROS */
    .pm-filters {
        display: grid;
        grid-template-columns:
            95px
            95px
            80px
            100px
            100px
            170px
            170px
            220px
            140px
            140px;
        gap: 8px 10px;
        align-items: end;
    }

    .pm-col-1,
    .pm-col-2,
    .pm-col-3,
    .pm-col-4 {
        grid-column: span 1;
        min-width: 0;
    }

    .pm-col-12 {
        grid-column: 1 / -1;
        min-width: 0;
    }

    .pm-filters .form-label {
        margin-bottom: 3px;
        font-size: 11px;
        line-height: 1.1;
    }

    .pm-filters .form-control,
    .pm-filters .form-select,
    .pm-filters .btn-select-like {
        height: 30px !important;
        min-height: 30px !important;
        padding: 3px 8px !important;
        font-size: 12px !important;
    }

    .pm-filters input::placeholder {
        font-size: 11px;
    }

    .pm-actions {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        align-items: center;
    }

    .pm-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
        height: 28px;
        padding: 0 10px;
        font-weight: 700;
        border-radius: 0;
        font-size: 12px;
        box-shadow: var(--shadow);
        white-space: nowrap;
        border: 1px solid #b48787;
        background: linear-gradient(#fffefe, #ecd7d7);
        color: #4b1f1f;
    }

    .pm-btn-primary {
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border: 1px solid #7a2d2d;
    }

    .pm-btn-excel {
        color: #fff;
        background: linear-gradient(180deg, #198754 0%, #146c43 100%);
        border: 1px solid #146c43;
    }

    /* TOP BAR */
    .pm-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 8px;
        width: 100%;
    }

    .pm-tabs-top {
        margin-bottom: 0 !important;
        flex: 0 0 auto;
    }

    .pm-top-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 6px;
        flex-wrap: wrap;
        margin-left: auto;
    }

    .pm-top-actions .pm-btn {
        height: 30px;
    }

    .pm-actions.pm-actions-bottom {
        display: none !important;
    }

    /* KPI */
    .kpis-bar {
        display: flex;
        align-items: stretch;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .kpis-main {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        flex: 1;
        justify-content: center;
    }

    .kpis-side {
        display: flex;
        margin-left: auto;
    }

    .kpi-card {
        min-width: 140px;
        border: 1px solid #d8bcbc;
        background: linear-gradient(#fffefe, #f3e4e4);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.7);
        padding: 6px 8px;
        text-align: center;
    }

    .kpi-card.kpi-right {
        min-width: 110px;
    }

    .kpi-title {
        font-size: 11px;
        color: #7a0000;
        font-weight: 700;
        margin-bottom: 3px;
        text-transform: uppercase;
        text-align: center;
    }

    .kpi-value {
        font-size: 16px;
        font-weight: 700;
        color: #401515;
        font-variant-numeric: tabular-nums;
        text-align: center;
    }

    /* TABLA PRINCIPAL */
    .table-card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 0;
        box-shadow: 0 0 0 1px rgba(255,255,255,.45) inset, 0 8px 18px rgba(70, 12, 12, 0.08);
        overflow: hidden;
        margin-bottom: 0 !important;
    }

    .table-responsive-sticky {
        max-height: 82vh !important;
        overflow-y: auto;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        border-top: 1px solid #d9b8b8;
        background: #fffafa;
        padding: 0;
        position: relative;
        display: block !important;
        width: 100% !important;
        max-width: 100% !important;
    }

    .table-responsive-sticky::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    .table-responsive-sticky::-webkit-scrollbar-track {
        background: #f1e4e4;
    }

    .table-responsive-sticky::-webkit-scrollbar-thumb {
        background: #8b0000;
    }

    .table-responsive-sticky::-webkit-scrollbar-thumb:hover {
        background: #6f0000;
    }

    #tbl-data {
        margin-bottom: 0;
        width: 100% !important;
        min-width: 100% !important;
        table-layout: fixed !important;
        border-collapse: separate !important;
        border-spacing: 0 !important;
        font-size: 12px !important;
        background: #fffafa;
    }

    #tbl-data thead,
    #tbl-data thead tr,
    #tbl-data thead th {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        color: #fff !important;
    }

    #tbl-data thead th {
        position: sticky;
        top: -1px;
        z-index: 20;
        border-top: 1px solid #c46a6a !important;
        border-right: 1px solid #8e3b3b !important;
        border-bottom: 1px solid #5c0000 !important;
        padding: 6px 5px !important;
        font-weight: 700 !important;
        letter-spacing: 0 !important;
        font-size: 12px !important;
        white-space: nowrap;
        line-height: 1.2 !important;
        box-shadow: 0 2px 0 #6f1d1d;
        cursor: pointer;
    }

    #tbl-data thead th:first-child,
    #tbl-data tbody td:first-child,
    #tbl-data tfoot th:first-child {
        border-left: 1px solid #d8bcbc !important;
    }

    #tbl-data thead th:first-child {
        border-left: 1px solid #8e3b3b !important;
    }

    #tbl-data tbody td {
        background: #fffafa !important;
        border-right: 1px solid #d8bcbc !important;
        border-bottom: 1px solid #d8bcbc !important;
        padding: 6px 5px !important;
        line-height: 1.2 !important;
        color: #111111 !important;
        font-weight: 400;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 12px !important;
        vertical-align: middle;
    }

    #tbl-data.table-striped > tbody > tr:nth-of-type(odd) > * {
        background-color: #fffafa !important;
    }

    #tbl-data tbody > tr:nth-of-type(even) > * {
        background-color: #f9eded !important;
    }

    #tbl-data tbody tr:hover > * {
        background: #f4dddd !important;
    }

    #tbl-data tbody tr.is-open > * {
        background: #f4dddd !important;
    }

    #tbl-data tfoot th {
        background: linear-gradient(#fff7f7, #edd9d9) !important;
        border-top: 1px solid #c79d9d;
        border-right: 1px solid #d8bcbc;
        color: #4a1818 !important;
        padding: 6px 5px;
        font-weight: 700;
        font-size: 12px;
        white-space: nowrap;
    }

   #tbl-data th:nth-child(1),  #tbl-data td:nth-child(1)  { width: 30px; }
#tbl-data th:nth-child(2),  #tbl-data td:nth-child(2)  { width: 85px; }
#tbl-data th:nth-child(3),  #tbl-data td:nth-child(3)  { width: 150px; }
#tbl-data th:nth-child(4),  #tbl-data td:nth-child(4)  { width: 60px; }
#tbl-data th:nth-child(5),  #tbl-data td:nth-child(5)  { width: 60px; }
#tbl-data th:nth-child(6),  #tbl-data td:nth-child(6)  { width: 135px; }
#tbl-data th:nth-child(7),  #tbl-data td:nth-child(7)  { width: 70px; }
#tbl-data th:nth-child(8),  #tbl-data td:nth-child(8)  { width: 60px; }
#tbl-data th:nth-child(9),  #tbl-data td:nth-child(9)  { width: 60px; }
#tbl-data th:nth-child(10), #tbl-data td:nth-child(10) { width: 60px; }  /* Venta Real */
#tbl-data th:nth-child(11), #tbl-data td:nth-child(11) { width: 45px; }  /* Devoluciones */
#tbl-data th:nth-child(12), #tbl-data td:nth-child(12) { width: 130px; } /* Tend. Venta */
#tbl-data th:nth-child(13), #tbl-data td:nth-child(13) { width: 50px; }  /* Pedidos */
#tbl-data th:nth-child(14), #tbl-data td:nth-child(14) { width: 60px; }  /* Alc. Venta */
#tbl-data th:nth-child(15), #tbl-data td:nth-child(15) { width: 50px; }  /* Inv. Ini */
#tbl-data th:nth-child(16), #tbl-data td:nth-child(16) { width: 50px; }  /* Inv. Act */
#tbl-data th:nth-child(17), #tbl-data td:nth-child(17) { width: 130px; } /* Tend. Inv */
#tbl-data th:nth-child(18), #tbl-data td:nth-child(18) { width: 50px; }  /* Variación */

    #tbl-data tbody td:nth-child(3) {
        white-space: normal !important;
        overflow: visible !important;
        text-overflow: clip !important;
        word-break: break-word;
        line-height: 1.15 !important;
    }

#tbl-data thead th:nth-child(7),
#tbl-data tbody td:nth-child(7),
#tbl-data thead th:nth-child(10),
#tbl-data tbody td:nth-child(10),
#tbl-data thead th:nth-child(14),
#tbl-data tbody td:nth-child(14){
        background-color: #fff4cc !important;
        color: #401515 !important;
    }

    #tbl-data thead th:nth-child(7),
    #tbl-data thead th:nth-child(10),
    #tbl-data thead th:nth-child(14) {
        background: linear-gradient(180deg, #dcb000 0%, #c79c00 55%, #a88000 100%) !important;
        color: #fff !important;
        border-right: 1px solid #916f00 !important;
        border-bottom: 1px solid #7b5f00 !important;
        border-top: 1px solid #e7c84e !important;
    }

    .sku-cell {
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .toggle-sku,
    .toggle-btn {
        width: 22px;
        height: 22px;
        border-radius: 0;
        padding: 0;
        flex: 0 0 auto;
        border: 1px solid #b48787;
        background: linear-gradient(#fffefe, #ecd7d7);
        color: #6b1f1f;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .sku-text {
        display: inline-block;
        line-height: 1;
        letter-spacing: .2px;
    }

    .toggle-ico {
        font-weight: 900;
        color: #7a0000;
    }

    .ped-link {
        font-weight: 700;
        text-decoration: underline;
        cursor: pointer;
        color: #5a0000;
    }

    .ped-link:hover,
    .ped-link.is-active {
        color: #8B0000;
    }

    tr.detail-row td {
        background: #f7eaea !important;
        padding: .50rem .60rem !important;
        border-bottom: 1px solid #d8bcbc;
    }

    .detail-box {
        border: 1px solid #d8bcbc;
        border-left: 4px solid #8b0000;
        box-shadow: none;
        border-radius: 0;
        background: #fffafa;
        overflow: hidden;
    }

    .detail-head {
        padding: 6px 8px;
        font-size: 12px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .detail-head::before {
        content: "";
        width: 8px;
        height: 8px;
        background: #fff;
        border-radius: 0;
    }

    .detail-box .table-responsive,
    .ped-table-wrap {
        overflow: auto;
        border-top: 1px solid #d8bcbc;
        background: #fffafa;
    }

    .detail-table,
    .ped-table {
        width: max-content !important;
        min-width: 100%;
        table-layout: auto !important;
        font-size: 12px;
        margin: 0;
        border-collapse: separate;
        border-spacing: 0;
        background: #fffafa;
    }

    .detail-table th,
    .ped-table th {
        position: sticky;
        top: 0;
        z-index: 1;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        color: #fff;
        border-bottom: 1px solid #5c0000;
        border-right: 1px solid #8e3b3b;
        padding: 6px 5px;
        white-space: nowrap;
        font-size: 12px;
    }

    .detail-table td,
    .ped-table td {
        background: #fffafa;
        border-bottom: 1px solid #d8bcbc;
        border-right: 1px solid #d8bcbc;
        padding: 6px 5px;
        white-space: nowrap;
        color: #111111;
        font-weight: 400;
    }

    .detail-table th:first-child,
    .detail-table td:first-child,
    .ped-table th:first-child,
    .ped-table td:first-child {
        border-left: 1px solid #d8bcbc;
    }

    .td-wrap {
        white-space: normal !important;
        word-break: break-word !important;
        line-height: 1.15;
    }

    .detail-split {
        display: grid;
        grid-template-columns: max-content minmax(380px, 1fr);
        gap: .40rem;
        align-items: start;
        width: 100%;
    }

    .ped-side-box {
        min-height: 100%;
    }

    .ped-side-body {
        padding: .45rem;
        background: #fff6f6;
        min-height: 220px;
    }

    .ped-placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 180px;
        border: 1px dashed #c79d9d;
        border-radius: 0;
        color: #6b7280;
        background: #fffafa;
        text-align: center;
        padding: 1rem;
    }

    .ped-loading,
    .ped-empty,
    .ped-error {
        padding: 1rem;
        border-radius: 0;
        font-size: .9rem;
    }

    .ped-loading {
        background: #fffafa;
        color: #4b5563;
        border: 1px solid #d7c0c0;
    }

    .ped-empty {
        background: #fff;
        color: #6b7280;
        border: 1px dashed #c7b4b4;
    }

    .ped-error {
        background: #fff5f5;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .ped-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
        margin-bottom: .45rem;
    }

    .ped-chip {
        background: #fff;
        border: 1px solid #cfd9e3;
        border-radius: 0;
        padding: .2rem .55rem;
        font-size: .76rem;
        color: #334155;
        font-weight: 700;
    }

    .progress-mini,
    .sp-progress {
        height: 7px;
        border-radius: 0;
        background-color: #eadede;
        overflow: hidden;
        min-width: 110px;
    }

    .progress-mini-bar,
    .sp-progress-bar {
        height: 100%;
        transition: width .3s ease;
    }

    .progress-danger,
    .sp-bar-bad {
        background: linear-gradient(90deg, #dc3545, #b02a37);
    }

    .progress-warning,
    .sp-bar-warn {
        background: linear-gradient(90deg, #ffc107, #d39e00);
    }

    .progress-success,
    .sp-bar-ok {
        background: linear-gradient(90deg, #198754, #146c43);
    }

    .progress-label,
    .sp-progress-label {
        font-size: 11px;
        font-weight: 700;
        color: #475569;
        margin-top: 2px;
        text-align: right;
    }

    /* MODAL */
    .modal-content {
        border: 1px solid #7d4949;
        border-radius: 0;
        box-shadow: 0 10px 20px rgba(60, 10, 10, 0.14);
    }

    .modal-header {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        color: white !important;
