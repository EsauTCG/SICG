  function render() {
    const base = filtrarBase();
    grouped = buildGrouped(base);
    view = grouped.slice();
    ordenarDatos();

    let tPlanProd = 0, tProducido = 0, tTendProd = 0, tAlcProd = 0;
    let tPres = 0, tKg = 0, tSurt = 0, tVentaReal = 0, tDev = 0, tTend = 0;
    let tInvIni = 0, tInvAct = 0, tTendInv = 0, tVar = 0;

    for (const g of view) {
      tPlanProd  += toNumber(g._planProd);
      tProducido += toNumber(g._producido);
      tTendProd  += toNumber(g._tendProd);
      tPres      += toNumber(g._pres);
      tKg        += toNumber(g._kg);
      tSurt      += toNumber(g._kgSurtido);
      tVentaReal += toNumber(g._ventaReal);
      tDev       += toNumber(g._devoluciones);
      tTend      += toNumber(g._tendencia);
      tInvIni    += toNumber(g._invIni);
      tInvAct    += toNumber(g._invAct);
      tTendInv   += toNumber(g._tendInv);
      tVar       += toNumber(g._variacion);
    }

            const tDisp = tPres - tKg - tSurt + tDev;
    const tAlc = (tPres > 0) ? (tTend / tPres) * 100 : 0;
    tAlcProd = (tPlanProd > 0) ? (tTendProd / tPlanProd) * 100 : 0;

    $totPlanProd.textContent = num(tPlanProd);
    $totProducido.textContent = num(tProducido);
    $totTendProd.textContent = num(tTendProd);
    $totAlcProd.textContent = isFinite(tAlcProd) ? (pct(tAlcProd) + "%") : "—";

    $totPres.textContent = num(tPres);
    $totKg.textContent = num(tKg);
    $totSurtido.textContent = num(tSurt);
    $totVentaReal.textContent = num(tVentaReal);
    if ($totDev) $totDev.textContent = num(tDev);
    $totTend.textContent = num(tTend);
    $totAlc.textContent = isFinite(tAlc) ? (pct(tAlc) + "%") : "—";

    $totInvIni.textContent = num(tInvIni);
    $totInvAct.textContent = num(tInvAct);
    $totTendInv.textContent = num(tTendInv);
    $totVar.textContent = num(tVar);

    if ($pmKpis) {
      if (view.length) {
        $pmPres.textContent = num(tPres);
        $pmPed.textContent = num(tKg);
        $pmSur.textContent = num(tSurt);
        $pmVr.textContent = num(tVentaReal);
        if ($pmDev) $pmDev.textContent = num(tDev);
        $pmDis.textContent = num(tDisp);
        $pmTen.textContent = num(tTend);

        const $pmPlanProd  = document.getElementById('pm-kpi-planprod');
        const $pmProducido = document.getElementById('pm-kpi-producido');
        const $pmTendProd  = document.getElementById('pm-kpi-tendprod');
        const $pmInvIni    = document.getElementById('pm-kpi-invini');
        const $pmInvAct    = document.getElementById('pm-kpi-invact');
        const $pmTendInv   = document.getElementById('pm-kpi-tendinv');
        const $pmVar       = document.getElementById('pm-kpi-var');

        if ($pmPlanProd)  $pmPlanProd.textContent = num(tPlanProd);
        if ($pmProducido) $pmProducido.textContent = num(tProducido);
        if ($pmTendProd)  $pmTendProd.textContent = num(tTendProd);
        if ($pmInvIni)    $pmInvIni.textContent = num(tInvIni);
        if ($pmInvAct)    $pmInvAct.textContent = num(tInvAct);
        if ($pmTendInv)   $pmTendInv.textContent = num(tTendInv);
        if ($pmVar)       $pmVar.textContent = num(tVar);

        $pmKpis.style.display = '';
      } else {
        $pmKpis.style.display = 'none';
      }
    }

    state.maxPage = Math.max(1, Math.ceil(view.length / state.pageSize));
    if (state.page > state.maxPage) state.page = state.maxPage;

    const start = (state.page - 1) * state.pageSize;
    const end = Math.min(start + state.pageSize, view.length);
    const pageSlice = view.slice(start, end);

    if (!pageSlice.length) {
      $tbody.innerHTML = `<tr><td colspan="18" class="text-center text-muted">Sin resultados.</td></tr>`;
      if ($pager) $pgInfo.textContent = `0–0 de 0`;
      return;
    }

    const frag = document.createDocumentFragment();

    pageSlice.forEach((g, idx) => {
      const isOpen = expanded.has(g._key);
      const rowNum = start + idx + 1;

      const tr = document.createElement('tr');
      if (isOpen) tr.classList.add('is-open');

      tr.innerHTML = `
        <td class="text-center"><b>${rowNum}</b></td>
        <td>
          <div class="sku-cell">
            <button class="toggle-btn toggle-sku" type="button" data-toggle="${escapeHtml(g._key)}" title="Ver detalle">
              <span class="toggle-ico">${isOpen ? "▾" : "▸"}</span>
            </button>
            <b class="sku-text">${escapeHtml(g.sku)}</b>
          </div>
        </td>
        <td class="td-wrap" title="${escapeHtml(g.producto)}">${escapeHtml(g.producto)}</td>
        <td class="text-end">${num(g._planProd)}</td>
        <td class="text-end">${num(g._producido)}</td>
        <td class="text-end" title="Tend. Prod: ${num(g._tendProd)} | Plan Prod: ${num(g._planProd)}">
          <div class="progress-mini">
            <div class="progress-mini-bar ${progressClass(g._planProd > 0 ? (g._tendProd / g._planProd * 100) : 0)}"
                 style="width:${g._planProd > 0 ? Math.min(100, (g._tendProd / g._planProd * 100)) : 0}%"></div>
          </div>
          <div class="progress-label">${num(g._tendProd)} kg</div>
        </td>
        <td class="text-end">${pct(g._alcProd)}%</td>
        <td class="text-end">${num(g._pres)}</td>
        <td class="text-end">${num(g._kgSurtido)}</td>
        <td class="text-end">${num(g._ventaReal)}</td>
        <td class="text-end">${num(g._devoluciones)}</td>
        <td class="text-end" title="Tendencia: ${num(g._tendencia)} | Plan: ${num(g._pres)}">
          <div class="progress-mini">
            <div class="progress-mini-bar ${progressClass(g._pres > 0 ? (g._tendencia / g._pres * 100) : 0)}"
                 style="width:${g._pres > 0 ? Math.min(100, (g._tendencia / g._pres * 100)) : 0}%"></div>
          </div>
          <div class="progress-label">${num(g._tendencia)} kg</div>
        </td>
        <td class="text-end">${num(g._kg)}</td>
        <td class="text-end">${pct(g._alc)}%</td>
        <td class="text-end">${num(g._invIni)}</td>
        <td class="text-end">${num(g._invAct)}</td>
        <td class="text-end" title="Tend. Inv: ${num(g._tendInv)} | Inv. Ini: ${num(g._invIni)}">
          <div class="progress-mini">
            <div class="progress-mini-bar ${progressClass(g._invIni > 0 ? (g._tendInv / g._invIni * 100) : 0)}"
                 style="width:${g._invIni > 0 ? Math.min(100, (g._tendInv / g._invIni * 100)) : 0}%"></div>
          </div>
          <div class="progress-label">${num(g._tendInv)} kg</div>
        </td>
        <td class="text-end">${num(g._variacion)}</td>
      `;

      frag.appendChild(tr);

      if (isOpen) {
        const trd = document.createElement('tr');
        trd.className = "detail-row";
        trd.innerHTML = `<td colspan="18">${renderDetalleHtml(g)}</td>`;
        frag.appendChild(trd);
      }
    });

    $tbody.replaceChildren(frag);

    if (pendingRestore && $scrollBox) {
      const { top, left } = pendingRestore;
      pendingRestore = null;
      requestAnimationFrame(() => {
        $scrollBox.scrollTop = top;
        $scrollBox.scrollLeft = left;
      });
    }

    if ($pager) $pgInfo.textContent = `${start + 1}–${end} de ${view.length}`;
  }

  function initSorting() {
    document.querySelectorAll('#tbl-data thead th[data-sort]').forEach(th => {
      if (th.dataset.boundSort === '1') return;

      th.addEventListener('click', () => {
        const col = th.dataset.sort;

        if (state.sort.column === col) {
          state.sort.direction =
            state.sort.direction === 'asc' ? 'desc' :
            state.sort.direction === 'desc' ? null : 'asc';
        } else {
          state.sort.column = col;
          state.sort.direction = 'asc';
        }

        document.querySelectorAll('#tbl-data thead th[data-sort]').forEach(h => {
          h.textContent = h.textContent.replace(/\s*[▲▼]$/, '');
        });

        if (state.sort.direction === 'asc') th.textContent += ' ▲';
        else if (state.sort.direction === 'desc') th.textContent += ' ▼';
        else {
          state.sort.column = null;
          state.sort.direction = null;
        }

        state.page = 1;
        scheduleRender(0);
      });

      th.dataset.boundSort = '1';
    });
  }

  async function fetchVentaRealRows() {
    const resp = await fetch(ENDPOINT_VR, { cache: "no-store" });
    if (!resp.ok) throw new Error("HTTP " + resp.status);
    return await resp.json();
  }

  async function fetchDevolucionesRows(mes, anio) {
    const resp = await fetch(`${ENDPOINT_DM}?mes=${mes}&anio=${anio}`, { cache: "no-store" });
    if (!resp.ok) throw new Error("HTTP " + resp.status);
    return await resp.json();
  }

  function buildDevolucionesMap(rows) {
  const map = new Map();

  for (const r of (rows || [])) {
    const sku    = String(r.sku  ?? "").toUpperCase().trim();
    const anio   = String(r.anio ?? "").trim();
    const mes    = String(r.mes  ?? "").trim();
    const kg     = toNumber(r.kg);
    const cli    = String(r.clienteId     ?? "").toUpperCase().trim();
    const venId  = String(r.vendedorId    ?? "").trim();
    const canal  = String(r.canal         ?? "").toUpperCase().trim();

    // Clave general por SKU/mes (para el total del grupo)
    const keyGen = `${anio}|${mes}|${sku}`;
    map.set(keyGen, (map.get(keyGen) || 0) + kg);

    // Clave por cliente
    if (cli) {
      const keyCli = `CLIENTE|${anio}|${mes}|${sku}|${cli}`;
      map.set(keyCli, (map.get(keyCli) || 0) + kg);
    }

    // Clave por vendedor
    if (venId) {
      const keyVen = `VENDEDOR|${anio}|${mes}|${sku}|${venId}`;
      map.set(keyVen, (map.get(keyVen) || 0) + kg);
    }

    // Clave por canal CEDIS (si tiene canal)
    if (canal) {
      const keyCedis = `CEDIS|${anio}|${mes}|${sku}|${canal}`;
      map.set(keyCedis, (map.get(keyCedis) || 0) + kg);
    }
  }

  return map;
}

  function buildVentaRealMap(rows) {
    const map = new Map();

    for (const r of (rows || [])) {
      const sku        = String(r.articuloCodigo ?? "").toUpperCase().trim();
      const anio       = String(r.anio ?? "").trim();
      const mes        = String(r.mes ?? "").trim();
      const vendedorId = r.vendedorId == null ? "" : String(r.vendedorId).trim();
      const canal      = String(r.u_CANAL ?? "").toUpperCase().trim();
      const kg         = toNumber(r.kgVendidos);

      if (vendedorId) {
        const kV = `VENDEDOR|${anio}|${mes}|${sku}|${vendedorId}`;
        map.set(kV, (map.get(kV) || 0) + kg);
      }

      if (canal) {
        const kC = `CEDIS|${anio}|${mes}|${sku}|${canal}`;
        map.set(kC, (map.get(kC) || 0) + kg);
      }
    }

    return map;
  }

  function getMasterValue(r) {
  return String(
    r.master ??
    r.Master ??
    r.MASTER ??
    r.u_MASTER ??
    r.productoMaster ??
    r.producto_master ??
    r.masterNombre ??
    r.nombreMaster ??
    r.familia ??
    r.Familia ??
    r.linea ??
    r.Linea ??
    r.grupo ??
    r.Grupo ??
    r.categoria ??
    r.Categoria ??
    r._master ??
    ''
  ).toUpperCase().trim();
}

  function normalizarData(rawRows, invIniMap, invActMap, ventaRealMap, devolucionesMap) {
  return (rawRows || []).map(r => {
    const presupuesto  = toNumber(r.presupuestoAsignado);
    const pedidos      = toNumber(r.kgPedidosMes);
    const surtido      = toNumber(r.kgSurtidoReal);
    const planProdRaw  = pickNumber(r, 'planProduccion', 'PlanProduccion', 'plan_prod', 'planProd');
    const producidoRaw = pickNumber(r, 'producido', 'Producido', 'producidoReal', 'prod_real', 'prodReal');

    const skuKey = String(r.productoCodigo ?? r._sku ?? '').toUpperCase().trim();
    const anio   = String(r.anioConsulta ?? r.anio ?? r._anio ?? '').trim();
    const mes    = String(r.mesConsulta ?? r.mes ?? r._mes ?? '').trim();

            const origen = String(r.origen ?? r._origen ?? '').toUpperCase().trim();

            const canalKey = String(
            r.canal ??
            r.u_CANAL ??
            r._canal ??
            ''
            ).toUpperCase().trim();

            const venIdKey = String(
            r.vendedorId ??
            r._venId ??
            ''
            ).trim();

            const cliCodKey = String(
            r.clienteCodigo ??
            r.codigoCliente ??
            r.CardCode ??
            r._cliCod ??
            ''
            ).toUpperCase().trim();

            const vrKeyVendedor = `VENDEDOR|${anio}|${mes}|${skuKey}|${venIdKey}`;
            const vrKeyCedis = `CEDIS|${anio}|${mes}|${skuKey}|${canalKey}`;

            let ventaReal = 0;
            if (origen === 'VENDEDOR') {
            ventaReal = toNumber(ventaRealMap.get(vrKeyVendedor));
            } else if (origen === 'CEDIS') {
            ventaReal = toNumber(ventaRealMap.get(vrKeyCedis));
            }

            let devKey = null;

            if (origen === 'VENDEDOR') {
            devKey = venIdKey
            ? `VENDEDOR|${anio}|${mes}|${skuKey}|${venIdKey}`
            : null;
            } else if (origen === 'CEDIS') {
            devKey = canalKey
            ? `CEDIS|${anio}|${mes}|${skuKey}|${canalKey}`
            : null;
            } else if (origen === 'CLIENTE') {
            devKey = cliCodKey
            ? `CLIENTE|${anio}|${mes}|${skuKey}|${cliCodKey}`
            : null;
            }

            const devoluciones = devKey
            ? toNumber(devolucionesMap.get(devKey))
            : 0;

    const cliCod = String(
      r.clienteCodigo ??
      r.codigoCliente ??
      r.CardCode ??
      r._cliCod ??
      ''
    ).toUpperCase().trim();

    const cliNom = String(
      r.nombreCliente ??
      r.clienteNombre ??
      r.CardName ??
      r._cliNom ??
      ''
    ).toUpperCase().trim();

 const master = getMasterValue(r);

    const clasificacionId = r.clasificacionId ?? r._clasificacionId ?? null;
    const clasificacionNombre = String(
      r.clasificacionNombre ??
      r._clasificacionNombre ??
      ''
    ).toUpperCase().trim();

    return {
      ...r,
      _anio: anio,
      _mes: mes,
      _sku: skuKey,
      _prod: String(r.productoNombre ?? r._prod ?? '').trim(),
      _origen: origen,
      _canal: String(r.canal ?? r.u_CANAL ?? r._canal ?? '').toUpperCase().trim(),
      _venId: r.vendedorId ?? r._venId ?? null,
      _venCod: String(r.vendedorCodigo ?? r.VendedorCodigo ?? r._venCod ?? '').trim(),
      _venNom: String(r.vendedorNombre ?? r.VendedorNombre ?? r._venNom ?? '').toUpperCase().trim(),
      _cliCod: cliCod,
      _cliNom: cliNom,
      _master: master,
      _clasificacionId: clasificacionId,
      _clasificacionNombre: clasificacionNombre,
      _pres: presupuesto,
      _kg: pedidos,
      _kgSurtido: surtido,
      _planProd: planProdRaw,
      _producido: producidoRaw,
      _ventaReal: ventaReal,
      // _devoluciones: 0,
      _invIni: toNumber(invIniMap.get(skuKey)),
      _invAct: toNumber(invActMap.get(skuKey)),
        _devoluciones: devoluciones,
      _disp: presupuesto - pedidos - surtido + devoluciones
    };
  });
}

async function cargarTodo() {
    try {
      await cargarModoVendedorActual();
      const now = new Date();
      const mesCarga = ($selMes.value || String(now.getMonth() + 1)).trim();
      const anioCarga = ($selAnio.value || String(now.getFullYear())).trim();

      if (!$selMes.value && !$selTri.value) $selMes.value = mesCarga;
      if (!$selAnio.value) $selAnio.value = anioCarga;

      $tbody.innerHTML = `
        <tr>
          <td colspan="18" class="text-center text-muted">
            <div>Cargando datos principales...</div>
            <div class="small text-muted mt-1" id="load-status">0 de 5 fuentes listas</div>
          </td>
        </tr>`;

      let listas = 0;
      function tickLoad(msg) {
        listas++;
        const el = document.getElementById('load-status');
        if (el) el.textContent = `${listas} de 5 fuentes listas — ${msg}`;
      }

      const [rawResult, invIniResult, invActResult, vrResult, devResult] = await Promise.allSettled([
        fetch(ENDPOINT_URL, { cache: 'no-store' })
          .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
          .then(d => { tickLoad('Presupuestos ✓'); return d; }),

        fetch(`${ENDPOINT_INVINI}?mes=${mesCarga}&anio=${anioCarga}`, { cache: 'no-store' })
          .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
          .then(d => { tickLoad('Inv. Inicial ✓'); return d; })
          .catch(e => { console.warn('InvIni:', e); tickLoad('Inv. Inicial ✗'); return []; }),

        fetch(ENDPOINT_INVACT, { cache: 'no-store' })
          .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
          .then(d => { tickLoad('Inv. Actual ✓'); return d; })
          .catch(e => { console.warn('InvAct:', e); tickLoad('Inv. Actual ✗'); return []; }),

        fetchVentaRealRows()
          .then(d => { tickLoad('Venta Real ✓'); return d; })
          .catch(e => { console.warn('VentaReal:', e); tickLoad('Venta Real ✗'); return []; }),

        fetchDevolucionesRows(mesCarga, anioCarga)
          .then(d => { tickLoad('Devoluciones ✓'); return d; })
          .catch(e => { console.warn('Devoluciones:', e); tickLoad('Devoluciones ✗'); return []; })
      ]);

      if (rawResult.status === 'rejected') throw rawResult.reason;

      raw = rawResult.value || [];

      const invIniRows = invIniResult.status === 'fulfilled' ? invIniResult.value : [];
      const invActRows = invActResult.status === 'fulfilled' ? invActResult.value : [];
      const vrRows     = vrResult.status === 'fulfilled' ? vrResult.value : [];
      const devRows    = devResult.status === 'fulfilled' ? devResult.value : [];

      const invIniMap = new Map(
        (invIniRows || []).map(x => [String(x.sku ?? '').toUpperCase().trim(), toNumber(x.invInicial)])
      );

      const invActMap = new Map(
        (invActRows || []).map(x => [String(x.sku ?? '').toUpperCase().trim(), toNumber(x.invActual)])
      );

      const ventaRealMap = buildVentaRealMap(vrRows);
  devolucionesMapGlobal = buildDevolucionesMap(devRows);
data = normalizarData(raw, invIniMap, invActMap, ventaRealMap, devolucionesMapGlobal);

      poblarAnos(data);
      poblarCanales(data);
      poblarMasters(data);
      poblarClasificaciones(data);
      poblarSkus(data);

      if (!$selAnio.value) $selAnio.value = anioCarga;
      if (!$selMes.value && !$selTri.value) $selMes.value = mesCarga;

      ensurePager();

      initMultiDropdown('dd-origen', 'multi-check-origen');
      initMultiDropdown('dd-canal', 'multi-check-canal');
      initMultiDropdown('dd-master', 'multi-check-master');
      initMultiDropdown('dd-clasificacion', 'multi-check-clasificacion');
      initMultiDropdown('dd-sku', 'multi-check-sku');

      scheduleRender(0);
    } catch (err) {
      console.error(err);
      $tbody.innerHTML = `<tr><td colspan="18" class="text-danger text-center">Error al cargar datos: ${err.message}</td></tr>`;
    }
  }

  $form?.addEventListener('submit', e => {
    e.preventDefault();
    state.page = 1;
    scheduleRender();
  });

  [$txtVendedores, $txtClientes].forEach(el => {
    if (!el) return;
    el.addEventListener('input', () => {
      state.page = 1;
      scheduleRender();
    });
    el.addEventListener('change', () => {
      state.page = 1;
      scheduleRender();
    });
  });

  $selTri?.addEventListener('change', async () => {
    if ($selTri.value) $selMes.value = "";
    state.page = 1;
    await cargarTodo();
  });

  $selMes?.addEventListener('change', async () => {
    if ($selMes.value) $selTri.value = "";
    state.page = 1;
    await cargarTodo();
  });

  $selAnio?.addEventListener('change', async () => {
    state.page = 1;
    await cargarTodo();
  });

  document.addEventListener('change', (e) => {
    if (e.target.classList.contains('canal-check-all')) {
      document.querySelectorAll('.multi-check-canal').forEach(c => c.checked = e.target.checked);
      setMultiLabel('dd-canal', '.multi-check-canal');
      state.page = 1;
      scheduleRender(0);
      return;
    }

    if (e.target.classList.contains('master-check-all')) {
      document.querySelectorAll('.multi-check-master').forEach(c => c.checked = e.target.checked);
      setMultiLabel('dd-master', '.multi-check-master');
      state.page = 1;
      scheduleRender(0);
      return;
    }

    if (e.target.classList.contains('clasificacion-check-all')) {
      document.querySelectorAll('.multi-check-clasificacion').forEach(c => c.checked = e.target.checked);
      setMultiLabel('dd-clasificacion', '.multi-check-clasificacion');
      state.page = 1;
      scheduleRender(0);
      return;
    }

    if (e.target.classList.contains('sku-check-all')) {
      document.querySelectorAll('.multi-check-sku').forEach(c => c.checked = e.target.checked);
      setMultiLabel('dd-sku', '.multi-check-sku');
      state.page = 1;
      scheduleRender(0);
      return;
    }

    if (
      e.target.classList.contains('multi-check-origen') ||
      e.target.classList.contains('multi-check-canal') ||
      e.target.classList.contains('multi-check-master') ||
      e.target.classList.contains('multi-check-clasificacion') ||
      e.target.classList.contains('multi-check-sku')
    ) {
      state.page = 1;
      scheduleRender(0);
    }
  });

  if ($btnLimpiar) {
    $btnLimpiar?.addEventListener('click', async (e) => {
  e.preventDefault();

  $selMes.value = "";
  $selAnio.value = "";
  $selTri.value = "";
            if ($txtVendedores) $txtVendedores.value = "";
            if ($txtClientes) $txtClientes.value = "";

  document.querySelectorAll(
    '.multi-check-origen,.multi-check-canal,.multi-check-master,.multi-check-clasificacion,.multi-check-sku,.canal-check-all,.master-check-all,.clasificacion-check-all,.sku-check-all'
  ).forEach(ch => ch.checked = false);

  ['dd-origen', 'dd-canal', 'dd-master', 'dd-clasificacion', 'dd-sku'].forEach(rootId => {
    const root = document.getElementById(rootId);
    const label = root?.querySelector('.multi-label');
    const btn = root?.querySelector('button.btn-select-like');
    if (label) label.textContent = '(Todos)';
    if (btn) btn.classList.remove('has-selection');
  });

  expanded.clear();
  state.sort.column = null;
  state.sort.direction = null;

  document.querySelectorAll('#tbl-data thead th[data-sort]').forEach(h => {
    h.textContent = h.textContent.replace(/\s*[▲▼]$/, '');
  });

  state.page = 1;
  await cargarTodo();
});
  }

  document.addEventListener('click', async (e) => {
    const btnToggle = e.target.closest('[data-toggle]');
    if (btnToggle) {
      e.preventDefault();
      toggleRow(btnToggle.dataset.toggle);
      return;
    }

    const linkPed = e.target.closest('.ped-link');
    if (linkPed) {
      e.preventDefault();

      try {
        const panelId = String(linkPed.dataset.panelId || '').trim();
        const anio = Number(linkPed.dataset.anio);
        const trimestre = String(linkPed.dataset.trimestre || '').trim() || null;
        const mes = trimestre ? null : Number(linkPed.dataset.mes);
        const sku = String(linkPed.dataset.sku || '').trim();
        const origen = String(linkPed.dataset.origen || 'TODOS').trim();
        const cliente = (linkPed.dataset.cliente || '').trim() || null;
        const canal = (linkPed.dataset.canal || '').trim() || null;
        const vendedorRaw = (linkPed.dataset.vendedor || '').trim();

        const vendedorId = (() => {
          const s = String(vendedorRaw || "").trim();
          if (!s || s === "0") return null;
          const n = Number(s);
          return Number.isFinite(n) && n > 0 ? n : null;
        })();

        await openPedidosInline(panelId, {
          anio,
          mes,
          trimestre,
          sku,
          origen,
          cliente,
          canal,
          vendedorId
        });
      } catch (err) {
        console.error(err);
        alert("Error al traer pedidos detalle");
      }
    }
  });

  [
    document.getElementById('btn-xlsx'),
    document.getElementById('btn-xlsx-top'),
    document.getElementById('btn-xlsx-body')
  ].filter(Boolean).forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      exportToExcel();
    });
  });

  [
    document.getElementById('btn-csv'),
    document.getElementById('btn-csv-top'),
    document.getElementById('btn-csv-body')
  ].filter(Boolean).forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const rows = buildExportRows({ onlyPage: false });
      exportToCsvExcel(buildExportFilename(), rows);
    });
  });

  initSorting();
  cargarTodo();
})();
</script>

    <script>
(() => {
  const BTN_OPEN = document.getElementById('btn-sp');
  const modalEl = document.getElementById('modal-sp');
  if (!BTN_OPEN || !modalEl) return;

  if (!window.bootstrap?.Modal) { console.error("Bootstrap Modal no está disponible."); return; }

  const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
  const SP_ENDPOINT = "/Comercial/ReporteVentasPresupuestoSPDetalle";

  const $anio = document.getElementById('sp-anio');
  const $ddMeses = document.getElementById('dd-sp-meses');
  const $mesSearch = document.getElementById('sp-meses-search');
  const $mesApply = document.getElementById('sp-meses-apply');
  const $mesClear = document.getElementById('sp-meses-clear');
  const $ven = document.getElementById('sp-vendedores');
  const $cli = document.getElementById('sp-clientes');
  const $pmDev = document.getElementById('pm-kpi-dev');
  const $run = document.getElementById('sp-run');
  const $clear = document.getElementById('sp-clear');
  const $status = document.getElementById('sp-status');
  const $tbody = document.querySelector('#sp-table tbody');
  const $call = document.getElementById('sp-call');

  const nfInt = new Intl.NumberFormat(undefined, { maximumFractionDigits: 0 });
  const num = (n) => nfInt.format(Math.round(Number(n || 0)));

  function getToken(){ const el=document.querySelector('input[name="__RequestVerificationToken"]'); return el?el.value:""; }
  function tokens(text){ return Array.from(new Set(String(text||'').toUpperCase().split(/[\s,;]+/g).map(x=>x.trim()).filter(Boolean))); }
  function getMesChecks(){ return Array.from(document.querySelectorAll('.multi-check-sp-mes')); }
  function selectedMeses(){ return getMesChecks().filter(c=>c.checked).map(c=>Number(c.value)); }

  function refreshMesLabel(){
    const label=$ddMeses?.querySelector('.multi-label'); if(!label)return;
    const sel=getMesChecks().filter(c=>c.checked).map(c=>c.dataset.text||c.value);
    if(!sel.length)label.textContent='(Todos)';
    else if(sel.length<=3)label.textContent=sel.join(', ');
    else label.textContent=`${sel.length} seleccionados`;
  }

  function preselectCurrentMonth(){ const m=String(new Date().getMonth()+1); getMesChecks().forEach(c=>c.checked=(c.value===m)); refreshMesLabel(); }
  function clearMeses(){ getMesChecks().forEach(c=>c.checked=false); refreshMesLabel(); }

  function initMesSearch(){
    if(!$mesSearch)return;
    $mesSearch.value="";
    $mesSearch.oninput=()=>{ const q=($mesSearch.value||'').trim().toUpperCase(); document.querySelectorAll('#dd-sp-meses .sp-meses-item').forEach(li=>{ const txt=(li.textContent||'').toUpperCase(); li.style.display=txt.includes(q)?'':'none'; }); };
  }

  $mesClear?.addEventListener('click',(e)=>{ e.preventDefault(); clearMeses(); });
  $mesApply?.addEventListener('click',(e)=>{ e.preventDefault(); refreshMesLabel(); const btn=$ddMeses?.querySelector('button[data-bs-toggle="dropdown"]'); if(btn)bootstrap.Dropdown.getOrCreateInstance(btn).hide(); });

  function setStatus(msg){ if($status)$status.textContent=msg||""; }
  function resetTable(msg="Sin datos."){
    if($tbody)$tbody.innerHTML=`<tr><td colspan="8" class="text-muted text-center">${msg}</td></tr>`;
    const $spKpis=document.getElementById("sp-kpis"); if($spKpis)$spKpis.style.display="none";
  }

  function fillYears(){
    const now=new Date(); const y0=now.getFullYear()-2; const y1=now.getFullYear()+1;
    $anio.innerHTML="";
    for(let y=y0;y<=y1;y++){ const opt=document.createElement('option'); opt.value=y; opt.textContent=y; if(y===now.getFullYear())opt.selected=true; $anio.appendChild(opt); }
  }

  function getCumpClass(v){ const n=Number(v); if(!isFinite(n))return""; if(n>=80)return"sp-cump-ok"; if(n>=60)return"sp-cump-warn"; return"sp-cump-bad"; }
  function getBarClass(v){ const n=Number(v); if(!isFinite(n))return"sp-bar-bad"; if(n>=80)return"sp-bar-ok"; if(n>=60)return"sp-bar-warn"; return"sp-bar-bad"; }

  function renderRows(rows){
    const $spKpis=document.getElementById("sp-kpis");
    const $spKpiVenta=document.getElementById("sp-kpi-venta"); const $spKpiPresupuesto=document.getElementById("sp-kpi-presupuesto");
    const $spKpiCump=document.getElementById("sp-kpi-cump"); const $spKpiTend=document.getElementById("sp-kpi-tend");/*  const $spKpiRows=document.getElementById("sp-kpi-rows"); */

    if(!rows||!rows.length){ resetTable("Sin resultados."); if($spKpis)$spKpis.style.display="none"; return; }

    let totalVenta=0,totalPresupuesto=0,totalTend=0;
    const frag=document.createDocumentFragment();

    rows.forEach(r=>{
      const venta=Number(r.venta||0); const presupuesto=Number(r.presupuesto||0); const tend=Number(r.tend||0); const cump=Number(r.cump||0);
      totalVenta+=venta; totalPresupuesto+=presupuesto; totalTend+=tend;
      const cumpCalc=Number(r.cump||0); const tendCalc=presupuesto>0?(tend/presupuesto)*100:0;
      const cumpClass=getCumpClass(cumpCalc); const tendBarClass=getBarClass(tendCalc);
      const tr=document.createElement('tr');
      tr.innerHTML=`<td>${r.clienteId??""}</td><td>${r.razonSocial??""}</td><td>${r.vendedorNombre??""}</td><td>${r.mes??""}</td><td class="text-end">${num(venta)}</td><td class="text-end">${num(presupuesto)}</td><td class="text-end ${cumpClass}">${cumpCalc.toFixed(2)}%</td><td class="text-end"><div class="sp-progress"><div class="sp-progress-bar ${tendBarClass}" style="width:${Math.min(tendCalc,100)}%"></div></div><div class="sp-progress-label">${num(tend)}</div></td>`;
      frag.appendChild(tr);
    });

    $tbody.replaceChildren(frag);
    const totalCump=totalPresupuesto>0?(totalVenta/totalPresupuesto)*100:0;
    if($spKpiVenta)$spKpiVenta.textContent=num(totalVenta);
    if($spKpiPresupuesto)$spKpiPresupuesto.textContent=num(totalPresupuesto);
    if($spKpiCump){ $spKpiCump.textContent=totalCump.toFixed(2)+"%"; $spKpiCump.className="sp-kpi-value "+getCumpClass(totalCump); }
    if($spKpiTend)$spKpiTend.textContent=num(totalTend);
    // if($spKpiRows)$spKpiRows.textContent=rows.length;
    if($spKpis)$spKpis.style.display="flex";
  }

  async function runSP(){
    const Anio=Number($anio.value);
    let Meses=selectedMeses();
    if(!Meses.length){ preselectCurrentMonth(); Meses=selectedMeses(); }
    const Vendedores=tokens($ven.value); const Clientes=tokens($cli.value); const mesesCsv=Meses.join(',');
    if($call){ $call.textContent=`EXEC dbo.Reporte_Ventas_Presupuesto\n  @@Anio  = ${Anio},\n  @@Meses = '${mesesCsv}';`; }
    const payload={Anio,Meses,Vendedores,Clientes};
    const token=getToken(); if(!token){ setStatus("No se encontró __RequestVerificationToken."); resetTable("Falta token."); return; }
    setStatus("Consultando..."); $run.disabled=true; resetTable("Cargando...");
    try{
      const resp=await fetch(SP_ENDPOINT,{ method:"POST", headers:{"Content-Type":"application/json","RequestVerificationToken":token}, body:JSON.stringify(payload), cache:"no-store" });
      if(!resp.ok)throw new Error("HTTP "+resp.status);
      const rows=await resp.json(); renderRows(rows); setStatus("");
    }catch(e){ console.error(e); setStatus("Error al consultar SP"); resetTable("Error al consultar."); }
    finally{ $run.disabled=false; }
  }

 BTN_OPEN.addEventListener('click',(e)=>{
    e.preventDefault(); fillYears(); initMesSearch(); clearMeses(); preselectCurrentMonth(); refreshMesLabel();
    $ven.value=""; $cli.value=""; setStatus(""); if($call)$call.textContent=""; resetTable(); modal.show();
  });

     document.addEventListener('DOMContentLoaded', function () {
        const mapClick = (topId, bodyId) => {
            const topBtn = document.getElementById(topId);
            const bodyBtn = document.getElementById(bodyId);

            if (topBtn && bodyBtn) {
                topBtn.addEventListener('click', function () {
                    bodyBtn.click();
                });
            }
        };

        mapClick('btn-xlsx-top', 'btn-xlsx-body');
        mapClick('btn-csv-top', 'btn-csv-body');
        mapClick('btn-sp-top', 'btn-sp-body');
        mapClick('btn-limpiar-top', 'btn-limpiar-body');
    });

  document.getElementById('sp-run')?.addEventListener('click',runSP);
  $clear?.addEventListener('click',()=>{ fillYears(); initMesSearch(); clearMeses(); preselectCurrentMonth(); refreshMesLabel(); $ven.value=""; $cli.value=""; setStatus(""); if($call)$call.textContent=""; resetTable(); });
  document.addEventListener('change',(e)=>{ if(e.target&&e.target.classList&&e.target.classList.contains('multi-check-sp-mes')){ refreshMesLabel(); } });

  document.getElementById('btn-sp-body')?.addEventListener('click',()=>{ document.getElementById('btn-sp')?.click(); });
  document.getElementById('btn-limpiar-body')?.addEventListener('click',()=>{ document.getElementById('btn-limpiar')?.click(); });
  document.getElementById('btn-xlsx-body')?.addEventListener('click',()=>{ document.getElementById('btn-xlsx')?.click(); });
  document.getElementById('btn-csv-body')?.addEventListener('click',()=>{ document.getElementById('btn-csv')?.click(); });
})();
</script>
}
