 function filtrarBase() {
  const f = getFiltros();
  let res = data;

  if (f.Trimestre) {
    const mesesTri = new Set(trimestreToMes(f.Trimestre));
    res = res.filter(r => mesesTri.has(String(r._mes)));
  }

  if (f.Mes) {
    res = res.filter(r => String(r._mes) === String(f.Mes));
  }

  if (f.Anio) {
    res = res.filter(r => String(r._anio) === String(f.Anio));
  }

  if (f.Origenes.length) {
    const oris = new Set(f.Origenes.map(x => String(x).toUpperCase().trim()));
    res = res.filter(r => oris.has(String(r._origen || '').toUpperCase().trim()));
  }

  if (f.Canales.length) {
    const setCan = new Set(f.Canales.map(x => String(x).toUpperCase().trim()));
    res = res.filter(r => setCan.has(String(r._canal || '').toUpperCase().trim()));
  }

  if (f.Vendedores.length) {
    res = res.filter(r =>
      f.Vendedores.some(t => {
        const venNom = String(r._venNom || '').toUpperCase();
        const venCod = String(r._venCod || '').toUpperCase();
        return venNom.includes(t) || venCod.includes(t);
      })
    );
  }

  if (f.Clientes.length) {
    res = res.filter(r =>
      f.Clientes.some(t => {
        const cliCod = String(r._cliCod || '').toUpperCase().trim();
        const cliNom = String(r._cliNom || '').toUpperCase().trim();
        return cliCod.includes(t) || cliNom.includes(t);
      })
    );
  }

if (f.Masters.length) {
  const setM = new Set(f.Masters.map(x => String(x).toUpperCase().trim()));
  res = res.filter(r => {
    const m = String(r._master ?? '').toUpperCase().trim();
    return m !== '' && setM.has(m);
  });
}

  if (f.Clasificaciones.length) {
    const setC = new Set(f.Clasificaciones.map(x => String(x).trim()));
    res = res.filter(r => setC.has(String(r._clasificacionId ?? '').trim()));
  }

  if (f.Skus.length) {
    const setS = new Set(f.Skus.map(x => String(x).toUpperCase().trim()));
    res = res.filter(r => setS.has(String(r._sku || '').toUpperCase().trim()));
  }

  return res;
}

  function diasDelMes(anio, mes) {
    const y = Number(anio), m = Number(mes);
    return new Date(y, m, 0).getDate();
  }

  function diasTranscurridosVentaNoHoy(anio, mes) {
    const hoy = new Date();
    const y = Number(anio), m = Number(mes);

    if (hoy.getFullYear() === y && (hoy.getMonth() + 1) === m) {
      return Math.max(0, hoy.getDate() - 1);
    }

    if (y < hoy.getFullYear() || (y === hoy.getFullYear() && m < (hoy.getMonth() + 1))) {
      return diasDelMes(y, m);
    }

    return 0;
  }

  function calcTendVenta(anio, mes, ventaTotal) {
    const totalMes = diasDelMes(anio, mes);
    const trans = diasTranscurridosVentaNoHoy(anio, mes);
    const venta = Math.round(Number(ventaTotal || 0));
    return (trans > 0) ? Math.round((venta / trans) * totalMes) : 0;
  }

  function isHolidayMX(d) {
    const y = d.getFullYear(), m = d.getMonth(), day = d.getDate();
    if (m === 0 && day === 1) return true;
    if (m === 4 && day === 1) return true;
    if (m === 8 && day === 16) return true;
    if (m === 11 && day === 25) return true;

    function sameYMD(a, b) {
      return a.getFullYear() === b.getFullYear() && a.getMonth() === b.getMonth() && a.getDate() === b.getDate();
    }

    function nthMondayOfMonth(year, month0, n) {
      const d = new Date(year, month0, 1);
      while (d.getDay() !== 1) d.setDate(d.getDate() + 1);
      d.setDate(d.getDate() + (n - 1) * 7);
      return d;
    }

    if (sameYMD(d, nthMondayOfMonth(y, 1, 1))) return true;
    if (sameYMD(d, nthMondayOfMonth(y, 2, 3))) return true;
    if (sameYMD(d, nthMondayOfMonth(y, 10, 3))) return true;

    return false;
  }

  function contarDiasRango(inicio, finIncl, { sinDom = false, sinSab = false, sinFeriadosMX = false } = {}) {
    let c = 0;
    const d = new Date(inicio.getFullYear(), inicio.getMonth(), inicio.getDate());
    const end = new Date(finIncl.getFullYear(), finIncl.getMonth(), finIncl.getDate());

    while (d <= end) {
      const dow = d.getDay();
      const excl =
        (sinDom && dow === 0) ||
        (sinSab && dow === 6) ||
        (sinFeriadosMX && isHolidayMX(d));

      if (!excl) c++;
      d.setDate(d.getDate() + 1);
    }

    return c;
  }

  function diasProdMes(anio, mes) {
    const y = Number(anio), m = Number(mes);
    return contarDiasRango(new Date(y, m - 1, 1), new Date(y, m, 0), {
      sinDom: true,
      sinSab: true,
      sinFeriadosMX: true
    });
  }

  function diasProdTransIncluyeHoy(anio, mes) {
    const hoy = new Date();
    const y = Number(anio), m = Number(mes);

    if (hoy.getFullYear() === y && (hoy.getMonth() + 1) === m) {
      const inicio = new Date(y, m - 1, 1);
      const finHoy = new Date(hoy.getFullYear(), hoy.getMonth(), hoy.getDate());
      if (finHoy < inicio) return 0;
      return contarDiasRango(inicio, finHoy, {
        sinDom: true,
        sinSab: true,
        sinFeriadosMX: true
      });
    }

    if (y < hoy.getFullYear() || (y === hoy.getFullYear() && m < (hoy.getMonth() + 1))) {
      return diasProdMes(y, m);
    }

    return 0;
  }

  function calcTendProd(anio, mes, producidoTotal) {
    const totalMes = diasProdMes(anio, mes);
    const trans = diasProdTransIncluyeHoy(anio, mes);
    const prod = Math.round(Number(producidoTotal || 0));
    return (trans > 0) ? Math.round((prod / trans) * totalMes) : 0;
  }

  function buildGrouped(rows) {
    const f = getFiltros();
    const usandoTrimestre = !!f.Trimestre;
    const map = new Map();

    for (const r of rows) {
      const periodoTexto = usandoTrimestre ? `QTR ${f.Trimestre}` : (r._mes || r.mesConsulta || "");
      const key = usandoTrimestre
        ? [r._anio || '', 'T' + f.Trimestre, r._sku || ''].join('|')
        : [r._anio || '', r._mes || '', r._sku || ''].join('|');

      if (!map.has(key)) {
        map.set(key, {
          _key: key,
          anio: r._anio || "",
          mes: periodoTexto,
          _mesNum: r._mes || "",
          _trimestre: usandoTrimestre ? String(f.Trimestre) : "",
          sku: r._sku || r.productoCodigo || "",
          producto: r._prod || r.productoNombre || "",
          _planProd: 0,
          _producido: 0,
          _tendProd: 0,
          _ventaReal: 0,
          _devoluciones: 0,
          _pres: 0,
          _kg: 0,
          _kgSurtido: 0,
          _tendencia: 0,
          _invIni: 0,
          _invAct: 0,
          _tendInv: 0,
          _variacion: 0,
          _rows: []
        });
      }

      const g = map.get(key);
      const pp = pickNumber(r, 'planProduccion', 'PlanProduccion', 'plan_prod', 'planProd', '_planProd');
      const pr = pickNumber(r, 'producido', 'Producido', 'producidoReal', 'prod_real', 'prodReal', '_producido');

      g._planProd      = Math.max(g._planProd, toNumber(pp));
      g._producido     = Math.max(g._producido, toNumber(pr));
      g._pres         += toNumber(r._pres);
      g._kg           += toNumber(r._kg);
      g._kgSurtido    += toNumber(r._kgSurtido);
      g._ventaReal    += toNumber(r._ventaReal);
      // no sumar aquí, porque viene consolidada por sku/mes
      g._invIni        = Math.max(g._invIni, toNumber(r._invIni));
      g._invAct        = Math.max(g._invAct, toNumber(r._invAct));
      g._rows.push(r);
    }

    const out = Array.from(map.values());

    out.forEach(g => {
      // g._disp = g._pres - g._kg - g._kgSurtido;

     if (usandoTrimestre) {
  g._tendencia = g._ventaReal;
  g._tendProd = g._producido;
} else {
  g._tendencia = calcTendVenta(g.anio, g._mesNum, g._ventaReal);
  g._tendProd  = calcTendProd(g.anio, g._mesNum, g._producido);
}

      g._tendInv   = toNumber(g._invIni) + toNumber(g._tendProd) - toNumber(g._tendencia);
      g._variacion = toNumber(g._tendInv) - toNumber(g._invIni);
      g._alc       = (g._pres > 0) ? (g._tendencia / g._pres) * 100 : 0;
      g._alcProd   = (g._planProd > 0) ? (g._tendProd / g._planProd) * 100 : 0;
      const devKey = `${g.anio}|${g._mesNum}|${g.sku}`;
      g._devoluciones = toNumber(devolucionesMapGlobal.get(devKey));

      g._disp = g._pres - g._kg - g._kgSurtido + g._devoluciones;
    });

    return out;
  }

  function ordenarDatos() {
    const col = state.sort.column;
    const dir = state.sort.direction;
    if (!col || !dir) return;

    const keyMap = {
      sku: 'sku',
      producto: 'producto',
      planprod: '_planProd',
      producido: '_producido',
      tendprod: '_tendProd',
      ventareal: '_ventaReal',
      devoluciones: '_devoluciones',
      alcprod: '_alcProd',
      presupuesto: '_pres',
      kg: '_kg',
      kgsurtido: '_kgSurtido',
      tendencia: '_tendencia',
      alcance: '_alc',
      invini: '_invIni',
      invact: '_invAct',
      tendinv: '_tendInv',
      variacion: '_variacion'
    };

    const key = keyMap[col];
    if (!key) return;

    view.sort((a, b) => {
      let x = a[key], y = b[key];

      if (typeof x === 'number' && typeof y === 'number') {
        return dir === 'asc' ? x - y : y - x;
      }

      x = String(x ?? '').toUpperCase();
      y = String(y ?? '').toUpperCase();
      return dir === 'asc' ? x.localeCompare(y) : y.localeCompare(x);
    });
  }

  function buildExportRows({ onlyPage = false } = {}) {
    const base = filtrarBase();
    const groupedRows = buildGrouped(base);
    view = groupedRows.slice();
    ordenarDatos();

    let rowsToExport = view;
    if (onlyPage) {
      const start = (state.page - 1) * state.pageSize;
      const end = Math.min(start + state.pageSize, view.length);
      rowsToExport = view.slice(start, end);
    }

    return rowsToExport.map((g, i) => ({
      "#": onlyPage ? ((state.page - 1) * state.pageSize + i + 1) : (i + 1),
      "SKU": g.sku,
      "Producto": g.producto,
      "Plan Producción": Math.round(g._planProd || 0),
      "Producido": Math.round(g._producido || 0),
      "Tend. Producción": Math.round(g._tendProd || 0),
      "Alc. Prod %": (isFinite(Number(g._alcProd)) ? Number(g._alcProd).toFixed(2) : ""),
      "Plan Venta": Math.round(g._pres || 0),
      "Surtido": Math.round(g._kgSurtido || 0),
      "Venta Real": Math.round(g._ventaReal || 0),
      "Devoluciones": Math.round(g._devoluciones || 0),
      "Tend. Venta": Math.round(g._tendencia || 0),
      "Pedidos": Math.round(g._kg || 0),
      "Alcance %": (isFinite(Number(g._alc)) ? Number(g._alc).toFixed(2) : ""),
      "Inv. Ini": Math.round(g._invIni || 0),
      "Inv. Act": Math.round(g._invAct || 0),
      "Tend. Inv": Math.round(g._tendInv || 0),
      "Variación": Math.round(g._variacion || 0)
    }));
  }

  function buildExportDetalleRows({ onlyPage = false } = {}) {
    const base = filtrarBase();
    const groupedRows = buildGrouped(base);
    view = groupedRows.slice();
    ordenarDatos();

    let groupsToExport = view;
    if (onlyPage) {
      const start = (state.page - 1) * state.pageSize;
      const end = Math.min(start + state.pageSize, view.length);
      groupsToExport = view.slice(start, end);
    }

    const out = [];

    for (const g of groupsToExport) {
      const det = buildDetalleGeneric(g._rows || [], g.anio, g._mesNum || g.mes);

      if (!det.length) {
        out.push({
          Anio: g.anio,
          Mes: g.mes,
          SKU: g.sku,
          Producto: g.producto,
          Origen: "",
          Detalle: "",
          "Plan Venta": 0,
          Surtido: 0,
          Disponible: 0,
          "Tend. Venta": 0,
          Pedidos: 0,
          "Alcance %": ""
        });
        continue;
      }

      for (const d of det) {
        out.push({
          Anio: g.anio,
          Mes: g.mes,
          SKU: g.sku,
          Producto: g.producto,
          Origen: d.origen,
          Detalle: d.label,
          "Plan Venta": Math.round(d.plan || 0),
          Surtido: Math.round(d.surt || 0),
          Disponible: Math.round(d.disp || 0),
          "Tend. Venta": Math.round(d.tend || 0),
          Pedidos: Math.round(d.ped || 0),
          "Alcance %": (isFinite(Number(d.alc)) ? Number(d.alc).toFixed(2) : "")
        });
      }
    }

    return out;
  }

  function exportToExcel() {
    if (!window.XLSX) {
      alert("Falta cargar la librería XLSX (SheetJS).");
      return;
    }

    const resumenRows = buildExportRows({ onlyPage: false });
    if (!resumenRows.length) {
      alert("No hay datos para exportar");
      return;
    }

    const detalleRows = buildExportDetalleRows({ onlyPage: false });

    const wb = XLSX.utils.book_new();
    const ws1 = XLSX.utils.json_to_sheet(resumenRows);
    XLSX.utils.book_append_sheet(wb, ws1, "Resumen");

    const ws2 = XLSX.utils.json_to_sheet(detalleRows);
    XLSX.utils.book_append_sheet(wb, ws2, "Detalle");

    XLSX.writeFile(wb, "PresupuestosMes.xlsx");
  }

  function exportToCsvExcel(filename, rows) {
    if (!rows || !rows.length) return;

    const headers = Object.keys(rows[0]);
    const lines = [];
    lines.push(headers.map(csvEscape).join(","));

    for (const r of rows) {
      lines.push(headers.map(h => csvEscape(r[h])).join(","));
    }

    const csv = "\uFEFF" + lines.join("\r\n");
    const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
    const url = URL.createObjectURL(blob);

    const a = document.createElement("a");
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    a.remove();

    setTimeout(() => URL.revokeObjectURL(url), 3000);
  }

  function buildExportFilename() {
    const f = getFiltros();
    const parts = ["PresupuestosMes"];
    if (f.Anio) parts.push("A" + f.Anio);
    if (f.Mes) parts.push("M" + f.Mes);
    if (f.Canales?.length) parts.push("Canal");
    if (f.Masters?.length) parts.push("Master");
    return parts.join("_") + ".csv";
  }

  async function fetchPedidosDetalle({ anio, mes, trimestre, sku, origen, cliente, canal, vendedorId }) {
    const qs = new URLSearchParams();
    qs.set("anio", anio);
    qs.set("sku", sku);
    qs.set("origen", origen || "TODOS");

    if (trimestre) qs.set("trimestre", trimestre);
    else if (mes) qs.set("mes", mes);

    if (cliente) qs.set("cliente", cliente);
    if (canal) qs.set("canal", canal);
    if (vendedorId != null) qs.set("vendedorId", vendedorId);

    const resp = await fetch(`${ENDPOINT_PEDDET}?${qs.toString()}`, { cache: "no-store" });
    if (!resp.ok) throw new Error("HTTP " + resp.status);
    return await resp.json();
  }

  function toggleRow(key) {
    const wasOpen = expanded.has(key);

    if ($scrollBox) {
      pendingRestore = {
        top: $scrollBox.scrollTop,
        left: $scrollBox.scrollLeft,
        key,
        open: !wasOpen
      };
    }

    if (wasOpen) expanded.delete(key);
    else expanded.add(key);

    scheduleRender(0);
  }

  function getVendedorLabel(row) {
    const cod = String(row._venCod ?? row.vendedorCodigo ?? row.VendedorCodigo ?? '').trim();
    const nom = String(row._venNom ?? row.vendedorNombre ?? row.VendedorNombre ?? '').trim();
    const lbl = [cod, nom].filter(Boolean).join(' - ');
    return lbl || '(Sin vendedor)';
  }

  function buildDetalleGeneric(rows, anio, mes) {
  const map = new Map();
  const esTrimestre = String(mes || '').toUpperCase().includes('QTR');

  function getOri(r) {
    return String(r._origen ?? r.origen ?? '').toUpperCase().trim();
  }

  function getKeyAndMeta(r) {
    const ori = getOri(r);

    if (ori === "VENDEDOR") {
      const label = getVendedorLabel(r);
      return {
        key: `VENDEDOR|${label}`,
        meta: { origen: "VENDEDOR", label, vendedorId: r._venId ?? null, canal: null, cliente: null }
      };
    }

    if (ori === "CEDIS") {
      const canal = String(r._canal ?? r.canal ?? "").toUpperCase().trim();
      const label = canal || "CEDIS";
      return {
        key: `CEDIS|${label}`,
        meta: { origen: "CEDIS", label, vendedorId: null, canal: canal || null, cliente: null }
      };
    }

    const cli = String(r._cliCod ?? r.clienteCodigo ?? "").toUpperCase().trim();
    const nom = String(r._cliNom ?? r.nombreCliente ?? "").trim();
    const label = cli ? `${cli} - ${nom}` : (nom || "-");

    return {
      key: `CLIENTE|${label}`,
      meta: { origen: "CLIENTE", label, vendedorId: null, canal: null, cliente: cli || null }
    };
  }

  for (const r of rows) {
    const { key, meta } = getKeyAndMeta(r);

    if (!map.has(key)) {
      map.set(key, {
        origen: meta.origen,
        label: meta.label,
        vendedorId: meta.vendedorId,
        canal: meta.canal,
        cliente: meta.cliente,
        plan: 0,
        surt: 0,
        disp: 0,
        ventaReal: 0,
        devoluciones: 0,
        ped: 0,
        tend: 0,
        alc: 0
      });
    }

    const d = map.get(key);

    if (d.vendedorId == null && meta.vendedorId != null) d.vendedorId = meta.vendedorId;
    if (!d.canal && meta.canal) d.canal = meta.canal;
    if (!d.cliente && meta.cliente) d.cliente = meta.cliente;

    d.plan += toNumber(r._pres);
    d.surt += toNumber(r._kgSurtido);
    
    d.ventaReal += toNumber(r._ventaReal);
  
    d.ped += toNumber(r._kg);

    const devKeyDet = (() => {
  const skuDet = String(r._sku || '').toUpperCase().trim();
  const anioDet = String(anio ?? '').trim();
  const mesDet  = String(mes  ?? '').trim();
  const ori = getOri(r);

  if (ori === 'VENDEDOR') {
    const venId = String(r._venId ?? '').trim();
    return venId ? `VENDEDOR|${anioDet}|${mesDet}|${skuDet}|${venId}` : null;
  }
  if (ori === 'CEDIS') {
    const canalDet = String(r._canal ?? '').toUpperCase().trim();
    return canalDet ? `CEDIS|${anioDet}|${mesDet}|${skuDet}|${canalDet}` : null;
  }
  // CLIENTE
  const cliDet = String(r._cliCod ?? '').toUpperCase().trim();
  return cliDet ? `CLIENTE|${anioDet}|${mesDet}|${skuDet}|${cliDet}` : null;
})();

            d.devoluciones += devKeyDet
            ? toNumber(devolucionesMapGlobal?.get(devKeyDet))
            : 0;

   d.tend = esTrimestre
  ? d.ventaReal
  : calcTendVenta(anio, mes, d.ventaReal);
  }

            const out = Array.from(map.values());

            out.forEach(d => {
            d.disp = d.plan - d.ped - d.surt + d.devoluciones;
            d.alc = d.plan > 0 ? (d.tend / d.plan) * 100 : 0;
            });
  out.sort((a, b) => b.plan - a.plan);
  return out;
}

  function fmtFecha(v) {
    if (!v) return "";
    const d = new Date(v);
    if (isNaN(d)) return String(v).slice(0, 10);
    return d.toLocaleDateString();
  }

