    color: #f9fafb !important;
    border-color: rgba(203,213,225,.28) !important;
}

body[data-theme="dark"] .table-responsive-sticky,
body[data-theme="dark"] .table-responsive-sticky table,
body[data-theme="dark"] .table,
body[data-theme="dark"] .sapmm-grid,
body[data-theme="dark"] .table tbody td,
