<!-- MODAL ORDEN DE VENTA (editable para pendientes) -->
<div class="modal fade" id="ovModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content" style="border-radius:12px;">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-receipt"></i> Orden de Venta
                    <small class="text-muted ms-2" id="ovSubtitulo">—</small>
                    <span class="ms-2" id="ovDoneBadge" style="display:none;">
                        <span class="ov-done-badge"><i class="bi bi-check2-circle"></i> COMPLETADO</span>
                    </span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            <div class="modal-body">
                <!-- Datos generales -->
                <div class="row g-3 mb-2">
                    <div class="col-md-3"><label class="form-label">Consecutivo</label><input id="ovConsecutivo" class="form-control" disabled></div>
                    <div class="col-md-3"><label class="form-label">Serie</label><input id="ovSerie" class="form-control" disabled></div>
                    <div class="col-md-3"><label class="form-label">Fecha Entrega</label><input id="ovFechaEntrega" class="form-control" disabled></div>
                    <div class="col-md-3"><label class="form-label">Fecha Creación</label><input id="ovFechaRegistro" class="form-control" disabled></div>
                </div>

                <!-- Cliente y condiciones -->
                <div class="row g-3 mb-2">
                    <div class="col-md-6"><label class="form-label">Cliente</label><input id="ovCliente" class="form-control" disabled></div>
                    <div class="col-md-6"><label class="form-label">Vendedor</label><input id="ovVendedor" class="form-control" disabled></div>
                    <div class="col-md-4"><label class="form-label">Dirección</label><input id="ovDireccion" class="form-control" disabled></div>
                    <div class="col-md-4"><label class="form-label">Presentación</label><input id="ovPresentacion" class="form-control" disabled></div>
                    <div class="col-md-4"><label class="form-label">Crédito</label><input id="ovCredito" class="form-control" disabled></div>
                    <div class="col-12"><label class="form-label">Observación</label><textarea id="ovObservacion" class="form-control" rows="2" disabled></textarea></div>
                    <div class="col-md-3"><label class="form-label">Saldo</label><input id="ovSaldo" class="form-control" disabled></div>
                    <div class="col-md-3"><label class="form-label">Otros Pedidos</label><input id="ovOtrosPedidos" class="form-control" disabled></div>
                </div>

                <!-- Logística -->
                <div class="row g-3 mb-2">
                    <div class="col-12">
                        <div class="panel-head" style="border-radius:8px;">Logística</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Fecha de embarque</label>
                        <input type="date" id="ovFechaEmbarque" class="form-control">
                        <small class="text-muted">No puede ser menor a la fecha de entrega.</small>
                    </div>

                    <div class="col-md-6 d-none" aria-hidden="true">
                        <label asp-for="SelectedAlmacenId" class="form-label">Almacén a surtir</label>
                        <select asp-for="SelectedAlmacenId" 
                                asp-items="Model.Almacenes" 
                                class="form-select" 
                                id="ovAlmacen">
                            <option value="">Selecciona…</option>
                        </select>
                        <span asp-validation-for="SelectedAlmacenId" class="text-danger"></span>
                    </div>
                </div>

                <!-- Productos -->
                <div class="d-flex justify-content-between align-items-center mt-3 mb-2">
                    <div class="panel-head" style="border-radius:8px; margin:0;">Productos</div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-success" id="btnGuardarProductos"><i class="bi bi-save2"></i> Guardar cambios</button>
                    </div>
                </div>

                <div id="rowAgregar" class="add-row" style="display:none;">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-2"><label class="form-label">SKU</label><input type="text" id="agSku" class="form-control" maxlength="50"></div>
                        <div class="col-md-4"><label class="form-label">Producto</label><input type="text" id="agNombre" class="form-control" maxlength="200"></div>
                        <div class="col-md-2"><label class="form-label">kg</label><input type="number" step="0.001" id="agKilos" class="form-control" min="0"></div>
                        <div class="col-md-2"><label class="form-label">Precio</label><input type="number" step="0.01" id="agPrecio" class="form-control" min="0"></div>
                        <div class="col-md-2"><label class="form-label">Cajas</label><input type="number" step="1" id="agCajas" class="form-control" min="0"></div>
                        <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                            <button class="btn btn-sm btn-secondary" id="btnCancelarAgregar">Cancelar</button>
                            <button class="btn btn-sm btn-primary" id="btnAgregarProducto"><i class="bi bi-check2"></i> Agregar</button>
                        </div>
                    </div>
                </div>

                <!-- Barra rápida -->
                <div class="d-flex flex-wrap gap-2 align-items-end mb-2" id="ovQuickBar">
                    <div style="min-width:240px;">
                        <label class="form-label">Almacén default</label>
                        <select class="form-select form-select-sm" id="ovAlmacenDefault"></select>
                    </div>

                    <div style="width:140px;">
                        <label class="form-label">Cajas default</label>
                        <input type="number" min="0" step="1" class="form-control form-control-sm" id="ovCajasDefault" value="1">
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-outline-primary" id="btnAlmTodos">Aplicar almacén a todos</button>
                        <button type="button" class="btn btn-sm btn-outline-primary" id="btnCajasTodos">Aplicar cajas a todos</button>
                    </div>

                    <div class="ms-auto small text-muted">
                        Atajos: <b>Ctrl+S</b> guardar · <b>Enter</b> siguiente renglón
                    </div>
                </div>

                <div class="table-responsive table-responsive-sticky">
                    <table class="table table-sm table-bordered align-middle sapmm-grid" id="ovProductos">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>SKU</th>
                                <th>Producto</th>
                                <th>kg</th>
                                <th>Precio</th>
                                <th>Cajas</th>
                                <th>Almacen</th>
                                <th>Importe</th>
                                <th style="width:90px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody><tr><td colspan="8" class="text-center text-muted">—</td></tr></tbody>
                        <tfoot>
                            <tr><th colspan="7" class="text-end">Total Peso:</th><th id="ovTotalPeso">0.00</th></tr>
                            <tr><th colspan="7" class="text-end">Total Importe:</th><th id="ovTotalImporte">$0.00</th></tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <a id="ovIrPantalla" class="btn btn-round primary" href="#" target="_blank"></a>
            </div>
        </div>
    </div>
</div>

