                      /* ===== Guardar cambios (AJAX) ===== */
        async function guardarCambiosProductos() {

          if (!ovState.id) {
            alert('Orden no cargada.');
            return false;
          }

          if (ovSoloLectura) {
            alert('Esta orden está completada (solo lectura).');
            return false;
          }

          // 1️⃣ Sincronizar almacenes desde el DOM al estado
          syncAlmacenesDesdeDOM();

          // 2️⃣ Validaciones (SOLO VALIDAN, NO MODIFICAN)
          if (!validarAlmacenesPorLinea()) return false;
          if (!validarCajasMayoresCero()) return false;

          // 3️⃣ Validar máximos (SI APLICA TU REGLA DE NEGOCIO)
          for (const p of ovState.productos) {
            if (p.eliminado) continue;

            const cap = lineMaxFor(p);
            const cajas = Number(p.cajas ?? 0);

            if (cajas > cap) {
              alert(
                `El producto ${p.productoCodigo} excede el máximo permitido (${cap} cajas).`
              );
              return false;
            }
          }

          const consecutivoVal =
            (document.getElementById('ovConsecutivo')?.value || '').trim();

          if (!consecutivoVal) {
            alert('Esta orden no tiene consecutivo aún.');
            return false;
          }

          const fechaEmbarqueVal =
            document.getElementById('ovFechaEmbarque')?.value || '';

          if (!fechaEmbarqueVal) {
            alert('Selecciona la Fecha de embarque.');
            return false;
          }

          const min =
            document.getElementById('ovFechaEmbarque')?.min;

          if (min && fechaEmbarqueVal < min) {
            alert('La fecha de embarque no puede ser menor a la fecha de entrega.');
            return false;
          }

          const almacenVal =
            (document.getElementById('ovAlmacen')?.value || '').trim();

          // 4️⃣ CONSTRUIR PAYLOAD (VALORES REALES DEL USUARIO)
          const payloadProductos = ovState.productos.map(p => ({
            productoCodigo: p.productoCodigo ?? p.sku ?? '',
            productoNombre: p.productoNombre ?? p.producto ?? '',
            sku: p.productoCodigo ?? p.sku ?? '',
            producto: p.productoNombre ?? p.producto ?? '',
            kilosCaja: Number(p.kilosCaja ?? p.peso ?? 0),
            precio: Number(p.precio ?? 0),
            cajas: Number(p.cajas ?? 0),      // 🔥 EXACTAMENTE LO CAPTURADO
            eliminado: !!p.eliminado,
            almacen: (p.almacen || '').toString().trim()
          }));

          // 🔎 Debug opcional (recomendado mientras pruebas)
          console.log('ANTES DE GUARDAR', payloadProductos);

          const payload = {
            ordenId: ovState.id,
            fechaEmbarque: new Date(fechaEmbarqueVal).toISOString(),
            almacenSurtir: almacenVal,
            productos: payloadProductos
          };

          const token =
            document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')
              ?.value || null;

          try {
            const res = await fetch('/Comercial/GestionarPedido', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                ...(token ? { 'RequestVerificationToken': token } : {})
              },
              body: JSON.stringify(payload)
            });

            const text = await res.text();

            if (!res.ok) {
              console.error('❌ Error HTTP', res.status, text);
              alert(text || 'No se pudieron guardar los cambios.');
              return false;
            }

            alert('¡Pedido gestionado y guardado!');

            // 5️⃣ Marcar como completado en UI
            const idx = pedidosCache.findIndex(x =>
              (x.id ?? x.Id) === ovState.id
            );
            if (idx > -1) pedidosCache[idx].estatus = 4;

            ovSoloLectura = true;
            bloquearOVLectura();
            draftBorrar(consecutivoVal);
            renderPedidos();
            setActualizadoAhora();

            // 6️⃣ Flujo rápido → abrir Subpedidos
            if (flujoRapidoActivo && ovState.id) {
              pvState.id = ovState.id;
              pvState.ov = pvState.ov || { consecutivo: consecutivoVal };
              await abrirSubpedidosPorOrden(ovState.id);
            }

            return true;

          } catch (e) {
            console.error(e);
            alert('No se pudieron guardar los cambios.');
            return false;
          }
        }



