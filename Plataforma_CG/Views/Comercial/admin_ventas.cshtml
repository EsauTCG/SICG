        let almacenesInvCargados = false;
        let almacenesInvData = [];              // [{value, text}]
        let almacenesInvSelected = new Set();   // values seleccionados
        let _almInvLastQuery = '';              // guarda lo escrito en el buscador

               function _debounceLite(fn, ms = 200) {
          let t;
          return function (...args) {
            const ctx = this;               // ✅ conserva this (input)
            clearTimeout(t);
            t = setTimeout(() => fn.apply(ctx, args), ms);
          };
        }


        // ✅ Obtiene los almacenes seleccionados (values)
        function getAlmacenesSeleccionadosInv() {
          return [...almacenesInvSelected];
        }

 

   
        // ==============================
        // ✅ BUSCADOR ALMACENES: match normal + "Resultados similares" (fuzzy)
        // ==============================

        // Normaliza: minúsculas, sin acentos, espacios limpios
        function _normTxt(s) {
          return (s ?? '')
            .toString()
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '')
            .replace(/\s+/g, ' ')
            .trim()
            .toLowerCase();
        }

        // Match "estricto" por tokens (AND): todas las palabras deben aparecer
        function _matchTokens(haystack, query) {
          const h = _normTxt(haystack);
          const q = _normTxt(query);
          if (!q) return true;
          const tokens = q.split(' ').filter(Boolean);
          return tokens.every(t => h.includes(t));
        }

        // Levenshtein (2 filas) para fuzzy
        function _levenshtein(a, b) {
          a = _normTxt(a);
          b = _normTxt(b);
          const n = a.length, m = b.length;
          if (n === 0) return m;
          if (m === 0) return n;

          let prev = new Array(m + 1);
          let cur  = new Array(m + 1);

          for (let j = 0; j <= m; j++) prev[j] = j;

          for (let i = 1; i <= n; i++) {
            cur[0] = i;
            const ca = a.charCodeAt(i - 1);
            for (let j = 1; j <= m; j++) {
              const cb = b.charCodeAt(j - 1);
              const cost = (ca === cb) ? 0 : 1;
              cur[j] = Math.min(
                prev[j] + 1,
                cur[j - 1] + 1,
                prev[j - 1] + cost
              );
            }
            const tmp = prev; prev = cur; cur = tmp;
          }
          return prev[m];
        }

        function _similarity(a, b) {
          a = _normTxt(a);
          b = _normTxt(b);
          const maxLen = Math.max(a.length, b.length, 1);
          const dist = _levenshtein(a, b);
          return 1 - (dist / maxLen); // 0..1
        }

        // Score fuzzy: mejor similitud contra string completo y contra palabras
        function _fuzzyScore(haystack, query) {
          const h = _normTxt(haystack);
          const q = _normTxt(query);
          if (!q) return 0;

          let best = _similarity(h, q);

          // intenta por token del haystack
          const parts = h.split(' ').filter(Boolean);
          for (const p of parts) best = Math.max(best, _similarity(p, q));

          // boost si contiene como substring
          if (h.includes(q)) best = Math.max(best, 0.92);

          // si query trae varias palabras, promedia la mejor coincidencia de cada token
          const qTokens = q.split(' ').filter(Boolean);
          if (qTokens.length > 1) {
            let sum = 0;
            for (const t of qTokens) {
              let bt = _similarity(h, t);
              for (const p of parts) bt = Math.max(bt, _similarity(p, t));
              if (h.includes(t)) bt = Math.max(bt, 0.92);
              sum += bt;
            }
            best = Math.max(best, sum / qTokens.length);
          }

          return best;
        }

        function renderAlmacenesInvDropdown(filterText = '') {
          const cont = document.getElementById('lstAlmInv');
          if (!cont) return;

          const q = (filterText || '').trim();
          const qNorm = _normTxt(q);

          // 1) filtro normal
          let list = !qNorm
            ? almacenesInvData
            : almacenesInvData.filter(x => _matchTokens(`${x.text} ${x.value}`, qNorm));

          let header = '';

          // 2) si NO hubo resultados => fuzzy + encabezado "Resultados similares"
          if (qNorm && list.length === 0) {
            const MIN_SCORE = 0.45; // sube a 0.55 si lo quieres más estricto
            const MAX_SHOW  = 25;

            const ranked = almacenesInvData
              .map(x => {
                const hay = `${x.text} ${x.value}`;
                return { x, score: _fuzzyScore(hay, qNorm) };
              })
              .filter(r => r.score >= MIN_SCORE)
              .sort((a, b) => b.score - a.score)
              .slice(0, MAX_SHOW)
              .map(r => r.x);

            if (ranked.length) {
              list = ranked;
              header = `<div class="text-muted small px-2 pt-2">Resultados similares</div>`;
            }
          }

          // 3) pintar
          if (!list.length) {
            cont.innerHTML = `<div class="text-muted small p-2">Sin resultados.</div>`;
            return;
          }

          cont.innerHTML = header + list.map(x => {
            const v = String(x.value);
            const checked = almacenesInvSelected.has(v) ? 'checked' : '';
            return `
              <label class="alm-multi-item">
                <input type="checkbox" class="form-check-input alm-inv-chk" value="${v}" ${checked}>
                <span>${x.text}</span>
              </label>
            `;
          }).join('');
        }



        // ✅ Inicializa listeners (búsqueda + checkboxes)
        function initAlmacenesInvDropdown() {
          const cont = document.getElementById('lstAlmInv');
          if (!cont) return;

          // 1) Checks (delegación dentro del contenedor)
          cont.addEventListener('change', (e) => {
            const chk = e.target?.classList?.contains('alm-inv-chk') ? e.target : null;
            if (!chk) return;

            const val = String(chk.value);
            if (chk.checked) almacenesInvSelected.add(val);
            else almacenesInvSelected.delete(val);
          });

          // 2) Buscador (id si existe, si no: buscarlo cerca del contenedor)
          //    - Primero intenta por id
                  let txt = document.getElementById('txtAlmInvSearch');

          //    - Fallback: busca el input dentro del mismo dropdown/menu
          if (!txt) {
            const root = cont.closest('.dropdown-menu') || cont.parentElement || document;
            // intenta encontrar el input del buscador (ajusta selectores si lo necesitas)
            txt = root.querySelector('input[type="search"], input[type="text"], input.form-control');
          }

          if (txt) {
            const onSearch = _debounceLite(() => renderAlmacenesInvDropdown(txt.value), 200);
            txt.addEventListener('input', onSearch);

            // opcional: al abrir/volver a pintar, conservar lo tecleado
            if (_almInvLastQuery && txt.value !== _almInvLastQuery) txt.value = _almInvLastQuery;
          } else {
            console.warn('[AlmacenesInv] No se encontró el input del buscador (txtBuscarAlmInv ni fallback).');
          }
        }

        // ✅ EXPONER A WINDOW
        window.getAlmacenesSeleccionadosInv = getAlmacenesSeleccionadosInv;
        window.renderAlmacenesInvDropdown = renderAlmacenesInvDropdown;
        window.initAlmacenesInvDropdown = initAlmacenesInvDropdown;






