                    function buildPreviewAlmacenSelectHtml(value){
              const sel = document.getElementById('ovAlmacen');
              const opts = sel ? [...sel.options] : [];
              const v = (value || '').toString().trim().toUpperCase();
            
              let html = `<select class="form-select form-select-sm pv-almacen">`;
            
              opts.forEach(o => {
                const val = (o.value || '').toString().trim();
                const isSel = val.toUpperCase() === v ? 'selected' : '';
                html += `<option value="${val}" ${isSel}>${o.textContent}</option>`;
              });
            
              html += `</select>`;
              return html;
            }



                //======================================
                // CREACIÓN DE PDF (incluye columna "Almacén" y resumen por almacén)
                //======================================
                async function generarPDFPreview(){
                  if (!pvState.ov){ alert('No hay datos para exportar.'); return; }
                  const ov = pvState.ov;
                  const { jsPDF } = window.jspdf;
                  const doc = new jsPDF({ unit:'pt', format:'a4' });

                  const M = 36, W = doc.internal.pageSize.getWidth();
                  const BRAND = [139,0,0],
                        INK   = [33,37,41],
                        MUTED = [108,117,125],
                        LINE  = [225,231,235],
                        BAND  = [246,248,251],
                        STRIPE= [251,253,255];

                  // Encabezado
                  doc.setTextColor(...INK);
                  doc.setFillColor(...BAND); doc.rect(0, 0, W, 96, 'F');
                  try{
                    const imgEl = document.getElementById('pdfLogo');
                    if (imgEl && imgEl.complete && imgEl.naturalWidth>0){
                      const maxH = 46, ratio = imgEl.naturalWidth / imgEl.naturalHeight;
                      const wLogo = Math.min(160, maxH*ratio), hLogo = wLogo / ratio;
                      doc.addImage(imgEl, 'PNG', M, 22, wLogo, hLogo);
                    }
                  }catch(e){}
                  doc.setFont('helvetica','bold'); doc.setFontSize(22);
                  doc.text('ORDEN DE SURTIDO', W/2, 50, { align:'center' });

                  const cons = ov.consecutivo || '-';
                  doc.setFont('helvetica','bold'); doc.setFontSize(11);
                  const chipTxt = ` ${cons} `;
                  const chipW = doc.getTextWidth(chipTxt) + 18, chipH = 22;
                  const chipX = W - M - chipW, chipY = 18;
                  doc.setDrawColor(...BRAND); doc.setFillColor(255,255,255);
                  doc.roundedRect(chipX, chipY, chipW, chipH, 8, 8, 'FD');
                  doc.setTextColor(...BRAND); doc.text(chipTxt, chipX + 9, chipY + 15);
                  doc.setTextColor(...INK);
                  doc.setDrawColor(...LINE); doc.line(M, 96, W - M, 96);

                  let y = 112;

                  // Pequeña utilidad para cards
                  function cardAuto(x, y, w, items){
                    const pad = 10; let h = pad;
                    items.forEach(it=>{
                      doc.setFont('helvetica','normal'); doc.setFontSize(11);
                      const txt = doc.splitTextToSize(String(it.value ?? '-'), w - pad*2);
                      const lineH = doc.getLineHeight() * doc.internal.getLineHeightFactor();
                      const valueH = (Array.isArray(txt) ? txt.length : 1) * lineH;
                      h += 12 + 12 + valueH + 8;
                    });
                    h += pad;
                    doc.setDrawColor(...LINE); doc.setFillColor(255,255,255);
                    doc.roundedRect(x, y, w, h, 8, 8, 'S');
                    let yy = y + pad;
                    items.forEach(it=>{
                      doc.setFont('helvetica','bold'); doc.setFontSize(10); doc.setTextColor(...MUTED);
                      doc.text(it.label, x + pad, yy + 10);
                      doc.setFont('helvetica','normal'); doc.setFontSize(11); doc.setTextColor(...INK);
                      const txt = doc.splitTextToSize(String(it.value ?? '-'), w - pad*2);
                      const lineH = doc.getLineHeight() * doc.internal.getLineHeightFactor();
                      const valueStart = yy + 22;
                      doc.text(txt, x + pad, valueStart);
                      const valueH = (Array.isArray(txt) ? txt.length : 1) * lineH;
                      yy = valueStart + valueH + 8;
                    });
                    doc.setTextColor(...INK);
                    return h;
                  }

                  // Cards superiores
                  const GAP = 12, cols = 3;
                  const cardW = (W - 2*M - (cols-1)*GAP)/cols;
                  const clienteNombrePDF = (typeof getClienteNombre === 'function'
                                            ? (getClienteNombre(ov) || ov.clienteNombre)
                                            : (ov.clienteNombre)) || '-';
                  const h1 = cardAuto(M, y, cardW, [{ label: 'Cliente', value: clienteNombrePDF }]);
                  const h2 = cardAuto(M + cardW + GAP, y, cardW, [{ label: 'Dirección', value: ov.direccion || 'Fiscal' }]);
                  const h3 = cardAuto(M + (cardW + GAP)*2, y, cardW, [{ label: 'Fecha creación', value: ov.fechaRegistro ? new Date(ov.fechaRegistro).toLocaleString('es-MX') : '-' }]);
                  y += Math.max(h1, h2, h3) + GAP;

                  const cardW2 = (W - 2*M - GAP)/2;
                  const h4 = cardAuto(M, y, cardW2, [{ label: 'Vendedor', value: ov.vendedor || '-' }, { label: 'Entrega', value: ov.fechaEntrega ? new Date(ov.fechaEntrega).toLocaleDateString('es-MX') : '-' }]);
                  const h5 = cardAuto(M + cardW2 + GAP, y, cardW2, [{ label: 'Almacén', value: ov.almacenSurtir || '-' }]);
                  y += Math.max(h4, h5) + 14;

                  // 👉 Cabecera con 8 columnas (incluye "Almacén")
                  const head=[['#','SKU','Producto','Peso/Caja (kg)','Precio','Cajas','Importe','Almacén']];
                  const body=[];
                  let tImp=0,tPeso=0;

                  (ov.productos||[]).forEach((r,i)=>{
                    const sku=r.productoCodigo??r.ProductoCodigo??r.sku??r.SKU??'';
                    const nombre=r.productoNombre??r.ProductoNombre??r.producto??r.Producto??'';
                    const kilosCaja=Number(r.kilosCaja??r.KilosCaja??r.peso??r.Peso??0)||0;
                    const precio=Number(r.precio??r.Precio??0)||0;
                    const cajas=Math.max(0, Math.floor(Number(r.cajas??r.Cajas??0)||0));
                    // 👉 toma el almacén por línea; si no viene, usa el global
                    const almacen = (r.almacen ?? r.Almacen ?? ov.almacenSurtir ?? '—');

            const kilosTot = kilosCaja;   // ✅ kilos/caja * número de cajas
            const importe  = precio * kilosTot;   // ✅ importe por renglón
            tImp  += importe;
            tPeso += kilosTot;

            body.push([
              (i+1).toString(),
              sku,
              nombre,
              kilosCaja.toLocaleString('es-MX',{minimumFractionDigits:2,maximumFractionDigits:2}),
              precio.toLocaleString('es-MX',{style:'currency',currency:'MXN'}),
              cajas.toLocaleString('es-MX',{minimumFractionDigits:0,maximumFractionDigits:0}),
              importe.toLocaleString('es-MX',{style:'currency',currency:'MXN'}),
              (almacen || '—')
            ]);
                  });

                  doc.autoTable({
                    startY:y, head, body, theme:'grid', tableWidth: W-2*M, margin:{left:M,right:M},
                    styles:{font:'helvetica',fontSize:9,cellPadding:6,lineColor:LINE,lineWidth:.5,valign:'middle',overflow:'linebreak'},
                    headStyles:{fillColor:BRAND,textColor:255,fontStyle:'bold',halign:'center'},
                    alternateRowStyles:{fillColor:STRIPE},
                    // 👉 ancho para 8 columnas
                    columnStyles:{
                      0:{halign:'center',cellWidth:22},
                      1:{halign:'left',  cellWidth:62},
                      2:{halign:'left',  cellWidth:170},
                      3:{halign:'right', cellWidth:64},
                      4:{halign:'right', cellWidth:64},
                      5:{halign:'right', cellWidth:48},
                      6:{halign:'right', cellWidth:73},
                      7:{halign:'left',  cellWidth:55}
                    },
                    didDrawPage:()=>{
                      const pageW=doc.internal.pageSize.getWidth(), pageH=doc.internal.pageSize.getHeight();
                      doc.setDrawColor(...LINE); doc.line(M, pageH-40, pageW-M, pageH-40);
                      doc.setFontSize(9); doc.setTextColor(...MUTED);
                      doc.text('Sistema SIGO — '+new Date().toLocaleString('es-MX'), M, pageH-22);
                      doc.text(`Página ${doc.internal.getNumberOfPages()}`, pageW-M, pageH-22, {align:'right'});
                    }
                  });

                  let after = doc.lastAutoTable.finalY || y;

                  // Resumen general
                  const bandH=56, bandY=after+14;
                  doc.setFillColor(245,251,245); doc.setDrawColor(200,231,200);
                  doc.roundedRect(M, bandY, W-2*M, bandH, 8, 8, 'FD');
                  doc.setFont('helvetica','bold'); doc.setFontSize(12); doc.setTextColor(22,77,44);
                  doc.text('Resumen', M+12, bandY+20);
                  doc.setFont('helvetica','normal'); doc.setFontSize(11); doc.setTextColor(...INK);
                  doc.text(`Total Peso (kg): ${(tPeso).toLocaleString('es-MX',{minimumFractionDigits:2,maximumFractionDigits:2})}`, W-M-280, bandY+40);
                  doc.text(`Total Importe: ${(tImp).toLocaleString('es-MX',{style:'currency',currency:'MXN'})}`, W-M-280, bandY+20);


                  // 👉 Resumen por almacén
                  const resumen = {};
                  (ov.productos||[]).forEach(r=>{
                    const alm = (r.almacen ?? r.Almacen ?? '—').toString() || '—';
                    const kCaja = Number(r.kilosCaja ?? r.KilosCaja ?? r.peso ?? r.Peso ?? 0) || 0;
                    const cjs = Math.max(0, Math.floor(Number(r.cajas ?? r.Cajas ?? 0) || 0));
                    const kg  = Number(r.kilosCaja ?? r.KilosCaja ?? r.peso ?? r.Peso ?? 0) || 0; // ✅ usar total directo
                    const imp = (Number(r.precio ?? r.Precio ?? 0) || 0) * kg;                    // ✅ $/kg * kg totales
                    if(!resumen[alm]) resumen[alm] = {kg:0, imp:0};
                    resumen[alm].kg += kg; resumen[alm].imp += imp;
                  });

                  let ySum = bandY + bandH + 16;
                  const rows = Object.entries(resumen).map(([alm, v])=>[
                    alm,
                    v.kg.toLocaleString('es-MX',{minimumFractionDigits:2,maximumFractionDigits:2}),
                    v.imp.toLocaleString('es-MX',{style:'currency',currency:'MXN'})
                  ]);

                  if (rows.length){
                    doc.autoTable({
                      startY: ySum,
                      head: [['Almacén','Kg totales','Importe']],
                      body: rows,
                      theme:'grid',
                      margin:{left:M,right:M},
                      styles:{font:'helvetica',fontSize:9,cellPadding:5},
                      headStyles:{fontStyle:'bold'}
                    });
                    ySum = doc.lastAutoTable.finalY || ySum;
                  }

                  const signY = (doc.lastAutoTable?.finalY || ySum) + 30;
                  doc.setDrawColor(...LINE);
                  doc.line(M+20, signY, M+220, signY);
                  doc.line(W/2 + 20, signY, W/2 + 220, signY);
                  doc.setFontSize(10); doc.setTextColor(...MUTED);
                  doc.text('Autorizó', M+20, signY + 14);
                  doc.text('Recibió CEDIS', W/2 + 20, signY + 14);

                  const fname = `OV_${(ov.consecutivo||'SIN_CONSECUTIVO').replace(/\s+/g,'_')}.pdf`;
                  doc.save(fname);
                }

