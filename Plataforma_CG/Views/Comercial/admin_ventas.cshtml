                }

                // === Utilidades para dividir SKU por almacenes (tope base + 5 cajas, compartido por grupo)
                function _gid(){ return Math.random().toString(36).slice(2,9); }

                function groupSumCajas(groupId){
                  return (ovState.productos || [])
                    .filter(p => p.groupId === groupId && !p.eliminado)
                    .reduce((s,p) => s + Math.max(0, Math.floor(Number(p.cajas ?? 0) || 0)), 0);
                }

                function groupCapTotal(groupId){
                  const any = (ovState.productos || []).find(p => p.groupId === groupId);
                  if(!any) return 0;
                  const base = Math.max(0, Math.floor(Number(any.baseMaxCajas ?? any.maxCajas ?? any.cajas ?? 0) || 0));
                  return base + 30; // +30 cajas extra por SKU (compartidas por todas las divisiones)
                }

                function lineMaxFor(r){
                  const gId = r.groupId;
                  if(!gId) return Math.max(0, Math.floor(Number(r.maxCajas ?? r.cajas ?? 0) || 0)) + 30; // fallback
                  const tot = groupCapTotal(gId);
                  const sum = groupSumCajas(gId);
                  const mi  = Math.max(0, Math.floor(Number(r.cajas ?? 0) || 0));
                  return Math.max(0, tot - (sum - mi));
                }

                // Crea una división del renglón para otro almacén (cajas=0, comparte tope del grupo)
