@section Scripts {
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- jsPDF + autoTable para PDF -->
    <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jspdf-autotable@3.8.2/dist/jspdf.plugin.autotable.min.js"></script>


    <script>


                // 🧹 Siempre limpiar borradores en cada carga
                    localStorage.removeItem('ovDraftsByConsecutivo');


                /* ===== Configuración/Utils ===== */
                const DIAS_AVISO = 2;
                function startOfDay(d){ const x=new Date(d); x.setHours(0,0,0,0); return x; }
                function daysDiff(a,b){ const MS=86400000; return Math.floor((startOfDay(a)-startOfDay(b))/MS); }
                function formatDateOnly(val){ if(!val) return ''; const s=String(val); const m=s.match(/^(\d{4}-\d{2}-\d{2})/); if(m){const [y,mo,d]=m[1].split('-'); return `${d}/${mo}/${y}`;} const d=new Date(s); return d.toLocaleDateString('es-MX'); }
                function formatDateTime(val){ if(!val) return ''; const d=new Date(val); return d.toLocaleString('es-MX'); }
                const mxn=n=>(Number(n||0)).toLocaleString('es-MX',{style:'currency',currency:'MXN'});
                const num=n=>(Number(n||0)).toLocaleString('es-MX',{minimumFractionDigits:2,maximumFractionDigits:2});
                const intn = n => (Math.floor(Number(n || 0))).toLocaleString('es-MX', { maximumFractionDigits: 0 });
                const toISODate = d => { if(!d) return ''; const x=new Date(d); const y=x.getFullYear(); const m=String(x.getMonth()+1).padStart(2,'0'); const day=String(x.getDate()).padStart(2,'0'); return `${y}-${m}-${day}`; };

           function addDays(date, days){
          const d = new Date(date);
          d.setDate(d.getDate() + days);
          return d;
        }

                function setRangoEntregaDefault(){
                  const $d = $('#fEntregaD');
                  const $h = $('#fEntregaH');
                  if(!$d.length || !$h.length) return;

                  const hoy = new Date();
                  const anteayer = new Date();
                  anteayer.setDate(hoy.getDate() - 2);

                  $d.val(toISODate(anteayer)); // hoy - 2
                  $h.val(toISODate(hoy));      // hoy
                }

                /* ===== Helpers de Cliente ===== */
                function getClienteNombre(obj){
                  return (
                    obj?.clienteNombre ?? obj?.ClienteNombre ??
                    obj?.nombreCliente ?? obj?.NombreCliente ??
                    obj?.razonSocial   ?? obj?.RazonSocial   ??
                    obj?.clienteNombreFiscal ?? obj?.ClienteNombreFiscal ?? ''
                  ).toString().trim();
                }
                function getClienteId(obj){
                  return (obj?.clienteId ?? obj?.ClienteId ?? obj?.cliente ?? obj?.Cliente ?? '').toString().trim();
                }
                function getClienteTextoBusqueda(obj){
                  const id = getClienteId(obj);
                  const nombre = getClienteNombre(obj);
                  return `${nombre} ${id}`.toLowerCase();
                }

                function normalizarAlmacenValue(inputVal) {
          const sel = document.getElementById('ovAlmacen');
          const opts = sel ? [...sel.options] : [];

          const raw = (inputVal ?? '').toString().trim();
          if (!raw) return '';

          const up = raw.toUpperCase();

          // 1) Match por VALUE
          const byVal = opts.find(o => (o.value || '').toString().trim().toUpperCase() === up);
          if (byVal) return byVal.value;

          // 2) Match por TEXTO visible
          const byTxt = opts.find(o => (o.textContent || '').toString().trim().toUpperCase() === up);
          if (byTxt) return byTxt.value;

          return ''; // no se pudo normalizar
        }


        function buildPreviewAlmacenSelectHtml(value){
  const sel = document.getElementById('ovAlmacen');
  const opts = sel ? [...sel.options] : [];
  const v = (value || '').toString().trim().toUpperCase();

  let html = `<select class="form-select form-select-sm pv-almacen">`;

  opts.forEach(o => {
    const val = (o.value || '').toString().trim();
    const isSel = val.toUpperCase() === v ? 'selected' : '';
    html += `<option value="${val}" ${isSel}>${o.textContent}</option>`;
  });

  html += `</select>`;
  return html;
}

                /* ===== Helper para <select> de Almacén por renglón (usa las opciones del select global) ===== */
                       function buildAlmacenSelectHtml(value, disabled){
                  const sel = document.getElementById('ovAlmacen');
                  const opts = sel ? [...sel.options] : [];
                  const v = (value||'').toString().toUpperCase();

                  let html = `<select class="form-select form-select-sm sel-almacen mb-1" ${disabled?'disabled':''}>`;

                  // ⛔ ya NO agregamos opción "—"
                  opts.forEach(o=>{
                    const val = (o.value||'').toString();
                    const isSel = val.toUpperCase() === v ? 'selected' : '';
                    html += `<option value="${val}" ${isSel}>${o.textContent}</option>`;
                  });

                  html += `</select>`;
                  return html;
                }

                          /* ===== Estado ===== */
                    let pedidosCache = [];
                    let ovState = { id:null, productos:[] };
                    let ovSoloLectura = false;

                    // 🔥 Modo “flujo rápido” (pendiente -> guardar -> subpedidos)
                    let flujoRapidoActivo = false;

                const _loadClosed = () => { try { return new Set(JSON.parse(localStorage.getItem('ovClosedByConsecutivo') || '[]')); } catch { return new Set(); } };
                let ovClosedByConsecutivo = _loadClosed();
                function persistirCerrados(){ localStorage.setItem('ovClosedByConsecutivo', JSON.stringify([...ovClosedByConsecutivo])); }

                let vistaActual = localStorage.getItem('vistaOV') || 'pendientes';

                        /* =========================================================
                   VISTAS: Pendientes / Completados / DemandaDetalle
                   Requiere:
                   - panel pedidos con id="panelPedidos"
                   - panel demanda detalle con id="panelDemandaDetalle" y tbody #demDetBody
                ========================================================= */

                function getPanelPedidos(){
                  // Preferente: #panelPedidos
                  const $p = $('#panelPedidos');
                  if ($p.length) return $p;

                  // Fallback si aún no pones el id (no recomendado)
                  const $fallback = $('.panel:has(#pedidosBody)').first();
                  return $fallback;
                }

                function switchVista(v){
                  vistaActual = v;
                  localStorage.setItem('vistaOV', vistaActual);

                  // Tabs active
                  $('#tabPendientes,#tabCompletados,#tabDemandaDetalle,#tabTransferencias,#tabInforme').removeClass('active');
                  if (v === 'pendientes') $('#tabPendientes').addClass('active');
                  else if (v === 'completados') $('#tabCompletados').addClass('active');
                  else if (v === 'demandaDetalle') $('#tabDemandaDetalle').addClass('active');

                  // Panels
                  const $panelPedidos = getPanelPedidos();
                  $panelPedidos.toggle(v === 'pendientes' || v === 'completados');

                  // Si usas también “Demanda vs Inventario”, lo dejamos apagado al entrar a detalle
                  $('#panelDemandaInv').hide();
                  $('#panelDemandaDetalle').toggle(v === 'demandaDetalle');

                  // Acciones por vista
                  if (v === 'pendientes' || v === 'completados'){
                    cargarPedidos();
                  } else if (v === 'demandaDetalle'){
                    cargarDemandaDetalle();
                  }
                }


                function setActualizadoAhora(){ document.getElementById('lblActualizado').textContent = 'Actualizado: ' + new Date().toLocaleTimeString('es-MX'); }
                function isCompletado(p){ return Number(p?.estatus ?? p?.Estatus ?? 0) === 4; }

                function contarCriticos(list){
                  const hoy = new Date();
                  let urgentes = 0;
                  for (const p of list){
                    if (isCompletado(p)) continue;
                    const fe = p.fechaEntrega ?? p.FechaEntrega;
                    if (!fe) continue;
                    const diff = daysDiff(new Date(fe), hoy);
                    if (diff < 0 || diff <= DIAS_AVISO) urgentes++;
                  }
                  return urgentes;
                }

                function setConteo(n){
                  const urg = contarCriticos(pedidosCache);
                  const chip = document.getElementById('chipConteo');
                  chip.innerHTML = `<i class="bi bi-list-ol"></i> ${n} pedido${n===1?'':'s'} ${urg>0?`<span class="badge bg-danger ms-2">${urg} urgentes</span>`:''}`;
                }

                function debounce(fn,ms=250){ let t; return (...a)=>{ clearTimeout(t); t=setTimeout(()=>fn(...a), ms); }; }

                function bloquearOVLectura(){
                    const badge = document.getElementById('ovDoneBadge'); if (badge) badge.style.display = '';
                    const fe = document.getElementById('ovFechaEmbarque'); const alm = document.getElementById('ovAlmacen');
                    if (fe) fe.disabled = true; if (alm) alm.disabled = true;
                    const btnMostrar = document.getElementById('btnMostrarAgregar'); const btnGuardar = document.getElementById('btnGuardarProductos'); const rowAgregar = document.getElementById('rowAgregar');
                    if (btnMostrar) btnMostrar.setAttribute('disabled','disabled');
                    if (btnGuardar){ btnGuardar.setAttribute('disabled','disabled'); btnGuardar.style.display='none'; }
                    if (rowAgregar) rowAgregar.style.display='none';
                    const tbody = document.querySelector('#ovProductos tbody');
                    if (tbody) { [...tbody.querySelectorAll('button.btn-outline-danger')].forEach(b=>{ b.disabled=true; b.style.display='none'; }); }
                }

                        function desbloquearOVLectura(){
                    const badge = document.getElementById('ovDoneBadge');
                    if (badge) badge.style.display = 'none';

                    const fe = document.getElementById('ovFechaEmbarque');
                    const alm = document.getElementById('ovAlmacen');
                    if (fe) fe.disabled = false;
                    if (alm) alm.disabled = false;

                    const btnMostrar = document.getElementById('btnMostrarAgregar');
                    const btnGuardar = document.getElementById('btnGuardarProductos');
                    const rowAgregar = document.getElementById('rowAgregar');

                    if (btnMostrar) btnMostrar.removeAttribute('disabled');
                    if (btnGuardar){
                        btnGuardar.removeAttribute('disabled');
                        btnGuardar.style.display = '';
                    }
                    if (rowAgregar) rowAgregar.style.display = 'none';

                    const tbody = document.querySelector('#ovProductos tbody');
                    if (tbody) {
                        [...tbody.querySelectorAll('button')].forEach(b=>{
                            b.disabled = false;
                            b.style.display = '';
                        });
                    }
                }


                /* ======== Borradores por consecutivo ======== */
                const LS_DRAFTS_KEY = 'ovDraftsByConsecutivo';
                function _loadDraftMap(){ try{ return new Map(Object.entries(JSON.parse(localStorage.getItem(LS_DRAFTS_KEY)||'{}'))); } catch{ return new Map(); } }
                function _saveDraftMap(map){ const obj = Object.fromEntries(map); localStorage.setItem(LS_DRAFTS_KEY, JSON.stringify(obj)); }
                let _drafts = _loadDraftMap();

                function getConsecutivoActual(){ return (document.getElementById('ovConsecutivo')?.value || '').toString().trim(); }
                function draftGuardar(cons, productos){ if(!cons) return; _drafts.set(cons, productos); _saveDraftMap(_drafts); }
                function draftObtener(cons){ if(!cons) return null; const v = _drafts.get(cons); return Array.isArray(v) ? JSON.parse(JSON.stringify(v)) : null; }
                function draftBorrar(cons){ if(!cons) return; _drafts.delete(cons); _saveDraftMap(_drafts); }

                /* ===== Filtros ===== */
                function getFiltros(){
                    return {
                        q: (document.getElementById('txtBuscar').value||'').trim().toLowerCase(),
                        consecutivo: (document.getElementById('fConsecutivo').value||'').trim().toLowerCase(),
                        cliente: (document.getElementById('fCliente').value||'').trim().toLowerCase(),
                        vendedor: (document.getElementById('fVendedor').value||'').trim().toLowerCase(),
                        entregaD: (document.getElementById('fEntregaD').value||'').trim(),
                        entregaH: (document.getElementById('fEntregaH').value||'').trim()
                    };
                }
                function pasaFiltros(p, f){
                    const cons = String(p.ordenDeVenta ?? p.OrdenDeVenta ?? '').toLowerCase();
                    const clienteTexto = getClienteTextoBusqueda(p);
                    const vendedor = String(p.vendedor ?? p.Vendedor ?? '').toLowerCase();
                    const obs = String(p.observacion ?? p.Observacion ?? '').toLowerCase();

                    if (f.q){
                        const hay = cons.includes(f.q) || clienteTexto.includes(f.q) || vendedor.includes(f.q) || obs.includes(f.q);
                        if(!hay) return false;
                    }
                    if (f.consecutivo && !cons.includes(f.consecutivo)) return false;
                    if (f.cliente && !clienteTexto.includes(f.cliente)) return false;
                    if (f.vendedor && !vendedor.includes(f.vendedor)) return false;

                    const fe = p.fechaEntrega ?? p.FechaEntrega;
                    if (f.entregaD){
                        const dmin = new Date(f.entregaD + 'T00:00:00');
                        if (!fe || startOfDay(new Date(fe)) < dmin) return false;
                    }
                    if (f.entregaH){
                        const dmax = new Date(f.entregaH + 'T00:00:00');
                        if (!fe || startOfDay(new Date(fe)) > dmax) return false;
                    }
                    return true;
                }

