/* ============================================================
   UX EJECUTIVO - PEDIDOS LIBERADOS / ALMACÉN
   Objetivo: mejorar lectura y operación SIN tocar lógica.
   Se conservan IDs, botones, tablas, modales y scripts existentes.
============================================================ */

:root {
    --pl-bg: #f3f4f6;
    --pl-surface: #ffffff;
    --pl-surface-soft: #f9fafb;
    --pl-ink: #111827;
    --pl-muted: #6b7280;
    --pl-border: #e5e7eb;
    --pl-brand: #8B0000;
    --pl-brand-dark: #450a0a;
    --pl-brand-mid: #7f1d1d;
    --pl-brand-soft: #fff1f2;
    --pl-blue-soft: #eff6ff;
    --pl-blue-border: #bfdbfe;
    --pl-blue-ink: #1e3a8a;
    --pl-warn-soft: #fffbeb;
    --pl-warn-border: #fde68a;
    --pl-warn-ink: #92400e;
    --pl-ok-soft: #ecfdf5;
    --pl-ok-border: #bbf7d0;
    --pl-ok-ink: #166534;
    --pl-radius-lg: 18px;
    --pl-radius-md: 14px;
    --pl-radius-sm: 10px;
    --pl-shadow: 0 18px 44px rgba(17, 24, 39, .10);
    --pl-shadow-sm: 0 10px 24px rgba(17, 24, 39, .08);
}

html,
body,
main,
.main,
.body-content,
.container,
.container-fluid {
    background: var(--pl-bg) !important;
    color: var(--pl-ink) !important;
}

body {
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif !important;
}

.window {
    width: min(100%, calc(100vw - 28px)) !important;
    max-width: 1920px !important;
    margin: 10px auto 18px !important;
    border: 0 !important;
    background: transparent !important;
    box-shadow: none !important;
}

.content-pad {
    background: transparent !important;
    padding: 0 !important;
}

.content-pad > .content-pad {
    margin-top: 12px !important;
}

.sap-page-header {
    position: relative;
    overflow: hidden;
    border: 0 !important;
    border-radius: var(--pl-radius-lg) !important;
    padding: 20px 22px !important;
    margin-bottom: 14px !important;
    background:
        radial-gradient(circle at top right, rgba(255,255,255,.20), transparent 30%),
        linear-gradient(135deg, #991b1b 0%, #7f1d1d 46%, #450a0a 100%) !important;
    box-shadow: var(--pl-shadow) !important;
    color: #ffffff !important;
}

.sap-page-header::before {
    content: "Centro operativo";
    display: inline-flex;
    align-items: center;
    position: absolute;
    left: 22px;
    top: 10px;
    color: #fecaca;
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .14em;
}

.sap-title {
    margin-top: 16px !important;
    color: #ffffff !important;
    font-size: clamp(1.35rem, 1.1vw + 1rem, 2rem) !important;
    line-height: 1.05 !important;
    gap: 10px !important;
}

.sap-title i {
    width: 42px;
    height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,.14);
    border: 1px solid rgba(255,255,255,.22);
    border-radius: 999px;
}

.sap-sub {
    color: rgba(255,255,255,.82) !important;
    font-size: 13px !important;
    margin-top: 6px !important;
}

.sap-ph-right {
    align-items: stretch !important;
    gap: 10px !important;
}

.sap-chip {
    min-height: 42px;
    border-radius: 999px !important;
    border: 1px solid rgba(255,255,255,.28) !important;
    background: rgba(255,255,255,.14) !important;
    color: #ffffff !important;
    box-shadow: none !important;
    padding: 0 15px !important;
    font-size: 12px !important;
    font-weight: 900 !important;
}

.sap-chip-danger {
    background: rgba(248,113,113,.20) !important;
    border-color: rgba(254,202,202,.45) !important;
    color: #fee2e2 !important;
}

.sap-chip-warn {
    background: rgba(245,158,11,.20) !important;
    border-color: rgba(253,230,138,.48) !important;
    color: #fef3c7 !important;
}

.sap-chip-muted {
    background: rgba(255,255,255,.12) !important;
    border-color: rgba(255,255,255,.22) !important;
    color: #e5e7eb !important;
}

.pl-workflow {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    margin: 0 0 14px 0;
}

.pl-step-card {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    background: var(--pl-surface);
    border: 1px solid var(--pl-border);
    border-radius: var(--pl-radius-md);
    padding: 13px;
    box-shadow: var(--pl-shadow-sm);
}

.pl-step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: var(--pl-brand);
    color: #ffffff;
    font-weight: 950;
}

.pl-step-title {
    display: block;
    color: var(--pl-ink);
    font-size: 13px;
    font-weight: 950;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.pl-step-help {
    display: block;
    color: var(--pl-muted);
    font-size: 11px;
    line-height: 1.15;
}

.sapmm-skin,
.sap-filterbar {
    background: var(--pl-surface) !important;
}

.sap-filterbar {
    border: 1px solid var(--pl-border) !important;
    border-radius: var(--pl-radius-lg) !important;
    padding: 16px !important;
    box-shadow: var(--pl-shadow-sm) !important;
}

.sap-filterbar-top {
    display: grid !important;
    grid-template-columns: auto minmax(320px, 1fr) auto;
    gap: 12px !important;
    align-items: center !important;
}

.segmented.sapmm-tabs,
.segmented {
    display: inline-flex !important;
    gap: 6px;
    border: 0 !important;
    border-radius: 999px !important;
    background: var(--pl-surface-soft) !important;
    padding: 5px !important;
    box-shadow: inset 0 0 0 1px var(--pl-border) !important;
}

.segmented.sapmm-tabs button,
.segmented button {
    border: 0 !important;
    border-radius: 999px !important;
    background: transparent !important;
    color: #374151 !important;
    min-height: 36px;
    padding: 0 14px !important;
    font-size: 12px !important;
    font-weight: 900 !important;
    white-space: nowrap;
}

.segmented.sapmm-tabs button.active,
.segmented button.active {
    background: linear-gradient(180deg, #b30000 0%, #8b0000 58%, #6e0000 100%) !important;
    color: #ffffff !important;
    box-shadow: 0 10px 18px rgba(139,0,0,.18) !important;
}

.sap-search {
    min-width: 0 !important;
    flex: initial !important;
    width: 100% !important;
    background: var(--pl-surface-soft);
    border: 1px solid var(--pl-border);
    border-radius: 999px;
    padding: 6px 12px;
    gap: 9px !important;
}

.sap-search i {
    color: var(--pl-brand);
    font-size: 16px;
}

.sap-search .form-control,
#txtBuscar {
    border: 0 !important;
    background: transparent !important;
    min-height: 34px !important;
    height: 34px !important;
    font-size: 14px !important;
    padding: 0 !important;
    color: var(--pl-ink) !important;
}

.sap-search .form-control:focus,
#txtBuscar:focus {
    box-shadow: none !important;
}

.sap-filterbar-base {
    margin-top: 14px !important;
    grid-template-columns: repeat(6, minmax(150px, 1fr)) !important;
    gap: 12px !important;
    align-items: end !important;
}

.sap-field label,
.form-label {
    color: #374151 !important;
    font-size: 11px !important;
    text-transform: uppercase;
    letter-spacing: .04em;
    font-weight: 950 !important;
}

.form-control,
.form-select,
.sapmm-skin .form-control,
.sapmm-skin .form-select {
    min-height: 38px !important;
    height: auto !important;
    border-radius: var(--pl-radius-sm) !important;
    border: 1px solid #d1d5db !important;
    background: #ffffff !important;
    color: var(--pl-ink) !important;
    font-size: 13px !important;
    padding: 7px 10px !important;
}

.form-control:focus,
.form-select:focus,
.sapmm-skin .form-control:focus,
.sapmm-skin .form-select:focus {
    border-color: var(--pl-brand) !important;
    box-shadow: 0 0 0 .2rem rgba(139,0,0,.12) !important;
}

.sap-filterbar-actions {
    grid-column: auto !important;
    justify-content: flex-end !important;
}

.sap-filterbar-actions .btn,
#btnLimpiarFiltros,
button[data-bs-target="#fbMore"] {
    min-height: 38px !important;
    border-radius: 999px !important;
    font-weight: 900 !important;
    padding-left: 14px !important;
    padding-right: 14px !important;
}

.sap-filterbar-more {
    margin-top: 14px !important;
    padding-top: 14px !important;
    border-top: 1px solid var(--pl-border) !important;
    background: var(--pl-surface-soft);
    border-radius: var(--pl-radius-md);
    padding: 14px !important;
}

.sap-legend {
    background: #ffffff;
    border: 1px solid var(--pl-border);
    border-radius: var(--pl-radius-md);
    padding: 10px 12px;
}

.panel {
    margin-top: 14px !important;
    border: 1px solid var(--pl-border) !important;
    border-radius: var(--pl-radius-lg) !important;
    background: var(--pl-surface) !important;
    box-shadow: var(--pl-shadow-sm) !important;
    overflow: hidden !important;
}

.panel-head {
    background: #ffffff !important;
    border-bottom: 1px solid var(--pl-border) !important;
    color: var(--pl-ink) !important;
    padding: 14px 16px !important;
    min-height: 54px;
}

.panel-head span,
.panel-head div,
.panel-head .text-muted {
    color: inherit !important;
}

.panel-head i {
    color: var(--pl-brand) !important;
}

.panel-head .text-muted,
#lblActualizado,
#lblTransActualizado {
    color: var(--pl-muted) !important;
    font-weight: 700 !important;
}

.table-wrap.table-responsive-sticky,
.table-responsive-sticky {
    border-top: 0 !important;
    background: #ffffff !important;
    max-height: 70vh !important;
}

.table-responsive-sticky table,
.table,
.sapmm-grid {
    background: #ffffff !important;
    font-size: 12px !important;
    min-width: 1180px;
}

.table-responsive-sticky thead th,
.sapmm-grid thead th,
.table thead th {
    position: sticky;
    top: 0;
    z-index: 20 !important;
    background: #7f1d1d !important;
    color: #ffffff !important;
    border-color: #7f1d1d !important;
    padding: 10px 8px !important;
    text-transform: uppercase !important;
    letter-spacing: .035em;
    font-size: 11px !important;
    font-weight: 950 !important;
}

.table tbody td,
.sapmm-grid tbody td {
    background: #ffffff !important;
    border-color: var(--pl-border) !important;
    color: #1f2937 !important;
    padding: 9px 8px !important;
    vertical-align: middle !important;
}

.table.table-striped > tbody > tr:nth-of-type(even) > *,
.sapmm-grid.table-striped > tbody > tr:nth-of-type(even) > * {
    background: #fafafa !important;
}

.table-hover tbody tr:hover > *,
.sapmm-grid.table-hover tbody tr:hover > * {
    background: #fff7ed !important;
}

.table td:nth-child(6) {
    max-width: 360px !important;
}

th.actions-col {
    width: 300px !important;
}

td.actions-cell {
    justify-content: flex-start !important;
    gap: 7px !important;
}

td.actions-cell .btn,
td.actions-cell a,
td.actions-cell button,
.btn-round {
    border-radius: 999px !important;
    min-height: 34px !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 6px !important;
    font-weight: 900 !important;
    font-size: 12px !important;
}

.btn-round.primary,
.btn-exec-red,
.btn-danger,
.btn-primary {
    background: linear-gradient(180deg, #b30000 0%, #8b0000 58%, #6e0000 100%) !important;
    border-color: #7f1d1d !important;
    color: #ffffff !important;
}

.btn-success {
    background: linear-gradient(180deg, #15803d 0%, #166534 100%) !important;
    border-color: #166534 !important;
    color: #ffffff !important;
}

.btn-outline-secondary,
.sapmm-skin .btn.btn-outline-secondary,
.btn-round {
    border: 1px solid #d1d5db !important;
    background: #ffffff !important;
    color: #374151 !important;
}

.btn-outline-secondary:hover,
.sapmm-skin .btn.btn-outline-secondary:hover,
.btn-round:hover {
    background: #f9fafb !important;
    color: #111827 !important;
}

.empty {
    padding: 28px 14px !important;
    color: var(--pl-muted) !important;
    font-weight: 800;
    background: #ffffff !important;
}

.table.table-striped tbody tr.table-danger > *,
.table.table-striped tbody tr.table-danger td.actions-cell {
    background-color: #fee2e2 !important;
    color: #7f1d1d !important;
}

.table.table-striped tbody tr.table-warning > *,
.table.table-striped tbody tr.table-warning td.actions-cell {
    background-color: #fef3c7 !important;
    color: #78350f !important;
}

.statusbar {
    width: min(100%, calc(100vw - 28px));
    max-width: 1920px;
    margin: 0 auto 12px !important;
    border: 1px solid var(--pl-border) !important;
    background: rgba(255,255,255,.92) !important;
    color: var(--pl-muted) !important;
    border-radius: var(--pl-radius-md) !important;
    padding: 10px 14px !important;
    font-size: 12px !important;
    box-shadow: var(--pl-shadow-sm) !important;
}

.modal-content {
    border: 0 !important;
    border-radius: var(--pl-radius-lg) !important;
    box-shadow: 0 24px 70px rgba(17, 24, 39, .24) !important;
    overflow: hidden !important;
}

.modal-header {
    background:
        radial-gradient(circle at top right, rgba(255,255,255,.18), transparent 30%),
        linear-gradient(135deg, #991b1b 0%, #7f1d1d 48%, #450a0a 100%) !important;
    border: 0 !important;
    padding: 16px 18px !important;
}

.modal-title {
    font-size: 15px !important;
    color: #ffffff !important;
    font-weight: 950 !important;
}

.modal-title small,
.modal-header small,
.modal-header .text-muted {
    color: rgba(255,255,255,.78) !important;
}

.modal-body {
    background: #ffffff !important;
    color: var(--pl-ink) !important;
}

.modal-footer {
    background: #f9fafb !important;
    border-top: 1px solid var(--pl-border) !important;
    padding: 12px 16px !important;
}

#ovModal .modal-dialog,
#ovPreviewModal .modal-dialog,
#subpedidosModal .modal-dialog,
#subpedidoDetalleModal .modal-dialog,
#trModal .modal-dialog {
    max-width: min(1500px, 96vw) !important;
}

#ovModal .panel-head,
#ovPreviewModal .panel-head,
#trModal .panel-head {
    border-radius: var(--pl-radius-md) !important;
    background: var(--pl-surface-soft) !important;
    color: var(--pl-ink) !important;
    border: 1px solid var(--pl-border) !important;
    min-height: 42px !important;
}

#ovQuickBar {
    background: var(--pl-blue-soft);
    border: 1px solid var(--pl-blue-border);
    border-radius: var(--pl-radius-md);
    padding: 12px !important;
    color: var(--pl-blue-ink);
}

#rowAgregar {
    background: var(--pl-warn-soft);
    border: 1px solid var(--pl-warn-border);
    border-radius: var(--pl-radius-md);
    padding: 12px;
    margin-bottom: 12px;
}

.ov-done-badge {
    border-radius: 999px !important;
    background: var(--pl-ok-soft) !important;
    color: var(--pl-ok-ink) !important;
    border: 1px solid var(--pl-ok-border) !important;
    padding: 5px 9px !important;
}

.alm-multi-menu {
    border-radius: var(--pl-radius-md) !important;
    border: 1px solid var(--pl-border) !important;
    background: #ffffff !important;
    box-shadow: var(--pl-shadow) !important;
}

.alm-multi-list {
    border-color: var(--pl-border) !important;
    border-radius: var(--pl-radius-sm) !important;
}

.alm-multi-item {
    border-radius: var(--pl-radius-sm) !important;
}

.alm-multi-item:hover {
    background: #fff7ed !important;
}

/* Estado oscuro compatible con Layout2 */
body[data-theme="dark"],
body[data-theme="dark"] html,
body[data-theme="dark"] main,
body[data-theme="dark"] .main,
body[data-theme="dark"] .body-content,
