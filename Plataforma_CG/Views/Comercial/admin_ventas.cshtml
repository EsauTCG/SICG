                       async function cargarDemandaDetalle(){
          const desde = ($('#fEntregaD').val() || '').trim();
          const hasta = ($('#fEntregaH').val() || '').trim();

          if(!desde || !hasta){
            alert('Selecciona el rango de fechas.');
            return;
          }

          getPanelPedidos().hide();
          $('#panelDemandaInv').hide();
          $('#panelDemandaDetalle').show();

          const $tbody = $('#demDetBody');
          $tbody.html(`<tr><td colspan="8" class="empty">⏳ Cargando…</td></tr>`);

          try{
            const url = `/Comercial/DemandaDetalle?desde=${encodeURIComponent(desde)}&hasta=${encodeURIComponent(hasta)}`;
            const res = await fetch(url, { cache:'no-store', headers:{'Accept':'application/json'} });
            const txt = await res.text();
            if(!res.ok){
              console.error(res.status, txt);
              alert(txt || 'Error al cargar detalle');
              return;
            }

            const data = JSON.parse(txt);

            if(!Array.isArray(data) || data.length===0){
              $tbody.html(`<tr><td colspan="8" class="empty">Sin resultados.</td></tr>`);
              return;
            }

            let html = '';
            data.forEach(r=>{
              const ruta = (r.ruta ?? r.Ruta ?? '').toString().trim();

              html += `
                <tr>
                  <td>${r.origen ?? r.Origen ?? ''}</td>
                  <td>${r.cliente ?? r.Cliente ?? ''}</td>
                  <td>${ruta}</td>
                  <td>${r.productoCodigo ?? r.ProductoCodigo ?? r.sku ?? r.SKU ?? ''}</td>
                  <td>${r.productoNombre ?? r.ProductoNombre ?? r.producto ?? r.Producto ?? ''}</td>
                          <td class="text-end">${intn(r.cajas ?? r.Cajas)}</td>
                  <td class="text-end">${num(r.kg ?? r.Kg)}</td>
                  <td>${formatDateOnly(r.fechaEmbarcar ?? r.FechaEmbarcar)}</td>
                </tr>`;
            });

            $tbody.html(html);
          }catch(e){
            console.error(e);
            $tbody.html(`<tr><td colspan="8" class="empty text-danger">Error al cargar.</td></tr>`);
          }
        }


