                  if (ovSoloLectura) return;
                  const base = ovState.productos?.[idx];
                  if (!base) return;

                  if (!base.groupId) {
                    base.groupId = _gid();
                    base.baseMaxCajas = Math.max(0, Math.floor(Number(base.maxCajas ?? base.cajas ?? 0) || 0));
                  }
                  const nuevo = {
                    ...base,
                    almacen: '',
                    cajas: 0,
                    eliminado: false,
                    groupId: base.groupId,
                    baseMaxCajas: base.baseMaxCajas,
                  };
                  ovState.productos.splice(idx + 1, 0, nuevo);
                  renderProductosTabla();

                  const cons = getConsecutivoActual();
                  if (cons) draftGuardar(cons, ovState.productos);
                }





