                        function getDefaultAlmacenValue() {
                  const qb = document.getElementById('ovAlmacenDefault');
                  const global = document.getElementById('ovAlmacen');

                  const v1 = normalizarAlmacenValue(qb?.value);
                  if (v1) return v1;

                  const v2 = normalizarAlmacenValue(global?.value);
                  if (v2) return v2;

                  return '';
                }

                function getDefaultCajasValue() {
                  const v = Number(document.getElementById('ovCajasDefault')?.value || 0);
                  return Math.max(0, Math.floor(v));
