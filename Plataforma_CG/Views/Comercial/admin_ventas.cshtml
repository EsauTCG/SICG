                        function bindTrCajasKgSync(){
          // Delegación sobre la tabla (sirve aunque re-renderices tbody)
          $(document).off('input.trsync', '#trProductos .tr-cajas');
          $(document).off('input.trsync', '#trProductos .tr-kg');

          $(document).on('input.trsync', '#trProductos .tr-cajas', function(){
            const $tr = $(this).closest('tr');
            const factor = Number($tr.data('kg-por-caja')) || 0;
            if (factor <= 0) { recalcTrTotal(); return; }

            const cajas = Math.max(0, Number(this.value || 0));
            const kg = cajas * factor;

            $tr.find('.tr-kg').val(kg.toFixed(3));
            recalcTrTotal();
          });

          $(document).on('input.trsync', '#trProductos .tr-kg', function(){
            const $tr = $(this).closest('tr');
            const factor = Number($tr.data('kg-por-caja')) || 0;
            if (factor <= 0) { recalcTrTotal(); return; }

            const kg = Math.max(0, Number(this.value || 0));
            const cajas = kg / factor;

            // Si CAJAS deben ser enteras, aquí puedes usar Math.round(cajas)
            $tr.find('.tr-cajas').val(Math.round(cajas));
            recalcTrTotal();
          });
        }

