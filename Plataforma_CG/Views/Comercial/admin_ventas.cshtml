                         ?.scrollIntoView({ behavior:'smooth', block:'center' });

                    alert('No puedes guardar: hay líneas con CAJAS = 0 ó KG = 0. Captura valores válidos antes de continuar.');
                    return false;
                  }

                  return true;
                }


