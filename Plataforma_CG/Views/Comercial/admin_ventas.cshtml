                    }

                    // Valores numéricos
                    const cajas     = Math.max(0, Math.floor(Number(p.cajas ?? 0) || 0));
                    const kilosCaja = Number(p.kilosCaja ?? p.peso ?? 0) || 0;

                    // ❌ Si hay 0 en cajas o en KG/Caja → marcar error
                    if (cajas <= 0 || kilosCaja <= 0){
