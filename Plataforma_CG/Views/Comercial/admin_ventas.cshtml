                        function aplicarAlmacen({ soloVacios = false } = {}) {
                  if (ovSoloLectura) return;

                  const alm = getDefaultAlmacenValue();
                  if (!alm) { alert('Selecciona un almacén default válido.'); return; }

                  (ovState.productos || []).forEach(p => {
                    if (p.eliminado) return;

                    const actual = normalizarAlmacenValue(p.almacen);
                    if (soloVacios && actual) return;

                    p.almacen = alm; // ✅ VALUE bueno
                  });

                  renderProductosTabla();
                }


                function aplicarCajas({ soloVacios = false } = {}) {
                  if (ovSoloLectura) return;

                  const cajas = getDefaultCajasValue();
                  if (!Number.isFinite(cajas)) return;

                  (ovState.productos || []).forEach(p => {
                    if (p.eliminado) return;

                    const actual = Math.max(0, Math.floor(Number(p.cajas ?? 0) || 0));
                    if (soloVacios && actual > 0) return;

                    // respeta el tope por grupo
                    const cap = lineMaxFor(p);
                    p.cajas = Math.min(cajas, cap);
                  });

                  renderProductosTabla();
                }

                // ✅ Autollenado: si la línea viene sin almacén, usa default/global/primera opción
                        function autoFillAlmacenSiVacio() {
                  const sel = document.getElementById('ovAlmacen');
                  const opts = sel ? [...sel.options] : [];
                  const firstValid = (opts.find(o => (o.value || '').toString().trim() !== '')?.value || '').toString().trim();

                  const def = getDefaultAlmacenValue() || firstValid || '';

                  (ovState.productos || []).forEach(p => {
                    if (p.eliminado) return;

                    const actual = normalizarAlmacenValue(p.almacen);
                    if (actual) {
                      p.almacen = actual; // ✅ lo dejamos en VALUE bueno
                      return;
                    }

                    if (!actual && def) p.almacen = def;
                  });
                }


