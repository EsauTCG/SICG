@model Plataforma_CG.ViewModels.AlmacenViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Pedidos Liberados";
}

<style>
    :root {
        --bg: #f0dede;
        --panel: #f8eeee;
        --panel-2: #f1dede;
        --line: #c79d9d;
        --line-dark: #8f4c4c;
        --text: #3b1717;
        --muted: #6a3a3a;
        --title: #ffffff;
        --white: #ffffff;
        --danger: #c00000;
        --warning: #f3b6b6;
        --ok: #f7e3e3;
        --shadow: 0 1px 0 rgba(255,255,255,.55) inset;
        --brand: #8B0000;
        --vino-1: #5c0000;
        --vino-2: #7a0000;
        --vino-3: #980000;
        --vino-4: #b30000;
        --vino-5: #d10000;
        --vino-soft: #f8e7e7;
        --vino-soft-2: #f2d9d9;
        --vino-border: #9a5a5a;
        --vino-text: #ffffff;
        --vino-text-dark: #4a1111;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0 !important;
        padding: 0 !important;
        font-family: Tahoma, Verdana, Arial, sans-serif;
        background: transparent !important;
        color: var(--text);
    }

    .container, .container-fluid {
        max-width: 100% !important;
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .window {
        width: 100%;
        max-width: 100%;
        margin: 0 !important;
        border: 1px solid #7e4a4a;
        background: var(--panel);
        box-shadow: 0 0 0 1px rgba(255,255,255,.45) inset, 0 8px 18px rgba(70,12,12,.14);
        overflow: hidden;
        padding: 0 !important;
    }

    .titlebar {
        height: 34px;
        /* display: flex; */
        display: none !important;
        align-items: center;
        justify-content: space-between;
        padding: 0 10px;
        background: linear-gradient(180deg, #c00000 0%, #8b0000 60%, #5c0000 100%);
        border-bottom: 1px solid #5c0000;
        color: #fff;
        font-size: 13px;
        font-weight: bold;
    }

        .titlebar .actions {
            display: flex;
            gap: 6px;
        }

    .win-btn {
        width: 16px;
        height: 16px;
        border: 1px solid #7c4848;
        background: linear-gradient(#fff6f6, #ead0d0);
    }

    .content-pad {
        padding: 8px;
        background: var(--bg);
    }

    .shell {
        max-width: none !important;
        margin: 0 !important;
        background: transparent !important;
        border: 0 !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        overflow: visible !important;
    }

    .sap-page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        padding: .75rem .9rem;
        border: 1px solid var(--line);
        background: linear-gradient(#fff6f6, #ecd8d8);
        flex-wrap: wrap;
        border-radius: 6px;
        margin-bottom: .75rem;
    }

    .sap-title {
        margin: 0;
        font-weight: 800;
        color: #5c1a1a;
        display: flex;
        gap: .5rem;
        align-items: center;
        font-size: 16px;
    }

    .sap-sub {
        margin-top: .2rem;
        color: var(--muted);
        font-size: 12px;
    }

    .sap-ph-right {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .sap-chip {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .35rem .6rem;
        border-radius: 3px;
        border: 1px solid #b48787;
        background: linear-gradient(#fffefe, #ecd7d7);
        color: #4a1111;
        font-weight: 700;
        box-shadow: var(--shadow);
        white-space: nowrap;
        font-size: 12px;
    }

    .sap-chip-danger {
        background: #fde2e2;
        border-color: #d9534f;
        color: #b00000;
    }

    .sap-chip-warn {
        background: #fff4cc;
        border-color: #d6b656;
        color: #7a5a00;
    }

    .sap-chip-muted {
        background: #f4f4f4;
        border-color: #ccc;
        color: #555;
    }

    .sap-filterbar {
        border: 1px solid var(--line);
        border-radius: 6px;
        background: var(--panel-2);
        box-shadow: none;
        padding: .75rem;
    }

    .sap-filterbar-top {
        display: flex;
        gap: .75rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .sap-search {
        flex: 1 1 420px;
        display: flex;
        align-items: center;
        gap: .5rem;
        min-width: 260px;
    }

    .sap-filterbar-base {
        margin-top: .75rem;
        display: grid;
        grid-template-columns: repeat(5, minmax(160px, 1fr));
        gap: .75rem;
        align-items: end;
    }

    .sap-field label,
    .form-label {
        font-size: 12px;
        color: #5c1a1a;
        margin-bottom: .2rem;
        display: block;
        font-weight: bold;
    }

    .form-control, .form-select {
        height: 28px !important;
        padding: 3px 6px !important;
        border: 1px solid #b48787 !important;
        background: #fffdfd !important;
        font-family: inherit !important;
        font-size: 12px !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        color: #421414 !important;
    }

        .form-control:focus, .form-select:focus {
            border-color: #8f4c4c !important;
            outline: none !important;
            box-shadow: none !important;
        }

    .sap-filterbar-actions {
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
        grid-column: 1 / -1;
    }

    .sap-filterbar-more {
        border-top: 1px dashed #caa0a0;
        margin-top: .75rem;
        padding-top: .75rem;
        display: flex;
        justify-content: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .segmented {
        display: inline-flex;
        border: 1px solid #caa0a0;
        border-radius: 0;
        overflow: hidden;
        background: linear-gradient(#f7e7e7, #ead1d1);
    }

        .segmented button {
            padding: .35rem .8rem;
            border: 0;
            background: transparent;
            font-weight: 700;
            font-size: 12px;
            color: #5c1a1a;
        }

            .segmented button.active {
                background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
                color: #fff;
            }

    .legend, .sap-legend {
        font-size: .85rem;
        color: var(--muted);
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        display: inline-block;
    }

        .dot.red {
            background: #f8d7da;
            border: 1px solid #f5c2c7;
        }

        .dot.yellow {
            background: #fff3cd;
            border: 1px solid #ffecb5;
        }

    .panel {
        margin-top: 1rem;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 6px;
        box-shadow: none;
    }

    .panel-head {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
        padding: .55rem .75rem;
        font-weight: 800;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        flex-wrap: wrap;
        border-radius: 0;
    }

        .panel-head i {
            color: #fff;
        }

    .table-wrap.table-responsive-sticky {
        padding: 0;
        background: #fffafa;
    }

    .table-responsive-sticky {
        max-height: 72vh;
        overflow: auto;
        position: relative;
        isolation: isolate;
        border-top: 1px solid #d9b8b8;
    }

        .table-responsive-sticky table {
            border-collapse: separate !important;
            border-spacing: 0 !important;
            width: 100%;
            font-size: 12px !important;
            background: #fffafa !important;
        }

        .table-responsive-sticky thead th {
            position: sticky;
            top: 0 !important;
            z-index: 999 !important;
            background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
            color: #fff !important;
            border-top: 1px solid #c46a6a !important;
            border-right: 1px solid #8e3b3b !important;
            border-bottom: 1px solid #5c0000 !important;
            padding: 6px 5px !important;
            font-weight: 700 !important;
            text-transform: none !important;
            white-space: nowrap !important;
        }

            .table-responsive-sticky thead th:first-child {
                border-left: 1px solid #8e3b3b !important;
            }

    .table tbody td {
        vertical-align: middle;
        background: #fffafa !important;
        border-right: 1px solid #d8bcbc !important;
        border-bottom: 1px solid #d8bcbc !important;
        padding: 5px !important;
        color: #401515 !important;
    }

        .table tbody td:first-child {
            border-left: 1px solid #d8bcbc !important;
        }

    .table.table-striped > tbody > tr:nth-of-type(odd) > * {
        background-color: #fffafa !important;
    }

    .table.table-striped > tbody > tr:nth-of-type(even) > * {
        background-color: #f9eded !important;
    }

    .table-hover tbody tr:hover > * {
        background: #f4dddd !important;
    }

    .table td:nth-child(6) {
        max-width: 420px;
        white-space: normal;
        word-break: break-word;
    }

    th.actions-col {
        width: 320px;
    }

    td.actions-cell {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: .5rem;
        flex-wrap: nowrap;
        white-space: nowrap;
        vertical-align: middle;
        background: inherit !important;
    }

        td.actions-cell .btn, td.actions-cell a, td.actions-cell button {
            flex: 0 0 auto;
            white-space: nowrap;
        }

    .empty {
        padding: 2.25rem 1rem;
        color: var(--muted);
        text-align: center;
    }

    .btn-round {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        border-radius: 0;
        padding: .45rem .75rem;
        border: 1px solid #9a5a5a;
        background: linear-gradient(#fffefe, #ecd7d7);
        color: #4a1111;
        transition: transform .12s ease, box-shadow .2s ease;
        font-size: 12px;
        font-weight: 700;
    }

        .btn-round.primary {
            background: linear-gradient(180deg, #b40000 0%, #8f0000 55%, #6e0000 100%);
            color: #fff;
            border-color: #7f0a0a;
        }

        .btn-round:hover {
            transform: translateY(-1px);
            box-shadow: none;
            color: inherit;
        }

        .btn-round.primary:hover {
            color: #fff;
        }

    #ovIrPantalla {
        display: none !important;
    }

    #ovModal .modal-body,
    #ovPreviewModal .modal-body,
    #subpedidosModal .modal-body,
    #trModal .modal-body {
        padding: .75rem .85rem;
    }

    #ovModal .row.g-3,
    #ovPreviewModal .row.g-3,
    #trModal .row.g-3 {
        --bs-gutter-x: .75rem;
        --bs-gutter-y: .5rem;
    }

    #ovModal .panel-head,
    #ovPreviewModal .panel-head,
    #trModal .panel-head {
        padding: .45rem .7rem;
        font-size: .9rem;
    }

    .ov-done-badge {
        font-size: .85rem;
        font-weight: 800;
        color: #0f5132;
        background: #d1e7dd;
        border: 1px solid #badbcc;
        border-radius: 999px;
        padding: .2rem .5rem;
    }

    .btn-exec-red {
        background: #9b1c1c !important;
        border: 1px solid rgba(0,0,0,.10) !important;
        color: #fff !important;
        font-weight: 800 !important;
    }

        .btn-exec-red:hover {
            background: #871818 !important;
            color: #fff !important;
        }

    .btn-exec-red-outline {
        background: transparent !important;
        border: 1px solid #dc3545 !important;
        color: #dc3545 !important;
        font-weight: 800 !important;
    }

        .btn-exec-red-outline:hover {
            background: #dc3545 !important;
            border-color: #dc3545 !important;
            color: #fff !important;
        }

    .table.table-striped tbody tr.table-danger {
        --bs-table-bg: #f8d7da;
        --bs-table-accent-bg: #f8d7da;
        --bs-table-striped-bg: #f8d7da;
        --bs-table-hover-bg: #f5c2c7;
    }

    .table.table-striped tbody tr.table-warning {
        --bs-table-bg: #fff3cd;
        --bs-table-accent-bg: #fff3cd;
        --bs-table-striped-bg: #fff3cd;
        --bs-table-hover-bg: #ffecb5;
    }

        .table.table-striped tbody tr.table-danger > *,
        .table.table-striped tbody tr.table-warning > * {
            background-color: var(--bs-table-bg) !important;
        }

        .table.table-striped tbody tr.table-danger td.actions-cell,
        .table.table-striped tbody tr.table-warning td.actions-cell {
            background-color: var(--bs-table-bg) !important;
        }

    #fAlmacenesInv {
        min-height: 210px;
        padding: .25rem;
    }

        #fAlmacenesInv option {
            padding: .35rem .5rem;
        }

            #fAlmacenesInv option[disabled] {
                color: #6c757d;
                font-weight: 600;
            }

    .alm-multi-menu {
        width: 320px;
        max-width: 92vw;
        border-radius: 6px;
        box-shadow: 0 8px 18px rgba(70,12,12,.14);
        border: 1px solid #b48787 !important;
        background: #fffafa !important;
    }

    .alm-multi-list {
        max-height: 240px;
        overflow: auto;
        padding: .25rem;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        background: #fff;
    }

    .alm-multi-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .35rem .45rem;
        border-radius: 4px;
    }

        .alm-multi-item:hover {
            background: #f7f9fb;
        }

        .alm-multi-item input {
            margin-top: 0;
        }

    .sapmm-grid {
        background: #dfeaf6 !important;
    }

        .sapmm-grid thead th {
            background: #f3f6fb !important;
            color: #1f2a33 !important;
            border-bottom: 1px solid #9fb2c8 !important;
            border-right: 1px solid #b7c6d6 !important;
        }

        .sapmm-grid tbody td {
            background: #dfeaf6 !important;
            border-bottom: 1px solid #b7c6d6 !important;
            border-right: 1px solid #b7c6d6 !important;
            color: #10212b !important;
        }

        .sapmm-grid.table-hover tbody tr:hover > * {
            background: #cfe0f2 !important;
        }

    .sapmm-skin {
        --mm-bg: #efe6da;
        --mm-pan: #f3eadf;
        --mm-head: #e7dccf;
        --mm-line: #b5aa9a;
        --mm-line2: #d1c7b9;
        --mm-text: #1a1a1a;
        --mm-focus: #6aa6d8;
    }

        .sapmm-skin .sap-filterbar {
            background: var(--mm-pan) !important;
            border: 1px solid var(--mm-line) !important;
            box-shadow: none !important;
            border-radius: 6px !important;
        }

        .sapmm-skin .sap-filterbar-more {
            border-top: 1px solid var(--mm-line2) !important;
        }

        .sapmm-skin .form-control,
        .sapmm-skin .form-select {
            background: #fffaf3 !important;
            border: 1px solid var(--mm-line) !important;
            border-radius: 3px !important;
            box-shadow: none !important;
        }

            .sapmm-skin .form-control:focus,
            .sapmm-skin .form-select:focus {
                border-color: var(--mm-focus) !important;
                box-shadow: 0 0 0 2px rgba(106,166,216,.35) !important;
            }

        .sapmm-skin .sap-field label {
            color: #2f2f2f !important;
            font-weight: 800 !important;
            font-size: 12px !important;
            margin-bottom: .15rem !important;
        }

        .sapmm-skin .segmented.sapmm-tabs {
            border: 1px solid var(--mm-line) !important;
            border-radius: 6px !important;
            overflow: hidden !important;
            background: linear-gradient(#f6efe6,#e7dccf) !important;
        }

            .sapmm-skin .segmented.sapmm-tabs button {
                border: 0 !important;
                background: transparent !important;
                color: var(--mm-text) !important;
                font-weight: 900 !important;
                padding: .28rem .75rem !important;
                border-right: 1px solid var(--mm-line) !important;
                position: relative;
                line-height: 1.1 !important;
            }

                .sapmm-skin .segmented.sapmm-tabs button:last-child {
                    border-right: 0 !important;
                }

                .sapmm-skin .segmented.sapmm-tabs button.active {
                    background: #fffaf3 !important;
                    box-shadow: inset 0 1px 0 rgba(255,255,255,.85) !important;
                }

                .sapmm-skin .segmented.sapmm-tabs button:hover {
                    background: linear-gradient(#fff8ef,#e7dccf) !important;
                }

        .sapmm-skin .btn.btn-outline-secondary {
            border: 1px solid var(--mm-line) !important;
            background: linear-gradient(#f7f2ea,#e1d7ca) !important;
            color: var(--mm-text) !important;
            font-weight: 900 !important;
        }

            .sapmm-skin .btn.btn-outline-secondary:hover {
                background: linear-gradient(#fff8ef,#e7dccf) !important;
            }

    .modal-content {
        border: 1px solid #7d4949;
        border-radius: 0;
    }

    .modal-header {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        border-bottom: 1px solid #5c0000 !important;
        color: #fff !important;
    }

    .modal-title {
        color: #fff !important;
        font-size: 13px;
        font-weight: 700;
    }

    .btn-close {
        filter: invert(1) grayscale(100%) !important;
        opacity: .95 !important;
    }

    .modal-footer {
        background: #f7eaea;
        border-top: 1px solid #d3b0b0;
    }

    .statusbar {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 6px 10px;
        font-size: 11px;
        color: #4a1a1a;
        border-top: 1px solid #b88c8c;
        background: linear-gradient(#f6e9e9, #ead5d5);
        flex-wrap: wrap;
        margin-top: 8px;
    }

    @@media (max-width: 1200px) {
        .sap-filterbar-base {
            grid-template-columns: repeat(2, minmax(160px, 1fr));
        }
    }

    /* FONDO GRIS / ROSITA */
html,
body {
    background: #e9edf2 !important;
    overflow-x: hidden !important;
}

body,
main,
.main,
.body-content,
.container,
.container-fluid {
    background: #e9edf2 !important;
}

.titlebar {
    display: none !important;
}

.window {
    width: min(100%, calc(100vw - 48px)) !important;
    max-width: 1900px !important;
    margin: 0 auto !important;
    background: #f8eeee !important;
    border: 1px solid #7e4a4a !important;
}

.content-pad {
    background: #f0dede !important;
    padding: 8px !important;
}

.sap-page-header,
.sap-filterbar,
.panel {
    background: #f8eeee !important;
    border: 1px solid #c79d9d !important;
}

.table-responsive-sticky,
.table-responsive-sticky table,
.table,
.sapmm-grid {
    background: #fffafa !important;
}

/* QUITAR AZUL SAP Y PASARLO A ROSITA */
.sapmm-grid thead th {
    background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
    color: #fff !important;
    border-right: 1px solid #8e3b3b !important;
    border-bottom: 1px solid #5c0000 !important;
}

.sapmm-grid tbody td,
.table tbody td {
    background: #fffafa !important;
    border-right: 1px solid #d8bcbc !important;
    border-bottom: 1px solid #d8bcbc !important;
    color: #401515 !important;
}

.sapmm-grid.table-striped > tbody > tr:nth-of-type(even) > *,
.table.table-striped > tbody > tr:nth-of-type(even) > * {
    background: #f9eded !important;
}

.sapmm-grid.table-hover tbody tr:hover > *,
.table-hover tbody tr:hover > * {
    background: #f4dddd !important;
}

/* RESPONSIVO */
@@media (min-width: 1400px) {
    .window {
        width: calc(100vw - 80px) !important;
    }
}

@@media (max-width: 1200px) {
    .window {
        width: calc(100vw - 24px) !important;
    }

    .sap-filterbar-base {
        grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
}

@@media (max-width: 768px) {
    .window {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        border-left: none !important;
        border-right: none !important;
    }

    .content-pad {
        padding: 6px !important;
    }

    .sap-page-header,
    .sap-filterbar-top,
    .sap-filterbar-more {
        display: block !important;
    }

    .sap-ph-right {
        justify-content: flex-start !important;
        margin-top: 8px;
    }

    .sap-search {
        min-width: 0 !important;
        width: 100% !important;
        margin: 8px 0;
    }

    .sap-filterbar-base {
        grid-template-columns: 1fr !important;
        gap: 8px !important;
    }

    .sap-filterbar-actions {
        display: grid !important;
        grid-template-columns: 1fr !important;
    }

    .sap-filterbar-actions button,
    .btn,
    .btn-round {
        width: 100% !important;
    }

    .table-responsive-sticky {
        width: 100% !important;
        overflow-x: auto !important;
        -webkit-overflow-scrolling: touch !important;
        max-height: 65vh !important;
    }

    .table-responsive-sticky table {
        min-width: 850px !important;
        font-size: 10px !important;
    }

    .table-responsive-sticky th,
    .table-responsive-sticky td {
        font-size: 10px !important;
        padding: 4px 3px !important;
    }

    td.actions-cell {
