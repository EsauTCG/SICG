                function bindQuickShortcuts() {
                  // Ctrl+S = guardar
                  document.addEventListener('keydown', function (e) {
                    if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 's') {
                      e.preventDefault();
                      document.getElementById('btnGuardarProductos')?.click();
                    }
                  });

                  // Enter en cajas -> siguiente cajas
                  $(document).on('keydown', '#ovProductos .inp-cajas', function (e) {
                    if (e.key !== 'Enter') return;
                    e.preventDefault();

                    const $rows = $('#ovProductos tbody tr');
                    const $tr = $(this).closest('tr');
                    const idx = $rows.index($tr);

                    // siguiente input cajas NO disabled
                    for (let i = idx + 1; i < $rows.length; i++) {
                      const next = $rows.eq(i).find('.inp-cajas:not(:disabled)').get(0);
                      if (next) { next.focus(); next.select?.(); return; }
                    }
                  });
                }


                       function renderProductosTabla(){
