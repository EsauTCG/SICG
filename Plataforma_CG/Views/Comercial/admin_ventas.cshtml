            tbody.innerHTML = `<tr><td colspan="9" class="text-center text-muted">Sin productos.</td></tr>`;
          } else {
            ovState.productos.forEach((r,i)=>{
              const eliminado = !!r.eliminado;
              const sku       = r.productoCodigo ?? r.sku ?? '';
              const nombre    = r.productoNombre ?? r.producto ?? '';
              const kilosCaja = Number(r.kilosCaja ?? r.peso ?? 0) || 0;

              // tope dinámico por grupo (SOLO VISUAL)
              const maxCajas  = lineMaxFor(r);

              // 👇 SOLO para pintar, NO tocar r.cajas
              const cajasUI   = Math.max(0, Math.floor(Number(r.cajas ?? 0) || 0));

              const precio    = Number(r.precio ?? 0) || 0;

              // KG totales = kilosCaja × cajas (UI)
              const kilosTotales = kilosCaja * cajasUI;
              const importe      = precio * kilosTotales;

              if (!eliminado) {
                totalImporte += importe;
                totalPeso    += kilosTotales;
