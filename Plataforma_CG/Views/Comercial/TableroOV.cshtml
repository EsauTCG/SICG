                cita: "30 nov 25 · 14:00 hrs",
                llegada: "30 nov 25 · 14:30 hrs",
                status: "Demorado",
                statusTipo: "bad",
                kilosSal: 5800,
                cumplimiento: "95.1"
            }
        ];

        function formatNumber(n) {
            if (n == null || n === "") return "";
            const num = typeof n === "number"
                ? n
                : parseFloat(String(n).replace(/,/g, ""));
            if (isNaN(num)) return n;
            return num.toLocaleString("es-MX", { minimumFractionDigits: 0 });
        }

        function renderTabla() {
            const tbody = document.getElementById("tbodyTablero");
            tbody.innerHTML = "";

            datos.forEach((r) => {
                const tr = document.createElement("tr");

                let cumpClass = "cump-good";
                const c = parseFloat(r.cumplimiento);
                if (!isNaN(c)) {
                    if (c < 80) cumpClass = "cump-bad";
                    else if (c < 95) cumpClass = "cump-warn";
                }

                let stClass = "st-ok";
                if (r.statusTipo === "bad") stClass = "st-bad";
                else if (r.statusTipo === "warn") stClass = "st-warn";

                tr.innerHTML = `
            <td class="col-fecha">${r.fecha || ""}</td>
            <td class="col-ruta">${r.ruta || ""}</td>
            <td class="col-cliente">${r.cliente || ""}</td>
            <td class="col-kilos">${formatNumber(r.kilosOrig)}</td>
            <td class="col-temp">${r.temp || ""}</td>
            <td class="col-transp">${r.transp || ""}</td>
            <td class="col-pedido">${r.pedido || ""}</td>
            <td class="col-unidad">${r.unidad || ""}</td>
            <td class="col-hora">${r.liberacion || ""}</td>
            <td class="col-hora">${r.validacion || ""}</td>
            <td class="col-doc">${r.documento || ""}</td>
            <td class="col-salida">${r.salida || ""}</td>
            <td class="col-cita">${r.cita || ""}</td>
            <td class="col-llegada">${r.llegada || ""}</td>
            <td class="col-status">
                <span class="badge-status ${stClass}">${r.status || ""}</span>
            </td>
            <td class="col-kilos-sal">${formatNumber(r.kilosSal)}</td>
            <td class="col-cump">
                <span class="cell-cump ${cumpClass}">
                    ${r.cumplimiento ? r.cumplimiento + "%" : ""}
                </span>
            </td>
        `;

                tbody.appendChild(tr);
            });
        }

        // Reloj arriba a la derecha
        function updateClock() {
            const el = document.getElementById("boardClock");
            const now = new Date();
            const opts = { hour: "2-digit", minute: "2-digit", second: "2-digit" };
            el.textContent =
                now.toLocaleDateString("es-MX") +
                " · " +
                now.toLocaleTimeString("es-MX", opts);
        }

        // Auto-scroll suave
        function startAutoScroll() {
            const inner = document.getElementById("scrollInner");
            const container = document.querySelector(".scroll-container");
            const step = 0.25;
            let offset = 0;

            function loop() {
                offset -= step;
                const maxScroll = inner.offsetHeight - container.offsetHeight;
                if (maxScroll > 0) {
                    if (-offset > maxScroll + 40) offset = 0;
                    inner.style.transform = `translateY(${offset}px)`;
                }
                requestAnimationFrame(loop);
            }
            requestAnimationFrame(loop);
        }

        // ===== SIMULACIÓN EN "TIEMPO REAL" =====
        function randInt(min, max) {
            return Math.floor(Math.random() * (max - min + 1)) + min;
        }

        function sample(arr) {
            return arr[randInt(0, arr.length - 1)];
        }

        function actualizarFilaAleatoria() {
            if (!datos.length) return;

            const idx = randInt(0, datos.length - 1);
            const r = datos[idx];

            const nuevoCump = randInt(70, 105);
            r.cumplimiento = nuevoCump.toFixed(1);

            const base = r.kilosOrig || 0;
            r.kilosSal = Math.round(base * (nuevoCump / 100));

            if (nuevoCump >= 98) {
                r.status = "Entregado";
                r.statusTipo = "ok";
            } else if (nuevoCump >= 85) {
                r.status = sample(["En ruta", "Entregado", "En descarga"]);
                r.statusTipo = "warn";
            } else {
                r.status = sample(["Demorado", "Detenido", "Reprogramado"]);
                r.statusTipo = "bad";
            }

            if (Math.random() < 0.35) {
                const moved = datos.splice(idx, 1)[0];
                datos.push(moved);
            }

            renderTabla();
            const rows = document.querySelectorAll("#tbodyTablero tr");
            const highlightIndex = Math.min(idx, rows.length - 1);
            if (rows[highlightIndex]) {
                rows[highlightIndex].classList.add("highlight");
                setTimeout(() => {
                    rows[highlightIndex].classList.remove("highlight");
                }, 1800);
            }
        }

        function startRandomUpdates() {
            function scheduleNext() {
                const delay = randInt(4000, 7000);
                setTimeout(() => {
                    actualizarFilaAleatoria();
                    scheduleNext();
                }, delay);
            }
            scheduleNext();
        }

        // ===== INIT =====
        renderTabla();
        updateClock();
        setInterval(updateClock, 1000);
        startAutoScroll();
        startRandomUpdates();
    </script>
</body>
</html>
