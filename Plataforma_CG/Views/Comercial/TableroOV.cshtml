@using System.Linq
@model Plataforma_CG.Models.OrdenesOVFiltro

@{
    Layout = null;  // Pantalla completa sin menú
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Tablero logística / distribución</title>

     <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/images/ico_sigo.ico" />

    <!-- Fuentes tipo “tablero de aeropuerto” -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@400;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">

    <!-- (Opcional) FontAwesome si quieres iconos en el título -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <style>
        :root {
            --bg: #111111;
            --board-bg: #111111;
            --board-border: #222;
            --header-red: #c00;
            --row-alt: #1b1b1b;
            --row-bg: #151515;
            --text: #f5f5f5;
            --muted: #cccccc;
            --line: #333333;
            --green: #009944;
            --yellow: #f4b000;
            --red: #d62929;
        }

        * {
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
            width: 100%;
            font-family: "Roboto Condensed", system-ui, sans-serif;
            background: radial-gradient(circle at top, #222 0, #000 50%, #000 100%);
            color: var(--text);
            overflow: hidden;
        }

        .board-shell {
            display: flex;
            flex-direction: column;
            height: 100%;
            width: 100%;
            padding: 16px 28px;
        }

        /* Título tipo aeropuerto */
        .board-title {
            text-align: center;
            font-size: 2.8rem;
            font-weight: 700;
            color: red;
            letter-spacing: .15em;
            text-transform: uppercase;
            margin-bottom: 4px;
            text-shadow: 0 3px 6px rgba(0,0,0,.7);
        }

            .board-title i {
                margin-right: .5rem;
            }

        .board-sub {
            text-align: center;
            font-size: .9rem;
            color: var(--muted);
            margin-bottom: 8px;
        }

        .board-wrapper {
            flex: 1;
            border-radius: 10px;
            border: 4px solid #555;
            background: #111;
            box-shadow: 0 18px 40px rgba(0,0,0,.9);
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .board-header {
            padding: 6px 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: .9rem;
            border-bottom: 2px solid #444;
            background: #000;
        }

        .board-header-left {
            text-transform: uppercase;
            letter-spacing: .18em;
            font-weight: 700;
            color: red;
        }

        .board-clock {
            font-variant-numeric: tabular-nums;
            font-weight: 600;
            color: #f5f5f5;
        }

        .board-table-wrapper {
            flex: 1;
            overflow-y: hidden;
            overflow-x: auto; /* permite ver todo si se hace muy ancho */
            position: relative;
        }

        .board-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: auto !important; /* asegura que no se corten datos */
            font-size: .9rem;
        }

            .board-table thead {
                background: #000;
                border-bottom: 2px solid #444;
            }

            .board-table th,
            .board-table td {
                padding: 6px 10px; /* más espacio = datos completos visibles */
                border-bottom: 1px solid var(--line);
                white-space: nowrap;
                overflow: visible !important; /* evita cortar información */
                text-overflow: clip !important; /* quita puntos suspensivos */
                text-align: left;
            }

            .board-table th {
                font-family: "Roboto Condensed", sans-serif;
                font-weight: 700;
                text-transform: uppercase;
                font-size: .75rem;
                letter-spacing: .16em;
                color: red;
            }

            .board-table td {
                font-family: "Share Tech Mono", monospace;
                font-size: .88rem;
                letter-spacing: .08em;
                color: #f5f5f5;
            }

            .board-table tbody tr:nth-child(odd) {
                background: var(--row-bg);
            }

            .board-table tbody tr:nth-child(even) {
                background: var(--row-alt);
            }

            .board-table tbody tr.highlight {
                animation: rowPulse 1.8s ease-out;
            }

        @@keyframes rowPulse {
            0% {
                background-color: #333;
            }

            100% {
                background-color: inherit;
            }
        }

        /* Badges */
        .badge-status {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 2px 8px;
            border-radius: 999px;
            font-size: .7rem;
            font-weight: 700;
            text-transform: uppercase;
            color: #fff;
        }

        .st-ok {
            background: var(--green);
        }

        .st-warn {
            background: var(--yellow);
            color: #111;
        }

        .st-bad {
            background: var(--red);
        }

        .cell-cump {
            font-family: "Share Tech Mono", monospace;
            font-weight: 700;
            color: #fff;
            border-radius: 999px;
            padding: 2px 6px;
            display: inline-block;
            min-width: 60px;
            text-align: center;
        }

        .cump-good {
            background: var(--green);
        }

        .cump-warn {
            background: var(--yellow);
            color: #111;
        }

        .cump-bad {
            background: var(--red);
        }

        /* Auto scroll */
        .scroll-container {
            height: 100%;
            overflow: hidden;
            position: relative;
        }

        .scroll-inner {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            will-change: transform;
        }
    </style>


</head>

<body>
    <div class="board-shell">
        <div class="board-title">
            <i class="fa-solid fa-truck-fast"></i>
            TABLERO LOGÍSTICA / DISTRIBUCIÓN
        </div>
        <div class="board-sub">Información fija de ejemplo para presentación</div>

        <div class="board-wrapper">
            <div class="board-header">
                <div class="board-header-left">Logística · centros de distribución</div>
                <div class="board-clock" id="boardClock"></div>
            </div>

            <div class="board-table-wrapper">
                <div class="scroll-container">
                    <div class="scroll-inner" id="scrollInner">
                        <table class="board-table">
                            <thead>
                                <tr>
                                    <th class="col-fecha">Fecha car.</th>
                                    <th class="col-ruta">Ruta / destino</th>
                                    <th class="col-cliente">Cliente</th>
                                    <th class="col-kilos">Kilos orig.</th>
                                    <th class="col-temp">Temp.</th>
                                    <th class="col-transp">Transp.</th>
                                    <th class="col-pedido">Pedido</th>
                                    <th class="col-unidad">Unidad</th>
                                    <th class="col-hora">Liberación</th>
                                    <th class="col-hora">Validación</th>
                                    <th class="col-doc">Documento</th>
                                    <th class="col-salida">Salida</th>
                                    <th class="col-cita">Cita</th>
                                    <th class="col-llegada">Llegada</th>
                                    <th class="col-status">Status</th>
                                    <th class="col-kilos-sal">Kilos sal.</th>
                                    <th class="col-cump">% Cump.</th>
                                </tr>
                            </thead>
                            <tbody id="tbodyTablero">
                                <!-- JS inyecta filas -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
