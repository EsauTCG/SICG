        function initHeaderSorting() {
            const table = document.querySelector('.table-wrap table');
            if (!table) return;

            const thead = table.querySelector('thead');
            const tbody = table.querySelector('tbody');
            if (!thead || !tbody) return;

            const ths = thead.querySelectorAll('th[data-sort-col]');
            if (!ths.length) return;

            const state = { index: null, dir: null }; // asc | desc | null

            function clearIcons() {
                ths.forEach(th => {
                    th.textContent = th.textContent.replace(/\s*[▲▼]$/, '');
                });
            }

            function getCellValue(tr, index) {
                const td = tr.children[index];
                if (!td) return '';
                return td.innerText.trim();
            }

            function parseValue(val, type) {
                if (type === 'num') {
                    const n = parseFloat(val.replace(/[^\d.-]/g, ''));
                    return isNaN(n) ? 0 : n;
                }
                if (type === 'date') {
                    const d = new Date(val);
                    return isNaN(d.getTime()) ? 0 : d.getTime();
                }
                return val.toUpperCase();
            }

            function sortBody(index, dir) {
                const rows = Array.from(tbody.querySelectorAll('tr'));
                if (!rows.length) return;

                if (index == null || dir == null) {
                    // restaurar orden original usando data-index
                    rows.sort((a, b) => {
                        const ia = parseInt(a.dataset.index || '0', 10);
                        const ib = parseInt(b.dataset.index || '0', 10);
                        return ia - ib;
                    });
                } else {
                    const type = ths[index].dataset.sortType || 'text';
                    rows.sort((a, b) => {
                        const va = parseValue(getCellValue(a, index), type);
                        const vb = parseValue(getCellValue(b, index), type);
                        if (va < vb) return -1;
                        if (va > vb) return 1;
                        return 0;
                    });
                    if (dir === 'desc') rows.reverse();
                }

                rows.forEach(r => tbody.appendChild(r));
            }

            ths.forEach((th, index) => {
                th.style.cursor = 'pointer';

                th.addEventListener('click', () => {
                    if (state.index === index) {
                        state.dir = state.dir === 'asc' ? 'desc' :
                                   state.dir === 'desc' ? null : 'asc';
                    } else {
                        state.index = index;
                        state.dir = 'asc';
                    }

                    clearIcons();

                    if (!state.dir) {
                        state.index = null;
                    } else {
                        th.textContent = th.textContent.replace(/\s*[▲▼]$/, '') +
                            (state.dir === 'asc' ? ' ▲' : ' ▼');
                    }

                    sortBody(state.index, state.dir);
                });
            });
        }

