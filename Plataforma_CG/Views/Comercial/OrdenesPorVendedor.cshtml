    btnCancelarOV.addEventListener('click', async () => {

        if (!ordenIdActual) {
            showMsg('warning', 'No se encontró la orden.');
            return;
        }

        if (Number(estatusActual) === 0) {
            showMsg('warning', 'Este pedido ya está cancelado.');
            return;
        }

        const consecutivoActual = document.getElementById('ovm-consecutivo')?.textContent || '';

        const seguro = confirm(
            `¿Estás seguro de eliminar el pedido ${consecutivoActual}?`
        );

        if (!seguro) return;

        const url = `/Comercial/CancelarOV?id=${encodeURIComponent(ordenIdActual)}`;

        try {
            btnCancelarOV.disabled = true;
            btnCancelarOV.textContent = 'Eliminando...';

            const resp = await fetch(url, {
                method: 'POST',
                headers: {
                    'Accept': 'application/json',
                    'RequestVerificationToken': getAntiForgeryToken()
                }
            });

            const raw = await resp.text();
            let json = {};
            try { json = JSON.parse(raw); } catch { }

            if (resp.status === 404) {
                showMsg('danger', 'Orden no encontrada.');
                return;
            }

            if (resp.status === 400) {
                showMsg('danger', 'Solicitud inválida o token faltante.');
                return;
            }

            if (resp.status === 409) {
                showMsg('warning', json.msg || 'No se puede cancelar este pedido.');
                return;
            }

            if (!resp.ok || json.ok === false) {
                showMsg('danger', json.msg || `Error (${resp.status}).`);
                return;
            }

            document.getElementById('ovm-estatus').textContent = json.estatus || 'Cancelado';

            estatusActual = 0;
