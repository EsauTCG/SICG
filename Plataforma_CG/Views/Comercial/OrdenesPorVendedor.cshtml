                        </div>

                        <div class="filter-group">
                            <label>Hasta</label>
                            <input type="date" name="Hasta" value="@(Model?.Hasta?.ToString("yyyy-MM-dd") ?? "")" />
                        </div>

                       

                        <div class="filter-group">
                            <label>Estatus</label>
                            @{
                                var ests = Model?.EstatusSeleccionados ?? new List<int>();
                                string TextoEstatus(IEnumerable<int> selec)
                                {
                                    if (selec == null || !selec.Any()) return "(Todos)";
                                    var nombres = new List<string>();
                                    if (selec.Contains(0)) nombres.Add("Cancelados");
                                    if (selec.Contains(1) || selec.Contains(3)) nombres.Add("Pendiente");
                                    if (selec.Contains(2)) nombres.Add("Autorización");
                                    if (selec.Contains(4)) nombres.Add("Validado");
                                    if (selec.Contains(5)) nombres.Add("Enviado a SAP");
                                    if (selec.Contains(6)) nombres.Add("Logistica");
                                    return string.Join(", ", nombres.Distinct());
                                }
                            }

                            <div class="dropdown w-100" id="dd-estatus">
                                <button class="btn-select-like w-100"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        data-bs-auto-close="outside"
                                        aria-expanded="false">
                                    <span class="multi-label">@TextoEstatus(ests)</span>
                                </button>

                                <div class="dropdown-menu multi-picker-menu" onclick="event.stopPropagation();">
                                    <input type="text"
                                           class="form-control multi-picker-search"
                                           placeholder="Buscar estatus..."
                                           autocomplete="off" />

                                    <div class="multi-picker-list">
                                        <label class="multi-picker-option">
                                            <input class="multi-check-estatus"
                                                   type="checkbox"
                                                   value="0"
                                                   id="est_0"
                                                   data-text="Cancelados"
                                            @(ests.Contains(0) ? "checked" : null) />
                                            <span>Cancelados</span>
                                        </label>

                                        <label class="multi-picker-option">
                                            <input class="multi-check-estatus"
                                                   type="checkbox"
                                                   value="1"
                                                   id="est_1"
                                                   data-text="Pendiente"
                                            @((ests.Contains(1) || ests.Contains(3)) ? "checked" : null) />
                                            <span>Pendiente</span>
                                        </label>

                                        <label class="multi-picker-option">
                                            <input class="form-check-input multi-check-estatus"
                                                   type="checkbox"
                                                   value="2"
                                                   id="est_2"
                                                   data-text="Autorización"
                                            @(ests.Contains(2) ? "checked" : null) />
                                            <span>Autorización</span>
                                        </label>

                                        <label class="multi-picker-option">
                                           <input class="multi-check-estatus"
                                                   type="checkbox"
                                                   value="4"
                                                   id="est_4"
                                                   data-text="Validado"
