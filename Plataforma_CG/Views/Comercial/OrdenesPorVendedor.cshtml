                function escapeRegExp(s){
          return (s ?? "").replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
        }

        function soloNombreProducto(productoNombre, productoCodigo){
          const d = (productoNombre ?? "").trim();
          const c = (productoCodigo ?? "").trim();

          if (!d) return "";

          // Caso: "V044 (S-PULPA ...)"  => "S-PULPA ..."
          if (c) {
            const m = d.match(new RegExp("^" + escapeRegExp(c) + "\\s*\\((.*)\\)\\s*$", "i"));
            if (m && m[1]) return m[1].trim();

            // Caso: "V044 - S-PULPA ..." o "V044 S-PULPA ..." => quitar prefijo
            return d.replace(new RegExp("^" + escapeRegExp(c) + "\\s*[-–—:]?\\s*", "i"), "").trim();
          }

          // Caso sin código: si viene "(S-PULPA ...)" quita paréntesis
          const m2 = d.match(/^\((.*)\)$/);
          return (m2 && m2[1]) ? m2[1].trim() : d;
        }

     


