function toggleCancelarBtn(estatus){
    if (!btnCancelarOV) return;

    const eliminado = Number(estatus) === 0;

    btnCancelarOV.classList.toggle('d-none', eliminado);
    btnCancelarOV.disabled = eliminado;
    btnCancelarOV.title = eliminado
        ? 'Este pedido ya está cancelado'
        : 'Eliminar pedido';
}

