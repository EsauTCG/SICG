@using System.Linq
@model Plataforma_CG.Models.OrdenesOVFiltro

@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<style>
    :root {
        --bg: #f0dede;
        --panel: #f8eeee;
        --panel-2: #f1dede;
        --line: #c79d9d;
        --line-dark: #8f4c4c;
        --text: #3b1717;
        --muted: #6a3a3a;
        --title: #ffffff;
        --white: #ffffff;
        --danger: #c00000;
        --warning: #f3b6b6;
        --ok: #f7e3e3;
        --shadow: 0 1px 0 rgba(255,255,255,.55) inset;
        --brand: #8B0000;

        --vino-1: #5c0000;
        --vino-2: #7a0000;
        --vino-3: #980000;
        --vino-4: #b30000;
        --vino-5: #d10000;

        --vino-soft: #f8e7e7;
        --vino-soft-2: #f2d9d9;
        --vino-border: #9a5a5a;
        --vino-text: #ffffff;
        --vino-text-dark: #4a1111;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0 !important;
        padding: 0 !important;
        font-family: Tahoma, Verdana, Arial, sans-serif;
        background: transparent !important;
        color: var(--text);
    }

    .container, .container-fluid {
        max-width: 100% !important;
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .window {
        width: 100%;
        max-width: 100%;
        margin: 0 !important;
        border: 1px solid #7e4a4a;
        background: var(--panel);
        box-shadow: 0 0 0 1px rgba(255,255,255,.45) inset, 0 8px 18px rgba(70, 12, 12, 0.14);
        overflow: hidden;
        padding: 0 !important;
    }

    .window > *:first-child,
    .titlebar {
        margin-top: 0 !important;
    }

    .titlebar {
        height: 34px;
       /*  display: flex; */
         display: none !important;
        align-items: center;
        justify-content: space-between;
        padding: 0 10px;
        background: linear-gradient(180deg, #c00000 0%, #8b0000 60%, #5c0000 100%);
        border-bottom: 1px solid #5c0000;
        color: #fff;
        font-size: 13px;
        font-weight: bold;
    }

    .titlebar .actions {
        display: flex;
        gap: 6px;
    }

    .win-btn {
        width: 16px;
        height: 16px;
        border: 1px solid #7c4848;
        background: linear-gradient(#fff6f6, #ead0d0);
    }

    .menubar {
        display: none !important;
    }

    .toolbar {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 4px 6px;
        background: linear-gradient(#fff6f6, #ecd8d8);
        border-bottom: 1px solid var(--line);
        font-size: 12px;
        flex-wrap: wrap;
    }

    .menu-item, .tool-btn, .tab {
        border: 1px solid transparent;
        padding: 4px 8px;
        user-select: none;
    }

    .tool-btn {
        min-width: 72px;
        text-align: center;
        background: linear-gradient(#fffefe, #ecd7d7);
        border: 1px solid var(--vino-border);
        box-shadow: var(--shadow);
        cursor: pointer;
        color: var(--vino-text-dark);
    }

    .tool-btn:hover,
    .small-btn:hover,
    .tab:hover {
        filter: brightness(0.98);
    }

    .content {
        padding: 8px;
        background: var(--bg);
    }

    .tabs {
        display: flex;
        gap: 4px;
        margin-bottom: 6px;
        flex-wrap: wrap;
    }

    .tab {
        font-size: 12px;
        background: linear-gradient(#f7e7e7, #ead1d1);
        border: 1px solid #caa0a0;
        border-bottom: none;
        padding: 7px 12px;
        color: #5c1a1a;
    }

    .tab.active {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        font-weight: bold;
        color: #fff;
        border-color: #7a2d2d;
    }

    .workspace {
        border: 1px solid var(--line);
        background: var(--panel);
        padding: 8px;
    }

    .section {
        border: 1px solid var(--line);
        background: var(--white);
        margin-bottom: 10px;
    }

    .section-title {
        padding: 6px 8px;
        font-size: 12px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
    }

.filters {
     display: grid;
    grid-template-columns: 160px 160px 160px minmax(260px, 1fr) auto;
    gap: 8px;
    padding: 10px;
    background: var(--panel-2);
    align-items: end;
}
.filter-group input[type="text"] {
    width: 100%;
}

    .filter-group label {
        display: block;
        color: #5c1a1a;
        font-size: 12px;
        margin-bottom: 4px;
        font-weight: bold;
    }

    input, select, .form-control, .form-select {
        height: 28px !important;
        padding: 3px 6px !important;
        border: 1px solid #b48787 !important;
        background: #fffdfd !important;
        font-family: inherit !important;
        font-size: 12px !important;
        width: 100%;
        border-radius: 0 !important;
        box-shadow: none !important;
        color: #421414 !important;
    }

    .small-btn {
        height: 28px;
        padding: 0 10px;
        border: 1px solid #9a5a5a;
        background: linear-gradient(#fffefe, #ecd7d7);
        font-size: 12px;
        box-shadow: var(--shadow);
        cursor: pointer;
        color: #4d1818;
        white-space: nowrap;
    }

    .table-wrap {
        padding: 0;
        overflow: auto;
        max-height: 70vh;
        background: #fffafa;
        width: 100%;
        position: relative;
        border-top: 1px solid #d9b8b8;
    }

    .table-wrap table {
        width: 100%;
        table-layout: fixed;
        border-collapse: separate !important;
        border-spacing: 0 !important;
        font-size: 12px;
        background: #fffafa;
    }

    .table-wrap thead,
    .table-wrap thead tr,
    .table-wrap thead th {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        color: #fff !important;
    }

    .table-wrap thead th {
        position: sticky;
        top: -1px;
        z-index: 20;
        border-top: 1px solid #c46a6a;
        border-right: 1px solid #8e3b3b;
        border-bottom: 1px solid #5c0000;
        padding: 6px 5px;
        text-align: left;
        white-space: nowrap;
        font-size: 12px;
        line-height: 1.2;
        box-shadow: 0 2px 0 #6f1d1d;
    }

    .table-wrap thead th:first-child {
        border-left: 1px solid #8e3b3b;
    }

    .table-wrap tbody td {
        background: #fffafa;
        border-right: 1px solid #d8bcbc;
        border-bottom: 1px solid #d8bcbc;
        padding: 6px 5px;
        white-space: nowrap;
        vertical-align: middle;
        font-size: 12px;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.2;
        color: #111111;
        font-weight: 400;
    }

    .table-wrap tbody td:first-child {
        border-left: 1px solid #d8bcbc;
    }

    .table-wrap tbody tr:nth-child(even) td {
        background: #f9eded;
    }

    .table-wrap tbody tr:hover td {
        background: #f4dddd;
    }

.table-wrap th:nth-child(1), .table-wrap td:nth-child(1) { width: 130px; } /* Consecutivo */
.table-wrap th:nth-child(2), .table-wrap td:nth-child(2) { width: 90px; }  /* Serie */
.table-wrap th:nth-child(3), .table-wrap td:nth-child(3) { width: 90px; }  /* ClienteId */
.table-wrap th:nth-child(4), .table-wrap td:nth-child(4) { width: 320px; } /* Nombre Cliente */
.table-wrap th:nth-child(5), .table-wrap td:nth-child(5) { width: 260px; } /* Vendedor */
.table-wrap th:nth-child(6), .table-wrap td:nth-child(6) { width: 120px; } /* Kg */
.table-wrap th:nth-child(7), .table-wrap td:nth-child(7) { width: 135px; } /* Importe */
.table-wrap th:nth-child(8), .table-wrap td:nth-child(8) { width: 130px; } /* Estatus */
.table-wrap th:nth-child(9), .table-wrap td:nth-child(9) { width: 140px; } /* Fecha */

    .num {
        text-align: right !important;
        font-variant-numeric: tabular-nums;
    }

    a.ver-ov {
        color: #5a0000;
        text-decoration: none;
        font-weight: bold;
    }

    a.ver-ov:hover {
        text-decoration: underline;
        color: #7a0000;
    }

    .badge-est {
        display: inline-block;
        min-width: 115px;
        text-align: center;
        padding: 4px 8px;
        border: 1px solid transparent;
        font-size: 11px;
        font-weight: 700;
        border-radius: 2px;
        line-height: 1.2;
        white-space: nowrap;
    }

    .est-0 {
        background: #fde2e2;
        border-color: #d9534f;
        color: #b00000;
    }

    .est-1, .est-3 {
        background: #fff4cc;
        border-color: #d6b656;
        color: #7a5a00;
    }

    .est-2 {
        background: #d9ecff;
        border-color: #6fa8dc;
        color: #0b5394;
    }

    .est-4 {
        background: #dff3e2;
        border-color: #6aa84f;
        color: #2f6b1f;
    }

    .est-5 {
        background: #eadcff;
        border-color: #8e7cc3;
        color: #5b3fa3;
    }

    .est-6 {
        background: #ffe7cc;
        border-color: #e69138;
        color: #9c5700;
    }

    .statusbar {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 6px 10px;
        font-size: 11px;
        color: #4a1a1a;
        border-top: 1px solid #b88c8c;
        background: linear-gradient(#f6e9e9, #ead5d5);
        flex-wrap: wrap;
    }

    .dropdown-menu {
        font-size: 12px !important;
        border-radius: 0 !important;
        border: 1px solid #b48787 !important;
        background: #fffafa !important;
    }

    .btn-select-like {
        display: flex !important;
        align-items: center;
        justify-content: space-between;
        background: #fff !important;
        cursor: pointer;
        height: 28px !important;
        border: 1px solid #b48787 !important;
        padding: 3px 6px !important;
        color: #421414 !important;
    }

    .btn-select-like::after {
        content: "▼";
        font-size: 10px;
        color: #7a3a3a;
    }

    /* =========================
       MODAL OV AJUSTADO
       ========================= */

   #ovModal .modal-dialog.modal-ov-wide {
    max-width: 84vw !important;
    width: 84vw !important;
    margin: .75rem auto !important;
}

#ovModal .modal-body {
    background: #f4e4e4;
    padding: 8px;
    max-height: 78vh;
    overflow-y: auto;
    overflow-x: hidden;
}

    #ovModal .modal-content {
        border: 1px solid #7d4949;
        border-radius: 0;
    }

    #ovModal .modal-header {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #5c0000;
        color: #fff;
        padding: 7px 10px;
    }

    #ovModal .modal-title {
        font-size: 13px;
        font-weight: bold;
    }

    #ovModal .modal-body {
        background: #f4e4e4;
        padding: 8px;
        max-height: 82vh;
        overflow-y: auto;
        overflow-x: hidden;
    }

    #ovModal .modal-footer {
        padding: 8px 10px;
        border-top: 1px solid #c9a3a3;
        background: #fffafa;
    }

    #ovModal .btn-close {
        transform: scale(.9);
    }

   #ovModal .header-row {
    display: grid;
    grid-template-columns: 1.6fr 1.4fr 1fr 1.3fr;
    gap: 8px 10px;
    padding: 8px 10px;
    background: #fffafa;
    border: 1px solid #d3b0b0;
    margin-bottom: 8px;
    align-items: start;
}

#ovModal .header-row > div {
    min-width: 0;
    padding: 4px 6px;
    background: transparent;
    border: none;
}

#ovModal .header-row strong {
    display: block;
    margin-bottom: 3px;
    font-size: 11px;
    line-height: 1.1;
    color: #7a0000;
    font-weight: 700;
    text-transform: uppercase;
}

#ovModal .header-row span,
#ovModal .header-row select,
#ovModal .header-row input {
    font-size: 12px !important;
    line-height: 1.2;
}

#ovModal .header-row span {
    white-space: normal;
    overflow: visible;
    text-overflow: unset;
    word-break: break-word;
}

#ovModal .ov-col-4,
#ovModal .ov-col-3,
#ovModal .ov-col-2,
#ovModal .ov-col-6,
#ovModal .ov-col-12 {
    grid-column: span 1;
}

#ovModal .ov-col-obs {
    grid-column: 1 / -1;
    padding-top: 2px;
}

#ovModal #ovm-serie {
    width: 100% !important;
