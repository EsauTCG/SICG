    </tr>
</thead>
                        <tbody>
                            @if (Model?.Resultados != null && Model.Resultados.Any())
                            {
                                var idx = 0;
                                foreach (var r in Model.Resultados)
                                {
                                    <tr data-index="@idx">
                                        <td>
                                            <a href="#"
                                                   class="ver-ov"
                                                   data-id="@(r?.Id)"
                                                   data-cons="@(r?.Consecutivo ?? "")">
                                                @(r?.Consecutivo ?? "")
                                            </a>
                                        </td>
                                       <td class="td-serie">@(r?.Serie ?? "")</td>
<td>@(r?.Cliente ?? "")</td>
<td>@(r?.ClienteNombre ?? "")</td>
<td>@(r?.Vendedor ?? "")</td>
                                        <td class="num">@string.Format("{0:N2} kg", r?.KgTotales ?? 0m)</td>
                                        <td class="num">@((r?.Importe ?? 0m).ToString("C"))</td>
                                        <td>
                                            @{
                                                var estVal = r?.Estatus ?? -1;
                                                var estClass = estVal == 0 ? "est-0"
                                                : (estVal == 1 || estVal == 3) ? "est-1"
                                                : estVal == 2 ? "est-2"
                                                : estVal == 4 ? "est-4"
                                                : estVal == 5 ? "est-5"
                                                : estVal == 6 ? "est-6" : "";

                                                var texto =
                                                estVal == 0 ? "Cancelado" :
                                                (estVal == 1 || estVal == 3) ? "Pendiente" :
                                                estVal == 2 ? "Autorización" :
                                                estVal == 4 ? "Validado" :
                                                estVal == 5 ? "Enviado a SAP" :
                                                estVal == 6 ? "Logistica" : "Otro";

                                                if (estVal == 2 && !string.IsNullOrWhiteSpace(r?.AutorizacionPendiente))
                                                {
                                                    texto += $" ({r.AutorizacionPendiente})";
                                                }
                                            }
                                            <span class="badge-est @estClass">@texto</span>
                                        </td>
                                        <td>@(r?.FechaEntrega?.ToString("yyyy-MM-dd") ?? "")</td>
                                    </tr>
                                    idx++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center text-muted">Sin resultados.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
