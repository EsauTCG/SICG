                   document.getElementById('ovm-serie').addEventListener('change', async function () {
            if (!ordenIdActual) return;

            const select = this;
            const nuevaSerieId = select.value;
            const serieAnterior = select.getAttribute('data-prev') ?? '';

            // 🔐 Confirmación
            const ok = confirm('¿Estás seguro de que deseas actualizar la serie de esta orden?');
            if (!ok) {
                // 🔄 Revertir selección
                select.value = serieAnterior;
                return;
            }

            const token = getAntiForgeryToken();

            try {
                const resp = await fetch('/Comercial/ActualizarSerieOV', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: `ordenVentaId=${ordenIdActual}&serieId=${nuevaSerieId}`
                });

                const json = await resp.json();

                if (!resp.ok || json.ok === false) {
                    showMsg('danger', json.msg || 'Error al actualizar serie');
                    select.value = serieAnterior; // rollback
                    return;
                }

                // ✅ Guardar nueva como previa
                select.setAttribute('data-prev', nuevaSerieId);

                // (opcional) actualizar texto visible
                const lblSerie = document.getElementById('ovm-serie-text');
                if (lblSerie && json.serieNombre) {
                    lblSerie.textContent = json.serieNombre;
                }

                // (opcional) actualizar listado
                const link = document.querySelector(`a.ver-ov[data-id="${ordenIdActual}"]`);
                if (link) {
                    const tr = link.closest('tr');
                    const tdSerie = tr ? tr.querySelector('.td-serie') : null;
                    if (tdSerie && json.serieNombre) {
                        tdSerie.textContent = json.serieNombre;
                    }
                }

                showMsg('success', 'Serie actualizada correctamente.');
                setTimeout(() => showMsg(), 2000);

            } catch (e) {
                console.error(e);
                showMsg('danger', 'Error de red al actualizar serie.');
                select.value = serieAnterior; // rollback
            }
        });

    </script>
}
