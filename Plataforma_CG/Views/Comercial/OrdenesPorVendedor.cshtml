}

#ovModal .ov-col-4,
#ovModal .ov-col-3,
#ovModal .ov-col-2,
#ovModal .ov-col-6,
#ovModal .ov-col-12 {
    grid-column: span 1;
}

#ovModal .ov-col-12-full {
    grid-column: 1 / -1;
}

#ovModal #ovm-serie {
    width: 100% !important;
}

#ovModal #ovm-entrega-actions {
