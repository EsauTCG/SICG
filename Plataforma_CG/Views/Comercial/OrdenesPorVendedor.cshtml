       function initMultiDropdown(rootId, checkClass, hiddenContainerId, hiddenName) {
    const root = document.getElementById(rootId);
    if (!root) return null;

    const labelSpan = root.querySelector('.multi-label');
    const checks = root.querySelectorAll('.' + checkClass);
    const hidden = document.getElementById(hiddenContainerId);

    function refresh() {
        if (!hidden) return;

        hidden.innerHTML = "";

        const texts = [];
        checks.forEach(ch => {
            if (ch.checked) {
                texts.push(ch.getAttribute('data-text') || ch.value);

                const inp = document.createElement('input');
                inp.type = 'hidden';
                inp.name = hiddenName;
                inp.value = ch.value;
                hidden.appendChild(inp);
            }
        });

        if (labelSpan) {
            if (texts.length === 0) {
                labelSpan.textContent = '(Todos)';
            } else if (texts.length <= 3) {
                labelSpan.textContent = texts.join(', ');
            } else {
                labelSpan.textContent = texts.length + ' seleccionados';
            }
        }
    }

    checks.forEach(ch => {
        ch.addEventListener('change', refresh);
    });

    refresh();

    return { refresh };
}

