                                            <span>Validado</span>
                                        </label>

                                        <label class="multi-picker-option">
                                            <input class="multi-check-estatus"
                                                   type="checkbox"
                                                   value="5"
                                                   id="est_5"
                                                   data-text="Enviado a SAP"
                                            @(ests.Contains(5) ? "checked" : null) />
                                            <span>Enviado a SAP</span>
                                        </label>

                                        <label class="multi-picker-option">
                                            <input class="multi-check-estatus"
                                                   type="checkbox"
                                                   value="6"
                                                   id="est_6"
                                                   data-text="Logistica"
                                            @(ests.Contains(6) ? "checked" : null) />
                                            <span>Logistica</span>
                                        </label>
                                    </div>
                                </div>

                                <div id="dd-estatus-hidden">
                                    @foreach (var e in ests)
                                    {
                                        <input type="hidden" name="EstatusSeleccionados" value="@e" />
                                    }
                                </div>
                            </div>
