@section Scripts {
    <script>
        // ========= utilidades =========
        function getAntiForgeryToken(){
            const el = document.querySelector('input[name="__RequestVerificationToken"]');
            return el ? el.value : '';
        }
        function estatusTexto(h) {
            let base =
                h.estatus === 0 ? "Cancelado" :
                (h.estatus === 1 || h.estatus === 3) ? "Pendiente" :
                h.estatus === 2 ? "Autorización" :
                h.estatus === 4 ? "Validado" :
