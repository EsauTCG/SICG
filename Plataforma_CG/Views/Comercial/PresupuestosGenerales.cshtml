        // 4) Consultar: usa el builder nuevo y manda rows (no porSku)
        async function cliConsultar() {
          const ids = cliGetSelectedClientIds();
          if (!ids.length) {
            showToast("Selecciona al menos 1 cliente (individual o lista).", "warning");
            return;
          }

          try {
