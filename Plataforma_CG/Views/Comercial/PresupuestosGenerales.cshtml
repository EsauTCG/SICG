            function cliRenderList(list) {
              const wrap = document.getElementById("cliListaClientes");
              if (!wrap) return;

              if (!list.length) {
                wrap.innerHTML = `<div class="text-muted p-2">No hay clientes con esos filtros.</div>`;
                return;
              }

              wrap.innerHTML = list.map(c => {
                const label = `${escapeHtml(c.id)}${c.nom ? " - " + escapeHtml(c.nom) : ""}`;
                const meta = [c.canal, c.clas, c.vend].filter(Boolean).map(escapeHtml).join(" · ");
                return `
                  <label class="d-flex align-items-start gap-2 border-bottom py-2">
                    <input class="form-check-input mt-1 cliChk" type="checkbox" value="${escapeHtml(c.id)}">
                    <span>
                      <div class="fw-semibold">${label}</div>
                      ${meta ? `<div class="text-muted" style="font-size:.82rem">${meta}</div>` : ``}
                    </span>
                  </label>
                `;
              }).join("");
            }

            function _N(x){ return String(x ?? "").trim().toUpperCase(); }

            function cliApplyFiltersLocal() {
              const q = String($("#cliBuscarLista").val() || "").trim().toLowerCase();
              const canal = _N($("#cliCanal").val() || "");
              const clas  = _N($("#cliClasificacion").val() || "");
              const vends = ($("#cliVendedores").val() || []).map(_N);

              const hasMeta = (_cliAll || []).some(c => (c.canal || c.clas || c.vend));

              _cliFiltered = (_cliAll || []).filter(c => {
                if (hasMeta) {
                  if (canal && _N(c.canal) !== canal) return false;
                  if (clas  && _N(c.clas)  !== clas)  return false;
                  if (vends.length && !vends.includes(_N(c.vend))) return false;
                }

                if (q) {
                  const bag = (String(c.id) + " " + String(c.nom)).toLowerCase();
                  if (!bag.includes(q)) return false;
                }
                return true;
              });

              cliRenderList(_cliFiltered);
            }

            function cliSetupAutocomplete() {
              const input = $("#cliClienteIndividual");
              if (!input.length || !$.fn.autocomplete) return;

              const src = (_cliAll || []).map(c => ({
                label: `${c.id}${c.nom ? " - " + c.nom : ""}`,
                value: `${c.id}${c.nom ? " - " + c.nom : ""}`,
                id: c.id
              }));

              input.autocomplete({
                minLength: 2,
                source: (req, res) => {
                  const t = String(req.term || "").toLowerCase();
                  res(src.filter(x => x.label.toLowerCase().includes(t)).slice(0, 50));
                },
                select: (e, ui) => {
                  $("#cliClienteIndividualId").val(ui.item.id);
                }
              });

              input.on("input", function () {
                if (!this.value) $("#cliClienteIndividualId").val("");
              });
            }

