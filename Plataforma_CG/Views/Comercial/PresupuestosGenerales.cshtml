/* ============================================================
   UX EJECUTIVO - PRESUPUESTOS CEDIS / VENDEDOR / CLIENTE
   IMPORTANTE:
   - No cambia endpoints.
   - No cambia funciones JS.
   - No cambia IDs.
   - No cambia nombres de inputs ni formularios.
   Solo mejora lectura, jerarquía visual y operación.
============================================================ */

:root {
    --pp-bg: #f3f4f6;
    --pp-surface: #ffffff;
    --pp-surface-soft: #f9fafb;
    --pp-ink: #111827;
    --pp-muted: #6b7280;
    --pp-border: #e5e7eb;
    --pp-brand: #8B0000;
    --pp-brand-dark: #450a0a;
    --pp-brand-mid: #7f1d1d;
    --pp-brand-soft: #fff1f2;
    --pp-blue-soft: #eff6ff;
    --pp-blue-border: #bfdbfe;
    --pp-blue-ink: #1e3a8a;
    --pp-warn-soft: #fffbeb;
    --pp-warn-border: #fde68a;
    --pp-warn-ink: #92400e;
    --pp-ok-soft: #ecfdf5;
    --pp-ok-border: #bbf7d0;
    --pp-ok-ink: #166534;
    --pp-radius-lg: 18px;
    --pp-radius-md: 14px;
    --pp-radius-sm: 10px;
    --pp-shadow: 0 18px 44px rgba(17, 24, 39, .10);
    --pp-shadow-sm: 0 10px 24px rgba(17, 24, 39, .08);
}

html,
body,
main,
.main,
.body-content,
.container,
.container-fluid {
    background: var(--pp-bg) !important;
    color: var(--pp-ink) !important;
}

body {
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif !important;
}

.container-fluid {
    padding-left: 14px !important;
    padding-right: 14px !important;
}

.shell {
    width: 100% !important;
    max-width: 1850px !important;
    margin: 10px auto 18px !important;
    border: 0 !important;
    border-radius: var(--pp-radius-lg) !important;
    background: transparent !important;
    box-shadow: none !important;
    overflow: visible !important;
}

.module-titlebar {
    position: relative;
    overflow: hidden;
    border: 0 !important;
    border-radius: var(--pp-radius-lg) var(--pp-radius-lg) 0 0 !important;
    padding: 20px 22px !important;
    background:
        radial-gradient(circle at top right, rgba(255,255,255,.22), transparent 30%),
        linear-gradient(135deg, #991b1b 0%, #7f1d1d 46%, #450a0a 100%) !important;
    box-shadow: var(--pp-shadow) !important;
}

.module-titlebar::before {
    content: "Control comercial";
    position: absolute;
    left: 22px;
    top: 10px;
    color: #fecaca;
    font-size: 11px;
    font-weight: 950;
    text-transform: uppercase;
    letter-spacing: .14em;
}

.module-titlebar > div:first-child {
    margin-top: 16px;
}

.module-title {
    color: #ffffff !important;
    font-size: clamp(1.35rem, 1.1vw + 1rem, 2rem) !important;
    line-height: 1.05 !important;
    font-weight: 950 !important;
    gap: 10px !important;
}

.module-title i {
    width: 42px;
    height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,.14);
    border: 1px solid rgba(255,255,255,.22);
    border-radius: 999px;
}

.module-subtitle {
    color: rgba(255,255,255,.84) !important;
    font-size: 13px !important;
    margin-top: 6px !important;
}

.module-titlebar .d-flex.align-items-center {
    gap: 10px !important;
    flex-wrap: wrap;
    justify-content: flex-end;
}

.modo-pill {
    border-radius: var(--pp-radius-md) !important;
    background: rgba(255,255,255,.14) !important;
    border: 1px solid rgba(255,255,255,.24) !important;
    box-shadow: none !important;
    padding: 10px !important;
}

.modo-title {
    color: #ffffff !important;
    font-size: 11px !important;
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: 6px;
}

#modoPresupuestoBox .btn {
    border-radius: 999px !important;
    min-height: 34px;
    font-weight: 900 !important;
}

#modoPresupuestoBox .btn.active {
    background: #ffffff !important;
    color: var(--pp-brand) !important;
}

.module-titlebar .tbtn {
    min-height: 40px !important;
    border-radius: 999px !important;
    padding: 0 15px !important;
    background: rgba(255,255,255,.12) !important;
    color: #ffffff !important;
    border: 1px solid rgba(255,255,255,.28) !important;
    box-shadow: none !important;
}

.module-titlebar .tbtn:hover {
    background: rgba(255,255,255,.20) !important;
    color: #ffffff !important;
}

.pp-workflow {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    background: #ffffff;
    border: 1px solid var(--pp-border);
    border-top: 0;
    padding: 12px;
    box-shadow: var(--pp-shadow-sm);
}

.pp-step-card {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    background: var(--pp-surface-soft);
    border: 1px solid var(--pp-border);
    border-radius: var(--pp-radius-md);
    padding: 12px;
}

.pp-step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: var(--pp-brand);
    color: #ffffff;
    font-weight: 950;
}

.pp-step-title {
    display: block;
    color: var(--pp-ink);
    font-size: 13px;
    font-weight: 950;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.pp-step-help {
    display: block;
    color: var(--pp-muted);
    font-size: 11px;
    line-height: 1.15;
}

.content,
.tab-content {
    background: #ffffff !important;
}

.content {
    border: 1px solid var(--pp-border);
    border-top: 0;
    border-radius: 0 0 var(--pp-radius-lg) var(--pp-radius-lg);
    box-shadow: var(--pp-shadow);
    overflow: hidden;
}

.content > .p-3:first-child {
    background: #ffffff !important;
    padding: 12px 16px !important;
    border-bottom: 1px solid var(--pp-border);
}

#alertsZone .alert {
    margin-bottom: 0 !important;
    border-radius: var(--pp-radius-md) !important;
}

.nav-tabs {
    display: flex;
    gap: 8px;
    border: 0 !important;
    background: #ffffff !important;
    padding: 12px 16px 0 !important;
    overflow-x: auto;
}

.nav-tabs .nav-link {
    min-height: 42px;
    border: 1px solid var(--pp-border) !important;
    border-radius: 999px !important;
    background: var(--pp-surface-soft) !important;
    color: #374151 !important;
    font-weight: 950 !important;
    padding: 0 16px !important;
    white-space: nowrap;
}

.nav-tabs .nav-link.active {
    background: linear-gradient(180deg, #b30000 0%, #8b0000 58%, #6e0000 100%) !important;
    color: #ffffff !important;
    border-color: #7f1d1d !important;
    box-shadow: 0 10px 20px rgba(139,0,0,.16);
}

.tab-content {
    padding: 16px !important;
}

.toolbar {
    background: var(--pp-surface-soft) !important;
    border: 1px solid var(--pp-border) !important;
    border-radius: var(--pp-radius-md) !important;
    padding: 10px !important;
    gap: 8px !important;
}

.tbtn,
.btn-outline-secondary {
    min-height: 38px !important;
    border-radius: 999px !important;
    border: 1px solid #d1d5db !important;
    background: #ffffff !important;
    color: #374151 !important;
    font-weight: 950 !important;
    font-size: 12px !important;
    padding: 0 14px !important;
    box-shadow: none !important;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
}

.tbtn:hover,
.btn-outline-secondary:hover {
    background: #f9fafb !important;
    color: #111827 !important;
}

.tbtn.primary,
.btn-danger {
    background: linear-gradient(180deg, #b30000 0%, #8b0000 58%, #6e0000 100%) !important;
    border-color: #7f1d1d !important;
    color: #ffffff !important;
}

.tbtn.primary:hover,
.btn-danger:hover {
    filter: brightness(1.06);
    color: #ffffff !important;
}

.panel {
    border: 1px solid var(--pp-border) !important;
    border-radius: var(--pp-radius-lg) !important;
    background: var(--pp-surface) !important;
    box-shadow: var(--pp-shadow-sm) !important;
    overflow: hidden;
}

.panel-head {
    min-height: 54px;
    background: #ffffff !important;
    color: var(--pp-ink) !important;
    border-bottom: 1px solid var(--pp-border) !important;
    padding: 14px 16px !important;
    font-size: 14px !important;
    font-weight: 950 !important;
}

.panel-head i {
    color: var(--pp-brand) !important;
}

.panel-body {
    background: #ffffff !important;
    padding: 16px !important;
}

.form-label,
.sap-field label {
    color: #374151 !important;
    font-size: 11px !important;
    font-weight: 950 !important;
    text-transform: uppercase;
    letter-spacing: .04em;
}

.form-control,
.form-select,
.input-group-text {
    min-height: 38px !important;
    height: auto !important;
    border-radius: var(--pp-radius-sm) !important;
    border: 1px solid #d1d5db !important;
    background: #ffffff !important;
    color: var(--pp-ink) !important;
    font-size: 13px !important;
    padding: 7px 10px !important;
    box-shadow: none !important;
}

.form-control:focus,
.form-select:focus {
    border-color: var(--pp-brand) !important;
    box-shadow: 0 0 0 .2rem rgba(139,0,0,.12) !important;
}

.form-text {
    color: var(--pp-muted) !important;
    font-size: 12px !important;
}

hr {
    border-color: var(--pp-border) !important;
    opacity: 1 !important;
}

.alert-light,
.alert {
    border-radius: var(--pp-radius-md) !important;
}

.table-responsive-sticky,
.table-wrapper {
    width: 100% !important;
    max-width: 100% !important;
    background: #ffffff !important;
    border: 0 !important;
    border-radius: 0 !important;
    overflow: auto !important;
    max-height: 65vh !important;
}

.table {
    background: #ffffff !important;
    color: var(--pp-ink) !important;
    font-size: 12px !important;
    border-collapse: separate !important;
    border-spacing: 0 !important;
}

#tablaCedis,
#tablaVendedor,
#tablaCliente {
    width: max-content !important;
    min-width: 1150px !important;
}

.table thead,
.table thead th {
    position: sticky;
    top: 0;
    z-index: 20;
    background: #7f1d1d !important;
    color: #ffffff !important;
    border-color: #7f1d1d !important;
    padding: 10px 8px !important;
    font-size: 11px !important;
    font-weight: 950 !important;
    text-transform: uppercase;
    letter-spacing: .035em;
}

.table tbody td {
    background: #ffffff !important;
    border-color: var(--pp-border) !important;
    color: #1f2937 !important;
    padding: 8px !important;
    vertical-align: middle !important;
}

.table tbody tr:nth-of-type(even) > * {
    background: #fafafa !important;
}

.table-hover tbody tr:hover > * {
    background: #fff7ed !important;
}

.table input.form-control,
.table .form-control-sm {
    min-height: 34px !important;
    font-weight: 800;
}

.table .btn {
    border-radius: 999px !important;
    min-height: 32px !important;
    font-weight: 900 !important;
}

.totales-sap {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 18px !important;
    background: var(--pp-surface-soft) !important;
    border-top: 1px solid var(--pp-border) !important;
    color: var(--pp-ink) !important;
    padding: 12px 14px !important;
    font-size: 13px !important;
}

.totales-sap span {
    color: var(--pp-brand);
    font-weight: 950;
}

#cliListaClientes {
    background: #ffffff !important;
}

#pane-cli .border.rounded-3 {
    border-color: var(--pp-border) !important;
    border-radius: var(--pp-radius-md) !important;
    background: #ffffff !important;
}

#loadingSpinnerCedis {
    background: rgba(255,255,255,.72) !important;
    backdrop-filter: blur(2px);
}

/* Modales */
.modal-content {
    border: 0 !important;
    border-radius: var(--pp-radius-lg) !important;
    box-shadow: 0 24px 70px rgba(17,24,39,.24) !important;
    overflow: hidden;
}

.modal-header {
    background:
        radial-gradient(circle at top right, rgba(255,255,255,.18), transparent 30%),
        linear-gradient(135deg, #991b1b 0%, #7f1d1d 48%, #450a0a 100%) !important;
    border: 0 !important;
    padding: 16px 18px !important;
}

.modal-title {
    color: #ffffff !important;
    font-size: 15px !important;
    font-weight: 950 !important;
}

.modal-body {
    background: #ffffff !important;
    color: var(--pp-ink) !important;
}

.modal-footer {
    background: #f9fafb !important;
    border-top: 1px solid var(--pp-border) !important;
}

/* Dark mode */
body[data-theme="dark"],
body[data-theme="dark"] html,
body[data-theme="dark"] main,
body[data-theme="dark"] .main,
body[data-theme="dark"] .body-content,
body[data-theme="dark"] .container,
body[data-theme="dark"] .container-fluid {
    background: #0f172a !important;
    color: #e5e7eb !important;
}

body[data-theme="dark"] .content,
body[data-theme="dark"] .tab-content,
body[data-theme="dark"] .panel,
body[data-theme="dark"] .panel-body,
body[data-theme="dark"] .content > .p-3:first-child,
body[data-theme="dark"] .pp-workflow,
body[data-theme="dark"] .modal-body {
    background: #111827 !important;
    color: #e5e7eb !important;
    border-color: rgba(255,255,255,.12) !important;
}

body[data-theme="dark"] .pp-step-card,
body[data-theme="dark"] .toolbar,
body[data-theme="dark"] .nav-tabs .nav-link,
body[data-theme="dark"] .totales-sap,
body[data-theme="dark"] .modal-footer,
body[data-theme="dark"] #pane-cli .border.rounded-3 {
    background: #172033 !important;
    color: #e5e7eb !important;
    border-color: rgba(255,255,255,.12) !important;
}

body[data-theme="dark"] .pp-step-title,
body[data-theme="dark"] .panel-head,
body[data-theme="dark"] .form-label {
    color: #f9fafb !important;
}

body[data-theme="dark"] .pp-step-help,
body[data-theme="dark"] .form-text,
body[data-theme="dark"] .text-muted {
    color: #cbd5e1 !important;
}

body[data-theme="dark"] .panel-head {
    background: #111827 !important;
    border-color: rgba(255,255,255,.12) !important;
}

body[data-theme="dark"] .form-control,
body[data-theme="dark"] .form-select,
body[data-theme="dark"] .input-group-text {
    background: #0b1220 !important;
    color: #f9fafb !important;
    border-color: rgba(203,213,225,.28) !important;
}

body[data-theme="dark"] .table-responsive-sticky,
body[data-theme="dark"] .table-wrapper,
body[data-theme="dark"] .table,
body[data-theme="dark"] .table tbody td {
    background: #111827 !important;
    color: #e5e7eb !important;
    border-color: rgba(255,255,255,.12) !important;
}

body[data-theme="dark"] .table tbody tr:nth-of-type(even) > * {
    background: #172033 !important;
}

body[data-theme="dark"] .table-hover tbody tr:hover > * {
    background: rgba(248,113,113,.13) !important;
}

body[data-theme="dark"] .tbtn,
body[data-theme="dark"] .btn-outline-secondary {
    background: #0b1220 !important;
    color: #e5e7eb !important;
    border-color: rgba(203,213,225,.28) !important;
}

body[data-theme="dark"] .totales-sap span {
    color: #fca5a5;
}

/* Responsive */
@@media (max-width: 1200px) {
    .pp-workflow {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .module-titlebar {
        display: grid !important;
        gap: 12px;
    }

    .module-titlebar .d-flex.align-items-center {
        justify-content: flex-start !important;
    }
}

@@media (max-width: 768px) {
    .container-fluid {
        padding-left: 0 !important;
        padding-right: 0 !important;
    }

    .shell {
        margin: 0 !important;
        border-radius: 0 !important;
    }

    .module-titlebar {
        border-radius: 0 !important;
        padding: 16px !important;
    }

    .pp-workflow {
        grid-template-columns: 1fr;
        border-left: 0;
        border-right: 0;
    }

    .content {
        border-left: 0;
        border-right: 0;
        border-radius: 0;
    }

    .tab-content {
        padding: 8px !important;
    }

    .toolbar {
        display: grid !important;
        grid-template-columns: 1fr !important;
    }

    .tbtn,
    .btn,
    .form-control,
    .form-select,
    .modo-pill {
        width: 100% !important;
    }

    #pane-cedis .col-xl-3,
    #pane-cedis .col-xl-9,
    #pane-ven .col-xl-3,
    #pane-ven .col-xl-9,
    #pane-cli .col-xl-4,
    #pane-cli .col-xl-8 {
        width: 100% !important;
        max-width: 100% !important;
        flex: 0 0 100% !important;
    }

    .table-responsive-sticky,
    .table-wrapper {
        max-height: 65vh !important;
    }

    #tablaCedis,
    #tablaVendedor,
    #tablaCliente {
        min-width: 1050px !important;
        font-size: 10px !important;
    }

    .totales-sap {
        display: grid !important;
        justify-content: stretch !important;
    }
}

</style>






<div class="container-fluid">
    <div class="shell">
        <div class="module-titlebar">
            <div>
                <h5 class="module-title"><i class="bi bi-graph-up-arrow"></i> Presupuestos</h5>

                <p class="module-subtitle" style="color: white;">
                    Presupuestos Cliente, Vendedor y Cedis.
                </p>

            </div>

            <div class="d-flex align-items-center" style="gap:.6rem">

          
         
                    <div id="modoPresupuestoBox" class="modo-pill">
                    <center><div class="modo-title">Modo Presupuesto</div></center>

                        <div class="btn-group btn-group-sm" role="group" aria-label="Modo Presupuesto">
                            <button type="button" class="btn btn-light" data-modo="VENDEDOR">
                                <i class="bi bi-person-badge me-1"></i>Vendedor
                            </button>
                            <button type="button" class="btn btn-light" data-modo="CLIENTE">
                                <i class="bi bi-people me-1"></i>Cliente
                            </button>
                        </div>                   
                    </div>
                <button type="button" id="btnAdminPres" class="tbtn">
                    <i class="bi bi-shield-lock"></i><span>Administrar</span>
                </button>
              

                <button type="button" class="tbtn" onclick="window.location='/Home/inicio'">
                    <i class="bi bi-x-lg"></i><span>Salir</span>
                </button>
            </div>
        </div>


        <div class="pp-workflow" aria-label="Guía de trabajo de presupuestos">
            <div class="pp-step-card">
                <span class="pp-step-num">1</span>
                <span>
                    <span class="pp-step-title">Elige el módulo</span>
                    <span class="pp-step-help">Trabaja por CEDIS, vendedor o cliente.</span>
                </span>
            </div>
            <div class="pp-step-card">
                <span class="pp-step-num">2</span>
                <span>
                    <span class="pp-step-title">Carga ventas</span>
                    <span class="pp-step-help">Calcula objetivo según la ventana de meses.</span>
                </span>
            </div>
            <div class="pp-step-card">
                <span class="pp-step-num">3</span>
                <span>
                    <span class="pp-step-title">Ajusta presupuesto</span>
                    <span class="pp-step-help">Modifica SKU, participación y comentarios.</span>
                </span>
            </div>
            <div class="pp-step-card">
                <span class="pp-step-num">4</span>
                <span>
                    <span class="pp-step-title">Guarda / exporta</span>
                    <span class="pp-step-help">Valida totales y genera Excel o plantilla.</span>
                </span>
            </div>
        </div>


        <div class="content">
            <div class="p-3">
                <div id="alertsZone"></div>
            </div>

            <!-- Tabs -->
            <ul class="nav nav-tabs" id="presTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="tab-cedis" data-bs-toggle="tab" data-bs-target="#pane-cedis" type="button" role="tab">
                        <i class="bi bi-building me-1"></i> Cedis
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-ven" data-bs-toggle="tab" data-bs-target="#pane-ven" type="button" role="tab">
                        <i class="bi bi-person-badge me-1"></i> Vendedor
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-cli" data-bs-toggle="tab" data-bs-target="#pane-cli" type="button" role="tab">
                        <i class="bi bi-people me-1"></i> Cliente
                    </button>
                </li>
            </ul>

            <div class="tab-content p-3">
                <!-- ============================== -->
                <!-- ============ CEDIS =========== -->
                <!-- ============================== -->
                <div class="tab-pane fade show active" id="pane-cedis" role="tabpanel" aria-labelledby="tab-cedis">

                    <div class="toolbar align-items-center mb-3">
                        <button type="button" id="btnAgregar" class="tbtn">
                            <i class="bi bi-plus-circle"></i><span>Cargar ventas</span>
                        </button>
                     

                        <button type="button" id="btnExportarXlsx" class="tbtn">
                            <i class="bi bi-file-earmark-spreadsheet"></i><span>Exportar Excel</span>
                        </button>

                        <button type="button" id="btnImportarXlsx" class="tbtn">
                            <i class="bi bi-upload"></i><span>Importar Excel</span>
                        </button>

                        <button type="button" id="btnPlantillaXlsx" class="tbtn">
                            <i class="bi bi-file-earmark-arrow-down"></i><span>Plantilla</span>
                        </button>
                       

                        <input type="file" id="fileExcelCedis" accept=".xlsx,.xls" style="display:none" />

                        <div class="ms-auto"></div>

                        <button type="button" id="btnAbrirModalGuardar" class="tbtn primary">
                            <i class="bi bi-save"></i><span>Guardar</span>
                        </button>
                    </div>
                  

                    <form id="frmPresupuestoCedis" asp-controller="Comercial" asp-action="GuardarPresupuestoCedis" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" id="CanalInput" name="Canal" />
                        <input type="hidden" id="MesInput" name="Mes" />
                        <input type="hidden" id="AnioInput" name="Anio" />

                        <div class="row g-3">
                            <div class="col-xl-3 col-lg-4">
                                <div class="panel h-100">
                                    <div class="panel-head"><i class="bi bi-filter-circle"></i> Filtros</div>
                                    <div class="panel-body">
                                        <label class="form-label fw-semibold">CEDIS</label>
                                        <select id="selCanal" class="form-select"><option value="">Selecciona CEDIS</option></select>

                                        <div class="mt-3">
                                            <label class="form-label fw-semibold">Meses para objetivo</label>
                                            <select id="filtroMesesObjetivo" class="form-select">
                                                <option value="4">Últimos 4</option>
                                                <option value="8">Últimos 8</option>
                                                <option value="12" selected>Últimos 12</option>
                                            </select>
                                            <div class="form-text">Se promedia por SKU en la ventana seleccionada.</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-9 col-lg-8">
                                <div class="panel h-100">
                                    <div class="panel-head"><i class="bi bi-collection"></i> Totales por SKU (CEDIS)</div>
                                    <div class="panel-body p-0">
                                        <div class="table-responsive-sticky">
                                            <!-- aquí el scroll -->
                                            <table class="table table-sm table-hover align-middle mb-0" id="tablaCedis">
                                                <thead>
                                                    <tr>
                                                        <th>SKU</th>
                                                        <th class="text-end">Objetivo</th>
                                                        <th class="text-end">Presupuesto</th>
                                                        <th class="text-end">Participación</th>
                                                        <th class="text-center">Comentario</th>
                                                        <th style="width:44px;"></th>
                                                    </tr>
                                                </thead>
                                                <tbody id="tbodyCedis"></tbody>
                                            </table>
                                        </div>
                                        <div class="d-flex justify-content-end gap-4 totales-sap">
                                            <div class="fw-semibold">Total Objetivo: <span id="totObj" class="ms-1"></span></div>
                                            <div class="fw-semibold">Total Presupuesto: <span id="totPre" class="ms-1"></span></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- ================================= -->
                <!-- ============ VENDEDOR ============ -->
                <!-- ================================= -->
                <div class="tab-pane fade" id="pane-ven" role="tabpanel" aria-labelledby="tab-ven">

                    <div class="toolbar align-items-center mb-3">
                        <button type="button" id="btnCargarVendedor" class="tbtn">
                            <i class="bi bi-download"></i><span>Cargar ventas</span>
                        </button>

                        <button type="button" id="btnExportarXlsxVen" class="tbtn">
