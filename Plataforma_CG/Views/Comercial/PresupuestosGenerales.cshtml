            async function cargarCanales() {
              const $sel = $("#selCanal").empty().append('<option value="">Selecciona CEDIS</option>');
              try {
                toggleSpin(true);
                const r = await fetch(API.canales, { credentials: 'same-origin' });
                const data = r.ok ? await r.json() : [];
                (data || [])
                  .filter(c => /^CEDIS/i.test(c))
                  .sort((a, b) => String(a).localeCompare(String(b)))
                  .forEach(c => $sel.append(`<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`));
              } catch {
                showToast("Error al cargar CEDIS.", "danger");
              } finally {
                toggleSpin(false);
              }
            }

            async function traerVentas() {
              const canal = $("#selCanal").val() || '';
              const meses = parseInt($("#filtroMesesObjetivo").val() || "12", 10);
              if (!canal) { showToast("Selecciona un CEDIS.", "warning"); return null; }

              const url = `${API.datos}?canal=${encodeURIComponent(canal)}&meses=${meses}`;
              try {
                toggleSpin(true);
                const r = await fetch(url, { credentials: 'same-origin' });
                if (!r.ok) throw 0;
                const data = await r.json();

                if (!Array.isArray(data) || !data.length) {
                  showToast("Sin datos del CEDIS.", "warning");
                  return null;
                }

                const refs = buildMonthRefs(meses), porSku = {};
                data.forEach(d => {
                  const sku = d.sku;
                  if (!sku) return;
                  const f = new Date(d.fecha);
                  const ym = `${f.getFullYear()}-${String(f.getMonth() + 1).padStart(2, '0')}`;
                  porSku[sku] = porSku[sku] || { porMes: {}, objetivo: 0 };
                  porSku[sku].porMes[ym] = (porSku[sku].porMes[ym] || 0) + Number(d.totalKilos || 0);
                });

                Object.keys(porSku).forEach(s => {
                  const sum = refs.reduce((a, r) => a + (porSku[s].porMes[r.key] || 0), 0);
                  porSku[s].objetivo = Math.round(sum / Math.max(1, meses));
                });

                return { porSku, refs };
              } catch {
                showToast("Error al consultar ventas.", "danger");
                return null;
              } finally {
                toggleSpin(false);
