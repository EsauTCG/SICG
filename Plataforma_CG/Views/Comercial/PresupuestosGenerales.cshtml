                $selMesesObjetivo: $("#cliMesesObjetivo"),
                sheetName: 'Plantilla',
                fileNameBase: `Plantilla_Presupuesto_Cliente_${clienteId}`
              });
            });

            $("#btnImportarXlsxCli").on("click", () => document.getElementById('fileExcelCliente')?.click());
            $("#fileExcelCliente").on("change", function () {
              const f = this.files?.[0];
              if (!f) return;
              EXCEL.importar({
                file: f,
                tbodySelector: '#tbodyCliente',
                theadSelector: '#tablaCliente thead',
                $selMesesObjetivo: $("#cliMesesObjetivo"),
                comentarioIdPrefix: 'cli-comentario-',
                comentarioBtnClass: 'btnComentarioCliente'
              });
              this.value = '';
            });
          }

          // =========================================================
          // ============================ Init ========================
          // =========================================================
          (async function init() {
            try {
              await CEDIS.init();
              VENDEDOR.init();
              CLIENTE.init();
              bindExcel();
              bindAdminPresupuestos();
              initModoPresupuesto(); // ✅ aquí
            } catch (e) {
              console.error(e);
              showToast("Error iniciando la pantalla. Revisa consola.", "danger");
            }
          })();

        })();

    </script>
}
