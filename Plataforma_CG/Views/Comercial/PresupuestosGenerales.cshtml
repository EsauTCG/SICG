                  // 1) Trae ventas por clientes y "inyecta" el cliente en cada registro (por si el API no lo trae)
        async function cliTraerVentasPorClientes(ids) {
          const meses = parseInt($("#cliMesesObjetivo").val() || "12", 10);
          const refs = buildMonthRefs(meses);

          const all = [];
          for (const id of ids) {
            const url = `${API.ventasCliente}?cardCode=${encodeURIComponent(id)}`;
            const r = await fetch(url, { credentials: "same-origin" });
            if (!r.ok) continue;

            const j = await r.json().catch(() => []);
            if (!Array.isArray(j)) continue;

            // 👇 IMPORTANTÍSIMO: asegura que cada registro "sepa" de qué cliente es
            j.forEach(x => {
              all.push({
                ...x,
                __cliente: id // inyectado
              });
            });
          }

          if (!all.length) return null;
          return { data: all, refs, meses };
        }


        // 2) Construye filas por Cliente+SKU (ya NO por SKU solamente)
        function cliBuildPorClienteSkuFromVentas(raw, refs, meses) {
          const porKey = {};

          (raw || []).forEach(d => {
            const sku = String(d.sku || d.Sku || d.productoCodigo || d.ProductoCodigo || "").trim();
            if (!sku) return;

            // ClienteId: intenta leerlo del payload; si no existe usa el inyectado __cliente
            const clienteId = String(
              d.Cliente || d.cliente ||
              d.CardCode || d.cardCode ||
              d.ClienteId || d.clienteId ||
              d.__cliente || ""
            ).trim();
            if (!clienteId) return;

            // Nombre cliente si existe (opcional)
            const clienteNom = String(d.CardName || d.cardName || d.nombreCliente || d.NombreCliente || "").trim();

            const f = new Date(d.fecha || d.Fecha);
            if (isNaN(f.getTime())) return;

            const ym = `${f.getFullYear()}-${String(f.getMonth() + 1).padStart(2, "0")}`;

            const key = `${clienteId}||${sku}`.toUpperCase();

            porKey[key] ||= {
              sku: sku.toUpperCase(),
              clienteId: clienteId.toUpperCase(),
              clienteNom,
              porMes: {},
              objetivo: 0,
              presupuesto: 0
            };

            porKey[key].porMes[ym] =
              (porKey[key].porMes[ym] || 0) +
              Number(d.totalKilos ?? d.TotalKilos ?? d.kilos ?? d.Kilos ?? d.total ?? 0);
          });

          const rows = Object.values(porKey);

          rows.forEach(r => {
            const sum = refs.reduce((a, m) => a + (r.porMes[m.key] || 0), 0);
            r.objetivo = Math.round(sum / Math.max(1, meses));
            r.presupuesto = r.objetivo;
          });

          // Orden opcional: por cliente y sku
          rows.sort((a, b) => (a.clienteId + " " + a.sku).localeCompare(b.clienteId + " " + b.sku));

          return rows;
        }


