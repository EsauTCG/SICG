@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Presupuesto (CEDIS / Vendedor / Cliente)";
}

<style>
    :root {
        --brand: linear-gradient(90deg,#8B0000 0%,#5a0000 50%,#1a0000 100%);
        --bg: linear-gradient(135deg,#eef2f6 0%,#e9edf2 50%,#d7dde3 100%);
        --panel: #fff;
        --bar: #e6e9ef;
        --bar-2: #dde2ea;
        --line: #d8dce3;
        --text: #20262e;
        --muted: #636d7b;
        --accent: #2d6cdf;
        --radius: 8px;
        --shadow: 0 1px 0 rgba(0,0,0,.04),0 12px 24px rgba(0,0,0,.06);
        --shadow-sm: 0 6px 16px rgba(0,0,0,.05);
        --focus: 0 0 0 .2rem rgba(45,108,223,.25);
        --font: system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial,"Noto Sans","Apple Color Emoji","Segoe UI Emoji";
    }

    body {
        background: var(--bg) !important;
        font-family: var(--font);
        color: var(--text);
    }

    .shell {
        width: 96%;
        max-width: 1800px;
        margin: 1.25rem auto;
        background: #fff;
        border-radius: var(--radius);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .module-titlebar {
        background: var(--brand); /* ✅ tu gradiente rojo */
        border-bottom: 1px solid rgba(255,255,255,.18);
        color: #fff;
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;

    }

    .module-title {
        display: flex;
        align-items: center;
        gap: .6rem;
        margin: 0;
        font-weight: 700;
    }

    .module-subtitle {
        margin: 0;
        color: var(--muted);
        font-size: .9rem;
    }

    .toolbar {
        background: var(--bar);
        border-bottom: 1px solid var(--bar-2);
        padding: .4rem .6rem;
        display: flex;
        flex-wrap: wrap;
        gap: .4rem;
    }

    .tbtn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        height: 34px;
        padding: 0 .6rem;
        border: 1px solid var(--line);
        border-radius: 6px;
        background: #fff;
        color: #1e2a35;
        font-size: .9rem;
        transition: .15s;
    }

        .tbtn:hover {
            background: #f8fafc;
            border-color: #cfd6e2;
        }

        .tbtn.primary {
            background: var(--brand);
            color: #fff;
            border-color: transparent;
        }

            .tbtn.primary:hover {
                filter: brightness(1.05);
            }

    .panel {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 6px;
        box-shadow: var(--shadow-sm);
    }

    .panel-head {
        background: linear-gradient(#f6f8fb,#eef2f7);
        border-bottom: 1px solid var(--line);
        padding: .6rem .8rem;
        font-weight: 600;
        color: #2b3642; /* ✅ typo corregido */
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .panel-body {
        padding: .9rem;
    }

    .form-control, .form-select {
        border-radius: 6px;
        border-color: #cfd6e2;
        font-size: .95rem;
    }

        .form-control:focus, .form-select:focus {
            box-shadow: var(--focus);
            border-color: var(--accent);
            outline: none;
        }

    .table-sm > :not(caption) > * > * {
        padding: .5rem .6rem;
    }

    .table-hover tbody tr:hover {
        background: #f9fbff;
    }

    .text-end {
        text-align: right;
    }

    .totales-sap {
        background: #f6f8fb;
        border-top: 1px solid var(--line);
        padding: .5rem .75rem;
    }

    #loadingSpinnerCedis {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 2000;
        backdrop-filter: blur(1.5px);
        background: rgba(255,255,255,.72);
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }

    .table-responsive > .table {
        min-width: 1200px;
    }

    .table-responsive-sticky {
        max-height: 65vh;
        overflow: auto;
        position: relative;
        border-radius: 8px;
        border: 1px solid #eee;
    }

        .table-responsive-sticky thead th {
            position: sticky;
            top: 0;
            z-index: 10;
            background: #f3f6fb; /* o tu var(--brand-soft) */
            border-bottom: 1px solid var(--line);
            box-shadow: 0 2px 0 rgba(0,0,0,.08);
        }

    /* ✅ contenedor scrolleable: aquí debe vivir el scroll */
    .table-wrapper {
        max-height: 65vh;
        overflow: auto;
        position: relative;
    }

    .nav-tabs {
        border-bottom: 1px solid var(--bar-2);
        background: #fff;
        padding: 0 1rem;
    }

        .nav-tabs .nav-link {
            border: none !important;
            border-bottom: 3px solid transparent !important;
            color: #334155;
            font-weight: 600;
            padding: .75rem 1rem;
            border-radius: 0 !important;
        }

            .nav-tabs .nav-link.active {
                color: #8B0000;
                border-bottom-color: #8B0000 !important;
                background: #fff !important;
            }

    @@media (max-width:1400px) {
        .shell {
            width: 98%;
            max-width: 1600px;
        }

        .table-responsive > .table {
            min-width: 1100px;
        }
    }

    /* =========================================================
         ✅ STICKY HEADER (NO TRANSPARENTE)
    ========================================================= */
    .table thead th {
        position: sticky;
        top: 0;
        z-index: 10; /* arriba de filas */
        background: #f3f6fb !important; /* tu tono azulito */
        background-clip: padding-box;
        border-bottom: 1px solid var(--line);
        color: #2b3642;
        font-weight: 700;
        box-shadow: 0 2px 0 rgba(0,0,0,.08);
        backdrop-filter: none !important;
    }

    /* Si quieres asegurar que todo el thead tenga fondo sólido */
    .table thead {
        position: sticky;
        top: 0;
        z-index: 9;
        background: #f3f6fb !important;
    }

    /* Sticky columnas (si usas) */
    .table .sticky-col {
        position: sticky;
        left: 0;
        z-index: 11; /* encima del header si se cruzan */
        background: #fff !important;
    }

    /* ===========================
       ✅ Switch Modo Presupuesto
    =========================== */
    .modo-pill {
        display: flex;
        flex-direction: column;
        gap: .35rem;
        padding: .45rem .6rem;
        border-radius: 10px;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.22);
        backdrop-filter: blur(2px);
        box-shadow: 0 6px 14px rgba(0,0,0,.10);
    }

    .modo-title {
        font-size: .78rem;
        font-weight: 700;
        line-height: 1;
        color: #fff;
        letter-spacing: .2px;
    }

    #modoPresupuestoBox .btn {
        border-color: rgba(255,255,255,.25) !important;
    }

        #modoPresupuestoBox .btn.active {
            background: #fff !important;
            color: #111 !important;
            font-weight: 700;
        }

