          // =========================================================
          // ======================== EXCEL (Genérico) =================
          // =========================================================
          const EXCEL = (function () {
            const ES_MONTHS = {
              'enero': 1, 'ene': 1,
              'febrero': 2, 'feb': 2,
              'marzo': 3, 'mar': 3,
              'abril': 4, 'abr': 4,
              'mayo': 5, 'may': 5,
              'junio': 6, 'jun': 6,
              'julio': 7, 'jul': 7,
              'agosto': 8, 'ago': 8,
              'septiembre': 9, 'sep': 9, 'setiembre': 9, 'set': 9,
              'octubre': 10, 'oct': 10,
              'noviembre': 11, 'nov': 11,
              'diciembre': 12, 'dic': 12
            };

            const pad2 = n => String(n).padStart(2, '0');

            function canonYMFromHeader(h) {
              if (!h) return null;
              let s = String(h).toLowerCase()
                .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
                .replace(/\./g, ' ')
                .replace(/\n/g, ' ')
                .replace(/\s+/g, ' ')
                .trim();

              let m = s.match(/^(\d{4})[\/\- ](\d{1,2})$/);
              if (m) { const y = +m[1], mm = +m[2]; if (y >= 1900 && mm >= 1 && mm <= 12) return `${y}-${pad2(mm)}`; }

              m = s.match(/^(\d{1,2})[\/\- ](\d{4})$/);
              if (m) { const mm = +m[1], y = +m[2]; if (y >= 1900 && mm >= 1 && mm <= 12) return `${y}-${pad2(mm)}`; }

              m = s.match(/^([a-z\u00f1]+)[ ]+(\d{4})$/i);
              if (m) { const mm = ES_MONTHS[m[1]], y = +m[2]; if (mm) return `${y}-${pad2(mm)}`; }

              m = s.match(/^(\d{4})[ ]+([a-z\u00f1]+)$/i);
              if (m) { const y = +m[1], mm = ES_MONTHS[m[2]]; if (mm) return `${y}-${pad2(mm)}`; }

              return null;
            }

            function currentMonthRefsFromSelect($selMesesObjetivo) {
              const meses = parseInt($selMesesObjetivo.val() || "12", 10);
              const refs = buildMonthRefs(meses);
              return refs.map(r => {
                const parts = String(r.label).split(' ');
                const mesSrc = (parts[0] || '').replace('.', '');
                const anio = parts[1] || '';
                const niceMes = mesSrc.charAt(0).toUpperCase() + mesSrc.slice(1).toLowerCase();
                return { key: r.key, nice: `${niceMes} ${anio}` };
              });
            }

            function armarDataDesdeTabla(tbodySelector, months) {
              const rows = [];
              document.querySelectorAll(`${tbodySelector} tr`).forEach(tr => {
                const sku = tr.getAttribute('data-sku') || tr.querySelector('td')?.innerText?.trim() || '';
                const objetivo = Number(tr.querySelector('input[name$=".Objetivo"]')?.value || 0);
                const presupuesto = Number(tr.querySelector('input.pre')?.value || 0);
                const comentario = tr.querySelector('input[name$=".Comentario"]')?.value || '';
                const c = { SKU: sku };

                const tds = [...tr.children];
                let idx = 1;
                months.forEach(m => {
                  const td = tds[idx++];
                  c[m.nice] = Number((td?.innerText || '0').replace(/[^\d.-]/g, '')) || 0;
                });

                c["Objetivo"] = objetivo;
                c["Presupuesto"] = presupuesto;
                c["Comentario"] = comentario;
                rows.push(c);
              });
              return rows;
            }

            function exportar({ tbodySelector, $selMesesObjetivo, sheetName, fileNameBase }) {
              const months = currentMonthRefsFromSelect($selMesesObjetivo);
              const rows = armarDataDesdeTabla(tbodySelector, months);
              if (!rows.length) { showToast("No hay datos para exportar.", "warning"); return; }

              const cols = ["SKU", ...months.map(m => m.nice), "Objetivo", "Presupuesto", "Comentario"];
              const data = rows.map(r => {
                const obj = {};
                cols.forEach(k => obj[k] = r[k] ?? (k === "Comentario" ? "" : 0));
                return obj;
              });

              const ws = XLSX.utils.json_to_sheet(data, { header: cols });
              ws['!cols'] = cols.map(c => ({ wch: Math.max(12, c.length + 2) }));

              const wb = XLSX.utils.book_new();
              XLSX.utils.book_append_sheet(wb, ws, sheetName);

              const f = new Date();
              const stamp = `${f.getFullYear()}${pad2(f.getMonth() + 1)}${pad2(f.getDate())}`;
              XLSX.writeFile(wb, `${fileNameBase}_${stamp}.xlsx`);
              showToast("Excel exportado.", "success");
            }

            function plantilla({ $selMesesObjetivo, sheetName, fileNameBase }) {
              const months = currentMonthRefsFromSelect($selMesesObjetivo);
              const cols = ["SKU", ...months.map(m => m.nice), "Objetivo", "Presupuesto", "Comentario"];
              const ws = XLSX.utils.aoa_to_sheet([cols]);
              ws['!cols'] = cols.map(c => ({ wch: Math.max(12, c.length + 2) }));

              const wb = XLSX.utils.book_new();
              XLSX.utils.book_append_sheet(wb, ws, sheetName);

              XLSX.writeFile(wb, `${fileNameBase}.xlsx`);
              showToast("Plantilla descargada.", "success");
            }

            function importar({ file, tbodySelector, theadSelector, $selMesesObjetivo, comentarioIdPrefix, comentarioBtnClass }) {
              if (!file) { showToast("Selecciona un archivo Excel.", "warning"); return; }
              toggleSpin(true);

              const reader = new FileReader();
              reader.onload = (e) => {
                try {
                  const wb = XLSX.read(e.target.result, { type: 'binary' });
                  const ws = wb.Sheets[wb.SheetNames[0]];
                  const data = XLSX.utils.sheet_to_json(ws, { defval: '' });
                  if (!data.length) { showToast("El Excel está vacío.", "warning"); return; }

                  const headersArchivo = Object.keys(data[0] || {});
                  const mapYM = {};
                  headersArchivo.forEach(h => {
                    const ym = canonYMFromHeader(h);
                    if (ym) mapYM[ym] = h;
                  });

                  const months = currentMonthRefsFromSelect($selMesesObjetivo);

                  // ✅ PERMISIVO: si no vienen columnas de meses, no falla
                  const missing = months.filter(m => !mapYM[m.key]);
                  const hasAnyMonth = months.some(m => !!mapYM[m.key]);
                  
                  // Si no viene ninguna columna de mes, seguimos y llenamos con 0
                  if (!hasAnyMonth) {
                    console.warn("[Import] Excel sin columnas de meses. Se llenará con 0.");
                  } else if (missing.length) {
                    // Si viene al menos una de mes, pero faltan otras, también seguimos (las faltantes van en 0)
                    console.warn("[Import] Faltan columnas de meses, se llenarán con 0:", missing.map(x => x.nice));
                  }


                  // Render headers
                  const thead = document.querySelector(theadSelector);
                  const tbody = document.querySelector(tbodySelector);
                  const thMeses = months.map(r => {
                    const [mes, anio] = r.nice.split(' ');
                    return `<th class="text-end"><div class="text-capitalize">${escapeHtml(mes)}</div><div class="small text-muted">${escapeHtml(anio)}</div></th>`;
                  }).join('');

                  thead.innerHTML = `
                    <tr>
                      <th>SKU</th>
                      ${thMeses}
                      <th class="text-end">Objetivo</th>
                      <th class="text-end">Presupuesto</th>
                      <th class="text-end">Participación</th>
                      <th class="text-center">Comentario</th>
                      ${tbodySelector === '#tbodyCedis' ? '<th style="width:44px;"></th>' : ''}
                    </tr>`;

                  // Fill body
                  tbody.innerHTML = '';
                  let i = 0;

                  data.forEach(row => {
                    const sku = String(row['SKU'] || row['sku'] || row['ProductoCodigo'] || row['productoCodigo'] || '').trim().toUpperCase();
                    if (!sku) return;

                           const tdsMeses = months.map(m => {
                         const col = mapYM[m.key];
                         const val = col ? Number(row[col] ?? 0) : 0;  // ✅ si no hay col -> 0
                         return `<td class="text-end">${fmt(val)}</td>`;
                       }).join('');


                    const objetivo = Math.round(Number(row['Objetivo'] ?? row['objetivo'] ?? 0));
                    const presupuesto = Math.round(Number(row['Presupuesto'] ?? row['presupuesto'] ?? objetivo));
                    const comentario = String(row['Comentario'] ?? row['comentario'] ?? '');

                    // if (!shouldIncludeRow(objetivo, presupuesto)) return;

                    // ✅ En importación NO filtres por mínimo (al menos en CEDIS)
                           const skipFilter = (tbodySelector === '#tbodyVendedor'); // ✅ vendedor siempre entra
        if (!skipFilter && tbodySelector !== '#tbodyCedis' && !shouldIncludeRow(objetivo, presupuesto)) return;


                    const skuSafe = escapeHtml(sku);
                    const comSafe = escapeHtml(comentario);

                    const extraDel = (tbodySelector === '#tbodyCedis')
                      ? `<td class="text-center"><button type="button" class="btn btn-outline-danger btn-sm del"><i class="bi bi-trash"></i></button></td>`
                      : '';

                    tbody.insertAdjacentHTML('beforeend', `
                      <tr data-sku="${skuSafe}">
                        <td>${skuSafe}
                          <input type="hidden" name="items[${i}].ProductoCodigo" value="${skuSafe}">
                          <input type="hidden" name="items[${i}].Objetivo" value="${objetivo}">
                        </td>
                        ${tdsMeses}
                        <td class="text-end">${fmt(objetivo)}</td>
                        <td class="text-end">
                          <input type="number" class="form-control form-control-sm text-end pre" name="items[${i}].Presupuesto" value="${presupuesto}" min="0" step="1">
                        </td>
                        <td class="text-end part-cell">0.0%</td>
                        <td class="text-center">
                          <button type="button" class="btn btn-outline-secondary btn-sm ${comentarioBtnClass}"
                                  data-sku="${skuSafe}" data-index="${i}">
                            <i class="bi bi-chat-left-text"></i>
                          </button>
                          <input type="hidden" name="items[${i}].Comentario" id="${comentarioIdPrefix}${i}" value="${comSafe}" />
                        </td>
                        ${extraDel}
                      </tr>`);
                    i++;
                  });

        // ✅ Recalcular totales según tabla
        if (tbodySelector === '#tbodyCedis') {
          updateTotalesUI('#tbodyCedis', 'totObj', 'totPre');
          recalcPartUI('#tbodyCedis');
        }
        if (tbodySelector === '#tbodyVendedor') {
          updateTotalesUI('#tbodyVendedor', 'venTotObj', 'venTotPre');
          recalcPartUI('#tbodyVendedor');
        }
        if (tbodySelector === '#tbodyCliente') {
          updateTotalesUI('#tbodyCliente', 'cliTotObj', 'cliTotPre');
          recalcPartUI('#tbodyCliente');
        }


                  showToast("Importación completada.", "success");
                } catch (err) {
                  console.error(err);
                  showToast("No se pudo leer el Excel.", "danger");
                } finally {
                  toggleSpin(false);
                }
              };

              

              reader.onerror = () => {
                toggleSpin(false);
                showToast("Error leyendo el archivo.", "danger");
              };

              reader.readAsBinaryString(file);
            }

            return { exportar, plantilla, importar };
          })();

        async function initModoPresupuesto() {
        const box = document.getElementById("modoPresupuestoBox");
        if (!box) return;

        const token =
        document.querySelector('#frmPresupuestoCedis input[name="__RequestVerificationToken"]')?.value ||
        document.querySelector('#frmPresupuestoCliente input[name="__RequestVerificationToken"]')?.value ||
        document.querySelector('input[name="__RequestVerificationToken"]')?.value || "";

        const norm = (modo) => {
        const m = String(modo || "").trim().toUpperCase();
        return (m === "VENDEDOR") ? "VENDEDOR" : "CLIENTE";
        };

        const setActive = (modo) => {
        const m = norm(modo);

        box.querySelectorAll("[data-modo]").forEach(b => b.classList.remove("active"));
        const active = box.querySelector(`[data-modo="${m}"]`);
        if (active) active.classList.add("active");

        window.__MODO_PRESUPUESTO__ = m;
        try { localStorage.setItem("modoPresupuesto", m); } catch {}
        };

        try {
        const r = await fetch(API.modoGet, { credentials: "same-origin" });
        const j = r.ok ? await r.json() : null;

        // sin permiso de lectura: ocultar
        if (!j?.puedeLeer) {
        box.style.display = "none";
        return;
        }

        // con permiso de lectura: mostrar
        box.style.display = "";

        const fallback = (() => {
        try { return localStorage.getItem("modoPresupuesto"); } catch { return null; }
        })();

        setActive(j?.modo || fallback || "CLIENTE");

        // sin permiso de escritura: deshabilitar
        if (!j?.puedeEscribir) {
        box.querySelectorAll("[data-modo]").forEach(btn => {
        btn.disabled = true;
        });
        return;
        }

        // con permiso de escritura: habilitar
        box.querySelectorAll("[data-modo]").forEach(btn => {
        btn.disabled = false;
        });

        } catch (e) {
        console.error("No se pudo cargar modo presupuesto:", e);
        box.style.display = "none";
        return;
        }

        box.querySelectorAll("[data-modo]").forEach(btn => {
        btn.addEventListener("click", async () => {
        if (btn.disabled) return;

        const modo = norm(btn.getAttribute("data-modo"));
        const fd = new FormData();
        fd.append("modo", modo);

        try {
        toggleSpin(true);

        const r = await fetch(API.modoSet, {
        method: "POST",
        credentials: "same-origin",
        headers: {
        "RequestVerificationToken": token,
        "X-Requested-With": "XMLHttpRequest"
        },
        body: fd
        });

        if (r.status === 403) {
        showToast("No tienes permiso para cambiar el modo.", "warning");
        return;
        }

        const j = r.ok ? await r.json() : null;
        if (r.ok && j?.ok) {
        setActive(j.modo);
        } else {
        showToast("No se pudo guardar el modo.", "danger");
        }
        } catch {
        showToast("Error al guardar modo presupuesto.", "danger");
        } finally {
        toggleSpin(false);
        }
        });
        });
        }


