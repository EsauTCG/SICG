        // ==========================
        // ✅ GUARDADO CLIENTE (FIX REAL)
        // ==========================

        // prefijos EXACTOS (incluye Items con I mayúscula)
        const CLIENTE_ITEM_PREFIXES = [
          "Items", "items",
          "Detalles", "Detalle",
          "Presupuestos", "Presupuesto",
          "Renglones", "Rows",
          "Lineas", "LineItems"
        ];

        function _dedupePrefixes(list) {
          const seen = new Set();
          const out = [];
          (list || []).forEach(p => {
            const v = String(p || "").trim();
            if (!v) return;
            const k = v.toLowerCase();
            if (seen.has(k)) return;
            seen.add(k);
            out.push(v);
          });
          return out;
        }

        function _ensureHidden(form, id, name) {
          let el = document.getElementById(id);
          if (!el) {
            el = document.createElement("input");
            el.type = "hidden";
            el.id = id;
            el.name = name;
            form.appendChild(el);
          } else {
            el.name = name;
          }
          return el;
        }

                function syncClienteItemsToForm(form, cardCode) {
          let shadow = document.getElementById("CliItemsShadow");
          if (!shadow) {
            shadow = document.createElement("div");
            shadow.id = "CliItemsShadow";
            shadow.style.display = "none";
            form.appendChild(shadow);
          }
          shadow.innerHTML = "";

          const rows = document.querySelectorAll("#tbodyCliente tr");
          let i = 0;

          const prefixes = _dedupePrefixes(CLIENTE_ITEM_PREFIXES);
          const cc = String(cardCode || "").trim();

          const add = (name, val) => {
            const inp = document.createElement("input");
            inp.type = "hidden";
            inp.name = name;
            inp.value = val ?? "";
            shadow.appendChild(inp);
          };

          rows.forEach(tr => {
            const sku =
              String(tr.querySelector('input[name$=".ProductoCodigo"]')?.value || "").trim() ||
              String(tr.getAttribute("data-sku") || "").trim() ||
              String(tr.querySelector("td")?.innerText || "").trim();

            if (!sku) return;

            const obj = String(tr.querySelector('input[name$=".Objetivo"]')?.value ?? "0");
            const pre = String(tr.querySelector("input.pre")?.value ?? "0");
            const com = String(tr.querySelector('input[name$=".Comentario"]')?.value ?? "");

            prefixes.forEach(prefix => {
              add(`${prefix}[${i}].ProductoCodigo`, sku);
              add(`${prefix}[${i}].Sku`, sku);
              add(`${prefix}[${i}].SKU`, sku);
              add(`${prefix}[${i}].ItemCode`, sku);

              add(`${prefix}[${i}].Objetivo`, obj);
              add(`${prefix}[${i}].ObjetivoKilos`, obj);

              add(`${prefix}[${i}].Presupuesto`, pre);
              add(`${prefix}[${i}].PresupuestoKilos`, pre);

              add(`${prefix}[${i}].Comentario`, com);

              // 👇 SIEMPRE manda el cliente por item (esto suele salvar el backend)
              add(`${prefix}[${i}].CardCode`, cc);
              add(`${prefix}[${i}].ClienteId`, cc);
              add(`items[${i}].Cliente`, cc); // <-- ESTE es el que usa el action (i.Cliente)
            });

            i++;
          });

          console.log("[Cliente] Filas armadas:", i, "CardCode:", cc);
          return i;
        }

                  async function guardarComoEstaVistaCliente(mes, anio, cardCode) {
          const form = document.getElementById("frmPresupuestoCliente");
          if (!form) { showToast("No se encontró frmPresupuestoCliente", "danger"); return false; }

          const cc = String(cardCode || "").trim();   // <-- ESTE es tu cliente real
          if (!cc) { showToast("Falta Cliente para guardar.", "danger"); return false; }

          // Root que tu Action sí entiende: string Cliente
          _ensureHidden(form, "CliClienteRoot", "Cliente").value = cc;
          _ensureHidden(form, "CliMesInput", "Mes").value = mes;
          _ensureHidden(form, "CliAnioInput", "Anio").value = anio;

          // arma items (asegúrate que syncClienteItemsToForm agrega items[i].Cliente = cc)
          const count = syncClienteItemsToForm(form, cc);
          if (!count) { showToast("No hay filas armadas para enviar.", "danger"); return false; }

          const token =
            form.querySelector('input[name="__RequestVerificationToken"]')?.value ||
            document.querySelector('input[name="__RequestVerificationToken"]')?.value || "";

          try {
            toggleSpin(true);
            const fd = new FormData(form);

            // Usa action del form o el API fallback
            const url = (form.getAttribute("action") || "").trim() || API.guardarCliente;

            const r = await fetch(url, {
              method: "POST",
              credentials: "same-origin",
              headers: { "RequestVerificationToken": token, "X-Requested-With": "XMLHttpRequest" },
              body: fd
            });

            const ct = r.headers.get("content-type") || "";
            const text = ct.includes("application/json") ? "" : await r.text().catch(() => "");
            const data = ct.includes("application/json") ? await r.json().catch(() => null) : null;

            if (r.ok && (data?.ok || data?.success)) {
              return true;
            }

            console.log("RESPUESTA BACKEND (texto):", text);
            console.log("RESPUESTA BACKEND (json):", data);
            showToast(data?.message || data?.error || text || "No se pudo guardar", "danger");
            return false;

          } catch (e) {
            console.error(e);
            showToast("Error de red al guardar.", "danger");
            return false;
          } finally {
            toggleSpin(false);
          }
        }



                 async function cliGuardar() {
          const ids = cliGetSelectedClientIds();
          if (!ids.length) { showToast("Selecciona cliente(s) antes de guardar.", "warning"); return; }

          const mes = parseInt($("#cliMes").val(), 10);
          const anio = parseInt($("#cliAnio").val(), 10);

          if (ids.length > 1) {
            let okCount = 0;
            for (const id of ids) {
              const ok = await guardarComoEstaVistaCliente(mes, anio, id);
              if (ok) okCount++;
            }
            showToast(`Guardados ${okCount} de ${ids.length}`, okCount ? "success" : "danger");
            return;
          }

          const ok = await guardarComoEstaVistaCliente(mes, anio, ids[0]);
          showToast(ok ? "Presupuesto guardado." : "No se pudo guardar.", ok ? "success" : "danger");
        }



























