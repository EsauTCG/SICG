@section Scripts {

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

    <!-- Requeridos (si NO están ya en _Layout) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>

    <!-- Bootstrap JS (necesario para Toast/Modal) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- XLSX -->
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

    <script>
        (function () {
          // ---- guard para no bindear 2 veces
          if (window.__PRESUPUESTOS_APP_BOUND__) return;
          window.__PRESUPUESTOS_APP_BOUND__ = true;

          const API = {
            // CEDIS
            canales: '@Url.Action("ObtenerCanalesCedis", "Comercial")',
            datos: '@Url.Action("ObtenerPresupuestoPorCedis2", "Comercial")',
            guardar: '@Url.Action("GuardarPresupuestoCedis", "Comercial")',
            reporte: '@Url.Action("ObtenerPresupuestoReporteCedis", "Comercial")',

            // VENDEDOR
            vendedores: '@Url.Action("ObtenerVendedores", "Comercial")',
            datosVendedor: '@Url.Action("ObtenerPresupuestoPorVendedor", "Comercial")',
            guardarVendedor: '@Url.Action("GuardarPresupuestoVendedor", "Comercial")',

            // ===== CLIENTES (lista) =====
            clientes: '@Url.Action("GetClientes", "Comercial")',
            clientesPorVendedor: '@Url.Action("GetClientesPorVendedor", "Comercial")',

            // ===== VENTAS (para armar la tabla de presupuesto / objetivos) =====
            ventasCliente: '@Url.Action("ObtenerPresupuesto", "Comercial")', // usa ?cardCode=

            // ===== PRESUPUESTOS GUARDADOS (histórico / validar duplicados) =====
            presupuestosMes: '@Url.Action("ObtenerPresupuestos", "Comercial")', // usa ?mes=&anio=

            // ===== GUARDAR =====
            guardarCliente: '@Url.Action("GuardarPresupuesto", "Comercial")',

            // ===== COMBOS (filtros) =====
            canalesCliente: '@Url.Action("GetCanales", "Comercial")',
            clasificacionesCliente: '@Url.Action("GetClasificacionesClientes", "Comercial")',


            clasificacionesCliente: '@Url.Action("GetClasificacionesClientes", "Comercial")',

            // ✅ MODO PRESUPUESTO (GLOBAL)
            modoGet: '@Url.Action("ObtenerModoPresupuesto", "Comercial")',
            modoSet: '@Url.Action("GuardarModoPresupuesto", "Comercial")',

                    // ===== ADMIN PRESUPUESTOS =====
              adminList: '@Url.Action("AdminListPresupuestos", "Comercial")',
              adminDelIds: '@Url.Action("AdminDeleteByIds", "Comercial")',
              adminDelFilter: '@Url.Action("AdminDeleteByFilter", "Comercial")',


          };

          // =========================================================
          // ===================== Helpers Comunes ====================
          // =========================================================
          const fmt = n => Number(n || 0).toLocaleString('es-MX');

          function toggleSpin(flag) {
            const el = document.getElementById('loadingSpinnerCedis');
            if (el) el.style.display = flag ? 'flex' : 'none';
          }

          function escapeHtml(s) {
            return String(s ?? '')
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;')
              .replace(/"/g, '&quot;')
              .replace(/'/g, '&#39;');
          }

          function showToast(msg, variant = "light") {
            const id = "appToastCedis";
            let root = document.getElementById(id);
            if (!root) {
              root = document.createElement('div');
              root.id = id;
              root.className = "position-fixed bottom-0 end-0 p-3";
              root.style.zIndex = 2100;
              root.innerHTML = `
                <div class="toast align-items-center border-0">
                  <div class="d-flex">
                    <div class="toast-body"></div>
                    <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
                  </div>
                </div>`;
              document.body.appendChild(root);
            }
            const el = root.querySelector('.toast');
            el.className = `toast align-items-center text-bg-${variant} border-0`;
            el.querySelector('.toast-body').textContent = msg;
            new bootstrap.Toast(el, { delay: 2600 }).show();
          }

          function banner(msg, type = "success") {
            const z = document.getElementById('alertsZone');
            if (!z) return;
            z.innerHTML = msg
              ? `<div class="alert alert-${type} shadow-sm">
                   <i class="bi ${type === 'success' ? 'bi-check-circle' : 'bi-exclamation-triangle'} me-2"></i>${msg}
                 </div>`
              : '';
          }

          function buildMonthRefs(n) {
            const out = [], hoy = new Date();
            for (let i = n - 1; i >= 0; i--) {
              const d = new Date(hoy.getFullYear(), hoy.getMonth() - i, 1);
              out.push({
                key: `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`,
                label: d.toLocaleString('es-MX', { month: 'short', year: 'numeric' })
              });
            }
            return out;
          }

          function shouldIncludeRow(objetivo, presupuesto) {
            const obj = Math.round(Number(objetivo || 0));
            const pre = Math.round(Number(presupuesto || obj));
            return Math.max(obj, pre) >= 100;
          }

          // function isPeriodoValido(mes, anio) {
          //   const now = new Date();
          //   const mA = now.getMonth() + 1, aA = now.getFullYear();
          //   return !(anio < aA || (anio === aA && mes < mA));
          // }

        function isPeriodoValido(mes, anio) {
        mes = Number(mes || 0);
        anio = Number(anio || 0);

        // Permitir guardar cualquier periodo válido
        return mes >= 1 && mes <= 12 && anio >= 2020 && anio <= 2100;
        }

          function setPeriodoSiguienteMes($selMes, $inpAnio) {
            const f = new Date();
            const m = f.getMonth() + 1, y = f.getFullYear();
            const ms = m === 12 ? 1 : m + 1;
            const ys = m === 12 ? y + 1 : y;
            $selMes.val(ms);
            $inpAnio.val(ys);
          }


                  function updateTotalesUI(tbodySelector, objSpanId, preSpanId) {
          let obj = 0, pre = 0;

          document.querySelectorAll(`${tbodySelector} input[name$=".Objetivo"]`)
            .forEach(x => obj += Number(x.value || 0));

          document.querySelectorAll(`${tbodySelector} input.pre`)
            .forEach(x => pre += Number(x.value || 0));

          const o = document.getElementById(objSpanId);
          const p = document.getElementById(preSpanId);

          if (o) o.textContent = fmt(obj);
          if (p) p.textContent = fmt(pre);
        }

        function recalcPartUI(tbodySelector) {
          const pres = [...document.querySelectorAll(`${tbodySelector} input.pre`)];
          const tot = pres.reduce((a, i) => a + Number(i.value || 0), 0);

          pres.forEach(inp => {
            const td = inp.closest('tr')?.querySelector('.part-cell');
            if (!td) return;
            const v = Number(inp.value || 0);
            td.textContent = (tot > 0 ? (v * 100 / tot) : 0).toFixed(1) + '%';
          });
        }






          // =========================================================
          // ============================ CEDIS =======================
          // =========================================================
          const CEDIS = (function () {
