                </td>

                <td>${cliLabel}</td>

                ${tds}

                <td class="text-end">${fmt(d.objetivo)}</td>

                <td class="text-end">
                  <input type="number" class="form-control form-control-sm text-end pre"
                         name="items[${i}].Presupuesto" value="${d.presupuesto}" min="0" step="1">
