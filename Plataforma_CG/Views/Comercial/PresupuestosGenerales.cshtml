              async function admBuscar() {
          const tipo = $("#admTipo").val();
          const mes = +$("#admMes").val();
          const anio = +$("#admAnio").val();

          const sku = ($("#admSku").val() || "").trim();
          const canal = ($("#admCanal").val() || "").trim();
          const vendedorId = ($("#admVendedorId").val() || "").trim();
          const cliente = ($("#admCliente").val() || "").trim();

          if (!API.adminList) {
            console.error("[ADMIN] API.adminList viene vacío. Revisa Url.Action('AdminListPresupuestos','Comercial')");
            showToast("API.adminList vacío. Revisa Url.Action.", "danger");
            return;
          }

          const qs = new URLSearchParams({ tipo, mes, anio, sku, canal, vendedorId, cliente });
          const url = `${API.adminList}?${qs.toString()}`;

          console.log("[ADMIN] fetch:", url);

          toggleSpin(true);
          try {
            const r = await fetch(url, { credentials: "same-origin" });

            console.log("[ADMIN] status:", r.status);

            const j = await r.json().catch(() => null);
            console.log("[ADMIN] json:", j);

            if (!r.ok || !j?.ok) {
              showToast(j?.message || `No se pudo listar (${r.status})`, "danger");
              return;
            }

            const rows = j.rows || [];
            $("#admMsg").text(`Resultados: ${rows.length}`);

            const html = rows.map(x => {
              const tipo2 = x.tipo ?? x.Tipo ?? "";
              const mes2 = x.mes ?? x.Mes ?? 0;
              const anio2 = x.anio ?? x.Anio ?? 0;
              const sku2 = x.sku ?? x.Sku ?? "";
              const obj2 = x.objetivo ?? x.Objetivo ?? 0;
              const pre2 = x.presupuesto ?? x.Presupuesto ?? 0;
              const com2 = x.comentario ?? x.Comentario ?? "";
              const rowId = x.rowId ?? x.RowId ?? 0;

              return `
                <tr data-rowid="${rowId}">
                  <td><input class="form-check-input admChk" type="checkbox" value="${rowId}"></td>
                  <td>${escapeHtml(String(tipo2))}</td>
                  <td>${String(mes2).padStart(2,'0')}/${anio2}</td>
                  <td>${escapeHtml(rowAmbito(x))}</td>
                  <td class="fw-semibold">${escapeHtml(String(sku2))}</td>
                  <td class="text-end">${fmt(obj2)}</td>
                  <td class="text-end">${fmt(pre2)}</td>
                  <td class="text-muted small">${escapeHtml(String(com2 || ""))}</td>
                </tr>`;
            }).join("");

            $("#admTbody").html(html || `<tr><td colspan="8" class="text-muted p-3">Sin resultados.</td></tr>`);

          } catch (err) {
            console.error("[ADMIN] error:", err);
            showToast("Error de red/JS en buscar. Revisa consola.", "danger");
          } finally {
            toggleSpin(false);
          }
        }


        async function admDeleteSelected() {
          const tipo = $("#admTipo").val();
          const ids = [...document.querySelectorAll("#admTbody .admChk:checked")]
            .map(x => +x.value).filter(Boolean);

          if (!ids.length) { showToast("Selecciona al menos 1 fila.", "warning"); return; }
          if (!confirm(`Eliminar ${ids.length} filas seleccionadas?`)) return;

          const reason = prompt("Motivo (opcional):") || "";

          toggleSpin(true);
          try {
            const fd = new FormData();
            fd.append("Tipo", tipo);
            ids.forEach(i => fd.append("RowIds", i));
            fd.append("Reason", reason);

            const r = await fetch(API.adminDelIds, {
              method:"POST",
              credentials:"same-origin",
              headers:{ "RequestVerificationToken": getTokenAny(), "X-Requested-With":"XMLHttpRequest" },
              body: fd
            });

            const j = await r.json().catch(()=>null);
            if (r.ok && j?.ok) {
              showToast(`Eliminadas: ${j.deleted}`, "success");
              await admBuscar();
            } else {
              showToast(j?.message || "No se pudo eliminar.", "danger");
            }
          } finally { toggleSpin(false); }
        }

