    while (idx < toFetch.length) {
    const master = toFetch[idx++];
    try {
    const d = normalizeArrayResult(await cargarVentaRealPorMaster(master), `VentaReal ${master}`);
    CACHE_VENTA_REAL.set(master, d);
    } catch {
    CACHE_VENTA_REAL.set(master, []);
    }
    }
    }

    await Promise.all(Array.from({ length: CONC }, worker));
    }

