    await prefetchPresOnly(masters);

    const set = new Set();
    for (const m of masters) {
    for (const p of (CACHE_PRES.get(m) || [])) {
    if (up(p.fuente) === 'CEDIS') {
    const c = String(p.canalVta || '').trim();
    const rs = String(p.razonSocial || '').trim();
    if (c) set.add(c);
    else if (rs) set.add(rs);
    }
    }
    }
    return Array.from(set).sort((a, b) => a.localeCompare(b));
    }

    async function prefetchForMasters(masters) {
    const list = (masters || []).filter(Boolean);
    const toFetch = list.filter(m => !(CACHE_PRES.has(m) && CACHE_PROD.has(m)));
    if (!toFetch.length) return;

    const CONC = 6;
    let idx = 0;

    async function worker() {
    while (idx < toFetch.length) {
    const master = toFetch[idx++];
    const tasks = [];

    if (!CACHE_PRES.has(master)) {
    tasks.push(
    Promise.resolve()
    .then(() => cargarPresupuestosPorMaster(master))
    .then(d => CACHE_PRES.set(master, normalizeArrayResult(d, `Pres ${master}`)))
    .catch(() => CACHE_PRES.set(master, []))
    );
    }

    if (!CACHE_PROD.has(master)) {
    tasks.push(
    Promise.resolve()
    .then(() => cargarProduccionPorMaster(master))
    .then(d => CACHE_PROD.set(master, normalizeArrayResult(d, `Plan ${master}`)))
    .catch(() => CACHE_PROD.set(master, []))
    );
    }

    await Promise.allSettled(tasks);
    }
    }

    await Promise.all(Array.from({ length: CONC }, worker));
    }

    async function loadSkuOptions() {
    const masters = mastersScopeForLookups();
    await prefetchForMasters(masters);
    await prefetchRealOnly(masters);

    const map = new Map();

    const add = (sku, name) => {
    const s = up(String(sku || '').trim());
    if (!s) return;
    const n = String(name || '').trim();
    const prev = map.get(s) || '';
    if (!prev && n) map.set(s, n);
    else if (!prev) map.set(s, '');
    };

    for (const m of masters) {
    for (const p of (CACHE_PRES.get(m) || [])) add(p.productoCodigo, p.productoNombre);
    for (const pr of (CACHE_PROD.get(m) || [])) add(pr.productoCodigo, pr.productoNombre);
    for (const rr of (CACHE_PROD_REAL.get(m) || [])) add(realSku(rr), realName(rr));
    }

    return Array.from(map.entries())
    .map(([sku, name]) => ({ sku, name }))
    .sort((a, b) => a.sku.localeCompare(b.sku));
    }

    // =======================
    // Filtros globales
    // =======================
    function getFilterState() {
    const elFuente = getEl('fFuente');
    const elCliente = getEl('fCliente');
    const elVendedor = getEl('fVendedor');
    const elCedis = getEl('fCedis');
    const elMaster = getEl('fMaster');
    const elSku = getEl('fSku');
    const elClasificacion = getEl('fClasificacion');

    const fuente = up(elFuente?.value || 'TODOS');

    const clienteRaw = String(elCliente?.value || '').trim();
    const vendedorRaw = String(elVendedor?.value || '').trim();
    const cedisRaw = String(elCedis?.value || '').trim();

    const masterRaw = String(elMaster?.value || '').trim();
    const masters = masterRaw ? masterRaw.split(',').map(x => up(x.trim())).filter(Boolean) : [];

    const skuRaw = String(elSku?.value || '').trim();
    const clasificacionRaw = String(elClasificacion?.value || '').trim();
    const clasificaciones = clasificacionRaw ? clasificacionRaw.split(',').map(x => up(x.trim())).filter(Boolean) : [];

    const clientes = clienteRaw ? clienteRaw.split(',').map(x => x.trim()).filter(Boolean) : [];
    const vendedores = vendedorRaw ? vendedorRaw.split(',').map(x => x.trim()).filter(Boolean) : [];
    const cedisList = cedisRaw ? cedisRaw.split(',').map(x => x.trim()).filter(Boolean) : [];
    const skus = skuRaw ? skuRaw.split(',').map(x => up(x.trim())).filter(Boolean) : [];

    return { fuente, clientes, vendedores, cedisList, masterRaw, masters, skuRaw, skus, clasificacionRaw, clasificaciones };
    }

    function isAnyFilterActive(state) {
    if (!state) return false;
    return (
    (state.fuente && state.fuente !== 'TODOS') ||
    (state.clientes && state.clientes.length) ||
    (state.vendedores && state.vendedores.length) ||
    (state.cedisList && state.cedisList.length) ||
    (state.masters && state.masters.length) ||
    (state.skus && state.skus.length) ||
    (state.clasificaciones && state.clasificaciones.length)
    );
    }

    function filtrarPresupuesto(list, state) {
    let data = [...(list || [])];

    const hasClas = list.some(x =>
    x.clasificacionId != null || x.ClasificacionId != null ||
    x.clasificacionNombre != null || x.ClasificacionNombre != null
    );

    if (state.clasificaciones && state.clasificaciones.length && hasClas) {
    const setClas = new Set(state.clasificaciones.map(up));
    data = data.filter(x => {
    const id = up(String(x.clasificacionId ?? x.ClasificacionId ?? '').trim());
    const nombre = up(String(x.clasificacionNombre ?? x.ClasificacionNombre ?? '').trim());
    return setClas.has(id) || setClas.has(nombre);
    });
    }

    if (state.skus && state.skus.length) {
    const setSku = new Set(state.skus.map(up));
    data = data.filter(x => setSku.has(up(String(x.productoCodigo ?? '').trim())));
    }

    if (state.fuente && state.fuente !== 'TODOS') {
    data = data.filter(x => up(x.fuente) === state.fuente);
    } else {
    if (state.clientes?.length) data = data.filter(x => up(x.fuente) === 'GENERAL');
    if (state.vendedores?.length) data = data.filter(x => up(x.fuente) === 'VENDEDOR');
    if (state.cedisList?.length) data = data.filter(x => up(x.fuente) === 'CEDIS');
    }

    if (state.clientes && state.clientes.length) {
    const setCli = new Set(state.clientes.map(up));
    data = data.filter(x => setCli.has(up(String(x.razonSocial ?? '').trim())));
    }

    if (state.vendedores && state.vendedores.length) {
    const setVen = new Set(state.vendedores.map(up));
    data = data.filter(x => setVen.has(up(String(x.razonSocial ?? '').trim())));
    }

    if (state.cedisList && state.cedisList.length) {
    const setC = new Set(state.cedisList.map(up));
    data = data.filter(x => {
    const c = up(String(x.canalVta ?? '').trim());
    const rs = up(String(x.razonSocial ?? '').trim());
    return setC.has(c) || setC.has(rs);
    });
    }

    return data;
    }

    function filtrarProduccion(list, state) {
    let data = [...(list || [])];

    if (state.clasificaciones && state.clasificaciones.length) {
    const setClas = new Set(state.clasificaciones.map(up));
    data = data.filter(x => {
    const id = up(String(x.clasificacionId ?? x.ClasificacionId ?? '').trim());
    const nombre = up(String(x.clasificacionNombre ?? x.ClasificacionNombre ?? '').trim());
    return setClas.has(id) || setClas.has(nombre);
    });
    }

    if (state.skus && state.skus.length) {
    const setSku = new Set(state.skus.map(up));
    data = data.filter(x => setSku.has(up(String(x.productoCodigo ?? '').trim())));
    }

    return data;
    }

    function filtrarProduccionReal(list, state) {
    let data = [...(list || [])];

    if (state.clasificaciones && state.clasificaciones.length) {
    const setClas = new Set(state.clasificaciones.map(up));
    data = data.filter(x => {
    const id = up(String(x.clasificacionId ?? x.ClasificacionId ?? '').trim());
    const nombre = up(String(x.clasificacionNombre ?? x.ClasificacionNombre ?? '').trim());
    return setClas.has(id) || setClas.has(nombre);
    });
    }

    if (state.skus && state.skus.length) {
    const setSku = new Set(state.skus.map(up));
    data = data.filter(x => setSku.has(up(realSku(x))));
    }

    return data;
    }

    function filtrarVentaReal(list, state) {
    let data = [...(list || [])];

    if (state.clasificaciones && state.clasificaciones.length) {
    const setClas = new Set(state.clasificaciones.map(up));
    data = data.filter(x => {
    const id = up(String(x.clasificacionId ?? x.ClasificacionId ?? '').trim());
    const nombre = up(String(x.clasificacionNombre ?? x.ClasificacionNombre ?? '').trim());
    return setClas.has(id) || setClas.has(nombre);
    });
    }

    if (state.skus && state.skus.length) {
    const setSku = new Set(state.skus.map(up));
    data = data.filter(x => setSku.has(up(ventaSku(x))));
    }

    const pick = (obj, names) => {
    for (const n of names) {
    const v = obj?.[n];
    if (v != null) {
    const s = String(v).trim();
    if (s) return s;
    }
    }
    return '';
    };

    const fCliente  = ['razonSocial','RazonSocial','cliente','Cliente','cardName','CardName','nombreCliente','NombreCliente'];
    const fVendedor = ['vendedor','Vendedor','nombreVendedor','NombreVendedor','asesor','Asesor','slpName','SlpName','salesPerson','SalesPerson'];
    const fCedis    = ['cedis','Cedis','canalVta','CanalVta','almacen','Almacen','warehouse','Warehouse','sucursal','Sucursal'];

    const sample = data.slice(0, 30);
    const hasCliente  = sample.some(x => pick(x, fCliente));
    const hasVendedor = sample.some(x => pick(x, fVendedor));
    const hasCedis    = sample.some(x => pick(x, fCedis));

    if (state.clientes && state.clientes.length) {
    if (!hasCliente) console.warn('[VentaReal] No hay campos de CLIENTE en la data. Se omite filtro por cliente.');
    else {
    const setCli = new Set(state.clientes.map(up));
    data = data.filter(x => setCli.has(up(pick(x, fCliente))));
    }
    }

    if (state.vendedores && state.vendedores.length) {
    if (!hasVendedor) console.warn('[VentaReal] No hay campos de VENDEDOR en la data. Se omite filtro por vendedor.');
    else {
    const setVen = new Set(state.vendedores.map(up));
    data = data.filter(x => setVen.has(up(pick(x, fVendedor))));
    }
    }

    if (state.cedisList && state.cedisList.length) {
    if (!hasCedis && !hasCliente) console.warn('[VentaReal] No hay campos de CEDIS/CLIENTE en la data. Se omite filtro por cedis.');
    else {
    const setC = new Set(state.cedisList.map(up));
    data = data.filter(x => {
    const c = up(pick(x, fCedis));
    const rs = up(pick(x, fCliente));
    return setC.has(c) || setC.has(rs);
    });
    }
    }

    return data;
    }

    // =======================
    // KPIs
    // =======================

    function updateBalanceGapKpiClass(totalGap) {
    const card = document.querySelector('.bm-kpi-gap');
    if (!card) return;

    const value = Number(totalGap || 0);
    card.classList.remove('bm-kpi-gap-ok', 'bm-kpi-gap-bad', 'bm-kpi-gap-neutral');

    if (value < 0) {
    card.classList.add('bm-kpi-gap-bad');
    } else if (value > 0) {
    card.classList.add('bm-kpi-gap-ok');
    } else {
    card.classList.add('bm-kpi-gap-neutral');
    }
    }

    function setKpis({ TotalProd, TotalProdReal, TotalInv, TotalInvIdeal, TotalDisp, TotalVenta, TotalVentaReal, TotalGap, TotalPorcentaje }) {
    const el = (id) => document.getElementById(id);

    if (el('tProd')) el('tProd').textContent = fmt(TotalProd);
    if (el('tProdReal')) el('tProdReal').textContent = fmt(TotalProdReal);

    if (el('tInv')) el('tInv').textContent = fmt(TotalInv);
    if (el('tInvIdeal')) el('tInvIdeal').textContent = fmt(TotalInvIdeal);
    if (el('tDisp')) el('tDisp').textContent = fmt(TotalDisp);

    if (el('tVenta')) el('tVenta').textContent = fmt(TotalVenta);
    if (el('tVentaReal')) el('tVentaReal').textContent = fmt(TotalVentaReal);

    if (el('tGap')) el('tGap').textContent = fmt(TotalGap);
    updateBalanceGapKpiClass(TotalGap);
    if (el('tPorcentaje')) el('tPorcentaje').textContent = String(TotalPorcentaje ?? 0);
    }

    function computeTotalsFromMasterRows(rows) {
    const data = rows || [];
    return {
    TotalProd: data.reduce((a, b) => a + Number(b.planProduccion || 0), 0),
    TotalProdReal: data.reduce((a, b) => a + Number(b.produccionReal || b.realTotalMaster || 0), 0),
    TotalInv: data.reduce((a, b) => a + Number(b.inventario || 0), 0),
    TotalInvIdeal: data.reduce((a, b) => a + Number(b.invIdeal || 0), 0),
    TotalDisp: data.reduce((a, b) => a + Number(b.disponible || 0), 0),
    TotalVenta: data.reduce((a, b) => a + Number(b.presupuesto || 0), 0),
    TotalVentaReal: data.reduce((a, b) => a + Number(b.ventaReal || b.ventaRealTotalMaster || 0), 0),
    TotalGap: data.reduce((a, b) => {
    const pr = Number(b.produccionReal ?? b.realTotalMaster ?? 0);
    const disp = Number(b.disponible ?? 0);
    const vr = Number(b.ventaReal ?? b.ventaRealTotalMaster ?? 0);
    return a + calcGapProjected(pr, disp, vr);
    }, 0),
    TotalPorcentaje: (data.length ? (data.reduce((a, b) => a + Number(b.porcentaje || 0), 0) / data.length) : 0).toFixed(0)
    };
    }

    function applyMasterRowVisibility(matchSet) {
    const rows = Array.from(document.querySelectorAll('tr.master-row[data-master]'));
    rows.forEach(tr => {
    const m = tr.getAttribute('data-master');
    const show = !matchSet || (m && matchSet.has(m));
    tr.style.display = show ? '' : 'none';

    const nxt = tr.nextElementSibling;
    if (!show && nxt && nxt.classList.contains('detail-row')) nxt.remove();
    });
    }

    let KPI_REAL_TIMER = null;
    function scheduleKpiRecalcFromCurrentState() {
    if (KPI_REAL_TIMER) clearTimeout(KPI_REAL_TIMER);
    KPI_REAL_TIMER = setTimeout(() => {
    try {
    const state = getFilterState();
    if (!isAnyFilterActive(state)) {
    setKpis(computeTotalsFromMasterRows(MASTER_DATA));
    } else {
    applyGlobalFiltersAndKpis().catch(console.error);
    }
    } catch (e) {
    console.error(e);
    }
    }, 200);
    }

    // =======================
    // Aplicar filtros globales
    // =======================
    let FILTER_TIMER = null;
    let FILTER_RUN_ID = 0;

    function updateOpenDetailAndModalFast() {
    if (LAST_OPEN_MASTER) {
    const row = document.querySelector(`tr.master-row[data-master="${LAST_OPEN_MASTER}"]`);
    const btn = row?.querySelector('.expander-btn');
    const expanded = btn?.getAttribute('aria-expanded') === 'true';
    if (expanded) {
    const idSuffix = safeId(LAST_OPEN_MASTER);
    const pres = CACHE_PRES.get(LAST_OPEN_MASTER) || [];
    const prod = CACHE_PROD.get(LAST_OPEN_MASTER) || [];
    const real = CACHE_PROD_REAL.get(LAST_OPEN_MASTER) || [];
    const venta = CACHE_VENTA_REAL.get(LAST_OPEN_MASTER) || [];
    const inv = CACHE_INV_SKU.get(LAST_OPEN_MASTER) || [];
    renderDetalleConData(LAST_OPEN_MASTER, idSuffix, pres, prod, real, venta, inv);
    }
    }

    const presModal = document.getElementById('presupuestoModal');
    if (presModal && presModal.classList.contains('show')) {
    const state = getFilterState();
    const filtered = filtrarPresupuesto(PRES_MODAL_RAW, state);
    renderPresupuestoTable(filtered);
    }
