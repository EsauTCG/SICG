        const response = await fetch(url, noCacheFetchOpts);
        const data = await response.json();

    MASTER_DATA = (data || [])
    .map(x => ({
    u_MASTER: String(x?.u_MASTER ?? '').trim() || 'SIN MASTER',
    rotacion: Number(x.rotacion),
    planProduccion: Number(x.planProduccion),
    produccionReal: null,
    realTotalMaster: null,
    ventaReal: null,
    ventaRealTotalMaster: null,
    inventario: Number(x.inventario),
    invIdeal: Number(x.invIdeal),
    disponible: Number(x.disponible),
    presupuesto: Number(x.presupuesto),
    gap: Number(x.gap),
    porcentaje: Number(x.porcentaje)
    }));

        refreshMasterMultiAfterDataLoad();
        pintarTabla(MASTER_DATA);

        setKpis(computeTotalsFromMasterRows(MASTER_DATA));
        snapshotBaseMasterView();

        scheduleApplyFilters();
        refreshPlanModalIfOpen();

        // Cargar PRODUCCIÓN REAL + VENTA REAL en paralelo
        const masters = MASTER_DATA.map(x => x.u_MASTER).filter(Boolean);
        fillProduccionRealForMasters(masters).catch(console.warn);
        fillVentaRealForMasters(masters).catch(console.warn);

      } catch (err) {
        console.error(err);
        const tb = document.getElementById('tbodyExcedidos');
        if (tb) tb.innerHTML = '<tr><td colspan="12" class="text-center text-danger">Error al cargar datos.</td></tr>';
