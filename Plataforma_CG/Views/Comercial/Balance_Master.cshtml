      // MASTER hidden: no selectionStart
      (function () {
        const masterInput = document.getElementById('fMaster');
        if (!masterInput) return;
        if ((masterInput.getAttribute('type') || '').toLowerCase() === 'hidden') return;
        const toUpperKeepCursor = () => {
          const start = masterInput.selectionStart;
          const end = masterInput.selectionEnd;
          masterInput.value = (masterInput.value || '').toUpperCase();
          if (start != null && end != null) masterInput.setSelectionRange(start, end);
        };
        masterInput.addEventListener('input', toUpperKeepCursor);
        masterInput.addEventListener('blur', toUpperKeepCursor);
      })();

      // filtros
    ['fFuente', 'fCliente', 'fVendedor', 'fCedis', 'fMaster', 'fSku', 'fClasificacion']
        .map(id => document.getElementById(id))
        .filter(Boolean)
        .forEach(el => {
          el.addEventListener('input', () => { scheduleApplyFilters(); refreshPlanModalIfOpen(); });
          el.addEventListener('change', () => { scheduleApplyFilters(); refreshPlanModalIfOpen(); });
        });

      // limpiar
      const btnClearOut = getEl('btnClearPresFilters');
      if (btnClearOut) {
        btnClearOut.addEventListener('click', () => {
          const a = getEl('fFuente'); if (a) a.value = 'TODOS';
          const b = getEl('fCliente'); if (b) b.value = '';
          const c = getEl('fVendedor'); if (c) c.value = '';
          const d = getEl('fCedis'); if (d) d.value = '';
          const m = getEl('fMaster'); if (m) m.value = '';
          const e = getEl('fSku'); if (e) e.value = '';
    const f = getEl('fClasificacion'); if (f) f.value = '';

          clearMasterMulti(false);

          const bc = getEl('btnClienteMulti'); if (bc) bc.textContent = bc.dataset.emptyLabel || 'CLIENTE';
          const bv = getEl('btnVendedorMulti'); if (bv) bv.textContent = bv.dataset.emptyLabel || 'VENDEDOR';
          const bd = getEl('btnCedisMulti'); if (bd) bd.textContent = bd.dataset.emptyLabel || 'CEDIS';
          const bs = getEl('btnSkuMulti'); if (bs) bs.textContent = bs.dataset.emptyLabel || 'SKU';
    const bc2 = getEl('btnClasificacionMulti'); if (bc2) bc2.textContent = bc2.dataset.emptyLabel || 'CLASIFICACIÓN';

          scheduleApplyFilters();
          refreshPlanModalIfOpen();
        });
      }

      // Factor (carga y actualización con Enter)
      (async () => {
        try {
          const res = await fetch('/Comercial/ObtenerFactor', noCacheFetchOpts);
          if (res.ok) {
            const data = await res.json();
            if (data && data.valor != null) {
              const inp = document.getElementById("entidad");
              if (inp) inp.value = data.valor;
            }
          }
        } catch { }

        const input = document.getElementById("entidad");
        if (!input) return;

        input.addEventListener("keydown", async e => {
          if (e.key !== "Enter") return;
          e.preventDefault();
          const valor = parseFloat(input.value);
          if (isNaN(valor)) { alert("Ingrese un valor numérico válido."); return; }
          try {
            const token = getCsrfToken();
            const res = await fetch('/Comercial/ActualizarFactor', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
              body: JSON.stringify({ valor })
            });
            if (!res.ok) throw 0;
            const result = await res.json();
            alert(result.mensaje || "Factor actualizado correctamente");
            location.reload();
          } catch {
            alert("Ocurrió un error al actualizar el factor.");
          }
        });
      })();

      // Init tabla
    (async () => {
    await cargarPermisosBalanceMaster();
    await cargarTabla();
    })();
    });

    // Expandir detalle
    document.getElementById('tbodyExcedidos')?.addEventListener('click', async (e) => {
      const btn = e.target.closest('.expander-btn');
      if (!btn) return;
      const row = btn.closest('.master-row');
      await toggleDetalle(row);
    });

    // Acciones detalle (modales)
    document.addEventListener('click', (e) => {
      const p = e.target.closest('.btn-pres-sku');
      const q = e.target.closest('.btn-plan-sku');
      if (p) openPresupuestoModal(p.getAttribute('data-master'), p.getAttribute('data-sku'));
      if (q) openPlanModal(q.getAttribute('data-master'), q.getAttribute('data-sku'));
    });

    // Cambio de mes/año: limpia cache + detalle + estado modales
    MES_SELECTOR?.addEventListener('change', async e => {
      MES = e.target.value;
      MES_CORTO = obtenerMesCorto(MES.split('-')[1] || "01");
      LAST_OPEN_MASTER = null;

      CURRENT_PLAN_MASTER = null;
      CURRENT_PLAN_SKU = null;
      PLAN_MODAL_RAW = [];

      CACHE_PRES.clear();
      CACHE_PROD.clear();
      CACHE_PROD_REAL.clear();
      CACHE_VENTA_REAL.clear();
    CACHE_INV_SKU.clear();

      await cargarTabla();
    });

    // Guardar ROT inline (si lo usas en otra parte)
    document.getElementById('tbodyExcedidos')?.addEventListener('focusout', async function (e) {
      const td = e.target.closest('.editable-rot');
      if (!td) return;
      const nuevoValor = parseInt(td.textContent.replace(/,/g, ''), 10);
      if (isNaN(nuevoValor)) { alert("Ingrese un valor numérico válido"); td.focus(); return; }
      const uMaster = td.getAttribute('data-master'); if (!uMaster) return;

      try {
        const token = getCsrfToken();
        const res = await fetch('/Comercial/ActualizarRotacion', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
          body: JSON.stringify({ U_MASTER: uMaster, Rotacion: nuevoValor })
        });
        if (!res.ok) throw 0;
        td.style.backgroundColor = "#d4edda"; setTimeout(() => td.style.backgroundColor = "", 800);
        await refreshMainAndDetail();
      } catch {
        alert("Error al actualizar ROT");
        td.style.backgroundColor = "#f8d7da"; setTimeout(() => td.style.backgroundColor = "", 800);
      }
    });
    // ====== PINTAR EN NEGRO OPCIONES SELECCIONADAS EN LOS MULTISELECT ======
    document.addEventListener('change', function (e) {
    if (e.target.matches(
    '#clienteMultiList input[type="checkbox"], ' +
    '#vendedorMultiList input[type="checkbox"], ' +
    '#cedisMultiList input[type="checkbox"], ' +
    '#masterMultiList input[type="checkbox"], ' +
    '#clasificacionMultiList input[type="checkbox"], ' +
    '#skuMultiList input[type="checkbox"]'
    )) {
    const item = e.target.closest('.form-check');
    if (item) {
    item.classList.toggle('selected', e.target.checked);
    }
    }
    });

    // ====== AL CARGAR O RENDERIZAR OPCIONES, SI YA VIENEN MARCADAS TAMBIÉN LAS PINTA ======
    function aplicarEstiloSeleccionados(contenedorId) {
    const contenedor = document.getElementById(contenedorId);
    if (!contenedor) return;

    contenedor.querySelectorAll('.form-check').forEach(item => {
    const chk = item.querySelector('input[type="checkbox"]');
    if (chk) {
    item.classList.toggle('selected', chk.checked);
    }
    });
    }

    // Ejecuta al iniciar
    document.addEventListener('DOMContentLoaded', function () {
    aplicarEstiloSeleccionados('clienteMultiList');
    aplicarEstiloSeleccionados('vendedorMultiList');
    aplicarEstiloSeleccionados('cedisMultiList');
    aplicarEstiloSeleccionados('masterMultiList');
    aplicarEstiloSeleccionados('clasificacionMultiList');
    aplicarEstiloSeleccionados('skuMultiList');
    });

    // ====== SI LLENAS LOS LISTADOS DINÁMICAMENTE, USA ESTA FUNCIÓN PARA CREAR CADA OPCIÓN ======
    function crearItemMulti(texto, valor, checked) {
    return `
    <div class="form-check ${checked ? 'selected' : ''}">
    <input class="form-check-input" type="checkbox" value="${valor}" id="chk_${valor}" ${checked ? 'checked' : ''}>
    <label class="form-check-label" for="chk_${valor}">${texto}</label>
    </div>
    `;
    }
</script>
