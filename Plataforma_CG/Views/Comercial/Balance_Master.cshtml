    const s = search.selectionStart, e = search.selectionEnd;
    search.value = up(search.value);
    if (s != null && e != null) search.setSelectionRange(s, e);
    }
    renderCheckboxList(listId, OPTIONS, SELECTED, search.value, wrapId, cfg.optionFns);
    });

    clearBtn.addEventListener('click', () => {
    SELECTED.clear();
    search.value = '';
    renderCheckboxList(listId, OPTIONS, SELECTED, search.value, wrapId, cfg.optionFns);
