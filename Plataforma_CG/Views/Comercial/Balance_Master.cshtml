    // =======================
    async function loadClasificacionOptions() {
    const masters = mastersScopeForLookups();

    await prefetchPresOnly(masters);
    await prefetchForMasters(masters);
    await prefetchRealOnly(masters);
    await prefetchVentaRealOnly(masters);

    const map = new Map();

    const addClas = (item) => {
    const id = String(item?.clasificacionId ?? item?.ClasificacionId ?? '').trim();
    const nombre = String(item?.clasificacionNombre ?? item?.ClasificacionNombre ?? '').trim();

    if (!id && !nombre) return;

    const value = up(id || nombre);
    const label = id && nombre ? `${id} - ${nombre}` : (nombre || id);

    if (!map.has(value)) {
    map.set(value, { value, label });
    }
    };

    for (const m of masters) {
    (CACHE_PRES.get(m) || []).forEach(addClas);
    (CACHE_PROD.get(m) || []).forEach(addClas);
    (CACHE_PROD_REAL.get(m) || []).forEach(addClas);
    (CACHE_VENTA_REAL.get(m) || []).forEach(addClas);
    }

    return Array.from(map.values()).sort((a, b) => a.label.localeCompare(b.label));
    }

    function mastersScopeForLookups() {
    const mastersAll = (MASTER_DATA || []).map(x => x.u_MASTER).filter(Boolean);
    const state = getFilterState?.() || {};
    const sel = state.masters || [];
    return sel.length ? mastersAll.filter(m => sel.includes(up(m))) : mastersAll;
    }

    async function prefetchPresOnly(masters) {
    const list = (masters || []).filter(Boolean);
    const toFetch = list.filter(m => !CACHE_PRES.has(m));
    if (!toFetch.length) return;

    const CONC = 6;
    let idx = 0;

    async function worker() {
    while (idx < toFetch.length) {
    const master = toFetch[idx++];
    try {
    const d = normalizeArrayResult(await cargarPresupuestosPorMaster(master), `Pres ${master}`);
    CACHE_PRES.set(master, d);
    } catch {
    CACHE_PRES.set(master, []);
    }
    }
    }

    await Promise.all(Array.from({ length: CONC }, worker));
    }

    async function prefetchRealOnly(masters) {
    const list = (masters || []).filter(Boolean);
    const toFetch = list.filter(m => !CACHE_PROD_REAL.has(m));
    if (!toFetch.length) return;

    const CONC = 6;
    let idx = 0;

    async function worker() {
    while (idx < toFetch.length) {
    const master = toFetch[idx++];
    try {
    const d = normalizeArrayResult(await cargarProduccionRealPorMaster(master), `Real ${master}`);
    CACHE_PROD_REAL.set(master, d);
    } catch {
    CACHE_PROD_REAL.set(master, []);
    }
    }
    }

    await Promise.all(Array.from({ length: CONC }, worker));
    }

