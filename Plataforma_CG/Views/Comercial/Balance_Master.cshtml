    // =======================
    const realSku  = (x) => String(x?.articuloCodigo ?? x?.ArticuloCodigo ?? x?.productoCodigo ?? x?.ProductoCodigo ?? '').trim();
    const realName = (x) => String(x?.producto ?? x?.Producto ?? x?.productoNombre ?? x?.ProductoNombre ?? '').trim();
    const realKg   = (x) => Number(x?.kgProducidos ?? x?.KgProducidos ?? x?.KGPRODUCIDOS ?? 0) || 0;

    function sumKgReal(list) {
    return (list || []).reduce((a, x) => a + realKg(x), 0);
    }

    const ventaSku  = (x) => String(x?.articulo ?? x?.Articulo ?? x?.sku ?? x?.Sku ?? x?.articuloCodigo ?? x?.ArticuloCodigo ?? '').trim();
    const ventaName = (x) => String(x?.productoNombre ?? x?.ProductoNombre ?? x?.producto ?? x?.Producto ?? '').trim();
    const ventaKg   = (x) => Number(x?.kgVendidos ?? x?.KgVendidos ?? x?.kgSurtido ?? x?.KgSurtido ?? x?.kg ?? x?.Kg ?? 0) || 0;

    function sumKgVentaReal(list) {
    return (list || []).reduce((a, x) => a + ventaKg(x), 0);
    }

    const invSku  = (x) => String(x?.sku ?? x?.SKU ?? x?.productoCodigo ?? x?.ProductoCodigo ?? x?.articuloCodigo ?? x?.ArticuloCodigo ?? '').trim();
    const invName = (x) => String(x?.productoNombre ?? x?.ProductoNombre ?? x?.producto ?? x?.Producto ?? '').trim();
    const invQty  = (x) => Number(x?.invActual ?? x?.InvActual ?? x?.inventario ?? x?.Inventario ?? x?.existencia ?? x?.Existencia ?? x?.stock ?? x?.Stock ?? 0) || 0;

    function groupSumInventarioBySku(list) {
    const map = new Map();
    (list || []).forEach(x => {
    const sku = invSku(x);
    if (!sku) return;
    const name = invName(x);
    const val = invQty(x);

    const obj = map.get(sku) || { sku, name, sum: 0 };
    obj.sum += val;
    if (!obj.name && name) obj.name = name;

    map.set(sku, obj);
    });
    return Array.from(map.values());
    }

