      if (thProd) thProd.textContent = MES_CORTO;
      if (thProdReal) thProdReal.textContent = MES_CORTO;
      if (thVenta) thVenta.textContent = MES_CORTO;
      if (thVentaReal) thVentaReal.textContent = MES_CORTO;

      try {
        closeAllDetails();

