@model TodoVentasModel
@Html.AntiForgeryToken()
@{
    ViewData["Title"] = "Balance Master";
    Layout = "~/Views/Shared/_Layout2.cshtml";

    var mes = (string)(ViewData["Mes"] ?? DateTime.Now.ToString("yyyy-MM"));

    string mesCorto;

    if (!string.IsNullOrEmpty(mes) && mes.Length >= 7)
    {
        int año = int.Parse(mes.Substring(0, 4));
        int mesNum = int.Parse(mes.Substring(5, 2));
        var fecha = new DateTime(año, mesNum, 1);
        mesCorto = fecha.ToString("MMM", new System.Globalization.CultureInfo("es-ES")).ToUpper();
    }
    else
    {
        mesCorto = DateTime.Now.ToString("MMM", new System.Globalization.CultureInfo("es-ES")).ToUpper();
    }
}

