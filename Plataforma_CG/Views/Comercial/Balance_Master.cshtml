    function updateBtnLabel(btnId, selectedSet, emptyLabel, manyFmt) {
    const btn = document.getElementById(btnId);
    if (!btn) return;

    const n = selectedSet.size;
    if (!n) btn.textContent = emptyLabel;
    else if (n === 1) btn.textContent = '1 seleccionado';
    else btn.textContent = `${n} seleccionados`;
    }

    function renderCheckboxList(listId, options, selectedSet, query, idPrefix, optFns) {
    const listEl = document.getElementById(listId);
    if (!listEl) return;

    const fns = optFns || {};
    const getValue = fns.getValue || (x => x);
    const getLabel = fns.getLabel || (x => x);
    const getSearch = fns.getSearch || (x => x);

    const q = up(query || '');
    const opts = Array.isArray(options) ? options : [];

    if (!opts.length) {
    listEl.innerHTML = `<div class="text-muted small px-2 py-2">Sin opciones disponibles</div>`;
    return;
    }

    const filtered = opts.filter(opt => {
    const s = up(getSearch(opt) || '');
    return !q || s.includes(q);
    });

    if (!filtered.length) {
    listEl.innerHTML = `<div class="text-muted small px-2 py-2">Sin resultados</div>`;
    return;
    }

    const allSelected = filtered.length > 0 && filtered.every(opt => {
    const val = up(String(getValue(opt) ?? '').trim());
    return selectedSet.has(val);
    });

    const selectAllId = `${idPrefix}-select-all`;

    let html = `
    <label class="multi-sigo-item select-all ${allSelected ? 'selected' : ''}" for="${selectAllId}">
    <input class="multi-opt-select-all" type="checkbox" id="${selectAllId}" ${allSelected ? 'checked' : ''}>
    <span>Seleccionar todo</span>
    </label>
    `;

    html += filtered.map(opt => {
    const val = up(String(getValue(opt) ?? '').trim());
    const label = String(getLabel(opt) ?? '').trim() || val;
    const id = `${idPrefix}-${safeId(val)}`;
    const isSelected = selectedSet.has(val);

    return `
    <label class="multi-sigo-item ${isSelected ? 'selected' : ''}" for="${id}">
    <input class="multi-opt" type="checkbox" value="${escHtml(val)}" id="${id}" ${isSelected ? 'checked' : ''}>
    <span>${escHtml(label)}</span>
    </label>`;
    }).join('');

    listEl.innerHTML = html;
    }

