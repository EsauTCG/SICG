    // =======================
    // Plan Producción modal
    // =======================
    let CURRENT_PLAN_MASTER = null;
    let CURRENT_PLAN_SKU = null;
    let PLAN_MODAL_RAW = [];

    const parseMxFloat = (val) => {
      const s = String(val ?? '').replace(/\s+/g, '').replace(/,/g, '');
      const n = parseFloat(s);
      return Number.isFinite(n) ? n : NaN;
    };

    const formatMx = (n) => Number(n || 0).toLocaleString('es-MX');

    function ensurePlanFooter() {
      const table = document.getElementById('tablaPlanProduccion');
      if (!table) return;
      if (!table.querySelector('tfoot')) {
        const tfoot = document.createElement('tfoot');
        tfoot.innerHTML = `
          <tr class="table-light">
            <th colspan="2" class="text-end">Total:</th>
            <th class="text-end" id="planTotalCell">0</th>
          </tr>`;
        table.appendChild(tfoot);
      }
    }

    function recalcPlanModalTotal() {
      const tbody = document.querySelector('#tablaPlanProduccion tbody');
      let total = 0;
      tbody?.querySelectorAll('tr').forEach(tr => {
        const lastTd = tr.lastElementChild;
        if (!lastTd) return;
        const v = parseMxFloat(lastTd.textContent || '0');
        if (!isNaN(v)) total += v;
      });
      const cell = document.getElementById('planTotalCell');
      if (cell) cell.textContent = formatMx(total);
    }

    function sanitizeEditableNumberCell(el, allowDecimal = true) {
      if (!el) return;
      let t = String(el.textContent ?? '');
      t = t.replace(/[^\d.,]/g, '');
      t = t.replace(/,/g, '');
      if (allowDecimal) {
        const parts = t.split('.');
        if (parts.length > 2) t = parts[0] + '.' + parts.slice(1).join('');
      } else {
        t = t.replace(/\./g, '');
      }
      el.textContent = t;
    }

    function renderPlanTable(data) {
      ensurePlanFooter();
      const tbody = $("#tablaPlanProduccion tbody");
      tbody.empty();

      if (data && data.length) {
        data.forEach(item => {
          tbody.append(`
            <tr data-id="${item.id}">
              <td>${item.productoCodigo ?? ''}</td>
              <td>${item.productoNombre ?? ''}</td>
              <td class="number editable-plan" contenteditable="true">${formatMx(item.plan || 0)}</td>
            </tr>`);
        });

        tbody.find(".editable-plan").off("input").on("input", function () {
          sanitizeEditableNumberCell(this, true);
        });

        tbody.find(".editable-plan").off("keydown").on("keydown", function (e) {
          if (e.ctrlKey || e.metaKey || e.altKey) return;
          const k = e.key;

          const allowed = ['Backspace', 'Delete', 'ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown', 'Home', 'End', 'Tab', 'Enter'];
          if (allowed.includes(k)) return;

          if (/^\d$/.test(k)) return;

          if (k === '.') {
            const txt = String(this.textContent || '');
            if (txt.includes('.')) e.preventDefault();
            return;
          }
          if (k === ',') { e.preventDefault(); return; }

          e.preventDefault();
        });

        tbody.find(".editable-plan").off("blur").on("blur", async function () {
          const td = $(this);
          const tr = td.closest('tr');
          const id = Number(tr.data('id'));

          sanitizeEditableNumberCell(td.get(0), true);

          const nuevo = parseMxFloat(td.text());
          if (isNaN(nuevo)) { alert('Ingrese un número'); td.focus(); return; }
          if (nuevo < 0) { alert('No se permiten negativos'); td.focus(); return; }

          try {
            const token = getCsrfToken();

            await $.ajax({
              url: "/Comercial/ActualizarPlanProduccion",
              type: "POST",
              cache: false,
              contentType: "application/json",
              headers: { 'RequestVerificationToken': token },
              data: JSON.stringify({ id, plan: nuevo })
            });

            td.text(formatMx(nuevo));
            td.css("background", "#d4edda"); setTimeout(() => td.css("background", ""), 600);
            recalcPlanModalTotal();
            await refreshMainAndDetail();
          } catch (err) {
            td.css("background", "#f8d7da"); setTimeout(() => td.css("background", ""), 600);
            alert("Error al actualizar el plan");
          }
        });

      } else {
        tbody.append('<tr><td colspan="3" class="text-center">No hay datos</td></tr>');
      }

      recalcPlanModalTotal();
    }

    function filterPlanByGlobalSku(list) {
      const state = (typeof getFilterState === 'function') ? getFilterState() : {};
      const skus = state?.skus || [];
      if (!skus.length) return list || [];
      const setSku = new Set(skus.map(up));
      return (list || []).filter(x => setSku.has(up(String(x.productoCodigo ?? '').trim())));
    }

    function refreshPlanModalIfOpen() {
      const modal = document.getElementById('planProduccionModal');
      if (!modal || !modal.classList.contains('show')) return;
