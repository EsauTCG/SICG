    // =======================
    // Excel (export completo)
    // =======================
    function normalizaNumero(n) { const v = Number(n ?? 0); return isNaN(v) ? 0 : v; }

    function combinarSumsPorSku3(presBySku, prodBySku, realBySku) {
      const idx = new Map();
      (presBySku || []).forEach(x => idx.set(x.sku, { sku: x.sku, name: x.name, pres: x.sum || 0, prod: 0, real: 0 }));
      (prodBySku || []).forEach(x => {
        const o = idx.get(x.sku) || { sku: x.sku, name: x.name, pres: 0, prod: 0, real: 0 };
        o.prod += (x.sum || 0);
        if (!o.name) o.name = x.name;
        idx.set(x.sku, o);
      });
      (realBySku || []).forEach(x => {
        const o = idx.get(x.sku) || { sku: x.sku, name: x.name, pres: 0, prod: 0, real: 0 };
        o.real += (x.sum || 0);
        if (!o.name) o.name = x.name;
        idx.set(x.sku, o);
      });
      return Array.from(idx.values()).sort((a, b) => String(a.sku).localeCompare(String(b.sku)));
    }

    async function obtenerInventarioAgrupadoSeguro() {
      const [anio, mes] = MES.split('-');
      const url = `/Comercial/ObtenerInventarioAgrupado?mes=${mes}&anio=${anio}&año=${anio}&t=${Date.now()}`;
      try {
        const res = await fetch(url, noCacheFetchOpts);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const ct = res.headers.get('content-type') || '';
        if (!ct.includes('application/json')) throw new Error('Respuesta no es JSON');
        const json = await res.json();
        if (!Array.isArray(json)) throw new Error('JSON no es un arreglo');
        return json;
      } catch (err) {
        console.warn('Fallo obtenerInventarioAgrupado, fallback DOM:', err);
        const rows = Array.from(document.querySelectorAll('tr.master-row[data-master]'));
        const mastersDOM = rows.map(r => r.getAttribute('data-master')).filter(Boolean);
        return mastersDOM.map(m => ({
          u_MASTER: m, rotacion: 0, planProduccion: 0, inventario: 0,
          invIdeal: 0, disponible: 0, presupuesto: 0, gap: 0, porcentaje: 0
        }));
      }
    }

    async function exportExcelCompletoRobusto() {
      const mastersData = await obtenerInventarioAgrupadoSeguro();
      const masters = [...new Set((mastersData || []).map(x => x.u_MASTER).filter(Boolean))];
      if (!masters.length) { alert('No hay masters para exportar.'); return; }

      const detalleSku = [];
      const presupuestoRaw = [];
      const planRaw = [];
      const realRaw = [];

      for (const master of masters) {
        let pres = [], prod = [], real = [];
        try {
          const r = await Promise.allSettled([
            cargarPresupuestosPorMaster(master),
            cargarProduccionPorMaster(master),
            cargarProduccionRealPorMaster(master)
          ]);
          if (r[0].status === 'fulfilled' && Array.isArray(r[0].value)) pres = r[0].value;
          if (r[1].status === 'fulfilled' && Array.isArray(r[1].value)) prod = r[1].value;
          if (r[2].status === 'fulfilled' && Array.isArray(r[2].value)) real = r[2].value;
        } catch (e) { console.warn(`Fallo datos ${master}:`, e); }

        (pres || []).forEach(p => presupuestoRaw.push({
          master,
          canalVta: p.canalVta ?? '',
          estatus: p.estatus ?? '',
          razonSocial: p.razonSocial ?? '',
          productoCodigo: p.productoCodigo ?? '',
          productoNombre: p.productoNombre ?? '',
          presupuesto: normalizaNumero(p.presupuesto),
          fuente: (p.fuente || 'GENERAL')
        }));

        (prod || []).forEach(p => planRaw.push({
          master,
          productoCodigo: p.productoCodigo ?? '',
          productoNombre: p.productoNombre ?? '',
          plan: normalizaNumero(p.plan)
        }));

        (real || []).forEach(rr => realRaw.push({
          master,
          articuloCodigo: realSku(rr),
          producto: realName(rr),
          kgProducidos: normalizaNumero(realKg(rr)),
          dia: rr?.dia ?? rr?.Dia ?? '',
          mes: rr?.mes ?? rr?.Mes ?? '',
          anio: rr?.anio ?? rr?.Anio ?? ''
        }));

        const presBySku = groupSumBySku(pres, 'productoCodigo', 'productoNombre', 'presupuesto');
        const prodBySku = groupSumBySku(prod, 'productoCodigo', 'productoNombre', 'plan');
        const realBySku = groupSumRealBySku(real);

        combinarSumsPorSku3(presBySku, prodBySku, realBySku).forEach(r => {
          detalleSku.push({
            master,
            sku: r.sku,
            producto: r.name ?? '',
            presupuesto: normalizaNumero(r.pres),
            produccionPlan: normalizaNumero(r.prod),
            produccionReal: normalizaNumero(r.real),
            difPlanVsPres: normalizaNumero(r.prod) - normalizaNumero(r.pres),
            difRealVsPlan: normalizaNumero(r.real) - normalizaNumero(r.prod)
          });
        });
      }

      const realTotByMaster = new Map();
      (realRaw || []).forEach(x => {
        const m = String(x.master || '').trim();
        if (!m) return;
        const prev = realTotByMaster.get(m) || 0;
        realTotByMaster.set(m, prev + normalizaNumero(x.kgProducidos));
      });

      const hojaMaster = XLSX.utils.json_to_sheet((mastersData || []).map(x => {
        const m = String(x.u_MASTER || '').trim();
        return {
          MASTER: x.u_MASTER,
          Rotación: normalizaNumero(x.rotacion),
          Producción: normalizaNumero(x.planProduccion),
          'Producción Real': normalizaNumero(realTotByMaster.get(m) || 0),
          Inventario: normalizaNumero(x.inventario),
          'Inventario ideal': normalizaNumero(x.invIdeal),
          Disponible: normalizaNumero(x.disponible),
          Presupuesto: normalizaNumero(x.presupuesto),
          Gap: normalizaNumero(x.gap),
          '%': normalizaNumero(x.porcentaje)
        };
      }));

      const hojaDetalle = XLSX.utils.json_to_sheet(detalleSku);
      const hojaPres = XLSX.utils.json_to_sheet(presupuestoRaw);
      const hojaPlan = XLSX.utils.json_to_sheet(planRaw);
      const hojaReal = XLSX.utils.json_to_sheet(realRaw);

      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, hojaMaster, 'Master');
      XLSX.utils.book_append_sheet(wb, hojaDetalle, 'Detalle SKU (sumas)');
      XLSX.utils.book_append_sheet(wb, hojaPres, 'Presupuesto (raw)');
      XLSX.utils.book_append_sheet(wb, hojaPlan, 'Plan (raw)');
      XLSX.utils.book_append_sheet(wb, hojaReal, 'Producción Real (raw)');

      XLSX.writeFile(wb, `BalanceMaster_${MES}.xlsx`);
    }

