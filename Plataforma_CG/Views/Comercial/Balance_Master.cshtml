    updateBtnLabel(btnId, SELECTED, emptyLabel, manyLabel);
    try { bootstrap.Dropdown.getOrCreateInstance(btn).hide(); } catch {}
    });

    applyBtn.addEventListener('click', () => {
    writeCsvHidden(hiddenId, SELECTED, true);
    try { bootstrap.Dropdown.getOrCreateInstance(btn).hide(); } catch {}
    });

    const dd = bootstrap?.Dropdown ? bootstrap.Dropdown.getOrCreateInstance(btn, { autoClose: 'outside' }) : null;
    wrap.addEventListener('click', (e) => e.stopPropagation());

    btn.addEventListener('click', async (e) => {
    e.preventDefault();
    if (dd) dd.toggle();

    SELECTED = new Set(parseCsvHidden(hiddenId));
    updateBtnLabel(btnId, SELECTED, emptyLabel, manyLabel);

    if (!LOADED) {
    list.innerHTML = `<div class="text-muted small px-1">Cargando…</div>`;
    try { OPTIONS = await loadOptions(); } catch { OPTIONS = []; }
    LOADED = true;
    }

    renderCheckboxList(listId, OPTIONS, SELECTED, search.value, wrapId, cfg.optionFns);
    search.focus();
    });

    btn.dataset.emptyLabel = emptyLabel;
    }

