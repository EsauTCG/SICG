    function parseCsvHidden(id) {
    const v = String(document.getElementById(id)?.value || '').trim();
    return v ? v.split(',').map(x => up(x.trim())).filter(Boolean) : [];
    }

    function writeCsvHidden(id, set, fireEvents = true) {
    const el = document.getElementById(id);
    if (!el) return;
    el.value = Array.from(set).join(',');
    if (fireEvents) {
