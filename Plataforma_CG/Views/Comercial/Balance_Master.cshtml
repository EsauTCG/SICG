    // =======================
    // Detalle por SKU
    // =======================
    function renderDetalleConData(master, idSuffix, presList, prodList, realList, ventaList, invList = []) {
    const state = getFilterState();

    const pres = filtrarPresupuesto(presList, state);
    const prod = filtrarProduccion(prodList, state);
    let real = filtrarProduccionReal(realList, state);
    let ventaReal = filtrarVentaReal(ventaList || [], state);

    const presActive = presupuestoFiltersActiveFromState(state);
    const skuActive = (state.skus && state.skus.length > 0);
    const clasificacionActive = (state.clasificaciones && state.clasificaciones.length > 0);

    if (!skuActive) {
    let skuSet = null;

    if (clasificacionActive) {
    skuSet = skuSetFromSources(pres, prod, real, ventaReal);
    } else if (presActive) {
    skuSet = skuSetFromPresupuesto(pres);
    }

    if (skuSet && skuSet.size) {
    real = filtrarRealPorSkuSet(real, skuSet, realSku);
    ventaReal = filtrarRealPorSkuSet(ventaReal, skuSet, ventaSku);
    }
    }

    const presBySku = groupSumBySku(pres, 'productoCodigo', 'productoNombre', 'presupuesto');
    const prodBySku = groupSumBySku(prod, 'productoCodigo', 'productoNombre', 'plan');
    const realBySku = groupSumRealBySku(real);
    const ventaBySku = groupSumVentaRealBySku(ventaReal);
    const invBySku = groupSumInventarioBySku(invList);

    const presMap = new Map(presBySku.map(x => [x.sku, x]));
    const prodMap = new Map(prodBySku.map(x => [x.sku, x]));
    const realMap = new Map(realBySku.map(x => [x.sku, x]));
    const ventaMap = new Map(ventaBySku.map(x => [x.sku, x]));
    const invMap = new Map(invBySku.map(x => [x.sku, x]));

    const allSkus = new Set([
    ...presBySku.map(x => x.sku),
    ...prodBySku.map(x => x.sku),
    ...realBySku.map(x => x.sku),
    ...ventaBySku.map(x => x.sku)
    ]);

    const invMapFiltrado = new Map(
    Array.from(invMap.entries()).filter(([sku]) => allSkus.has(sku))
    );

    const rows = Array.from(allSkus).sort().map(sku => {
    const p = presMap.get(sku)?.sum || 0;
    const pl = prodMap.get(sku)?.sum || 0;
    const r = realMap.get(sku)?.sum || 0;
    const v = ventaMap.get(sku)?.sum || 0;
    const inv = invMapFiltrado.get(sku)?.sum || 0;

    const nombre =
    presMap.get(sku)?.name ||
    prodMap.get(sku)?.name ||
    realMap.get(sku)?.name ||
    ventaMap.get(sku)?.name ||
    invMap.get(sku)?.name ||
    '';

    const gap = calcGapProjectedByInv(r, inv, v);

    const btnPres = permisosBalance.presupuesto.puedeLeer
    ? `<button type="button"
    class="btn btn-sm btn-outline-danger btn-pres-sku"
    data-master="${escHtml(master)}"
    data-sku="${escHtml(sku)}">
    Presupuesto
    </button>`
    : '';

    const btnPlan = permisosBalance.produccion.puedeLeer
    ? `<button type="button"
    class="btn btn-sm btn-outline-primary btn-plan-sku"
    data-master="${escHtml(master)}"
    data-sku="${escHtml(sku)}">
    Producción
    </button>`
    : '';

    return `
    <tr>
    <td>${escHtml(sku)}</td>
    <td>${escHtml(nombre)}</td>
    <td class="text-end">${fmt(inv)}</td>
    <td class="text-end">${fmt(p)}</td>
    <td class="text-end">${fmt(pl)}</td>
    <td class="text-end">${fmt(r)}</td>
    <td class="text-end">${fmt(v)}</td>
    <td class="text-end">
    <span class="${gap < 0 ? 'badge-neg' : 'badge-pos'}">${fmt(gap)}</span>
    </td>
    <td>
    <div class="d-flex gap-1 flex-wrap">
    ${btnPres}
    ${btnPlan}
    </div>
    </td>
    </tr>`;
    }).join('');

    const tbody = document.getElementById(`tbody-sum-${idSuffix}`);
    if (tbody) {
    tbody.innerHTML = rows || `<tr><td colspan="9" class="text-center text-muted">Sin datos</td></tr>`;
    }

    const totInv = Array.from(allSkus).reduce((a, sku) => a + (invMapFiltrado.get(sku)?.sum || 0), 0);
    const totPres = Array.from(allSkus).reduce((a, sku) => a + (presMap.get(sku)?.sum || 0), 0);
    const totProd = Array.from(allSkus).reduce((a, sku) => a + (prodMap.get(sku)?.sum || 0), 0);
    const totReal = Array.from(allSkus).reduce((a, sku) => a + (realMap.get(sku)?.sum || 0), 0);
    const totVenta = Array.from(allSkus).reduce((a, sku) => a + (ventaMap.get(sku)?.sum || 0), 0);

    const totDif = Array.from(allSkus).reduce((a, sku) => {
    const inv = invMapFiltrado.get(sku)?.sum || 0;
    const r = realMap.get(sku)?.sum || 0;
    const v = ventaMap.get(sku)?.sum || 0;
    return a + calcGapProjectedByInv(r, inv, v);
    }, 0);

    document.getElementById(`tot-inv-${idSuffix}`)?.replaceChildren(document.createTextNode(fmt(totInv)));
    document.getElementById(`tot-pres-${idSuffix}`)?.replaceChildren(document.createTextNode(fmt(totPres)));
    document.getElementById(`tot-prod-${idSuffix}`)?.replaceChildren(document.createTextNode(fmt(totProd)));
    document.getElementById(`tot-real-${idSuffix}`)?.replaceChildren(document.createTextNode(fmt(totReal)));
    document.getElementById(`tot-venta-${idSuffix}`)?.replaceChildren(document.createTextNode(fmt(totVenta)));
    document.getElementById(`tot-dif-${idSuffix}`)?.replaceChildren(document.createTextNode(fmt(totDif)));
    }

    // =======================
    // Expandir detalle
    // =======================
    async function toggleDetalle(row) {
    const btn = row.querySelector('.expander-btn');
    const master = row.getAttribute('data-master');
    const idSuffix = safeId(master);
    const expanded = btn.getAttribute('aria-expanded') === 'true';

    const existing = row.nextElementSibling;
    if (expanded && existing && existing.classList.contains('detail-row')) {
    existing.remove();
    btn.setAttribute('aria-expanded', 'false');
    return;
    }

    closeAllDetails();
    row.insertAdjacentHTML('afterend', renderDetailSkeleton(master, idSuffix));
    btn.setAttribute('aria-expanded', 'true');
    LAST_OPEN_MASTER = master;

    try {
    const r = await Promise.allSettled([
    CACHE_PRES.has(master) ? CACHE_PRES.get(master) : cargarPresupuestosPorMaster(master),
    CACHE_PROD.has(master) ? CACHE_PROD.get(master) : cargarProduccionPorMaster(master),
    CACHE_PROD_REAL.has(master) ? CACHE_PROD_REAL.get(master) : cargarProduccionRealPorMaster(master),
    CACHE_VENTA_REAL.has(master) ? CACHE_VENTA_REAL.get(master) : cargarVentaRealPorMaster(master),
    CACHE_INV_SKU.has(master) ? CACHE_INV_SKU.get(master) : cargarInventarioPorMaster(master)
    ]);

    const pres  = normalizeArrayResult((r[0].status === 'fulfilled' ? r[0].value : []), `Pres(det) ${master}`);
    const prod  = normalizeArrayResult((r[1].status === 'fulfilled' ? r[1].value : []), `Plan(det) ${master}`);
    const real  = normalizeArrayResult((r[2].status === 'fulfilled' ? r[2].value : []), `Real(det) ${master}`);
    const venta = normalizeArrayResult((r[3].status === 'fulfilled' ? r[3].value : []), `Venta(det) ${master}`);
    const inv   = normalizeArrayResult((r[4].status === 'fulfilled' ? r[4].value : []), `Inv(det) ${master}`);

    CACHE_PRES.set(master, pres);
    CACHE_PROD.set(master, prod);
    CACHE_PROD_REAL.set(master, real);
    CACHE_VENTA_REAL.set(master, venta);
    CACHE_INV_SKU.set(master, inv);

    renderDetalleConData(master, idSuffix, pres, prod, real, venta, inv);

    if (r.some(x => x.status === 'rejected')) {
    const tb = document.getElementById(`tbody-sum-${idSuffix}`);
    if (tb) {
    tb.insertAdjacentHTML('afterbegin', `
    <tr>
    <td colspan="9" class="text-center text-warning small">
    Advertencia: una de las fuentes no respondió. Revisa Network/Console.
    </td>
    </tr>`);
    }
    }
    } catch (err) {
    console.error(err);
    const tb = document.getElementById(`tbody-sum-${idSuffix}`);
    if (tb) tb.innerHTML = `<tr><td colspan="9" class="text-danger text-center">Error al cargar el detalle.</td></tr>`;
    }
    }

    // =======================
    // Producción real principal
    // =======================
    async function fillProduccionRealForMasters(masters) {
    const list = (masters || []).filter(Boolean);
    if (!list.length) return;

    const CONC = 6;
    let idx = 0;

    const updateRowCell = (master, totalReal) => {
    const rowObj = MASTER_DATA.find(x => String(x.u_MASTER ?? '').trim() === String(master ?? '').trim());
    if (rowObj) {
    rowObj.produccionReal = Number(totalReal || 0);
    rowObj.realTotalMaster = Number(totalReal || 0);
    }

    if (BASE_MASTER_VIEW.has(master)) {
    const b = BASE_MASTER_VIEW.get(master);
    b.produccionReal = Number(totalReal || 0);
    BASE_MASTER_VIEW.set(master, b);
    }

    const tr = document.querySelector(`tr.master-row[data-master="${master}"]`);
    if (tr) {
    const tds = tr.querySelectorAll('td');

    if (tds[3]) tds[3].textContent = fmt(totalReal || 0);
    if (tds[4]) tds[4].innerHTML = renderTrendCellProjectedOnly(Number(totalReal || 0));

    if (tds[9]) {
    const disp = Number(tr.getAttribute('data-disponible') ?? rowObj?.disponible ?? 0);
    const vr = Number(rowObj?.ventaReal ?? 0);
    const gapNow = calcGapProjected(Number(totalReal ?? 0), disp, vr);
    tds[9].innerHTML = `<span class="${gapNow < 0 ? 'badge-neg' : 'badge-pos'}">${fmt(gapNow)}</span>`;
    }
    }

    if (LAST_OPEN_MASTER && LAST_OPEN_MASTER === master) {
    const row = document.querySelector(`tr.master-row[data-master="${master}"]`);
    const btn = row?.querySelector('.expander-btn');
    const expanded = btn?.getAttribute('aria-expanded') === 'true';
    if (expanded) {
    const idSuffix = safeId(master);
    renderDetalleConData(
    master,
    idSuffix,
    CACHE_PRES.get(master) || [],
    CACHE_PROD.get(master) || [],
    CACHE_PROD_REAL.get(master) || [],
    CACHE_VENTA_REAL.get(master) || [],
    CACHE_INV_SKU.get(master) || []
    );
    }
    }

    scheduleKpiRecalcFromCurrentState();
    };

    async function worker() {
    while (idx < list.length) {
    const master = list[idx++];
    try {
    const data = CACHE_PROD_REAL.has(master) ? CACHE_PROD_REAL.get(master) : await cargarProduccionRealPorMaster(master);
    const arr = normalizeArrayResult(data, `Real ${master}`);
    CACHE_PROD_REAL.set(master, arr);
    updateRowCell(master, sumKgReal(arr));
    } catch (e) {
    console.warn(`Real ${master} fallo:`, e);
    CACHE_PROD_REAL.set(master, []);
    updateRowCell(master, 0);
    }
    }
    }

    await Promise.all(Array.from({ length: CONC }, worker));
    scheduleKpiRecalcFromCurrentState();
    }

    // =======================
    // Venta real en tabla principal
    // =======================
    async function fillVentaRealForMasters(masters) {
      const list = (masters || []).filter(Boolean);
      if (!list.length) return;

      const CONC = 6;
      let idx = 0;

      const updateRowCell = (master, totalVentaReal) => {
        const rowObj = MASTER_DATA.find(x => String(x.u_MASTER ?? '').trim() === String(master ?? '').trim());
        if (rowObj) {
          rowObj.ventaReal = Number(totalVentaReal || 0);
          rowObj.ventaRealTotalMaster = Number(totalVentaReal || 0);
        }

        if (BASE_MASTER_VIEW.has(master)) {
          const b = BASE_MASTER_VIEW.get(master);
          b.ventaReal = Number(totalVentaReal || 0);
          BASE_MASTER_VIEW.set(master, b);
        }

           const tr = document.querySelector(`tr.master-row[data-master="${master}"]`);
    if (tr) {
      const tds = tr.querySelectorAll('td');

      if (tds[7]) tds[7].textContent = fmt(totalVentaReal || 0);
      if (tds[8]) tds[8].innerHTML = renderTrendCellProjectedOnly(Number(totalVentaReal || 0));

      // ✅ GAP dentro del if(tr)
      if (tds[9]) {
        const disp = Number(tr.getAttribute('data-disponible') ?? rowObj?.disponible ?? 0);
        const pr = Number(rowObj?.produccionReal ?? 0);
        const gapNow = calcGapProjected(pr, disp, Number(totalVentaReal ?? 0));
        tds[9].innerHTML = `<span class="${gapNow < 0 ? 'badge-neg' : 'badge-pos'}">${fmt(gapNow)}</span>`;
      }
    }


        // refrescar detalle si abierto
        if (LAST_OPEN_MASTER && LAST_OPEN_MASTER === master) {
          const row = document.querySelector(`tr.master-row[data-master="${master}"]`);
          const btn = row?.querySelector('.expander-btn');
          const expanded = btn?.getAttribute('aria-expanded') === 'true';
          if (expanded) {
            const idSuffix = safeId(master);
            renderDetalleConData(
              master,
              idSuffix,
              CACHE_PRES.get(master) || [],
              CACHE_PROD.get(master) || [],
              CACHE_PROD_REAL.get(master) || [],
              CACHE_VENTA_REAL.get(master) || [],
    CACHE_INV_SKU.get(master) || []
            );
          }
        }

        scheduleKpiRecalcFromCurrentState();
      };

      async function worker() {
        while (idx < list.length) {
          const master = list[idx++];
          try {
            const data = CACHE_VENTA_REAL.has(master) ? CACHE_VENTA_REAL.get(master) : await cargarVentaRealPorMaster(master);
            const arr = normalizeArrayResult(data, `VentaReal ${master}`);
            CACHE_VENTA_REAL.set(master, arr);
            updateRowCell(master, sumKgVentaReal(arr));
          } catch (e) {
            console.warn(`VentaReal ${master} fallo:`, e);
            CACHE_VENTA_REAL.set(master, []);
            updateRowCell(master, 0);
          }
        }
      }

      await Promise.all(Array.from({ length: CONC }, worker));
      scheduleKpiRecalcFromCurrentState();
    }

    // =======================
    // Presupuesto Modal
    // =======================
    function ensurePresupuestoFooter() {
      const table = document.getElementById('tablaPresupuesto');
      if (!table) return;
      if (!table.querySelector('tfoot')) {
        const tfoot = document.createElement('tfoot');
        tfoot.innerHTML = `
          <tr class="table-light">
            <th colspan="4" class="text-end">Total:</th>
            <th class="text-end" id="presuTotalCell">0</th>
          </tr>`;
        table.appendChild(tfoot);
      }
    }

    function recalcPresupuestoModalTotal() {
      const tbody = document.querySelector('#tablaPresupuesto tbody');
      let total = 0;
      tbody?.querySelectorAll('tr').forEach(tr => {
        const lastTd = tr.lastElementChild;
        if (!lastTd) return;
        const v = parseFloat(String(lastTd.textContent || '0').replace(/,/g, ''));
        if (!isNaN(v)) total += v;
      });
      const cell = document.getElementById('presuTotalCell');
      if (cell) cell.textContent = Number(total).toLocaleString('es-MX');
    }

    function patchPresupuestoInList(list, id, fuente, nuevo) {
      if (!Array.isArray(list)) return false;
      const f = up(fuente || 'GENERAL');
      let touched = false;

      for (const it of list) {
        const itId = Number(it?.id ?? it?.Id ?? 0);
        const itFuente = up(it?.fuente ?? it?.Fuente ?? 'GENERAL');
        if (itId === Number(id) && itFuente === f) {
          it.presupuesto = Number(nuevo);
          touched = true;
        }
      }
      return touched;
    }

    function patchPresupuestoCaches({ master, id, fuente, nuevo }) {
      patchPresupuestoInList(PRES_MODAL_RAW, id, fuente, nuevo);
      if (master && CACHE_PRES.has(master)) {
        patchPresupuestoInList(CACHE_PRES.get(master), id, fuente, nuevo);
      }
    }


    function patchMasterRowFromCache(master) {
      if (!master) return;

      const presAll = CACHE_PRES.get(master);
      if (!Array.isArray(presAll)) return;

      const totalPres = presAll.reduce((a, x) => a + Number(x?.presupuesto || 0), 0);

      const mRow = MASTER_DATA.find(x =>
        String(x.u_MASTER ?? '').trim() === String(master ?? '').trim()
      );
      if (!mRow) return;

      const inv = Number(mRow.inventario ?? 0);
      const prodReal = Number(mRow.produccionReal ?? mRow.realTotalMaster ?? 0);
      const ventaReal = Number(mRow.ventaReal ?? mRow.ventaRealTotalMaster ?? 0);
      const disp = Number(mRow.disponible ?? 0); // ✅ FIX

      const gapNew = calcGapProjected(prodReal, disp, ventaReal);

      mRow.presupuesto = totalPres;
      mRow.gap = gapNew;

      const tr = document.querySelector(`tr.master-row[data-master="${master}"]`);
      if (!tr) return;

      const tds = tr.querySelectorAll('td');

      if (tds[6]) tds[6].textContent = fmt(totalPres);
      if (tds[9]) {
        tds[9].innerHTML =
          `<span class="${gapNew < 0 ? 'badge-neg' : 'badge-pos'}">${fmt(gapNew)}</span>`;
      }
    }


    function calcGapProjectedByInv(prodReal, inventario, ventaReal) {
      const tp = projectedMonthValue(Number(prodReal ?? 0));     // TEND PROD
      const tv = projectedMonthValue(Number(ventaReal ?? 0));    // TEND VENTA
      return tp + Number(inventario ?? 0) - tv;
    }


    function renderPlanTable(rows) {
    const tbody = $("#tablaPlanProduccion tbody");
    tbody.empty();

    const puedeEditar = !!permisosBalance?.produccion?.puedeEscribir;

    if (rows && rows.length) {
    rows.forEach(item => {
    const tdPlan = puedeEditar
    ? `<td class="number editable-plan" contenteditable="true">${formatMx(item.plan || 0)}</td>`
    : `<td class="number">${formatMx(item.plan || 0)}</td>`;

    tbody.append(`
    <tr data-id="${item.id}">
    <td>${item.productoCodigo ?? ''}</td>
    <td>${item.productoNombre ?? ''}</td>
    ${tdPlan}
    </tr>`);
    });

    if (!puedeEditar) {
    recalcPlanModalTotal();
    return;
    }

    tbody.find(".editable-plan").off("input").on("input", function () {
    sanitizeEditableNumberCell(this, true);
    });

    tbody.find(".editable-plan").off("keydown").on("keydown", function (e) {
    if (e.ctrlKey || e.metaKey || e.altKey) return;
    const k = e.key;

    const allowed = ['Backspace', 'Delete', 'ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown', 'Home', 'End', 'Tab', 'Enter'];
    if (allowed.includes(k)) return;
    if (/^\d$/.test(k)) return;

    if (k === '.') {
    const txt = String(this.textContent || '');
    if (txt.includes('.')) e.preventDefault();
    return;
    }

    if (k === ',') { e.preventDefault(); return; }

    e.preventDefault();
    });

    tbody.find(".editable-plan").off("blur").on("blur", async function () {
    if (!permisosBalance?.produccion?.puedeEscribir) {
    alert('No tienes permiso para editar producción.');
    return;
    }

    const td = $(this);
    const tr = td.closest('tr');
    const id = Number(tr.data('id'));

    sanitizeEditableNumberCell(td.get(0), true);

    const nuevo = parseMxFloat(td.text());
    if (isNaN(nuevo)) { alert('Ingrese un número'); td.focus(); return; }
    if (nuevo < 0) { alert('No se permiten negativos'); td.focus(); return; }

    try {
    const token = getCsrfToken();

    const resp = await $.ajax({
    url: "/Comercial/ActualizarPlanProduccion",
    type: "POST",
    cache: false,
    contentType: "application/json",
    headers: { 'RequestVerificationToken': token },
    data: JSON.stringify({ id, plan: nuevo })
    });

    if (resp?.success === false) {
    throw new Error(resp?.mensaje || 'No se pudo actualizar');
    }

    td.text(formatMx(nuevo));
    td.css("background", "#d4edda");
    setTimeout(() => td.css("background", ""), 600);

    recalcPlanModalTotal();
    await refreshMainAndDetail();
    } catch (err) {
    td.css("background", "#f8d7da");
    setTimeout(() => td.css("background", ""), 600);
    alert("Error al actualizar el plan");
    }
    });
    } else {
    tbody.append('<tr><td colspan="3" class="text-center">No hay datos</td></tr>');
    }

    recalcPlanModalTotal();
    }

    async function openPresupuestoModal(master, sku) {
    CURRENT_MODAL_MASTER = master;
    CURRENT_MODAL_SKU = sku || null;
    $("#pdtPres").text(sku ? `${master}: ${sku}` : master);

    try {
    const data = CACHE_PRES.has(master)
    ? CACHE_PRES.get(master)
    : await cargarPresupuestosPorMaster(master);

    const arr = normalizeArrayResult(data, `PresModal ${master}`);
