    const v = up(cb.value);
    if (cb.checked) SELECTED.add(v);
    else SELECTED.delete(v);

    const item = cb.closest('.multi-sigo-item');
    if (item) item.classList.toggle('selected', cb.checked);

    const allChecks = Array.from(list.querySelectorAll('input.multi-opt'));
