<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>


<script>
    /* ============================================================
    BALANCE MASTER - SCRIPT AJUSTADO (COMPLETO)
    - Corrige filtro por clasificación
    - Corrige inflación de datos
    - Corrige ceros en venta real / prod real
    - Corrige detalle por SKU usando unión de fuentes
    ============================================================ */

    // =======================
    // Base / utilidades
    // =======================
    const MES_SELECTOR = document.getElementById('mesSelector');
    let MES = (MES_SELECTOR && MES_SELECTOR.value) ? MES_SELECTOR.value : new Date().toISOString().slice(0, 7); // "YYYY-MM"
    const fmt = n => Number(n || 0).toLocaleString('es-MX');

    const noCacheFetchOpts = {
    method: 'GET',
    credentials: 'same-origin',
    cache: 'no-store',
    headers: { 'Accept': 'application/json', 'Pragma': 'no-cache', 'Cache-Control': 'no-cache' }
    };

    let permisosBalance = {
    presupuesto: {
    puedeLeer: false,
    puedeEscribir: false,
    puedeEliminar: false
    },
    produccion: {
    puedeLeer: false,
    puedeEscribir: false,
    puedeEliminar: false
    }
    };

    async function cargarPermisosBalanceMaster() {
    try {
    const r = await fetch('/Comercial/ObtenerPermisosBalanceMaster', {
    credentials: 'same-origin'
    });

    permisosBalance = r.ok
    ? await r.json()
    : {
    presupuesto: { puedeLeer: false, puedeEscribir: false, puedeEliminar: false },
    produccion: { puedeLeer: false, puedeEscribir: false, puedeEliminar: false }
    };

    console.log('Permisos Balance Master =>', permisosBalance);
    } catch (e) {
    console.error('Error cargando permisos:', e);
    permisosBalance = {
    presupuesto: { puedeLeer: false, puedeEscribir: false, puedeEliminar: false },
    produccion: { puedeLeer: false, puedeEscribir: false, puedeEliminar: false }
    };
    }
    }

    function obtenerMesCorto(numMes) {
    const meses = ["ENE", "FEB", "MAR", "ABR", "MAY", "JUN", "JUL", "AGO", "SEP", "OCT", "NOV", "DIC"];
    return meses[parseInt(numMes, 10) - 1] || "";
    }
    let MES_CORTO = obtenerMesCorto((MES.split('-')[1] || "01"));

    function normalizeArrayResult(data, label) {
    if (data && typeof data === 'object' && !Array.isArray(data) && data.error) {
    console.warn(`[${label}] Backend devolvió error:`, data.error, data);
    return [];
    }
    if (!Array.isArray(data)) return [];
    return data;
    }

    // =======================
    // Tendencias
    // =======================
    function getWorkedDaysInMonthExcludingWeekends(year, month1to12) {
    const daysInMonth = new Date(year, month1to12, 0).getDate();
    let worked = 0;
    for (let d = 1; d <= daysInMonth; d++) {
    const dow = new Date(year, month1to12 - 1, d).getDay();
    if (dow !== 0 && dow !== 6) worked++;
    }
    return worked;
    }

    function getElapsedWorkedDaysExcludingWeekends(year, month1to12, today = new Date()) {
    const isSameMonth =
    today.getFullYear() === year &&
    (today.getMonth() + 1) === month1to12;

    const lastDay = isSameMonth
    ? today.getDate()
    : new Date(year, month1to12, 0).getDate();

    let elapsed = 0;
    for (let d = 1; d <= lastDay; d++) {
    const dow = new Date(year, month1to12 - 1, d).getDay();
    if (dow !== 0 && dow !== 6) elapsed++;
    }
    return elapsed;
    }

    function getPaceContext() {
    const [yy, mm] = (MES || '').split('-').map(Number);
    const totalWD = getWorkedDaysInMonthExcludingWeekends(yy, mm);
    const elapsedWD = getElapsedWorkedDaysExcludingWeekends(yy, mm);
    return { yy, mm, totalWD, elapsedWD };
    }

    function projectedMonthValue(actualTotal) {
    const a = Number(actualTotal ?? 0);
    const { totalWD, elapsedWD } = getPaceContext();
    if (elapsedWD <= 0 || totalWD <= 0) return 0;
    return (a / elapsedWD) * totalWD;
    }

    function renderTrendCellProjectedOnly(actualTotal) {
    if (actualTotal == null) return '—';

    const a = Number(actualTotal ?? 0);
    const proj = projectedMonthValue(a);
    const deltaKg = proj - a;

    const icon = deltaKg > 0 ? 'bi-arrow-up-right'
    : (deltaKg < 0 ? 'bi-arrow-down-right' : 'bi-dash');

    const cls  = deltaKg > 0 ? 'text-success'
    : (deltaKg < 0 ? 'text-danger' : 'text-muted');

    return `
    <span class="${cls} fw-semibold">
    <i class="bi ${icon}"></i>
    ${fmt(proj)}
    </span>`;
    }

    function parseCellNumber(td) {
    if (!td) return 0;
    const s = String(td.textContent || '').replace(/,/g, '').trim();
    const n = parseFloat(s);
    return Number.isFinite(n) ? n : 0;
    }

    function calcGapProjected(prodReal, disponible, ventaReal) {
    const tp = projectedMonthValue(Number(prodReal ?? 0));
    const tv = projectedMonthValue(Number(ventaReal ?? 0));
    return tp + Number(disponible ?? 0) - tv;
    }

    function calcGapProjectedByInv(prodReal, inventario, ventaReal) {
    const tp = projectedMonthValue(Number(prodReal ?? 0));
    const tv = projectedMonthValue(Number(ventaReal ?? 0));
    return tp + Number(inventario ?? 0) - tv;
    }

    // =======================
    // Estado UI / datos
    // =======================
    let LAST_OPEN_MASTER = null;
    let CURRENT_MODAL_MASTER = null;
    let CURRENT_MODAL_SKU = null;

    const CACHE_PRES = new Map();
    const CACHE_PROD = new Map();
    const CACHE_PROD_REAL = new Map();
    const CACHE_VENTA_REAL = new Map();
    const CACHE_INV_SKU = new Map();

    let MASTER_DATA = [];
    const BASE_MASTER_VIEW = new Map();

    function snapshotBaseMasterView() {
    BASE_MASTER_VIEW.clear();
    (MASTER_DATA || []).forEach(m => {
    // const master = String(m.u_MASTER ?? '').trim();
    // if (!master) return; bloqueo sin master

    const master = String(m.u_MASTER ?? '').trim() || 'SIN MASTER';
    BASE_MASTER_VIEW.set(master, {
    planProduccion: Number(m.planProduccion || 0),
    produccionReal: Number(m.produccionReal ?? m.realTotalMaster ?? 0),
    ventaReal: Number(m.ventaReal ?? m.ventaRealTotalMaster ?? 0),
    presupuesto: Number(m.presupuesto || 0),
    gap: Number(m.gap || 0),
    porcentaje: Number(m.porcentaje || 0)
    });
    });
    }

    function updateMasterRowCells(master, { plan, real, venta, ventaReal, gap, porcentaje }) {
    const tr = document.querySelector(`tr.master-row[data-master="${master}"]`);
    if (!tr) return;

    const tds = tr.querySelectorAll('td');

    if (tds[2] && plan != null) tds[2].textContent = fmt(plan);
    if (tds[3] && real != null) tds[3].textContent = fmt(real);
    if (tds[6] && venta != null) tds[6].textContent = fmt(venta);
    if (tds[7] && ventaReal != null) tds[7].textContent = fmt(ventaReal);

    if (tds[4]) {
    const realNow = (real != null) ? Number(real) : parseCellNumber(tds[3]);
    tds[4].innerHTML = renderTrendCellProjectedOnly(realNow);
    }

    if (tds[8]) {
    const ventaRealNow = (ventaReal != null) ? Number(ventaReal) : parseCellNumber(tds[7]);
    tds[8].innerHTML = renderTrendCellProjectedOnly(ventaRealNow);
    }

    if (tds[9]) {
    const invNow = Number(tr.getAttribute('data-inventario') ?? 0);
    const realNow = (real != null) ? Number(real) : parseCellNumber(tds[3]);
    const ventaRealNow = (ventaReal != null) ? Number(ventaReal) : parseCellNumber(tds[7]);
    const gapNow = calcGapProjectedByInv(realNow, invNow, ventaRealNow);
    tds[9].innerHTML = `<span class="${gapNow < 0 ? 'badge-neg' : 'badge-pos'}">${fmt(gapNow)}</span>`;
    }

    if (tds[10] && porcentaje != null) {
    tds[10].textContent = `${Number(porcentaje || 0).toFixed(0)}%`;
    }
    }

    function restoreAllMasterRowsToBase() {
    for (const [master, b] of BASE_MASTER_VIEW.entries()) {
    updateMasterRowCells(master, {
    plan: b.planProduccion,
    real: b.produccionReal,
    venta: b.presupuesto,
    ventaReal: b.ventaReal,
    gap: b.gap,
    porcentaje: b.porcentaje
    });
    }
    }

    let PRES_MODAL_RAW = [];

    const safeId = s => String(s ?? '').replace(/[^\w\-:.]/g, '_');
    const up = s => String(s ?? '').trim().toUpperCase();
    const getEl = (...ids) => ids.map(id => document.getElementById(id)).find(Boolean) || null;

    const closeAllDetails = () => {
    document.querySelectorAll('.detail-row').forEach(dr => dr.remove());
    document.querySelectorAll('.expander-btn[aria-expanded="true"]').forEach(b => b.setAttribute('aria-expanded', 'false'));
    };

    async function refreshMainAndDetail() {
    await cargarTabla();
    if (LAST_OPEN_MASTER) {
    const row = document.querySelector(`tr.master-row[data-master="${LAST_OPEN_MASTER}"]`);
    if (row) await toggleDetalle(row);
    }
    }

    // =======================
    // Helpers de filtros
    // =======================
    function presupuestoFiltersActiveFromState(state) {
    return (
    (state.fuente && state.fuente !== 'TODOS') ||
    (state.clientes && state.clientes.length) ||
    (state.vendedores && state.vendedores.length) ||
    (state.cedisList && state.cedisList.length)
    );
    }

    function skuSetFromPresupuesto(presF) {
    const set = new Set();
    (presF || []).forEach(x => {
    const sku = up(String(x.productoCodigo ?? '').trim());
    if (sku) set.add(sku);
    });
    return set;
    }

    function skuSetFromSources(presF, prodF, realF, ventaRealF) {
    const set = new Set();

    (presF || []).forEach(x => {
    const sku = up(String(x.productoCodigo ?? '').trim());
    if (sku) set.add(sku);
    });

    (prodF || []).forEach(x => {
    const sku = up(String(x.productoCodigo ?? '').trim());
    if (sku) set.add(sku);
    });

