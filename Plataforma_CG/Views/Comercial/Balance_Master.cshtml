    function scheduleApplyFilters() {
    updateOpenDetailAndModalFast();

    if (FILTER_TIMER) clearTimeout(FILTER_TIMER);
    FILTER_TIMER = setTimeout(() => {
    applyGlobalFiltersAndKpis().catch(console.error);
    }, 250);
    }

    async function applyGlobalFiltersAndKpis() {
    const runId = ++FILTER_RUN_ID;

    const state = getFilterState();
    const active = isAnyFilterActive(state);

    if (!MASTER_DATA.length) return;

    if (!active) {
    applyMasterRowVisibility(null);
    restoreAllMasterRowsToBase();
    setKpis(computeTotalsFromMasterRows(MASTER_DATA));
    return;
    }

    const presupuestoFiltersActive = presupuestoFiltersActiveFromState(state);
    const skuActive = (state.skus && state.skus.length > 0);
    const masterActive = (state.masters && state.masters.length > 0);
    const clasificacionActive = (state.clasificaciones && state.clasificaciones.length > 0);

    const mastersAll = MASTER_DATA.map(x => String(x.u_MASTER ?? '').trim() || 'SIN MASTER');
    const masters = masterActive
    ? mastersAll.filter(m => state.masters.includes(up(m)))
    : mastersAll;

    if (masterActive && !presupuestoFiltersActive && !skuActive && !clasificacionActive) {
    const matchSetOnlyMaster = new Set(masters);
    applyMasterRowVisibility(matchSetOnlyMaster);

    const visibleRows = MASTER_DATA.filter(x => matchSetOnlyMaster.has(x.u_MASTER));
    setKpis(computeTotalsFromMasterRows(visibleRows));

    if (LAST_OPEN_MASTER && !matchSetOnlyMaster.has(LAST_OPEN_MASTER)) {
    closeAllDetails();
    LAST_OPEN_MASTER = null;
    }
    return;
    }

    await prefetchForMasters(masters);

    if (skuActive || presupuestoFiltersActive || clasificacionActive) {
    await prefetchRealOnly(masters);
    await prefetchVentaRealOnly(masters);
    }

    if (runId !== FILTER_RUN_ID) return;

    const matchSet = new Set();

    let totalVenta = 0;
    let totalVentaReal = 0;
    let totalProdSku = 0;
    let totalProdRealSku = 0;
    let totalProdReal = 0;
    let totalInv = 0;
    let totalInvIdeal = 0;
    let totalDisp = 0;
    let sumPor = 0;
    let countPor = 0;
    let totalGap = 0;

    for (const m of MASTER_DATA) {
    // const master = m.u_MASTER;
    // if (!master) continue; bloqueo de sin master

    const master = String(m.u_MASTER ?? '').trim() || 'SIN MASTER';


    if (masterActive && !state.masters.includes(up(master))) continue;

    const presAll = CACHE_PRES.get(master) || [];
    const prodAll = CACHE_PROD.get(master) || [];
    const realAll = CACHE_PROD_REAL.get(master) || [];
    const ventaRealAll = CACHE_VENTA_REAL.get(master) || [];

    const presF = filtrarPresupuesto(presAll, state);
    const prodF = filtrarProduccion(prodAll, state);
    let realF = filtrarProduccionReal(realAll, state);
    let ventaRealF = filtrarVentaReal(ventaRealAll, state);

    if (!skuActive) {
    let skuSet = null;

    if (clasificacionActive) {
    skuSet = skuSetFromSources(presF, prodF, realF, ventaRealF);
    } else if (presupuestoFiltersActive) {
    skuSet = skuSetFromPresupuesto(presF);
    }

    if (skuSet && skuSet.size) {
    realF = filtrarRealPorSkuSet(realF, skuSet, realSku);
    // ventaRealF = filtrarRealPorSkuSet(ventaRealF, skuSet, ventaSku);
    }
    }

    let match = false;
    if (clasificacionActive || skuActive || presupuestoFiltersActive) {
    match =
    presF.length > 0 ||
    prodF.length > 0 ||
    realF.length > 0;
    } else {
    match = true;
    }

    if (!match) continue;

    matchSet.add(master);

    totalInv += Number(m.inventario || 0);
    totalInvIdeal += Number(m.invIdeal || 0);
    totalDisp += Number(m.disponible || 0);

    const ventaMaster = presF.reduce((a, x) => a + Number(x.presupuesto || 0), 0);
    totalVenta += ventaMaster;

    const ventaRealMaster = sumKgVentaReal(ventaRealF);
    totalVentaReal += ventaRealMaster;

    const porMaster = (ventaMaster > 0)
    ? (Number(m.disponible || 0) / ventaMaster) * 100
    : 0;

    let planMaster = Number(m.planProduccion || 0);
    let realMaster = Number(m.realTotalMaster ?? m.produccionReal ?? 0);

    if (skuActive || clasificacionActive) {
    planMaster = prodF.reduce((a, x) => a + Number(x.plan || 0), 0);
    realMaster = sumKgReal(realF);

    totalProdSku += planMaster;
    totalProdRealSku += realMaster;
    } else {
    totalProdReal += realMaster;
    }

    const gapMaster = calcGapProjected(realMaster, Number(m.disponible || 0), ventaRealMaster);
    totalGap += gapMaster;

    updateMasterRowCells(master, {
    plan: (skuActive || clasificacionActive) ? planMaster : null,
    real: realMaster,
    venta: ventaMaster,
    ventaReal: ventaRealMaster,
    gap: gapMaster,
    porcentaje: porMaster
    });

    sumPor += porMaster;
    countPor += 1;
    }

    const totalProd = (skuActive || clasificacionActive)
    ? totalProdSku
    : MASTER_DATA.reduce((a, x) => a + (matchSet.has(x.u_MASTER) ? Number(x.planProduccion || 0) : 0), 0);

    const totalPorcentaje = countPor ? (sumPor / countPor).toFixed(0) : 0;

    applyMasterRowVisibility(matchSet);

    if (LAST_OPEN_MASTER && !matchSet.has(LAST_OPEN_MASTER)) {
    closeAllDetails();
    LAST_OPEN_MASTER = null;
    }

    setKpis({
    TotalProd: totalProd,
    TotalProdReal: (skuActive || clasificacionActive) ? totalProdRealSku : totalProdReal,
    TotalInv: totalInv,
    TotalInvIdeal: totalInvIdeal,
    TotalDisp: totalDisp,
    TotalVenta: totalVenta,
    TotalVentaReal: totalVentaReal,
    TotalGap: totalGap,
    TotalPorcentaje: totalPorcentaje
    });
    }

    // =======================
    // Render tabla master
    // =======================
    function renderMasterRow(r) {
    const gapVal = calcGapProjected(r.produccionReal ?? 0, r.disponible ?? 0, r.ventaReal ?? 0);
    const gapHtml = `<span class="${gapVal < 0 ? 'badge-neg' : 'badge-pos'}">${fmt(gapVal)}</span>`;
    const realCell = (r.produccionReal == null) ? '—' : fmt(r.produccionReal);
    const ventaRealCell = (r.ventaReal == null) ? '—' : fmt(r.ventaReal);

    const tendProdHtml = (r.produccionReal == null) ? '—' : renderTrendCellProjectedOnly(r.produccionReal);
    const tendVentaHtml = (r.ventaReal == null) ? '—' : renderTrendCellProjectedOnly(r.ventaReal);

    return `
    <tr class="master-row" data-master="${r.u_MASTER}" data-inventario="${Number(r.inventario ?? 0)}" data-disponible="${Number(r.disponible ?? 0)}">
    <td class="text-center" style="width:40px;">
    <button class="expander-btn btn btn-sm btn-outline-secondary" aria-expanded="false" title="Ver detalle">
    <i class="bi bi-chevron-right"></i>
    </button>
    </td>

    <td>${r.u_MASTER}</td>
    <td class="number">${fmt(r.planProduccion)}</td>
    <td class="number">${realCell}</td>
    <td class="number">${tendProdHtml}</td>
    <td class="number">${fmt(r.inventario)}</td>
    <td class="number">${fmt(r.presupuesto)}</td>
    <td class="number">${ventaRealCell}</td>
