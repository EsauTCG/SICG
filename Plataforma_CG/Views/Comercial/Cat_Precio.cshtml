@model IEnumerable<Plataforma_CG.Models.CatalogoPrecioSap>

@{
    ViewData["Title"] = "Catálogo de Precios por Cliente";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<style>
    :root {
        --bg: #f0dede;
        --panel: #f8eeee;
        --panel-2: #f1dede;
        --line: #c79d9d;
        --line-dark: #8f4c4c;
        --text: #3b1717;
        --muted: #6a3a3a;
        --title: #ffffff;
        --white: #ffffff;
        --danger: #c00000;
        --warning: #f3b6b6;
        --ok: #f7e3e3;
        --shadow: 0 1px 0 rgba(255,255,255,.55) inset;
        --brand: #8B0000;
        --vino-1: #5c0000;
        --vino-2: #7a0000;
        --vino-3: #980000;
        --vino-4: #b30000;
        --vino-5: #d10000;
        --vino-soft: #f8e7e7;
        --vino-soft-2: #f2d9d9;
        --vino-border: #9a5a5a;
        --vino-text: #ffffff;
        --vino-text-dark: #4a1111;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0 !important;
        padding: 0 !important;
        font-family: Tahoma, Verdana, Arial, sans-serif;
        background: transparent !important;
        color: var(--text);
    }

    .container, .container-fluid {
        max-width: 100% !important;
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .window {
        width: 100%;
        max-width: 100%;
        margin: 0 !important;
        border: 1px solid #7e4a4a;
        background: var(--panel);
        box-shadow: 0 0 0 1px rgba(255,255,255,.45) inset, 0 8px 18px rgba(70,12,12,.14);
        overflow: hidden;
        padding: 0 !important;
    }

    .titlebar {
        height: 34px;
        /* display: flex; */
        display: none !important;
        align-items: center;
        justify-content: space-between;
        padding: 0 10px;
        background: linear-gradient(180deg, #c00000 0%, #8b0000 60%, #5c0000 100%);
        border-bottom: 1px solid #5c0000;
        color: #fff;
        font-size: 13px;
        font-weight: bold;
    }

        .titlebar .actions {
            display: flex;
            gap: 6px;
        }

    .win-btn {
        width: 16px;
        height: 16px;
        border: 1px solid #7c4848;
        background: linear-gradient(#fff6f6, #ead0d0);
    }

    .toolbar {
        display: flex;
        align-items: flex-end;
        gap: 6px;
        padding: 6px 8px;
        background: linear-gradient(#fff6f6, #ecd8d8);
        border-bottom: 1px solid var(--line);
        font-size: 12px;
        flex-wrap: wrap;
    }

        .toolbar .group {
            display: flex;
            flex-direction: column;
            gap: 3px;
            min-width: 260px;
            flex: 1 1 320px;
        }

        .toolbar label {
            display: block;
            color: #5c1a1a;
            font-size: 12px;
            margin-bottom: 2px !important;
            font-weight: bold;
        }

        .toolbar input,
        .toolbar .form-control {
            height: 28px !important;
            padding: 3px 6px !important;
            border: 1px solid #b48787 !important;
            background: #fffdfd !important;
            font-family: inherit !important;
            font-size: 12px !important;
            width: 100%;
            border-radius: 0 !important;
            box-shadow: none !important;
            color: #421414 !important;
        }

            .toolbar input:focus,
            .toolbar .form-control:focus,
            .modal-body .form-control:focus,
            .modal-body .form-select:focus {
                border-color: #8f4c4c !important;
                outline: none !important;
                box-shadow: none !important;
            }

    .tool-btn {
        min-width: 72px;
        text-align: center;
        background: linear-gradient(#fffefe, #ecd7d7);
        border: 1px solid var(--vino-border);
        box-shadow: var(--shadow);
        cursor: pointer;
        color: var(--vino-text-dark);
        height: 28px;
        font-size: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 0 10px;
        text-decoration: none;
        border-radius: 0;
        white-space: nowrap;
    }

        .tool-btn:hover {
            filter: brightness(.98);
        }

    .tool-btn-primary {
        color: #fff;
        border-color: #7f0a0a;
        background: linear-gradient(180deg, #b40000 0%, #8f0000 55%, #6e0000 100%);
    }

    .tool-btn-success {
        color: #fff;
        border-color: #157347;
        background: linear-gradient(180deg, #27ae60 0%, #1f9a54 55%, #198754 100%);
    }

    .tool-btn-secondary {
        color: #4a1111;
        border-color: #9a5a5a;
        background: linear-gradient(#fffefe, #ecd7d7);
    }

    .tool-btn-purple {
        color: #fff;
        border-color: #5b21b6;
        background: linear-gradient(180deg, #7c3aed 0%, #6d28d9 55%, #5b21b6 100%);
    }

    .sep {
        width: 1px;
        height: 24px;
        background: #cfa8a8;
        align-self: center;
        margin: 0 .2rem;
    }

    .content {
        padding: 8px;
        background: var(--bg);
    }

    .tabs {
        display: flex;
        gap: 4px;
        margin-bottom: 6px;
        flex-wrap: wrap;
    }

    .tab {
        font-size: 12px;
        background: linear-gradient(#f7e7e7, #ead1d1);
        border: 1px solid #caa0a0;
        border-bottom: none;
        padding: 7px 12px;
        color: #5c1a1a;
        user-select: none;
    }

        .tab.active {
            background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
            font-weight: bold;
            color: #fff;
            border-color: #7a2d2d;
        }

    .workspace {
        border: 1px solid var(--line);
        background: var(--panel);
        padding: 8px;
    }

    .section {
        border: 1px solid var(--line);
        background: var(--white);
        margin-bottom: 10px;
    }

    .section-title {
        padding: 6px 8px;
        font-size: 12px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        flex-wrap: wrap;
    }

    .section-body {
        padding: 10px;
        background: #fffafa;
    }

    .status-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 3px 8px;
        font-size: 11px;
        font-weight: 700;
        border: 1px solid #caa0a0;
        border-radius: 2px;
        background: #fff7f7;
        color: #5c1a1a;
    }

    .table-wrap {
        padding: 0;
        overflow: auto;
        max-height: 70vh;
        background: #fffafa;
        width: 100%;
        position: relative;
        border-top: 1px solid #d9b8b8;
    }

        .table-wrap table {
            width: 100%;
            table-layout: fixed;
            border-collapse: separate !important;
            border-spacing: 0 !important;
            font-size: 12px;
            background: #fffafa;
        }

        .table-wrap thead,
        .table-wrap thead tr,
        .table-wrap thead th {
            background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
            color: #fff !important;
        }

            .table-wrap thead th {
                position: sticky;
                top: -1px;
                z-index: 20;
                border-top: 1px solid #c46a6a;
                border-right: 1px solid #8e3b3b;
                border-bottom: 1px solid #5c0000;
                padding: 6px 5px;
                text-align: left;
                white-space: nowrap;
                font-size: 12px;
                line-height: 1.2;
                box-shadow: 0 2px 0 #6f1d1d;
                font-weight: 700;
            }

                .table-wrap thead th:first-child {
                    border-left: 1px solid #8e3b3b;
                }

        .table-wrap tbody td {
            background: #fffafa;
            border-right: 1px solid #d8bcbc;
            border-bottom: 1px solid #d8bcbc;
            padding: 6px 5px;
            white-space: nowrap;
            vertical-align: middle;
            font-size: 12px;
            overflow: hidden;
            text-overflow: ellipsis;
            line-height: 1.2;
            color: #111111;
            font-weight: 400;
        }

            .table-wrap tbody td:first-child {
                border-left: 1px solid #d8bcbc;
            }

        .table-wrap tbody tr:nth-child(even) td {
            background: #f9eded;
        }

        .table-wrap tbody tr:hover td {
            background: #f4dddd;
        }

    .num {
        text-align: right !important;
        font-variant-numeric: tabular-nums;
    }

    #tablaPrecios th:nth-child(1), #tablaPrecios td:nth-child(1) {
        width: 130px;
    }

    #tablaPrecios th:nth-child(2), #tablaPrecios td:nth-child(2) {
        width: 360px;
    }

    #tablaPrecios th:nth-child(3), #tablaPrecios td:nth-child(3) {
        width: 120px;
    }

    #tablaPrecios th:nth-child(4), #tablaPrecios td:nth-child(4) {
        width: 260px;
    }

    #tablaPrecios th:nth-child(5), #tablaPrecios td:nth-child(5) {
        width: 100px;
    }

    #tablaPrecios th:nth-child(6), #tablaPrecios td:nth-child(6) {
        width: 120px;
    }

    #tablaPrecios th:nth-child(7), #tablaPrecios td:nth-child(7) {
        width: 130px;
    }

    #tablaPrecios th:nth-child(8), #tablaPrecios td:nth-child(8) {
        width: 180px;
    }

    .pager {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        flex-wrap: wrap;
        padding: 10px;
        border-top: 1px solid #d9b8b8;
        background: #fffafa;
    }

        .pager .btn {
            min-width: 110px;
            border-radius: 0;
            font-size: 12px;
        }

            .pager .btn:focus {
                box-shadow: none;
            }

    #pageInfo {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 3px 8px;
        font-size: 11px;
        font-weight: 700;
        border: 1px solid #caa0a0;
        border-radius: 2px;
        background: #fff7f7;
        color: #5c1a1a;
    }

    #loader {
        font-weight: 700;
        color: #7a0000;
        font-size: 12px;
    }

    .statusbar {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 6px 10px;
        font-size: 11px;
        color: #4a1a1a;
        border-top: 1px solid #b88c8c;
        background: linear-gradient(#f6e9e9, #ead5d5);
        flex-wrap: wrap;
    }

    .modal-xl-cg {
        max-width: 97vw;
    }

    .analisis-grid-wrap {
        overflow: auto;
        max-height: 60vh;
        border-top: 1px solid #d9b8b8;
        background: #fffafa;
    }

        .analisis-grid-wrap table {
            width: 100%;
            min-width: 2600px;
            border-collapse: separate !important;
            border-spacing: 0 !important;
            table-layout: fixed;
            font-size: 12px;
        }

        .analisis-grid-wrap thead th {
            position: sticky;
            top: 0;
            z-index: 30;
            background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
            color: #fff !important;
            border-top: 1px solid #c46a6a;
            border-right: 1px solid #8e3b3b;
            border-bottom: 1px solid #5c0000;
            padding: 6px 5px;
            white-space: nowrap;
            font-size: 12px;
            line-height: 1.2;
            font-weight: 700;
        }

        .analisis-grid-wrap tbody td {
            background: #fffafa;
            border-right: 1px solid #d8bcbc;
            border-bottom: 1px solid #d8bcbc;
            padding: 6px 5px;
            white-space: nowrap;
            vertical-align: middle;
            color: #111;
        }

        .analisis-grid-wrap tbody tr:nth-child(even) td {
            background: #f9eded;
        }

        .analisis-grid-wrap tbody tr:hover td {
            background: #f4dddd;
        }

    .reco-bajar {
        background: #f8d7da !important;
        color: #842029 !important;
        font-weight: 700;
    }

    .reco-subir {
        background: #d1e7dd !important;
        color: #0f5132 !important;
        font-weight: 700;
    }

    .reco-mantener {
        background: #fff3cd !important;
        color: #856404 !important;
        font-weight: 700;
    }

    /* ── MODAL IMPORTAR COMPETENCIA ── */
    .imp-modal-body {
        background: #f4e4e4;
        padding: 14px;
    }

    .imp-step {
        border: 1px solid var(--line);
        background: #fff;
        margin-bottom: 10px;
    }

    .imp-step-title {
        padding: 6px 10px;
        font-size: 12px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .imp-step-num {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: rgba(255,255,255,.25);
        border: 1px solid rgba(255,255,255,.5);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        flex-shrink: 0;
    }

    .imp-step-body {
        padding: 12px;
        background: #fffafa;
    }

    .drop-zone {
        border: 2px dashed #c79d9d;
        background: #fff7f7;
        padding: 24px 16px;
        text-align: center;
        cursor: pointer;
        transition: background .15s, border-color .15s;
    }

        .drop-zone:hover, .drop-zone.over {
            background: #f9eded;
            border-color: #8b0000;
        }

        .drop-zone .dz-icon {
            font-size: 28px;
            margin-bottom: 6px;
        }

        .drop-zone p {
            font-size: 12px;
            color: #6a3a3a;
            margin: 4px 0 0;
        }

    .imp-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        height: 30px;
        padding: 0 14px;
        font-size: 12px;
        font-weight: 700;
        border-radius: 0;
        cursor: pointer;
        border: 1px solid transparent;
        font-family: inherit;
    }

    .imp-btn-primary {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-color: #7a2d2d;
        color: #fff;
    }

        .imp-btn-primary:hover {
            background: linear-gradient(180deg, #c00000 0%, #9a0000 55%, #6b0000 100%);
        }

        .imp-btn-primary:disabled {
            opacity: .5;
            cursor: not-allowed;
        }

    .imp-btn-secondary {
        background: linear-gradient(#fffefe, #ecd7d7);
        border-color: #9a5a5a;
        color: #4a1111;
    }

        .imp-btn-secondary:hover {
            filter: brightness(.97);
        }

    .imp-btn-success {
        background: linear-gradient(180deg, #27ae60 0%, #198754 100%);
        border-color: #157347;
        color: #fff;
    }

        .imp-btn-success:hover {
            filter: brightness(1.05);
        }

        .imp-btn-success:disabled {
            opacity: .5;
            cursor: not-allowed;
        }

    .imp-status {
        display: none;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: #5c1a1a;
        margin-top: 8px;
    }

    .imp-spinner {
        display: none;
        width: 14px;
        height: 14px;
        border: 2px solid #d8bcbc;
        border-top-color: #8b0000;
        border-radius: 50%;
        animation: imp-spin .6s linear infinite;
    }

    @@keyframes imp-spin {
        to {
            transform: rotate(360deg);
        }
    }

    .imp-filter-bar {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-bottom: 8px;
    }

    .imp-chip {
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
        border: 1px solid #c79d9d;
        background: #fff7f7;
        color: #5c1a1a;
        cursor: pointer;
        border-radius: 0;
    }

        .imp-chip.active {
            background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
            border-color: #7a2d2d;
            color: #fff;
        }

    .imp-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

        .imp-table th {
            background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
            color: #fff;
            padding: 6px 8px;
            text-align: left;
            font-size: 11px;
            border-right: 1px solid #8e3b3b;
            white-space: nowrap;
        }

        .imp-table td {
            padding: 6px 8px;
            border-bottom: 1px solid #d8bcbc;
            border-right: 1px solid #d8bcbc;
            vertical-align: middle;
            color: #111;
        }

        .imp-table tr:nth-child(even) td {
            background: #f9eded;
        }

        .imp-table tr:hover td {
            background: #f4dddd;
        }

        .imp-table td:first-child {
            border-left: 1px solid #d8bcbc;
        }
.imp-table select,
.imp-table input[type=text] {
    font-size: 12px;
    padding: 3px 6px;
    border: 1px solid #b48787;
    background: #fffdfd;
    color: #421414;
    width: 100%;
    border-radius: 0;
    font-family: inherit;
}

.imp-sku-search {
    width: 90px !important;
    flex: 0 0 90px !important;
    min-width: 0 !important;
}

.imp-table select[data-idx] {
    width: auto !important;
    flex: 1 !important;
    min-width: 0 !important;
}

            .imp-table select:focus,
            .imp-table input:focus {
                border-color: #8b0000;
                outline: none;
            }

    .imp-row-mapped td:first-child {
        border-left: 3px solid #198754 !important;
    }

    .imp-row-unmapped td:first-child {
        border-left: 3px solid #dc3545 !important;
    }

    .imp-dif-pos {
        color: #842029;
        font-weight: 700;
    }

    .imp-dif-neg {
        color: #0f5132;
        font-weight: 700;
    }

    .imp-dif-neu {
        color: #6a3a3a;
    }

    .imp-preview-img {
        max-width: 100%;
        max-height: 160px;
        border: 1px solid #d8bcbc;
        display: none;
        margin-top: 8px;
        object-fit: contain;
    }

    .imp-alert {
        padding: 8px 12px;
        font-size: 12px;
        border-left: 3px solid;
        margin-bottom: 10px;
    }

    .imp-alert-info {
        background: #fff4e5;
        border-color: #c79c00;
        color: #5a4200;
    }

    .imp-alert-success {
        background: #e8f6ee;
        border-color: #198754;
        color: #0a4020;
    }

    .imp-alert-error {
        background: #fff1f1;
        border-color: #dc3545;
        color: #7a0000;
    }

    .imp-summary-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
    }

    .imp-summary-chip {
        font-size: 11px;
        padding: 3px 8px;
        border: 1px solid #caa0a0;
        background: #fff7f7;
        color: #5c1a1a;
    }

    @@media (max-width: 992px) {
        .toolbar {
            align-items: stretch;
        }

            .toolbar .group {
                min-width: 100%;
                flex: 1 1 100%;
            }
    }

    @@media (max-width: 768px) {
        .table-wrap table {
            min-width: 1400px;
        }
    }

    .imp-sku-search {
        width: 100%;
        font-size: 12px;
        padding: 3px 6px;
        border: 1px solid #b48787;
        background: #fffdfd;
        color: #421414;
        border-radius: 0;
        font-family: inherit;
        margin-bottom: 4px;
    }

        .imp-sku-search:focus {
            border-color: #8b0000;
            outline: none;
        }

    .imp-sku-cell {
        display: flex;
        flex-direction: row;
        gap: 4px;
        align-items: center;
    }

    #tablaAnalisisSemanal th:nth-child(1),
    #tablaAnalisisSemanal td:nth-child(1) {
        width: 120px;
    }

    #tablaAnalisisSemanal th:nth-child(2),
    #tablaAnalisisSemanal td:nth-child(2) {
        width: 120px;
    }

    #tablaAnalisisSemanal th:nth-child(3),
    #tablaAnalisisSemanal td:nth-child(3) {
        width: 130px;
    }

    #tablaAnalisisSemanal th:nth-child(4),
    #tablaAnalisisSemanal td:nth-child(4) {
        width: 320px;
        white-space: normal;
    }

    #tablaAnalisisSemanal th:nth-child(19),
#tablaAnalisisSemanal td:nth-child(19) {
    width: 130px;
}

#tablaAnalisisSemanal th:nth-child(20),
#tablaAnalisisSemanal td:nth-child(20) {
    width: 220px;
}

#tablaAnalisisSemanal th:nth-child(21),
#tablaAnalisisSemanal td:nth-child(21) {
    width: 90px;
    text-align: center;
}

#tablaAnalisisSemanal th:nth-child(22),
#tablaAnalisisSemanal td:nth-child(22) {
    width: 150px;
}

    .gestion-dropdown {
        display: inline-flex;
        position: relative;
    }

    .gestion-menu {
        border-radius: 0;
        border: 1px solid #8b0000;
        background: #fffafa;
        padding: 4px;
        min-width: 245px;
        box-shadow: 0 6px 16px rgba(70,12,12,.22);
    }

        .gestion-menu .dropdown-item {
            font-size: 12px;
            color: #4a1111;
            padding: 8px 10px;
            border-radius: 0;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .gestion-menu .dropdown-item:hover,
