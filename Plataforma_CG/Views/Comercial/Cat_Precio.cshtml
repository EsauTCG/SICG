        /* ── Construir select de SKUs ── */
        function impEscapeHtml(str) {
        return String(str ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
        }


        function impNormalizarBusqueda(txt) {
        return String(txt ?? '')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toUpperCase()
        .replace(/\$/g, ' ')
        .replace(/\b\d{4,}\b/g, ' ')
        .replace(/\b\d{1,4}\.\d{1,3}\b/g, ' ')
        .replace(/\b(FREASA|DENES|TC|ORIGINAL|NORTEÑA|NORTENA)\b/g, ' ')
        .replace(/[^A-Z0-9Ñ]+/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
        }

        function impTokensBusqueda(txt) {
        const stop = new Set(['DE', 'DEL', 'LA', 'EL', 'LOS', 'LAS', 'CON', 'SIN', 'Y', 'EN', 'PARA', 'KG']);
        return impNormalizarBusqueda(txt)
        .split(' ')
        .map(x => x.trim())
        .filter(x => x.length >= 3 && !stop.has(x));
        }

        function impPrepararSkuSearchData() {
        impSkusData = (impSkusData || []).map(s => {
        const sku = String(s.sku ?? '').trim().toUpperCase();
        const nombre = String(s.nombre ?? '').trim();
        const master = String(s.master ?? '').trim();
        const tipo = String(s.tipo ?? '').trim();

        const searchText = impNormalizarBusqueda(`${sku} ${nombre} ${master} ${tipo}`);
        const tokens = impTokensBusqueda(`${nombre} ${master} ${tipo}`);

        return {
        ...s,
        sku,
        nombre,
        master,
        tipo,
        _searchText: searchText,
        _tokens: tokens
        };
        });
        }

        function impScoreSku(term, s) {
        const q = impNormalizarBusqueda(term);
        if (!q) return 0;

        const qTokens = impTokensBusqueda(q);
        let score = 0;

        const sku = String(s.sku ?? '').toUpperCase();
        const nombre = String(s.nombre ?? '').toUpperCase();
        const searchText = s._searchText || impNormalizarBusqueda(`${sku} ${nombre}`);

        if (sku === q) score += 500;
        if (sku.startsWith(q)) score += 250;
        if (searchText.includes(q)) score += 80;

        qTokens.forEach(t => {
        if (sku.includes(t)) score += 80;
        if (nombre.includes(t)) score += 35;
        if (searchText.includes(t)) score += 20;
        });

        return score;
        }

        function impFiltrarSkus(term, selectedValue = '', limit = 30) {
        const q = impNormalizarBusqueda(term);

        let resultados = [];

        if (q.length >= 2) {
        resultados = impSkusData
        .map(s => ({
        ...s,
        _score: impScoreSku(q, s)
        }))
        .filter(s => s._score > 0)
        .sort((a, b) => b._score - a._score || String(a.sku).localeCompare(String(b.sku)))
        .slice(0, limit);
        }

        if (selectedValue) {
        const actual = impSkusData.find(x => String(x.sku) === String(selectedValue));
        if (actual && !resultados.some(x => String(x.sku) === String(selectedValue))) {
        resultados.unshift(actual);
        }
        }

        return resultados;
        }

        function impBuildSelOpts(term = '', selectedValue = '') {
        const filtrados = impFiltrarSkus(term, selectedValue, 30);

        let html = '<option value="">— Sin mapear —</option>';

        html += filtrados.map(s => {
        const selected = String(s.sku) === String(selectedValue) ? 'selected' : '';
        
        
        return `<option value="${impEscapeHtml(s.sku)}"
        data-nombre="${impEscapeHtml(s.nombre)}"
                data-precio="${Number(s.precioPublico ?? s.precio ?? 0)}"
        ${selected}>
        ${impEscapeHtml(s.nombre)}
        </option>`;
        }).join('');

        return html;
        }

