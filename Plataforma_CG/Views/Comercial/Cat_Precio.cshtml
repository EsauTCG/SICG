        function getISOWeek(date) {
        const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
        const dayNum = d.getUTCDay() || 7;
        d.setUTCDate(d.getUTCDate() + 4 - dayNum);
        const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
        return Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
        }

        function formatFechaMX(date) {
        return `${String(date.getDate()).padStart(2, '0')}/${String(date.getMonth() + 1).padStart(2, '0')}/${date.getFullYear()}`;
        }

        function actualizarEncabezadosAnalisis(fechaCorte) {
        if (!fechaCorte) return;
        const fc = new Date(`${fechaCorte}T00:00:00`);
        if (isNaN(fc)) return;

        const ant = new Date(fc); ant.setDate(ant.getDate() - 7);
        const s1 = new Date(fc); s1.setDate(s1.getDate() - 21);
        const s2 = new Date(fc); s2.setDate(s2.getDate() - 14);
        const s3 = new Date(fc); s3.setDate(s3.getDate() - 7);

        document.getElementById('thInvActual').textContent = `Inventario ${formatFechaMX(fc)}`;
        document.getElementById('thInvAnterior').textContent = `Inventario ${formatFechaMX(ant)}`;
        document.getElementById('thSemana1').textContent = `Semana ${getISOWeek(s1)}`;
        document.getElementById('thSemana2').textContent = `Semana ${getISOWeek(s2)}`;
        document.getElementById('thSemana3').textContent = `Semana ${getISOWeek(s3)}`;
        }

        function hoyLocalISO() {
            const d = new Date();
            const y = d.getFullYear();
            const m = String(d.getMonth() + 1).padStart(2, '0');
            const day = String(d.getDate()).padStart(2, '0');
            return `${y}-${m}-${day}`;
        }

        function parseMoneyValue(v) {
            const n = Number(String(v ?? '').replace(/[^0-9.-]/g, ''));
            return Number.isFinite(n) ? n : 0;
        }

        function parsePrecioExcel(v) {
    let s = String(v ?? '').trim();

    if (!s) return null;

    s = s
        .replace(/\$/g, '')
        .replace(/MXN/gi, '')
        .replace(/\s+/g, '');

    // Caso 142,50 sin punto decimal
    if (s.includes(',') && !s.includes('.')) {
        s = s.replace(',', '.');
    } else {
        // Caso 1,234.50
        s = s.replace(/,/g, '');
    }

    s = s.replace(/[^0-9.-]/g, '');

    const n = Number(s);

    return Number.isFinite(n) ? n : null;
}

function aplicarPegadoPreciosDesdeExcel(inputInicial, textoPegado) {
    const filas = String(textoPegado || '')
        .split(/\r?\n/)
        .filter(x => x.trim() !== '');

    if (!filas.length) return;

    const inputs = Array.from(
        document.querySelectorAll('#analisisSemanalBody .ana-precio-nuevo')
    );

    const startIndex = inputs.indexOf(inputInicial);

    if (startIndex < 0) return;

    filas.forEach((fila, i) => {
        const inputDestino = inputs[startIndex + i];

        if (!inputDestino) return;

        // Si viene desde Excel con columnas, toma la primera celda de cada fila
        const primeraCelda = fila.split('\t')[0];

        const precio = parsePrecioExcel(primeraCelda);

        if (precio === null) return;

        inputDestino.value = precio.toFixed(2);

        const tr = inputDestino.closest('tr');
        const chk = tr?.querySelector('.ana-chk-guardar');

        if (chk) chk.checked = true;

        inputDestino.dispatchEvent(new Event('input', { bubbles: true }));
        inputDestino.dispatchEvent(new Event('change', { bubbles: true }));
    });
}

document.getElementById('analisisSemanalBody')?.addEventListener('paste', function (e) {
    const input = e.target.closest('.ana-precio-nuevo');

    if (!input) return;

    const texto = (e.clipboardData || window.clipboardData)?.getData('text') || '';

    if (!texto) return;

    // Si es un solo precio, deja que el navegador lo pegue normal
    const esPegadoMultiple = texto.includes('\n') || texto.includes('\t');

    if (!esPegadoMultiple) return;

    e.preventDefault();

    aplicarPegadoPreciosDesdeExcel(input, texto);
});

        function sugerirPrecioNuevoAnalisis(r) {
            const actual = Number(r.ppVentaReal ?? 0);
            const promedioComp = Number(r.prom ?? 0);
            const reco = String(r.recomendacion ?? '').toUpperCase();

            if (reco === 'BAJAR' && promedioComp > 0 && actual > 0) {
                return Math.min(actual, promedioComp);
            }

            if (reco === 'SUBIR' && promedioComp > 0 && actual > 0) {
                return Math.max(actual, promedioComp);
            }

            if (actual > 0) return actual;
            if (promedioComp > 0) return promedioComp;

            return 0;
        }

