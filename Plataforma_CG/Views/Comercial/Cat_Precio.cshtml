        function impFechaHoyISO() {
            return new Date().toISOString().split('T')[0];
        }

      

        /* ── Cargar SKUs del backend al abrir modal ── */
        async function impCargarSkus() {
        if (impSkusData.length) return;

        try {
        const res = await fetch('/Comercial/ObtenerSkusParaMapeo');
        if (!res.ok) return;

        const json = await res.json();
        impSkusData = Array.isArray(json) ? json : (json.data || []);
        impPrepararSkuSearchData();
        } catch (e) {
        console.warn('No se pudieron cargar SKUs para mapeo:', e);
        }
        }

        let anaCanalesCargados = false;
        let anaClientesData = [];

        async function cargarCanalesPrecio() {
            const sel = document.getElementById('anaCanal');

            if (!sel || anaCanalesCargados) return;

            sel.innerHTML = '<option value="">Todos los canales</option>';

            try {
                const res = await fetch('/Comercial/ObtenerCanalesPrecio');

                if (!res.ok) throw new Error('No se pudieron cargar los canales.');

                const canales = await res.json();

                canales.forEach(canal => {
                    const opt = document.createElement('option');
                    opt.value = canal;
                    opt.textContent = canal;
                    sel.appendChild(opt);
                });

                anaCanalesCargados = true;
            } catch (e) {
                console.warn('Error cargando canales:', e);
            }
        }

        async function cargarClientesPrecio() {
            const canal = document.getElementById('anaCanal')?.value || '';
            const sel = document.getElementById('anaClientes');

            if (!sel) return;

            sel.innerHTML = '<option disabled>⏳ Cargando clientes...</option>';

            try {
                const res = await fetch(`/Comercial/ObtenerClientesPrecio?canal=${encodeURIComponent(canal)}`);

                if (!res.ok) throw new Error('No se pudieron cargar los clientes.');

                const listaClientes = await res.json();

                anaClientesData = Array.isArray(listaClientes) ? listaClientes : [];

                sel.innerHTML = '';

                anaClientesData.forEach(c => {
                    const opt = document.createElement('option');
                    opt.value = c.cliente;
                    opt.textContent = `${c.cliente} - ${c.nombreCliente} (${c.canal || 'SIN CANAL'})`;
                    sel.appendChild(opt);
                });

                actualizarContadorClientesPrecio();

            } catch (e) {
                sel.innerHTML = '';
                console.warn('Error cargando clientes:', e);
                alert('No se pudieron cargar los clientes: ' + e.message);
            }
        }

        function actualizarModoDestinoPrecio() {
            const modo = document.getElementById('anaAlcanceClientes')?.value || 'ACTIVOS';
            const canal = document.getElementById('anaCanal');
            const clientes = document.getElementById('anaClientes');
            const btnClientes = document.getElementById('btnMarcarTodosClientes');

            if (!canal || !clientes || !btnClientes) return;

            if (modo === 'ACTIVOS') {
                canal.disabled = true;
                clientes.disabled = true;
                btnClientes.disabled = true;
                canal.value = '';
                Array.from(clientes.options).forEach(o => o.selected = false);
            }

            if (modo === 'ACTIVOS_CANAL') {
                canal.disabled = false;
                clientes.disabled = true;
                btnClientes.disabled = true;
                Array.from(clientes.options).forEach(o => o.selected = false);
            }

            if (modo === 'CLIENTES') {
                canal.disabled = false;
                clientes.disabled = false;
                btnClientes.disabled = false;
                cargarClientesPrecio();
            }

            actualizarContadorClientesPrecio();
        }

        function actualizarContadorClientesPrecio() {
            const sel = document.getElementById('anaClientes');
            const lbl = document.getElementById('anaClientesCount');

            if (!sel || !lbl) return;

            const seleccionados = Array.from(sel.selectedOptions || []).length;
            const total = Array.from(sel.options || []).filter(o => !o.disabled).length;

            lbl.textContent = `${seleccionados.toLocaleString('es-MX')} de ${total.toLocaleString('es-MX')} clientes seleccionados`;
        }

        function obtenerClientesSeleccionadosPrecio() {
            const sel = document.getElementById('anaClientes');

            if (!sel) return [];

            return Array.from(sel.selectedOptions || [])
                .map(o => o.value)
                .filter(x => x);
        }

        async function cargarListasPrecioGuardar() {
            const sel = document.getElementById('anaPriceListNum');
            if (!sel) return;

            if (sel.dataset.cargado === '1') return;

            sel.innerHTML = '<option value="1">⏳ Cargando listas...</option>';

            try {
                const res = await fetch('/Comercial/ObtenerListasPrecioParaGuardar');

                if (!res.ok) {
                    throw new Error('No se pudieron cargar las listas de precios.');
                }

                const json = await res.json();
                const listas = Array.isArray(json.data) ? json.data : [];

                sel.innerHTML = '';

                listas.forEach(l => {
                    const opt = document.createElement('option');

                    opt.value = l.priceListNum;

                    const factor = Number(l.factor || 0);

                    if (Number(l.priceListNum) === 1) {
                        opt.textContent = `${l.priceListNum} - ${l.priceListName}`;
                    } else {
                        opt.textContent = `${l.priceListNum} - ${l.priceListName} / Especial`;
                    }

                    sel.appendChild(opt);
                });

                if (!listas.some(x => Number(x.priceListNum) === 1)) {
                    const opt = document.createElement('option');
                    opt.value = '1';
                    opt.textContent = '1 - Precio Publico';
                    sel.prepend(opt);
                }

                sel.value = '1';
                sel.dataset.cargado = '1';

            } catch (e) {
                console.warn(e);

                sel.innerHTML = '<option value="1">1 - Precio Publico</option>';
                alert('No se pudieron cargar las listas de precios: ' + e.message);
            }
        }


