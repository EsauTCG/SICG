@section Scripts {
   @*  <script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script> *@
    <script>
        /* ═══════════════════════════════════════════════════════════
        TABLA DE PRECIOS — original sin cambios
        ═══════════════════════════════════════════════════════════ */
        let currentPage = 1;
        let pageSize = 50;
        let currentSearch = "";
        let totalPages = 1;
        let totalItems = 0;
        let modalAnalisisSemanal = null;
        let modalImportarComp = null;

        function debounce(fn, ms = 350) {
        let t;
        return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); };
        }

        function fmtMoney(n) {
        const x = Number(n);
        return Number.isFinite(x)
        ? x.toLocaleString('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
        : "0.00";
        }

        function fmtNumAnalisis(v) {
        const n = Number(v ?? 0);
        return n.toLocaleString('es-MX', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
        }

        function fmtMoneyAnalisis(v) {
        const n = Number(v ?? 0);
        return n.toLocaleString('es-MX', { style: 'currency', currency: 'MXN' });
        }

        function fmtPctAnalisis(v) {
        return `${Number(v ?? 0).toFixed(0)}%`;
        }

        function claseRecomendacion(reco) {
        const r = (reco || '').toUpperCase();
        if (r === 'BAJAR') return 'reco-bajar';
        if (r === 'SUBIR') return 'reco-subir';
        return 'reco-mantener';
        }

        async function cargarPrecios(page = 1, search = "") {
        const tbody = document.querySelector("#tablaPrecios tbody");
        tbody.innerHTML = `<tr><td colspan="8" class="text-center py-4">⏳ Cargando...</td></tr>`;
        document.getElementById("loader").style.display = "inline";
        document.getElementById("prevPage").disabled = true;
        document.getElementById("nextPage").disabled = true;

        try {
        const res = await fetch(`/Comercial/GetCatalogoPrecioJsonPaged?page=${page}&pageSize=${pageSize}&search=${encodeURIComponent(search)}`);
        if (!res.ok) throw new Error("Error al cargar catálogo de precios");

        const data = await res.json();
        tbody.innerHTML = "";

        const rows = Array.isArray(data.precios) ? data.precios : [];
        totalItems = Number(data.total || 0);
        totalPages = Math.max(1, Math.ceil((data.total || 0) / (data.pageSize || pageSize)));

        if (!rows.length) {
        tbody.innerHTML = `<tr><td colspan="8" class="text-center text-warning py-4">No hay registros para mostrar.</td></tr>`;
        document.getElementById("pageInfo").innerHTML = `<i class="bi bi-info-circle"></i> Sin resultados`;
        return;
        }

        rows.forEach(p => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
        <td>${p.productoCodigo ?? p.ProductoCodigo ?? p.itemCode ?? "—"}</td>
        <td>${p.productoNombre ?? p.ProductoNombre ?? "—"}</td>
        <td>${p.cliente ?? p.Cliente ?? "—"}</td>
        <td>${p.clienteNombre ?? p.ClienteNombre ?? "—"}</td>
        <td>${p.priceListNum ?? p.PriceListNum ?? "—"}</td>
        <td>${p.priceListName ?? p.PriceListName ?? "—"}</td>
        <td class="text-end">${fmtMoney(p.precio ?? p.Precio)}</td>
        <td>${(p.fechaModificacion ?? p.FechaModificacion) ? new Date(p.fechaModificacion ?? p.FechaModificacion).toLocaleString('es-MX') : "—"}</td>
        `;
        tbody.appendChild(tr);
        });

        currentPage = Number(data.page || page);
        pageSize = Number(data.pageSize || pageSize);
        document.getElementById("pageInfo").innerHTML =
        `<i class="bi bi-collection"></i> Página <strong>${currentPage}</strong> de <strong>${totalPages}</strong> · Registros: <strong>${totalItems.toLocaleString('es-MX')}</strong>`;
        } catch (err) {
        tbody.innerHTML = `<tr><td colspan="8" class="text-center text-danger py-4">Error: ${err.message}</td></tr>`;
        document.getElementById("pageInfo").innerHTML = `<i class="bi bi-exclamation-triangle"></i> Error`;
        } finally {
        document.getElementById("loader").style.display = "none";
        document.getElementById("prevPage").disabled = currentPage <= 1;
        document.getElementById("nextPage").disabled = currentPage >= totalPages;
        }
        }

        async function cargarAnalisisSemanal() {
        const tbody = document.getElementById('analisisSemanalBody');
        const colCount = document.querySelectorAll('#tablaAnalisisSemanal thead th').length || 1;

        tbody.innerHTML = `<tr><td colspan="${colCount}" class="text-center py-4">⏳ Calculando...</td></tr>`;

        const skus = actualizarContadorSkus();

        const payload = {
        fechaCorte: document.getElementById('anaFechaCorte')?.value || '',
        skus: skus,
        master: document.getElementById('anaMaster')?.value || ''
        };

        console.log('Payload análisis semanal:', payload);

        try {
        const res = await fetch('/Comercial/ObtenerAnalisisSemanal', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
        });

        const text = await res.text();

        if (!res.ok) {
        tbody.innerHTML = `<tr><td colspan="${colCount}" class="text-center text-danger py-4">${text}</td></tr>`;
        return;
        }

        let rows = [];
        try {
        rows = JSON.parse(text);
        } catch {
        tbody.innerHTML = `<tr><td colspan="${colCount}" class="text-center text-danger py-4">Respuesta inválida</td></tr>`;
        console.error('Respuesta no JSON:', text);
        return;
        }

        console.log('Resultado análisis semanal:', rows);

        if (!Array.isArray(rows) || !rows.length) {
        tbody.innerHTML = `<tr><td colspan="${colCount}" class="text-center py-4">Sin resultados.</td></tr>`;
        return;
        }

                tbody.innerHTML = rows.map(r => {
                    const precioSugerido = sugerirPrecioNuevoAnalisis(r);

                    return `<tr
                data-sku="${impEscapeHtml(r.sku ?? '')}"
                data-master="${impEscapeHtml(r.master ?? '')}"
                data-prod="${impEscapeHtml(r.skuProd ?? '')}"
                data-clasificacion="${impEscapeHtml(r.clasificacion ?? '')}">

                <td>${r.clasificacion ?? ''}</td>
                <td>${r.master ?? ''}</td>
                <td>${r.sku ?? ''}</td>
