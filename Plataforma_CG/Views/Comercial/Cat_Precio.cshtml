        /* ═══════════════════════════════════════════════════════════
        IMPORTAR COMPETENCIA CON OCR
        ═══════════════════════════════════════════════════════════ */
        let impData = null;       // { competidor, fecha, productos:[{nombre,precio,sku,nuestroNombre,nuestroPrecio}] }
        let impSkusData = [];     // catálogo de SKUs del sistema
        let impImgBase64 = null;
