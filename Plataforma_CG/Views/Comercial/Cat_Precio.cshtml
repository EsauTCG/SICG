            if (!competidor) { alert('Captura el nombre del competidor.'); return; }
            const fecha = document.getElementById('impFechaCompetencia')?.value?.trim();
            if (!fecha) {
                const inp = document.getElementById('impFechaCompetencia');
                inp.style.border = '2px solid #c00000';
                inp.focus();
                alert('La fecha de corte es obligatoria.');
                return;
            }
            document.getElementById('impFechaCompetencia').style.border = '1px solid #b48787';
            const filas = document.querySelectorAll('#tablaCapturaBody tr');
            const productos = [];
            filas.forEach(tr => {
                const codigo = tr.querySelector('.cap-codigo')?.value?.trim() || '';
                const nombre = tr.querySelector('.cap-nombre')?.value?.trim() || '';
                const precioRaw = tr.querySelector('.cap-precio')?.value?.trim() || '';
                const sku = tr.querySelector('.cap-sku')?.value?.trim() || '';
                const precio = parseFloat(precioRaw.replace(/[^0-9.]/g, '')) || 0;
                if (!nombre && !codigo) return;
                if (precio <= 0) return;
                let nuestroNombre = '';
                let nuestroPrecio = null;
                if (sku) {
                    const s = impSkusData.find(x => x.sku?.toUpperCase() === sku.toUpperCase());
                    if (s) {
                        nuestroNombre = s.nombre || '';
                        nuestroPrecio = Number(s.precioPublico ?? s.precio ?? 0);
                    }
                }
                productos.push({ codigoCompetencia: codigo, nombre, precio, sku, nuestroNombre, nuestroPrecio, searchTerm: sku ? sku : nombre });
            });

            if (!productos.length) { alert('Agrega al menos un producto con nombre y precio.'); return; }
            impData = { competidor, fecha, productos };
            document.getElementById('impStep1').style.display = 'none';
            document.getElementById('impStep2').style.display = 'block';
            impRenderMapTable();
        });

        function actualizarContadorSkus() {
        const txt = document.getElementById('anaSku');
        const lbl = document.getElementById('anaSkuCount');

        const skus = normalizarSkusMasivo(txt?.value || '');

        if (lbl) {
        lbl.textContent = `${skus.length.toLocaleString('es-MX')} SKU capturados`;
        }

        return skus;
        }

      


        function impUpdateSummary() {
        if (!impData || !Array.isArray(impData.productos)) return;

        const mapped = impData.productos.filter(p => p.sku).length;
        const total = impData.productos.length;
        document.getElementById('impMapSummary').textContent = `${mapped} de ${total} productos mapeados`;
        document.getElementById('impBtnGuardar').disabled = mapped === 0;

        const alert = document.getElementById('impMapAlert');
        if (mapped === 0) {
        alert.textContent = 'Para cada producto de la competencia, selecciona el SKU propio correspondiente en el desplegable.';
        alert.style.display = 'block';
        } else {
        alert.style.display = 'none';
        }
        }

        /* ── Filtros ── */
        document.getElementById('impFilterBar').addEventListener('click', e => {
        const chip = e.target.closest('.imp-chip');
        if (!chip) return;
        document.querySelectorAll('.imp-chip').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        impFiltro = chip.dataset.filter;
        impRenderMapTable();
        });

        document.getElementById('impBtnAutoSugerir')?.addEventListener('click', function (e) {
    e.preventDefault();
    e.stopPropagation();

    if (!impData || !Array.isArray(impData.productos)) return;

    let asignados = 0;

    impData.productos.forEach((p, idx) => {
        if (p.sku) return;

        const termino = impNormalizarBusqueda(p.nombre);
        const sugeridos = impFiltrarSkus(termino, '', 1);

        if (!sugeridos.length) return;

        const score = impScoreSku(termino, sugeridos[0]);

        // Umbral conservador para evitar malas relaciones
        if (score >= 45) {
            impAplicarSkuAProducto(idx, sugeridos[0].sku);
            asignados++;
        } else {
            p.searchTerm = termino;
        }
    });

    impRenderMapTable();
    impUpdateSummary();

    alert(`Auto sugerencia terminada. SKUs asignados: ${asignados}`);
});

document.getElementById('impBtnPegarSkus')?.addEventListener('click', function (e) {
    e.preventDefault();
    e.stopPropagation();

    if (!impData || !Array.isArray(impData.productos)) return;

    const texto = prompt(
        'Pega un SKU por renglón, en el mismo orden de la tabla.\n\nEjemplo:\nN003\nV054\nV055'
    );

    if (!texto) return;

    const skusPegados = texto
        .split(/\r?\n/g)
        .map(x => x.trim())
        .filter(x => x.length > 0)
        .map(linea => {
            // Si viene con columnas pegadas desde Excel, toma la última columna
            const partes = linea.split(/\t|,|;/g).map(x => x.trim()).filter(Boolean);
            return partes.length ? partes[partes.length - 1].toUpperCase() : linea.toUpperCase();
        });

    let asignados = 0;

    const productosVisibles = impData.productos.filter(p => {
        if (impFiltro === 'mapped') return p.sku;
        if (impFiltro === 'unmapped') return !p.sku;
        return true;
    });

    skusPegados.forEach((sku, i) => {
        const p = productosVisibles[i];
        if (!p) return;

        const realIdx = impData.productos.indexOf(p);
        const existe = impSkusData.some(s => String(s.sku).toUpperCase() === sku);

        if (existe) {
            impAplicarSkuAProducto(realIdx, sku);
            asignados++;
        }
    });

    impRenderMapTable();
    impUpdateSummary();

    alert(`SKUs pegados y asignados: ${asignados}`);
});

        /* ── Volver ── */
        document.getElementById('impBtnVolver').addEventListener('click', () => {
        document.getElementById('impStep2').style.display = 'none';
        document.getElementById('impStep1').style.display = 'block';
        });

        /* ── Guardar en sistema ── */
        document.getElementById('impBtnGuardar').addEventListener('click', async () => {
            const btn = document.getElementById('impBtnGuardar');
            const mapeados = impData?.productos?.filter(p => p.sku) || [];

            if (!mapeados.length) {
                alert('No hay productos mapeados para guardar.');
                return;
            }

            const orig = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '⏳ Guardando...';

            const competidorInput = (
                document.getElementById('impNombreCompetidor')?.value || ''
            ).trim();

            const competidorData = (
                impData?.competidor || ''
            ).trim();

            const competidorNombre = competidorInput ||
                (competidorData.toUpperCase() !== 'COMPETENCIA' ? competidorData : '');

            if (!competidorNombre) {
                alert('Captura el nombre real del competidor. Ejemplo: Redbuchef, Praderas, C-Fira, Denes.');
                btn.disabled = false;
                btn.innerHTML = orig;
                return;
            }

            const fechaCorteFinal = (
                impData?.fechaCorte ||
                impData?.fecha ||
                document.getElementById('impFechaCompetencia')?.value ||
                ''
            ).trim();

            if (!fechaCorteFinal) {
                alert('Captura la fecha corte antes de guardar.');
                btn.disabled = false;
                btn.innerHTML = orig;
                return;
            }

            const payload = {
                competidor: competidorNombre,
                fecha: fechaCorteFinal,
                fechaCorte: fechaCorteFinal,
                registros: mapeados.map(p => ({
                    skuPropio: p.sku,
                    codigoCompetencia: p.codigoCompetencia || '',
                    nombreCompetencia: p.nombre || '',
                    precioCompetencia: Number(p.precio || 0),
                    nuestroPrecio: p.nuestroPrecio !== null && p.nuestroPrecio !== undefined
                        ? Number(p.nuestroPrecio)
                        : null
                }))
            };

            try {
                const res = await fetch('/Comercial/GuardarCompetenciaLote', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const text = await res.text();

                let data = null;

                try {
                    data = JSON.parse(text);
                } catch {
                    throw new Error(text || 'Respuesta inválida del servidor.');
                }

                if (!res.ok || data.ok === false) {
                    throw new Error(data.mensaje || data.error || 'Error al guardar.');
                }

                document.getElementById('impStep2').style.display = 'none';
                document.getElementById('impStep3').style.display = 'block';

                document.getElementById('impSavedMsg').textContent =
                    `${mapeados.length} registros de "${competidorNombre}" guardados correctamente para fecha corte ${fechaCorteFinal}.`;

                const savedBody = document.getElementById('impSavedBody');

                savedBody.innerHTML = mapeados.map(p => {
                    const precioComp = Number(p.precio || 0);
                    const precioNuestro = p.nuestroPrecio !== null && p.nuestroPrecio !== undefined
                        ? Number(p.nuestroPrecio)
                        : null;

                    const dif = precioNuestro !== null ? precioNuestro - precioComp : null;

                    const difCls = dif === null
                        ? 'imp-dif-neu'
                        : dif > 5
                            ? 'imp-dif-pos'
                            : dif < -5
                                ? 'imp-dif-neg'
                                : 'imp-dif-neu';

                    const difHtml = dif === null
                        ? '—'
                        : `${dif >= 0 ? '+' : ''}$${dif.toFixed(2)}`;

                    return `<tr>
                        <td><strong>${impEscapeHtml(p.sku)}</strong></td>
                        <td>${impEscapeHtml(p.nuestroNombre || '')}</td>
                        <td>${impEscapeHtml(p.codigoCompetencia || '—')}</td>
                        <td>${impEscapeHtml(p.nombre || '')}</td>
                        <td style="font-family:monospace;text-align:right;">$${precioComp.toFixed(2)}</td>
                        <td style="font-family:monospace;text-align:right;">${precioNuestro !== null ? '$' + precioNuestro.toFixed(2) : '—'}</td>
                        <td style="text-align:right;"><span class="${difCls}">${difHtml}</span></td>
                    </tr>`;
                }).join('');

            } catch (e) {
                alert('Error al guardar: ' + e.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = orig;
            }
        });

