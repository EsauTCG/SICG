@{
    ViewData["Title"] = "Control Center Logística";
    Layout = "~/Views/Shared/_Layout2.cshtml"; // o _Layout2.cshtml según uses
}

<div class="container-fluid py-3">

    <!-- Título + rango de fecha -->
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-3">
        <div>
            <h2 class="h4 mb-0 fw-bold">
                <i class="fa-solid fa-gauge-high me-2"></i>Control Center · Logística / Distribución
            </h2>
            <small class="text-muted">Monitoreo en tiempo real de rutas y entregas</small>
        </div>

        <div class="mt-2 mt-md-0 d-flex flex-wrap align-items-center gap-2">
            <div class="input-group input-group-sm">
                <span class="input-group-text"><i class="fa-regular fa-calendar"></i></span>
                <input type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <button class="btn btn-sm btn-outline-secondary">
                <i class="fa-solid fa-rotate-right me-1"></i>Actualizar
            </button>
        </div>
    </div>

    <!-- Resumen KPI -->
    <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-muted text-uppercase">Viajes del día</div>
                            <div class="h4 mb-0 fw-bold">24</div>
                        </div>
                        <div class="rounded-circle bg-primary-subtle d-flex align-items-center justify-content-center" style="width:40px;height:40px;">
                            <i class="fa-solid fa-truck-fast"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-muted text-uppercase">A tiempo</div>
                            <div class="h4 mb-0 fw-bold text-success">18</div>
                        </div>
                        <div class="rounded-circle bg-success-subtle d-flex align-items-center justify-content-center" style="width:40px;height:40px;">
                            <i class="fa-solid fa-circle-check"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-muted text-uppercase">En riesgo</div>
                            <div class="h4 mb-0 fw-bold text-warning">4</div>
                        </div>
                        <div class="rounded-circle bg-warning-subtle d-flex align-items-center justify-content-center" style="width:40px;height:40px;">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="small text-muted text-uppercase">% Cumplimiento</div>
                            <div class="h4 mb-0 fw-bold text-primary">96.3%</div>
                        </div>
                        <div class="rounded-circle bg-info-subtle d-flex align-items-center justify-content-center" style="width:40px;height:40px;">
                            <i class="fa-solid fa-chart-line"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FILTROS SUPERIORES -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-6 col-md-3">
                    <label class="form-label small mb-1">Ruta / CD</label>
                    <select class="form-select form-select-sm">
                        <option>Todos</option>
                        <option>CD Tijuana</option>
                        <option>CD Monterrey</option>
                        <option>CDMX</option>
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label small mb-1">Cliente</label>
                    <select class="form-select form-select-sm">
                        <option>Todos</option>
                        <option>Soriana</option>
                        <option>Chedraui</option>
                        <option>Mayorista Qro</option>
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label small mb-1">Transportista</label>
                    <select class="form-select form-select-sm">
                        <option>Todos</option>
                        <option>Robles</option>
                        <option>TransNorte</option>
                        <option>Metropolitana</option>
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label small mb-1">Estatus</label>
                    <select class="form-select form-select-sm">
                        <option>Todos</option>
                        <option>Programado</option>
                        <option>Liberado</option>
                        <option>En rampa</option>
                        <option>En ruta</option>
                        <option>Entregado</option>
                        <option>Demorado</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- GRID PRINCIPAL + PANEL DETALLE -->
    <div class="row g-3">
        <!-- TABLA PRINCIPAL -->
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-dark text-white py-2 d-flex justify-content-between align-items-center">
                    <div class="small fw-semibold">
                        <i class="fa-solid fa-table-columns me-1"></i>
                        Tablero de salidas
                    </div>
                    <div class="small text-end">
                        Última actualización<br />
                        <span class="fw-bold">09:26:54 a.m.</span>
                    </div>
                </div>
                <div class="table-responsive" style="max-height: 60vh;">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-dark text-uppercase small">
                            <tr>
                                <th>Fecha</th>
                                <th>Ruta</th>
                                <th>Cliente</th>
                                <th>Temp.</th>
                                <th>Transp.</th>
                                <th>Pedido</th>
                                <th>Salida</th>
                                <th>ETA</th>
                                <th>Estatus</th>
                                <th class="text-end">% Cumpl.</th>
                            </tr>
                        </thead>
                        <tbody class="small">
                            <tr class="table-success-subtle">
                                <td>29.11.25</td>
                                <td>Tijuana</td>
                                <td>Soriana</td>
                                <td>Congelado</td>
                                <td>Robles</td>
                                <td>T-1634</td>
                                <td>05:35 a.m.</td>
                                <td>03 dic 25 · 11:00</td>
                                <td>
                                    <span class="badge rounded-pill text-bg-success">Entregado</span>
                                </td>
                                <td class="text-end fw-semibold text-success">98.0%</td>
                            </tr>
                            <tr class="table-warning-subtle">
                                <td>29.11.25</td>
                                <td>Monterrey</td>
                                <td>Cedis Mty</td>
                                <td>Congelado</td>
                                <td>Aluma</td>
                                <td>T-1636</td>
                                <td>12:30 a.m.</td>
                                <td>01 dic 25 · 09:00</td>
                                <td>
                                    <span class="badge rounded-pill text-bg-warning">En ruta</span>
                                </td>
                                <td class="text-end fw-semibold text-warning">75.0%</td>
                            </tr>
                            <tr class="table-danger-subtle">
                                <td>30.11.25</td>
                                <td>CDMX</td>
                                <td>Autoservicio MX</td>
                                <td>Refrigerado</td>
                                <td>Metropolitana</td>
                                <td>M-9833</td>
                                <td>03:10 a.m.</td>
                                <td>30 nov 25 · 09:00</td>
                                <td>
                                    <span class="badge rounded-pill text-bg-danger">Demorado</span>
                                </td>
                                <td class="text-end fw-semibold text-danger">88.5%</td>
                            </tr>
                            <tr>
                                <td>30.11.25</td>
                                <td>Puebla</td>
                                <td>Mayorista Pue</td>
                                <td>Congelado</td>
                                <td>Del Centro</td>
                                <td>P-4420</td>
                                <td>08:50 a.m.</td>
                                <td>30 nov 25 · 14:00</td>
                                <td>
                                    <span class="badge rounded-pill text-bg-info">En rampa</span>
                                </td>
                                <td class="text-end fw-semibold text-primary">95.1%</td>
                            </tr>
                            <!-- agrega más filas reales desde tu modelo -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- PANEL DERECHO: detalle del viaje seleccionado + acciones -->
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-secondary text-white py-2">
                    <div class="small fw-semibold">
                        <i class="fa-solid fa-truck me-1"></i>Detalle del viaje
                    </div>
                </div>
                <div class="card-body small">
                    <div class="d-flex justify-content-between mb-2">
                        <div>
                            <div class="text-muted text-uppercase small">Ruta</div>
                            <div class="fw-semibold">CDMX · Autoservicio MX</div>
                        </div>
                        <div class="text-end">
                            <div class="text-muted text-uppercase small">Unidad</div>
                            <div class="fw-semibold">M-9833 · Refrigerado</div>
                        </div>
                    </div>

                    <div class="mb-2">
                        <div class="text-muted text-uppercase small">Status actual</div>
                        <span class="badge rounded-pill text-bg-danger">Demorado</span>
                        <span class="ms-2 text-danger fw-semibold">+1h 20m</span>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted text-uppercase small mb-1">Timeline</div>
                        <ul class="list-unstyled timeline small">
                            <li class="timeline-item done">
                                <span class="timeline-dot"></span>
                                <div>
                                    <div class="fw-semibold">Liberado</div>
                                    <div class="text-muted">03:40 a.m.</div>
                                </div>
                            </li>
                            <li class="timeline-item done">
                                <span class="timeline-dot"></span>
                                <div>
                                    <div class="fw-semibold">Salida de planta</div>
                                    <div class="text-muted">04:20 a.m.</div>
                                </div>
                            </li>
                            <li class="timeline-item active">
                                <span class="timeline-dot"></span>
                                <div>
                                    <div class="fw-semibold">En ruta</div>
                                    <div class="text-muted">ETA 09:00 a.m.</div>
                                </div>
                            </li>
                            <li class="timeline-item">
                                <span class="timeline-dot"></span>
                                <div>
                                    <div class="fw-semibold">Llegada a cliente</div>
                                    <div class="text-muted">Pendiente</div>
                                </div>
                            </li>
                        </ul>
                    </div>

                    <div>
                        <div class="text-muted text-uppercase small mb-1">Actualizar estatus</div>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-sm btn-outline-secondary">En rampa</button>
                            <button class="btn btn-sm btn-outline-secondary">Salida</button>
                            <button class="btn btn-sm btn-outline-primary">En ruta</button>
                            <button class="btn btn-sm btn-outline-success">Entregado</button>
                            <button class="btn btn-sm btn-outline-danger">Incidencia</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light py-2">
                    <div class="small fw-semibold">
                        <i class="fa-solid fa-bell me-1"></i>Alertas recientes
                    </div>
                </div>
                <div class="card-body small">
                    <div class="d-flex justify-content-between mb-2">
                        <div>
                            <span class="badge bg-danger rounded-pill me-1">Delay</span>
                            CDMX · Autoservicio MX
                        </div>
                        <span class="text-muted">09:10</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <div>
                            <span class="badge bg-warning rounded-pill me-1">Riesgo</span>
                            Monterrey · Cedis Mty
                        </div>
                        <span class="text-muted">08:45</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <div>
                            <span class="badge bg-info rounded-pill me-1">Info</span>
                            Puebla · Mayorista Pue
                        </div>
                        <span class="text-muted">08:20</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .timeline {
        padding-left: 0.75rem;
        border-left: 2px solid rgba(0,0,0,.1);
    }

    .timeline-item {
        position: relative;
        margin-bottom: .75rem;
        padding-left: .75rem;
    }

    .timeline-dot {
        position: absolute;
        left: -10px;
        top: 4px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #dee2e6;
        border: 2px solid #6c757d;
    }

    .timeline-item.done .timeline-dot {
        background: #198754;
        border-color: #198754;
    }

    .timeline-item.active .timeline-dot {
        background: #ffc107;
        border-color: #ffc107;
    }
</style>

@section Scripts {
    <!-- Aquí luego puedes conectar AJAX / SignalR para datos reales -->
}