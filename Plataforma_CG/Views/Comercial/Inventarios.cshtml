                    type="button"
                    class="btn btn-light btn-sm">
                <i class="fa-solid fa-xmark"></i>
                Cerrar
            </button>
        </div>

        <form id="incidentForm" class="incident-form-body" enctype="multipart/form-data">
            <div class="incident-form-grid">
                <div>
                    <label for="incidentTypeInput" class="form-label fw-bold">Tipo</label>
                    <select id="incidentTypeInput" name="tipo" class="form-select" required>
                        <option value="">Selecciona una opción</option>
                        <option>Producto sin etiqueta</option>
                        <option>Caja dañada</option>
                        <option>Producto no localizado</option>
                        <option>Producto sobrante</option>
                        <option>Producto mezclado</option>
                        <option>Lote incorrecto</option>
                        <option>Tarima incompleta</option>
                    </select>
                </div>

                <div>
                    <label for="incidentWarehouseInput" class="form-label fw-bold">Almacén</label>
                    <select id="incidentWarehouseInput" name="almacenId" class="form-select" required></select>
                </div>

                <div>
                    <label for="incidentCodeInput" class="form-label fw-bold">Código de etiqueta</label>
                    <input id="incidentCodeInput"
                           name="codigoEtiqueta"
                           type="text"
                           class="form-control"
                           autocomplete="off" />
                </div>

                <div>
                    <label for="incidentProductInput" class="form-label fw-bold">Producto</label>
                    <input id="incidentProductInput"
                           name="producto"
                           type="text"
                           class="form-control" />
                </div>

                <div>
                    <label for="incidentWeightInput" class="form-label fw-bold">Kg de la caja / producto</label>
                    <div class="input-group">
                        <input id="incidentWeightInput"
                               name="pesoKg"
                               type="number"
                               class="form-control"
                               min="0.001"
                               max="99999"
                               step="0.001"
                               inputmode="decimal"
                               placeholder="0.000"
                               required />
                        <span class="input-group-text">kg</span>
                    </div>
                </div>

                <div>
                    <label for="incidentLocationInput" class="form-label fw-bold">Ubicación</label>
                    <input id="incidentLocationInput"
                           name="ubicacion"
                           type="text"
                           class="form-control"
                           placeholder="Ejemplo: pasillo A, posición 03" />
