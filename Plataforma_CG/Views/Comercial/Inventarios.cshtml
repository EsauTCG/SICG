                    </label>
                    <select id="activeWarehouseSelect"
                            class="form-select form-select-sm"></select>
                </div>
            </div>
        </div>

        <div id="sessionWarning" class="session-warning"></div>
    </section>

    <!-- CAPTURA -->
    <main class="panel scan-shell">
