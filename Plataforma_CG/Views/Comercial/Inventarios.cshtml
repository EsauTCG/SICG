            <div class="scan-title-row">
                <div class="scan-title">
                    <i class="fa-solid fa-barcode"></i>
                    <span>Escanear etiqueta</span>
                </div>
                <span class="real-pill">
                    <i class="fa-solid fa-bolt"></i>
                    REAL
                </span>
            </div>

            <input id="scanInput"
                   class="form-control scan-input"
                   placeholder="Escanea aquí"
                   autocomplete="off"
                   inputmode="text"
