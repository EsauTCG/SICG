                                <input id="warehouseSearchInput"
                                       type="search"
                                       class="form-control warehouse-search-input"
                                       placeholder="Buscar almacén..."
                                       autocomplete="off" />
                            </div>

                            <label class="warehouse-select-all">
                                <input id="warehouseSelectAll" type="checkbox" />
                                <span id="warehouseSelectAllText">Seleccionar todo</span>
                            </label>

                            <div id="warehouseChoices"
                                 class="warehouse-options"
                                 role="listbox"
