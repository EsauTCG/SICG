            async function renderReportReal() {
                const queryVersion = ++reportQueryVersion;

                rLogo.src = LOGO_URL;
                rTitle.textContent = "Reporte histórico de inventario";
                showReportError("");

                reportIncidentPage = 1;
                reportReadingPage = 1;
                reportIncidentLoaded = false;
                reportReadingLoaded = false;

                const selectedWarehouse =
                    repAlmacen?.value || "ALL";

                const selectedWarehouseOption =
                    repAlmacen?.selectedOptions?.[0];

                const warehouseText =
                    selectedWarehouse === "ALL"
                        ? "TODOS LOS ALMACENES PERMITIDOS"
                        : (
                            selectedWarehouseOption?.textContent?.trim() ||
                            selectedWarehouse
                        );

                rSub.textContent =
                    `${SITE_NAME} · ${warehouseText}`;

                const now = new Date();

                rFecha.textContent =
                    `Generado: ${now.toLocaleString("es-MX", {
                        year: "numeric",
                        month: "2-digit",
                        day: "2-digit",
                        hour: "2-digit",
                        minute: "2-digit"
                    })}`;

                const today = new Date();
                const todayString = toDateInputValue(today);

                const from =
                    repDesde?.value || todayString;

                const to =
                    repHasta?.value || from;

                if (from > to) {
                    resetHistoricalReportView();
                    showReportError(
                        "Rango inválido: DESDE no puede ser mayor que HASTA."
                    );
                    return;
                }

                btnRepFiltrar.disabled = true;
                btnRepFiltrar.innerHTML =
                    `<span class="spinner-border spinner-border-sm"></span> Consultando`;

                try {
                    const data = await postJson(
                        `${REALTIME_BASE_URL}/ReporteHistorico`,
                        {
                            almacen: selectedWarehouse,
                            desde: from,
                            hasta: to
                        }
                    );

                    if (queryVersion !== reportQueryVersion) {
                        return;
                    }

                    historicalReportData = data;
                    reportIncidentPage = 1;
                    reportReadingPage = 1;

                    rTotal.textContent =
                        `Lecturas: ${formatNumber(data?.totalLecturas)}`;

                    rKpiSessions.textContent =
                        formatNumber(data?.totalSesiones);

                    rKpiExpected.textContent =
                        formatNumber(data?.totalEsperado);

                    rKpiCounted.textContent =
                        formatNumber(data?.totalContadas);

                    rKpiPending.textContent =
                        formatNumber(data?.totalPendiente);

                    rKpiKg.textContent =
                        `${formatKg(data?.totalKgContados)}`;

                    rKpiIncidents.textContent =
                        formatNumber(data?.totalIncidencias);

                    renderReportWarehouseSummary(
                        data?.resumenAlmacenes
                    );

                    renderReportAging(data?.antiguedad);

                    renderReportStock(
                        data?.stockPorSku,
                        toNumber(data?.totalLecturas)
                    );

                    renderReportSessions(data?.sesiones);

                    renderReportIncidentTypeOptions(
                        data?.incidenciasResumen
                    );

                    rIncidentCount.textContent =
                        `${formatNumber(data?.totalIncidencias)} incidencias`;

                    rReadingCount.textContent =
                        `${formatNumber(data?.totalLecturas)} lecturas`;

                    rIncidentRows.innerHTML = `
                        <tr>
                            <td colspan="7" class="report-empty">
                                Abre la sección para consultar solo 50 incidencias por página.
                            </td>
                        </tr>`;

                    rReadingRows.innerHTML = `
                        <tr>
                            <td colspan="8" class="report-empty">
                                Abre la sección para consultar solo 50 lecturas por página.
                            </td>
                        </tr>`;

                    rIncidentPagerInfo.textContent = "";
                    rReadingPagerInfo.textContent = "";

                    if (reportIncidentSection?.open) {
                        renderReportIncidentsPage();
                    }

                    if (reportReadingSection?.open) {
                        renderReportReadingsPage();
                    }

                    setTimeout(() => {
                        /*
                         * El contenedor ya tiene una altura estable. El resize
                         * se ejecuta una sola vez después de que el modal quedó
                         * visible.
                         */
                        reportAgingChart?.resize();
                    }, 120);
                } catch (error) {
                    if (queryVersion !== reportQueryVersion) {
                        return;
                    }

                    resetHistoricalReportView();
                    showReportError(
                        error?.message ||
                        "No se pudo cargar el reporte histórico."
                    );
                } finally {
                    if (queryVersion === reportQueryVersion) {
                        btnRepFiltrar.disabled = false;
                        btnRepFiltrar.classList.remove("btn-danger");
                        btnRepFiltrar.classList.add("btn-outline-danger");
                        btnRepFiltrar.innerHTML =
                            `<i class="fa-solid fa-filter me-1"></i> Consultar`;
                    }
                }
            }

            function showReport() {
                populateReportWarehouseSelect();

                /*
                 * El reporte abre siempre en HOY para que la primera consulta
                 * sea pequeña y rápida.
                 */
                if (repDesde && repHasta) {
                    const todayString =
                        toDateInputValue(new Date());

                    repDesde.value = todayString;
                    repHasta.value = todayString;
                }

                if (repAlmacen) {
                    repAlmacen.value = "ALL";
                }

                if (reportIncidentSection) {
                    reportIncidentSection.open = false;
                }

                if (reportReadingSection) {
                    reportReadingSection.open = false;
                }

                resetHistoricalReportView();

                reportModal.classList.add("show");
                reportModal.setAttribute("aria-hidden", "false");
                syncInventoryModalBodyLock();

                setTimeout(renderReportReal, 60);
            }

            function hideReport() {
                reportModal.classList.remove("show");
                reportModal.setAttribute("aria-hidden", "true");
                syncInventoryModalBodyLock();
            }

            /* ===================== EVENTOS ===================== */

            input.addEventListener("keydown", event => {
                if (event.key !== "Enter") return;

                event.preventDefault();

                if ((input.value || "").includes("\n")) {
                    acceptMany(input.value);
                } else {
                    acceptCode(input.value);
                }
            });

            input.addEventListener("paste", () => {
                setTimeout(() => {
                    if ((input.value || "").includes("\n")) {
                        acceptMany(input.value);
                    }
                }, 0);
            });

            // Evita que el lector robe el foco cuando el usuario usa filtros,
            // botones, selects, fechas o modales.
            function keepScannerFocus() {
                const active = document.activeElement;

                const isInteractive =
                    active &&
                    (
                        active.tagName === "BUTTON" ||
                        active.tagName === "SELECT" ||
                        active.tagName === "TEXTAREA" ||
                        (
                            active.tagName === "INPUT" &&
                            active !== input
                        )
                    );

                const modalOpen =
                    dashboardModal.classList.contains("show") ||
                    reportModal.classList.contains("show") ||
                    photoModal.classList.contains("show") ||
                    incidentFormModal.classList.contains("show") ||
                    inventoryConfirmModal.classList.contains("show");

                if (!isInteractive && !modalOpen && active !== input) {
                    input.focus();
                }
            }

            setInterval(keepScannerFocus, 1000);
            setTimeout(() => input.focus(), 150);

            btnFlush.addEventListener("click", async () => {
                if (!activeSession || !currentWarehouseId()) {
                    setStatus(
                        "Inicia una sesión y selecciona el almacén activo.",
                        "bad"
                    );
                    return;
                }

                if (busy) {
                    setStatus("El inventario se está procesando…", "muted");
                    return;
                }

                if (queue.length === 0) {
                    setStatus(
                        "No hay lecturas pendientes. Las etiquetas con estado OK ya están inventariadas.",
                        "ok"
                    );
                    flashScanInput("ok");
                    updateInventariarButtonState();
                    setTimeout(() => input.focus(), 25);
                    return;
                }

                if (flushTimer) {
                    clearTimeout(flushTimer);
                    flushTimer = null;
                }

                setStatus(
                    `Inventariando ${queue.length} lectura(s) pendiente(s)…`,
                    "muted"
                );

                await flush(true);

                if (queue.length) {
                    await flush(true);
                }
            });

            btnReport.addEventListener("click", async () => {
                /*
                 * Sin sesión activa no existe un sesionId para consultar el
                 * dashboard. En ese caso se abre el reporte histórico normal.
                 */
                if (!activeSession) {
                    showReport();
                    return;
                }

                if (queue.length) {
                    const inventariarPendientes = await showInventoryConfirm({
                        variant: "warning",
                        title: "Lecturas pendientes",
                        message:
                            `Hay ${queue.length} lectura(s) pendiente(s) antes de abrir la reportería.`,
                        detail:
                            "Puedes inventariarlas ahora para que el tablero muestre la información más reciente.",
                        acceptText: "Inventariar y abrir",
                        cancelText: "Abrir sin esperar",
                        icon: "fa-solid fa-chart-column",
                        focusCancel: false
                    });

                    if (inventariarPendientes) {
                        await flush(true);

                        if (queue.length) {
                            await flush(true);
                        }
                    }
                }

                await showDashboardModal();
            });

            btnCloseDashboard.addEventListener("click", hideDashboardModal);

            dashboardModal.addEventListener("click", event => {
                if (event.target === dashboardModal) {
                    hideDashboardModal();
                }
            });

            btnOpenDetailedReport.addEventListener("click", () => {
                showReport();
            });

            btnClear.addEventListener("click", () => {
                /*
                 * Solo limpia el campo de captura. El historial de etiquetas,
                 * sus datos y sus estados permanecen visibles.
                 */
                input.value = "";

                setStatus(
                    "Campo limpio. El historial de etiquetas se conserva.",
                    "muted"
                );

                requestAnimationFrame(() => {
                    lastList.scrollTop = lastList.scrollHeight;
                });

                input.focus();
            });

            warehouseSelectTrigger.addEventListener("click", event => {
                event.preventDefault();
                event.stopPropagation();
                toggleWarehouseMultiSelect();
            });

            warehouseSelectMenu.addEventListener("click", event => {
                event.stopPropagation();
            });

            warehouseSearchInput.addEventListener("input", () => {
                renderWarehouseOptionList();
                updateWarehouseSelectionUi();
            });

            warehouseSelectAll.addEventListener("change", () => {
                if (warehouseSelectAll.checked) {
                    selectedWarehouseIds = new Set(
                        allowedWarehouses.map(item => String(item.id))
                    );
                } else {
                    selectedWarehouseIds.clear();
                }

                renderWarehouseOptionList();
                updateWarehouseSelectionUi();
            });

            warehouseChoices.addEventListener("change", event => {
                const check = event.target.closest(".warehouse-session-check");
                if (!check) return;

                const id = String(check.value);

                if (check.checked) {
                    selectedWarehouseIds.add(id);
                } else {
                    selectedWarehouseIds.delete(id);
                }

                check.closest(".warehouse-option")
                    ?.setAttribute("aria-selected", check.checked ? "true" : "false");

                updateWarehouseSelectionUi();
            });

            document.addEventListener("click", event => {
                if (!warehouseMultiSelect.contains(event.target)) {
                    closeWarehouseMultiSelect();
                }
            });

            document.addEventListener("keydown", event => {
                if (event.key === "Escape") {
                    closeWarehouseMultiSelect();
                }
            });

            btnStartSession.addEventListener("click", startInventorySession);
            btnCloseSession.addEventListener("click", closeInventorySession);

            activeWarehouseSelect.addEventListener("change", () => {
                incidentWarehouseInput.value = currentWarehouseId();
                renderKpis();

                setStatus(
                    `Almacén activo: ${currentWarehouseName()}`,
                    "muted"
                );

                /*
                 * Refresca los valores del almacén recién seleccionado sin
                 * interrumpir la captura del handheld.
                 */
                loadRealtimeDashboard(true);
                input.focus();
            });

            btnNewIncident.addEventListener("click", showIncidentForm);
            btnCloseIncidentForm.addEventListener("click", hideIncidentForm);
            incidentForm.addEventListener("submit", saveIncident);

            incidentFormModal.addEventListener("click", event => {
                if (event.target === incidentFormModal) {
                    hideIncidentForm();
                }
            });

            btnRefreshDashboard.addEventListener(
                "click",
                () => loadRealtimeDashboard(false)
            );

            incidentFilters.addEventListener("click", event => {
                const button = event.target.closest(".incident-filter");
                if (!button) return;

                selectedIncidentType =
                    button.getAttribute("data-type") || "ALL";

                document.querySelectorAll(".incident-filter")
                    .forEach(item => {
                        item.classList.toggle(
                            "active",
                            item === button
                        );
                    });

                renderIncidents();
            });

            incidentsBody.addEventListener("click", event => {
                const image = event.target.closest("[data-photo-url]");
                if (!image) return;

                const url = image.getAttribute("data-photo-url");
                if (!url) return;

                photoModalImage.src = url;
                photoModal.classList.add("show");
                photoModal.setAttribute("aria-hidden", "false");
                syncInventoryModalBodyLock();
            });

            function hidePhoto() {
                photoModal.classList.remove("show");
                photoModal.setAttribute("aria-hidden", "true");
                photoModalImage.src = "";
                syncInventoryModalBodyLock();
            }

            btnClosePhoto.addEventListener("click", hidePhoto);

            photoModal.addEventListener("click", event => {
                if (event.target === photoModal) {
                    hidePhoto();
                }
            });

            btnInventoryConfirmCancel.addEventListener("click", () => {
                closeInventoryConfirm(false);
            });

            btnInventoryConfirmAccept.addEventListener("click", () => {
                closeInventoryConfirm(true);
            });

            inventoryConfirmModal.addEventListener("click", event => {
                if (event.target === inventoryConfirmModal) {
                    closeInventoryConfirm(false);
                }
            });

            btnCloseReport.addEventListener("click", hideReport);

            reportModal.addEventListener("click", event => {
                if (event.target === reportModal) {
                    hideReport();
                }
            });

            document.addEventListener("keydown", event => {
                if (event.key !== "Escape") return;

                if (inventoryConfirmModal.classList.contains("show")) {
                    event.preventDefault();
                    closeInventoryConfirm(false);
                    return;
                }

                if (incidentFormModal.classList.contains("show")) {
                    hideIncidentForm();
                    return;
                }

                if (photoModal.classList.contains("show")) {
                    hidePhoto();
                    return;
                }

                if (reportModal.classList.contains("show")) {
                    hideReport();
                    return;
                }

                if (dashboardModal.classList.contains("show")) {
                    hideDashboardModal();
                }
            });

            if (btnRepFiltrar) {
                btnRepFiltrar.addEventListener(
                    "click",
                    renderReportReal
                );
            }

            function markHistoricalReportFilterChanged() {
                /*
                 * No se consulta automáticamente al cambiar cada fecha. Así se
                 * evita lanzar dos consultas seguidas mientras el usuario
                 * captura DESDE y HASTA.
                 */
                reportQueryVersion++;
                reportIncidentLoaded = false;
                reportReadingLoaded = false;

                btnRepFiltrar.classList.add("btn-danger");
                btnRepFiltrar.classList.remove("btn-outline-danger");
                btnRepFiltrar.innerHTML =
                    `<i class="fa-solid fa-filter me-1"></i> Aplicar filtro`;
            }

            repDesde?.addEventListener(
                "change",
                markHistoricalReportFilterChanged
            );

            repHasta?.addEventListener(
                "change",
                markHistoricalReportFilterChanged
            );

            repAlmacen?.addEventListener(
                "change",
                markHistoricalReportFilterChanged
            );

            reportIncidentSection?.addEventListener("toggle", () => {
                if (
                    reportIncidentSection.open &&
                    historicalReportData &&
                    !reportIncidentLoaded
                ) {
                    renderReportIncidentsPage();
                }
            });

            reportReadingSection?.addEventListener("toggle", () => {
                if (
                    reportReadingSection.open &&
                    historicalReportData &&
                    !reportReadingLoaded
                ) {
                    renderReportReadingsPage();
                }
            });

            rIncidentType.addEventListener("change", () => {
                reportIncidentPage = 1;
                reportIncidentLoaded = false;

                if (reportIncidentSection?.open) {
                    renderReportIncidentsPage();
                }
            });

            btnIncidentPrev.addEventListener("click", () => {
                reportIncidentPage--;
                renderReportIncidentsPage();
            });

            btnIncidentNext.addEventListener("click", () => {
                reportIncidentPage++;
                renderReportIncidentsPage();
            });

            btnReadingPrev.addEventListener("click", () => {
                reportReadingPage--;
                renderReportReadingsPage();
            });

            btnReadingNext.addEventListener("click", () => {
                reportReadingPage++;
                renderReportReadingsPage();
            });

            if (btnPdfReport) {
                btnPdfReport.addEventListener("click", () => {
                    const from =
                        repDesde?.value ||
                        toDateInputValue(new Date());

                    const to =
                        repHasta?.value ||
                        from;

                    const selectedWarehouse =
                        repAlmacen?.value ||
                        "ALL";

                    const url =
                        `${REALTIME_BASE_URL}/ReporteHistoricoPdf` +
                        `?almacen=${encodeURIComponent(selectedWarehouse)}` +
                        `&desde=${encodeURIComponent(from)}` +
                        `&hasta=${encodeURIComponent(to)}`;

                    window.open(url, "_blank");
                });
            }

            document.addEventListener("visibilitychange", () => {
                if (
                    document.visibilityState === "visible" &&
                    dashboardModal.classList.contains("show")
                ) {
                    loadRealtimeDashboard(true);
                }
            });

            window.addEventListener("beforeunload", () => {
                if (scanHistorySaveTimer) {
                    clearTimeout(scanHistorySaveTimer);
                    scanHistorySaveTimer = null;
                }

                persistScanHistoryNow();
            });

            renderKpis();
            setStatus(
                "Selecciona los almacenes e inicia una sesión de inventario.",
                "muted"
            );

            initializeSessionEnvironment();
            startDashboardTimer();
        })();
    </script>
}
