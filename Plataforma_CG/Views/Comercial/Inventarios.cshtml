                                <div class="warehouse-empty-result">
                                    Cargando almacenes permitidos…
                                </div>
                            </div>

                            <div id="warehouseSelectionHint" class="warehouse-selection-hint">
                                0 almacenes seleccionados
                            </div>
                        </div>
                    </div>
                </div>

                <button id="btnStartSession"
                        type="button"
                        class="btn btn-danger w-100"
