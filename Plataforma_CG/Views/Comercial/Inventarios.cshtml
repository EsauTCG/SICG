                reportQueryVersion++;
                historicalReportData = null;
                reportIncidentPage = 1;
                reportReadingPage = 1;
                reportIncidentLoaded = false;
                reportReadingLoaded = false;

                rKpiSessions.textContent = "0";
                rKpiExpected.textContent = "0";
                rKpiCounted.textContent = "0";
                rKpiPending.textContent = "0";
                rKpiKg.textContent = "0.000 kg";
                rKpiIncidents.textContent = "0";
                rTotal.textContent = "Lecturas: 0";

                rWarehouseRows.innerHTML = "";
                rRows.innerHTML = "";
                rSessionRows.innerHTML = "";
                rIncidentRows.innerHTML = `
                    <tr>
                        <td colspan="7" class="report-empty">
                            Abre esta sección para cargar las incidencias.
                        </td>
                    </tr>`;

                rReadingRows.innerHTML = `
                    <tr>
                        <td colspan="8" class="report-empty">
                            Abre esta sección para cargar las lecturas.
                        </td>
                    </tr>`;

                rIncidentPagerInfo.textContent = "";
                rReadingPagerInfo.textContent = "";
                btnIncidentPrev.disabled = true;
                btnIncidentNext.disabled = true;
                btnReadingPrev.disabled = true;
                btnReadingNext.disabled = true;
