                    reportAgingChart = null;
                }

                if (!canvas || !window.Chart) {
                    return;
                }

                const data = Array.isArray(rows) ? rows : [];

                reportAgingChart = new Chart(canvas, {
                    type: "bar",
                    data: {
                        labels: data.map(item => item.rango),
                        datasets: [{
                            label: "Etiquetas",
                            data: data.map(item =>
                                toNumber(item.cantidad)
                            ),
                            maxBarThickness: 28,
                            borderRadius: 6
                        }]
                    },
                    options: {
                        indexAxis: "y",
                        responsive: true,
                        maintainAspectRatio: false,
                        resizeDelay: 120,
                        animation: {
                            duration: 180
                        },
                        interaction: {
                            intersect: false,
                            mode: "nearest"
                        },
                        plugins: {
