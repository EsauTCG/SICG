            const rIncidentRows = document.getElementById("rIncidentRows");
            const rIncidentPagerInfo = document.getElementById("rIncidentPagerInfo");
            const btnIncidentPrev = document.getElementById("btnIncidentPrev");
            const btnIncidentNext = document.getElementById("btnIncidentNext");

            const rReadingCount = document.getElementById("rReadingCount");
            const rReadingRows = document.getElementById("rReadingRows");
            const rReadingPagerInfo = document.getElementById("rReadingPagerInfo");
            const btnReadingPrev = document.getElementById("btnReadingPrev");
            const btnReadingNext = document.getElementById("btnReadingNext");

            const repDesde = document.getElementById("repDesde");
            const repHasta = document.getElementById("repHasta");
            const repAlmacen = document.getElementById("repAlmacen");
            const btnRepFiltrar = document.getElementById("btnRepFiltrar");

            const SCAN_HISTORY_STORAGE_PREFIX =
                "inventarioTiempoReal.historialEscaneos.v1.";

            const FLUSH_MS = 140;
            const DEDUPE_WINDOW_MS = 900;
            const BATCH_SIZE = 25;
            const DASHBOARD_AFTER_SCAN_MS = 1100;

            let queue = [];
            let okCount = 0;
            let badCount = 0;
            let scanSequence = 0;

            let allowedWarehouses = [];
            let selectedWarehouseIds = new Set();
            let activeSession = null;

            let busy = false;
            let flushTimer = null;
            let lastCode = "";
            let lastCodeAt = 0;

            let dashboardBusy = false;
            let dashboardTimer = null;
            let dashboardData = {
                resumenAlmacenes: [],
                antiguedad: [],
                incidenciasResumen: [],
                incidencias: []
            };

            let selectedIncidentType = "ALL";
            let agingChart = null;
            let differencesChart = null;
            let reportAgingChart = null;
            let historicalReportData = null;
            let reportIncidentPage = 1;
            let reportReadingPage = 1;
            let reportIncidentLoaded = false;
            let reportReadingLoaded = false;
            let reportQueryVersion = 0;
            const REPORT_PAGE_SIZE = 50;

            const pendingScanVisuals = new Map();
            let dashboardAfterScanTimer = null;
            let scanInputFlashTimer = null;
            let scanHistorySaveTimer = null;
            let restoringScanHistory = false;

            let inventoryConfirmResolver = null;
            let inventoryConfirmPreviousFocus = null;

            function showSessionWarning(message) {
                sessionWarning.textContent = message || "";
                sessionWarning.classList.toggle("show", Boolean(message));
            }

            function syncInventoryModalBodyLock() {
                const modalOpen = [
                    dashboardModal,
                    reportModal,
                    incidentFormModal,
                    photoModal,
                    inventoryConfirmModal
                ].some(modal => modal?.classList.contains("show"));

                document.documentElement.classList.toggle(
                    "inventory-modal-open",
                    modalOpen
                );

                document.body.classList.toggle(
                    "inventory-modal-open",
                    modalOpen
                );
            }


            function closeInventoryConfirm(result) {
                if (!inventoryConfirmModal.classList.contains("show")) {
                    return;
                }

                inventoryConfirmModal.classList.remove("show");
                inventoryConfirmModal.setAttribute("aria-hidden", "true");
                syncInventoryModalBodyLock();

                const resolver = inventoryConfirmResolver;
                inventoryConfirmResolver = null;

                const previousFocus = inventoryConfirmPreviousFocus;
                inventoryConfirmPreviousFocus = null;

                if (
                    previousFocus &&
                    typeof previousFocus.focus === "function" &&
                    document.contains(previousFocus)
                ) {
                    setTimeout(() => previousFocus.focus(), 25);
                }

                if (resolver) {
                    resolver(Boolean(result));
                }
            }

            function showInventoryConfirm(options = {}) {
                /*
                 * Si por alguna razón ya existe otra confirmación abierta,
                 * la anterior se resuelve como cancelada.
                 */
                if (inventoryConfirmResolver) {
                    closeInventoryConfirm(false);
                }

                const variant = String(options.variant || "danger").toLowerCase();
                const allowedVariants = ["danger", "warning", "success"];
                const normalizedVariant = allowedVariants.includes(variant)
                    ? variant
                    : "danger";

                inventoryConfirmModal.classList.remove(
                    "confirm-danger",
                    "confirm-warning",
                    "confirm-success"
                );

                inventoryConfirmModal.classList.add(
                    `confirm-${normalizedVariant}`
                );

                inventoryConfirmTitle.textContent =
                    options.title || "Confirmar acción";

                inventoryConfirmMessage.textContent =
                    options.message || "¿Deseas continuar?";

                const detail = String(options.detail || "").trim();
                inventoryConfirmDetail.textContent = detail;
                inventoryConfirmDetail.classList.toggle("show", Boolean(detail));

                inventoryConfirmIcon.className =
                    options.icon ||
                    (
                        normalizedVariant === "warning"
                            ? "fa-solid fa-boxes-stacked"
                            : normalizedVariant === "success"
                                ? "fa-solid fa-circle-check"
                                : "fa-solid fa-triangle-exclamation"
                    );

                btnInventoryConfirmAccept.querySelector("span").textContent =
                    options.acceptText || "Confirmar";

                btnInventoryConfirmCancel.querySelector("span").textContent =
                    options.cancelText || "Cancelar";

                inventoryConfirmPreviousFocus = document.activeElement;

                inventoryConfirmModal.classList.add("show");
                inventoryConfirmModal.setAttribute("aria-hidden", "false");
                syncInventoryModalBodyLock();

                return new Promise(resolve => {
                    inventoryConfirmResolver = resolve;

                    requestAnimationFrame(() => {
                        const preferredButton =
                            options.focusCancel === false
                                ? btnInventoryConfirmAccept
                                : btnInventoryConfirmCancel;

                        preferredButton.focus();
                    });
                });
            }

            function currentWarehouseId() {
                return normalize(activeWarehouseSelect?.value || "");
            }

            function currentWarehouseName() {
                const option = activeWarehouseSelect?.selectedOptions?.[0];
                return option?.textContent?.trim() || currentWarehouseId() || "N/D";
            }

            function getKnownWarehouses() {
                const sessionWarehouses =
                    Array.isArray(activeSession?.almacenes)
                        ? activeSession.almacenes
                        : [];

                return [
                    ...(Array.isArray(allowedWarehouses)
                        ? allowedWarehouses
                        : []),
                    ...sessionWarehouses
                ];
            }

            function warehouseDisplayName(warehouseId, rawName = "") {
                const id = normalize(warehouseId || "");
                const name = normalize(rawName || "");

                const match = getKnownWarehouses().find(item => {
                    const itemId = normalize(
                        item?.id ||
                        item?.almacenId ||
                        ""
                    );

                    const itemName = normalize(
                        item?.nombre ||
                        item?.almacen ||
                        ""
                    );

                    return (
                        (id && itemId === id) ||
                        (name && itemName === name)
                    );
                });

                return (
                    match?.nombreMostrar ||
                    match?.displayName ||
                    rawName ||
                    warehouseId ||
                    "N/D"
                ).toString().trim();
            }

            function warehousePlant(item) {
                return normalize(item?.planta || item?.plant || "P1") === "TIF"
                    ? "TIF"
                    : "P1";
            }

            function warehouseBranch(item) {
                return (
                    item?.sucursal ||
                    item?.branch ||
                    (warehousePlant(item) === "TIF" ? "TIF" : "PLANTA 1")
                ).toString().trim();
            }

            function getScanHistoryStorageKey(sessionId = activeSession?.id) {
                const id = Number(sessionId || 0);
                return id > 0
                    ? `${SCAN_HISTORY_STORAGE_PREFIX}${id}`
                    : "";
            }

            function readScanHistory(sessionId) {
                const key = getScanHistoryStorageKey(sessionId);
                if (!key) return [];

                try {
                    const raw = localStorage.getItem(key);
                    if (!raw) return [];

                    const parsed = JSON.parse(raw);
                    const rows = Array.isArray(parsed)
                        ? parsed
                        : parsed?.rows;

                    return Array.isArray(rows) ? rows : [];
                } catch (error) {
                    console.warn("No fue posible leer el historial de escaneos.", error);
                    return [];
                }
            }

            function collectScanHistory() {
                return Array.from(lastList.children).map((item, index) => ({
                    order: Number(item.dataset.scanOrder || index + 1),
                    time: item.dataset.scanTime || "",
                    code: item.dataset.scanCode || "",
                    label: item.dataset.scanLabel || "",
                    kind: item.dataset.scanKind || "err",
                    sku: item.dataset.scanSku || "",
                    producto: item.dataset.scanProduct || "",
                    pesoNeto: toNumber(item.dataset.scanWeight)
                }));
            }

            function persistScanHistoryNow() {
                if (restoringScanHistory || !activeSession?.id) return;

                const key = getScanHistoryStorageKey(activeSession.id);
                if (!key) return;

                try {
                    localStorage.setItem(
                        key,
                        JSON.stringify({
                            version: 1,
                            sessionId: Number(activeSession.id),
                            updatedAt: new Date().toISOString(),
                            rows: collectScanHistory()
                        })
                    );
                } catch (error) {
                    /*
                     * El historial permanece visible aunque el navegador
                     * alcance su límite de almacenamiento local.
                     */
                    console.warn(
                        "El historial sigue visible, pero no pudo guardarse localmente.",
                        error
                    );
                }
            }

            function schedulePersistScanHistory() {
                if (restoringScanHistory || !activeSession?.id) return;

                if (scanHistorySaveTimer) {
                    clearTimeout(scanHistorySaveTimer);
                }

                scanHistorySaveTimer = setTimeout(() => {
                    scanHistorySaveTimer = null;
                    persistScanHistoryNow();
                }, 80);
            }

            function restoreScanHistory(sessionId) {
                const rows = readScanHistory(sessionId)
                    .slice()
                    .sort((a, b) =>
                        toNumber(a?.order) - toNumber(b?.order)
                    );

                restoringScanHistory = true;

                try {
                    lastList.innerHTML = "";
                    pendingScanVisuals.clear();
                    scanSequence = 0;
                    queue = [];

                    for (const stored of rows) {
                        const li = document.createElement("li");
                        const order = Math.max(
                            1,
                            Math.trunc(toNumber(stored?.order) || scanSequence + 1)
                        );

                        li.dataset.scanOrder = String(order);
                        li.dataset.scanTime = stored?.time || "";

                        renderScanVisual(
                            li,
                            stored?.code || "",
                            stored?.label || "",
                            stored?.kind || "err",
                            {
                                sku: stored?.sku || "",
                                producto: stored?.producto || "",
                                pesoNeto: toNumber(stored?.pesoNeto)
                            }
                        );

                        lastList.appendChild(li);
                        scanSequence = Math.max(scanSequence, order);

                        if (
                            li.dataset.scanKind === "pending" ||
                            li.dataset.scanKind === "validating"
                        ) {
                            const code = normalize(li.dataset.scanCode || "");
                            const pendingRows = pendingScanVisuals.get(code) || [];
                            pendingRows.push(li);
                            pendingScanVisuals.set(code, pendingRows);
                        }
                    }

                    okCount = rows.filter(row => row?.kind === "ok").length;
                    badCount = rows.filter(row =>
                        ["dup", "warn", "err"].includes(row?.kind)
                    ).length;

                    renderKpis();

                    requestAnimationFrame(() => {
                        lastList.scrollTop = lastList.scrollHeight;
                    });
                } finally {
                    restoringScanHistory = false;
                }
            }

            function setScannerEnabled(enabled) {
                input.disabled = !enabled;
                btnNewIncident.disabled = !enabled;

                /*
                 * Reportes permanece habilitado incluso sin sesión. Cuando no
                 * existe sesión abre el reporte histórico; con sesión abierta
                 * abre el tablero de control en tiempo real.
                 */
                btnReport.disabled = false;

                document.querySelector(".scan-shell")
                    ?.classList.toggle("scanner-disabled", !enabled);

                updateInventariarButtonState();

                if (enabled) {
                    setTimeout(() => input.focus(), 100);
                }
            }

            function updateInventariarButtonState() {
                if (!btnFlush) return;

                const sessionOpen =
                    Boolean(activeSession) &&
                    String(activeSession?.estatus || "").toUpperCase() === "ABIERTO" &&
                    Boolean(currentWarehouseId());

                const pending = queue.length;

                btnFlush.disabled = !sessionOpen || busy;
                btnFlush.classList.toggle("has-pending", sessionOpen && pending > 0 && !busy);
                btnFlush.classList.toggle("inventory-busy", sessionOpen && busy);

                if (busy) {
                    btnFlushText.textContent = "Inventariando…";
                    btnFlushIcon.className = "fa-solid fa-rotate fa-spin";
                    btnFlush.title = "Procesando las lecturas pendientes";
                    return;
                }

                btnFlushIcon.className =
                    pending > 0
                        ? "fa-solid fa-boxes-stacked"
                        : "fa-solid fa-circle-check";

                btnFlushText.textContent =
                    pending > 0
                        ? `Inventariar (${pending})`
                        : "Inventariar";

                btnFlush.title =
                    pending > 0
                        ? `Inventariar ${pending} lectura(s) pendiente(s)`
                        : "Las etiquetas se inventarían automáticamente al escanear";
            }

            function normalizeSearchText(value) {
                return (value ?? "")
                    .toString()
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "")
                    .toLowerCase()
                    .trim();
            }

            function getSelectedWarehouseIds() {
                const allowedIds = new Set(
                    allowedWarehouses.map(item => String(item.id))
                );

                return Array.from(selectedWarehouseIds)
                    .filter(id => allowedIds.has(String(id)));
            }

            function openWarehouseMultiSelect() {
                if (warehouseSelectTrigger.disabled) return;

                warehouseMultiSelect.classList.add("open");
                warehouseSelectTrigger.setAttribute("aria-expanded", "true");

                setTimeout(() => {
                    warehouseSearchInput.focus();
                    warehouseSearchInput.select();
                }, 30);
            }

            function closeWarehouseMultiSelect() {
                warehouseMultiSelect.classList.remove("open");
                warehouseSelectTrigger.setAttribute("aria-expanded", "false");
            }

            function toggleWarehouseMultiSelect() {
                if (warehouseMultiSelect.classList.contains("open")) {
                    closeWarehouseMultiSelect();
                } else {
                    openWarehouseMultiSelect();
                }
            }

            function updateWarehouseSelectionUi() {
                const selected = getSelectedWarehouseIds();
                const selectedCount = selected.length;
                const total = allowedWarehouses.length;

                if (selectedCount === 0) {
                    warehouseSelectText.textContent = "Selecciona uno o varios almacenes";
                } else if (total > 0 && selectedCount === total) {
                    warehouseSelectText.textContent = "(Todos)";
                } else if (selectedCount === 1) {
                    const selectedItem = allowedWarehouses.find(
                        item => String(item.id) === String(selected[0])
                    );
                    warehouseSelectText.textContent =
                        selectedItem?.nombreMostrar ||
                        selectedItem?.nombre ||
                        selected[0];
                } else if (selectedCount === 2) {
                    warehouseSelectText.textContent = selected
                        .map(id => {
                            const item = allowedWarehouses.find(
                                row => String(row.id) === String(id)
                            );

                            return (
                                item?.nombreMostrar ||
                                item?.nombre ||
                                id
                            );
                        })
                        .join(", ");
                } else {
                    warehouseSelectText.textContent = `${selectedCount} almacenes seleccionados`;
                }

                warehouseSelectionHint.textContent =
                    `${selectedCount} de ${total} almacén(es) seleccionados`;

                warehouseSelectAll.checked = total > 0 && selectedCount === total;
                warehouseSelectAll.indeterminate = selectedCount > 0 && selectedCount < total;
                warehouseSelectAllText.textContent =
                    warehouseSelectAll.checked ? "Quitar selección" : "Seleccionar todo";

                btnStartSession.disabled = selectedCount === 0;

                warehouseChoices
                    .querySelectorAll(".warehouse-session-check")
                    .forEach(check => {
                        const checked = selectedWarehouseIds.has(String(check.value));
                        check.checked = checked;
                        check.closest(".warehouse-option")
                            ?.classList.toggle("selected", checked);
                    });
            }

            function renderWarehouseOptionList() {
                const term = normalizeSearchText(warehouseSearchInput.value);

                const filtered = allowedWarehouses.filter(item => {
                    if (!term) return true;

                    const searchable = normalizeSearchText(
                        `${item.id ?? ""} ` +
                        `${item.nombre ?? ""} ` +
                        `${item.nombreMostrar ?? ""} ` +
                        `${item.sucursal ?? ""} ` +
                        `${item.planta ?? ""}`
                    );

                    return searchable.includes(term);
                });

                if (filtered.length === 0) {
                    warehouseChoices.innerHTML = `
                        <div class="warehouse-empty-result">
                            <i class="fa-solid fa-magnifying-glass mb-2"></i><br />
                            No se encontraron almacenes.
                        </div>`;
                    return;
                }

                warehouseChoices.innerHTML = filtered.map(item => {
                    const id = String(item.id);
                    const checked = selectedWarehouseIds.has(id);
                    const showId =
                        normalizeSearchText(item.id) !==
                        normalizeSearchText(item.nombre);

                    const plant = warehousePlant(item);
                    const branch = warehouseBranch(item);
                    const configured = item?.plantaConfigurada !== false;
                    const displayName =
                        item?.nombreMostrar ||
                        `${branch} · ${item?.nombre || id}`;

                    return `
                        <label class="warehouse-option ${checked ? "selected" : ""}"
                               role="option"
                               aria-selected="${checked ? "true" : "false"}">
                            <input type="checkbox"
                                   class="warehouse-session-check"
                                   value="${esc(id)}"
                                   ${checked ? "checked" : ""} />
                            <span>
                                <span class="warehouse-option-main">
                                    <span class="warehouse-plant-badge
                                                 ${plant === "TIF" ? "tif" : "p1"}
                                                 ${configured ? "" : "inferred"}"
                                          title="${
                                              configured
                                                  ? `Planta configurada: ${plant}`
                                                  : "Planta inferida; revisar appsettings.json"
                                          }">
                                        ${esc(plant)}${configured ? "" : "*"}
                                    </span>
                                    <span class="warehouse-option-name">
                                        ${esc(displayName)}
                                    </span>
                                </span>

                                <div class="warehouse-branch-line">
                                    Sucursal: ${esc(branch)}
                                    ${configured
                                        ? ""
                                        : `<span class="warehouse-config-warning">
                                               · planta por revisar
                                           </span>`}
                                </div>

                                ${showId
                                    ? `<div class="warehouse-option-id">
                                           ID: ${esc(item.id)}
                                       </div>`
                                    : ""}
                            </span>
                        </label>`;
                }).join("");
            }

            function renderWarehouseChoices() {
                const rows = Array.isArray(allowedWarehouses)
                    ? allowedWarehouses
                    : [];

                const allowedIds = new Set(rows.map(item => String(item.id)));
                selectedWarehouseIds = new Set(
                    Array.from(selectedWarehouseIds)
                        .filter(id => allowedIds.has(String(id)))
                );

                warehouseSearchInput.value = "";

                if (rows.length === 0) {
                    selectedWarehouseIds.clear();
                    warehouseChoices.innerHTML = `
                        <div class="warehouse-empty-result text-danger fw-bold">
                            No tienes almacenes asignados. Contacta a Sistemas.
                        </div>`;
                    warehouseSelectText.textContent = "Sin almacenes asignados";
                    warehouseSelectionHint.textContent = "0 almacenes disponibles";
                    warehouseSelectTrigger.disabled = true;
                    warehouseSelectAll.disabled = true;
                    btnStartSession.disabled = true;
                    closeWarehouseMultiSelect();
                    return;
                }

                warehouseSelectTrigger.disabled = false;
                warehouseSelectAll.disabled = false;
                renderWarehouseOptionList();
                updateWarehouseSelectionUi();
            }

            function warehouseOptionsHtml(rows) {
                return (Array.isArray(rows) ? rows : []).map(item => {
                    const label =
                        item?.nombreMostrar ||
                        item?.displayName ||
                        item?.nombre ||
                        item?.id;

                    return `
                        <option value="${esc(item.id)}"
                                data-plant="${esc(warehousePlant(item))}"
                                data-branch="${esc(warehouseBranch(item))}"
                                data-raw-name="${esc(item?.nombre || "")}">
                            ${esc(label)}
                        </option>`;
                }).join("");
            }

            function populateWarehouseSelects(warehouses) {
                const rows = Array.isArray(warehouses) ? warehouses : [];
                const options = warehouseOptionsHtml(rows);

                activeWarehouseSelect.innerHTML = options;
                incidentWarehouseInput.innerHTML = options;

                if (rows.length > 0) {
                    activeWarehouseSelect.value = rows[0].id;
                    incidentWarehouseInput.value = rows[0].id;
                }
            }

            function populateReportWarehouseSelect() {
                const current = repAlmacen?.value || "ALL";
                const options = warehouseOptionsHtml(allowedWarehouses);

                repAlmacen.innerHTML =
                    `<option value="ALL">
                        Todos los almacenes permitidos
                     </option>` + options;

                const exists = Array.from(repAlmacen.options)
                    .some(option => option.value === current);

                repAlmacen.value = exists ? current : "ALL";
            }

            function applyActiveSession(session) {
                const previousSessionId = Number(activeSession?.id || 0);
                activeSession = session || null;

                if (!activeSession) {
                    sessionSetupBlock.classList.remove("d-none");
                    sessionActiveBlock.classList.add("d-none");
                    sessionStorage.removeItem(SESSION_STORAGE_KEY);
                    localStorage.removeItem(SESSION_STORAGE_KEY);

                    dashboardData = {
                        resumenAlmacenes: [],
                        antiguedad: [],
                        incidenciasResumen: [],
                        incidencias: []
                    };

                    populateWarehouseSelects([]);
                    setScannerEnabled(false);
                    renderKpis();
                    return;
                }

                sessionStorage.setItem(SESSION_STORAGE_KEY, String(activeSession.id));
                localStorage.setItem(SESSION_STORAGE_KEY, String(activeSession.id));

                closeWarehouseMultiSelect();
                sessionSetupBlock.classList.add("d-none");
                sessionActiveBlock.classList.remove("d-none");
                sessionFolio.textContent = activeSession.folio || `Sesión ${activeSession.id}`;

                const warehouses = Array.isArray(activeSession.almacenes)
                    ? activeSession.almacenes
                    : [];

                const totalExpected = warehouses.reduce(
                    (sum, item) => sum + toNumber(item.totalEsperado),
                    0
                );

                const totalKg = warehouses.reduce(
                    (sum, item) => sum + toNumber(item.kgEsperados),
                    0
                );

                sessionMeta.innerHTML = `
                    <span class="session-badge">
                        <i class="fa-solid fa-calendar"></i>
                        ${esc(formatDateTime(activeSession.fechaInicio))}
                    </span>
                    <span class="session-badge">
                        <i class="fa-solid fa-warehouse"></i>
                        ${formatNumber(warehouses.length)} almacén(es)
                    </span>
                    <span class="session-badge">
                        <i class="fa-solid fa-box"></i>
                        ${formatNumber(totalExpected)} etiquetas/cajas iniciales
                    </span>
                    <span class="session-badge">
                        <i class="fa-solid fa-weight-hanging"></i>
                        ${formatNumber(totalKg)} kg iniciales
                    </span>`;

                populateWarehouseSelects(warehouses);

                const currentSessionId = Number(activeSession.id || 0);
                if (
                    currentSessionId > 0 &&
                    (
                        previousSessionId !== currentSessionId ||
                        lastList.children.length === 0
                    )
                ) {
                    restoreScanHistory(currentSessionId);
                }

                setScannerEnabled(String(activeSession.estatus || "").toUpperCase() === "ABIERTO");
                showSessionWarning("");
                renderKpis();

                setStatus(
                    `Listo. Almacén activo: ${currentWarehouseName()}`,
                    "muted"
                );

                /*
                 * No bloquea el inicio del lector. La cantidad pendiente se
                 * reconcilia en segundo plano con los registros de SQL Server.
                 */
                setTimeout(() => {
                    if (activeSession) {
                        loadRealtimeDashboard(true);
                    }
                }, 0);
            }

            async function loadAllowedWarehouses() {
                const data = await getJson(`${REALTIME_BASE_URL}/AlmacenesPermitidos?_=${Date.now()}`);
                allowedWarehouses = Array.isArray(data?.almacenes)
                    ? data.almacenes
                    : [];

                renderWarehouseChoices();
                populateReportWarehouseSelect();
            }

            async function restoreSession() {
                const storedId =
                    localStorage.getItem(SESSION_STORAGE_KEY) ||
                    sessionStorage.getItem(SESSION_STORAGE_KEY) ||
                    "";

                const suffix = storedId
                    ? `?sesionId=${encodeURIComponent(storedId)}`
                    : "";

                const data = await getJson(
                    `${REALTIME_BASE_URL}/SesionActiva${suffix}${suffix ? "&" : "?"}_=${Date.now()}`
                );

                applyActiveSession(data?.sesion || null);
            }

            async function initializeSessionEnvironment() {
                setScannerEnabled(false);
                showSessionWarning("");

                try {
                    await loadAllowedWarehouses();
                    await restoreSession();

                    if (activeSession) {
                        await retryPendingSessionRegistrations();
                    } else {
                        warehouseSummaryBody.innerHTML = `
                            <tr>
                                <td colspan="5" class="empty-state">
                                    Selecciona los almacenes e inicia el inventario.
                                </td>
                            </tr>`;
                    }
                } catch (error) {
                    showSessionWarning(
                        `No se pudo preparar la sesión de inventario. ${error?.message || ""}`
                    );
                }
            }

            async function startInventorySession() {
                const selected = getSelectedWarehouseIds();

                if (selected.length === 0) {
                    showSessionWarning("Selecciona al menos un almacén.");
                    return;
                }

                btnStartSession.disabled = true;
                btnStartSession.innerHTML =
                    `<span class="spinner-border spinner-border-sm"></span> Iniciando…`;

                try {
                    const data = await postJson(
                        `${REALTIME_BASE_URL}/IniciarSesion`,
                        { almacenes: selected }
                    );

                    applyActiveSession(data?.sesion || null);
                    startDashboardTimer();
                } catch (error) {
                    if (error?.responseData?.sesion) {
                        applyActiveSession(error.responseData.sesion);
                    }

                    showSessionWarning(error?.message || "No se pudo iniciar el inventario.");
                } finally {
                    btnStartSession.innerHTML =
                        `<i class="fa-solid fa-play"></i> Iniciar inventario`;
                    btnStartSession.disabled = getSelectedWarehouseIds().length === 0;
                }
            }

            async function closeInventorySession() {
                if (!activeSession) return;

                if (queue.length > 0) {
                    const inventariarPendientes = await showInventoryConfirm({
                        variant: "warning",
                        title: "Lecturas pendientes",
                        message:
                            `Hay ${queue.length} lectura(s) pendiente(s) por inventariar.`,
                        detail:
                            "Para cerrar la sesión primero deben procesarse todas las lecturas pendientes.",
                        acceptText: "Inventariar ahora",
                        cancelText: "Volver",
                        icon: "fa-solid fa-boxes-stacked"
                    });

                    if (!inventariarPendientes) {
                        return;
                    }

                    await flush(true);

                    if (queue.length > 0) {
                        showSessionWarning(
                            "No se puede cerrar mientras existan lecturas pendientes."
                        );
                        return;
                    }
                }

                const confirmed = await showInventoryConfirm({
                    variant: "danger",
                    title: "Cerrar sesión de inventario",
                    message:
                        "¿Confirmas que deseas cerrar esta sesión de inventario?",
                    detail:
                        "Después de cerrarla ya no se podrán agregar nuevas lecturas. Los registros guardados permanecerán disponibles en la reportería.",
                    acceptText: "Sí, cerrar sesión",
                    cancelText: "Continuar inventariando",
                    icon: "fa-solid fa-lock"
                });

                if (!confirmed) {
                    return;
                }

                btnCloseSession.disabled = true;
                btnCloseSession.innerHTML =
                    `<span class="spinner-border spinner-border-sm"></span> Cerrando…`;

                try {
                    await postJson(
                        `${REALTIME_BASE_URL}/CerrarSesion`,
                        { sesionId: activeSession.id }
                    );

                    applyActiveSession(null);
                    hideDashboardModal();
                    await loadAllowedWarehouses();
                    renderWarehouseChoices();
                    showSessionWarning(
                        "Sesión cerrada correctamente. Puedes iniciar un inventario nuevo."
                    );
                } catch (error) {
                    showSessionWarning(
                        error?.message || "No se pudo cerrar la sesión."
                    );
                } finally {
                    btnCloseSession.disabled = false;
                    btnCloseSession.innerHTML =
                        `<i class="fa-solid fa-lock"></i> Cerrar sesión de inventario`;
                }
            }

            function readPendingTracking() {
                try {
                    const raw = localStorage.getItem(PENDING_TRACKING_KEY) || "[]";
                    const rows = JSON.parse(raw);
                    return Array.isArray(rows) ? rows : [];
                } catch {
                    return [];
                }
            }

            function writePendingTracking(rows) {
                localStorage.setItem(
                    PENDING_TRACKING_KEY,
                    JSON.stringify(Array.isArray(rows) ? rows : [])
                );
            }

            function preservePendingTracking(payload) {
                const rows = readPendingTracking();
                const key = `${payload.sesionId}|${payload.almacenId}`;
                const existing = rows.find(
                    item => `${item.sesionId}|${item.almacenId}` === key
                );

                if (existing) {
                    existing.codigos = Array.from(new Set([
                        ...(existing.codigos || []),
                        ...(payload.codigos || [])
                    ]));
                } else {
                    rows.push(payload);
                }

                writePendingTracking(rows);
            }

            async function retryPendingSessionRegistrations() {
                const rows = readPendingTracking();
                if (rows.length === 0) return;

                const pending = [];

                for (const payload of rows) {
                    try {
                        await postJson(
                            `${REALTIME_BASE_URL}/RegistrarLecturas`,
                            payload
                        );
                    } catch {
                        pending.push(payload);
                    }
                }

                writePendingTracking(pending);
            }

            async function registerSuccessfulScans(codes, warehouseId) {
                if (!activeSession || !Array.isArray(codes) || codes.length === 0) {
                    return null;
                }

                const payload = {
                    sesionId: activeSession.id,
                    almacenId: normalize(warehouseId || currentWarehouseId()),
                    codigos: Array.from(
                        new Set(codes.map(normalize).filter(Boolean))
                    )
                };

                try {
                    return await postJson(
                        `${REALTIME_BASE_URL}/RegistrarLecturas`,
                        payload
                    );
                } catch (error) {
                    /*
                     * ScanBatch ya guardó las etiquetas. No se bloquea al lector:
                     * las lecturas quedan en localStorage para volver a relacionarlas
                     * con la sesión en el siguiente refresco.
                     */
                    preservePendingTracking(payload);

                    return {
                        ok: false,
                        deferred: true,
                        message:
                            error?.message ||
                            "Guardada; pendiente de actualizar el tablero.",
                        results: []
                    };
                }
            }

            function showIncidentForm() {
                if (!activeSession) return;

                const latestScan = lastList?.lastElementChild;
                const latestCode = latestScan?.dataset?.scanCode || "";
                const latestSku = latestScan?.dataset?.scanSku || "";
                const latestProduct = latestScan?.dataset?.scanProduct || "";
                const latestWeight = Number(
                    latestScan?.dataset?.scanWeight || 0
                );

                incidentForm.reset();
                incidentWarehouseInput.value = currentWarehouseId();

                if (latestCode) {
                    incidentCodeInput.value = latestCode;
                }

                if (latestProduct || latestSku) {
                    incidentProductInput.value = latestProduct || latestSku;
                }

                if (Number.isFinite(latestWeight) && latestWeight > 0) {
                    incidentWeightInput.value = latestWeight.toFixed(3);
                }

                incidentFormModal.classList.add("show");
                incidentFormModal.setAttribute("aria-hidden", "false");
                syncInventoryModalBodyLock();
                setTimeout(() => incidentTypeInput.focus(), 80);
            }

            function hideIncidentForm() {
                incidentFormModal.classList.remove("show");
                incidentFormModal.setAttribute("aria-hidden", "true");
                incidentForm.reset();
                syncInventoryModalBodyLock();
            }

            async function saveIncident(event) {
                event.preventDefault();
                if (!activeSession) return;

                const formData = new FormData(incidentForm);
                formData.set("sesionId", String(activeSession.id));

                btnSaveIncident.disabled = true;
                btnSaveIncident.innerHTML =
                    `<span class="spinner-border spinner-border-sm"></span> Guardando…`;

                try {
                    const response = await fetch(
                        `${REALTIME_BASE_URL}/RegistrarIncidencia`,
                        {
                            method: "POST",
                            body: formData
                        }
                    );

                    const raw = await response.text();
                    let data = null;
                    try { data = raw ? JSON.parse(raw) : null; } catch { }

                    if (!response.ok) {
                        throw new Error(data?.message || raw || "No se pudo guardar la incidencia.");
                    }

                    hideIncidentForm();
                    await loadRealtimeDashboard(true);
                    setStatus("Incidencia registrada correctamente.", "ok");
                } catch (error) {
                    alert(error?.message || "No se pudo guardar la incidencia.");
                } finally {
                    btnSaveIncident.disabled = false;
                    btnSaveIncident.innerHTML =
                        `<i class="fa-solid fa-floppy-disk"></i> Guardar incidencia`;
                }
            }

            function formatKg(value) {
                const number = Number(value);
                if (!Number.isFinite(number)) return "0.000";

                return number.toLocaleString("es-MX", {
                    minimumFractionDigits: 3,
                    maximumFractionDigits: 3
                });
            }

            function esc(value) {
                return (value ?? "")
                    .toString()
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            function normalize(code) {
                return (code || "").trim().toUpperCase();
            }

            function toNumber(value) {
                const number = Number(value);
                return Number.isFinite(number) ? number : 0;
            }

            function clamp(value, min, max) {
                return Math.min(Math.max(value, min), max);
            }

            function formatNumber(value) {
                return new Intl.NumberFormat("es-MX").format(toNumber(value));
            }

            function formatDateTime(value) {
                if (!value) return "--";

                const date = new Date(value);
                if (Number.isNaN(date.getTime())) return esc(value);

                return date.toLocaleString("es-MX", {
                    year: "numeric",
                    month: "2-digit",
                    day: "2-digit",
                    hour: "2-digit",
                    minute: "2-digit"
                });
            }

            function toDateInputValue(date) {
                const yyyy = date.getFullYear();
                const mm = String(date.getMonth() + 1).padStart(2, "0");
                const dd = String(date.getDate()).padStart(2, "0");
                return `${yyyy}-${mm}-${dd}`;
            }

            function setStatus(text, type = "muted") {
                const className =
                    type === "ok"
                        ? "text-success"
                        : type === "bad"
                            ? "text-danger"
                            : "text-muted";

                statusMsg.className = `small mt-2 ${className}`;
                statusMsg.textContent = text;
            }

            function getActiveSessionWarehouse() {
                if (!activeSession) return null;

                const activeId = currentWarehouseId();
                const warehouses = Array.isArray(activeSession.almacenes)
                    ? activeSession.almacenes
                    : [];

                return warehouses.find(item =>
                    normalize(item?.id || item?.almacenId || "") === activeId
                ) || null;
            }

            function getActiveDashboardWarehouse() {
                const activeId = currentWarehouseId();
                const activeName = normalize(currentWarehouseName());
                const rows = Array.isArray(dashboardData?.resumenAlmacenes)
                    ? dashboardData.resumenAlmacenes
                    : [];

                return rows.find(item => {
                    const rowId = normalize(
                        item?.almacenId ||
                        item?.id ||
                        item?.warehouseId ||
                        ""
                    );

                    const rowName = normalize(
                        item?.almacen ||
                        item?.nombre ||
                        item?.warehouse ||
                        ""
                    );

                    return (
                        (activeId && rowId === activeId) ||
                        (activeName && rowName === activeName)
                    );
                }) || null;
            }

            function renderWarehouseInventoryKpis() {
                if (!activeSession || !currentWarehouseId()) {
                    kTotalBoxes.textContent = "0";
                    kMissingBoxes.textContent = "0";
                    return;
                }

                const sessionWarehouse = getActiveSessionWarehouse();
                const dashboardWarehouse = getActiveDashboardWarehouse();

                let totalBoxes = toNumber(
                    sessionWarehouse?.totalEsperado ??
                    sessionWarehouse?.ubicaciones ??
                    0
                );

                let countedBoxes = 0;
                let missingBoxes = totalBoxes;

                if (dashboardWarehouse) {
                    totalBoxes = toNumber(
                        dashboardWarehouse?.ubicaciones ??
                        dashboardWarehouse?.totalEsperado ??
                        dashboardWarehouse?.locations ??
                        totalBoxes
                    );

                    countedBoxes = toNumber(
                        dashboardWarehouse?.contadas ??
                        dashboardWarehouse?.counted ??
                        dashboardWarehouse?.ubicacionesContadas ??
                        0
                    );

                    const explicitMissing =
                        dashboardWarehouse?.pendientes ??
                        dashboardWarehouse?.pending ??
                        dashboardWarehouse?.ubicacionesPendientes;

                    missingBoxes = explicitMissing == null
                        ? Math.max(totalBoxes - countedBoxes, 0)
                        : Math.max(toNumber(explicitMissing), 0);
                }

                kTotalBoxes.textContent = formatNumber(totalBoxes);
                kMissingBoxes.textContent = formatNumber(missingBoxes);

                kTotalBoxes.closest(".kpi")?.setAttribute(
                    "title",
                    `${currentWarehouseName()}: ${formatNumber(totalBoxes)} cajas iniciales`
                );

                kMissingBoxes.closest(".kpi")?.setAttribute(
                    "title",
                    `${currentWarehouseName()}: ${formatNumber(missingBoxes)} cajas pendientes por escanear`
                );
            }

            function renderKpis() {
                renderWarehouseInventoryKpis();
                kQueue.textContent = String(queue.length);
                kOk.textContent = String(okCount);
                kBad.textContent = String(badCount);
                updateScanListCount();
                updateInventariarButtonState();
            }

            function getScanVisualClass(kind) {
                switch ((kind || "").toLowerCase()) {
                    case "pending":
                        return "scan-pending";
                    case "validating":
                        return "scan-validating";
                    case "ok":
                        return "scan-ok";
                    case "warn":
                        return "scan-warn";
                    case "dup":
                        return "scan-dup";
                    default:
                        return "scan-error";
                }
            }

            function getScanPill(kind) {
                switch ((kind || "").toLowerCase()) {
                    case "pending":
                        return `<span class="pill pill-warn">
                            <i class="fa-solid fa-magnifying-glass"></i> BUSCANDO
                        </span>`;
                    case "validating":
                        return `<span class="pill" style="background:#e7f1ff;color:#084298;border-color:#9ec5fe">
                            <i class="fa-solid fa-rotate fa-spin"></i> VALIDANDO
                        </span>`;
                    case "ok":
                        return `<span class="pill pill-ok">
                            <i class="fa-solid fa-circle-check"></i> OK
                        </span>`;
                    case "warn":
                        return `<span class="pill pill-warn">
                            <i class="fa-solid fa-triangle-exclamation"></i> REVISAR
                        </span>`;
                    case "dup":
                        return `<span class="pill pill-warn">DUP</span>`;
                    default:
                        return `<span class="pill pill-bad">ERR</span>`;
                }
            }

            function updateScanListCount() {
                if (!scanListCount) return;

                const count = lastList?.children?.length || 0;
                scanListCount.textContent =
                    `${count} ${count === 1 ? "registro" : "registros"}`;
            }

            function normalizeScanMetadata(metadata, li) {
                const source = metadata || {};

                const sku = (
                    source.sku ||
                    source.articulo ||
                    source.itemCode ||
                    li?.dataset?.scanSku ||
                    ""
                ).toString().trim();

                const producto = (
                    source.producto ||
                    source.nombreProducto ||
                    source.descripcion ||
                    source.product ||
                    li?.dataset?.scanProduct ||
                    ""
                ).toString().trim();

                const pesoRaw =
                    source.pesoNeto ??
                    source.pesoKg ??
                    source.peso ??
                    source.kg ??
                    li?.dataset?.scanWeight ??
                    "";

                const pesoNumero = Number(pesoRaw);
                const pesoNeto = Number.isFinite(pesoNumero) && pesoNumero > 0
                    ? pesoNumero
                    : 0;

                return { sku, producto, pesoNeto };
            }

            function renderScanVisual(li, code, label, kind, metadata = null) {
                if (!li.dataset.scanOrder) {
                    scanSequence += 1;
                    li.dataset.scanOrder = String(scanSequence);
                }

                if (!li.dataset.scanTime) {
                    li.dataset.scanTime = new Date().toLocaleTimeString("es-MX", {
                        hour: "2-digit",
                        minute: "2-digit",
                        second: "2-digit"
                    });
                }

                const meta = normalizeScanMetadata(metadata, li);

                li.dataset.scanSku = meta.sku;
                li.dataset.scanProduct = meta.producto;
                li.dataset.scanWeight = meta.pesoNeto > 0
                    ? String(meta.pesoNeto)
                    : "";

                const order = String(li.dataset.scanOrder).padStart(3, "0");
                const scanTime = li.dataset.scanTime;

                const metaChips = [
                    meta.sku
                        ? `<span class="scan-meta-chip"><i class="fa-solid fa-tag"></i> SKU ${esc(meta.sku)}</span>`
                        : "",
                    meta.pesoNeto > 0
                        ? `<span class="scan-meta-chip"><i class="fa-solid fa-weight-hanging"></i> ${esc(formatKg(meta.pesoNeto))} kg</span>`
                        : ""
                ].filter(Boolean).join("");

                const productHtml = meta.producto
                    ? `<div class="scan-product-name">${esc(meta.producto)}</div>`
                    : "";

                const metadataHtml = metaChips || productHtml
                    ? `${productHtml}<div class="scan-product-meta">${metaChips}</div>`
                    : "";

                li.className = `last-item ${getScanVisualClass(kind)}`;
                li.dataset.scanCode = normalize(code);
                li.dataset.scanLabel = label || "";
                li.dataset.scanKind = kind || "err";

                li.innerHTML = `
                    <div class="scan-order">#${esc(order)}</div>
                    <div class="scan-main">
                        <div class="code">
                            <i class="fa-solid fa-barcode me-1"></i>
                            ${esc(code)}
                        </div>
                        ${metadataHtml}
                        <div class="scan-detail">${esc(label || "")}</div>
                        <div class="scan-time">${esc(scanTime)}</div>
                    </div>
                    <div>${getScanPill(kind)}</div>`;

                updateScanListCount();

                if (li.isConnected) {
                    schedulePersistScanHistory();
                }
            }

            function pushLast(code, label, kind, metadata = null) {
                const li = document.createElement("li");
                renderScanVisual(li, code, label, kind, metadata);
                lastList.appendChild(li);

                /*
                 * No se recorta el listado. Todas las etiquetas de la sesión
                 * permanecen visibles y se respaldan en el navegador.
                 */
                updateScanListCount();
                schedulePersistScanHistory();

                requestAnimationFrame(() => {
                    lastList.scrollTop = lastList.scrollHeight;
                });

                return li;
            }

            function addPendingScanVisual(code) {
                const normalized = normalize(code);
                const li = pushLast(
                    normalized,
                    `Consultando ${currentWarehouseName()}…`,
                    "pending"
                );

                const rows = pendingScanVisuals.get(normalized) || [];
                rows.push(li);
                pendingScanVisuals.set(normalized, rows);
                return li;
            }

            function takePendingScanVisual(code) {
                const normalized = normalize(code);
                const rows = pendingScanVisuals.get(normalized) || [];

                while (rows.length > 0) {
                    const li = rows.shift();
                    if (li?.isConnected) {
                        if (rows.length > 0) {
                            pendingScanVisuals.set(normalized, rows);
                        } else {
                            pendingScanVisuals.delete(normalized);
                        }

                        return li;
                    }
                }

                pendingScanVisuals.delete(normalized);
                return null;
            }

            function updateScanVisual(code, label, kind, reusePending = true, metadata = null) {
                const li = reusePending
                    ? takePendingScanVisual(code)
                    : null;

                const row = li || pushLast(code, label, kind, metadata);

                if (li) {
                    renderScanVisual(row, code, label, kind, metadata);
                }

                if (kind === "ok" || kind === "warn" || kind === "err") {
                    flashScanInput(kind);
                }

                return row;
            }

            function updateExistingScanVisual(code, label, kind, metadata = null) {
                const normalized = normalize(code);

                const row = Array.from(lastList.children).find(item =>
                    normalize(item.dataset.scanCode || "") === normalized &&
                    (
                        item.dataset.scanKind === "validating" ||
                        item.dataset.scanKind === "pending"
                    )
                );

                if (row) {
                    renderScanVisual(row, normalized, label, kind, metadata);
                    flashScanInput(kind);
                    return row;
                }

                return updateScanVisual(normalized, label, kind, true, metadata);
            }

            function flashScanInput(kind) {
                if (!input) return;

                if (scanInputFlashTimer) {
                    clearTimeout(scanInputFlashTimer);
                }

                input.classList.remove(
                    "scan-flash-ok",
                    "scan-flash-warn",
                    "scan-flash-error"
                );

                const className =
                    kind === "ok"
                        ? "scan-flash-ok"
                        : kind === "warn"
                            ? "scan-flash-warn"
                            : "scan-flash-error";

                input.classList.add(className);

                scanInputFlashTimer = setTimeout(() => {
                    input.classList.remove(
                        "scan-flash-ok",
                        "scan-flash-warn",
                        "scan-flash-error"
                    );
                }, 650);
            }

            function showSending(on, info = "") {
                if (on) {
                    sendingInfo.textContent = info;
                    sendingBar.classList.remove("d-none");
                } else {
                    sendingBar.classList.add("d-none");
                }
            }

            function acceptMany(text) {
                const lines = (text || "")
                    .split(/\r?\n/)
                    .map(x => normalize(x))
                    .filter(Boolean);

                if (lines.length <= 1) {
                    acceptCode(text);
                    return;
                }

                lines.forEach(code => acceptCode(code, true));
                input.value = "";

                setStatus(
                    `Pegados ${lines.length} códigos. Cola: ${queue.length}`,
                    "muted"
                );

                scheduleFlush();
            }

            function acceptCode(code, fromPaste = false) {
                if (!activeSession || !currentWarehouseId()) {
                    setStatus(
                        "Inicia una sesión y selecciona el almacén activo.",
                        "bad"
                    );
                    return;
                }

                const normalized = normalize(code);
                if (!normalized) return;

                const now = Date.now();

                if (
                    !fromPaste &&
                    normalized === lastCode &&
                    (now - lastCodeAt) <= DEDUPE_WINDOW_MS
                ) {
                    badCount += 1;
                    pushLast(
                        normalized,
                        "Lectura repetida inmediatamente; se ignoró.",
                        "dup"
                    );
                    renderKpis();
                    flashScanInput("warn");
                    return;
                }

                lastCode = normalized;
                lastCodeAt = now;

                queue.push(normalized);
                addPendingScanVisual(normalized);
                renderKpis();

                if (!fromPaste) {
                    input.value = "";
                }

                setStatus(
                    `Buscando ${normalized} en ${currentWarehouseName()}…`,
                    "muted"
                );

                if (queue.length >= BATCH_SIZE) {
                    flush(true);
                } else {
                    scheduleFlush();
                }
            }

            function scheduleFlush() {
                if (flushTimer) {
                    clearTimeout(flushTimer);
                }

                flushTimer = setTimeout(async () => {
                    flushTimer = null;

                    // Se envía incluso si hay menos de 25 para que sea realmente automático.
                    await flush(true);
                }, FLUSH_MS);
            }

            async function postJson(url, payload) {
                const response = await fetch(url, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(payload)
                });

                const raw = await response.text();

                let data = null;
                try {
                    data = raw ? JSON.parse(raw) : null;
                } catch {
                    data = null;
                }

                if (!response.ok) {
                    const error = new Error(
                        `HTTP ${response.status}: ${
                            (data?.msg || data?.message || raw || "")
                                .substring(0, 240)
                        }`
                    );
                    error.responseData = data;
                    throw error;
                }

                return data;
            }

            async function getJson(url) {
                const response = await fetch(url, {
                    method: "GET",
                    headers: {
                        "Accept": "application/json"
                    },
                    cache: "no-store"
                });

                const raw = await response.text();

                let data = null;
                try {
                    data = raw ? JSON.parse(raw) : null;
                } catch {
                    data = null;
                }

                if (!response.ok) {
                    throw new Error(
                        `HTTP ${response.status}: ${
                            (data?.msg || data?.message || raw || "")
                                .substring(0, 240)
                        }`
                    );
                }

                return data;
            }

            async function flush(force) {
                if (busy) return false;
                if (queue.length === 0) return false;
                if (!force && queue.length < BATCH_SIZE) return false;

                if (!activeSession || !currentWarehouseId()) {
                    setStatus(
                        "Inicia una sesión y selecciona el almacén activo.",
                        "bad"
                    );
                    return;
                }

                busy = true;
                updateInventariarButtonState();

                try {
                    while (
                        queue.length > 0 &&
                        (force || queue.length >= BATCH_SIZE)
                    ) {
                        const take = Math.min(BATCH_SIZE, queue.length);
                        const batch = queue.splice(0, take);

                        renderKpis();
                        showSending(true, `${batch.length} etiqueta(s)`);

                        const batchWarehouseId = currentWarehouseId();
                        const batchWarehouseName = currentWarehouseName();

                        let scanData;

                        try {
                            scanData = await postJson(
                                "/Inventario/ScanBatch",
                                {
                                    almacen: batchWarehouseId,
                                    codigos: batch
                                }
                            );
                        } catch (error) {
                            // Se conserva el lote para reintentar sin perder lecturas.
                            queue = batch.concat(queue);
                            renderKpis();

                            batch.forEach(code => {
                                updateExistingScanVisual(
                                    code,
                                    "No se pudo consultar. Se volverá a intentar.",
                                    "err"
                                );
                            });

                            throw error;
                        }

                        const scanResults = Array.isArray(scanData?.results)
                            ? scanData.results
                            : [];

                        const successfulCodes = [];

                        for (const result of scanResults) {
                            const code = normalize(
                                result.codigoEtiqueta ||
                                result.codigo ||
                                result.code ||
                                ""
                            );

                            const kind = (
                                result.kind ||
                                (result.ok ? "ok" : "err")
                            ).toLowerCase();

                            const message = (result.msg || "").toString();

                            if (kind === "ok") {
                                okCount += 1;
                                successfulCodes.push(code);

                                updateExistingScanVisual(
                                    code,
                                    "Guardada. Validando contra la fotografía inicial…",
                                    "validating",
                                    {
                                        sku: result.sku || result.articulo || "",
                                        producto:
                                            result.producto ||
                                            result.descripcion ||
                                            result.nombreProducto ||
                                            "",
                                        pesoNeto:
                                            result.pesoNeto ??
                                            result.pesoKg ??
                                            result.peso ??
                                            0
                                    }
                                );
                            } else if (kind === "dup") {
                                badCount += 1;

                                updateExistingScanVisual(
                                    code,
                                    message || "La etiqueta ya estaba guardada.",
                                    "dup"
                                );
                            } else {
                                badCount += 1;

                                updateExistingScanVisual(
                                    code,
                                    message || "No se pudo guardar la etiqueta.",
                                    "err"
                                );
                            }
                        }

                        /*
                         * El endpoint optimizado realiza el match de todas las
                         * etiquetas del lote en una sola consulta a SIGO.
                         */
                        if (successfulCodes.length > 0) {
                            const trackingData =
                                await registerSuccessfulScans(
                                    successfulCodes,
                                    batchWarehouseId
                                );

                            const trackingResults = Array.isArray(
                                trackingData?.results
                            )
                                ? trackingData.results
                                : [];

                            if (trackingResults.length > 0) {
                                for (const result of trackingResults) {
                                    const code = normalize(
                                        result.codigoEtiqueta ||
                                        result.codigo ||
                                        result.code ||
                                        ""
                                    );

                                    const kind = (
                                        result.kind || "ok"
                                    ).toLowerCase();

                                    const message =
                                        (result.msg || "").toString();

                                    updateExistingScanVisual(
                                        code,
                                        message ||
                                            "Etiqueta registrada correctamente.",
                                        kind === "ok"
                                            ? "ok"
                                            : kind === "warn"
                                                ? "warn"
                                                : kind === "dup"
                                                    ? "dup"
                                                    : "err",
                                        {
                                            sku: result.sku || "",
                                            producto: result.producto || "",
                                            pesoNeto:
                                                result.pesoNeto ??
                                                result.pesoKg ??
                                                0
                                        }
                                    );
                                }
                            } else {
                                /*
                                 * ScanBatch sí guardó. Si la relación con la sesión
                                 * quedó pendiente, no se obliga al operador a esperar.
                                 */
                                successfulCodes.forEach(code => {
                                    updateExistingScanVisual(
                                        code,
                                        trackingData?.deferred
                                            ? "Guardada. El tablero se sincronizará automáticamente."
                                            : "Etiqueta guardada correctamente.",
                                        "ok"
                                    );
                                });
                            }
                        }

                        renderKpis();

                        setStatus(
                            `Último lote procesado en ${batchWarehouseName}.`,
                            "ok"
                        );

                        scheduleDashboardRefreshAfterScan();
                    }
                } catch (error) {
                    setStatus(
                        error?.message || "Error al guardar.",
                        "bad"
                    );
                } finally {
                    showSending(false);
                    busy = false;
                    updateInventariarButtonState();

                    if (queue.length > 0) {
                        scheduleFlush();
                    }

                    setTimeout(() => input.focus(), 25);
                }
            }

            function scheduleDashboardRefreshAfterScan() {
                if (!activeSession) {
                    return;
                }

                if (dashboardAfterScanTimer) {
                    clearTimeout(dashboardAfterScanTimer);
                }

                /*
                 * Se ejecuta en segundo plano. No bloquea el escáner ni obliga
                 * a que el modal de reportería esté abierto.
                 */
                dashboardAfterScanTimer = setTimeout(() => {
                    dashboardAfterScanTimer = null;

                    if (activeSession) {
                        loadRealtimeDashboard(true);
                    }
                }, DASHBOARD_AFTER_SCAN_MS);
            }

            /* ===================== TABLERO TIEMPO REAL ===================== */

            function showDashboardError(message) {
                dashboardError.textContent = message || "";
                dashboardError.classList.toggle("show", Boolean(message));
            }

            function normalizeDashboardData(data) {
                return {
                    fechaActualizacion:
                        data?.fechaActualizacion ||
                        data?.updatedAt ||
                        new Date().toISOString(),

                    totalEsperado:
                        toNumber(
                            data?.totalEsperado ??
                            data?.totalExpected
                        ),

                    totalContado:
                        toNumber(
                            data?.totalContado ??
                            data?.totalCounted
                        ),

                    totalPendiente:
                        toNumber(
                            data?.totalPendiente ??
                            data?.totalPending
                        ),

                    resumenAlmacenes:
                        data?.resumenAlmacenes ||
                        data?.warehouses ||
                        [],

                    antiguedad:
                        data?.antiguedad ||
                        data?.aging ||
                        [],

                    incidenciasResumen:
                        data?.incidenciasResumen ||
                        data?.incidentSummary ||
                        [],

                    incidencias:
                        data?.incidencias ||
                        data?.incidents ||
                        []
                };
            }

            async function loadRealtimeDashboard(silent = false) {
                if (dashboardBusy) return;
                if (!activeSession) return;

                dashboardBusy = true;

                if (!silent && btnRefreshDashboard) {
                    btnRefreshDashboard.disabled = true;
                    btnRefreshDashboard.innerHTML =
                        `<span class="spinner-border spinner-border-sm" aria-hidden="true"></span> Actualizando`;
                }

                try {
                    await retryPendingSessionRegistrations();

                    const url =
                        `${DASHBOARD_URL}?sesionId=${encodeURIComponent(activeSession.id)}` +
                        `&_=${Date.now()}`;

                    const data = await getJson(url);
                    dashboardData = normalizeDashboardData(data);

                    renderKpis();
                    renderWarehouseSummary(dashboardData.resumenAlmacenes);
                    renderAgingChart(dashboardData.antiguedad);
                    renderIncidentCounts(
                        dashboardData.incidenciasResumen,
                        dashboardData.incidencias
                    );
                    renderIncidents();
                    renderDifferencesChart(
                        dashboardData.incidenciasResumen,
                        dashboardData.incidencias
                    );

                    dashboardUpdated.textContent =
                        `Última actualización: ${
                            formatDateTime(dashboardData.fechaActualizacion)
                        }`;

                    showDashboardError("");
                } catch (error) {
                    showDashboardError(
                        `No se pudo actualizar el tablero en tiempo real. ${
                            error?.message || ""
                        }`
                    );
                } finally {
                    dashboardBusy = false;

                    if (btnRefreshDashboard) {
                        btnRefreshDashboard.disabled = false;
                        btnRefreshDashboard.innerHTML =
                            `<i class="fa-solid fa-rotate"></i> Actualizar`;
                    }
                }
            }

            function renderWarehouseSummary(rows) {
                const items = Array.isArray(rows) ? rows : [];

                if (items.length === 0) {
                    warehouseSummaryBody.innerHTML = `
                        <tr>
                            <td colspan="5" class="empty-state">
                                No hay información de almacenes.
                            </td>
                        </tr>`;
                    return;
                }

                warehouseSummaryBody.innerHTML = items.map(item => {
                    const rawWarehouse =
                        item.almacen ||
                        item.nombre ||
                        item.warehouse ||
                        "N/D";

                    const warehouse = warehouseDisplayName(
                        item.almacenId ||
                        item.id ||
                        item.warehouseId ||
                        "",
                        rawWarehouse
                    );

                    const locations = toNumber(
                        item.ubicaciones ??
                        item.locations ??
                        item.totalUbicaciones
                    );

                    const counted = toNumber(
                        item.contadas ??
                        item.counted ??
                        item.ubicacionesContadas
                    );

                    let pending = toNumber(
                        item.pendientes ??
                        item.pending ??
                        item.ubicacionesPendientes
                    );

                    if (
                        item.pendientes == null &&
                        item.pending == null &&
                        item.ubicacionesPendientes == null
                    ) {
                        pending = Math.max(locations - counted, 0);
                    }

                    let progress = toNumber(
                        item.avance ??
                        item.progress ??
                        item.porcentaje
                    );

                    if (
                        item.avance == null &&
                        item.progress == null &&
                        item.porcentaje == null
                    ) {
                        progress = locations > 0
                            ? (counted / locations) * 100
                            : 0;
                    }

                    progress = clamp(progress, 0, 100);

                    const expectedKg = toNumber(
                        item.kgEsperados ??
                        item.expectedKg ??
                        item.kgInicial
                    );

                    return `
                        <tr>
                            <td>
                                <div class="warehouse-name">
                                    ${esc(warehouse)}
                                </div>
                                <div class="small text-muted">
                                    ${formatNumber(expectedKg)} kg iniciales
                                </div>
                            </td>
                            <td class="num">${formatNumber(locations)}</td>
                            <td class="num">${formatNumber(counted)}</td>
                            <td class="num">${formatNumber(pending)}</td>
                            <td>
                                <div class="progress-shell">
                                    <div class="progress">
                                        <div class="progress-bar progress-bar-red"
                                             role="progressbar"
                                             style="width:${progress.toFixed(1)}%"
                                             aria-valuenow="${progress.toFixed(1)}"
                                             aria-valuemin="0"
                                             aria-valuemax="100">
                                        </div>
                                    </div>
                                    <div class="progress-label">
                                        <span>${progress.toFixed(0)}%</span>
                                        <span class="text-muted">
                                            ${formatNumber(counted)} / ${formatNumber(locations)}
                                        </span>
                                    </div>
                                </div>
                            </td>
                        </tr>`;
                }).join("");
            }

            function mapAgingValues(rows) {
                const base = [
                    { key: "0-15", label: "0-15 días", value: 0 },
                    { key: "16-30", label: "16-30 días", value: 0 },
                    { key: "31-60", label: "31-60 días", value: 0 },
                    { key: "61-90", label: "61-90 días", value: 0 },
                    { key: "90+", label: "Más de 90 días", value: 0 }
                ];

                const items = Array.isArray(rows) ? rows : [];

                for (const item of items) {
                    const rawLabel = (
                        item.rango ||
                        item.range ||
                        item.nombre ||
                        ""
                    ).toString().toLowerCase();

                    const value = toNumber(
                        item.cantidad ??
                        item.qty ??
                        item.total ??
                        item.value
                    );

                    if (
                        rawLabel.includes("0-15") ||
                        rawLabel.includes("0 a 15")
                    ) {
                        base[0].value += value;
                    } else if (
                        rawLabel.includes("16-30") ||
                        rawLabel.includes("16 a 30")
                    ) {
                        base[1].value += value;
                    } else if (
                        rawLabel.includes("31-60") ||
                        rawLabel.includes("31 a 60")
                    ) {
                        base[2].value += value;
                    } else if (
                        rawLabel.includes("61-90") ||
                        rawLabel.includes("61 a 90")
                    ) {
                        base[3].value += value;
                    } else if (
                        rawLabel.includes("más de 90") ||
                        rawLabel.includes("mas de 90") ||
                        rawLabel.includes(">90") ||
                        rawLabel.includes("90+")
                    ) {
                        base[4].value += value;
                    }
                }

                return base;
            }

            function renderAgingChart(rows) {
                const items = mapAgingValues(rows);

                const canvas = document.getElementById("agingChart");
                if (!canvas || !window.Chart) return;

                if (agingChart) {
                    agingChart.destroy();
                    agingChart = null;
                }

                agingChart = new Chart(canvas, {
                    type: "bar",
                    data: {
                        labels: items.map(x => x.label),
                        datasets: [{
                            label: "Etiquetas",
                            data: items.map(x => x.value),
                            backgroundColor: [
                                "rgba(139, 0, 0, .38)",
                                "rgba(139, 0, 0, .52)",
                                "rgba(139, 0, 0, .66)",
                                "rgba(139, 0, 0, .78)",
                                "rgba(139, 0, 0, .92)"
                            ],
                            borderColor: [
                                "rgba(139, 0, 0, .55)",
                                "rgba(139, 0, 0, .65)",
                                "rgba(139, 0, 0, .75)",
                                "rgba(139, 0, 0, .88)",
                                "rgba(139, 0, 0, 1)"
                            ],
                            borderWidth: 1,
                            borderRadius: 8,
                            maxBarThickness: 46
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: {
                            mode: "index",
                            intersect: false
                        },
                        plugins: {
                            legend: {
                                display: false
                            },
                            tooltip: {
                                callbacks: {
                                    label: context =>
                                        ` ${formatNumber(context.raw)} etiqueta(s)`
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: {
                                    display: false
                                },
                                ticks: {
                                    font: {
                                        weight: "700"
                                    }
                                }
                            },
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    precision: 0
                                }
                            }
                        }
                    }
                });
            }

            function buildIncidentCountMap(summaryRows, incidentRows) {
                const map = new Map(
                    INCIDENT_TYPES.map(type => [type, 0])
                );

                const summary = Array.isArray(summaryRows)
                    ? summaryRows
                    : [];

                if (summary.length > 0) {
                    for (const item of summary) {
                        const type = (
                            item.tipo ||
                            item.type ||
                            item.nombre ||
                            ""
                        ).toString().trim();

                        const quantity = toNumber(
                            item.cantidad ??
                            item.qty ??
                            item.total ??
                            item.value
                        );

                        if (!type) continue;
                        map.set(type, (map.get(type) || 0) + quantity);
                    }
                } else {
                    const incidents = Array.isArray(incidentRows)
                        ? incidentRows
                        : [];

                    for (const item of incidents) {
                        const type = (
                            item.tipo ||
                            item.type ||
                            "Sin tipo"
                        ).toString().trim();

                        map.set(type, (map.get(type) || 0) + 1);
                    }
                }

                return map;
            }

            function renderIncidentCounts(summaryRows, incidentRows) {
                const countMap = buildIncidentCountMap(
                    summaryRows,
                    incidentRows
                );

                const total = Array.from(countMap.values())
                    .reduce((sum, value) => sum + value, 0);

                incidentTotalPill.textContent =
                    `${formatNumber(total)} incidencia${total === 1 ? "" : "s"}`;

                document.querySelectorAll("[data-count-for]")
                    .forEach(element => {
                        const type = element.getAttribute("data-count-for");

                        if (type === "ALL") {
                            element.textContent = formatNumber(total);
                        } else {
                            element.textContent = formatNumber(
                                countMap.get(type) || 0
                            );
                        }
                    });
            }

            function incidentTypeOf(item) {
                return (
                    item?.tipo ||
                    item?.type ||
                    "Sin tipo"
                ).toString().trim();
            }

            function renderIncidents() {
                const allIncidents = Array.isArray(dashboardData.incidencias)
                    ? dashboardData.incidencias
                    : [];

                const filtered = selectedIncidentType === "ALL"
                    ? allIncidents
                    : allIncidents.filter(
                        item => incidentTypeOf(item) === selectedIncidentType
                    );

                incidentFilterLabel.textContent =
                    selectedIncidentType === "ALL"
                        ? `Mostrando todas (${formatNumber(filtered.length)})`
                        : `${selectedIncidentType} (${formatNumber(filtered.length)})`;

                if (filtered.length === 0) {
                    incidentsBody.innerHTML = `
                        <tr>
                            <td colspan="6" class="empty-state">
                                No hay incidencias para este filtro.
                            </td>
                        </tr>`;
                    return;
                }

                incidentsBody.innerHTML = filtered.map(item => {
                    const type = incidentTypeOf(item);

                    const code =
                        item.codigoEtiqueta ||
                        item.codigo ||
                        item.code ||
                        "Sin etiqueta";

                    const product =
                        item.producto ||
                        item.descripcion ||
                        item.product ||
                        "";

                    const weightKg = toNumber(
                        item.pesoKg ??
                        item.pesoNeto ??
                        item.peso ??
                        item.kg
                    );

                    const rawWarehouse =
                        item.almacen ||
                        item.warehouse ||
                        "N/D";

                    const warehouse = warehouseDisplayName(
                        item.almacenId ||
                        item.warehouseId ||
                        "",
                        rawWarehouse
                    );

                    const location =
                        item.ubicacion ||
                        item.location ||
                        "N/D";

                    const comment =
                        item.comentario ||
                        item.comment ||
                        "Sin comentario";

                    const photoUrl =
                        item.fotoUrl ||
                        item.photoUrl ||
                        item.imagenUrl ||
                        "";

                    const date =
                        item.fecha ||
                        item.createdAt ||
                        item.fechaRegistro ||
                        "";

                    const photoHtml = photoUrl
                        ? `
                            <img class="incident-photo"
                                 src="${esc(photoUrl)}"
                                 alt="Fotografía"
                                 data-photo-url="${esc(photoUrl)}"
                                 onerror="this.outerHTML='<span class=&quot;photo-empty&quot; title=&quot;Imagen no disponible&quot;><i class=&quot;fa-solid fa-image&quot;></i></span>'" />`
                        : `
                            <span class="photo-empty"
                                  title="Sin fotografía">
                                <i class="fa-solid fa-image"></i>
                            </span>`;

                    return `
                        <tr>
                            <td>${photoHtml}</td>
                            <td>
                                <div class="incident-type">${esc(type)}</div>
                            </td>
                            <td>
                                <div class="code">${esc(code)}</div>
                                <div class="small text-muted">${esc(product)}</div>
                                ${weightKg > 0
                                    ? `<div class="small fw-bold text-success">${esc(formatKg(weightKg))} kg</div>`
                                    : ""}
                            </td>
                            <td>
                                <div class="fw-bold">${esc(warehouse)}</div>
                                <div class="small text-muted">${esc(location)}</div>
                            </td>
                            <td>
                                <div class="incident-comment">${esc(comment)}</div>
                            </td>
                            <td class="small text-muted">
                                ${formatDateTime(date)}
                            </td>
                        </tr>`;
                }).join("");
            }

            function renderDifferencesChart(summaryRows, incidentRows) {
                const countMap = buildIncidentCountMap(
                    summaryRows,
                    incidentRows
                );

                const rows = Array.from(countMap.entries())
                    .map(([type, quantity]) => ({
                        type,
                        quantity
                    }))
                    .filter(item => item.quantity > 0)
                    .sort((a, b) => b.quantity - a.quantity);

                // Si no hay datos, conserva las siete causas en cero.
                const chartRows = rows.length > 0
                    ? rows
                    : INCIDENT_TYPES.map(type => ({
                        type,
                        quantity: 0
                    }));

                const canvas = document.getElementById("differencesChart");
                if (!canvas || !window.Chart) return;

                if (differencesChart) {
                    differencesChart.destroy();
                    differencesChart = null;
                }

                differencesChart = new Chart(canvas, {
                    type: "bar",
                    data: {
                        labels: chartRows.map(item => item.type),
                        datasets: [{
                            label: "Incidencias",
                            data: chartRows.map(item => item.quantity),
                            backgroundColor: "rgba(139, 0, 0, .78)",
                            borderColor: "rgba(139, 0, 0, 1)",
                            borderWidth: 1,
                            borderRadius: 7,
                            maxBarThickness: 28
                        }]
                    },
                    options: {
                        indexAxis: "y",
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            },
                            tooltip: {
                                callbacks: {
                                    label: context =>
                                        ` ${formatNumber(context.raw)} incidencia(s)`
                                }
                            }
                        },
                        scales: {
                            x: {
                                beginAtZero: true,
                                ticks: {
                                    precision: 0
                                }
                            },
                            y: {
                                grid: {
                                    display: false
                                },
                                ticks: {
                                    autoSkip: false,
                                    font: {
                                        size: 11,
                                        weight: "700"
                                    }
                                }
                            }
                        }
                    }
                });
            }

            function startDashboardTimer() {
                if (dashboardTimer) {
                    clearInterval(dashboardTimer);
                }

                dashboardTimer = setInterval(() => {
                    if (
                        document.visibilityState === "visible" &&
                        activeSession &&
                        !reportModal.classList.contains("show") &&
                        !photoModal.classList.contains("show") &&
                        !incidentFormModal.classList.contains("show") &&
                        !inventoryConfirmModal.classList.contains("show")
                    ) {
                        loadRealtimeDashboard(true);
                    }
                }, DASHBOARD_REFRESH_MS);
            }

            function resizeDashboardCharts() {
                setTimeout(() => {
                    agingChart?.resize();
                    differencesChart?.resize();
                }, 80);
            }

            async function showDashboardModal() {
                dashboardModal.classList.add("show");
                dashboardModal.setAttribute("aria-hidden", "false");
                syncInventoryModalBodyLock();

                await loadRealtimeDashboard(false);
                resizeDashboardCharts();
            }

            function hideDashboardModal() {
                dashboardModal.classList.remove("show");
                dashboardModal.setAttribute("aria-hidden", "true");
                syncInventoryModalBodyLock();

                if (activeSession && !input.disabled) {
                    setTimeout(() => input.focus(), 80);
                }
            }

            /* ===================== REPORTE HISTÓRICO ===================== */

            function showReportError(message) {
                reportError.textContent = message || "";
                reportError.classList.toggle(
                    "d-none",
                    !message
                );
            }

            function reportStatusClass(value) {
                const normalized = normalize(value);

                if (
                    normalized === "CORRECTO" ||
                    normalized === "CERRADO"
                ) {
                    return "ok";
                }

                if (
                    normalized === "SOBRANTE" ||
                    normalized === "MEZCLADO" ||
                    normalized === "ABIERTO"
                ) {
                    return "warn";
                }

                return "bad";
            }

            function renderReportWarehouseSummary(rows) {
                const data = Array.isArray(rows) ? rows : [];
                rWarehouseCount.textContent =
                    `${formatNumber(data.length)} almacenes`;

                if (!data.length) {
                    rWarehouseRows.innerHTML = `
                        <tr>
                            <td colspan="8" class="report-empty">
                                No hay almacenes con sesiones en el rango.
                            </td>
                        </tr>`;
                    return;
                }

                rWarehouseRows.innerHTML = data.map(item => {
                    const incidents =
                        toNumber(item.sobrantes) +
                        toNumber(item.mezcladas) +
                        toNumber(item.incidenciasManuales);

                    return `
                        <tr>
                            <td data-label="Almacén">
                                <b>${esc(
                                    item.almacenMostrar ||
                                    item.almacen ||
                                    item.almacenId
                                )}</b>
                                <div class="r-muted">
                                    ${esc(item.planta || "")}
                                    ${item.sucursal
                                        ? ` · ${esc(item.sucursal)}`
                                        : ""}
                                </div>
                            </td>
                            <td data-label="Sesiones" class="num">
                                ${formatNumber(item.sesiones)}
                            </td>
                            <td data-label="Inicial" class="num">
                                ${formatNumber(item.cajasIniciales)}
                            </td>
                            <td data-label="Kg iniciales" class="num">
                                ${formatKg(item.kgIniciales)}
                            </td>
                            <td data-label="Contadas" class="num">
                                ${formatNumber(item.contadas)}
                            </td>
                            <td data-label="Pendientes" class="num">
                                <b class="text-danger">
                                    ${formatNumber(item.pendientes)}
                                </b>
                            </td>
                            <td data-label="Avance" class="num">
                                ${toNumber(item.avance).toFixed(2)}%
                            </td>
