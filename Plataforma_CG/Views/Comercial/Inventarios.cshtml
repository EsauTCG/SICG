@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Inventario Carnes G";
}

@section Styles {
    <style>
        :root {
            --brand: #8b0000;
            --brand-dark: #4b0000;
            --brand-soft: #fff3f3;
            --ok: #198754;
            --warn: #d39e00;
            --bad: #dc3545;
            --info: #0d6efd;
            --ink: #20252b;
            --muted: #6c757d;
            --line: #e6e8eb;
            --panel: #ffffff;
            --page: #f3f5f7;
            --shadow: 0 10px 28px rgba(20, 24, 31, .09);
        }

        html, body {
            min-height: 100%;
            overflow-x: hidden;
        }

        body {
            background: var(--page);
        }

        .handheld-page {
            width: min(100%, 760px);
            min-height: calc(100vh - 20px);
            margin: 0 auto;
            padding: 10px;
        }

        .handheld-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding: 13px 14px;
            color: #fff;
            background: linear-gradient(110deg, var(--brand), #650000 58%, var(--brand-dark));
            border-radius: 16px;
            box-shadow: 0 13px 28px rgba(92, 0, 0, .20);
            margin-bottom: 10px;
        }

        .handheld-title {
            min-width: 0;
        }

            .handheld-title h4 {
                margin: 0;
                font-weight: 950;
                font-size: 1rem;
                line-height: 1.15;
            }

            .handheld-title small {
                display: block;
                margin-top: 3px;
                opacity: .88;
                font-size: .73rem;
            }

        .live-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            flex: 0 0 auto;
            padding: .34rem .58rem;
            border: 1px solid rgba(255,255,255,.25);
            border-radius: 999px;
            background: rgba(255,255,255,.13);
            font-size: .72rem;
            font-weight: 900;
            white-space: nowrap;
        }

        .live-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #6ee7b7;
            box-shadow: 0 0 0 4px rgba(110,231,183,.16);
        }

        .panel {
            background: var(--panel);
            border: 1px solid var(--line);
            border-radius: 15px;
            box-shadow: var(--shadow);
        }

        .session-panel {
            padding: 12px;
            margin-bottom: 10px;
        }

        .setup-title {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--ink);
            font-weight: 950;
            font-size: .91rem;
        }

            .setup-title i {
                color: var(--brand);
            }

        .setup-subtitle {
            color: var(--muted);
            font-size: .74rem;
            margin-top: 3px;
        }

        .session-grid {
            display: grid;
            grid-template-columns: minmax(0,1fr) 170px;
            gap: 10px;
            align-items: end;
        }

        .session-active-box {
            display: grid;
            grid-template-columns: minmax(0,1fr) minmax(210px,.72fr);
            gap: 10px;
            align-items: end;
        }

        .session-folio {
            color: var(--brand);
            font-size: .91rem;
            font-weight: 950;
            overflow-wrap: anywhere;
        }

        .session-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            margin-top: 6px;
        }

        .session-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: .20rem .48rem;
            border: 1px solid rgba(139,0,0,.15);
            border-radius: 999px;
            background: rgba(139,0,0,.06);
            color: #650000;
            font-size: .67rem;
            font-weight: 900;
        }

        .session-warning {
            display: none;
            margin-top: 9px;
            padding: 8px 10px;
            border: 1px solid rgba(220,53,69,.20);
            border-radius: 10px;
            background: rgba(220,53,69,.07);
            color: #842029;
            font-size: .78rem;
            font-weight: 800;
        }

            .session-warning.show {
                display: block;
            }

        .warehouse-multiselect {
            position: relative;
            width: 100%;
            margin-top: 8px;
        }

        .warehouse-select-trigger {
            width: 100%;
            min-height: 43px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding: 8px 11px;
            border: 1px solid #dac5c5;
            border-radius: 10px;
            background: #fff;
            color: #222;
            cursor: pointer;
            text-align: left;
            font-weight: 850;
        }

            .warehouse-select-trigger:hover,
            .warehouse-multiselect.open .warehouse-select-trigger {
                border-color: var(--brand);
                box-shadow: 0 0 0 3px rgba(139,0,0,.08);
            }

            .warehouse-select-trigger:disabled {
                cursor: not-allowed;
                opacity: .6;
                background: #f6f6f6;
            }

        .warehouse-select-text {
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .warehouse-select-chevron {
            color: var(--brand);
            transition: transform .18s ease;
        }

        .warehouse-multiselect.open .warehouse-select-chevron {
            transform: rotate(180deg);
        }

        .warehouse-select-menu {
            position: absolute;
            top: calc(100% + 5px);
            left: 0;
            right: 0;
            z-index: 3600;
            display: none;
            overflow: hidden;
            border: 1px solid #dbc7c7;
            border-radius: 12px;
            background: #fff;
            box-shadow: 0 20px 44px rgba(35,10,10,.20);
        }

        .warehouse-multiselect.open .warehouse-select-menu {
            display: block;
        }

        .warehouse-search-wrap {
            position: relative;
            padding: 10px 10px 7px;
        }

            .warehouse-search-wrap i {
                position: absolute;
                left: 22px;
                top: 50%;
                transform: translateY(-34%);
                color: #8b9096;
            }

        .warehouse-search-input {
            min-height: 39px;
            padding-left: 35px;
            border-radius: 9px;
        }

        .warehouse-select-all {
            display: flex;
            align-items: center;
            gap: 9px;
            margin: 0 10px;
            padding: 8px 4px;
            border-top: 1px solid #f0e4e4;
            border-bottom: 1px solid #f0e4e4;
            cursor: pointer;
            font-size: .82rem;
            font-weight: 950;
        }

            .warehouse-select-all input,
            .warehouse-option input {
                width: 17px;
                height: 17px;
                accent-color: var(--brand);
            }

        .warehouse-options {
            max-height: 260px;
            overflow-y: auto;
            padding: 3px 0;
        }

        .warehouse-option {
            display: flex;
            align-items: flex-start;
            gap: 9px;
            padding: 9px 13px;
            border-bottom: 1px solid #f3e9e9;
            cursor: pointer;
            font-size: .81rem;
            font-weight: 800;
        }

            .warehouse-option:hover,
            .warehouse-option.selected {
                background: #fff4f4;
                color: #650000;
            }

        .warehouse-option-id {
            color: #8b9096;
            font-size: .69rem;
            margin-top: 2px;
        }

        .warehouse-option-main {
            display: flex;
            align-items: center;
            gap: 7px;
            min-width: 0;
        }

        .warehouse-option-name {
            min-width: 0;
            font-weight: 900;
            line-height: 1.2;
            overflow-wrap: anywhere;
        }

        .warehouse-plant-badge {
            display: inline-flex;
            flex: 0 0 auto;
            align-items: center;
            justify-content: center;
            min-width: 38px;
            min-height: 23px;
            padding: 3px 7px;
            border-radius: 999px;
            font-size: .65rem;
            font-weight: 950;
            letter-spacing: .02em;
        }

            .warehouse-plant-badge.p1 {
                border: 1px solid #9ec5fe;
                background: #eaf3ff;
                color: #084298;
            }

            .warehouse-plant-badge.tif {
                border: 1px solid #a3cfbb;
                background: #e8f7ef;
                color: #0f5132;
            }

            .warehouse-plant-badge.inferred {
                border-color: #ffda6a;
                background: #fff3cd;
                color: #664d03;
            }

        .warehouse-branch-line {
            margin-top: 3px;
            color: #626970;
            font-size: .69rem;
            font-weight: 750;
        }

        .warehouse-config-warning {
            color: #9a6900;
            font-weight: 850;
        }

        .warehouse-selection-hint {
            padding: 8px 10px;
            border-top: 1px solid #f0e4e4;
            background: #fffafa;
            color: #6b5a5a;
            font-size: .70rem;
            font-weight: 850;
        }

        .warehouse-empty-result {
            padding: 20px 12px;
            text-align: center;
            color: var(--muted);
            font-size: .79rem;
        }

        .scan-shell {
            overflow: hidden;
        }

        .scan-head {
            padding: 13px;
            border-bottom: 1px solid var(--line);
        }

        .scan-title-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 10px;
        }

        .scan-title {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--ink);
            font-size: .93rem;
            font-weight: 950;
        }

            .scan-title i {
                color: var(--brand);
            }

        .real-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: .20rem .48rem;
            border-radius: 999px;
            background: rgba(25,135,84,.11);
            color: var(--ok);
            font-size: .67rem;
            font-weight: 950;
        }

        .scan-input {
            min-height: 58px;
            padding: .80rem .90rem;
            border: 2px solid #dccaca;
            border-radius: 13px;
            font-size: 1.10rem;
            font-weight: 950;
            letter-spacing: .35px;
            text-transform: uppercase;
        }

            .scan-input:focus {
                border-color: var(--brand);
                box-shadow: 0 0 0 .22rem rgba(139,0,0,.10);
            }

            .scan-input.scan-flash-ok {
                background: #e8f7ef !important;
                border-color: var(--ok) !important;
                box-shadow: 0 0 0 .24rem rgba(25,135,84,.16) !important;
            }

            .scan-input.scan-flash-warn {
                background: #fff8e1 !important;
                border-color: var(--warn) !important;
                box-shadow: 0 0 0 .24rem rgba(255,193,7,.17) !important;
            }

            .scan-input.scan-flash-error {
                background: #fff0f1 !important;
                border-color: var(--bad) !important;
                box-shadow: 0 0 0 .24rem rgba(220,53,69,.14) !important;
            }

        .scan-status {
            min-height: 20px;
            margin-top: 7px;
            font-size: .76rem;
            font-weight: 780;
        }

        .kpis {
            display: grid;
            grid-template-columns: repeat(5,minmax(0,1fr));
            gap: 7px;
            padding: 9px 13px;
            border-top: 1px solid #f3f3f3;
            border-bottom: 1px solid var(--line);
            background: #fafafa;
        }

        .kpi {
            min-width: 0;
            padding: 7px 8px;
            border: 1px solid #ececec;
            border-radius: 10px;
            background: #fff;
            text-align: center;
        }

            .kpi .lbl {
                display: block;
                color: var(--muted);
                font-size: .61rem;
                font-weight: 900;
                text-transform: uppercase;
                line-height: 1.1;
            }

            .kpi .val {
                display: block;
                margin-top: 2px;
                color: var(--ink);
                font-size: 1.02rem;
                font-weight: 950;
                line-height: 1;
            }

        .kpi-total {
            border-color: rgba(13,110,253,.22);
            background: #f4f8ff;
        }

            .kpi-total .val {
                color: #0b5ed7;
            }

        .kpi-pending {
            border-color: rgba(220,53,69,.22);
            background: #fff7f8;
        }

            .kpi-pending .val {
                color: #c82333;
            }

        @@media (max-width: 760px) {
            .kpis {
                grid-template-columns: repeat(3,minmax(0,1fr));
            }
        }

        @@media (max-width: 430px) {
            .kpis {
                grid-template-columns: repeat(2,minmax(0,1fr));
                padding-left: 8px;
                padding-right: 8px;
            }

                .kpis .kpi-total {
                    grid-column: span 2;
                }

            .kpi {
                min-height: 52px;
                display: flex;
                flex-direction: column;
                justify-content: center;
            }
        }

        .scan-list-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding: 10px 13px 7px;
        }

            .scan-list-head strong {
                font-size: .84rem;
                color: var(--ink);
            }

        .scan-list-count {
            padding: .18rem .46rem;
            border-radius: 999px;
            background: #f0f1f2;
            color: #4d5359;
            font-size: .68rem;
            font-weight: 900;
        }

        .last-list {
            list-style: none;
            min-height: 310px;
            height: calc(100vh - 435px);
            max-height: 720px;
            overflow-y: auto;
            margin: 0;
            padding: 2px 10px 82px;
            scroll-behavior: smooth;
        }

        .last-item {
            display: grid;
            grid-template-columns: 42px minmax(0,1fr) auto;
            align-items: center;
            gap: 9px;
            margin: 6px 0;
            padding: 10px;
            border: 1px solid #eceff1;
            border-radius: 12px;
            background: #fff;
            font-size: .82rem;
            transition: .18s ease;
        }

        .scan-order {
            display: flex;
            align-items: center;
            justify-content: center;
            min-width: 36px;
            height: 36px;
            border-radius: 10px;
            background: #f1f2f3;
            color: #555d65;
            font-size: .72rem;
            font-weight: 950;
            font-variant-numeric: tabular-nums;
        }

        .scan-main {
            min-width: 0;
        }

        .code {
            color: #24282d;
            font-size: .90rem;
            font-weight: 950;
            overflow-wrap: anywhere;
        }

        .scan-detail {
            margin-top: 2px;
            color: inherit;
            opacity: .78;
            font-size: .70rem;
            line-height: 1.25;
        }

        .scan-time {
            margin-top: 2px;
            color: inherit;
            opacity: .62;
            font-size: .64rem;
            font-weight: 800;
        }

        .scan-product-meta {
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
            margin-top: 7px;
        }

        .scan-meta-chip {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            max-width: 100%;
            padding: .18rem .48rem;
            border-radius: 999px;
            background: rgba(255,255,255,.56);
            border: 1px solid rgba(0,0,0,.08);
            color: inherit;
            font-size: .74rem;
            font-weight: 900;
            line-height: 1.2;
        }

        .scan-product-name {
            margin-top: 5px;
            font-size: .82rem;
            font-weight: 900;
            color: inherit;
            line-height: 1.25;
            word-break: break-word;
        }

        .pill {
            display: inline-block;
            padding: .19rem .46rem;
            border: 1px solid transparent;
            border-radius: 999px;
            font-size: .64rem;
            font-weight: 950;
            white-space: nowrap;
        }

        .pill-ok {
            color: var(--ok);
            background: rgba(25,135,84,.11);
            border-color: rgba(25,135,84,.18);
        }

        .pill-warn {
            color: #664d03;
            background: rgba(255,193,7,.19);
            border-color: rgba(255,193,7,.34);
        }

        .pill-bad {
            color: var(--bad);
            background: rgba(220,53,69,.11);
            border-color: rgba(220,53,69,.18);
        }

        .last-item.scan-pending {
            background: #fff8e1;
            border-color: #ffe08a;
            color: #664d03;
        }

        .last-item.scan-validating {
            background: #eaf3ff;
            border-color: #9ec5fe;
            color: #084298;
        }

        .last-item.scan-ok {
            background: #d1e7dd;
            border-color: #75b798;
            color: #0f5132;
            box-shadow: 0 7px 18px rgba(25,135,84,.14);
            animation: scanOkPulse .45s ease;
        }

            .last-item.scan-ok .scan-order {
                background: rgba(25,135,84,.15);
                color: #0f5132;
            }

            .last-item.scan-ok .code {
                color: #0a5c35;
            }

        .last-item.scan-warn,
        .last-item.scan-dup {
            background: #fff3cd;
            border-color: #ffda6a;
            color: #664d03;
        }

        .last-item.scan-error {
            background: #f8d7da;
            border-color: #ea868f;
            color: #842029;
        }

        @@keyframes scanOkPulse {
            0% {
                transform: scale(.985);
            }

            55% {
                transform: scale(1.008);
            }

            100% {
                transform: scale(1);
            }
        }

        .bottom-actions {
            position: sticky;
            bottom: 8px;
            z-index: 100;
            display: grid;
            grid-template-columns: repeat(4,minmax(0,1fr));
            gap: 7px;
            width: calc(100% - 20px);
            margin: -70px auto 10px;
            padding: 8px;
            border: 1px solid rgba(220,224,228,.96);
            border-radius: 15px;
            background: rgba(255,255,255,.95);
            box-shadow: 0 12px 30px rgba(20,24,31,.16);
            backdrop-filter: blur(12px);
        }

        .action-btn {
            min-height: 48px;
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 3px;
            padding: 5px;
            border: 1px solid #dde1e5;
            border-radius: 11px;
            background: #fff;
            color: #333940;
            font-size: .64rem;
            font-weight: 950;
        }

            .action-btn i {
                font-size: .97rem;
            }

            .action-btn.primary {
                color: #fff;
                border-color: var(--brand);
                background: linear-gradient(180deg,#a00000,var(--brand-dark));
            }

            .action-btn.warning {
                color: #7a5400;
                border-color: #f0cb5d;
                background: #fff8dc;
            }

            .action-btn.inventory-action {
                color: #0f5132;
                border-color: rgba(25,135,84,.32);
                background: #eef9f3;
            }

                .action-btn.inventory-action.has-pending {
                    color: #fff;
                    border-color: var(--ok);
                    background: linear-gradient(180deg,#23955e,#146c43);
                    box-shadow: 0 7px 17px rgba(25,135,84,.20);
                }

                .action-btn.inventory-action.inventory-busy {
                    color: #084298;
                    border-color: #9ec5fe;
                    background: #eaf3ff;
                }

            .action-btn.danger {
                color: var(--bad);
                border-color: rgba(220,53,69,.25);
                background: #fff5f6;
            }

            .action-btn:disabled {
                opacity: .48;
                cursor: not-allowed;
            }

        .scanner-disabled {
            /*
                             * El lector y las acciones de inventario se deshabilitan de forma
                             * individual. No se bloquea el contenedor completo porque Reportes
                             * debe seguir disponible sin una sesión activa.
                             */
            opacity: 1;
            pointer-events: auto;
            filter: none;
        }

            .scanner-disabled .scanner-head,
            .scanner-disabled .scan-input,
            .scanner-disabled .status-msg,
            .scanner-disabled .kpi-row,
            .scanner-disabled .scan-list-head,
            .scanner-disabled .last-list {
                opacity: .58;
                filter: grayscale(.12);
            }

        .sending {
            position: fixed;
            left: 12px;
            right: 12px;
            bottom: 12px;
            z-index: 6200;
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 10px 12px;
            border-radius: 13px;
            background: rgba(0,0,0,.80);
            color: #fff;
        }

            .sending .spinner-border {
                width: 1.15rem;
                height: 1.15rem;
                border-width: .18rem;
            }

        /* ===================== MODAL GENERAL ===================== */
        .control-modal,
        .report-modal,
        .incident-form-modal,
        .photo-modal {
            position: fixed;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 12px;
            background: rgba(0,0,0,.55);
        }

            .control-modal.show,
            .report-modal.show,
            .incident-form-modal.show,
            .photo-modal.show {
                display: flex;
            }

        .control-modal {
            z-index: 4000;
        }

        .report-modal {
            z-index: 4600;
        }

        .incident-form-modal {
            z-index: 5000;
        }

        .photo-modal {
            z-index: 5600;
            background: rgba(0,0,0,.80);
        }

        .control-shell,
        .report-shell,
        .incident-form-shell {
            width: min(1180px,100%);
            max-height: 94vh;
            overflow: auto;
            border-radius: 16px;
            background: #f5f7f9;
            box-shadow: 0 28px 70px rgba(0,0,0,.34);
        }

        .control-header,
        .report-actions,
        .incident-form-header {
            position: sticky;
            top: 0;
            z-index: 20;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            padding: 10px 12px;
            border-bottom: 1px solid #e2e5e8;
            background: #fff;
        }

        .control-header-title {
            min-width: 0;
        }

            .control-header-title strong {
                display: block;
                color: var(--ink);
                font-size: .94rem;
            }

            .control-header-title small {
                display: block;
                color: var(--muted);
                font-size: .70rem;
            }

        .control-header-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 6px;
            flex-wrap: wrap;
        }

        .control-body {
            padding: 11px;
        }

        .dashboard-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 10px;
        }

        .updated-text {
            color: var(--muted);
            font-size: .73rem;
        }

