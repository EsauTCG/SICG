        /* ================= REPORTE HISTÓRICO COMPLETO ================= */
        .report-filter-bar {
            display: grid;
            grid-template-columns: minmax(130px, .8fr) minmax(130px, .8fr) minmax(230px, 1.7fr) auto;
            gap: 8px;
            align-items: end;
            margin-top: 12px;
        }

        .report-filter-field label {
            display: block;
            margin-bottom: 4px;
            color: #687079;
            font-size: .68rem;
            font-weight: 900;
            text-transform: uppercase;
        }

        .report-filter-field .form-control,
        .report-filter-field .form-select,
        .report-filter-bar .btn {
            min-height: 42px;
        }

        .report-note {
            margin-top: 8px;
            color: #6d747b;
            font-size: .72rem;
        }

        .report-kpi-grid {
            display: grid;
            grid-template-columns: repeat(6, minmax(0, 1fr));
            gap: 8px;
            margin-top: 10px;
        }

        .report-kpi {
            min-width: 0;
            padding: 11px 10px;
            border: 1px solid #e3e7ea;
            border-radius: 12px;
            background: #fff;
        }

            .report-kpi span {
                display: block;
                color: #737a81;
                font-size: .65rem;
                font-weight: 900;
                text-transform: uppercase;
            }

            .report-kpi strong {
                display: block;
                margin-top: 4px;
                color: #20252a;
                font-size: 1.05rem;
                font-weight: 950;
                overflow-wrap: anywhere;
            }

            .report-kpi.pending strong,
            .report-kpi.incidents strong {
                color: #c82333;
            }

            .report-kpi.counted strong {
                color: #198754;
            }

        .report-section {
            margin-top: 12px;
            overflow: hidden;
            border: 1px solid #e2e6e9;
            border-radius: 13px;
            background: #fff;
        }

            .report-section > summary {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 10px;
                min-height: 48px;
                padding: 11px 13px;
                cursor: pointer;
                list-style: none;
                border-bottom: 1px solid transparent;
                background: #fafbfc;
                color: #24292f;
                font-weight: 950;
            }

                .report-section > summary::-webkit-details-marker {
                    display: none;
                }

            .report-section[open] > summary {
                border-bottom-color: #e7eaed;
            }

            .report-section > summary::after {
                content: "⌄";
                flex: 0 0 auto;
                color: #9f0000;
                font-size: 1rem;
            }

            .report-section[open] > summary::after {
                content: "⌃";
            }

        .report-section-body {
            padding: 11px;
        }

        .report-two-columns {
            display: grid;
            grid-template-columns: minmax(0, 1.3fr) minmax(280px, .7fr);
            gap: 12px;
            align-items: start;
        }

        /*
                         * Chart.js necesita un contenedor con altura definida cuando
                         * maintainAspectRatio=false. Sin este límite el canvas puede crecer
                         * repetidamente y ocupar casi todo el modal.
                         */
        .report-aging-panel {
            align-self: start;
            min-width: 0;
            overflow: hidden;
            padding: 11px;
            border: 1px solid #e5e8eb;
            border-radius: 11px;
            background: #fff;
        }

        .report-aging-chart-box {
            position: relative;
            width: 100%;
            height: 250px;
            min-height: 250px;
            max-height: 250px;
            margin-top: 7px;
            overflow: hidden;
        }

            .report-aging-chart-box canvas {
                position: absolute;
                inset: 0;
                width: 100% !important;
                height: 100% !important;
                max-height: 250px !important;
            }

        .report-table-scroll {
            max-height: 420px;
            overflow: auto;
            border: 1px solid #e5e8eb;
            border-radius: 10px;
            -webkit-overflow-scrolling: touch;
        }

        .report-stock-table-full {
            width: 100%;
            max-height: 520px;
        }

            .report-stock-table-full .report-data-table {
                min-width: 760px;
            }

        .report-data-table {
            width: 100%;
            min-width: 840px;
            border-collapse: collapse;
            font-size: .76rem;
        }

            .report-data-table th,
            .report-data-table td {
                padding: 9px 10px;
                border-bottom: 1px solid #edf0f2;
                vertical-align: top;
                text-align: left;
            }

            .report-data-table th {
                position: sticky;
                top: 0;
                z-index: 2;
                background: #f7f8fa;
                color: #5e666e;
                font-size: .66rem;
                font-weight: 950;
                text-transform: uppercase;
                white-space: nowrap;
            }

                .report-data-table td.num,
                .report-data-table th.num {
                    text-align: right;
                }

            .report-data-table tbody tr:hover {
                background: #fff9f9;
            }

        .report-status {
            display: inline-flex;
            align-items: center;
            padding: 3px 7px;
            border-radius: 999px;
            font-size: .64rem;
            font-weight: 950;
        }

            .report-status.ok {
                background: #e8f7ef;
                color: #0f6b42;
            }

            .report-status.warn {
                background: #fff3cd;
                color: #795700;
            }

            .report-status.bad {
                background: #fdebed;
                color: #a31623;
            }

        .report-pagination {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            margin-top: 9px;
        }

        .report-pagination-info {
            color: #667079;
            font-size: .72rem;
            font-weight: 800;
        }

        .report-pagination-buttons {
            display: flex;
            gap: 6px;
        }

        .report-empty {
            padding: 18px;
            color: #70777e;
            text-align: center;
        }

        .report-incident-filter {
            min-width: 210px;
        }

        .report-photo-link {
            color: #0d6efd;
            font-weight: 800;
            text-decoration: none;
        }

            .report-photo-link:hover {
                text-decoration: underline;
            }

        @@media (max-width: 1100px) {
            .report-kpi-grid {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }

            .report-two-columns {
                grid-template-columns: 1fr;
            }

            .report-aging-chart-box {
                height: 225px;
                min-height: 225px;
                max-height: 225px;
            }

                .report-aging-chart-box canvas {
                    max-height: 225px !important;
                }
        }

        @@media (max-width: 768px) {
            .report-filter-bar {
                grid-template-columns: 1fr;
            }

            .report-kpi-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .report-table-scroll {
                max-height: 52vh;
                overflow-x: hidden;
                border: 0;
            }

            .report-data-table {
                display: block;
                min-width: 0;
            }

                .report-data-table thead {
                    display: none;
                }

                .report-data-table tbody {
                    display: grid;
                    gap: 8px;
                }

                .report-data-table tr {
                    display: block;
                    overflow: hidden;
                    border: 1px solid #e4e7ea;
                    border-radius: 11px;
                    background: #fff;
                    box-shadow: 0 4px 12px rgba(20,24,31,.05);
                }

                .report-data-table td {
                    display: grid;
                    grid-template-columns: minmax(105px, .72fr) minmax(0, 1.28fr);
                    gap: 8px;
                    min-height: 36px;
                    padding: 8px 9px;
                    border-bottom: 1px solid #edf0f2;
                    word-break: break-word;
                }

                    .report-data-table td:last-child {
                        border-bottom: 0;
                    }

                    .report-data-table td::before {
                        content: attr(data-label);
                        color: #6b737b;
                        font-size: .63rem;
                        font-weight: 950;
                        text-transform: uppercase;
                    }

                    .report-data-table td.num {
                        text-align: left;
                    }

            .report-pagination {
                align-items: stretch;
                flex-direction: column;
            }

            .report-pagination-buttons {
                display: grid;
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

                .report-pagination-buttons .btn {
                    width: 100%;
                }
        }

        @@media (max-width: 430px) {
            .report-kpi-grid {
                grid-template-columns: 1fr 1fr;
            }

            .report-section-body {
                padding: 8px;
            }

            .report-aging-panel {
                padding: 9px 8px;
            }

            .report-aging-chart-box {
                height: 205px;
                min-height: 205px;
                max-height: 205px;
            }

                .report-aging-chart-box canvas {
                    max-height: 205px !important;
                }

            .report-data-table td {
                grid-template-columns: minmax(90px, .65fr) minmax(0, 1.35fr);
            }
        }

        @@media print {
            body * {
                visibility: hidden !important;
            }

            #reportModal,
            #reportModal * {
                visibility: visible !important;
            }

            #reportModal {
                position: static !important;
                inset: auto !important;
                display: block !important;
                background: transparent !important;
            }

            .report-actions {
                display: none !important;
            }

            .report-shell,
            .r-card {
                box-shadow: none !important;
                border: none !important;
            }
        }
    </style>
}


<div class="handheld-page">
    <header class="handheld-top">
        <div class="handheld-title">
