@model TodoPlanModel

@{
    int index = 0;
}

<div class="table-responsive mt-3 p-3 border border-danger rounded shadow-sm" style="background-color:#fff3f3;">
    <h4 class="mb-4 text-center text-dark fw-bold">PLANEACIÓN DE PRODUCCIÓN</h4>
    <button type="button" class="btn btn-secondary" onclick="loadPartial('@Url.Action("Index", "PlanSemanal", new { id = Model._PlanPro.Id, fecha=Model._PlanPro.Fecha })',document.querySelector('.toolbar button[data-url=\'/Planeacion/Index\']'));return false;">📅 Plan Semanal</button>
    <form asp-action="Modificar" method="post" id="formPlaneacion" data-fecha="@Model._PlanPro.Fecha">
        <input type="hidden" asp-for="_PlanPro.Id"/>
        <!-- ENCABEZADO -->
        <div class="row">
            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Mes de Producción</label>
                <input name="_PlanPro.Fecha" type="hidden" readonly class="form-control" value="@Model._PlanPro.Fecha" />
                <input type="text" readonly class="form-control" value="@Convert.ToDateTime(Model._PlanPro.Fecha).ToString("MMMM").ToUpper()" />
            </div>

            @*             <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Planta</label>
                <select asp-for="" class="form-select">
                    <option value="">Selecciona planta</option>
                    <option value="1">TIF</option>
                    <option value="2">Planta 1</option>
                </select>
            </div> *@

            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Clasificación</label>
                <input type="hidden" asp-for="_PlanPro.fk_Clasificacion" />
                @foreach (var item in Model._ListaClasificacion)
                {
                    if (item.SKU == Model._PlanPro.fk_Clasificacion)
                        {
                        <input type="text" value="@item.Nombre" class="form-control" readonly/>
                        }
                }
            </div>

            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Canales</label>
                <input asp-for="_PlanPro.Canales" id="canalesInput" type="number" step="1" class="form-control" />
            </div>

            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Kg Promedio</label>
                <input asp-for="_PlanPro.PesoPromedio" id="kgPromedioInput" type="number" step="0.01" class="form-control" />
            </div>

            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Kg Estimados</label>
                <input asp-for="_PlanPro.PesoTotal" id="kgEstimadosInput" type="number" step="0.01" class="form-control" readonly />
            </div>
        </div>

        <hr />

        <!-- TABLA -->
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-danger">
                    <tr>
                        <th>#</th>
                        <th>SKU</th>
                        <th>%</th>
                        <th>Kilos</th>
                    </tr>
                </thead>
                <tbody id="masterBody">
                    
                    @foreach (var item in Model._ListaPlanDetalle)
                    {
                        <tr>
                            <td>@(index+1)</td>
                            <td><input name="_ListaPlanDetalle[@index].ProductoCodigo" class="form-control productoCodigo" value="@item.ProductoCodigo" readonly /></td>
                            <td><input name="_ListaPlanDetalle[@index].Porcentaje" type="number" step="0.01" class="form-control porcentajeInput" value="@item.Porcentaje" /></td>
                            <td><input name="_ListaPlanDetalle[@index].Peso" type="number" step="0.01" class="form-control kilosInput" value="@item.Peso" /></td>
                        </tr>
                        index++;
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <div>
                <button type="submit" class="btn btn-primary">Guardar</button>
                <button type="button" class="btn btn-secondary" onclick="loadPartial('@Url.Action("Planes", "Planeacion", new {fecha=Model._PlanPro.Fecha})',document.querySelector('.toolbar button[data-url=\'/Planeacion/Index\']'));return false;">Cancelar</button>
            </div>
        </div>
    </form>
</div>



