@model Plataforma_CG.Models.Vista
@{
    ViewBag.Title = "Crear Nueva Vista";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<style>
    :root {
        --brand: linear-gradient(90deg,#8B0000 0%,#5a0000 50%,#1a0000 100%);
        --bg: linear-gradient(135deg,#eef2f6 0%,#e9edf2 50%,#d7dde3 100%);
        --panel: #fff;
        --bar: #e6e9ef;
        --bar-2: #dde2ea;
        --line: #d8dce3;
        --text: #20262e;
        --muted: #636d7b;
        --radius: 10px;
        --shadow: 0 1px 0 rgba(0,0,0,.05),0 12px 24px rgba(0,0,0,.06);
        --focus: 0 0 0 .2rem rgba(45,108,223,.25);
        --accent: #2d6cdf;
    }

    body {
        background: var(--bg) !important;
        color: var(--text);
        font-family: system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial,"Noto Sans";
    }

    .form-shell {
        max-width: 700px;
        margin: 2.5rem auto;
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    /* Encabezado */
    .module-titlebar {
        background: linear-gradient(#eef1f6,#e7ebf2);
        border-bottom: 1px solid var(--bar-2);
        padding: .85rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .module-title {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-weight: 700;
        color: #2b3642;
        margin: 0;
    }

        .module-title i {
            color: #8B0000;
        }

    .module-subtitle {
        font-size: .9rem;
        color: var(--muted);
        margin: 0;
    }

    /* Formulario */
    .form-panel {
        padding: 1.5rem;
    }

    .form-label {
        font-weight: 600;
        color: #1e2a35;
    }

    .form-control {
        border: 1px solid var(--line);
        border-radius: 8px;
        transition: .15s ease;
    }

        .form-control:focus {
            border-color: var(--accent);
            box-shadow: var(--focus);
            outline: none;
        }

    .btn {
        border-radius: 8px;
        padding: .55rem 1.2rem;
        font-weight: 600;
        transition: all .25s ease;
    }

    .btn-reflejo {
        background: var(--brand);
        color: #fff;
        border: none;
    }

        .btn-reflejo:hover {
            filter: brightness(1.07);
        }

    .btn-secondary {
        background: #5b6478;
        border: none;
        color: #fff;
    }

        .btn-secondary:hover {
            filter: brightness(1.05);
        }

    .text-center {
        text-align: center;
    }
</style>

<div class="form-shell">
    <div class="module-titlebar">
        <div>
            <h5 class="module-title"><i class="bi bi-window-plus"></i> Crear Nueva Vista</h5>
            <p class="module-subtitle">Registra una nueva vista del sistema especificando su controlador y acción correspondiente.</p>
        </div>
    </div>

    <div class="form-panel">
        <form asp-action="CrearVista" method="post">
            <div class="mb-3">
                <label asp-for="Nombre" class="form-label">Nombre de la Vista</label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej. Prospectos, Planeación..." />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Controlador" class="form-label">Controlador</label>
                <input asp-for="Controlador" class="form-control" placeholder="Ej. Prospecto, Planeacion..." />
                <span asp-validation-for="Controlador" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Accion" class="form-label">Acción</label>
                <input asp-for="Accion" class="form-control" placeholder="Ej. Index, Crear, Editar..." />
                <span asp-validation-for="Accion" class="text-danger small"></span>
            </div>

            <div class="text-center">
                <button type="submit" class="btn btn-reflejo"><i class="bi bi-save me-1"></i> Guardar</button>
                <a asp-action="PermisosConfiguracion" class="btn btn-secondary ms-2"><i class="bi bi-x-circle me-1"></i> Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <partial name="_ValidationScriptsPartial" />
}
