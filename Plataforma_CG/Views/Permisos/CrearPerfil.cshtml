@model Plataforma_CG.Models.Perfil
@{
    ViewBag.Title = "Crear Nuevo Perfil";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<style>
    :root {
        --brand: linear-gradient(90deg,#8B0000 0%,#5a0000 50%,#1a0000 100%);
        --bg: linear-gradient(135deg,#eef2f6 0%,#e9edf2 50%,#d7dde3 100%);
        --panel: #fff;
        --bar: #e6e9ef;
        --bar-2: #dde2ea;
        --line: #d8dce3;
        --text: #20262e;
        --muted: #636d7b;
        --radius: 10px;
        --shadow: 0 1px 0 rgba(0,0,0,.05),0 12px 24px rgba(0,0,0,.06);
        --focus: 0 0 0 .2rem rgba(45,108,223,.25);
        --accent: #2d6cdf;
    }

    body[data-theme="dark"] {
        --brand: linear-gradient(135deg, #7f1d1d 0%, #450a0a 50%, #111827 100%);
        --bg: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        --panel: #111827;
        --bar: #1f2937;
        --bar-2: #374151;
        --line: rgba(255,255,255,0.12);
        --text: #e5e7eb;
        --muted: #94a3b8;
        --shadow: 0 1px 0 rgba(0,0,0,.2), 0 12px 24px rgba(0,0,0,.32);
        --focus: 0 0 0 .2rem rgba(248,113,113,.25);
        --accent: #ef4444;
    }

    body[data-theme="dark"] .layout-main-content {
        background: var(--bg) !important;
    }

    body[data-theme="dark"] .layout-main-content .layout-container-fluid {
        background: transparent !important;
        box-shadow: none !important;
    }

    body {
        background: var(--bg) !important;
        color: var(--text);
        font-family: system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial,"Noto Sans";
    }

    .form-shell {
        max-width: 700px;
        margin: 2.5rem auto;
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    /* Encabezado */
    .module-titlebar {
        background: linear-gradient(#eef1f6,#e7ebf2);
        border-bottom: 1px solid var(--bar-2);
        padding: .85rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .module-title {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-weight: 700;
        color: #2b3642;
        margin: 0;
    }

        .module-title i {
            color: #8B0000;
        }

    .module-subtitle {
        font-size: .9rem;
        color: var(--muted);
        margin: 0;
    }

    /* Formulario */
    .form-panel {
        padding: 1.5rem;
    }

    .form-label {
        font-weight: 600;
        color: #1e2a35;
    }

    .form-control, textarea {
        border: 1px solid var(--line);
        border-radius: 8px;
        transition: .15s ease;
    }

        .form-control:focus, textarea:focus {
            border-color: var(--accent);
            box-shadow: var(--focus);
            outline: none;
        }

    .form-check-label {
        color: #2b3642;
        font-weight: 500;
    }

    .btn {
        border-radius: 8px;
        padding: .55rem 1.2rem;
        font-weight: 600;
        transition: all .25s ease;
    }

    .btn-reflejo {
        background: var(--brand);
        color: #fff;
        border: none;
    }

        .btn-reflejo:hover {
            filter: brightness(1.07);
        }

    .btn-secondary {
        background: #5b6478;
        border: none;
        color: #fff;
    }

        .btn-secondary:hover {
            filter: brightness(1.05);
        }

    .text-center {
        text-align: center;
    }

    body[data-theme="dark"] .form-shell {
        background: var(--panel);
        border-color: var(--line);
    }

    body[data-theme="dark"] .module-titlebar {
        background: linear-gradient(135deg, rgba(31,41,55,0.98), rgba(17,24,39,0.98));
        border-bottom-color: rgba(255,255,255,0.12);
    }

    body[data-theme="dark"] .module-title {
        color: #f9fafb;
    }

    body[data-theme="dark"] .module-title i {
        color: #fca5a5;
    }

    body[data-theme="dark"] .module-subtitle {
        color: #94a3b8;
    }

    body[data-theme="dark"] .form-label {
        color: #cbd5e1;
    }

    body[data-theme="dark"] .form-control,
    body[data-theme="dark"] textarea {
        background: #0b1220;
        color: #f9fafb;
        border-color: rgba(255,255,255,0.12);
    }

    body[data-theme="dark"] .form-control:focus,
    body[data-theme="dark"] textarea:focus {
        border-color: #ef4444;
        box-shadow: 0 0 0 0.18rem rgba(248,113,113,0.18);
    }

    body[data-theme="dark"] .form-control::placeholder,
    body[data-theme="dark"] textarea::placeholder {
        color: #64748b;
    }

    body[data-theme="dark"] .form-check-label {
        color: #e5e7eb;
    }

    body[data-theme="dark"] .form-check-input {
        background-color: #0b1220;
        border-color: rgba(203,213,225,0.45);
        accent-color: #ef4444;
    }

    body[data-theme="dark"] .form-check-input:checked {
        background-color: #ef4444;
        border-color: #ef4444;
    }

    body[data-theme="dark"] .btn-reflejo {
        background: linear-gradient(135deg, #7f1d1d 0%, #450a0a 50%, #111827 100%);
    }

    body[data-theme="dark"] .btn-reflejo:hover {
        filter: brightness(1.15);
    }

    body[data-theme="dark"] .btn-secondary {
        background: #4b5563;
    }

    body[data-theme="dark"] .btn-secondary:hover {
        background: #6b7280;
    }

    body[data-theme="dark"] .text-danger {
        color: #fca5a5 !important;
    }

    @@media (max-width: 576px) {
        .form-shell {
            margin: 1rem auto;
            border-radius: 8px;
        }

        .form-panel {
            padding: 1rem;
        }
    }
</style>

<div class="form-shell">
    <div class="module-titlebar">
        <div>
            <h5 class="module-title"><i class="bi bi-person-plus"></i> Crear Nuevo Perfil</h5>
            <p class="module-subtitle">Define el nombre, descripción y estado del nuevo perfil de usuario.</p>
        </div>
    </div>

    <div class="form-panel">
        <form asp-action="CrearPerfil" method="post">
            <div class="mb-3">
                <label class="form-label">Nombre del Perfil</label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej. Supervisor de ventas" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Descripción</label>
                <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Breve descripción del perfil..."></textarea>
            </div>

            <div class="form-check mb-4">
                <input asp-for="Activo" class="form-check-input" type="checkbox" checked />
                <label class="form-check-label">Activo</label>
            </div>

            <div class="text-center">
                <button type="submit" class="btn btn-reflejo"><i class="bi bi-save me-1"></i> Guardar</button>
                <a asp-action="PermisosConfiguracion" class="btn btn-secondary"><i class="bi bi-x-circle me-1"></i> Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <partial name="_ValidationScriptsPartial" />
}
