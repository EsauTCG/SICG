@model IEnumerable<Plataforma_CG.Models.Perfil>
@{
    ViewBag.Title = "Eliminar Perfiles";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<style>
    :root {
        --brand: linear-gradient(90deg,#8B0000 0%,#5a0000 50%,#1a0000 100%);
        --bg: linear-gradient(135deg,#eef2f6 0%,#e9edf2 50%,#d7dde3 100%);
        --panel: #fff;
        --bar: #e6e9ef;
        --bar-2: #dde2ea;
        --line: #d8dce3;
        --text: #20262e;
        --muted: #636d7b;
        --radius: 10px;
        --shadow: 0 1px 0 rgba(0,0,0,.05),0 12px 24px rgba(0,0,0,.06);
        --focus: 0 0 0 .2rem rgba(45,108,223,.25);
    }

    body[data-theme="dark"] {
        --brand: linear-gradient(135deg, #7f1d1d 0%, #450a0a 50%, #111827 100%);
        --bg: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        --panel: #111827;
        --bar: #1f2937;
        --bar-2: #374151;
        --line: rgba(255,255,255,0.12);
        --text: #e5e7eb;
        --muted: #94a3b8;
        --shadow: 0 1px 0 rgba(0,0,0,.2), 0 12px 24px rgba(0,0,0,.32);
        --focus: 0 0 0 .2rem rgba(248,113,113,.25);
    }

    body[data-theme="dark"] .layout-main-content {
        background: var(--bg) !important;
    }

    body[data-theme="dark"] .layout-main-content .layout-container-fluid {
        background: transparent !important;
        box-shadow: none !important;
    }

    body {
        background: var(--bg) !important;
        color: var(--text);
        font-family: system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial,"Noto Sans";
    }

    /* ---------- Titlebar ---------- */
    .module-titlebar {
        background: linear-gradient(#eef1f6,#e7ebf2);
        border: 1px solid var(--bar-2);
        padding: .9rem 1.25rem;
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        margin: 1.5rem auto 1rem;
        max-width: 1100px;
    }

    .module-title {
        display: flex;
        align-items: center;
        gap: .6rem;
        font-weight: 700;
        color: #2b3642;
        margin: 0;
    }

        .module-title i {
            color: #8B0000;
        }

    .module-subtitle {
        font-size: .9rem;
        color: var(--muted);
        margin: 0;
    }

    /* ---------- Panel principal ---------- */
    .panel {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 1rem 1.25rem 1.5rem;
        margin: 0 auto 2rem;
        max-width: 1100px;
    }

    /* ---------- Tabla ---------- */
    .table {
        width: 100%;
        border-collapse: collapse;
        margin-top: .5rem;
        font-size: .95rem;
    }

        .table thead th {
            background: var(--brand);
            color: #fff;
            font-weight: 700;
            padding: .75rem;
            text-align: left;
            border: none;
        }

        .table tbody td {
            padding: .7rem .9rem;
            border-bottom: 1px solid var(--line);
            vertical-align: middle;
        }

        .table tbody tr:hover {
            background: #f8fafc;
        }

    /* ---------- Estados ---------- */
    .estado-activo {
        color: #198754;
        font-weight: 600;
    }

    .estado-inactivo {
        color: #dc3545;
        font-weight: 600;
    }

    /* ---------- Botones ---------- */
    .btn {
        border-radius: 8px;
        padding: .45rem .9rem;
        font-weight: 600;
        transition: all .2s ease;
    }

    .btn-reflejo {
        background: var(--brand);
        color: #fff;
        border: none;
    }

        .btn-reflejo:hover {
            filter: brightness(1.07);
        }

    .btn-secondary {
        background: #5b6478;
        color: #fff;
        border: none;
    }

        .btn-secondary:hover {
            filter: brightness(1.05);
        }

    .btn-danger {
        background: #dc3545;
        color: #fff;
        border: none;
    }

        .btn-danger:hover {
            filter: brightness(1.1);
        }

    body[data-theme="dark"] .module-titlebar {
        background: linear-gradient(135deg, rgba(31,41,55,0.98), rgba(17,24,39,0.98));
        border-color: rgba(255,255,255,0.12);
    }

    body[data-theme="dark"] .module-title {
        color: #f9fafb;
    }

    body[data-theme="dark"] .module-title i {
        color: #fca5a5;
    }

    body[data-theme="dark"] .module-subtitle {
        color: #94a3b8;
    }

    body[data-theme="dark"] .panel {
        background: var(--panel);
        border-color: var(--line);
    }

    body[data-theme="dark"] .table thead th {
        background: linear-gradient(135deg, #7f1d1d, #450a0a) !important;
    }

    body[data-theme="dark"] .table tbody td {
        border-bottom-color: rgba(255,255,255,0.08);
    }

    body[data-theme="dark"] .table tbody tr:hover {
        background: rgba(248,113,113,0.06);
    }

    body[data-theme="dark"] .estado-activo {
        color: #4ade80;
    }

    body[data-theme="dark"] .estado-inactivo {
        color: #f87171;
    }

    body[data-theme="dark"] .btn-danger {
        background: #dc2626;
    }

    body[data-theme="dark"] .btn-secondary {
        background: #4b5563;
    }

    body[data-theme="dark"] .btn-secondary:hover {
        background: #6b7280;
    }

    @@media (max-width: 768px) {
        .module-titlebar {
            flex-direction: column;
            align-items: flex-start;
            gap: .75rem;
        }

        .table {
            font-size: .85rem;
        }

        .table thead th,
        .table tbody td {
            padding: .6rem .5rem;
        }
    }

    @@media (max-width: 576px) {
        .table-responsive {
            font-size: .8rem;
        }
    }
</style>

<div class="module-titlebar">
    <div>
        <h5 class="module-title"><i class="bi bi-trash3"></i> Eliminar Perfiles</h5>
        <p class="module-subtitle">Gestiona la eliminación de perfiles del sistema.</p>
    </div>
    <a asp-action="PermisosConfiguracion" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="panel">
    <table class="table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Estado</th>
                <th class="text-center">Acción</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var perfil in Model)
            {
                <tr>
                    <td>@perfil.Nombre</td>
                    <td>@perfil.Descripcion</td>
                    <td>
                        @if (perfil.Activo)
                        {
                            <span class="estado-activo">Activo</span>
                        }
                        else
                        {
                            <span class="estado-inactivo">Inactivo</span>
                        }
                    </td>
                    <td class="text-center">
                        <form asp-action="EliminarPerfil" method="post" onsubmit="return confirm('¿Seguro que deseas eliminar este perfil?');">
                            <input type="hidden" name="id" value="@perfil.Id" />
                            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
}
