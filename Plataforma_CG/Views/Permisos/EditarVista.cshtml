@model List<Plataforma_CG.Models.Vista>
@{
    ViewBag.Title = "Editar Vistas";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<style>
    :root {
        --brand: linear-gradient(90deg,#8B0000 0%,#5a0000 50%,#1a0000 100%);
        --bg: linear-gradient(135deg,#eef2f6 0%,#e9edf2 50%,#d7dde3 100%);
        --panel: #fff;
        --bar: #e6e9ef;
        --bar-2: #dde2ea;
        --line: #d8dce3;
        --text: #20262e;
        --muted: #636d7b;
        --radius: 10px;
        --shadow: 0 1px 0 rgba(0,0,0,.05),0 12px 24px rgba(0,0,0,.06);
    }

    body {
        background: var(--bg) !important;
        color: var(--text);
        font-family: system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial,"Noto Sans";
    }

    /* ---------- Titlebar ---------- */
    .module-titlebar {
        background: linear-gradient(#eef1f6,#e7ebf2);
        border: 1px solid var(--bar-2);
        padding: .9rem 1.25rem;
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        margin: 1.5rem auto 1rem;
        max-width: 1100px;
    }

    .module-title {
        display: flex;
        align-items: center;
        gap: .6rem;
        font-weight: 700;
        color: #2b3642;
        margin: 0;
    }

        .module-title i {
            color: #8B0000;
        }

    .module-subtitle {
        font-size: .9rem;
        color: var(--muted);
        margin: 0;
    }

    /* ---------- Panel principal ---------- */
    .panel {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 1rem 1.25rem 1.5rem;
        margin: 0 auto 2rem;
        max-width: 1100px;
    }

    /* ---------- Tabla ---------- */
    .table {
        width: 100%;
        border-collapse: collapse;
        margin-top: .5rem;
        font-size: .95rem;
    }

        .table thead th {
            background: var(--brand);
            color: #fff;
            font-weight: 700;
            padding: .75rem;
            text-align: left;
            border: none;
        }

        .table tbody td {
            padding: .7rem .9rem;
            border-bottom: 1px solid var(--line);
            vertical-align: middle;
        }

        .table tbody tr:hover {
            background: #f8fafc;
        }

    /* ---------- Botones ---------- */
    .btn {
        border-radius: 8px;
        padding: .45rem .9rem;
        font-weight: 600;
        transition: all .2s ease;
    }

    .btn-warning {
        background: #ffc107;
        color: #000;
        border: none;
    }

        .btn-warning:hover {
            background: #e0a800;
        }

    .btn-secondary {
        background: #5b6478;
        color: #fff;
        border: none;
    }

        .btn-secondary:hover {
            filter: brightness(1.05);
        }

    .alert-info {
        background: #eef4ff;
        border: 1px solid #c8d7ff;
        color: #2b3642;
        border-radius: 8px;
        padding: .9rem;
        margin-top: 1rem;
    }
</style>

<div class="module-titlebar">
    <div>
        <h5 class="module-title"><i class="bi bi-pencil-square"></i> Editar Vistas</h5>
        <p class="module-subtitle">Selecciona una vista existente para editar su información.</p>
    </div>
    <a asp-action="PermisosConfiguracion" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="panel">
    @if (Model.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Controlador</th>
                    <th>Acción</th>
                    <th class="text-center">Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var vista in Model)
                {
                    <tr>
                        <td>@vista.Nombre</td>
                        <td>@vista.Controlador</td>
                        <td>@vista.Accion</td>
                        <td class="text-center">
                            <a asp-action="EditarVistaForm" asp-route-id="@vista.Id" class="btn btn-warning">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info text-center">
            No hay vistas disponibles para editar.
        </div>
    }
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
}
