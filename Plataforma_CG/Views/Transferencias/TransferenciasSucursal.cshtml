@using System.Linq
@model Plataforma_CG.ViewModels.TransferenciasFiltroVM
@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<style>
    :root {
        --bg: #f0dede;
        --panel: #f8eeee;
        --panel-2: #f1dede;
        --line: #c79d9d;
        --line-dark: #8f4c4c;
        --text: #3b1717;
        --muted: #6a3a3a;
        --title: #ffffff;
        --white: #ffffff;
        --danger: #c00000;
        --warning: #f3b6b6;
        --ok: #f7e3e3;
        --shadow: 0 1px 0 rgba(255,255,255,.55) inset;
        --brand: #8B0000;
        --vino-1: #5c0000;
        --vino-2: #7a0000;
        --vino-3: #980000;
        --vino-4: #b30000;
        --vino-5: #d10000;
        --vino-soft: #f8e7e7;
        --vino-soft-2: #f2d9d9;
        --vino-border: #9a5a5a;
        --vino-text: #ffffff;
        --vino-text-dark: #4a1111;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0 !important;
        padding: 0 !important;
        font-family: Tahoma, Verdana, Arial, sans-serif;
        background: transparent !important;
        color: var(--text);
    }

    .container, .container-fluid {
        max-width: 100% !important;
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .window {
        width: 100%;
        max-width: 100%;
        margin: 0 !important;
        border: 1px solid #7e4a4a;
        background: var(--panel);
        box-shadow: 0 0 0 1px rgba(255,255,255,.45) inset, 0 8px 18px rgba(70, 12, 12, 0.14);
        overflow: hidden;
        padding: 0 !important;
    }

        .window > *:first-child,
        .titlebar {
            margin-top: 0 !important;
        }

    .titlebar {
        height: 34px;
        /* display: flex; */
        display: none !important;
        align-items: center;
        justify-content: space-between;
        padding: 0 10px;
        background: linear-gradient(180deg, #c00000 0%, #8b0000 60%, #5c0000 100%);
        border-bottom: 1px solid #5c0000;
        color: #fff;
        font-size: 13px;
        font-weight: bold;
    }

        .titlebar .actions {
            display: flex;
            gap: 6px;
        }

    .win-btn {
        width: 16px;
        height: 16px;
        border: 1px solid #7c4848;
        background: linear-gradient(#fff6f6, #ead0d0);
    }

    .menubar {
        display: none !important;
    }

    .toolbar {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 4px 6px;
        background: linear-gradient(#fff6f6, #ecd8d8);
        border-bottom: 1px solid var(--line);
        font-size: 12px;
        flex-wrap: wrap;
    }

    .tool-btn, .tab {
        border: 1px solid transparent;
        padding: 4px 8px;
        user-select: none;
    }

    .tool-btn {
        min-width: 72px;
        text-align: center;
        background: linear-gradient(#fffefe, #ecd7d7);
        border: 1px solid var(--vino-border);
        box-shadow: var(--shadow);
        cursor: pointer;
        color: var(--vino-text-dark);
    }

        .tool-btn:hover,
        .small-btn:hover,
        .tab:hover,
        .tr-btn-search:hover,
        .tr-btn-excel:hover,
        .tr-btn-csv:hover {
            filter: brightness(0.98);
        }

    .content {
        padding: 8px;
        background: var(--bg);
    }

    .tabs {
        display: flex;
        gap: 4px;
        margin-bottom: 6px;
        flex-wrap: wrap;
    }

    .tab {
        font-size: 12px;
        background: linear-gradient(#f7e7e7, #ead1d1);
        border: 1px solid #caa0a0;
        border-bottom: none;
        padding: 7px 12px;
        color: #5c1a1a;
    }

        .tab.active {
            background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
            font-weight: bold;
            color: #fff;
            border-color: #7a2d2d;
        }

    .workspace {
        border: 1px solid var(--line);
        background: var(--panel);
        padding: 8px;
    }

    .section {
        border: 1px solid var(--line);
        background: var(--white);
        margin-bottom: 10px;
    }

    .section-title {
        padding: 6px 8px;
        font-size: 12px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
    }

    .text-end {
        text-align: right !important;
        font-variant-numeric: tabular-nums;
    }

    .btn {
        border-radius: 4px;
        font-weight: 600;
        padding: 0.45rem 1rem;
        transition: all 0.2s ease;
        border: 1px solid transparent;
        box-shadow: 0 1px 3px rgba(60, 10, 10, 0.08);
    }

    .btn-primary {
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-color: #7a2d2d;
    }

        .btn-primary:hover {
            color: #fff;
        }

    .btn-danger {
        color: #fff;
        background: linear-gradient(180deg, #d33b3b 0%, #b71f1f 100%);
        border-color: #992222;
    }

        .btn-danger:hover {
            color: #fff;
        }

    .btn-secondary {
        background: linear-gradient(#fffefe, #ecd7d7);
        border-color: #9a5a5a;
        color: #4d1818;
    }

        .btn-secondary:hover {
            background: linear-gradient(#fff, #e7cfcf);
            color: #4d1818;
        }

    .btn-sm {
        padding: .30rem .70rem;
        font-size: .78rem;
    }

    input, select, .form-control, .form-select, .form-control-sm {
        border: 1px solid #b48787 !important;
        background: #fffdfd !important;
        color: #421414 !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        font-size: 12px !important;
    }

        .form-control:focus,
        .form-select:focus,
        .form-control-sm:focus {
            border-color: #8b0000 !important;
            box-shadow: 0 0 0 0.18rem rgba(139, 0, 0, 0.14) !important;
        }

    a.ver-tr {
        color: #5a0000 !important;
        text-decoration: none;
        font-weight: 700;
        font-size: 11px;
        transition: all .2s ease;
    }

        a.ver-tr:hover {
            color: #7a0000 !important;
            text-decoration: underline;
        }

    .dropdown-menu {
        font-size: 12px !important;
        border-radius: 0 !important;
        border: 1px solid #b48787 !important;
        background: #fffafa !important;
    }

    .btn-select-like {
        display: flex !important;
        align-items: center;
        justify-content: space-between;
        background: #fff !important;
        cursor: pointer;
        height: 36px !important;
        border: 1px solid #b48787 !important;
        padding: 3px 8px !important;
        color: #421414 !important;
        border-radius: 0 !important;
    }

        .btn-select-like::after {
            content: "▼";
            font-size: 10px;
            color: #7a3a3a;
        }

    /* Filtros */
    .filters {
        display: grid;
        grid-template-columns: 330px 200px 200px minmax(340px, 1fr) auto;
        gap: 8px;
        padding: 10px;
        background: var(--panel-2);
        align-items: end;
    }

    .fechas-group {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6px;
    }

        .fechas-group input {
            width: 100%;
        }

    .tr-btn-search,
    .tr-btn-excel,
    .tr-btn-csv,
    .small-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
        height: 28px;
        padding: 0 10px;
        font-weight: 700;
        border-radius: 0;
        font-size: 12px;
        box-shadow: var(--shadow);
        white-space: nowrap;
    }

    .tr-btn-search {
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border: 1px solid #7a2d2d;
    }

    .tr-btn-excel {
        color: #fff;
        background: linear-gradient(180deg, #198754 0%, #146c43 100%);
        border: 1px solid #146c43;
    }

    .tr-btn-csv,
    .small-btn {
        background: linear-gradient(#fffefe, #ecd7d7);
        color: #4b1f1f;
        border: 1px solid #b48787;
    }

    /* Tabla principal */
    .table-card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 0;
        box-shadow: 0 0 0 1px rgba(255,255,255,.45) inset, 0 8px 18px rgba(70, 12, 12, 0.08);
        overflow: hidden;
        margin-bottom: 1rem !important;
    }

    .table-responsive-sticky {
        max-height: 82vh !important;
        overflow-y: auto;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        border-top: 1px solid #d9b8b8;
        background: #fffafa;
        padding: 0;
        position: relative;
    }

        .table-responsive-sticky::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        .table-responsive-sticky::-webkit-scrollbar-track {
            background: #f1e4e4;
        }

        .table-responsive-sticky::-webkit-scrollbar-thumb {
            background: #8b0000;
        }

            .table-responsive-sticky::-webkit-scrollbar-thumb:hover {
                background: #6f0000;
            }

    .table {
        margin-bottom: 0;
        width: 100%;
    }

    .tr-page .table-responsive-sticky {
        display: block;
        width: 100%;
        max-width: 100%;
        vertical-align: top;
    }

        .tr-page .table-responsive-sticky,
        .tr-page .table-responsive-sticky * {
            text-align: left;
        }

    .table-responsive-sticky > table.table {
        width: 100%;
        table-layout: fixed;
        border-collapse: separate !important;
        border-spacing: 0 !important;
        font-size: 12px !important;
        background: #fffafa;
    }

        .table-responsive-sticky > table.table thead,
        .table-responsive-sticky > table.table thead tr,
        .table-responsive-sticky > table.table thead th {
            background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
            color: #fff !important;
        }

            .table-responsive-sticky > table.table thead th {
                position: sticky;
                top: -1px;
                z-index: 20;
                border-top: 1px solid #c46a6a !important;
                border-right: 1px solid #8e3b3b !important;
                border-bottom: 1px solid #5c0000 !important;
                padding: 6px 5px !important;
                font-weight: 700 !important;
                letter-spacing: 0 !important;
                font-size: 12px !important;
                white-space: nowrap;
                line-height: 1.2 !important;
                box-shadow: 0 2px 0 #6f1d1d;
            }

                .table-responsive-sticky > table.table thead th:first-child,
                .table-responsive-sticky > table.table tbody td:first-child {
                    border-left: 1px solid #d8bcbc !important;
                }

                .table-responsive-sticky > table.table thead th:first-child {
                    border-left: 1px solid #8e3b3b !important;
                }

        .table-responsive-sticky > table.table tbody td {
            background: #fffafa !important;
            border-right: 1px solid #d8bcbc !important;
            border-bottom: 1px solid #d8bcbc !important;
            padding: 6px 5px !important;
            line-height: 1.2 !important;
            color: #111111 !important;
            font-weight: 400;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            font-size: 12px !important;
            vertical-align: middle;
        }

        .table-responsive-sticky > table.table.table-striped > tbody > tr:nth-of-type(odd) > * {
            background-color: #fffafa !important;
        }

        .table-responsive-sticky > table.table tbody > tr:nth-of-type(even) > * {
            background-color: #f9eded !important;
        }

        .table-responsive-sticky > table.table tbody tr:hover > * {
            background: #f4dddd !important;
        }

        /* Consecutivo */
        .table-responsive-sticky > table.table th:nth-child(1),
        .table-responsive-sticky > table.table td:nth-child(1) {
            width: 130px;
        }

        /* Sucursal */
        .table-responsive-sticky > table.table th:nth-child(2),
        .table-responsive-sticky > table.table td:nth-child(2) {
            width: 140px;
        }

        /* Total cajas */
        .table-responsive-sticky > table.table th:nth-child(3),
        .table-responsive-sticky > table.table td:nth-child(3) {
            width: 95px;
        }

        /* Total kg */
        .table-responsive-sticky > table.table th:nth-child(4),
        .table-responsive-sticky > table.table td:nth-child(4) {
            width: 95px;
        }

        /* Solicita */
        .table-responsive-sticky > table.table th:nth-child(5),
        .table-responsive-sticky > table.table td:nth-child(5) {
            width: 190px;
        }

        /* Observación */
        .table-responsive-sticky > table.table th:nth-child(6),
        .table-responsive-sticky > table.table td:nth-child(6) {
            width: 300px;
        }

        /* Fecha Embarcar */
        .table-responsive-sticky > table.table th:nth-child(7),
        .table-responsive-sticky > table.table td:nth-child(7) {
            width: 120px;
        }

        /* Estatus */
        .table-responsive-sticky > table.table th:nth-child(8),
        .table-responsive-sticky > table.table td:nth-child(8) {
            width: 160px;
        }

        .table-responsive-sticky > table.table tbody td:nth-child(6) {
            white-space: normal !important;
            overflow: visible !important;
            text-overflow: clip !important;
            word-break: break-word;
            line-height: 1.15 !important;
        }

        .table-responsive-sticky > table.table tbody tr {
            min-height: 28px;
        }

    /* Badges */
    .badge-est {
        display: inline-block;
        min-width: 135px;
        text-align: center;
        padding: 4px 8px;
        border: 1px solid transparent;
        font-size: 11px;
        font-weight: 700;
        border-radius: 2px;
        line-height: 1.2;
        white-space: nowrap;
        box-shadow: none !important;
    }

        .badge-est::before {
            display: none !important;
        }

    .tr-est-0 {
        background: #fde2e2;
        border-color: #d9534f;
        color: #b00000;
    }

    .tr-est-1 {
        background: #fff4cc;
        border-color: #d6b656;
        color: #7a5a00;
    }

    .tr-est-2 {
        background: #d9ecff;
        border-color: #6fa8dc;
        color: #0b5394;
    }

    .tr-est-4 {
        background: #dff3e2;
        border-color: #6aa84f;
        color: #2f6b1f;
    }

    .tr-est-5 {
        background: #eadcff;
        border-color: #8e7cc3;
        color: #5b3fa3;
    }

    /* Modal */
    .modal-content {
        border: 1px solid #7d4949;
        border-radius: 0;
        box-shadow: 0 10px 20px rgba(60, 10, 10, 0.14);
    }

    .modal-header {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        color: white !important;
        border-bottom: 1px solid #5c0000 !important;
        padding: .65rem 1rem !important;
        border-radius: 0;
    }

    .modal-title {
        color: white !important;
        font-weight: 700;
        font-size: 1.05rem;
        letter-spacing: 0.2px;
    }

    .modal-header .btn-close {
        filter: invert(1) grayscale(100%) !important;
        opacity: .95 !important;
    }

    .modal-body {
        padding: .75rem !important;
        background: #f4e4e4;
    }

    #trModal .modal-dialog.modal-xl {
        max-width: 80vw !important;
        width: 80vw !important;
        margin: 1rem auto !important;
    }

    .tr-header {
        background: #fffafa;
        padding: .75rem .90rem;
        border-radius: 0;
        box-shadow: 0 1px 3px rgba(60, 10, 10, 0.08);
        border-left: 4px solid #8b0000;
        margin-bottom: .75rem;
        border-top: 1px solid #d8bcbc;
        border-right: 1px solid #d8bcbc;
        border-bottom: 1px solid #d8bcbc;
    }

    .tr-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        color: #7a0000;
        font-weight: 700;
        margin-bottom: 0.20rem;
    }

    .tr-value {
        font-size: 0.90rem;
        color: #401515;
    }

    hr {
        border-top: 2px solid #c79d9d;
        opacity: 0.5;
        margin: 1rem 0;
    }

    h6 {
        color: #7a0000;
        font-weight: 700;
        font-size: .95rem;
        margin-bottom: .75rem;
        padding-bottom: 0.35rem;
        border-bottom: 2px solid #d9b8b8;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        h6::before {
            content: '';
            width: 4px;
            height: 18px;
            background: #8b0000;
            border-radius: 0;
        }

    .modal-body .table {
        background: #fffafa;
        border-radius: 0;
        overflow: hidden;
        box-shadow: 0 1px 3px rgba(60, 10, 10, 0.08);
    }

        .modal-body .table thead th {
            background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
            color: #fff;
            border-bottom: 1px solid #5c0000;
        }

        .modal-body .table tbody td {
            background: #fffafa;
        }

    #trModal .table-responsive {
        border: 1px solid #d8bcbc;
        border-radius: 0;
        background: #fffafa;
        overflow: auto;
    }

    #trModal table.sap-grid {
        border-collapse: separate;
        border-spacing: 0;
        background: #fffafa;
        width: 100%;
        font-size: 12px;
        margin: 0;
    }

        #trModal table.sap-grid thead,
        #trModal table.sap-grid thead tr,
        #trModal table.sap-grid thead th {
            background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
            color: #fff !important;
        }

            #trModal table.sap-grid thead th {
                position: sticky;
                top: -1px;
                z-index: 5;
                border-top: 1px solid #c46a6a;
                border-right: 1px solid #8e3b3b;
                border-bottom: 1px solid #5c0000;
                padding: 6px 5px;
                font-weight: 700;
                letter-spacing: 0;
                font-size: 12px;
                white-space: nowrap;
                line-height: 1.2;
                box-shadow: 0 2px 0 #6f1d1d;
            }

        #trModal table.sap-grid tbody td {
            background: #fffafa;
            border-bottom: 1px solid #d8bcbc;
            border-right: 1px solid #d8bcbc;
            padding: 6px 5px;
            line-height: 1.2;
            color: #111111;
            font-weight: 400;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            font-size: 12px;
        }

            #trModal table.sap-grid thead th:first-child,
            #trModal table.sap-grid tbody td:first-child {
                border-left: 1px solid #d8bcbc;
            }

        #trModal table.sap-grid thead th:first-child {
            border-left: 1px solid #8e3b3b;
        }

        #trModal table.sap-grid.table-striped > tbody > tr:nth-of-type(odd) > * {
            background-color: #fffafa;
        }

        #trModal table.sap-grid tbody > tr:nth-of-type(even) > * {
            background-color: #f9eded;
        }

        #trModal table.sap-grid tbody tr:hover > * {
            background: #f4dddd !important;
        }

        #trModal table.sap-grid tfoot th {
            background: linear-gradient(#fff7f7, #edd9d9) !important;
            border-top: 1px solid #c79d9d;
            border-right: 1px solid #d8bcbc;
            color: #4a1818 !important;
            padding: 6px 5px;
            font-weight: 700;
            font-size: 12px;
        }

    #trm-comp-tbody td:nth-child(3) {
        white-space: normal !important;
        overflow: visible !important;
        text-overflow: clip !important;
        word-break: break-word;
        line-height: 1.15 !important;
    }

    .modal-footer {
        background: #f7eaea;
        border-top: 1px solid #d3b0b0;
    }

    .statusbar {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 6px 10px;
        font-size: 11px;
        color: #4a1a1a;
        border-top: 1px solid #b88c8c;
        background: linear-gradient(#f6e9e9, #ead5d5);
        flex-wrap: wrap;
    }

    @@media (max-width: 1200px) {
        .filters {
            grid-template-columns: 1fr 1fr 1fr;
        }
    }

    @@media (max-width: 768px) {
        .filters {
            grid-template-columns: 1fr;
        }

        .table-responsive-sticky > table.table tbody td,
        #trModal table.sap-grid tbody td {
            white-space: normal !important;
            overflow: visible !important;
            text-overflow: clip !important;
            word-break: break-word !important;
        }

        .table-responsive-sticky > table.table {
            min-width: 1000px;
        }

        #trModal .modal-dialog.modal-xl {
            max-width: 100vw !important;
            width: 100vw !important;
            margin: 0 !important;
        }

        #trModal .modal-content {
            border-radius: 0 !important;
            min-height: 100vh;
        }
    }

    .filters input,
    .filters select,
    .filters .form-control,
    .filters .form-select,
    .filters .btn-select-like {
        height: 36px !important;
        min-height: 36px !important;
        padding: 6px 10px !important;
        line-height: 1.2 !important;
        box-sizing: border-box !important;
    }

    .pm-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .pm-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        height: 34px;
        padding: 0 14px;
        border: 1px solid transparent;
        border-radius: 0;
        font-family: Tahoma, Verdana, Arial, sans-serif;
        font-size: 13px;
        font-weight: 700;
        line-height: 1;
        cursor: pointer;
        text-decoration: none;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
        transition: filter 0.15s ease, transform 0.05s ease;
    }

        .pm-btn i {
            font-size: 15px;
            line-height: 1;
        }

