<div class="window">
    <div class="titlebar">
        <div></div>
        <div class="actions">
            <div class="win-btn"></div>
            <div class="win-btn"></div>
            <div class="win-btn"></div>
        </div>
    </div>

    <div class="toolbar">
        @* <button class="tool-btn" type="submit" form="frmTransferencias">Buscar</button> *@
       @*  <button class="tool-btn" type="submit" form="frmTransferencias" name="Export" value="xlsx">Exportar Excel</button>
        <button class="tool-btn" type="submit" form="frmTransferencias" name="Export" value="csv">Exportar CSV</button>
        <button class="tool-btn" type="button" onclick="location.reload()">Actualizar</button> *@
    </div>

    <div class="content">
       

        <div class="workspace">
            <div class="section">
                <div class="section-title">Filtros de búsqueda</div>

                <form id="frmTransferencias" method="get">
                    <div class="filters">
                        @{
                            var hoy = DateTime.Today;
                            var desdeDef = (Model?.Desde ?? hoy.AddDays(-2)).ToString("yyyy-MM-dd");
                            var hastaDef = (Model?.Hasta ?? hoy).ToString("yyyy-MM-dd");
                        }

                        <div class="filter-group fechas-group">
                            <div>
                                <label>Desde</label>
                                <input type="date" name="Desde" value="@desdeDef" />
                            </div>

                            <div>
                                <label>Hasta</label>
                                <input type="date" name="Hasta" value="@hastaDef" />
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Sucursal</label>
                            @{
                                var sucSel = Model?.SucursalesSeleccionadas ?? new List<string>();

                                string TextoSucursalesFiltro(IEnumerable<string> selec)
                                {
                                    if (selec == null || !selec.Any()) return "(Todas)";
                                    if (Model?.Sucursales == null) return string.Join(", ", selec);

                                    var nombres = Model.Sucursales
                                        .Where(s => selec.Contains(s.Codigo))
                                        .Select(s => $"{s.Codigo}")
                                        .ToList();

                                    if (!nombres.Any()) nombres = selec.ToList();
                                    return string.Join(", ", nombres.Distinct());
                                }
                            }

                            <div class="dropdown w-100" id="dd-sucursal-tr">
                                <button class="btn-select-like w-100"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        data-bs-auto-close="outside"
                                        aria-expanded="false">
                                    <span class="multi-label">@TextoSucursalesFiltro(sucSel)</span>
                                </button>
                                <div class="dropdown-menu multi-picker-menu" onclick="event.stopPropagation();">
                                    <input type="text"
                                           class="form-control multi-picker-search"
                                           placeholder="Buscar sucursal..."
                                           autocomplete="off" />

                                    <div class="multi-picker-list">
                                        @if (Model?.Sucursales != null)
                                        {
                                            foreach (var s in Model.Sucursales)
                                            {
                                                var isChecked = sucSel.Contains(s.Codigo);
                                                var text = string.IsNullOrWhiteSpace(s.Nombre) ? s.Codigo : $"{s.Nombre}";

                                                <label class="multi-picker-option">
                                                    <input class="multi-check-sucursal-tr"
                                                           type="checkbox"
                                                           value="@s.Codigo"
                                                           id="tr_suc_@s.Codigo"
                                                           data-text="@text"
                                                    @(isChecked ? "checked" : null) />
                                                    <span>@text</span>
                                                </label>
                                            }
                                        }
                                    </div>
                                </div>

                                <div id="dd-sucursal-tr-hidden">
                                    @foreach (var s in sucSel)
                                    {
                                        <input type="hidden" name="SucursalesSeleccionadas" value="@s" />
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Estatus</label>
                            @{
                                var ests = Model?.EstatusSeleccionados ?? new List<int>();

                                string TextoEstatusFiltro(IEnumerable<int> selec)
                                {
                                    if (selec == null || !selec.Any()) return "(Todos)";

                                    var set = selec.ToHashSet();
                                    var nombres = new List<string>();

                                    if (set.Contains(1) || set.Contains(3)) nombres.Add("Pendiente");
                                    if (set.Contains(2)) nombres.Add("Autorización");
                                    if (set.Contains(4)) nombres.Add("Validado");
                                    if (set.Contains(5)) nombres.Add("Surtido");
                                    if (set.Contains(0)) nombres.Add("Cancelada");

                                    return string.Join(", ", nombres);
                                }
                            }

                            <div class="dropdown w-100" id="dd-estatus-tr">
                                <button class="btn-select-like w-100"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        data-bs-auto-close="outside"
                                        aria-expanded="false">
                                    <span class="multi-label">@TextoEstatusFiltro(ests)</span>
                                </button>
                                <div class="dropdown-menu multi-picker-menu" onclick="event.stopPropagation();">
                                    <input type="text"
                                           class="form-control multi-picker-search"
                                           placeholder="Buscar estatus..."
                                           autocomplete="off" />

                                    <div class="multi-picker-list">
                                        <label class="multi-picker-option">
                                            <input class="multi-check-estatus-tr"
                                                   type="checkbox"
                                                   value="1"
                                                   data-extra="3"
                                                   id="tr_est_pend"
                                                   data-text="Pendiente"
                                            @(ests.Contains(1) || ests.Contains(3) ? "checked" : null) />
                                            <span>Pendiente</span>
                                        </label>

                                        <label class="multi-picker-option">
                                            <input class="multi-check-estatus-tr"
                                                   type="checkbox"
                                                   value="2"
                                                   id="tr_est_2"
                                                   data-text="Autorización"
                                            @(ests.Contains(2) ? "checked" : null) />
                                            <span>Autorización</span>
                                        </label>

                                        <label class="multi-picker-option">
                                            <input class="multi-check-estatus-tr"
                                                   type="checkbox"
                                                   value="4"
                                                   id="tr_est_4"
                                                   data-text="Validado"
                                            @(ests.Contains(4) ? "checked" : null) />
                                            <span>Validado</span>
                                        </label>

                                        <label class="multi-picker-option">
                                            <input class="multi-check-estatus-tr"
                                                   type="checkbox"
                                                   value="5"
                                                   id="tr_est_5"
                                                   data-text="Surtido"
                                            @(ests.Contains(5) ? "checked" : null) />
                                            <span>Surtido</span>
                                        </label>

                                        <label class="multi-picker-option">
                                            <input class="multi-check-estatus-tr"
                                                   type="checkbox"
                                                   value="0"
                                                   id="tr_est_0"
                                                   data-text="Cancelada"
                                            @(ests.Contains(0) ? "checked" : null) />
                                            <span>Cancelada</span>
                                        </label>
                                    </div>
                                </div>

                                <div id="dd-estatus-tr-hidden">
                                    @foreach (var e in ests)
                                    {
                                        <input type="hidden" name="EstatusSeleccionados" value="@e" />
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Buscar</label>
                            <input type="text" name="Buscar"
                                   value="@(Model?.Buscar ?? "")"
                                   placeholder="Consecutivo / SKU / Observación" />
                        </div>
                        <div class="pm-actions">
                            <button class="pm-btn pm-btn-primary" type="submit">
                                <i class="bi bi-search"></i>
                                <span>Aplicar</span>
                            </button>

                            <button class="pm-btn pm-btn-excel"
                                    type="submit"
                                    form="frmTransferencias"
                                    name="Export"
                                    value="xlsx">
                                <i class="bi bi-file-earmark-excel"></i>
                                <span>Exportar a Excel</span>
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="section">
                @* <div class="section-title">Listado de transferencias</div> *@

                @Html.AntiForgeryToken()

                <div class="table-card table-responsive-sticky">
                    <table class="table table-sm table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th data-sort-col="cons" data-sort-type="text">Consecutivo</th>
                                <th data-sort-col="suc" data-sort-type="text">Sucursal</th>
                                <th class="text-end" data-sort-col="cajas" data-sort-type="num">Total cajas</th>
                                <th class="text-end" data-sort-col="kg" data-sort-type="num">Total kg</th>
                                <th data-sort-col="sol" data-sort-type="text">Solicita</th>
                                <th data-sort-col="obs" data-sort-type="text">Observación</th>
                                <th data-sort-col="fsol" data-sort-type="date">Fecha Embarcar</th>
                                <th data-sort-col="est" data-sort-type="text">Estatus</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var resultadosOrdenados = Model?.Resultados?.OrderByDescending(t => t.Consecutivo);
                            }

                            @if (resultadosOrdenados != null && resultadosOrdenados.Any())
                            {
                                var idx = 0;
                                foreach (var t in resultadosOrdenados)
                                {
                                    var estVal = t?.Estatus ?? -1;

                                    var estClass =
                                    estVal == 0 ? "tr-est-0" :
                                    (estVal == 1 || estVal == 3) ? "tr-est-1" :
                                    estVal == 2 ? "tr-est-2" :
                                    estVal == 4 ? "tr-est-4" :
                                    estVal == 5 ? "tr-est-5" : "";

                                    var texto =
                                    estVal == 0 ? "Cancelada" :
                                    (estVal == 1 || estVal == 3) ? "Pendiente" :
                                    estVal == 2 ? "Autorización Presupuesto" :
                                    estVal == 4 ? "Validado" :
                                    estVal == 5 ? "Surtido" : "Otro";

                                    <tr data-index="@idx">
                                        <td>
                                            <a href="#" class="ver-tr"
                                               data-id="@(t?.Id)"
                                               data-cons="@(t?.Consecutivo ?? "")">
                                                @(t?.Consecutivo ?? "")
                                            </a>
                                        </td>

                                        <td>@(t?.SucursalNombre ?? "")</td>

                                        <td class="text-end">
                                            @((t?.TotalCajas ?? 0).ToString("N0"))
                                        </td>

                                        <td class="text-end">
                                            @((t?.TotalKg ?? 0m).ToString("N2"))
                                        </td>

                                        <td>@(t?.UsuarioSolicita ?? "")</td>

                                        <td>@(t?.Observacion ?? "")</td>

                                        <td>@(t?.FechaSolicitud?.ToString("yyyy-MM-dd") ?? "")</td>

                                        <td>
                                            <span class="badge-est @estClass">@texto</span>
                                        </td>
                                    </tr>
                                    idx++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center text-muted">Sin resultados.</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="modal fade" id="trModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-xl modal-dialog-scrollable">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">
                                        Transferencia : <span id="trm-consecutivo"></span>
                                    </h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                                </div>

                                <div class="modal-body">
                                    <div class="row g-3 mb-3 tr-header">
                                        <div class="col-md-3 col-sm-6">
                                            <div class="tr-label">Sucursal</div>
                                            <div class="tr-value fw-bold" id="trm-sucursal"></div>
                                        </div>

                                        <div class="col-md-3 col-sm-6">
                                            <div class="tr-label">Embarcar</div>
                                            <div class="d-flex align-items-center gap-2">
                                                <input type="date"
                                                       class="form-control form-control-sm"
                                                       id="trm-fecha-sol-input"
                                                       style="max-width: 170px;" />

                                                <button type="button"
                                                        class="btn btn-primary btn-sm d-none"
                                                        id="btn-fecha-sol-save"
                                                        title="Guardar">
                                                    <i class="bi bi-check-lg"></i>
                                                </button>

                                                <button type="button"
                                                        class="btn btn-outline-secondary btn-sm d-none"
                                                        id="btn-fecha-sol-cancel"
                                                        title="Cancelar">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </div>

                                            <small class="text-muted d-block mt-1" id="trm-fecha-sol-help"></small>
                                        </div>

                                        <div class="col-md-4 col-sm-6">
                                            <div class="tr-label">Solicitó</div>
                                            <div class="tr-value fw-bold" id="trm-usuario"></div>
                                        </div>

                                        <div class="col-md-2 col-sm-6">
                                            <div class="tr-label">Estatus</div>
                                            <div class="tr-value fw-bold" id="trm-estatus"></div>
                                        </div>
                                    </div>

                                    <div class="row g-2 mb-3 small text-muted">
                                        <div class="col-12"><strong>Observación:</strong> <span id="trm-obs"></span></div>
                                    </div>

                                    <hr class="my-3" />
                                    <h6 class="mb-2">Pedido vs surtido</h6>

                                    <div class="table-responsive">
                                        <table class="table table-sm table-striped align-middle sap-grid trm-sap">
                                            <thead>
                                                <tr>
                                                    <th>#</th>
                                                    <th>SKU</th>
                                                    <th>Producto</th>
                                                    <th class="text-end">Kg pedido</th>
                                                    <th class="text-end">Cajas pedido</th>
                                                    <th class="text-end col-conf">Kg confirmadas</th>      <!-- ← -->
                                                    <th class="text-end col-conf">Cajas confirmadas</th>   <!-- ← -->
                                                    <th class="text-end">Kg surtido</th>
                                                    <th class="text-end">Cajas surtidas</th>
                                                    <th class="text-end">Dif kg</th>
                                                    <th class="text-end">Dif cajas</th>
                                                    <th>Estatus</th>
                                                </tr>
                                            </thead>

                                            <tbody id="trm-comp-tbody">
                                                <tr><td colspan="12" class="text-center text-muted">—</td></tr>
                                            </tbody>

                                            <tfoot>
                                                <tr>
                                                    <th colspan="3" class="text-end">Totales:</th>
                                                    <th class="text-end" id="trm-tot-kg-ped">0.00</th>
                                                    <th class="text-end" id="trm-tot-caj-ped">0</th>
                                                    <th class="text-end col-conf" id="trm-tot-kg-conf">0.00</th>   <!-- ← -->
                                                    <th class="text-end col-conf" id="trm-tot-caj-conf">0</th>     <!-- ← -->
                                                    <th class="text-end" id="trm-tot-kg-sur">0.00</th>
                                                    <th class="text-end" id="trm-tot-caj-sur">0</th>
                                                    <th colspan="3"></th>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>

                                <div class="modal-footer">
                                    <small class="text-muted me-auto">Folio interno: <span id="trm-id"></span></small>
                                    <button type="button" class="btn btn-danger btn-slim d-none" id="btn-cancelar-tr">
                                        <i class="bi bi-x-circle"></i> Cancelar transferencia
                                    </button>
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="statusbar">
            <div>Registro listo</div>
            <div>Usuario: @User.Identity.Name</div>
            <div>Empresa: Carnes G SA de CV</div>
            <div>Módulo: Transferencias</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function getAntiForgeryToken() {
            const el = document.querySelector('input[name="__RequestVerificationToken"]');
            return el ? el.value : '';
        }

        function fmtNum(n, d = 2) {
            if (n == null) return "";
            return Number(n).toLocaleString('es-MX', {
                minimumFractionDigits: d,
                maximumFractionDigits: d
            });
        }

        function showMsg(type, text) {
            const id = 'tr-alert';
            let box = document.getElementById(id);
            if (!box) {
                box = document.createElement('div');
                box.id = id;
                document.body.prepend(box);
            }
            box.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show m-3 shadow-sm"
                     role="alert" style="position:sticky; top:0; z-index:2000;">
                    ${text}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>`;
        }

        // ✅ incluye estatus 5
        function estatusTextoTr(e) {
            const est = Number(e);
            return est === 0 ? "Cancelada" :
                   est === 1 ? "Pendiente" :
                   est === 2 ? "Autorización Presupuesto" :
                   est === 3 ? "Pendiente" :
                   est === 4 ? "Validado" :
                   est === 5 ? "Surtido" : "Otro";
        }

        function toDateInputValue(isoString) {
            if (!isoString) return "";
            const d = new Date(isoString);
            if (isNaN(d)) return "";
            const pad = n => String(n).padStart(2, '0');
            return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
        }

        let trIdActual = null;
        let trEstatusAct = null;
        let trFechaSolOriginal = null;


function toggleCancelarBtnTr(estatus) {
    const btn = document.getElementById('btn-cancelar-tr');
    if (!btn) return;

    const cancelada = Number(estatus) === 0;

    btn.classList.toggle('d-none', cancelada);
    btn.disabled = cancelada;
    btn.title = cancelada
        ? 'Esta transferencia ya está cancelada'
        : 'Cancelar transferencia';
}


        function setFechaEditUI(show) {
            const btnSave = document.getElementById('btn-fecha-sol-save');
            const btnCancel = document.getElementById('btn-fecha-sol-cancel');
            if (!btnSave || !btnCancel) return;
            btnSave.classList.toggle('d-none', !show);
            btnCancel.classList.toggle('d-none', !show);
        }

        function toggleEditarFechaPermitido(estatus) {
            const inp = document.getElementById('trm-fecha-sol-input');
            const est = Number(estatus);
            const permitido = (est === 1 || est === 2);
            if (inp) inp.disabled = !permitido;
            if (!permitido) setFechaEditUI(false);
            return permitido;
        }

        async function guardarFechaSolicitudActual() {
            if (!trIdActual) { showMsg("warning", "No hay transferencia seleccionada."); return; }
            const inp = document.getElementById('trm-fecha-sol-input');
            if (!inp) return;

            const nueva = inp.value;
            if (!nueva) { showMsg("warning", "Selecciona una fecha válida."); return; }
            if (nueva === trFechaSolOriginal) { setFechaEditUI(false); return; }

            const btnSave = document.getElementById('btn-fecha-sol-save');
            const btnCancel = document.getElementById('btn-fecha-sol-cancel');
            if (btnSave) btnSave.disabled = true;
            if (btnCancel) btnCancel.disabled = true;

            try {
                const res = await fetch('/Transferencias/ActualizarFechaSolicitud', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getAntiForgeryToken()
                    },
                    body: JSON.stringify({ transferenciaId: Number(trIdActual), fechaSolicitud: nueva })
                });

                const raw = await res.text();
                let data = null;
                try { data = JSON.parse(raw); } catch { }

                if (!res.ok || !data?.ok) {
                    showMsg("danger", data?.msg || raw.substring(0, 160) || "No se pudo guardar la fecha.");
                    if (btnSave) btnSave.disabled = false;
                    if (btnCancel) btnCancel.disabled = false;
                    return;
                }

                showMsg("success", data.msg || "Fecha actualizada.");
                trFechaSolOriginal = nueva;
                setFechaEditUI(false);
                setTimeout(() => location.reload(), 400);

            } catch (e) {
                console.error(e);
                showMsg("danger", "No se pudo conectar con el servidor.");
                if (btnSave) btnSave.disabled = false;
                if (btnCancel) btnCancel.disabled = false;
            }
        }

    async function cancelarTransferenciaActual() {
    if (!trIdActual) {
        showMsg("warning", "No hay transferencia seleccionada.");
        return;
    }

    if (Number(trEstatusAct) === 0) {
        showMsg("warning", "Esta transferencia ya está cancelada.");
        return;
    }

    const consecutivo = document.getElementById('trm-consecutivo')?.textContent || '';

    const ok = confirm(
        `¿Seguro que deseas CANCELAR la transferencia ${consecutivo}?`
    );

    if (!ok) return;

    const btn = document.getElementById('btn-cancelar-tr');

    if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Cancelando...';
    }

    try {
       const res = await fetch('/Transferencias/Cancelar', {
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'RequestVerificationToken': getAntiForgeryToken()
    },
    body: JSON.stringify({
        transferenciaId: Number(trIdActual)
    })
});

        const raw = await res.text();
        let data = null;

        try {
            data = JSON.parse(raw);
        } catch { }

        if (!res.ok || data?.ok === false) {
            console.error("Error cancelar transferencia:", {
                status: res.status,
                raw,
                data
            });

            showMsg(
                "danger",
                data?.msg || raw.substring(0, 300) || `No se pudo cancelar. HTTP ${res.status}`
            );

            if (btn) {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-x-circle"></i> Cancelar transferencia';
            }

            return;
        }

        showMsg("success", data.msg || "Transferencia cancelada correctamente.");

        trEstatusAct = 0;
        toggleCancelarBtnTr(0);

        const modalEl = document.getElementById('trModal');
        const inst = bootstrap.Modal.getInstance(modalEl);
        inst?.hide();

        setTimeout(() => location.reload(), 500);

    } catch (e) {
        console.error(e);
        showMsg("danger", "No se pudo conectar con el servidor.");

        if (btn) {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-x-circle"></i> Cancelar transferencia';
        }
    }
}




        function escapeRegExp(s){
            return (s ?? "").replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
        }

        function soloNombreProducto(productoNombre, productoCodigo){
            const d = (productoNombre ?? "").trim();
            const c = (productoCodigo ?? "").trim();
            if (!d) return "";

            if (c) {
                const m = d.match(new RegExp("^" + escapeRegExp(c) + "\\s*\\((.*)\\)\\s*$", "i"));
                if (m && m[1]) return m[1].trim();
                return d.replace(new RegExp("^" + escapeRegExp(c) + "\\s*[-–—:]?\\s*", "i"), "").trim();
            }

            const m2 = d.match(/^\((.*)\)$/);
            return (m2 && m2[1]) ? m2[1].trim() : d;
        }

        // ✅ TABLA ÚNICA: une lineas + surtido por SKU
        async function cargarDetalleTr(id, consecutivo) {
            const modalEl = document.getElementById('trModal');
            const compTbody = document.getElementById('trm-comp-tbody');

            if (!modalEl || !compTbody) {
                console.error("Falta modal #trModal o tbody #trm-comp-tbody");
                showMsg("danger", "No existe el modal o la tabla comparativa.");
                return;
            }

            compTbody.innerHTML = `<tr><td colspan="12" class="text-center text-muted">Cargando...</td></tr>`;

            try {
                const resp = await fetch(`/Transferencias/DetalleApi?id=${encodeURIComponent(id)}`, { cache: 'no-store' });
                if (!resp.ok) throw new Error('HTTP ' + resp.status);

                const payload = await resp.json();
                const h = payload.header || {};
                const lineas = payload.lineas || [];
                const surtido = payload.surtido || [];

                trIdActual = h.id || id;
                trEstatusAct = Number(h.estatus);

                // header
                const elCons = document.getElementById('trm-consecutivo');
                const elId = document.getElementById('trm-id');
                const elSuc = document.getElementById('trm-sucursal');
                const elUsr = document.getElementById('trm-usuario');
                const elEst = document.getElementById('trm-estatus');
                const elObs = document.getElementById('trm-obs');

                if (elCons) elCons.textContent = h.consecutivo || consecutivo || "";
                if (elId) elId.textContent = trIdActual || "";
                if (elSuc) elSuc.textContent = h.sucursalNombre || h.sucursal || "";
                if (elUsr) elUsr.textContent = h.usuarioSolicita || "";
                if (elEst) elEst.textContent = estatusTextoTr(h.estatus);
                if (elObs) elObs.textContent = h.observacion || "";

                // fecha input
                const inpFecha = document.getElementById('trm-fecha-sol-input');
                if (inpFecha) {
                    const v = toDateInputValue(h.fechaSolicitud);
                    inpFecha.value = v;
                    trFechaSolOriginal = v;
                    setFechaEditUI(false);
                }

                toggleCancelarBtnTr(trEstatusAct);
                toggleEditarFechaPermitido(trEstatusAct);

                // totales footer
                        const totKgPedEl   = document.getElementById('trm-tot-kg-ped');
                        const totCajPedEl  = document.getElementById('trm-tot-caj-ped');
                        const totKgConfEl  = document.getElementById('trm-tot-kg-conf');
                        const totCajConfEl = document.getElementById('trm-tot-caj-conf');
                        const totKgSurEl   = document.getElementById('trm-tot-kg-sur');
                        const totCajSurEl  = document.getElementById('trm-tot-caj-sur');
        

                const normSku = s => (s ?? "").toString().trim().toUpperCase();

                const map = new Map();

                // 1) Pedido (lineas)
                (lineas || []).forEach(l => {
                    const sku = normSku(l.productoCodigo);
                    if (!sku) return;

                    const kgPed = Number(l.cantidadKg || l.cantidad || 0);
                    const cajPed = Number(l.cajas || 0);
                    const kgConf = Number(l.kgConfirmadas || l.kilosConfirmados || l.cantidadKgConfirmada || 0);
                    const cajConf = Number(l.cajasConfirmadas || l.cajasConfirmadasTotal || l.cajasConfirmada || 0);

                            const ex = map.get(sku) || {
                             sku,
                             productoCodigo: l.productoCodigo || sku,
                             productoNombre: l.productoNombre || "",
                             kgPedido: 0,
                             cajasPedido: 0,
                             kgConfirmadas: 0,
                             cajasConfirmadas: 0,
                             kgSurtido: 0,
                             cajasSurtidas: 0,
                             etiquetas: 0,
                             kgEscaneado: 0
                         };

                    if (!ex.productoNombre && l.productoNombre) ex.productoNombre = l.productoNombre;

                   
                   ex.kgPedido += kgPed;
                   ex.cajasPedido += cajPed;
                   ex.kgConfirmadas += kgConf;
                   ex.cajasConfirmadas += cajConf;

                    map.set(sku, ex);
                });

                // 2) Surtido (surtido)
                (surtido || []).forEach(s => {
                    const sku = normSku(s.sku);
                    if (!sku) return;

                            const ex = map.get(sku) || {
            sku,
            productoCodigo: sku,
            productoNombre: "",
            kgPedido: 0,
            cajasPedido: 0,
            kgConfirmadas: 0,
            cajasConfirmadas: 0,
            kgSurtido: 0,
            cajasSurtidas: 0,
            etiquetas: 0,
            kgEscaneado: 0
        };

                    ex.kgSurtido += Number(s.kgSurtido || 0);
                    ex.cajasSurtidas += Number(s.cajasSurtidas || 0);
                    ex.etiquetas += Number(s.etiquetas || 0);
                    ex.kgEscaneado += Number(s.kgEscaneado || 0);

                    map.set(sku, ex);
                });

                // 3) Orden: primero como vienen en lineas y después los extras
                const orderSkus = (lineas || []).map(x => normSku(x.productoCodigo)).filter(Boolean);
                const seen = new Set();
                const rows = [];

                orderSkus.forEach(sku => {
                    if (seen.has(sku)) return;
                    seen.add(sku);
                    if (map.has(sku)) rows.push(map.get(sku));
                });

                for (const [sku, obj] of map.entries()) {
                    if (!seen.has(sku)) rows.push(obj);
                }

                // 4) Render
                compTbody.innerHTML = "";

                if (!rows.length) {
                    compTbody.innerHTML = `<tr><td colspan="12" class="text-center text-muted">Sin datos.</td></tr>`;
                } else {
                    let tKgPed = 0, tCajPed = 0, tKgConf = 0, tCajConf = 0, tKgSur = 0, tCajSur = 0;
        rows.forEach((r, i) => {
            const difKg = (r.kgSurtido || 0) - (r.kgConfirmadas || 0);
            const difCaj = (r.cajasSurtidas || 0) - (r.cajasConfirmadas || 0);

            const baseCajas = (r.cajasConfirmadas || 0);
            const baseKg = (r.kgConfirmadas || 0);

            tKgPed += Number(r.kgPedido || 0);
            tCajPed += Number(r.cajasPedido || 0);
            tKgConf += Number(r.kgConfirmadas || 0);
            tCajConf += Number(r.cajasConfirmadas || 0);
            tKgSur += Number(r.kgSurtido || 0);
            tCajSur += Number(r.cajasSurtidas || 0);

            const estado = baseCajas > 0
                ? (r.cajasSurtidas >= baseCajas
                    ? "COMPLETO"
                    : (r.cajasSurtidas > 0 ? "INCOMPLETO" : "NO SURTIDO"))
                : baseKg > 0
                    ? (r.kgSurtido >= baseKg
                        ? "COMPLETO"
                        : (r.kgSurtido > 0 ? "INCOMPLETO" : "NO SURTIDO"))
                    : ((r.kgSurtido > 0 || r.cajasSurtidas > 0) ? "SURTIDO SIN CONF." : "SIN CONFIRMAR");

            const prod = soloNombreProducto(r.productoNombre, r.productoCodigo);

            compTbody.insertAdjacentHTML('beforeend', `
                <tr>
                    <td>${i + 1}</td>
                    <td>${r.sku}</td>
                    <td>${prod}</td>
                    <td class="text-end">${fmtNum(r.kgPedido, 2)}</td>
                    <td class="text-end">${fmtNum(r.cajasPedido, 0)}</td>
                    <td class="text-end col-conf">${fmtNum(r.kgConfirmadas, 2)}</td>
                    <td class="text-end col-conf">${fmtNum(r.cajasConfirmadas, 0)}</td>
                    <td class="text-end">${fmtNum(r.kgSurtido, 2)}</td>
                    <td class="text-end">${fmtNum(r.cajasSurtidas, 0)}</td>
                    <td class="text-end">${fmtNum(difKg, 2)}</td>
                    <td class="text-end">${fmtNum(difCaj, 0)}</td>
                            <td class="${estado === 'COMPLETO'
                                ? 'estado-completo'
                                : estado === 'INCOMPLETO'
                                    ? 'estado-incompleto'
                                    : 'estado-sin-confirmar'
                            }">
            ${estado}
        </td>
                </tr>
            `);
        });
              

                           if (totKgPedEl)   totKgPedEl.textContent   = fmtNum(tKgPed, 2);
                           if (totCajPedEl)  totCajPedEl.textContent  = fmtNum(tCajPed, 0);
                           if (totKgConfEl)  totKgConfEl.textContent  = fmtNum(tKgConf, 2);
                           if (totCajConfEl) totCajConfEl.textContent = fmtNum(tCajConf, 0);
                           if (totKgSurEl)   totKgSurEl.textContent   = fmtNum(tKgSur, 2);
                           if (totCajSurEl)  totCajSurEl.textContent  = fmtNum(tCajSur, 0);
                  
                }

                new bootstrap.Modal(modalEl).show();

            } catch (e) {
                console.error(e);
                compTbody.innerHTML = `<tr><td colspan="12" class="text-danger text-center">Error al cargar el detalle.</td></tr>`;
                new bootstrap.Modal(modalEl).show();
            }
        }

        function wireClickConsecutivo() {
            const table = document.querySelector('.table-responsive-sticky table.table');
            if (!table) return;

            const tbody = table.querySelector('tbody');
            if (!tbody) return;

            if (tbody.dataset.wiredClick === "1") return;
            tbody.dataset.wiredClick = "1";

            tbody.addEventListener('click', function (ev) {
                const a = ev.target.closest('a.ver-tr');
                if (!a) return;

                ev.preventDefault();

                const id = a.getAttribute('data-id');
                const cons = a.getAttribute('data-cons') || a.textContent.trim();
                if (id) cargarDetalleTr(id, cons);
            });
        }

        function normMultiText(s) {
            return (s ?? '')
                .toString()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .toLowerCase()
                .trim();
        }

        function initMultiDropdownSearch(rootId) {
            const root = document.getElementById(rootId);

            if (!root) return;

            const search = root.querySelector('.multi-picker-search');
            const options = Array.from(root.querySelectorAll('.multi-picker-option'));

            if (!search || !options.length) return;

            search.addEventListener('input', function () {
                const q = normMultiText(search.value);
                const words = q.split(/\s+/).filter(Boolean);

                options.forEach(opt => {
                    const input = opt.querySelector('input');
                    const text = normMultiText(`${opt.innerText} ${input?.value || ''}`);
                    const visible = words.every(w => text.includes(w));

                    opt.style.display = visible ? 'flex' : 'none';
                });
            });

            root.addEventListener('shown.bs.dropdown', function () {
                setTimeout(() => {
                    search.focus();
                    search.select();
                }, 0);
            });
        }

        function initMultiDropdown(rootId, checkClass, hiddenContainerId, hiddenName) {
            const root = document.getElementById(rootId);
            if (!root) return;

            const labelSpan = root.querySelector('.multi-label');
            const checks = root.querySelectorAll('.' + checkClass);
            const hidden = document.getElementById(hiddenContainerId);

            function refresh() {
                hidden.innerHTML = "";
                const texts = [];

                checks.forEach(ch => {
                    if (ch.checked) {
                        texts.push(ch.getAttribute('data-text') || ch.value);

                        const inp = document.createElement('input');
                        inp.type = 'hidden';
                        inp.name = hiddenName;
                        inp.value = ch.value;
                        hidden.appendChild(inp);
                    }
                });

                if (texts.length === 0) labelSpan.textContent = '(Todos)';
                else if (texts.length <= 3) labelSpan.textContent = texts.join(', ');
                else labelSpan.textContent = texts.length + ' seleccionados';
            }

            checks.forEach(ch => ch.addEventListener('change', refresh));
            refresh();
        }

        function initHeaderSortingTransferencias() {
            const table = document.querySelector('.table-responsive-sticky table.table');
            if (!table) return;

            const thead = table.querySelector('thead');
            const tbody = table.querySelector('tbody');
            if (!thead || !tbody) return;

            const ths = thead.querySelectorAll('th[data-sort-col]');
            if (!ths.length) return;

            const state = { index: null, dir: null };

            function clearIcons() {
                ths.forEach(th => th.textContent = th.textContent.replace(/\s*[▲▼]$/, ''));
            }

            function getCellValue(tr, index) {
                const td = tr.children[index];
                if (!td) return '';
                return td.innerText.trim();
            }

            function parseValue(val, type) {
                if (type === 'num') {
                    const n = parseFloat(val.replace(/[^\d.-]/g, ''));
                    return isNaN(n) ? 0 : n;
                }
                if (type === 'date') {
                    const d = new Date(val);
                    return isNaN(d.getTime()) ? 0 : d.getTime();
                }
                return val.toUpperCase();
            }

            function sortBody(index, dir) {
                const rows = Array.from(tbody.querySelectorAll('tr'));
                if (!rows.length) return;

                if (index == null || dir == null) {
                    rows.sort((a, b) => (parseInt(a.dataset.index || '0', 10) - parseInt(b.dataset.index || '0', 10)));
                } else {
                    const type = ths[index].dataset.sortType || 'text';
                    rows.sort((a, b) => {
                        const va = parseValue(getCellValue(a, index), type);
                        const vb = parseValue(getCellValue(b, index), type);
                        if (va < vb) return -1;
                        if (va > vb) return 1;
                        return 0;
                    });
                    if (dir === 'desc') rows.reverse();
                }

                rows.forEach(r => tbody.appendChild(r));
            }

            ths.forEach((th, index) => {
                th.style.cursor = 'pointer';

                th.addEventListener('click', () => {
                    if (state.index === index) {
                        state.dir = state.dir === 'asc' ? 'desc' : state.dir === 'desc' ? null : 'asc';
                    } else {
                        state.index = index;
                        state.dir = 'asc';
                    }

                    clearIcons();

                    if (!state.dir) {
                        state.index = null;
                    } else {
                        th.textContent = th.textContent.replace(/\s*[▲▼]$/, '') + (state.dir === 'asc' ? ' ▲' : ' ▼');
                    }

                    sortBody(state.index, state.dir);
                });
            });
        }
        document.addEventListener('DOMContentLoaded', function () {
            initMultiDropdown('dd-sucursal-tr', 'multi-check-sucursal-tr', 'dd-sucursal-tr-hidden', 'SucursalesSeleccionadas');
            initMultiDropdown('dd-estatus-tr', 'multi-check-estatus-tr', 'dd-estatus-tr-hidden', 'EstatusSeleccionados');

            initMultiDropdownSearch('dd-sucursal-tr');
            initMultiDropdownSearch('dd-estatus-tr');

            wireClickConsecutivo();
            initHeaderSortingTransferencias();

            const btn = document.getElementById('btn-cancelar-tr');
            btn?.addEventListener('click', (ev) => { ev.preventDefault(); cancelarTransferenciaActual(); });

            const inpFecha = document.getElementById('trm-fecha-sol-input');
            const btnSave = document.getElementById('btn-fecha-sol-save');
            const btnCancel = document.getElementById('btn-fecha-sol-cancel');

            inpFecha?.addEventListener('change', () => {
                if (inpFecha.disabled) return;
                const changed = (inpFecha.value && inpFecha.value !== trFechaSolOriginal);
                setFechaEditUI(changed);
            });

            btnSave?.addEventListener('click', (ev) => { ev.preventDefault(); guardarFechaSolicitudActual(); });

            btnCancel?.addEventListener('click', (ev) => {
                ev.preventDefault();
                if (!inpFecha) return;
                inpFecha.value = trFechaSolOriginal || "";
                setFechaEditUI(false);
            });
        });
    </script>
