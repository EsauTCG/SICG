        </div>

        <div class="st-steps" aria-label="Flujo de captura">
            <div class="st-step" id="stStepSucursal">
                <span class="st-step-number">1</span>
                <span class="st-step-text">
                    <span class="st-step-title">Sucursal</span>
                    <span class="st-step-help">Elige el origen/destino autorizado</span>
                </span>
            </div>
            <div class="st-step" id="stStepFecha">
                <span class="st-step-number">2</span>
                <span class="st-step-text">
                    <span class="st-step-title">Fecha</span>
                    <span class="st-step-help">Confirma cuándo se solicita</span>
                </span>
            </div>
            <div class="st-step" id="stStepProductos">
                <span class="st-step-number">3</span>
                <span class="st-step-text">
                    <span class="st-step-title">Productos</span>
                    <span class="st-step-help">SKU, kilos, cajas y disponible</span>
                </span>
            </div>
            <div class="st-step" id="stStepGuardar">
                <span class="st-step-number">4</span>
                <span class="st-step-text">
                    <span class="st-step-title">Guardar</span>
                    <span class="st-step-help">Revisa y confirma</span>
                </span>
            </div>
        </div>

        <div class="content-block">
            <form id="formST" asp-action="Guardar" asp-controller="Transferencias" method="post">
                <input type="hidden" name="accion" id="accionField" value="salir" />
                @Html.AntiForgeryToken()

                <div class="st-guidance">
                    <div class="st-guidance-main">
                        <i class="bi bi-lightning-charge-fill"></i>
                        <span>Flujo rápido: primero sucursal y fecha; después productos. Presupuesto y disponible se calculan automáticamente.</span>
                    </div>
                    <small><i class="bi bi-info-circle me-1"></i>Los campos en gris son informativos y no se capturan manualmente.</small>
                </div>

                <div class="row g-3 st-capture-grid">
                    <div class="col-12 col-xl-5">
                        <div class="panel h-100">
                            <div class="panel-head">
                                <span class="st-card-title">
                                    <span class="st-num">1</span>
                                    <span><i class="bi bi-clipboard-check"></i> Datos de la solicitud</span>
                                </span>
                            </div>
                            <div class="panel-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-4 col-xl-12 st-field-readonly">
                                        <label class="form-label">Consecutivo</label>
                                        <input asp-for="Consecutivo" class="form-control" readonly />
                                    </div>

                                    <div class="col-12 col-md-4 col-xl-12">
                                        <label class="form-label">Sucursal</label>
                                        <select asp-for="Sucursal" class="form-select st-primary-field" asp-items="Model.SeriesDisponibles">
                                            <option value="">Selecciona Sucursal</option>
                                        </select>
                                        <span asp-validation-for="Sucursal" class="text-danger small"></span>
                                    </div>

                                    <div class="col-12 col-md-4 col-xl-12">
                                        <label class="form-label">Fecha Solicitud</label>
                                        <input asp-for="FechaSolicitud" type="date" class="form-control st-primary-field" />
                                        <span asp-validation-for="FechaSolicitud" class="text-danger small"></span>
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label">Observación</label>
                                        <textarea asp-for="Observacion" rows="2" class="form-control" placeholder="Comentarios de la transferencia, prioridad, referencia o indicaciones..."></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-xl-7">
                        <div class="panel h-100">
                            <div class="panel-head st-panel-head-split">
                                <span class="st-card-title">
                                    <span class="st-num">2</span>
                                    <span><i class="bi bi-speedometer2"></i> Resumen rápido</span>
                                </span>
                                <span class="st-mini-note">Vista para validar antes de guardar</span>
                            </div>
                            <div class="panel-body">
                                <div class="st-summary-grid">
                                    <div class="st-summary-card">
                                        <i class="bi bi-box-seam"></i>
                                        <span class="st-summary-label">Productos</span>
                                        <span class="st-summary-value" id="stItemCount">0</span>
                                        <span class="st-summary-help">Renglones capturados en la solicitud.</span>
                                    </div>

                                    <div class="st-summary-card">
                                        <i class="bi bi-truck"></i>
                                        <span class="st-summary-label">Total kg</span>
                                        <span class="st-summary-value"><span id="totKg">0.00</span></span>
                                        <span class="st-summary-help">Suma automática de la columna Cantidad.</span>
                                    </div>

                                    <div class="st-summary-card">
                                        <i class="bi bi-shield-check"></i>
                                        <span class="st-summary-label">Estado</span>
                                        <span class="st-summary-value" id="stEstadoCaptura" style="font-size:1rem;line-height:1.25;">Pendiente</span>
                                        <span class="st-summary-help">Completa sucursal, fecha y al menos un producto.</span>
                                    </div>
                                </div>

                                <div class="st-products-tip mt-3" style="margin-left:0;margin-right:0;">
                                    <i class="bi bi-magic"></i>
                                    <span>Escribe dos letras del producto, selecciónalo y captura cajas o kilos. El sistema recalcula presupuesto, disponible y total.</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="panel st-products-panel">
                    <div class="panel-head st-panel-head-split">
                        <span class="st-card-title">
                            <span class="st-num">3</span>
                            <span><i class="bi bi-boxes"></i> Productos solicitados</span>
                        </span>
                        <span class="st-mini-note">Captura simple por producto</span>
                    </div>

                    <div class="st-products-tip">
                        <i class="bi bi-info-circle"></i>
                        <span>Si el disponible queda negativo, el renglón se marca en rojo para corregir antes de guardar.</span>
                    </div>

                    <div class="panel-body p-0">
                        <div class="table-responsive st-table-wrap">
                            <table class="table table-sm table-hover align-middle mb-0 st-product-table">
                                <thead>
                                    <tr>
                                        <th style="width:50px">#</th>
                                        <th>Producto</th>
                                        <th style="width:140px">Cantidad kg</th>
                                        <th style="width:120px">Cajas</th>
                                        <th style="width:140px">Presupuesto</th>
                                        <th style="width:140px">Disponible</th>
                                        <th style="width:115px">Comentario</th>
                                        <th style="width:70px">Quitar</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyArt">
                                            @for (int i = 0; i < items.Count; i++)
                                            {
                                                <tr>
                                                    <td>@(i + 1)</td>
                                                    <td>
                                                        <input name="Productos[@i].ProductoNombre" class="form-control productoInput" placeholder="Buscar producto…" value="@items[i].ProductoNombre" />
                                                        <input type="hidden" name="Productos[@i].ProductoCodigo" class="productoCodigo" value="@items[i].ProductoCodigo" />
                                                    </td>
                                                    <td>
                                                        <input name="Productos[@i].CantidadKg"
                                                               type="number"
                                                               step="0.01"
                                                               min="0.01"
                                                               class="form-control cant"
                                                               value="@(items[i].CantidadKg == 0 ? 0 : items[i].CantidadKg)" />
                                                    </td>
                                                    <td>
                                                        <input name="Productos[@i].Cajas"
                                                               type="number"
                                                               step="1"
                                                               min="0"
                                                               inputmode="numeric"
                                                               pattern="[0-9]*"
                                                               class="form-control cajas"
                                                               value="@(items[i].Cajas <= 0 ? 0 : (int)Math.Round(items[i].Cajas))" />
                                                    </td>

                                                    <td>
                                                        <input name="Productos[@i].Presupuesto"
                                                               type="number"
                                                               step="0.01"
                                                               min="0"
                                                               class="form-control bg-light"
                                                               value="@(items[i].Presupuesto == 0 ? 0 : items[i].Presupuesto)"
                                                               readonly />
                                                    </td>
                                                    <td>
                                                        <input name="Productos[@i].Disponible"
                                                               type="number"
                                                               step="0.01"
                                                               min="0"
                                                               class="form-control bg-light"
                                                               value="@(items[i].Disponible == 0 ? 0 : items[i].Disponible)"
                                                               readonly />
                                                    </td>
                                                    <td class="text-center">
                                                        <button type="button"
                                                                class="btn btn-light btn-sm cell-btn @(string.IsNullOrWhiteSpace(items[i].Nota) ? "" : "note-exists")"
                                                                title="@(string.IsNullOrWhiteSpace(items[i].Nota) ? "Agregar comentario" : items[i].Nota)"
                                                                data-bs-toggle="tooltip"
                                                                onclick="abrirComentarioModal(this)">
                                                            <i class="bi bi-chat-left-text"></i>
                                                        </button>
                                                        <input type="hidden" name="Productos[@i].Nota" class="notaHidden" value="@items[i].Nota" />
                                                    </td>
                                                    <td class="text-center">
                                                        <a href="#" class="btn btn-outline-danger btn-sm cell-btn" title="Eliminar" data-bs-toggle="tooltip" onclick="eliminarFila(this);return false;">
                                                            <i class="bi bi-trash"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                            @if (!items.Any())
                                            {
                                                <tr>
                                                    <td>1</td>
                                                    <td>
                                                        <input name="Productos[0].ProductoNombre" class="form-control productoInput" placeholder="Buscar producto…" />
                                                        <input type="hidden" name="Productos[0].ProductoCodigo" class="productoCodigo" />
                                                    </td>
                                                    <td>
                                                        <input name="Productos[0].CantidadKg"
                                                               type="number"
                                                               step="0.01"
                                                               min="0.01"
                                                               class="form-control cant"
                                                               value="0" />
                                                    </td>
                                                    <td>
                                                        <input name="Productos[0].Cajas"
                                                               type="number"
                                                               step="1"
                                                               min="0"
                                                               inputmode="numeric"
                                                               pattern="[0-9]*"
                                                               class="form-control cajas"
                                                               value="0" />
                                                    </td>
                                                    <td>
                                                        <input name="Productos[0].Presupuesto"
                                                               type="number"
                                                               step="0.01"
                                                               min="0"
                                                               class="form-control bg-light"
                                                               value="0"
                                                               readonly />
                                                    </td>
                                                    <td>
                                                        <input name="Productos[0].Disponible"
                                                               type="number"
                                                               step="0.01"
                                                               min="0"
                                                               class="form-control bg-light"
                                                               value="0"
                                                               readonly />
                                                    </td>
                                                    <td class="text-center">
                                                        <button type="button" class="btn btn-light btn-sm cell-btn" title="Agregar comentario" data-bs-toggle="tooltip" onclick="abrirComentarioModal(this)">
                                                            <i class="bi bi-chat-left-text"></i>
                                                        </button>
                                                        <input type="hidden" name="Productos[0].Nota" class="notaHidden" />
                                                    </td>
                                                    <td class="text-center">
                                                        <a href="#" class="btn btn-outline-danger btn-sm cell-btn" title="Eliminar" data-bs-toggle="tooltip" onclick="eliminarFila(this);return false;">
                                                            <i class="bi bi-trash"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="st-product-actions">
                    <div class="st-product-actions-left">
                        <a href="#" onclick="agregarFila();return false;" class="btn btn-reflejo st-add-btn">
                            <i class="bi bi-plus-circle"></i> Agregar producto
                        </a>
                        <span class="st-empty-hint"><i class="bi bi-keyboard me-1"></i>También puedes capturar con teclado; Enter no envía el formulario.</span>
                    </div>
                    <div class="st-product-actions-right">
                        <span class="st-mini-note"><i class="bi bi-calculator me-1"></i>Total kg se actualiza automáticamente.</span>
                    </div>
                </div>

                <div class="st-sticky-actions">
                    <div>
                        <strong>Último paso: revisar y guardar solicitud</strong>
                        <span>Valida sucursal, fecha, productos, kilos, cajas y disponible antes de confirmar.</span>
                    </div>

                    <div class="st-actions">
                        <button type="submit" name="accion" value="salir" class="tbtn primary">
                            <i class="bi bi-check2-circle"></i> Guardar y salir
                        </button>
                        <button type="submit" name="accion" value="nuevo" class="tbtn primary">
                            <i class="bi bi-plus-circle"></i> Guardar y nueva
                        </button>
                        <a class="tbtn" href="/Home/inicio">
                            <i class="bi bi-x-lg"></i> Cancelar
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL: Comentario -->
<div class="modal fade" id="comentarioModal" tabindex="-1" aria-labelledby="comentarioLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="comentarioLabel">Comentario del producto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <strong id="skuInfo">SKU: -</strong>
                </div>
                <textarea id="comentarioText" class="form-control" rows="4" placeholder="Escribe instrucciones, observaciones o aclaraciones del producto..."></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" id="btnGuardarComentario" class="btn btn-danger">
                    <i class="bi bi-check2-circle"></i> Guardar comentario
                </button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    @* <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js"></script>

    <style>
        .ui-autocomplete {
        z-index: 2000 !important
        }
    </style>

    <script>
        // ===== Toast / Overlay =====
        let toastInst = null;
        let pendingPresupuestos = 0; // para saber cuándo esconder el spinner

        function ensureToast() {
        if (document.getElementById('saveToast')) return;
        const wrap = document.createElement('div');
        wrap.innerHTML = `
        <div aria-live="polite" aria-atomic="true" class="position-relative">
        <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1080">
        <div id="saveToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
        <i class="bi bi-check2-circle me-2"></i>
        <strong class="me-auto">Transferencia</strong>
        <small>ahora</small>
        <button type="button" class="btn-close ms-2 mb-1" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body" id="saveToastBody">Guardado.</div>
        </div>
        </div>
        </div>`;
        document.body.appendChild(wrap);
        }
        function showToast(msg) {
        ensureToast();
        document.getElementById('saveToastBody').innerText = msg || 'Listo.';
        const el = document.getElementById('saveToast');
        if (!toastInst && window.bootstrap) toastInst = new bootstrap.Toast(el, { delay: 2200 });
        toastInst ? toastInst.show() : alert(msg || 'Listo.');
        }
        function ensureOverlay() {
        if (document.getElementById('savingOverlay')) return;
        const ov = document.createElement('div');
        ov.id = 'savingOverlay';
        ov.style.cssText = 'display:none;position:fixed;inset:0;background:rgba(255,255,255,.6);z-index:1070';
        ov.innerHTML = `
        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center">
        <div class="spinner-border" role="status" aria-hidden="true"></div>
        <div class="mt-2">Procesando…</div>
        </div>`;
        document.body.appendChild(ov);
        }
        function showOverlay(blocking) {
        ensureOverlay();
        const el = document.getElementById('savingOverlay');
        if (!el) return;
        // En consultas de presupuesto no bloquea toques/clicks en móvil.
        // En guardado sí bloquea para evitar doble envío.
        el.style.pointerEvents = blocking ? 'auto' : 'none';
        el.style.display = 'block';
        }
        function hideOverlay() {
        const el = document.getElementById('savingOverlay');
        if (el) {
        el.style.display = 'none';
        el.style.pointerEvents = 'none';
        }
        }

        // ===== Utilidades =====
        let modalElem, modalInstance, currentRow = null;
        const toUpper = (s) => (s ?? "").toString().toUpperCase().trim();

        function enableTooltips(scope) {
        (scope || document).querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
        if (window.bootstrap && bootstrap.Tooltip) { new bootstrap.Tooltip(el); }
        });
        }

        function renumerar() {
        $("#tbodyArt tr").each(function (i) {
        $(this).find("td:first").text(i + 1);
        $(this).find("input").each(function () {
        const n = $(this).attr("name"); if (!n) return;
        $(this).attr("name", n.replace(/Productos\[\d+\]/, `Productos[${i}]`));
        });
        });
        }

        function agregarFila() {
        const i = $("#tbodyArt tr").length;
        const html = `
        <tr>
        <td>${i + 1}</td>
        <td>
        <input name="Productos[${i}].ProductoNombre" class="form-control productoInput" placeholder="Buscar producto…" />
        <input type="hidden" name="Productos[${i}].ProductoCodigo" class="productoCodigo" />
        </td>
        <td>
        <input name="Productos[${i}].CantidadKg" type="number" step="0.01" min="0.01" class="form-control cant" value="0" />
        </td>
        <td>
        <input name="Productos[${i}].Cajas"
        type="number"
        step="1"
        min="0"
        inputmode="numeric"
        pattern="[0-9]*"
        class="form-control cajas"
        value="0" />
        </td>
        <td>
        <input name="Productos[${i}].Presupuesto"
        type="number"
        step="0.01"
        min="0"
        class="form-control bg-light"
        value="0"
        readonly />
        </td>
        <td>
        <input name="Productos[${i}].Disponible"
        type="number"
        step="0.01"
        class="form-control bg-light"
        value="0"
        readonly />
        </td>
        <td class="text-center">
        <button type="button" class="btn btn-light btn-sm cell-btn" title="Agregar comentario" data-bs-toggle="tooltip" onclick="abrirComentarioModal(this)">
        <i class="bi bi-chat-left-text"></i>
        </button>
        <input type="hidden" name="Productos[${i}].Nota" class="notaHidden" />
        </td>
        <td class="text-center">
        <a href="#" class="btn btn-outline-danger btn-sm cell-btn" title="Eliminar" data-bs-toggle="tooltip" onclick="eliminarFila(this);return false;">
        <i class="bi bi-trash"></i>
        </a>
        </td>
        </tr>`;
        $("#tbodyArt").append(html);
        const $last = $("#tbodyArt tr:last .productoInput");
        initAutoComplete($last);
        enableTooltips($("#tbodyArt tr:last")[0]);
        }

        function eliminarFila(a) {
        const tr = a.closest("tr"); tr.remove();
        if ($("#tbodyArt tr").length === 0) agregarFila();
        renumerar(); calcKg();
        }

        let calcKgRaf = null;
        function calcKgNow() {
        let t = 0;
        $("#tbodyArt .cant").each(function () { t += parseFloat($(this).val()) || 0; });
        $("#totKg").text(t.toFixed(2));
        }
        function calcKg() {
        if (calcKgRaf) cancelAnimationFrame(calcKgRaf);
        calcKgRaf = requestAnimationFrame(function () {
        calcKgRaf = null;
        calcKgNow();
        });
        }

        // ✅ Resetear fila (cuando NO hay presupuesto)
        function resetRow($row) {
        $row.find(".productoInput").val("");
        $row.find(".productoCodigo").val("");

        $row.find(".cant").val("0.00");
        $row.find(".cajas").val("0").attr("placeholder", "");

        $row.find("input[name$='.Presupuesto']").val("0.00");
        $row.find("input[name$='.Disponible']").val("0.00").data("base", 0);

        $row.data("factorCaja", 0);

        $row.find(".notaHidden").val("");
        const $btnNota = $row.find("button.cell-btn").first();
        $btnNota.removeClass("note-exists")
        .attr("title", "Agregar comentario")
        .attr("data-bs-original-title", "Agregar comentario");

        $row.removeClass("table-danger");
        calcKg();
        }

        // ✅ NUEVO: Recalcular fila con lo que ya capturó el usuario (evita “brinco” al cambiar sucursal)
        function recalcularFila($row) {
        const cant = parseFloat($row.find(".cant").val()) || 0;

        const $dispInput = $row.find("input[name$='.Disponible']");
        const dispBase = parseFloat($dispInput.data("base"));
        const dispOriginal = isFinite(dispBase) ? dispBase : (parseFloat($dispInput.val()) || 0);

        const dispFinal = dispOriginal - cant;
        $dispInput.val(dispFinal.toFixed(2));

        if (dispFinal < 0) $row.addClass("table-danger");
        else $row.removeClass("table-danger");

        return dispFinal;
        }

        // ====== MODAL DE COMENTARIO ======
        function abrirComentarioModal(btn) {
        currentRow = $(btn).closest("tr");
        const sku = toUpper(currentRow.find(".productoCodigo").val());
        const nota = currentRow.find(".notaHidden").val() || "";
        $("#skuInfo").text(`SKU: ${sku || "-"}`);
        $("#comentarioText").val(nota);
        if (!modalElem) {
        modalElem = document.getElementById('comentarioModal');
        modalInstance = new bootstrap.Modal(modalElem);
        }
        modalInstance.show();
        setTimeout(() => { $("#comentarioText").trigger("focus"); }, 250);
        }
        $("#btnGuardarComentario").on("click", function () {
        if (!currentRow) return;
        const txt = $("#comentarioText").val() || "";
        const hidden = currentRow.find(".notaHidden");
        const btn = currentRow.find(".cell-btn i.bi-chat-left-text").closest("button");
        hidden.val(txt);
        if (txt.trim()) {
        btn.addClass("note-exists").attr("title", txt).attr("data-bs-original-title", txt);
        } else {
        btn.removeClass("note-exists").attr("title", "Agregar comentario").attr("data-bs-original-title", "Agregar comentario");
        }
        if (window.bootstrap && bootstrap.Tooltip) {
        const tip = bootstrap.Tooltip.getInstance(btn[0]); if (tip) { tip.dispose(); }
        new bootstrap.Tooltip(btn[0]);
        }
        modalInstance.hide();
        });

        // ====== AUTOCOMPLETE ======
        function initAutoComplete($el) {
        $el.autocomplete({
        appendTo: 'body',
        position: { my: "left top+2", at: "left bottom" },
        minLength: 2,
        source: function (request, response) {
        $.getJSON('/Transferencias/BuscarProductosAutocomplete', { term: request.term }, data => {
        response(data || []);
        });
        },
        focus: function () { return false; },
        select: function (e, ui) {
        const row = $(this).closest("tr");
        const label = (ui.item.label || "").toString().toUpperCase();
        const sku = (ui.item.value || "").toString().toUpperCase();

        const kilosCaja = parseFloat(ui.item.kilosCaja ?? ui.item.KilosCaja) || 0;

        $(this).val(label);
        row.find(".productoCodigo").val(sku);

        const $cajasInput = row.find(".cajas");
        if (kilosCaja > 0) {
        row.data("factorCaja", kilosCaja);
        $cajasInput.attr("placeholder", `1 caja = ${kilosCaja.toFixed(2)} kg`);
        } else {
        row.data("factorCaja", 0);
        $cajasInput.attr("placeholder", "");
        }

        cargarPresupuestoRow(row);
        return false;
        },
        open: function () {
        const $menu = $(this).autocomplete("widget");
        $menu.css("width", $(this).outerWidth());
        }
        }).on('input', function () {
        const s = this.selectionStart, e = this.selectionEnd;
        this.value = toUpper(this.value);
        this.setSelectionRange(s, e);

        const $row = $(this).closest("tr");
        $row.find(".productoCodigo").val("");
        $row.data("factorCaja", 0);
        $row.find(".cajas").attr("placeholder", "");
        });
        }

        // ====== ERRORES ======
        function clearErrors() {
        $('.is-invalid').removeClass('is-invalid');
        $('[data-valmsg-for]').text('');
        }
        function renderErrors(errors) {
        Object.entries(errors || {}).forEach(([key, msgs]) => {
        if (!msgs || !msgs.length) return;
        if (key) {
        const nameSel = `[name="${key}"]`;
        const spanSel = `[data-valmsg-for="${key}"]`;
        $(nameSel).addClass('is-invalid');
        const $span = $(spanSel);
        if ($span.length) $span.text(msgs[0]);
        } else {
        showToast(msgs[0]);
        }
        });
        const $first = $('.is-invalid').first();
        if ($first.length) {
        $('html, body').animate({ scrollTop: Math.max(0, $first.offset().top - 120) }, 250);
        }
        }

        // ====== Cargar presupuesto/disponible para una fila ======
        function cargarPresupuestoRow($row) {
        const sku = toUpper($row.find(".productoCodigo").val());
        const sucursal = ($("select[name='Sucursal']").val() || "").toString().trim();
        const fecha = $("input[name='FechaSolicitud']").val();

        if (!sku || !sucursal || !fecha) {
        $row.find("input[name$='.Presupuesto']").val("0.00");
        $row.find("input[name$='.Disponible']").val("0.00").data("base", 0);
        $row.find(".cajas").val("0").attr("placeholder", "");
        $row.data("factorCaja", 0);
        $row.removeClass('table-danger');
        return;
        }

        pendingPresupuestos++;

        $.getJSON('/Transferencias/PresupuestoDisponible', {
        sucursal: sucursal,
        sku: sku,
        fechaSolicitud: fecha
        }).done(function (data) {
        if (!data) return;

        const pres = parseFloat(data.presupuesto) || 0;
        const disp = parseFloat(data.disponible) || 0;
        const factorCajaSrv = parseFloat(data.factorCaja) || 0;

        const sinDisponible = disp <= 0; // <-- manda tu endpoint

        if (sinDisponible) {
        showToast(`No puedes agregar el SKU ${sku}: no tiene disponible para este producto.`);
        resetRow($row);
        setTimeout(() => { $row.find(".productoInput").trigger("focus"); }, 150);
        return;
        }

        const $presInput = $row.find("input[name$='.Presupuesto']");
        const $dispInput = $row.find("input[name$='.Disponible']");

        $presInput.val(pres.toFixed(2));
        $dispInput.val(disp.toFixed(2));
        $dispInput.data("base", disp);

        if (factorCajaSrv > 0) {
        $row.data("factorCaja", factorCajaSrv);
        }

        const factorCaja = parseFloat($row.data("factorCaja")) || 0;
        const $cajasInput = $row.find(".cajas");
        if (factorCaja > 0) $cajasInput.attr("placeholder", `1 caja = ${factorCaja.toFixed(2)} kg`);
        else $cajasInput.attr("placeholder", "");

        // ✅ clave: al recargar por cambio de sucursal/fecha, reaplica lo capturado
        const dispFinal = recalcularFila($row);
        if (dispFinal < 0) {
        showToast(`El SKU ${sku} se pasa del presupuesto. Disponible final: ${dispFinal.toFixed(2)} kg`);
        }

        }).fail(function (xhr) {
        console.error(xhr);
        const $presInput = $row.find("input[name$='.Presupuesto']");
        const $dispInput = $row.find("input[name$='.Disponible']");
        $presInput.val("0.00");
        $dispInput.val("0.00").data("base", 0);
        $row.find(".cajas").val("0").attr("placeholder", "");
        $row.data("factorCaja", 0);
        $row.addClass('table-danger');
        }).always(function () {
        pendingPresupuestos--;
        if (pendingPresupuestos <= 0) hideOverlay();
        });
        }

        let _fromCajas = false;

        // ====== Cambio de cantidad (kg): recalcula total, disponible simulado y cajas ======
        $(document).on("input", ".cant", function () {
        const $row = $(this).closest("tr");
        const cant = parseFloat($(this).val()) || 0;

        const $dispInput = $row.find("input[name$='.Disponible']");
        const dispBase = parseFloat($dispInput.data("base"));
        const dispOriginal = isFinite(dispBase) ? dispBase : (parseFloat($dispInput.val()) || 0);

        const dispFinal = dispOriginal - cant;
        $dispInput.val(dispFinal.toFixed(2));

        const factorCaja = parseFloat($row.data("factorCaja")) || 0;
        const $cajasInput = $row.find(".cajas");

        if (!_fromCajas) {
        if (factorCaja > 0) {
        const cajas = cant / factorCaja;
        $cajasInput.val(Math.round(cajas)); // entero
        } else {
        $cajasInput.val("0");
        }
        }

        if (dispFinal < 0) $row.addClass('table-danger');
        else $row.removeClass('table-danger');

        calcKg();
        });

        // ====== Cambio de cajas: recalcula kg y disponible simulado ======
        $(document).on("input", ".cajas", function () {
        const $row = $(this).closest("tr");
        const factorCaja = parseFloat($row.data("factorCaja")) || 0;

        const raw = ($(this).val() || "").toString().replace(",", ".");
        const cajas = parseFloat(raw);
        if (!isFinite(cajas)) return;

        _fromCajas = true;
        try {
        if (factorCaja > 0) {
        const kg = cajas * factorCaja;
        $row.find(".cant").val(kg.toFixed(2)).trigger("input");
        } else {
        $row.find(".cant").val("0.00").trigger("input");
        }
        } finally {
        _fromCajas = false;
        }
        });

        // ====== Cambio de sucursal o fecha: recargar todos los presupuestos ======
        $(document).on('change', "select[name='Sucursal'], input[name='FechaSolicitud']", function () {
        const sucursal = ($("select[name='Sucursal']").val() || "").toString().trim();
        const fecha = $("input[name='FechaSolicitud']").val();

        let haySku = false;
        $("#tbodyArt tr").each(function () {
        const sku = toUpper($(this).find(".productoCodigo").val());
        if (sku) { haySku = true; return false; }
        });

        if (!sucursal || !fecha) {
        $("#tbodyArt tr").each(function () {
        $(this).find("input[name$='.Presupuesto']").val("0.00");
        $(this).find("input[name$='.Disponible']").val("0.00").data("base", 0);
        $(this).find(".cajas").val("0").attr("placeholder", "");
        $(this).data("factorCaja", 0);
        $(this).removeClass('table-danger');
        });
        calcKg();
        hideOverlay();
        return;
        }

        if (!haySku) {
        $("#tbodyArt tr").each(function () {
        $(this).find("input[name$='.Presupuesto']").val("0.00");
        $(this).find("input[name$='.Disponible']").val("0.00").data("base", 0);
        $(this).find(".cajas").val("0").attr("placeholder", "");
        $(this).data("factorCaja", 0);
        $(this).removeClass('table-danger');
        });
        calcKg();
        hideOverlay();
        return;
        }

        showOverlay();
        pendingPresupuestos = 0;

        $("#tbodyArt tr").each(function () {
        const $row = $(this);
        const sku = toUpper($row.find(".productoCodigo").val());

        if (sku) {
        cargarPresupuestoRow($row);
        } else {
        $row.find("input[name$='.Presupuesto']").val("0.00");
        $row.find("input[name$='.Disponible']").val("0.00").data("base", 0);
        $row.find(".cajas").val("0").attr("placeholder", "");
        $row.data("factorCaja", 0);
        $row.removeClass('table-danger');
        }
        });
        });

        // ====== READY ======
        $(function () {
        $(".productoInput").each(function () { initAutoComplete($(this)); });

        $('#formST').on('keydown', 'input, select', function (e) {
        if (e.key === 'Enter') {
        e.preventDefault();
        e.stopPropagation();
        return false;
        }
        });

        const hoy = new Date(),
        y = hoy.getFullYear(),
        m = String(hoy.getMonth() + 1).padStart(2, '0'),
        d = String(hoy.getDate()).padStart(2, '0');
        $("input[name='FechaSolicitud']").attr("min", `${y}-${m}-${d}`);

        enableTooltips();

        $(document).on('click', 'button[form="formST"][type="submit"], #formST button[type="submit"]', function () {
        const val = (this.value || 'salir').toLowerCase();
        $('#accionField').val(val);
        });

        $('#formST').on('submit', async function (e) {
        const sucursal = ($("select[name='Sucursal']").val() || "").toString().trim();
        const fecha = $("input[name='FechaSolicitud']").val();
        let ok = true, msg = "";
        if (!sucursal) { ok = false; msg += "- Debes seleccionar una Sucursal.\n"; }

        let alMenosUno = false;
        $("#tbodyArt tr").each(function () {
        const $row = $(this);
        const code = toUpper($row.find(".productoCodigo").val());
        const kg = parseFloat($row.find(".cant").val()) || 0;
        const cajas = parseFloat($row.find(".cajas").val()) || 0;
        const disp = parseFloat($row.find("input[name$='.Disponible']").val()) || 0;
        const pres = parseFloat($row.find("input[name$='.Presupuesto']").val()) || 0;

        $row.removeClass('table-danger');

        if (code) {
        if (pres <= 0) {
        ok = false;
        msg += `- El producto ${code} no se puede agregar porque no tiene presupuesto asignado.\n`;
        $row.addClass('table-danger');
        return;
        }

        if (kg <= 0 || cajas <= 0) {
        ok = false;
        msg += `- El producto ${code} debe tener CANTIDAD y CAJAS mayores a 0. Corrige o elimina la línea.\n`;
        $row.addClass('table-danger');
        return;
        }

        if (disp < 0) {
        ok = false;
        msg += `- El producto ${code} no se puede agregar porque el DISPONIBLE es ${disp.toFixed(2)} (debe ser > 0).\n`;
        $row.addClass('table-danger');
        return;
        }

        alMenosUno = true;
        }
        });

        if (!alMenosUno) { ok = false; msg += "- Debes agregar al menos un producto con cantidad.\n"; }
        if (!fecha) { ok = false; msg += "- Debes seleccionar la fecha de solicitud.\n"; }

        if (!ok) {
        e.preventDefault();
        alert("Corrige:\n\n" + msg);
        return false;
        }

        e.preventDefault();
        clearErrors(); showOverlay(true);

        try {
        const form = document.getElementById('formST');
        const fd = new FormData(form);
        const token = $('input[name="__RequestVerificationToken"]').val();

        const resp = await fetch(form.action, {
        method: 'POST',
        body: fd,
        headers: { 'X-Requested-With': 'XMLHttpRequest', 'RequestVerificationToken': token || '' },
        credentials: 'same-origin'
        });

        const raw = await resp.text();
        let data = {};
        try { data = JSON.parse(raw); } catch { }

        hideOverlay();

        if (!resp.ok || !data.ok) {
        if (!data || data.ok === undefined) {
        console.warn('Respuesta no JSON:', raw.slice(0, 300));
        showToast('No se pudo guardar. Revisa la captura.');
        return false;
        }
        if (data.errors) renderErrors(data.errors);
        showToast(data.message || 'Revisa la captura de la solicitud.');
        return false;
        }

        if (data.sobrePresupuesto && data.skusSobrePresupuesto && data.skusSobrePresupuesto.length) {
        const lista = data.skusSobrePresupuesto.join(', ');
        showToast(`Transferencia guardada con folio ${data.folio}. SKUs sobre presupuesto: ${lista}. Queda pendiente de autorización.`);
        } else {
        showToast(`Transferencia guardada con folio ${data.folio}.`);
        }

        const accionSel = (data.accion || $('#accionField').val() || 'salir').toLowerCase();
        const url = data.redirect || (accionSel === 'nuevo' ? '/Transferencias/TransferenciasCedis' : '/Home/inicio');
        setTimeout(() => { window.location.href = url; }, 1200);

        } catch (err) {
        hideOverlay();
        console.error(err);
        showToast('Error de red. Intenta de nuevo.');
        }
        });
        });
    </script>

    <script>
        /* ============================================================
           FIX RESPONSIVO SIDEBAR - TRANSFERENCIA OPTIMIZADO
           Sin setInterval permanente para evitar congelamiento en móvil.
        ============================================================ */
        (function () {
            const sidebar =
                document.querySelector('.layout-sidebar') ||
                document.querySelector('.sidebar') ||
                document.querySelector('#sidebar') ||
                document.querySelector('.main-sidebar');

            const main =
                document.querySelector('.layout-main-content') ||
                document.querySelector('.layout-page') ||
                document.querySelector('main') ||
                document.body;

            if (!sidebar || !main) return;

            let lastPush = -1;
            let lastWidth = -1;
            let sidebarRaf = null;

            function applyTransferenciaSidebar() {
                if (window.innerWidth < 992) {
                    document.body.classList.remove('st-sidebar-final-ready');
                    document.documentElement.style.removeProperty('--st-sidebar-push');
                    document.documentElement.style.removeProperty('--st-page-width');
                    lastPush = -1;
                    lastWidth = -1;
                    return;
                }

                const sidebarStyle = window.getComputedStyle(sidebar);
                const sidebarRect = sidebar.getBoundingClientRect();
                const mainRect = main.getBoundingClientRect();

                const sidebarVisible =
                    sidebarStyle.display !== 'none' &&
                    sidebarStyle.visibility !== 'hidden' &&
                    sidebarRect.width > 40;

                let push = 0;

                if (sidebarVisible && sidebarRect.right > 0 && mainRect.left < sidebarRect.right - 2) {
                    push = Math.max(0, Math.ceil(sidebarRect.right - mainRect.left));
                }

                const pageWidth = Math.max(320, Math.floor(window.innerWidth - push));

                document.body.classList.add('st-sidebar-final-ready');

                if (push !== lastPush) {
                    document.documentElement.style.setProperty('--st-sidebar-push', push + 'px');
                    lastPush = push;
                }

                if (pageWidth !== lastWidth) {
                    document.documentElement.style.setProperty('--st-page-width', pageWidth + 'px');
                    lastWidth = pageWidth;
                }
            }

            function scheduleTransferenciaSidebar() {
                if (sidebarRaf) return;
                sidebarRaf = requestAnimationFrame(function () {
                    sidebarRaf = null;
                    applyTransferenciaSidebar();
                });
            }

            function trackFor(ms) {
                const end = performance.now() + ms;

                function frame(now) {
                    applyTransferenciaSidebar();
                    if (now < end) requestAnimationFrame(frame);
                }

                requestAnimationFrame(frame);
            }

            applyTransferenciaSidebar();

            window.addEventListener('resize', scheduleTransferenciaSidebar, { passive: true });
            window.addEventListener('orientationchange', function () { trackFor(700); }, { passive: true });

            if (window.ResizeObserver) {
                const resizeObserver = new ResizeObserver(scheduleTransferenciaSidebar);
                resizeObserver.observe(sidebar);
                resizeObserver.observe(main);
            }

            const mutationObserver = new MutationObserver(scheduleTransferenciaSidebar);

            mutationObserver.observe(sidebar, {
                attributes: true,
                attributeFilter: ['class', 'style', 'aria-expanded']
            });

            mutationObserver.observe(document.body, {
                attributes: true,
                attributeFilter: ['class', 'style']
            });

            sidebar.addEventListener('transitionstart', function () { trackFor(700); });
            sidebar.addEventListener('transitionrun', function () { trackFor(700); });
            sidebar.addEventListener('transitionend', function () { trackFor(250); });

            document.addEventListener('click', function (e) {
                if (e.target.closest('[data-bs-toggle], .sidebar-toggle, .layout-menu-toggle, .hamburger, .menu-toggle')) {
                    trackFor(700);
                }
            }, true);
        })();
    </script>



    <script>
        /* ============================================================
           FIX: CONVERSIÓN BIDIRECCIONAL CAJAS <-> KG
           - Cajas cambia kg.
           - Kg cambia cajas.
           - Refuerza el factor de caja aunque venga como:
             factorCaja, FactorCaja, kilosCaja, KilosCaja, kgCaja, PesoCaja, etc.
           - No cambia guardado, nombres, IDs ni modelo.
        ============================================================ */
        (function () {
            if (window.__stFixCajasKgActivo) return;
            window.__stFixCajasKgActivo = true;

            const factorPorSku = window.__stFactorCajaPorSku || (window.__stFactorCajaPorSku = {});
            let sincronizando = false;
            let fetchTimer = null;

            function n(v) {
                if (v === null || v === undefined) return 0;
                const x = parseFloat(String(v).replace(",", "."));
                return isFinite(x) ? x : 0;
            }

            function txt(v) {
                return String(v || "").trim().toUpperCase();
            }

            function getSku($row) {
                return txt($row.find(".productoCodigo").val());
            }

            function parseFactorFromObject(obj) {
                if (!obj) return 0;

                const posibles = [
                    "factorCaja", "FactorCaja",
                    "kilosCaja", "KilosCaja",
                    "kgCaja", "KgCaja", "KGCaja", "KgPorCaja",
                    "pesoCaja", "PesoCaja",
                    "pesoPorCaja", "PesoPorCaja",
                    "kilogramosCaja", "KilogramosCaja"
                ];

                for (const k of posibles) {
                    const val = n(obj[k]);
                    if (val > 0) return val;
                }

                return 0;
            }

            function parseFactorFromPlaceholder($row) {
                const ph = String($row.find(".cajas").attr("placeholder") || "");
                const m = ph.match(/=\s*([0-9]+(?:[.,][0-9]+)?)/);
                return m ? n(m[1]) : 0;
            }

            function setFactor($row, factor) {
                factor = n(factor);
                if (factor <= 0) return 0;

                const sku = getSku($row);
                if (sku) factorPorSku[sku] = factor;

                $row.data("factorCaja", factor);
                $row.attr("data-factor-caja", factor);

                const $cajas = $row.find(".cajas");
                $cajas.data("factorCaja", factor);
                $cajas.attr("data-factor-caja", factor);
                $cajas.attr("placeholder", `1 caja = ${factor.toFixed(2)} kg`);

                return factor;
            }

            function getFactor($row) {
                const sku = getSku($row);

                let factor =
                    n($row.data("factorCaja")) ||
                    n($row.attr("data-factor-caja")) ||
                    n($row.find(".cajas").data("factorCaja")) ||
                    n($row.find(".cajas").attr("data-factor-caja")) ||
                    (sku ? n(factorPorSku[sku]) : 0) ||
                    parseFactorFromPlaceholder($row);

                if (factor > 0) setFactor($row, factor);
                return factor;
            }

            function actualizarDisponibleYTotal($row, kg) {
                kg = n(kg);

                const $disp = $row.find("input[name$='.Disponible']");
                const base = n($disp.data("base"));
                if (base > 0 || $disp.data("base") !== undefined) {
                    const final = base - kg;
                    $disp.val(final.toFixed(2));
                    $row.toggleClass("table-danger", final < 0);
                }

                if (typeof calcKg === "function") {
                    calcKg();
                } else {
                    let total = 0;
                    $(".cant").each(function () { total += n($(this).val()); });
                    $("#totKg").text(total.toFixed(2));
                }

                if (typeof window.stRefreshExecutiveState === "function") {
                    setTimeout(window.stRefreshExecutiveState, 0);
                }
            }

            function fetchFactorSiHaceFalta($row, callback) {
                let factor = getFactor($row);
                if (factor > 0) {
                    callback(factor);
                    return;
                }

                const sku = getSku($row);
                const sucursal = $("select[name='Sucursal']").val() || "";
                const fecha = $("input[name='FechaSolicitud']").val() || "";

                if (!sku || !sucursal || !fecha) {
                    callback(0);
                    return;
                }

                clearTimeout(fetchTimer);
                fetchTimer = setTimeout(function () {
                    $.getJSON("/Transferencias/PresupuestoDisponible", {
                        sucursal: sucursal,
                        sku: sku,
                        fechaSolicitud: fecha
                    }).done(function (data) {
                        const factorSrv = parseFactorFromObject(data);
                        if (factorSrv > 0) {
                            factor = setFactor($row, factorSrv);
                        }
                        callback(factor || 0);
                    }).fail(function () {
                        callback(0);
                    });
                }, 80);
            }

            function recalcularDesdeCajas(input) {
                if (sincronizando) return;

                const $row = $(input).closest("tr");
                const cajas = n($(input).val());

                fetchFactorSiHaceFalta($row, function (factor) {
                    if (factor <= 0) return;

                    const kg = cajas * factor;

                    sincronizando = true;
                    try {
                        $row.find(".cant").val(kg.toFixed(2));
                    } finally {
                        sincronizando = false;
                    }

                    actualizarDisponibleYTotal($row, kg);
                });
            }

            function recalcularDesdeKg(input) {
                if (sincronizando) return;

                const $row = $(input).closest("tr");
                const kg = n($(input).val());

                fetchFactorSiHaceFalta($row, function (factor) {
                    if (factor <= 0) return;

                    const cajas = kg / factor;

                    sincronizando = true;
                    try {
                        $row.find(".cajas").val(Math.round(cajas));
                    } finally {
                        sincronizando = false;
                    }

                    actualizarDisponibleYTotal($row, kg);
                });
            }

            /*
               Captura el factor desde el autocomplete del producto.
               Esto no reemplaza el select original; solo guarda el dato
               de forma más persistente para la conversión.
            */
            $(document).on("autocompleteselect.stFixCajasKg", ".productoInput", function (e, ui) {
                const $row = $(this).closest("tr");
                const factor = parseFactorFromObject(ui && ui.item);
                if (factor > 0) setFactor($row, factor);
            });

            /*
               Intercepta futuras consultas de presupuesto/disponible para
               guardar el factor aunque el backend lo mande con otro nombre.
            */
            if (!$.getJSON.__stFixCajasKgWrapped) {
                const originalGetJSON = $.getJSON;

                $.getJSON = function (url, data, success) {
                    const req = originalGetJSON.apply($, arguments);

                    try {
                        const urlTxt = String(url || "");
                        if (urlTxt.indexOf("/Transferencias/PresupuestoDisponible") >= 0) {
                            req.done(function (resp) {
                                const factor = parseFactorFromObject(resp);
                                const sku = txt(data && data.sku);
                                if (factor > 0 && sku) {
                                    factorPorSku[sku] = factor;

                                    $("#tbodyArt tr").each(function () {
                                        const $row = $(this);
                                        if (getSku($row) === sku) setFactor($row, factor);
                                    });
                                }
                            });
                        }
                    } catch (err) {
                        console.warn("No se pudo registrar factorCaja:", err);
                    }

                    return req;
                };

                $.getJSON.__stFixCajasKgWrapped = true;
            }

            /*
               Se ejecuta después del handler original para corregir cualquier
               renglón que haya quedado sin sincronizar.
            */
            let cajasKgRaf = null;
            let cajasKgPendiente = null;

            function scheduleCajasKg(fn, el) {
                cajasKgPendiente = { fn: fn, el: el };

                if (cajasKgRaf) return;

                cajasKgRaf = requestAnimationFrame(function () {
                    const item = cajasKgPendiente;
                    cajasKgPendiente = null;
                    cajasKgRaf = null;

                    if (item && item.el) item.fn(item.el);
                });
            }

            $(document)
                .on("input.stFixCajasKg change.stFixCajasKg", ".cajas", function () {
                    scheduleCajasKg(recalcularDesdeCajas, this);
                })
                .on("input.stFixCajasKg change.stFixCajasKg", ".cant", function () {
                    scheduleCajasKg(recalcularDesdeKg, this);
                });

            /*
               Inicializa factores visibles si ya había productos cargados.
            */
            $(function () {
                $("#tbodyArt tr").each(function () {
                    const $row = $(this);
                    const factor = getFactor($row);
                    if (factor > 0) setFactor($row, factor);
                });
            });
        })();
    </script>


    <script>
        // ===== UX EJECUTIVO: Estado visual de la captura OPTIMIZADO =====
        (function () {
            let stStateRaf = null;
            let stStateTimer = null;

            function stNumber(value) {
                const n = parseFloat((value || "0").toString().replace(",", "."));
                return isFinite(n) ? n : 0;
            }

            function stFilledRows() {
                let count = 0;
                document.querySelectorAll("#tbodyArt tr").forEach(function (tr) {
                    const sku = (tr.querySelector(".productoCodigo")?.value || "").trim();
                    const kg = stNumber(tr.querySelector(".cant")?.value || "0");
                    if (sku && kg > 0) count++;
                });
                return count;
            }

            function stSetStep(step, active) {
                const el = document.querySelector('.st-step[data-step="' + step + '"]');
                if (el) el.classList.toggle("is-active", !!active);
            }

            window.stRefreshExecutiveState = function () {
                const sucursal = (document.querySelector("select[name='Sucursal']")?.value || "").trim();
                const fecha = (document.querySelector("input[name='FechaSolicitud']")?.value || "").trim();
                const rows = stFilledRows();
                const notas = Array.from(document.querySelectorAll(".notaHidden")).filter(function (x) {
                    return (x.value || "").trim();
                }).length;

                stSetStep(1, !!sucursal);
                stSetStep(2, !!fecha);
                stSetStep(3, rows > 0);
                stSetStep(4, rows > 0 && !!sucursal && !!fecha);

                const filled = document.getElementById("stRowsFilled");
                if (filled) filled.textContent = rows;

                const notes = document.getElementById("stNotesCount");
                if (notes) notes.textContent = notas;

                const summaryRows = document.getElementById("stSummaryRows");
                if (summaryRows) summaryRows.textContent = rows + " línea(s)";
            };

            function scheduleStRefresh(delay) {
                if (stStateTimer) clearTimeout(stStateTimer);

                stStateTimer = setTimeout(function () {
                    stStateTimer = null;

                    if (stStateRaf) return;
                    stStateRaf = requestAnimationFrame(function () {
                        stStateRaf = null;
                        window.stRefreshExecutiveState();
                    });
                }, delay || 0);
            }

            document.addEventListener("input", function (e) {
                if (e.target.matches("select[name='Sucursal'], input[name='FechaSolicitud'], .productoInput, .productoCodigo, .cant, .cajas, .notaHidden")) {
                    scheduleStRefresh(80);
                }
            }, true);

            document.addEventListener("change", function (e) {
                if (e.target.matches("select[name='Sucursal'], input[name='FechaSolicitud'], .productoInput, .productoCodigo, .cant, .cajas, .notaHidden")) {
                    scheduleStRefresh(80);
                }
            }, true);

            document.addEventListener("DOMContentLoaded", function () {
                scheduleStRefresh(80);
                scheduleStRefresh(700);

                const tbody = document.getElementById("tbodyArt");
                if (tbody && window.MutationObserver) {
                    new MutationObserver(function () {
                        scheduleStRefresh(120);
                    }).observe(tbody, { childList: true, subtree: true });
                }

                if (window.jQuery) {
                    jQuery(document).ajaxStop(function () {
                        scheduleStRefresh(120);
                    });
                }
            });
        })();
    </script>

}
