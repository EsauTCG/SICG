@using Plataforma_CG.ViewModels
@model SolicitudTransferenciaViewModel
@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Nueva Solicitud de Transferencia";
    var items = Model?.Productos ?? new List<SolicitudTransferenciaProductoVM>();
}

<style>
    :root {
        --brand-solid: #8B0000;
        --brand-dark: #5c0000;
        --brand-mid: #7a0000;
        --brand-soft: #f6e7e7;
        --brand-soft-2: #f1dcdc;
        --brand-line: #c99f9f;
        /* texto más oscuro */
        --brand-text: #111111;
        --panel: #ffffff;
        --panel-soft: #fff9f9;
        --muted: #222222;
        --line: #d8bcbc;
        --line-dark: #8f4c4c;
        --radius: 8px;
        --shadow: 0 1px 0 rgba(0,0,0,.04), 0 12px 24px rgba(70,12,12,.10);
        --shadow-sm: 0 6px 16px rgba(70,12,12,.08);
        --focus: 0 0 0 .2rem rgba(139,0,0,.18);
        --font: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        --brand-grad: linear-gradient(180deg, #b30000 0%, #8B0000 55%, #5c0000 100%);
        /* Escala compacta */
        --fs-base: 13px;
        --fs-sm: 12px;
        --fs-xs: 11px;
    }

    html, body {
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
        margin: 0;
        padding: 0;
        background: #ffffff !important;
        font-family: var(--font);
        color: var(--brand-text);
        font-size: var(--fs-base);
    }

    body {
        background: #ffffff !important;
        color: #111 !important;
    }

    .container,
    .container-fluid,
    main,
    .content-wrapper,
    .card {
        width: 100% !important;
        max-width: 100% !important;
        margin-left: auto !important;
        margin-right: auto !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
        background: #ffffff !important;
        box-shadow: none !important;
        border: none !important;
    }

    .shell {
        width: 100%;
        max-width: 100%;
        margin: 8px auto 14px;
        padding: 0 10px;
        box-sizing: border-box;
        background: #ffffff;
        border: none;
        box-shadow: none;
        overflow: visible;
    }

    .module-titlebar {
        background: var(--brand-grad);
        border: 1px solid #4a0000;
        border-bottom: none;
        padding: .65rem .85rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        border-radius: 10px 10px 0 0;
        flex-wrap: wrap;
    }

    .module-title {
        margin: 0;
        font-weight: 800;
        color: #fff !important;
        letter-spacing: .2px;
        font-size: 1.1rem;
        line-height: 1.1;
    }

    .module-subtitle {
        margin: 0;
        color: #f4d7d7 !important;
        font-size: var(--fs-sm);
        line-height: 1.2;
    }

    .toolbar {
        background: #ffffff;
        border-top: 1px solid rgba(255,255,255,.12);
        border-bottom: 1px solid var(--brand-line);
        padding: .35rem .5rem;
        display: flex;
        gap: .35rem;
        flex-wrap: wrap;
        justify-content: flex-end;
        align-items: center;
    }

    .tbtn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .35rem;
        min-width: 118px;
        height: 30px;
        padding: 0 .65rem;
        border: 1px solid var(--brand-line);
        border-radius: 6px;
        background: #fff;
        color: #111 !important;
        font-size: var(--fs-sm);
        font-weight: 600;
        line-height: 1;
        text-decoration: none;
        transition: .15s ease;
        white-space: nowrap;
        flex: 0 0 auto;
    }

        .tbtn:hover {
            background: #fff7f7;
            border-color: #b77474;
            color: #111 !important;
        }

        .tbtn.primary {
            background: var(--brand-grad);
            color: #fff !important;
            border-color: #6a0000;
        }

            .tbtn.primary:hover {
                filter: brightness(1.05);
                color: #fff !important;
            }

    .content-block,
    .p-3 {
        padding: .75rem !important;
        background: #ffffff;
        border: 1px solid var(--brand-line);
        border-top: none;
        border-radius: 0 0 10px 10px;
        box-shadow: var(--shadow);
        color: #111 !important;
    }

    .panel {
        background: #ffffff;
        border: 1px solid var(--brand-line);
        border-radius: 8px;
        margin-top: 10px;
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        color: #111 !important;
    }

    .panel-head {
        background: var(--brand-grad);
        border-bottom: 1px solid #5c0000;
        padding: .55rem .75rem;
        font-weight: 700;
        color: #fff !important;
        display: flex;
        align-items: center;
        gap: .45rem;
        font-size: var(--fs-sm);
        line-height: 1.1;
    }

        .panel-head i {
            color: #fff !important;
        }

    .panel-body {
        padding: .7rem;
        background: #ffffff;
        color: #111 !important;
    }

    .row > [class*="col-"] {
        min-width: 0;
    }

    .form-label {
        color: #111 !important;
        font-weight: 700;
        margin-bottom: .25rem;
        font-size: var(--fs-sm);
        line-height: 1.15;
    }

    .form-control,
    .form-select,
    input,
    select,
    textarea {
        border-radius: 6px;
        border: 1px solid #c79b9b !important;
        background: #fff !important;
        color: #111 !important;
        font-size: var(--fs-sm);
        min-height: 32px;
        padding: .32rem .55rem;
        box-shadow: none !important;
    }

        .form-control:focus,
        .form-select:focus,
        input:focus,
        select:focus,
        textarea:focus {
            box-shadow: var(--focus) !important;
            border-color: var(--brand-solid) !important;
            outline: none;
            color: #111 !important;
        }

        .form-control::placeholder,
        textarea::placeholder,
        input::placeholder {
            color: #5f5f5f !important;
            opacity: 1 !important;
        }

        textarea.form-control {
            resize: vertical;
            min-height: 90px;
        }

    .text-danger.small,
    .small.text-danger {
        font-size: var(--fs-xs) !important;
        line-height: 1.2;
    }

    .bg-light {
        background: #fff7f7 !important;
        border-color: #d9b7b7 !important;
        color: #111 !important;
    }

    .table-responsive {
        width: 100%;
        overflow-x: hidden;
        background: #fffafa;
    }

    .table {
        width: 100%;
        margin-bottom: 0;
        min-width: 0;
        table-layout: fixed;
        font-size: var(--fs-sm);
        color: #111 !important;
    }

    table.table-sm th,
    table.table-sm td {
        vertical-align: middle;
        white-space: normal;
        word-break: break-word;
        padding: .35rem .4rem !important;
        color: #111 !important;
    }

    .table thead th {
        font-size: var(--fs-xs);
        line-height: 1.1;
        font-weight: 700;
        color: #fff !important;
    }

    /* Ajuste proporcional de columnas */
    .table.table-sm thead th:nth-child(1),
    .table.table-sm tbody td:nth-child(1) {
        width: 4%;
        text-align: center;
    }

    .table.table-sm thead th:nth-child(2),
    .table.table-sm tbody td:nth-child(2) {
        width: 28%;
    }

    .table.table-sm thead th:nth-child(3),
    .table.table-sm tbody td:nth-child(3) {
        width: 14%;
    }

    .table.table-sm thead th:nth-child(4),
    .table.table-sm tbody td:nth-child(4) {
        width: 12%;
    }

    .table.table-sm thead th:nth-child(5),
    .table.table-sm tbody td:nth-child(5) {
        width: 14%;
    }

    .table.table-sm thead th:nth-child(6),
    .table.table-sm tbody td:nth-child(6) {
        width: 14%;
    }

    .table.table-sm thead th:nth-child(7),
    .table.table-sm tbody td:nth-child(7) {
        width: 8%;
        text-align: center;
    }

    .table.table-sm thead th:nth-child(8),
    .table.table-sm tbody td:nth-child(8) {
        width: 6%;
        text-align: center;
    }

    td > input[type="number"] {
        text-align: right;
        padding-right: .5rem;
        color: #111 !important;
    }

    .cell-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 28px;
        border-radius: 6px;
        padding: 0;
        font-size: var(--fs-sm);
    }

    .note-exists {
        outline: 2px solid #0d6efd;
        outline-offset: -2px;
        border-radius: 4px;
    }

    .btn-reflejo,
    .btn-success,
    .btn-danger {
        background: var(--brand-grad) !important;
        color: #fff !important;
        border: 1px solid #6a0000 !important;
        font-size: var(--fs-sm);
    }

        .btn-reflejo:hover,
        .btn-success:hover,
        .btn-danger:hover {
            filter: brightness(1.06);
            border-color: #6a0000 !important;
            color: #fff !important;
        }

    .btn-sm,
    .btn-group-sm > .btn {
        padding: .25rem .5rem;
        font-size: var(--fs-sm);
        border-radius: .25rem;
    }

    .btn-outline-secondary {
        border-color: #b78383 !important;
        color: #111 !important;
        background: #fff !important;
        font-size: var(--fs-sm);
    }

        .btn-outline-secondary:hover {
            background: #f7e7e7 !important;
            border-color: #a55d5d !important;
            color: #111 !important;
        }

    .btn-outline-danger {
        border-color: #b55e5e !important;
        color: #8B0000 !important;
        font-size: var(--fs-sm);
    }

        .btn-outline-danger:hover {
            background: #8B0000 !important;
            color: #fff !important;
            border-color: #8B0000 !important;
        }

    a,
    a[style*="color:#8B0000"] {
        color: #7a0000 !important;
        font-weight: 700 !important;
        text-decoration: none !important;
        font-size: var(--fs-sm);
    }

        a:hover,
        a[style*="color:#8B0000"]:hover {
            text-decoration: underline !important;
        }

    .modal-content {
        border: 1px solid #b78383;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 16px 40px rgba(70,12,12,.18);
    }

    .modal-header {
        background: var(--brand-grad);
        border-bottom: 1px solid #5c0000;
        color: #fff !important;
        padding: .6rem .8rem;
    }

        .modal-header .modal-title {
            font-weight: 700;
            color: #fff !important;
            font-size: .95rem;
        }

        .modal-header .btn-close {
            filter: invert(1) brightness(200%);
        }

    .modal-body {
        background: #fffdfd;
        font-size: var(--fs-sm);
        color: #111 !important;
    }

    .modal-footer {
        background: #fff6f6;
        border-top: 1px solid #d7b3b3;
        padding: .5rem .8rem;
    }

    #comentarioModal .modal-dialog {
        max-width: 620px;
    }

    #comentarioModal textarea {
        min-height: 120px;
    }

    @@media (max-width: 1400px) {
        .shell {
            width: min(1440px, calc(100% - 18px));
            margin: 8px auto 12px;
        }
    }

    @@media (max-width: 1200px) {
        .shell {
            width: calc(100% - 14px);
            margin: 6px auto 12px;
        }

        .module-titlebar {
            flex-direction: column;
            align-items: stretch;
        }

        .toolbar {
            width: 100%;
            justify-content: flex-end;
        }

        .p-3,
        .content-block {
            padding: .65rem !important;
        }
    }

    @@media (max-width: 768px) {
        .shell {
            width: calc(100% - 8px);
            margin: 4px auto 8px;
        }

        .p-3,
        .content-block {
            padding: .5rem !important;
        }

        .panel-body {
            padding: .6rem;
        }

        .toolbar,
        .toolbar .tbtn,
        .mt-3 .btn,
        .mt-3 a.btn {
            width: 100%;
        }

        .shell {
            width: 100%;
            max-width: 100%;
            margin: 4px auto 8px;
            padding: 0 6px;
            box-sizing: border-box;
        }

        .p-3,
        .content-block {
            padding: .5rem !important;
        }

        .panel-body {
            padding: .6rem;
        }

        .toolbar,
        .toolbar .tbtn,
        .mt-3 .btn,
        .mt-3 a.btn {
            width: 100%;
        }

        .table-responsive {
            width: 100%;
            max-width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        .table {
            width: 100%;
            min-width: 0;
            table-layout: auto;
            font-size: 11px;
        }

            .table th,
            .table td {
                white-space: normal;
                word-break: break-word;
            }
    }

    .module-title-group {
        display: flex;
        flex-direction: column;
        gap: .2rem;
        min-width: 0;
    }
    /* Encabezados de tabla que vienen como links */
    .table thead th a,
    .table thead th a:link,
    .table thead th a:visited,
    .table thead th a:hover,
    .table thead th a:active,
    .table thead th a:focus,
    .table.table-sm thead th a,
    .table.table-sm thead th a:link,
    .table.table-sm thead th a:visited,
    .table.table-sm thead th a:hover,
    .table.table-sm thead th a:active,
    .table.table-sm thead th a:focus {
        color: #111 !important;
        text-decoration: none !important;
        font-weight: 700 !important;
    }

    /* Por si el th trae spans o labels internos */
    .table thead th,
    .table thead th span,
    .table thead th label {
        color: #111 !important;
    }

    /* ROSITA / GRIS + RESPONSIVO TRANSFERENCIAS */
    html,
    body {
        background: #e9edf2 !important;
        overflow-x: hidden !important;
    }

    body,
    main,
    .main,
    .body-content,
    .container,
    .container-fluid,
    .card {
        background: #e9edf2 !important;
    }

    .shell {
        width: 100% !important;
        max-width: 1850px !important;
        margin: 8px auto !important;
        padding: 0 12px !important;
        background: transparent !important;
    }

    .p-3,
    .content-block {
        background: #f0dede !important;
        border: 1px solid #c79d9d !important;
        border-top: none !important;
    }

    .toolbar,
    .modal-footer {
        background: #f1dede !important;
        border-color: #c79d9d !important;
    }

    .panel,
    .modal-content,
    .bg-light {
        background: #fffafa !important;
        border: 1px solid #c79d9d !important;
        border-radius: 0 !important;
    }

    .panel-body,
    .modal-body {
        background: #fffafa !important;
    }

    .form-control,
    .form-select,
    .input-group-text,
    input,
    select,
    textarea {
        background: #fffafa !important;
        border: 1px solid #b48787 !important;
        color: #421414 !important;
        border-radius: 0 !important;
    }

    .table-responsive {
        background: #fffafa !important;
        overflow-x: auto !important;
        -webkit-overflow-scrolling: touch !important;
    }

    .table {
        min-width: 1050px !important;
        table-layout: auto !important;
        background: #fffafa !important;
    }

        .table thead th,
        .table thead th span,
        .table thead th label,
        .table thead th a {
            background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
            color: #fff !important;
            border-color: #7b2a2a !important;
        }

        .table tbody td {
            background: #fffafa !important;
            border-color: #d8bcbc !important;
        }

        .table tbody tr:nth-of-type(even) td {
            background: #f9eded !important;
        }

    .table-hover tbody tr:hover td {
        background: #f4dddd !important;
    }

    /* RESPONSIVO */
    @@media (max-width: 768px) {
        .shell {
            width: 100% !important;
            max-width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        .module-titlebar {
            display: block !important;
            border-radius: 0 !important;
        }

        .toolbar {
            display: grid !important;
            grid-template-columns: 1fr !important;
            gap: 6px !important;
            width: 100% !important;
        }

        .tbtn,
        .btn,
        .form-control,
        .form-select {
            width: 100% !important;
            font-size: 12px !important;
        }

        .p-3,
        .content-block {
            padding: 6px !important;
        }

        .table-responsive {
            width: 100% !important;
            max-height: 65vh !important;
            overflow-x: auto !important;
            overflow-y: auto !important;
        }

        .table {
            min-width: 980px !important;
            font-size: 10px !important;
        }

            .table th,
            .table td {
                font-size: 10px !important;
                padding: 4px 3px !important;
                white-space: nowrap !important;
            }
    }

    /* ============================================================
       DARK MODE - NUEVA SOLICITUD DE TRANSFERENCIA
============================================================ */

body[data-theme="dark"] {
    --brand-solid: #dc2626;
    --brand-dark: #450a0a;
    --brand-mid: #991b1b;
    --brand-soft: rgba(127,29,29,0.22);
    --brand-soft-2: rgba(127,29,29,0.32);
    --brand-line: rgba(248,113,113,0.35);
    --brand-text: #f9fafb;

    --panel: #111827;
    --panel-soft: #172033;
    --muted: #cbd5e1;
    --line: rgba(255,255,255,0.12);
    --line-dark: rgba(248,113,113,0.45);

    --brand-grad: linear-gradient(180deg, #7f1d1d 0%, #450a0a 58%, #111827 100%);
    --shadow: 0 18px 38px rgba(0,0,0,0.42);
    --shadow-sm: 0 10px 26px rgba(0,0,0,0.34);
    --focus: 0 0 0 .2rem rgba(248,113,113,.22);
}

/* Fondo general */
body[data-theme="dark"],
body[data-theme="dark"] html,
body[data-theme="dark"] main,
body[data-theme="dark"] .main,
body[data-theme="dark"] .body-content,
body[data-theme="dark"] .container,
body[data-theme="dark"] .container-fluid,
body[data-theme="dark"] .card {
    background: #0f172a !important;
    color: #e5e7eb !important;
}

body[data-theme="dark"] .layout-main-content {
    background: #0f172a !important;
}

body[data-theme="dark"] .layout-main-content .layout-container-fluid {
    background: transparent !important;
    box-shadow: none !important;
}

/* Shell */
body[data-theme="dark"] .shell {
    background: transparent !important;
    color: #e5e7eb !important;
}

/* Encabezado superior */
body[data-theme="dark"] .module-titlebar {
    background: linear-gradient(180deg, #7f1d1d 0%, #450a0a 58%, #111827 100%) !important;
    border-color: rgba(248,113,113,0.28) !important;
    box-shadow: 0 14px 34px rgba(0,0,0,.38) !important;
}

body[data-theme="dark"] .module-title,
body[data-theme="dark"] .module-title i {
    color: #ffffff !important;
}

body[data-theme="dark"] .module-subtitle {
    color: #fecaca !important;
}

/* Toolbar */
body[data-theme="dark"] .toolbar {
    background: #172033 !important;
    border-color: rgba(255,255,255,0.12) !important;
}

/* Botones toolbar */
body[data-theme="dark"] .tbtn {
    background: #0b1220 !important;
    color: #e5e7eb !important;
    border-color: rgba(203,213,225,0.28) !important;
}

body[data-theme="dark"] .tbtn:hover {
    background: rgba(248,113,113,0.14) !important;
    color: #ffffff !important;
    border-color: rgba(248,113,113,0.55) !important;
}

body[data-theme="dark"] .tbtn.primary {
    background: linear-gradient(180deg, #dc2626 0%, #991b1b 58%, #7f1d1d 100%) !important;
    color: #ffffff !important;
    border-color: rgba(248,113,113,0.55) !important;
}

body[data-theme="dark"] .tbtn.primary:hover {
    filter: brightness(1.08) !important;
    color: #ffffff !important;
}

/* Bloque principal */
body[data-theme="dark"] .p-3,
body[data-theme="dark"] .content-block {
    background: #111827 !important;
    color: #e5e7eb !important;
    border-color: rgba(255,255,255,0.12) !important;
    box-shadow: 0 18px 38px rgba(0,0,0,0.42) !important;
}

/* Paneles */
body[data-theme="dark"] .panel {
    background: #111827 !important;
    color: #e5e7eb !important;
    border-color: rgba(255,255,255,0.12) !important;
    box-shadow: var(--shadow-sm) !important;
}

body[data-theme="dark"] .panel-head {
    background: linear-gradient(180deg, #7f1d1d 0%, #450a0a 58%, #111827 100%) !important;
    color: #ffffff !important;
    border-color: rgba(248,113,113,0.28) !important;
}

body[data-theme="dark"] .panel-head i {
    color: #ffffff !important;
}

body[data-theme="dark"] .panel-body {
    background: #111827 !important;
    color: #e5e7eb !important;
}

/* Labels y textos */
body[data-theme="dark"] .form-label {
    color: #f9fafb !important;
}

body[data-theme="dark"] .text-danger,
body[data-theme="dark"] .text-danger.small,
body[data-theme="dark"] .small.text-danger {
    color: #fca5a5 !important;
}

body[data-theme="dark"] .text-muted,
body[data-theme="dark"] .form-text,
body[data-theme="dark"] small {
    color: #cbd5e1 !important;
}

body[data-theme="dark"] strong,
body[data-theme="dark"] #totKg {
    color: #f9fafb !important;
}

/* Inputs / selects / textareas */
body[data-theme="dark"] .form-control,
body[data-theme="dark"] .form-select,
body[data-theme="dark"] .input-group-text,
body[data-theme="dark"] input,
body[data-theme="dark"] select,
body[data-theme="dark"] textarea {
    background: #0b1220 !important;
    color: #f9fafb !important;
    border-color: rgba(203,213,225,0.28) !important;
    box-shadow: none !important;
}

body[data-theme="dark"] .form-control:focus,
body[data-theme="dark"] .form-select:focus,
body[data-theme="dark"] input:focus,
body[data-theme="dark"] select:focus,
body[data-theme="dark"] textarea:focus {
    background: #0f172a !important;
    color: #ffffff !important;
    border-color: #ef4444 !important;
    box-shadow: 0 0 0 .2rem rgba(239,68,68,.22) !important;
    outline: none !important;
}

body[data-theme="dark"] .form-control::placeholder,
body[data-theme="dark"] input::placeholder,
body[data-theme="dark"] textarea::placeholder {
    color: #94a3b8 !important;
    opacity: 1 !important;
}

body[data-theme="dark"] input[readonly],
body[data-theme="dark"] .form-control[readonly],
body[data-theme="dark"] input:read-only {
    background: #111827 !important;
    color: #cbd5e1 !important;
    border-color: rgba(203,213,225,0.22) !important;
}

body[data-theme="dark"] .form-select {
    color-scheme: dark;
}

body[data-theme="dark"] .form-select option {
    background: #111827 !important;
    color: #f9fafb !important;
}

/* bg-light usado en presupuesto/disponible */
body[data-theme="dark"] .bg-light,
body[data-theme="dark"] .form-control.bg-light {
    background: #172033 !important;
    color: #e5e7eb !important;
    border-color: rgba(203,213,225,0.22) !important;
}

/* Tabla */
body[data-theme="dark"] .table-responsive {
    background: #111827 !important;
    border-color: rgba(255,255,255,0.12) !important;
}

body[data-theme="dark"] .table {
    background: #111827 !important;
    color: #e5e7eb !important;
    --bs-table-bg: #111827;
    --bs-table-color: #e5e7eb;
    --bs-table-border-color: rgba(255,255,255,0.12);
    --bs-table-striped-bg: #172033;
    --bs-table-striped-color: #e5e7eb;
    --bs-table-hover-bg: rgba(248,113,113,0.12);
    --bs-table-hover-color: #ffffff;
}

body[data-theme="dark"] .table thead th,
body[data-theme="dark"] .table thead th span,
body[data-theme="dark"] .table thead th label,
body[data-theme="dark"] .table thead th a {
    background: linear-gradient(180deg, #7f1d1d 0%, #450a0a 58%, #111827 100%) !important;
    color: #ffffff !important;
    border-color: rgba(248,113,113,0.28) !important;
}

body[data-theme="dark"] table.table-sm th,
body[data-theme="dark"] table.table-sm td,
body[data-theme="dark"] .table td,
body[data-theme="dark"] .table tbody tr td,
body[data-theme="dark"] .table tbody tr th {
    background: #111827 !important;
    color: #e5e7eb !important;
    border-color: rgba(255,255,255,0.12) !important;
}

body[data-theme="dark"] .table tbody tr:nth-of-type(even) td {
    background: #172033 !important;
}

body[data-theme="dark"] .table-hover tbody tr:hover td {
    background: rgba(248,113,113,0.13) !important;
    color: #ffffff !important;
}

/* Fila marcada como error o sobre presupuesto */
body[data-theme="dark"] .table-danger,
body[data-theme="dark"] tr.table-danger td {
    background: rgba(220,38,38,0.22) !important;
    color: #fecaca !important;
}

body[data-theme="dark"] tr.table-danger input {
    border-color: rgba(248,113,113,0.65) !important;
}

/* Botón de comentario */
body[data-theme="dark"] .btn-light {
    background: #0b1220 !important;
    color: #e5e7eb !important;
    border-color: rgba(203,213,225,0.28) !important;
}

body[data-theme="dark"] .btn-light:hover {
    background: rgba(248,113,113,0.14) !important;
    color: #ffffff !important;
    border-color: rgba(248,113,113,0.55) !important;
}

body[data-theme="dark"] .note-exists {
    outline: 2px solid #60a5fa !important;
    outline-offset: -2px;
}

/* Botones */
body[data-theme="dark"] .btn-reflejo,
body[data-theme="dark"] .btn-success,
body[data-theme="dark"] .btn-danger {
    background: linear-gradient(180deg, #dc2626 0%, #991b1b 58%, #7f1d1d 100%) !important;
    color: #ffffff !important;
    border-color: rgba(248,113,113,0.50) !important;
}

body[data-theme="dark"] .btn-reflejo:hover,
body[data-theme="dark"] .btn-success:hover,
body[data-theme="dark"] .btn-danger:hover {
    filter: brightness(1.08) !important;
    color: #ffffff !important;
}

body[data-theme="dark"] .btn-outline-secondary {
    background: #0b1220 !important;
    color: #e5e7eb !important;
    border-color: rgba(203,213,225,0.32) !important;
}

body[data-theme="dark"] .btn-outline-secondary:hover {
    background: rgba(248,113,113,0.14) !important;
    color: #ffffff !important;
    border-color: rgba(248,113,113,0.55) !important;
}

body[data-theme="dark"] .btn-outline-danger {
    background: #0b1220 !important;
    color: #fca5a5 !important;
    border-color: rgba(248,113,113,0.45) !important;
}

body[data-theme="dark"] .btn-outline-danger:hover {
    background: rgba(220,38,38,0.28) !important;
    color: #ffffff !important;
    border-color: rgba(248,113,113,0.75) !important;
}

/* Links */
body[data-theme="dark"] a,
body[data-theme="dark"] a[style*="color:#8B0000"] {
    color: #fca5a5 !important;
}

body[data-theme="dark"] a:hover,
body[data-theme="dark"] a[style*="color:#8B0000"]:hover {
    color: #fecaca !important;
    text-decoration: underline !important;
}

/* Modales */
body[data-theme="dark"] .modal-content {
    background: #111827 !important;
    color: #e5e7eb !important;
    border-color: rgba(255,255,255,0.12) !important;
    box-shadow: 0 22px 50px rgba(0,0,0,0.58) !important;
}

body[data-theme="dark"] .modal-header {
    background: linear-gradient(180deg, #7f1d1d 0%, #450a0a 58%, #111827 100%) !important;
    color: #ffffff !important;
    border-color: rgba(248,113,113,0.28) !important;
}

body[data-theme="dark"] .modal-header .modal-title {
    color: #ffffff !important;
}

body[data-theme="dark"] .modal-header .btn-close,
body[data-theme="dark"] .btn-close {
    filter: invert(1) grayscale(100%) brightness(200%) !important;
    opacity: .95 !important;
}

body[data-theme="dark"] .modal-body {
    background: #111827 !important;
    color: #e5e7eb !important;
}

body[data-theme="dark"] .modal-footer {
    background: #172033 !important;
    color: #e5e7eb !important;
    border-color: rgba(255,255,255,0.12) !important;
}

body[data-theme="dark"] #comentarioModal textarea {
    background: #0b1220 !important;
    color: #f9fafb !important;
    border-color: rgba(203,213,225,0.28) !important;
}

body[data-theme="dark"] #skuInfo {
    color: #f9fafb !important;
}

/* Validaciones */
body[data-theme="dark"] .is-invalid {
    border-color: #ef4444 !important;
}

body[data-theme="dark"] .field-validation-error,
body[data-theme="dark"] [data-valmsg-for] {
    color: #fca5a5 !important;
}

/* Toast dinámico creado por JS */
body[data-theme="dark"] .toast {
    background: #111827 !important;
    color: #e5e7eb !important;
    border: 1px solid rgba(255,255,255,0.12) !important;
    box-shadow: 0 16px 36px rgba(0,0,0,0.42) !important;
}

body[data-theme="dark"] .toast-header {
    background: #172033 !important;
    color: #f9fafb !important;
    border-bottom: 1px solid rgba(255,255,255,0.12) !important;
}

body[data-theme="dark"] .toast-header small {
    color: #cbd5e1 !important;
}

body[data-theme="dark"] .toast-body {
    background: #111827 !important;
    color: #e5e7eb !important;
}

body[data-theme="dark"] .toast .btn-close {
    filter: invert(1) grayscale(100%) brightness(200%) !important;
}

/* Overlay "Procesando…" creado por JS */
body[data-theme="dark"] #savingOverlay {
    background: rgba(15,23,42,.82) !important;
    backdrop-filter: blur(2px);
}

body[data-theme="dark"] #savingOverlay div,
body[data-theme="dark"] #savingOverlay .mt-2 {
    color: #f9fafb !important;
}

body[data-theme="dark"] #savingOverlay .spinner-border {
    color: #f87171 !important;
}

/* jQuery UI Autocomplete */
body[data-theme="dark"] .ui-widget,
body[data-theme="dark"] .ui-widget-content,
body[data-theme="dark"] .ui-autocomplete {
    background: #111827 !important;
    color: #e5e7eb !important;
    border-color: rgba(203,213,225,0.28) !important;
    box-shadow: 0 16px 34px rgba(0,0,0,0.42) !important;
}

body[data-theme="dark"] .ui-menu .ui-menu-item-wrapper {
    color: #e5e7eb !important;
    background: #111827 !important;
}

body[data-theme="dark"] .ui-menu .ui-menu-item-wrapper.ui-state-active,
body[data-theme="dark"] .ui-menu .ui-menu-item-wrapper:hover {
    background: rgba(220,38,38,0.65) !important;
    color: #ffffff !important;
    border-color: transparent !important;
}

/* Tooltips */
body[data-theme="dark"] .tooltip-inner {
    background: #020617 !important;
    color: #f9fafb !important;
    border: 1px solid rgba(255,255,255,0.12);
}

body[data-theme="dark"] .tooltip.bs-tooltip-top .tooltip-arrow::before {
    border-top-color: #020617 !important;
}

body[data-theme="dark"] .tooltip.bs-tooltip-bottom .tooltip-arrow::before {
    border-bottom-color: #020617 !important;
}

body[data-theme="dark"] .tooltip.bs-tooltip-start .tooltip-arrow::before {
    border-left-color: #020617 !important;
}

body[data-theme="dark"] .tooltip.bs-tooltip-end .tooltip-arrow::before {
    border-right-color: #020617 !important;
}

/* Scrollbars */
body[data-theme="dark"] .table-responsive,
body[data-theme="dark"] .modal-body,
body[data-theme="dark"] textarea {
    scrollbar-color: rgba(248,113,113,0.42) #0f172a;
}

body[data-theme="dark"] .table-responsive::-webkit-scrollbar,
body[data-theme="dark"] .modal-body::-webkit-scrollbar,
body[data-theme="dark"] textarea::-webkit-scrollbar {
    width: 9px;
    height: 9px;
}

body[data-theme="dark"] .table-responsive::-webkit-scrollbar-track,
body[data-theme="dark"] .modal-body::-webkit-scrollbar-track,
body[data-theme="dark"] textarea::-webkit-scrollbar-track {
    background: #0f172a;
}

body[data-theme="dark"] .table-responsive::-webkit-scrollbar-thumb,
body[data-theme="dark"] .modal-body::-webkit-scrollbar-thumb,
body[data-theme="dark"] textarea::-webkit-scrollbar-thumb {
    background: rgba(248,113,113,0.42);
    border-radius: 999px;
}

/* Responsive */
@@media (max-width: 768px) {
    body[data-theme="dark"] .module-titlebar {
        border-radius: 0 !important;
    }

    body[data-theme="dark"] .toolbar {
        background: #172033 !important;
    }

    body[data-theme="dark"] .p-3,
    body[data-theme="dark"] .content-block {
        border-left: none !important;
        border-right: none !important;
    }

    body[data-theme="dark"] .table {
        background: #111827 !important;
    }
}


/* ============================================================
   FIX FINAL RESPONSIVO SIDEBAR - TRANSFERENCIA
   Hace que la vista se encoja al abrir el sidebar como OrdenVenta
============================================================ */

.st-page {
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    transform: none !important;
    padding: 8px 12px !important;
    box-sizing: border-box !important;
    overflow-x: hidden !important;
    background: #e9edf2 !important;
}

.st-page .shell {
    width: 100% !important;
    max-width: 1850px !important;
    margin: 8px auto !important;
    padding: 0 !important;
    box-sizing: border-box !important;
}

.st-page .p-3,
.st-page .content-block {
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
}

/* Desktop: ajusta ancho cuando el sidebar está abierto */
@@media (min-width: 992px) {
    body.st-sidebar-final-ready {
        overflow-x: hidden !important;
    }

    body.st-sidebar-final-ready .st-page {
        margin-left: var(--st-sidebar-push, 0px) !important;
        width: var(--st-page-width, 100%) !important;
        max-width: var(--st-page-width, 100%) !important;
        transform: none !important;
        box-sizing: border-box !important;
        overflow-x: hidden !important;
        transition:
            margin-left .12s ease-out,
            width .12s ease-out,
            max-width .12s ease-out !important;
    }

    body.st-sidebar-final-ready .st-page .shell,
    body.st-sidebar-final-ready .st-page .p-3,
    body.st-sidebar-final-ready .st-page .content-block {
        width: 100% !important;
        max-width: 100% !important;
        box-sizing: border-box !important;
    }

    body.st-sidebar-final-ready .st-page .table-responsive {
        max-width: 100% !important;
        overflow-x: auto !important;
    }
}

/* Celular */
@@media (max-width: 768px) {
    .st-page {
        padding: 0 !important;
    }

    .st-page .shell {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
    }
}

/* Dark mode */
body[data-theme="dark"] .st-page {
    background: #0f172a !important;
}




/* ============================================================
   UX EJECUTIVO - SOLICITUD DE TRANSFERENCIA SIMPLE E INTUITIVA
   Conserva IDs/clases funcionales existentes.
============================================================ */
:root {
    --st-bg: #f3f4f6;
    --st-surface: #ffffff;
    --st-surface-soft: #f9fafb;
    --st-ink: #111827;
    --st-muted: #6b7280;
    --st-border: #e5e7eb;
    --st-brand: #8B0000;
    --st-brand-2: #5c0000;
    --st-brand-soft: #fff1f2;
    --st-blue-soft: #eff6ff;
    --st-blue-border: #bfdbfe;
    --st-blue-ink: #1e3a8a;
    --st-success: #166534;
    --st-warning: #92400e;
    --st-radius-lg: 18px;
    --st-radius-md: 14px;
    --st-radius-sm: 10px;
    --st-shadow: 0 18px 44px rgba(17, 24, 39, .10);
    --st-shadow-sm: 0 10px 24px rgba(17, 24, 39, .08);
}

html,
body,
body,
main,
.main,
.body-content,
.container,
.container-fluid,
.card,
.st-page,
.st-executive {
    background: var(--st-bg) !important;
    color: var(--st-ink) !important;
}

.st-executive {
    padding: 12px !important;
}

.st-executive .shell {
    max-width: 1850px !important;
    margin: 0 auto 18px !important;
    padding: 0 !important;
    background: transparent !important;
}

.st-hero {
    background:
        radial-gradient(circle at top right, rgba(255,255,255,.22), transparent 28%),
        linear-gradient(135deg, #991b1b 0%, #7f1d1d 48%, #450a0a 100%) !important;
    border: 0 !important;
    padding: 18px 20px !important;
    box-shadow: var(--st-shadow) !important;
    border-radius: var(--st-radius-lg) var(--st-radius-lg) 0 0 !important;
}

.st-hero-copy {
    display: grid;
    gap: 2px;
}

.st-kicker {
    color: #fecaca;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .12em;
}

.st-executive .module-title {
    font-size: clamp(1.35rem, 1.2vw + 1rem, 2rem) !important;
    color: #ffffff !important;
    line-height: 1.05 !important;
    display: flex;
    align-items: center;
    gap: 10px;
}

.st-executive .module-subtitle {
    color: rgba(255,255,255,.84) !important;
    font-size: 13px !important;
}

.st-executive .toolbar,
.st-hero-actions {
    background: transparent !important;
    border: 0 !important;
    padding: 0 !important;
    gap: 10px !important;
}

.st-executive .tbtn {
    min-height: 42px !important;
    height: auto !important;
    border-radius: 999px !important;
    padding: 0 16px !important;
    font-weight: 800 !important;
    box-shadow: 0 10px 20px rgba(0,0,0,.12) !important;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.st-hero .tbtn.primary {
    background: #ffffff !important;
    color: #7f1d1d !important;
    border-color: rgba(255,255,255,.72) !important;
}

.st-hero .tbtn.primary:hover {
    color: #450a0a !important;
    background: #fff7ed !important;
}

.st-hero .tbtn.ghost {
    background: rgba(255,255,255,.12) !important;
    color: #ffffff !important;
    border-color: rgba(255,255,255,.30) !important;
}

.st-hero .tbtn.ghost:hover {
    background: rgba(255,255,255,.20) !important;
    color: #ffffff !important;
}

.st-steps {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    background: #ffffff;
    border: 1px solid var(--st-border);
    border-top: 0;
    padding: 12px;
    box-shadow: var(--st-shadow-sm);
}

.st-step {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    background: var(--st-surface-soft);
    border: 1px solid var(--st-border);
    border-radius: var(--st-radius-md);
    padding: 12px;
    transition: .16s ease;
}

.st-step.is-active {
    background: var(--st-brand-soft);
    border-color: rgba(139,0,0,.26);
}

.st-step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: var(--st-brand);
    color: #ffffff;
    font-weight: 900;
    flex: 0 0 auto;
}

.st-step-text {
    min-width: 0;
}

.st-step-title {
    display: block;
    color: var(--st-ink);
    font-size: 13px;
    font-weight: 900;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.st-step-help {
    display: block;
    color: var(--st-muted);
    font-size: 11px;
    line-height: 1.15;
}

.st-executive .content-block,
.st-executive .p-3 {
    background: #ffffff !important;
    border: 1px solid var(--st-border) !important;
    border-top: 0 !important;
    border-radius: 0 0 var(--st-radius-lg) var(--st-radius-lg) !important;
    padding: 16px !important;
    box-shadow: var(--st-shadow) !important;
}

.st-guidance {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: linear-gradient(180deg, #fff7ed 0%, #fff 100%);
    border: 1px solid #fed7aa;
    border-radius: var(--st-radius-md);
    padding: 12px 14px;
    margin-bottom: 14px;
}

.st-guidance-main {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    color: #7c2d12;
}

.st-guidance-main i {
    font-size: 1.25rem;
}

.st-guidance small {
    color: #9a3412 !important;
}

.st-executive .panel,
.st-executive .modal-content,
.st-executive .bg-light {
    border-radius: var(--st-radius-md) !important;
    border: 1px solid var(--st-border) !important;
    background: var(--st-surface) !important;
    box-shadow: var(--st-shadow-sm) !important;
    overflow: hidden;
}

.st-executive .panel {
    margin-top: 0 !important;
}

.st-executive .panel-head {
    background: #ffffff !important;
    color: var(--st-ink) !important;
    border-bottom: 1px solid var(--st-border) !important;
    padding: 13px 16px !important;
    font-size: 14px !important;
    font-weight: 900 !important;
}

.st-executive .panel-head i {
    color: var(--st-brand) !important;
}

.st-executive .panel-body,
.st-executive .modal-body {
    background: #ffffff !important;
    padding: 16px !important;
}

.st-panel-head-split {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    gap: 10px !important;
    flex-wrap: wrap !important;
}

.st-card-title {
    display: flex;
    align-items: center;
    gap: 10px;
}

.st-card-title .st-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 999px;
    background: var(--st-brand);
    color: #ffffff;
    font-weight: 900;
}

.st-mini-note {
    color: var(--st-muted);
    font-size: 12px;
    font-weight: 600;
}

.st-executive .form-label {
    color: #374151 !important;
    font-size: 12px !important;
    text-transform: uppercase;
    letter-spacing: .035em;
    font-weight: 900 !important;
}

.st-executive .form-control,
.st-executive .form-select,
.st-executive .input-group-text,
.st-executive input,
.st-executive select,
.st-executive textarea {
    border-radius: var(--st-radius-sm) !important;
    border: 1px solid #d1d5db !important;
    background: #ffffff !important;
    min-height: 42px !important;
    font-size: 14px !important;
    color: var(--st-ink) !important;
}

.st-executive .form-control:focus,
.st-executive .form-select:focus,
.st-executive input:focus,
.st-executive select:focus,
.st-executive textarea:focus {
    border-color: var(--st-brand) !important;
    box-shadow: 0 0 0 .2rem rgba(139,0,0,.14) !important;
}

.st-executive textarea.form-control,
.st-executive textarea {
    min-height: 92px !important;
}

.st-primary-field {
    min-height: 52px !important;
    font-size: 18px !important;
    font-weight: 900 !important;
}

.st-field-readonly input[readonly],
.st-field-readonly .form-control[readonly] {
    background: #f9fafb !important;
    color: #4b5563 !important;
    font-weight: 800;
}

.st-summary-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
}

.st-summary-card {
