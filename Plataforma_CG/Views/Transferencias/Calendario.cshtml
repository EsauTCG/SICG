@section Scripts {
    <script>
        (() => {
            const URL_GET_PEDIDOS = '@Url.Action("GetPedidosLogistica", "Calendario")';
            const URL_GUARDAR_LOGISTICA = '@Url.Action("GuardarLogistica", "Calendario")';

            const nombresDias = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
            const nombresMeses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

            let currentEditId = null;
            let currentEditItem = null;
            let tipoCancelacionActual = null;
            let currentDate = getTodayNoon();
            let data = [];
            let isLoading = false;

            const $vistaTipo             = document.getElementById('vista-tipo');
            const $fechaBase             = document.getElementById('fecha-base');
            const $filtroVendedor        = document.getElementById('filtro-vendedor');
            const $filtroEstatus         = document.getElementById('filtro-estatus');
            const $btnPrev               = document.getElementById('btn-prev');
            const $btnHoy                = document.getElementById('btn-hoy');
            const $btnNext               = document.getElementById('btn-next');
            const $btnFiltrar            = document.getElementById('btn-filtrar');
            const $btnReset              = document.getElementById('btn-reset');
            const $rangeTitle            = document.getElementById('range-title');
            const $loadingBar            = document.getElementById('loading-bar');
            const $board                 = document.getElementById('calendar-board');
            const $tbodyListado          = document.getElementById('tbody-listado');
            const $listadoCount          = document.getElementById('listado-count');
            const $btnVerListado         = document.getElementById('btn-ver-listado');

            const $kpiEmbarques          = document.getElementById('kpi-embarques');
            const $kpiKilos              = document.getElementById('kpi-kilos');
            const $kpiPendientes         = document.getElementById('kpi-pendientes');
            const $kpiAsignados          = document.getElementById('kpi-asignados');
            const $kpiCancelados         = document.getElementById('kpi-cancelados');

            const $modal                 = document.getElementById('modal-mask');
            const $modalTitle            = document.getElementById('modal-title');
            const $btnCancelar           = document.getElementById('btn-cancelar');
            const $btnCancelar2          = document.getElementById('btn-cancelar2');
            const $btnGuardar            = document.getElementById('btn-guardar');

            const $mConsecutivo          = document.getElementById('m-consecutivo');
            const $mSerie                = document.getElementById('m-serie');
            const $mFecha                = document.getElementById('m-fecha');
            const $mCliente              = document.getElementById('m-cliente');
            const $mVendedor             = document.getElementById('m-vendedor');
            const $mKilos                = document.getElementById('m-kilos');
            const $mPresentacion         = document.getElementById('m-presentacion');
            const $mObservacionVenta     = document.getElementById('m-observacion-venta');

            const $mFletera              = document.getElementById('m-fletera');
            const $mEstatus              = document.getElementById('m-estatus');
            const $mEstatusDisplay       = document.getElementById('m-estatus-display');
            const $mEspacioTarimas       = document.getElementById('m-espacio-tarimas');
            const $mHoraLlegada          = document.getElementById('m-hora-llegada');
            const $mObservacionLogistica = document.getElementById('m-observacion-logistica');

            const $rutasContainer        = document.getElementById('rutas-container');
            const $btnCancelarFletera    = document.getElementById('btn-cancelar-fletera');
            const $btnCancelarRegistro   = document.getElementById('btn-cancelar-registro');
            const $motivoInfo            = document.getElementById('motivo-info');

            const $modalListado          = document.getElementById('modal-listado-mask');
            const $modalListadoTitle     = document.getElementById('modal-listado-title');
            const $btnCerrarListado      = document.getElementById('btn-cerrar-listado');
            const $btnCerrarListado2     = document.getElementById('btn-cerrar-listado2');

            const $modalCancelacion        = document.getElementById('modal-cancelacion-mask');
            const $cancelacionTitle        = document.getElementById('cancelacion-title');
            const $cancelacionResumen      = document.getElementById('cancelacion-resumen');
            const $cancelacionMotivo       = document.getElementById('cancelacion-motivo');
            const $btnCerrarCancelacion    = document.getElementById('btn-cerrar-cancelacion');
            const $btnCancelarCancelacion  = document.getElementById('btn-cancelar-cancelacion');
            const $btnConfirmarCancelacion = document.getElementById('btn-confirmar-cancelacion');

            const nf = new Intl.NumberFormat('es-MX');

            function getTodayNoon() {
                const d = new Date();
                return new Date(d.getFullYear(), d.getMonth(), d.getDate(), 12, 0, 0);
            }

            function pad(n) {
                return String(n).padStart(2, '0');
            }

            function toDateString(d) {
                return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
            }

            function parseDate(str) {
                if (!str) return getTodayNoon();
                const [y, m, d] = str.split('-').map(Number);
                return new Date(y, m - 1, d, 12, 0, 0);
            }

            function cloneDate(d) {
                return new Date(d.getFullYear(), d.getMonth(), d.getDate(), 12, 0, 0);
            }

            function addDays(d, days) {
                const x = cloneDate(d);
                x.setDate(x.getDate() + days);
                return x;
            }

            function getMonday(d) {
                const x = cloneDate(d);
                const day = x.getDay();
                const diff = day === 0 ? -6 : 1 - day;
                x.setDate(x.getDate() + diff);
                return x;
            }

            function escapeHtml(v) {
                return String(v ?? '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function pick(obj, ...names) {
                for (const name of names) {
                    if (obj && Object.prototype.hasOwnProperty.call(obj, name)) {
                        return obj[name];
                    }
                }
                return null;
            }

            function normalizeDateOnly(value) {
                if (!value) return '';

                if (typeof value === 'string') {
                    const msMatch = /\/Date\((\d+)\)\//.exec(value);
                    if (msMatch) {
                        const d = new Date(Number(msMatch[1]));
                        return toDateString(new Date(d.getFullYear(), d.getMonth(), d.getDate(), 12, 0, 0));
                    }

                    if (value.length >= 10) {
                        return value.substring(0, 10);
                    }
                }

                const d = new Date(value);
                if (!isNaN(d.getTime())) {
                    return toDateString(new Date(d.getFullYear(), d.getMonth(), d.getDate(), 12, 0, 0));
                }

                return '';
            }

            function normalizeTime(value) {
                if (!value) return '';

                if (typeof value === 'string') {
                    if (value.length >= 5) return value.substring(0, 5);
                    return value;
                }

                if (typeof value === 'object') {
                    const h = value.Hours ?? value.hours ?? 0;
                    const m = value.Minutes ?? value.minutes ?? 0;
                    return `${pad(h)}:${pad(m)}`;
                }

                return '';
            }

            function normalizeText(value) {
                return String(value ?? '').trim();
            }

            function normalizeStatusByCarrier(item) {
                if (item.estatus === 'CANCELADO' || item.estatus === 'FLETERA CANCELADA') return item.estatus;
                if (item.fletera && item.estatus !== 'ASIGNADO') return 'ASIGNADO';
                if (!item.fletera && item.estatus === 'ASIGNADO') return 'PENDIENTE FLETERA';
                return item.estatus || 'PENDIENTE FLETERA';
            }

            function setEstatusModal(estatus) {
                const valor = estatus || 'PENDIENTE FLETERA';
                $mEstatus.value = valor;
                $mEstatusDisplay.value = valor;
            }

            function calcularEstatusAutomatico() {
                const fletera = ($mFletera.value || '').trim();

                if (fletera) {
                    return 'ASIGNADO';
                }

                return 'PENDIENTE FLETERA';
            }

            function setLoading(value) {
                isLoading = value;
                $loadingBar.classList.toggle('show', value);
                $btnFiltrar.disabled = value;
                $btnPrev.disabled = value;
                $btnHoy.disabled = value;
                $btnNext.disabled = value;
                $btnGuardar.disabled = value;
                if ($btnConfirmarCancelacion) $btnConfirmarCancelacion.disabled = value;
            }

            function getAntiForgeryToken() {
                const input = document.querySelector('input[name="__RequestVerificationToken"]');
                return input ? input.value : '';
            }

            function getCardClass(estatus) {
                if (estatus === 'ASIGNADO') return 'asignado';
                if (estatus === 'PENDIENTE FLETERA') return 'pendiente';
                if (estatus === 'FLETERA CANCELADA') return 'cancelado-fletera';
                if (estatus === 'CANCELADO') return 'cancelado';
                return 'programado';
            }

            function getChipClass(estatus) {
                if (estatus === 'ASIGNADO') return 'status-asignado';
                if (estatus === 'PENDIENTE FLETERA') return 'status-pendiente';
                if (estatus === 'FLETERA CANCELADA') return 'status-cancelado-fletera';
                if (estatus === 'CANCELADO') return 'status-cancelado';
                return 'status-programado';
            }

            function getVisibleDays() {
                if ($vistaTipo.value === 'day') return [cloneDate(currentDate)];
                const monday = getMonday(currentDate);
                return Array.from({ length: 7 }, (_, i) => addDays(monday, i));
            }

            function getFilteredData() {
                const days = getVisibleDays();
                const minDate = toDateString(days[0]);
                const maxDate = toDateString(days[days.length - 1]);

                return data.filter(x => {
                    const okRange = x.fecha >= minDate && x.fecha <= maxDate;
                    const okVend = !$filtroVendedor.value || x.vendedor === $filtroVendedor.value;
                    const okEst = !$filtroEstatus.value || x.estatus === $filtroEstatus.value;
                    return okRange && okVend && okEst;
                });
            }

            function mapPedidoToItem(x) {
                const fecha = normalizeDateOnly(pick(x, 'FechaEntrega', 'fechaEntrega'));

                const item = {
                    id: Number(pick(x, 'Id', 'id') || 0),
                    ordenVentaId: Number(pick(x, 'Id', 'id') || pick(x, 'OrdenVentaId', 'ordenVentaId') || 0),
                    consecutivo: normalizeText(pick(x, 'Consecutivo', 'consecutivo')),
                    serie: normalizeText(pick(x, 'Serie', 'serie')),
                    nombreSerie: normalizeText(pick(x, 'NombreSerie', 'nombreSerie')),
                    sucursal: normalizeText(pick(x, 'Sucursal', 'sucursal')),
                    sucursalId: normalizeText(pick(x, 'SucursalId', 'sucursalId', 'sucursalid')),

                    fecha: fecha,
                    fechaEmbarque: normalizeDateOnly(pick(x, 'FechaEmbarque', 'fechaEmbarque')),
                    horaEmbarque: normalizeTime(pick(x, 'HoraEmbarque', 'horaEmbarque')),

                    clienteCodigo: normalizeText(pick(x, 'Cliente', 'cliente', 'ClienteId', 'clienteId', 'CodigoCliente', 'codigoCliente')),
                    clienteNombre: normalizeText(pick(x, 'NombreCliente', 'nombreCliente', 'ClienteNombre', 'clienteNombre', 'RazonSocial', 'razonSocial', 'CardName', 'cardName')),
                    cliente: normalizeText(pick(x, 'NombreCliente', 'nombreCliente', 'ClienteNombre', 'clienteNombre', 'RazonSocial', 'razonSocial', 'CardName', 'cardName')) 
                        || normalizeText(pick(x, 'Cliente', 'cliente', 'ClienteId', 'clienteId', 'CodigoCliente', 'codigoCliente')),
                    vendedor: normalizeText(pick(x, 'Vendedor', 'vendedor')),
                    rutas: [normalizeText(pick(x, 'Ruta', 'ruta')) || 'SIN RUTA'],
                    presentacion: normalizeText(pick(x, 'Presentacion', 'presentacion')),
                    observaciones: normalizeText(pick(x, 'Observacion', 'observacion')),

                    kilos: Number(pick(x, 'Saldo', 'saldo') || 0),
                    otrosPedidos: Number(pick(x, 'OtrosPedidos', 'otrosPedidos') || 0),
                    credito: Number(pick(x, 'Credito', 'credito') || 0),

                    fletera: normalizeText(pick(x, 'Fletera', 'fletera')),
                    espacioTarimas: Number(pick(x, 'EspacioTarimas', 'espacioTarimas') || 0),
                    horaLlegadaUnidad: normalizeTime(pick(x, 'HoraLlegadaUnidad', 'horaLlegadaUnidad')),
                    estatus: normalizeText(pick(x, 'EstatusLogistico', 'estatusLogistico')) || 'PENDIENTE FLETERA',
                    observacionLogistica: normalizeText(pick(x, 'ObservacionLogistica', 'observacionLogistica')),

                    cancelado: Boolean(pick(x, 'Cancelado', 'cancelado')),
                    canceladoFletera: Boolean(pick(x, 'CanceladoFletera', 'canceladoFletera')),
                    motivoCancelacion: normalizeText(pick(x, 'MotivoCancelacion', 'motivoCancelacion')),
                    motivoCancelacionFletera: normalizeText(pick(x, 'MotivoCancelacionFletera', 'motivoCancelacionFletera'))
                };

                item.estatus = normalizeStatusByCarrier(item);
                return item;
            }

            async function cargarPedidosDesdeBD() {
                const days = getVisibleDays();
                const fechaInicio = toDateString(days[0]);
                const fechaFin = toDateString(days[days.length - 1]);

                const url = `${URL_GET_PEDIDOS}?fechaInicio=${encodeURIComponent(fechaInicio)}&fechaFin=${encodeURIComponent(fechaFin)}`;

                setLoading(true);

                try {
                    const response = await fetch(url, {
                        method: 'GET',
                        headers: {
                            'Accept': 'application/json'
                        }
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }

                    const pedidos = await response.json();
                    data = Array.isArray(pedidos) ? pedidos.map(mapPedidoToItem) : [];
                } catch (error) {
                    console.error(error);
                    data = [];
                    alert('No se pudieron cargar las órdenes de venta para logística. Revisa el controlador GetPedidosLogistica.');
                } finally {
                    setLoading(false);
                }
            }

            async function guardarLogisticaRequest(payload) {
                const headers = {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                };

                const token = getAntiForgeryToken();
                if (token) {
                    headers['RequestVerificationToken'] = token;
                    headers['__RequestVerificationToken'] = token;
                }

                const response = await fetch(URL_GUARDAR_LOGISTICA, {
                    method: 'POST',
                    headers: headers,
                    body: JSON.stringify(payload)
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }

                const result = await response.json();
                const ok = result.ok ?? result.Ok ?? result.success ?? result.Success ?? false;

                if (!ok) {
                    throw new Error(result.mensaje || result.Mensaje || result.message || 'No se pudo guardar la logística.');
                }

                return result;
            }

            function renderVendedores() {
                const vendedores = [...new Set(data.map(x => x.vendedor).filter(Boolean))].sort();
                const selected = $filtroVendedor.value;

                $filtroVendedor.innerHTML = '<option value="">Todos</option>' +
                    vendedores.map(v => `<option value="${escapeHtml(v)}">${escapeHtml(v)}</option>`).join('');

                $filtroVendedor.value = vendedores.includes(selected) ? selected : '';
            }

            function renderRangeTitle() {
                const days = getVisibleDays();

                if ($vistaTipo.value === 'day') {
                    const d = days[0];
                    $rangeTitle.textContent = `${nombresDias[d.getDay()]} ${d.getDate()} de ${nombresMeses[d.getMonth()]} de ${d.getFullYear()}`;
                    return;
                }

                const first = days[0];
                const last = days[days.length - 1];

                if (first.getMonth() === last.getMonth() && first.getFullYear() === last.getFullYear()) {
                    $rangeTitle.textContent = `${first.getDate()} - ${last.getDate()} de ${nombresMeses[first.getMonth()]} de ${first.getFullYear()}`;
                } else if (first.getFullYear() === last.getFullYear()) {
                    $rangeTitle.textContent = `${first.getDate()} de ${nombresMeses[first.getMonth()]} - ${last.getDate()} de ${nombresMeses[last.getMonth()]} de ${first.getFullYear()}`;
                } else {
                    $rangeTitle.textContent = `${first.getDate()} de ${nombresMeses[first.getMonth()]} de ${first.getFullYear()} - ${last.getDate()} de ${nombresMeses[last.getMonth()]} de ${last.getFullYear()}`;
                }
            }

            function renderKpis(items) {
                $kpiEmbarques.textContent = nf.format(items.length);
                $kpiKilos.textContent = nf.format(items.reduce((a, b) => a + Number(b.kilos || 0), 0));
                $kpiPendientes.textContent = nf.format(items.filter(x => x.estatus === 'PENDIENTE FLETERA').length);
                $kpiAsignados.textContent = nf.format(items.filter(x => x.estatus === 'ASIGNADO').length);
                $kpiCancelados.textContent = nf.format(items.filter(x => x.estatus === 'CANCELADO' || x.estatus === 'FLETERA CANCELADA').length);
            }

            function renderRutas(rutas = ['SIN RUTA']) {
                $rutasContainer.innerHTML = rutas.map(ruta => `
                    <div class="ruta-row">
                        <input type="text"
                               class="form-control js-ruta"
                               value="${escapeHtml(ruta)}"
                               readonly />
                    </div>
                `).join('');
            }

            function getMotivoResumen(item) {
                if (item.motivoCancelacion) return item.motivoCancelacion;
                if (item.motivoCancelacionFletera) return item.motivoCancelacionFletera;
                return '';
            }

            function renderBoard() {
                const visibleDays = getVisibleDays();
                const items = getFilteredData();

                const minCol = window.innerWidth >= 1700 ? 'minmax(0, 1fr)' : 'minmax(230px, 1fr)';
                $board.style.gridTemplateColumns = `repeat(${visibleDays.length}, ${minCol})`;

                let html = '';

                visibleDays.forEach(d => {
                    html += `
                        <div class="day-head sticky-top">
                            <div class="day-num">${d.getDate()}</div>
                            <div class="day-name">${nombresDias[d.getDay()]}</div>
                            <div class="day-date">${pad(d.getDate())}/${pad(d.getMonth() + 1)}/${d.getFullYear()}</div>
                        </div>`;
                });

                visibleDays.forEach(d => {
                    const fecha = toDateString(d);
                    const embarques = items
                        .filter(x => x.fecha === fecha)
                        .sort((a, b) => ((a.rutas || []).join(',') + a.cliente + a.consecutivo)
                            .localeCompare((b.rutas || []).join(',') + b.cliente + b.consecutivo));

                    html += `<div class="day-col"><div class="day-slot">`;

                    if (!embarques.length) {
                        html += `<div class="empty-cell">Sin órdenes de matriz para esta fecha de entrega</div>`;
                    } else {
                        html += embarques.map(x => `
                            <div class="embarque-card ${getCardClass(x.estatus)}">
                                <div class="embarque-head">
                                    <div class="embarque-ruta">${escapeHtml((x.rutas || []).join(', '))}</div>
                                    <div class="embarque-kg">${nf.format(x.kilos)} kg</div>
                                </div>

                                <div class="embarque-row">
                                    <span class="badge-mini">${escapeHtml(x.consecutivo || 'SIN PEDIDO')}</span>
                                    <span class="badge-mini">${escapeHtml(x.serie || '')}</span>
                                </div>

                                <div class="embarque-row">
                                    <span class="embarque-label">Cliente:</span>
                                    ${escapeHtml(x.cliente || 'Sin cliente')}
                                    ${x.clienteCodigo && x.clienteCodigo !== x.cliente
                                        ? `<span class="badge-mini" title="Código cliente">${escapeHtml(x.clienteCodigo)}</span>`
                                        : ''
                                    }
                                </div>

                                <div class="embarque-row">
                                    <span class="embarque-label">Vendedor:</span>
                                    ${escapeHtml(x.vendedor || 'Sin vendedor')}
                                </div>

                                <div class="embarque-row">
                                    <span class="embarque-label">Presentación:</span>
                                    ${escapeHtml(x.presentacion || '')}
                                </div>

                                <div class="embarque-row">
                                    <span class="embarque-label">Fletera:</span>
                                    ${escapeHtml(x.fletera || 'Sin asignar')}
                                </div>

                                <div class="embarque-row">
                                    <span class="embarque-label">Tarimas:</span>
                                    ${escapeHtml(x.espacioTarimas || 0)}
                                </div>

                                <div class="embarque-row">
                                    <span class="embarque-label">Llegada unidad:</span>
                                    ${escapeHtml(x.horaLlegadaUnidad || 'Sin definir')}
                                </div>

                                <div class="embarque-row">
                                    <span class="status-chip ${getChipClass(x.estatus)}">${escapeHtml(x.estatus)}</span>
                                </div>

                                ${getMotivoResumen(x)
                                    ? `<div class="embarque-row"><span class="embarque-label">Motivo:</span> ${escapeHtml(getMotivoResumen(x))}</div>`
                                    : ''
                                }

                                <div class="embarque-actions">
                                    <button type="button" class="mini-btn js-edit" data-id="${x.id}">Editar logística</button>
                                  
                                </div>
                            </div>
                        `).join('');
                    }

                    html += `</div></div>`;
                });

                $board.innerHTML = html;
                renderKpis(items);
                renderRangeTitle();
            }

            function renderListado() {
                const items = getFilteredData()
                    .slice()
                    .sort((a, b) => (a.fecha + a.rutas.join(',') + a.cliente).localeCompare(b.fecha + b.rutas.join(',') + b.cliente));

                $listadoCount.textContent = `${items.length} orden${items.length !== 1 ? 'es' : ''} en el rango`;
                $modalListadoTitle.textContent = `Listado de órdenes para logística — ${items.length} registro${items.length !== 1 ? 's' : ''}`;

                if (!items.length) {
                    $tbodyListado.innerHTML = `<tr><td colspan="15" style="text-align:center;">Sin órdenes de matriz en este rango</td></tr>`;
                    return;
                }

                $tbodyListado.innerHTML = items.map(x => `
                    <tr>
                        <td>${escapeHtml(x.fecha)}</td>
                        <td>${escapeHtml(x.consecutivo)}</td>
                        <td>${escapeHtml(x.serie)}</td>
                        <td title="${escapeHtml(x.clienteCodigo || '')}">
                            ${escapeHtml(x.cliente || '')}
                            ${x.clienteCodigo && x.clienteCodigo !== x.cliente ? `<br><span class="badge-mini">${escapeHtml(x.clienteCodigo)}</span>` : ''}
                        </td>
                        <td>${escapeHtml((x.rutas || []).join(', '))}</td>
                        <td>${escapeHtml(x.vendedor)}</td>
                        <td>${escapeHtml(x.presentacion)}</td>
                        <td>${nf.format(x.kilos)}</td>
                        <td>${escapeHtml(x.fletera || 'Sin asignar')}</td>
                        <td><span class="status-chip ${getChipClass(x.estatus)}">${escapeHtml(x.estatus)}</span></td>
                        <td>${escapeHtml(x.espacioTarimas || 0)}</td>
                        <td>${escapeHtml(x.horaLlegadaUnidad || '')}</td>
                        <td>${escapeHtml(x.observacionLogistica || '')}</td>
                        <td>${escapeHtml(getMotivoResumen(x))}</td>
                        <td>
                            <button type="button" class="mini-btn js-edit" data-id="${x.id}">Editar</button>
                            <button type="button" class="mini-btn js-fletera" data-id="${x.id}">Fletera</button>
                        </td>
                    </tr>
                `).join('');
            }

            async function renderAll() {
                $fechaBase.value = toDateString(currentDate);
                renderRangeTitle();
                await cargarPedidosDesdeBD();
                renderVendedores();
                renderBoard();
                renderListado();
            }

            function refreshMotivoInfo(item) {
                const texto = item
                    ? [
                        item.motivoCancelacion ? `Registro cancelado: ${item.motivoCancelacion}` : '',
                        item.motivoCancelacionFletera ? `Fletera cancelada: ${item.motivoCancelacionFletera}` : ''
                    ].filter(Boolean).join(' | ')
                    : '';

                if (texto) {
                    $motivoInfo.style.display = 'block';
                    $motivoInfo.textContent = texto;
                } else {
                    $motivoInfo.style.display = 'none';
                    $motivoInfo.textContent = '';
                }
            }

            function openModal(item) {
                if (!item) {
                    alert('Selecciona una orden de venta existente. Los embarques se generan desde OrdenVenta.');
                    return;
                }

                currentEditItem = item;
                currentEditId = item.ordenVentaId || item.id;

                $modalTitle.textContent = `Ajustar logística — ${item.consecutivo || 'Orden ' + currentEditId}`;

                $mConsecutivo.value = item.consecutivo || '';
                $mSerie.value = item.serie || '';
                $mFecha.value = item.fecha || '';
                $mCliente.value = item.cliente || '';
                $mVendedor.value = item.vendedor || '';
                $mKilos.value = item.kilos || 0;
                $mPresentacion.value = item.presentacion || '';
                $mObservacionVenta.value = item.observaciones || '';

                $mFletera.value = item.fletera || '';
                setEstatusModal(item.estatus || 'PENDIENTE FLETERA');
                $mEspacioTarimas.value = item.espacioTarimas || '';
                $mHoraLlegada.value = item.horaLlegadaUnidad || '';
                $mObservacionLogistica.value = item.observacionLogistica || '';

                renderRutas(item.rutas?.length ? item.rutas : ['SIN RUTA']);
                refreshMotivoInfo(item);

                $modal.classList.add('show');
            }

            function closeModal() {
                $modal.classList.remove('show');
                currentEditId = null;
                currentEditItem = null;
                $motivoInfo.style.display = 'none';
                $motivoInfo.textContent = '';
            }

            function buildPayloadFromModal() {
                if (!currentEditId) {
                    throw new Error('No hay una orden de venta seleccionada.');
                }

                const fletera = ($mFletera.value || '').trim().toUpperCase();
                const estatus = calcularEstatusAutomatico();

                setEstatusModal(estatus);

                return {
                    OrdenVentaId: currentEditId,
                    Fletera: fletera,
                    EspacioTarimas: Number($mEspacioTarimas.value || 0),
                    HoraLlegadaUnidad: $mHoraLlegada.value || null,
                    EstatusLogistico: estatus,
                    ObservacionLogistica: ($mObservacionLogistica.value || '').trim().toUpperCase(),
                    MotivoCancelacion: '',
                    MotivoCancelacionFletera: '',
                    Cancelado: false,
                    CanceladoFletera: false
                };
            }

            function abrirModalCancelacion(tipo) {
                if (!currentEditId || !currentEditItem) {
                    alert('Selecciona una orden de venta primero.');
                    return;
                }

                tipoCancelacionActual = tipo;
                $cancelacionMotivo.value = '';

                if (tipo === 'FLETERA') {
                    $cancelacionTitle.textContent = 'Cancelar fletera';
                    $cancelacionResumen.innerHTML = `
                        <b>Pedido:</b> ${escapeHtml(currentEditItem.consecutivo || '')}<br>
                        <b>Cliente:</b> ${escapeHtml(currentEditItem.cliente || '')}<br>
                        <b>Fletera actual:</b> ${escapeHtml(currentEditItem.fletera || $mFletera.value || 'Sin asignar')}<br>
                        <b>Acción:</b> Se cancelará únicamente la fletera y el estatus quedará como <b>FLETERA CANCELADA</b>.
                    `;
                } else {
                    $cancelacionTitle.textContent = 'Cancelar registro logístico';
                    $cancelacionResumen.innerHTML = `
                        <b>Pedido:</b> ${escapeHtml(currentEditItem.consecutivo || '')}<br>
                        <b>Cliente:</b> ${escapeHtml(currentEditItem.cliente || '')}<br>
                        <b>Acción:</b> Se cancelará el registro logístico completo y el estatus quedará como <b>CANCELADO</b>.
                    `;
                }

                $modalCancelacion.classList.add('show');

                setTimeout(() => {
                    $cancelacionMotivo.focus();
                }, 100);
            }

            function cerrarModalCancelacion() {
                $modalCancelacion.classList.remove('show');
                tipoCancelacionActual = null;
                $cancelacionMotivo.value = '';
            }

            async function confirmarCancelacion() {
                if (!tipoCancelacionActual || !currentEditId || !currentEditItem) {
                    alert('No hay una cancelación válida.');
                    return;
                }

                const motivo = ($cancelacionMotivo.value || '').trim().toUpperCase();

                if (!motivo) {
                    alert('Captura el motivo de cancelación.');
                    return;
                }

                const esCancelacionFletera = tipoCancelacionActual === 'FLETERA';
                const esCancelacionRegistro = tipoCancelacionActual === 'REGISTRO';
                const estatusFinal = esCancelacionFletera ? 'FLETERA CANCELADA' : 'CANCELADO';

                const payload = {
                    OrdenVentaId: currentEditId,
                    Fletera: '',
                    EspacioTarimas: Number($mEspacioTarimas.value || currentEditItem.espacioTarimas || 0),
                    HoraLlegadaUnidad: $mHoraLlegada.value || currentEditItem.horaLlegadaUnidad || null,
                    EstatusLogistico: estatusFinal,
                    ObservacionLogistica: ($mObservacionLogistica.value || currentEditItem.observacionLogistica || '').trim().toUpperCase(),
                    MotivoCancelacion: esCancelacionRegistro ? motivo : (currentEditItem.motivoCancelacion || ''),
                    MotivoCancelacionFletera: esCancelacionFletera ? motivo : (currentEditItem.motivoCancelacionFletera || ''),
                    Cancelado: esCancelacionRegistro,
                    CanceladoFletera: esCancelacionFletera
                };

                try {
                    setLoading(true);
                    await guardarLogisticaRequest(payload);

                    cerrarModalCancelacion();
                    closeModal();

                    await renderAll();
                } catch (error) {
                    console.error(error);
                    alert(error.message || 'No se pudo guardar la cancelación.');
                } finally {
                    setLoading(false);
                }
            }

            async function saveModal() {
                try {
                    const payload = buildPayloadFromModal();

                    setLoading(true);
                    await guardarLogisticaRequest(payload);

                    currentDate = parseDate($mFecha.value);
                    closeModal();
                    await renderAll();
                } catch (error) {
                    console.error(error);
                    alert(error.message || 'No se pudo guardar logística.');
                } finally {
                    setLoading(false);
                }
            }

            async function quickAssignCarrier(id) {
                const item = data.find(x => x.id === id || x.ordenVentaId === id);
                if (!item) return;

                const nuevaFletera = prompt(
                    'Escribe la fletera para este embarque. Deja vacío para quitarla:',
                    item.fletera || ''
                );

                if (nuevaFletera === null) return;

                const fletera = nuevaFletera.trim().toUpperCase();

                const payload = {
                    OrdenVentaId: item.ordenVentaId || item.id,
                    Fletera: fletera,
                    EspacioTarimas: item.espacioTarimas || 0,
                    HoraLlegadaUnidad: item.horaLlegadaUnidad || null,
                    EstatusLogistico: fletera ? 'ASIGNADO' : 'PENDIENTE FLETERA',
                    ObservacionLogistica: item.observacionLogistica || '',
                    MotivoCancelacion: item.motivoCancelacion || '',
                    MotivoCancelacionFletera: '',
                    Cancelado: false,
                    CanceladoFletera: false
                };

                try {
                    setLoading(true);
                    await guardarLogisticaRequest(payload);
                    await renderAll();
                } catch (error) {
                    console.error(error);
                    alert(error.message || 'No se pudo guardar la fletera.');
                } finally {
                    setLoading(false);
                }
            }

            function cancelarFleteraActual() {
                abrirModalCancelacion('FLETERA');
            }

            function cancelarRegistroActual() {
                abrirModalCancelacion('REGISTRO');
            }

            async function navigate(step) {
                if ($vistaTipo.value === 'day') {
                    currentDate = addDays(currentDate, step);
                } else {
                    currentDate = addDays(currentDate, step * 7);
                }

                await renderAll();
            }

            async function resetFilters() {
                $vistaTipo.value = 'week';
                $filtroVendedor.value = '';
                $filtroEstatus.value = '';
                currentDate = getTodayNoon();
                await renderAll();
            }

            function openListadoModal() {
                renderListado();
                $modalListado.classList.add('show');
            }

            function closeListadoModal() {
                $modalListado.classList.remove('show');
            }

            $btnPrev.addEventListener('click', () => navigate(-1));
            $btnNext.addEventListener('click', () => navigate(1));
            $btnHoy.addEventListener('click', async () => {
                currentDate = getTodayNoon();
                await renderAll();
            });

            $fechaBase.addEventListener('change', async () => {
                if ($fechaBase.value) {
                    currentDate = parseDate($fechaBase.value);
                    await renderAll();
                }
            });

            $vistaTipo.addEventListener('change', renderAll);
            $btnFiltrar.addEventListener('click', renderAll);
            $btnReset.addEventListener('click', resetFilters);

            $btnCancelar.addEventListener('click', closeModal);
            $btnCancelar2.addEventListener('click', closeModal);
            $btnGuardar.addEventListener('click', saveModal);

            $btnCancelarFletera.addEventListener('click', cancelarFleteraActual);
            $btnCancelarRegistro.addEventListener('click', cancelarRegistroActual);

            $btnCerrarCancelacion.addEventListener('click', cerrarModalCancelacion);
            $btnCancelarCancelacion.addEventListener('click', cerrarModalCancelacion);
            $btnConfirmarCancelacion.addEventListener('click', confirmarCancelacion);

            $mFletera.addEventListener('input', () => {
                const estatus = calcularEstatusAutomatico();
                setEstatusModal(estatus);
            });

            $btnVerListado.addEventListener('click', openListadoModal);
            $btnCerrarListado.addEventListener('click', closeListadoModal);
            $btnCerrarListado2.addEventListener('click', closeListadoModal);

            $modal.addEventListener('click', e => {
                if (e.target === $modal) closeModal();
            });

            $modalListado.addEventListener('click', e => {
                if (e.target === $modalListado) closeListadoModal();
            });

            $modalCancelacion.addEventListener('click', e => {
                if (e.target === $modalCancelacion) cerrarModalCancelacion();
            });

            $board.addEventListener('click', e => {
                const editBtn = e.target.closest('.js-edit');
                if (editBtn) {
                    const item = data.find(x => x.id === Number(editBtn.dataset.id));
                    if (item) openModal(item);
                    return;
                }

                const fleteraBtn = e.target.closest('.js-fletera');
                if (fleteraBtn) {
                    quickAssignCarrier(Number(fleteraBtn.dataset.id));
                }
            });

            $tbodyListado.addEventListener('click', e => {
                const editBtn = e.target.closest('.js-edit');
                if (editBtn) {
                    const item = data.find(x => x.id === Number(editBtn.dataset.id));
                    if (item) {
                        closeListadoModal();
                        openModal(item);
                    }
                    return;
                }

                const fleteraBtn = e.target.closest('.js-fletera');
                if (fleteraBtn) {
                    quickAssignCarrier(Number(fleteraBtn.dataset.id));
                }
            });

            let resizeTimer = null;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(() => {
                    renderBoard();
                    renderListado();
                }, 150);
            });

            renderRutas(['SIN RUTA']);
            renderAll();
        })();
    </script>
}
