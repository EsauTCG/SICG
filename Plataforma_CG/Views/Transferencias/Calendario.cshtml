@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewBag.Title = "Calendario de Logística";
}

@Html.AntiForgeryToken()

<style>
    :root {
        --bg: #f1dede;
        --panel: #f8eeee;
        --line: #c79d9d;
        --line-dark: #8f4c4c;
        --text: #351313;
        --muted: #6d4c4c;
        --brand: #8B0000;
        --brand-dark: #5c0000;
        --brand-light: #b30000;
        --gold: #c79c00;
        --gold-dark: #8d6d00;
        --ok: #198754;
        --warn: #ffc107;
        --danger: #dc3545;
        --orange: #ff8c00;
        --card: #f6e7e7;
        --card2: #efdddd;
        --slot: #f3e3e3;
        --slot2: #ecd8d8;
    }

    html,
    body {
        width: 100%;
        min-height: 100%;
        margin: 0;
        overflow-x: hidden;
    }

    body {
        font-family: Tahoma, Verdana, Arial, sans-serif;
        background: transparent !important;
    }

    .cal-window {
        width: calc(100vw - 18px);
        max-width: none;
        min-height: calc(100vh - 18px);
        margin: 0 auto 8px auto;
        border: 1px solid #7e4a4a;
        background: var(--panel);
        box-shadow: 0 0 0 1px rgba(255,255,255,.45) inset, 0 8px 18px rgba(70,12,12,.14);
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .cal-titlebar {
        min-height: 38px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 0 14px;
        background: linear-gradient(180deg,#c00000 0%,#8b0000 60%,#5c0000 100%);
        border-bottom: 1px solid #5c0000;
        color: #fff;
        font-size: 15px;
        font-weight: bold;
    }

    .cal-titlebar small {
        display: block;
        font-size: 11px;
        font-weight: 400;
        opacity: .92;
    }

    .cal-content {
        padding: clamp(8px, .7vw, 14px);
        background: var(--bg);
        flex: 1;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    .section {
        border: 1px solid var(--line);
        background: transparent;
        margin-bottom: 10px;
        flex-shrink: 0;
    }

    .section-calendar {
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    .section-calendar .section-body {
        flex: 1 1 auto;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    .section-title {
        padding: 6px 10px;
        font-size: 13px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
    }

    .section-body {
        padding: 10px 12px;
        background: transparent;
    }

    .toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: flex-end;
    }

    .toolbar-group {
        display: flex;
        gap: 8px;
        align-items: flex-end;
        flex-wrap: wrap;
    }

    .toolbar-sep {
        width: 1px;
        height: 36px;
        background: var(--line);
        margin: 0 4px;
        align-self: flex-end;
    }

    .form-label {
        display: block;
        color: #5c1a1a;
        font-size: 12px;
        margin-bottom: 3px;
        font-weight: bold;
    }

    .form-control, .form-select {
        border: 1px solid #b48787 !important;
        background: #fff7f7 !important;
        color: #421414 !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        font-size: 13px !important;
        height: 36px !important;
    }

    .form-control[readonly],
    .form-control:disabled,
    .form-select:disabled {
        background: #ead6d6 !important;
        color: #604040 !important;
        opacity: 1 !important;
        cursor: not-allowed;
    }

    textarea.form-control {
        height: auto !important;
        resize: vertical;
    }

    .form-control:focus, .form-select:focus {
        border-color: #8b0000 !important;
        box-shadow: 0 0 0 .18rem rgba(139,0,0,.14) !important;
    }

    .btn-main, .btn-light, .btn-gold, .btn-danger-soft, .btn-orange-soft {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        min-height: 36px;
        padding: 0 14px;
        font-weight: 700;
        border-radius: 0;
        font-size: 13px;
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
    }

    .btn-main {
        border: 1px solid #7a2d2d;
        color: #fff;
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
    }

    .btn-light {
        border: 1px solid #b48787;
        color: #4b1f1f;
        background: linear-gradient(#fffefe,#ecd7d7);
    }

    .btn-gold {
        border: 1px solid var(--gold-dark);
        color: #fff;
        background: linear-gradient(180deg,#dcb000 0%,#c79c00 55%,#a88000 100%);
    }

    .btn-danger-soft {
        border: 1px solid #b02a37;
        color: #fff;
        background: linear-gradient(180deg,#dc3545 0%,#c12d3c 55%,#9f2030 100%);
    }

    .btn-orange-soft {
        border: 1px solid #d97706;
        color: #fff;
        background: linear-gradient(180deg,#ff9f1a 0%,#ff8c00 55%,#d97706 100%);
    }

    .btn-main:disabled,
    .btn-light:disabled,
    .btn-gold:disabled,
    .btn-danger-soft:disabled,
    .btn-orange-soft:disabled,
    .mini-btn:disabled {
        opacity: .55;
        cursor: not-allowed;
    }

    .range-title {
        font-size: 17px;
        font-weight: 700;
        color: #5a1111;
        padding: 6px 0 0 0;
    }

    .loading-bar {
        display: none;
        margin-top: 8px;
        padding: 7px 10px;
        border: 1px solid #d6b4b4;
        background: #fff5f5;
        color: #5a1111;
        font-size: 12px;
        font-weight: 700;
    }

    .loading-bar.show {
        display: block;
    }

    .kpis {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: center;
    }

    .kpi-card {
        min-width: 170px;
        border: 1px solid #d8bcbc;
        background: linear-gradient(#fffefe,#f1dddd);
        padding: 10px 14px;
        text-align: center;
        flex: 1 1 170px;
        max-width: 230px;
    }

    .kpi-title {
        font-size: 11px;
        color: #7a0000;
        font-weight: 700;
        margin-bottom: 4px;
        text-transform: uppercase;
    }

    .kpi-value {
        font-size: 20px;
        font-weight: 700;
        color: #401515;
        font-variant-numeric: tabular-nums;
    }

    .legend {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 10px;
        font-size: 12px;
        color: #4b1f1f;
        justify-content: center;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .legend-box {
        width: 14px;
        height: 14px;
        border: 1px solid #a87e7e;
    }

    .lg-programado { background: #8b0000; }
    .lg-pendiente { background: #c79c00; }
    .lg-asignado { background: #198754; }
    .lg-cancelado-fletera { background: #ff8c00; border-color: #c75b00; }
    .lg-cancelado { background: #8b0000; border-color: #5c0000; }

    .calendar-wrap {
        overflow: auto;
        border: 1px solid var(--line);
        background: transparent;
        width: 100%;
        flex: 1 1 auto;
        min-height: 460px;
        height: max(460px, calc(100vh - 345px));
        max-height: none;
    }

    .calendar-board {
        min-width: 1280px;
        width: 100%;
        min-height: 100%;
        display: grid;
        grid-template-columns: repeat(7, minmax(230px, 1fr));
        background: transparent;
    }

    .sticky-top {
        position: sticky;
        top: 0;
        z-index: 20;
    }

    .day-head {
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
        color: #fff;
        border-right: 1px solid #8e3b3b;
        border-bottom: 1px solid #5c0000;
        padding: 8px 10px;
        min-height: 62px;
    }

    .day-num {
        font-size: 26px;
        line-height: 1;
        font-weight: 700;
    }

    .day-name {
        font-size: 12px;
        margin-top: 4px;
    }

    .day-date {
        font-size: 11px;
        opacity: .9;
    }

    .day-col {
        background: #f4e4e4;
        border-right: 1px solid #d2b1b1;
    }

    .day-slot {
        min-height: 100%;
        height: 100%;
        border-bottom: 1px solid #d2b1b1;
        padding: 6px;
        background: linear-gradient(to bottom, rgba(255,255,255,.08), rgba(255,255,255,0));
    }

    .embarque-card {
        border: 1px solid #b99595;
        background: linear-gradient(#f7eded,#ecd8d8);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.6);
        padding: 8px;
        font-size: 12px;
        color: #2e1111;
        margin-bottom: 6px;
        min-height: 140px;
    }

    .embarque-card.programado { border-left: 5px solid #8b0000; }
    .embarque-card.pendiente { border-left: 5px solid #c79c00; }
    .embarque-card.asignado { border-left: 5px solid #198754; }

    .embarque-card.cancelado-fletera {
        border-left: 6px solid #c75b00;
        background: linear-gradient(180deg,#fff0d9 0%, #ffd59a 50%, #ffbe66 100%);
        border-color: #d97706;
    }

    .embarque-card.cancelado {
        border-left: 7px solid #7a0000;
        background: linear-gradient(180deg,#ffd9d9 0%, #ffb3b3 45%, #ff8f8f 100%);
        border-color: #8b0000;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.35), 0 0 0 1px rgba(122,0,0,.18);
        opacity: 1;
    }

    .embarque-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 8px;
        margin-bottom: 6px;
    }

    .embarque-ruta {
        font-weight: 700;
        color: #7a0000;
        font-size: 12px;
        text-transform: uppercase;
    }

    .embarque-kg {
        font-weight: 700;
        font-size: 12px;
        background: #fff3f3;
        border: 1px solid #d8bcbc;
        padding: 2px 6px;
        white-space: nowrap;
    }

    .embarque-row {
        margin-bottom: 3px;
        line-height: 1.25;
    }

    .embarque-label {
        font-weight: 700;
        color: #6b1f1f;
    }

    .embarque-actions {
        margin-top: 7px;
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .mini-btn {
        border: 1px solid #b48787;
        background: linear-gradient(#fffefe,#ecd7d7);
        color: #4b1f1f;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 8px;
        cursor: pointer;
    }

    .status-chip {
        display: inline-block;
        padding: 2px 7px;
        font-size: 11px;
        font-weight: 700;
        color: #fff;
    }

    .status-programado { background: #8b0000; }
    .status-pendiente { background: #c79c00; }
    .status-asignado { background: #198754; }

    .status-cancelado-fletera {
        background: linear-gradient(180deg,#ff9f1a 0%, #ff8c00 55%, #d97706 100%);
        color: #fff;
        border: 1px solid #b45309;
    }

    .status-cancelado {
        background: linear-gradient(180deg,#b30000 0%, #8b0000 55%, #5c0000 100%);
        color: #fff;
        border: 1px solid #4a0000;
    }

    .listado-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .listado-count {
        font-size: 13px;
        color: #5a1111;
        font-weight: 700;
    }

    .table-responsive {
        overflow: auto;
        border: 1px solid #d3b2b2;
        background: #f7ebeb;
    }

    .table-list {
        width: 100%;
        border-collapse: collapse;
        background: transparent;
        margin-top: 0;
    }

    .table-list th {
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
        color: #fff;
        font-size: 12px;
        padding: 7px 6px;
        border: 1px solid #8e3b3b;
        text-align: left;
        white-space: nowrap;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .table-list td {
        padding: 7px 6px;
        border: 1px solid #d3b2b2;
        font-size: 12px;
        color: #2f1111;
        background: #f7ebeb;
        vertical-align: middle;
    }

    .table-list tr:hover td {
        background: #f0dede;
    }

    .modal-mask {
        position: fixed;
        inset: 0;
        background: rgba(35,8,8,.45);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        padding: 20px;
    }

    .modal-mask.show {
        display: flex;
    }

    .modal-box {
        width: min(980px, 96vw);
        border: 1px solid #7e4a4a;
        background: var(--panel);
        box-shadow: 0 0 0 1px rgba(255,255,255,.45) inset, 0 18px 40px rgba(30,0,0,.35);
        overflow: hidden;
    }

    .modal-box.wide {
        width: min(1900px, calc(100vw - 28px));
        max-height: calc(100vh - 28px);
        display: flex;
        flex-direction: column;
    }

    .modal-box.wide .modal-body {
        overflow-y: auto;
        flex: 1;
    }

    .modal-title {
        padding: 10px 12px;
        color: #fff;
        font-size: 14px;
        font-weight: 700;
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .modal-close {
        background: none;
        border: none;
        color: #fff;
        font-size: 18px;
        cursor: pointer;
        line-height: 1;
        padding: 0 4px;
        opacity: .8;
    }

    .modal-close:hover {
        opacity: 1;
    }

    .modal-body {
        padding: 14px;
        background: #f4e4e4;
    }

    #modal-mask .modal-body {
        overflow: auto;
        flex: 1 1 auto;
    }

    .modal-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .modal-grid .full {
        grid-column: 1 / -1;
    }

    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        padding: 12px 14px;
        border-top: 1px solid #d6b4b4;
        background: #f0dddd;
    }

    .empty-cell {
        color: #8a6666;
        font-size: 11px;
        padding-top: 2px;
    }

    .split-grid {
        display: grid;
        grid-template-columns: 1.15fr .85fr;
        gap: 12px;
    }

    .ruta-row {
        display: flex;
        gap: 8px;
        margin-bottom: 8px;
        align-items: center;
    }

    .ruta-row .form-control {
        flex: 1;
    }

    .motivo-box {
        margin-top: 10px;
        padding: 8px;
        border: 1px dashed #b48787;
        background: #fff5f5;
        font-size: 12px;
        color: #5a1111;
    }

    .badge-mini {
        display: inline-block;
        font-size: 10px;
        font-weight: 700;
        padding: 2px 6px;
        border: 1px solid #b48787;
        background: #fff7f7;
        color: #6b1f1f;
        margin-right: 3px;
    }

    .container,
    .container-fluid {
        max-width: none !important;
        width: 100% !important;
        background: transparent !important;
        box-shadow: none !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
    }

    main,
    .content-wrapper,
    .page-content,
    .main-content,
    .wrapper,
    .body-content {
        max-width: none !important;
        width: 100% !important;
        background: transparent !important;
        box-shadow: none !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
    }


    @@media (min-width: 1700px) {
        .cal-titlebar {
            min-height: 44px;
            font-size: 16px;
        }

        .section-title {
            font-size: 14px;
            padding: 7px 12px;
        }

        .form-control,
        .form-select,
        .btn-main,
        .btn-light,
        .btn-gold,
        .btn-danger-soft,
        .btn-orange-soft {
            height: 38px !important;
            min-height: 38px;
            font-size: 13.5px !important;
        }

        .kpi-card {
            max-width: none;
            min-width: 190px;
            padding: 11px 16px;
        }

        .kpi-value {
            font-size: 23px;
        }

        .calendar-board {
            min-width: 0;
            grid-template-columns: repeat(7, minmax(0, 1fr));
        }

        .embarque-card {
            font-size: 12.5px;
            min-height: 150px;
        }
    }

    @@media (min-width: 2200px) {
        .cal-window {
            width: calc(100vw - 26px);
        }

        .calendar-wrap {
            height: max(560px, calc(100vh - 345px));
        }

        .calendar-board {
            grid-template-columns: repeat(7, minmax(0, 1fr));
        }

        .embarque-card {
            font-size: 13px;
        }
    }

    @@media (max-width: 1200px) {
        .toolbar-sep {
            display: none;
        }

        .modal-grid,
        .split-grid {
            grid-template-columns: 1fr;
        }

        .calendar-board {
            min-width: 1120px;
            grid-template-columns: repeat(7, minmax(180px, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .calendar-board {
            min-width: 980px;
        }

        .calendar-wrap {
            min-height: 420px;
            height: max(420px, calc(100vh - 300px));
            max-height: none;
        }

        .day-slot {
            min-height: 100%;
        }

        .ruta-row {
            flex-direction: column;
            align-items: stretch;
        }
    }


    /* =========================================================
       KPIS A COLOR - Calendario de Logística
       Mantiene los mismos IDs de JavaScript y solo mejora vista.
       ========================================================= */
    .kpis {
        align-items: stretch;
    }

    .kpi-card {
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,.28) !important;
        border-radius: 14px;
        min-height: 92px;
        box-shadow: inset 5px 0 0 rgba(255,255,255,.18), 0 12px 24px rgba(49, 7, 7, .14) !important;
    }

    .kpi-card::after {
        content: "";
        position: absolute;
        right: -34px;
        bottom: -44px;
        width: 122px;
        height: 122px;
        border-radius: 999px;
        background: rgba(255,255,255,.14);
        border: 18px solid rgba(255,255,255,.07);
        pointer-events: none;
    }

    .kpi-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,.10), transparent 52%);
        pointer-events: none;
    }

    .kpi-title,
    .kpi-value {
        position: relative;
        z-index: 1;
    }

    .kpi-card .kpi-title {
        color: rgba(255,255,255,.90) !important;
        letter-spacing: .055em;
        font-size: 11px !important;
    }

    .kpi-card .kpi-value {
        color: #ffffff !important;
        text-shadow: 0 2px 8px rgba(0,0,0,.22);
        font-size: clamp(20px, 1.45vw, 27px) !important;
    }

    .kpi-ordenes {
        background: linear-gradient(135deg, #7b1113 0%, #a3161a 55%, #5c090b 100%) !important;
    }

    .kpi-kilos {
        background: linear-gradient(135deg, #174ea6 0%, #2563eb 55%, #0f2f73 100%) !important;
    }

    .kpi-pendientes {
        background: linear-gradient(135deg, #b7791f 0%, #d99a28 55%, #8a4f05 100%) !important;
    }

    .kpi-asignados {
        background: linear-gradient(135deg, #157f49 0%, #22a65a 55%, #0f5132 100%) !important;
    }

    .kpi-cancelados {
        background: linear-gradient(135deg, #991b1b 0%, #dc2626 55%, #6f0808 100%) !important;
    }

    .kpi-card:hover {
        transform: translateY(-1px);
        box-shadow: inset 5px 0 0 rgba(255,255,255,.20), 0 16px 30px rgba(49, 7, 7, .18) !important;
    }

    @@media (max-width: 768px) {
        .kpi-card {
            min-width: 145px !important;
            min-height: 82px;
            flex: 1 1 145px;
            padding: 9px 10px;
        }

        .kpi-card .kpi-title {
            font-size: 10px !important;
        }

        .kpi-card .kpi-value {
            font-size: 19px !important;
        }
    }

</style>

<div class="cal-window">
    <div class="cal-titlebar">
        <div>
            Calendario de Logística / Embarques
           @*  <small>Órdenes de venta de MATRIZ por FechaEntrega</small> *@
        </div>
        <div id="title-clock"></div>
    </div>

    <div class="cal-content">

        <div class="section">
            <div class="section-title">Navegación y filtros</div>
            <div class="section-body">
                <div class="toolbar">
                    <div class="toolbar-group">
                        <div>
                            <label class="form-label">Vista</label>
                            <select id="vista-tipo" class="form-select" style="width:120px;">
                                <option value="week">Semana</option>
                                <option value="day">Día</option>
                            </select>
                        </div>

                        <div>
                            <label class="form-label">Ir a fecha entrega</label>
                            <input type="date" id="fecha-base" class="form-control" style="width:155px;" />
                        </div>
                    </div>

                    <div class="toolbar-sep"></div>

                    <div class="toolbar-group">
                        <div>
                            <label class="form-label">Vendedor</label>
                            <select id="filtro-vendedor" class="form-select" style="width:190px;">
                                <option value="">Todos</option>
                            </select>
