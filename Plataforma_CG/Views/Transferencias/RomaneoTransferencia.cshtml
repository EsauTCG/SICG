@using System.Linq
@using Plataforma_CG.Models
@model Plataforma_CG.ViewModels.RomaneoTransferenciasVM
@{
    Layout = "~/Views/Shared/_Layout2.cshtml";

    var desdeDef = (Model?.Desde ?? DateTime.Today).ToString("yyyy-MM-dd");
    var hastaDef = (Model?.Hasta ?? DateTime.Today).ToString("yyyy-MM-dd");

    var rows = Model?.Rows ?? new List<Plataforma_CG.ViewModels.RomaneoTransferenciasRowVM>();

    var totalCajasGlobal = rows.Sum(x => x.Cajas);
    var totalPesoGlobal = rows.Sum(x => x.Peso);

    var destSel = Model?.DestinosSeleccionados ?? new List<string>();
    var pedSel = Model?.PedidosSeleccionados ?? new List<string>();
    var tarSel = Model?.TarimasSeleccionadas ?? new List<string>();
    var codigoEtiquetaDef = Model?.CodigoEtiqueta ?? "";

    string LabelMulti(List<string> sel, string emptyText, string pluralText)
    {
        if (sel == null || sel.Count == 0) return emptyText;
        if (sel.Count <= 3) return string.Join(", ", sel);
        return $"{sel.Count} {pluralText}";
    }

    var logoUrl = Url.Content("~/images/sigoNegro.png");

    var excelUrl = Url.Action("ExportCaducidadTransferencias", "Transferencias",
        new
        {
            desde = Model?.Desde?.ToString("yyyy-MM-dd"),
            hasta = Model?.Hasta?.ToString("yyyy-MM-dd"),
            destinosSel = destSel,
            pedidosSel = pedSel,
            tarimasSel = tarSel
        });
}

