    page-break-inside: avoid !important;
}

        #excelOverlay { display: none !important; }
    }

    /* Excel overlay */
    #excelOverlay{
        position:fixed;
        inset:0;
        background:rgba(15, 23, 42, .45);
        z-index:99999;
        display:none;
        align-items:center;
        justify-content:center;
        padding:18px;
    }

    #excelOverlay.show{ display:flex; }

    .excel-modal{
        width:min(420px, 92vw);
        background:#fff;
        border:1px solid #d9d9d9;
        border-radius:14px;
        box-shadow:0 10px 30px rgba(0,0,0,.18);
        padding:18px 16px;
        text-align:center;
    }

    .excel-title{ margin-top:10px; font-weight:900; font-size:16px; color:#1d2d3e; }
    .excel-sub{ margin-top:4px; font-weight:700; font-size:12.5px; color:#556b82; }

    .spinner{
        width:44px;
        height:44px;
        border-radius:50%;
        border:5px solid #e6e6e6;
        border-top-color:#0a6ed1;
        margin:0 auto;
        animation:spin .9s linear infinite;
    }

    @@keyframes spin{
        from{ transform:rotate(0deg); }
        to{ transform:rotate(360deg); }
    }

    @@media(max-width:768px){
        .tablewrap table.t{ min-width:900px; }
        .statusbar{ font-size:10px; }
    }

    .excel-btn{
    background: #18a85b;
    color: #fff;
    border: 1px solid #0f7e44;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    font-weight: 700;
    text-decoration: none;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.15);
}

.excel-btn i{
    color: #fff;
}
.pm-btn{
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: 8px 14px;
    border: 1px solid transparent;
    text-decoration: none;
    font-weight: 600;
    cursor: pointer;
}

.pm-btn-excel{
    color: #fff;
    border-color: #157347;
    background: linear-gradient(180deg, #27ae60 0%, #1f9a54 55%, #198754 100%);
}

.pm-btn-excel i,
.pm-btn-excel span{
    color: #fff;
}

.pm-btn-excel:hover{
    color: #fff;
    border-color: #146c43;
    background: linear-gradient(180deg, #2dc26b 0%, #239b59 55%, #1b7f4f 100%);
}

.pm-btn-excel:visited,
.pm-btn-excel:focus{
    color: #fff;
    text-decoration: none;
}

