<div class="window">

@*     <div class="titlebar no-print">
        <div></div>
        <div class="actions">
            <div class="win-btn"></div>
            <div class="win-btn"></div>
            <div class="win-btn"></div>
        </div>
    </div> *@



    <div class="content">


        <div class="workspace">

            <!-- PRINT HEADER -->
            <div class="print-only">
                <div class="print-top">
                    <div class="print-logo">
                        <img src="@logoUrl" alt="Logo" />
                    </div>
                    <div class="print-title">
                        <div style="font-size:28px;font-weight:900;margin:0 0 3px;color:#111;text-align:center;">Embarque concentrado por tarima</div>
                        <div style="font-size:10.5px;color:#333;line-height:1.3;">
                            Muestra la información concentrada de cada pedido surtido, agrupada por tarima.
                        </div>
                    </div>
                    <div class="print-meta" style="font-size:11px;line-height:1.4;">
                        <div><b>Fecha Inicial:</b> @(Model?.Desde?.ToString("dd/MM/yyyy") ?? "")</div>
                        <div><b>Fecha Final:</b> @(Model?.Hasta?.ToString("dd/MM/yyyy") ?? "")</div>
                        <div><b>Destino:</b> @(destSel.Any() ? string.Join(", ", destSel) : "TODOS")</div>
                        <div><b>Transferencia:</b> @(pedSel.Any() ? string.Join(", ", pedSel) : "TODOS")</div>
                        <div><b>Tarima:</b> @(tarSel.Any() ? string.Join(", ", tarSel) : "TODAS")</div>
                        <div><b>Impreso:</b> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                </div>

                <div class="print-kpis">
                    <div class="kpi-box">
                        <div style="font-size:28px;line-height:1;">📦</div>
                        <div>
                            <div style="font-size:18px;font-weight:900;color:var(--print-red);line-height:1.1;">@totalCajasGlobal</div>
                            <div style="font-size:11px;color:#111;">Unidades Surtidas</div>
                        </div>
                    </div>
                    <div class="kpi-box">
                        <div style="font-size:28px;line-height:1;">⚖️</div>
                        <div>
                            <div style="font-size:18px;font-weight:900;color:var(--print-red);line-height:1.1;">@totalPesoGlobal.ToString("N0") Kg</div>
                            <div style="font-size:11px;color:#111;">Kilogramos Surtidos</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FILTROS -->
            <div class="section no-print">
                <div class="section-title">Filtros de búsqueda</div>
                <form id="frmRomaneo" method="get" style="padding:10px; background:var(--panel-2);">
                    <div class="grid">

                        <div class="gcol-3">
                            <div class="label">Fecha inicial</div>
                            <input type="date" class="in" name="desde" value="@desdeDef" />
                        </div>

                        <div class="gcol-3">
                            <div class="label">Fecha final</div>
                            <input type="date" class="in" name="hasta" value="@hastaDef" />
                        </div>

                        <div class="gcol-2">
                            <div class="label">Destino</div>
                            <div class="dropdown w-100 multi-dd" id="dd-destino">
                                <button class="in" type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                        style="text-align:left; display:flex; align-items:center; justify-content:space-between;">
                                    <span class="multi-label">@LabelMulti(destSel, "(Todos)", "seleccionados")</span>
                                    <span style="margin-left:10px;">▾</span>
                                </button>
                                <ul class="dropdown-menu w-100 p-2" style="max-height:260px; overflow-y:auto;">
                                    <li class="mb-2">
                                        <input type="text" class="form-control form-control-sm dd-search" placeholder="Buscar destino..." />
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    @foreach (var d in (Model?.Destinos ?? new List<string>()))
                                    {
                                        var isChecked = destSel.Contains(d);
                                        var id = "dest_" + d.Replace(" ", "_").Replace("/", "_").Replace("\\", "_");
                                        <li class="px-1 dd-item" data-text="@d">
                                            <div class="form-check">
                                                <input class="form-check-input dd-check" type="checkbox" value="@d" id="@id" data-text="@d" @(isChecked ? "checked" : null) />
                                                <label class="form-check-label" for="@id">@d</label>
                                            </div>
                                        </li>
                                    }
                                    <li class="dd-actions mt-2 d-flex justify-content-between gap-2">
                                        <button type="button" class="btn btn-sm btn-outline-secondary dd-clear">Limpiar</button>
                                        <button type="button" class="btn btn-sm btn-primary dd-apply">Aplicar</button>
                                    </li>
                                </ul>
                                <div class="dd-hidden">
                                    @foreach (var d in destSel) { <input type="hidden" name="destinosSel" value="@d" /> }
                                </div>
                            </div>
                        </div>

                        <div class="gcol-2">
                            <div class="label">Transferencia</div>
                            <div class="dropdown w-100 multi-dd" id="dd-pedido">
                                <button class="in" type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                        style="text-align:left; display:flex; align-items:center; justify-content:space-between;">
                                    <span class="multi-label">@LabelMulti(pedSel, "(Todos)", "seleccionados")</span>
                                    <span style="margin-left:10px;">▾</span>
                                </button>
                                <ul class="dropdown-menu w-100 p-2" style="max-height:260px; overflow-y:auto;">
                                    <li class="mb-2">
                                        <input type="text" class="form-control form-control-sm dd-search" placeholder="Buscar transferencia..." />
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    @foreach (var p in (Model?.Pedidos ?? new List<string>()))
                                    {
                                        var isChecked = pedSel.Contains(p);
                                        var id = "ped_" + p.Replace(" ", "_").Replace("/", "_").Replace("\\", "_");
                                        <li class="px-1 dd-item" data-text="@p">
                                            <div class="form-check">
                                                <input class="form-check-input dd-check" type="checkbox" value="@p" id="@id" data-text="@p" @(isChecked ? "checked" : null) />
                                                <label class="form-check-label" for="@id">@p</label>
                                            </div>
                                        </li>
                                    }
                                    <li class="dd-actions mt-2 d-flex justify-content-between gap-2">
                                        <button type="button" class="btn btn-sm btn-outline-secondary dd-clear">Limpiar</button>
                                        <button type="button" class="btn btn-sm btn-primary dd-apply">Aplicar</button>
                                    </li>
                                </ul>
                                <div class="dd-hidden">
                                    @foreach (var p in pedSel) { <input type="hidden" name="pedidosSel" value="@p" /> }
                                </div>
                            </div>
                        </div>

                        <div class="gcol-2">
                            <div class="label">Tarima</div>
                            <div class="dropdown w-100 multi-dd" id="dd-tarima">
                                <button class="in" type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                        style="text-align:left; display:flex; align-items:center; justify-content:space-between;">
                                    <span class="multi-label">@LabelMulti(tarSel, "(Todas)", "seleccionadas")</span>
                                    <span style="margin-left:10px;">▾</span>
                                </button>
                                <ul class="dropdown-menu w-100 p-2" style="max-height:260px; overflow-y:auto;">
                                    <li class="mb-2">
                                        <input type="text" class="form-control form-control-sm dd-search" placeholder="Buscar tarima..." />
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    @foreach (var t in (Model?.Tarimas ?? new List<string>()))
                                    {
                                        var isChecked = tarSel.Contains(t);
                                        var id = "tar_" + t.Replace(" ", "_").Replace("/", "_").Replace("\\", "_");
                                        <li class="px-1 dd-item" data-text="@t">
                                            <div class="form-check">
                                                <input class="form-check-input dd-check" type="checkbox" value="@t" id="@id" data-text="@t" @(isChecked ? "checked" : null) />
                                                <label class="form-check-label" for="@id">@t</label>
                                            </div>
                                        </li>
                                    }
                                    <li class="dd-actions mt-2 d-flex justify-content-between gap-2">
                                        <button type="button" class="btn btn-sm btn-outline-secondary dd-clear">Limpiar</button>
                                        <button type="button" class="btn btn-sm btn-primary dd-apply">Aplicar</button>
                                    </li>
                                </ul>
                                <div class="dd-hidden">
                                    @foreach (var t in tarSel) { <input type="hidden" name="tarimasSel" value="@t" /> }
                                </div>
                            </div>
                        </div>

                       <div class="gcol-3">
    <div class="label">Código etiqueta</div>
    <input type="text" class="in" name="codigoEtiqueta" value="@codigoEtiquetaDef" placeholder="Ej. DEST0002343115101" />
</div>



                        <div class="gcol-12 filtro-botones no-print">
                            <button class="btnx btn-primary" type="submit">
                                <i class="bi bi-search"></i><span>Buscar</span>
                            </button>

                            <a class="btnx btn-ghost" href="@Url.Action("RomaneoTransferencia", "Transferencias")">
                                Limpiar
                            </a>

                            <a id="btnExcelAviso"
                               class="pm-btn pm-btn-excel"
                               href="javascript:void(0);"
                               data-url="@excelUrl">
                                <i class="bi bi-filetype-xls"></i> <span>Aviso de Movilización</span>
                            </a>

                            <button type="button" class="tool-btn" onclick="window.print()">
                                <i class="fa-solid fa-print"></i> Imprimir
                            </button>
                        </div>

                    </div>
                </form>
            </div>

            <!-- RESULTADOS -->
            <div class="section">
                @* <div class="section-title">Listado de embarques por tarima</div> *@
                <div style="padding:10px;">

                    @if (!rows.Any())
                    {
                        <div class="empty">Sin resultados para los filtros seleccionados.</div>
                    }
                    else
                    {
                        var grupos = rows
                            .GroupBy(r => new { r.Pedido, r.Fecha, r.Destino })
                            .OrderBy(g => g.Key.Fecha)
                            .ThenBy(g => g.Key.Pedido);

                        foreach (var g in grupos)
                        {
                            var totalCajas = g.Sum(x => x.Cajas);
                            var totalPeso = g.Sum(x => x.Peso);
                            var totalUnid = totalCajas;

                            <div class="order-card avoid-break">

                                <div class="order-band no-print">
                                    <div>FOLIO: @g.Key.Pedido</div>
                                    <div class="meta">
                                        Destino: @g.Key.Destino &nbsp;•&nbsp; Fecha: @g.Key.Fecha.ToString("dd/MM/yyyy")
                                    </div>
                                </div>

                                <div class="order-body">

                                    <div class="print-only print-bar">
                                        <span>Pedido: @g.Key.Pedido</span>
                                        <span>Fecha: @g.Key.Fecha.ToString("dd/MM/yyyy")</span>
                                    </div>

                                    <div class="group-head no-print">
                                        <div>
                                            <div class="muted">Destino: <b>@g.Key.Destino</b> · Fecha: <b>@g.Key.Fecha.ToString("dd/MM/yyyy")</b></div>
                                        </div>
                                        <div class="bar" style="margin:0; justify-content:flex-end;">
                                            <div class="pill"><span class="muted small">Cajas</span><span class="kpi">@totalCajas</span></div>
                                            <div class="pill"><span class="muted small">Peso</span><span class="kpi">@totalPeso.ToString("N2")</span></div>
                                          @*   <div class="pill"><span class="muted small">Unidades</span><span class="kpi">@totalUnid</span></div> *@
                                        </div>
                                    </div>

                                    <div class="hr no-print"></div>

                                    @{
                                        var tarimasGrp = g.GroupBy(x => x.Tarima).OrderBy(t => t.Key);
                                    }

                                    @foreach (var t in tarimasGrp)
                                    {
                                        var transferenciaId = t.First().TransferenciaId;

                                        var tarimaKey = string.IsNullOrWhiteSpace(t.Key)
                                            ? "SIN TARIMA"
                                            : t.Key.Trim().ToUpperInvariant();

                                        var detalleTarima = (Model?.DetalleEtiquetas ?? new List<Plataforma_CG.ViewModels.TransferenciaScanEtiquetaDetalleVM>())
                                            .Where(x =>
                                                x.TransferenciaId == transferenciaId &&
                                                (string.IsNullOrWhiteSpace(x.TarimaCodigo) ? "SIN TARIMA" : x.TarimaCodigo.Trim().ToUpperInvariant()) == tarimaKey
                                            )
                                            .OrderBy(x => x.Fecha)
                                            .ToList();

                                        var tCajas = t.Sum(x => x.Cajas);
                                        var tPeso = t.Sum(x => x.Peso);
                                        var tUnid = tCajas;

                                        <div class="print-only print-bar small avoid-break">
                                            <span>Tarima: @t.Key</span>
                                            <span>Cajas: @tCajas &nbsp;|&nbsp; Peso: @tPeso.ToString("N2")</span>
                                        </div>

                                        <div class="tarima-block">
                                            <div class="tarima-title no-print">Tarima <span class="tag">@t.Key</span></div>

                                            <div class="tablewrap" style="margin-top:6px">
                                                <table class="t t-romaneo">
                                                    <thead>
                                                        <tr>
                                                         <th class="col-sku" style="width:12%">Sku</th>
                                                         <th class="col-producto" style="width:46%">Producto</th>
                                                         <th class="text-end col-cajas" style="width:14%">Cajas</th>
                                                         <th class="text-end col-peso" style="width:28%">Peso</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var r in t.OrderBy(x => x.ProductoCodigo))
                                                        {
                                                            <tr>
                                                                <td>@r.ProductoCodigo</td>
                                                                <td>@r.ProductoNombre</td>
                                                                <td class="text-end">@r.Cajas</td>
                                                                <td class="text-end">@r.Peso.ToString("N2")</td>
                                                            </tr>
                                                        }
                                                        <tr>
                                                            <td colspan="2" class="text-end" style="font-weight:900;color:var(--muted)">TOTAL TARIMA:</td>
                                                            <td class="text-end" style="font-weight:900">@tCajas</td>
                                                            <td class="text-end" style="font-weight:900">@tPeso.ToString("N2")</td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>

                                            @if (detalleTarima.Any())
                                            {
                                                <details class="detail-toggle no-print">
                                                    <summary>
                                                        <span class="summary-left">
                                                            <span class="summary-icon">▶</span>
                                                            <span>Detalle de etiquetas escaneadas</span>
                                                        </span>
                                                        <span class="tag">@detalleTarima.Count etiqueta(s)</span>
                                                    </summary>
                                                    <div class="detail-body">
                                                        <div class="tablewrap">
                                                            <table class="t t-detalle">
                                                                <thead>
                                                                    <tr>
                                                                        <th style="width:120px">Sku</th>
                                                                        <th>Código Etiqueta</th>
                                                                        <th class="text-end" style="width:120px">Kg</th>
                                                                        <th style="width:170px">Fecha Escaneo</th>
                                                                        <th style="width:160px">Usuario</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    @foreach (var d in detalleTarima)
                                                                    {
                                                                        <tr>
                                                                            <td>@d.Sku</td>
                                                                            <td>@d.CodigoEtiqueta</td>
                                                                            <td class="text-end">@d.Kg.ToString("N3")</td>
                                                                            <td>@d.Fecha.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                                                            <td>@d.Usuario</td>
                                                                        </tr>
                                                                    }
                                                                    <tr>
                                                                        <td colspan="2" class="text-end" style="font-weight:900;color:var(--sap-muted)">TOTAL:</td>
                                                                        <td class="text-end" style="font-weight:900">@detalleTarima.Sum(x => x.Kg).ToString("N3")</td>
                                                                        <td colspan="2"></td>
                                                                    </tr>
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </div>
                                                </details>
                                            }
                                        </div>

                                        <div class="hr no-print"></div>
                                    }

                                    <div class="muted small text-end no-print">
                                        Total pedido: <b>@totalCajas</b> cajas · <b>@totalPeso.ToString("N2")</b> kg
                                    </div>

                                </div>
                            </div>
                        }
                    }

                </div>
            </div>

        </div>
    </div>


    <div class="statusbar no-print">
        <div>Registro listo</div>
        <div>Usuario: @User.Identity.Name</div>
        <div>Empresa: Carnes G SA de CV</div>
        <div>Módulo: Romaneo</div>
    </div>
</div>

<div id="excelOverlay" aria-hidden="true">
    <div class="excel-modal">
        <div class="spinner"></div>
        <div class="excel-title">Cargando Aviso de Movilización</div>
        <div class="excel-sub">Por favor espere…</div>
    </div>
</div>


@section Scripts{
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<script>
(function () {
  function initMultiDD(root) {
    const label  = root.querySelector('.multi-label');
    const hidden = root.querySelector('.dd-hidden');
    const search = root.querySelector('.dd-search');
    const clear  = root.querySelector('.dd-clear');
    const apply  = root.querySelector('.dd-apply');
    const checks = root.querySelectorAll('.dd-check');
    const form   = root.closest('form');

    const map = {
      'dd-destino': 'destinosSel',
      'dd-pedido':  'pedidosSel',
      'dd-tarima':  'tarimasSel'
    };
    const rootId = root.id;
    const name = map[rootId];

    function rebuildHiddenAndLabel() {
      const selected = Array.from(checks).filter(c => c.checked).map(c => c.value);

      // label
      if (rootId === 'dd-tarima') {
        if (!selected.length) label.textContent = '(Todas)';
        else if (selected.length <= 3) label.textContent = selected.join(', ');
        else label.textContent = selected.length + ' seleccionadas';
      } else {
        if (!selected.length) label.textContent = '(Todos)';
        else if (selected.length <= 3) label.textContent = selected.join(', ');
        else label.textContent = selected.length + ' seleccionados';
      }

      // hidden
      hidden.innerHTML = '';
      selected.forEach(v => {
        const inp = document.createElement('input');
        inp.type = 'hidden';
        inp.name = name;
        inp.value = v;
        hidden.appendChild(inp);
      });
    }

    search?.addEventListener('input', () => {
      const q = (search.value || '').toLowerCase().trim();
      root.querySelectorAll('.dd-item').forEach(li => {
        const txt = (li.getAttribute('data-text') || '').toLowerCase();
        li.style.display = (!q || txt.includes(q)) ? '' : 'none';
      });
    });

    clear?.addEventListener('click', () => {
      checks.forEach(c => c.checked = false);
      if (search) search.value = '';
      root.querySelectorAll('.dd-item').forEach(li => li.style.display = '');
      rebuildHiddenAndLabel();
    });

    apply?.addEventListener('click', () => {
      rebuildHiddenAndLabel();
      form?.requestSubmit();
    });

    checks.forEach(c => c.addEventListener('change', rebuildHiddenAndLabel));

    rebuildHiddenAndLabel();
  }

  document.querySelectorAll('.multi-dd').forEach(initMultiDD);

  // ===================== EXCEL OVERLAY HANDLER =====================
  const overlay  = document.getElementById('excelOverlay');
  const btnExcel = document.getElementById('btnExcelAviso');

  function showOverlay(){
    if (!overlay) return;
    overlay.classList.add('show');
    overlay.setAttribute('aria-hidden', 'false');
  }

  function hideOverlay(){
    if (!overlay) return;
    overlay.classList.remove('show');
    overlay.setAttribute('aria-hidden', 'true');
  }

  function getFileNameFromDisposition(disposition) {
    if (!disposition) return null;

    const match = /filename\*?=(?:UTF-8''|")?([^\";]+)"?/i.exec(disposition);
    if (!match || !match[1]) return null;

    try { return decodeURIComponent(match[1]); }
    catch { return match[1]; }
  }

  async function downloadExcel(url) {
  showOverlay();
  console.log('Iniciando descarga Excel:', url);

  try {
    const resp = await fetch(url, {
      method: 'GET',
      credentials: 'same-origin',
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });

    console.log('Status:', resp.status, resp.statusText);
    console.log('Content-Type:', resp.headers.get('content-type'));
    console.log('Content-Disposition:', resp.headers.get('content-disposition'));

    if (!resp.ok) {
      const txt = await resp.text().catch(() => '');
      console.error('Respuesta error del servidor:', txt);
      throw new Error(`Error ${resp.status}: ${txt || resp.statusText}`);
    }

    const blob = await resp.blob();
    console.log('Blob size:', blob.size);
    console.log('Blob type:', blob.type);

    const disposition = resp.headers.get('content-disposition');
    const serverName  = getFileNameFromDisposition(disposition);
    const filename    = serverName || 'AvisoMovilizacion.xlsx';

    console.log('Filename final:', filename);

    const blobUrl = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = blobUrl;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    a.remove();
    window.URL.revokeObjectURL(blobUrl);

    console.log('Descarga disparada correctamente');
  } catch (err) {
    console.error('Error en downloadExcel:', err);
    alert('No se pudo generar el Excel. Intenta de nuevo o revisa el filtro.');
  } finally {
    hideOverlay();
  }
}

btnExcel?.addEventListener('click', function (e) {
  e.preventDefault();

  const form = document.getElementById('frmRomaneo');
  console.log('frmRomaneo:', form);

  if (!form) {
    console.error('No se encontró el formulario frmRomaneo');
    return;
  }

  const params = new URLSearchParams(new FormData(form)).toString();
  const url = '/Transferencias/ExportCaducidadTransferencias?' + params;

  console.log('Params Excel:', params);
  console.log('URL Excel:', url);

  downloadExcel(url);
});

})();
</script>
}