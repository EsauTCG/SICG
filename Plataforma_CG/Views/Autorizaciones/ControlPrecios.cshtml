let graficaTipo = 'linea';
let graficaVista = 'total';
let graficaDatosCache = null;

/* ===== control de auto-recalculo ===== */
let recalculoDemandaEnProceso = null;
let ultimoRecalculoDemanda = 0;
const DEMANDA_TTL_MS = 5 * 60 * 1000;

/* ===== NUEVO: perfil del usuario logueado ===== */
let perfilUsuario = { tieneVendedor: false, vendedorId: null, nombre: '' };

let permisosReglas = {
    puedeLeer: false,
    puedeEscribir: false,
    puedeEliminar: false
};

const COLORES = {
    alta:  { bg: 'rgba(220,53,69,.15)',  border: '#dc3545' },
    media: { bg: 'rgba(179,134,0,.15)',  border: '#b38600' },
    baja:  { bg: 'rgba(25,135,84,.15)',  border: '#198754' },
    total: { bg: 'rgba(139,0,0,.12)',    border: '#8b0000' },
    sku:   { bg: 'rgba(13,110,253,.15)', border: '#0d6efd' }
};

const money = v => v == null ? '—' :
    new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN' }).format(v);

function fmtKg(v) {
    const num = Number(v || 0);
    if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M kg';
    if (num >= 1000)    return (num / 1000).toFixed(1)    + 'k kg';
    return num.toFixed(0) + ' kg';
}

function labelCanal(canal) {
    if (!canal) return canal;
    return canal === 'ESTRATEGICO' ? 'ESTRATÉGICO' : canal;
}

function getSelectedValues(selector) {
    return [...document.querySelectorAll(selector)]
        .filter(cb => cb.checked)
        .map(cb => cb.value);
}

function escapeHtml(text) {
    return (text ?? '').toString()
        .replace(/&/g,  '&amp;')
        .replace(/</g,  '&lt;')
        .replace(/>/g,  '&gt;')
        .replace(/"/g,  '&quot;')
        .replace(/'/g,  '&#039;');
}

async function fetchJSON(url) {
    const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return res.json();
}

async function postJSON(url, body) {
    const res = await fetch(url, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body:    JSON.stringify(body)
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return res.json();
}

function setupMultiSelect(rootId) {
    const root = document.getElementById(rootId);
    if (!root) return;

    const btn = root.querySelector('.multi-select-btn');
    if (!btn) return;

    btn.addEventListener('click', (e) => {
        e.stopPropagation();
        document.querySelectorAll('.multi-select.open').forEach(x => {
            if (x !== root) x.classList.remove('open');
        });
        root.classList.toggle('open');
    });

    root.querySelectorAll('input[type="checkbox"]').forEach(cb => {
        cb.addEventListener('change', () => updateMultiSelectButton(rootId));
    });
}

function closeAllMultiSelects() {
    document.querySelectorAll('.multi-select.open').forEach(x => x.classList.remove('open'));
}
        function updateMultiSelectButton(rootId) {
            const root = document.getElementById(rootId);
            if (!root) return;

            const btn = root.querySelector('.multi-select-btn');
            if (!btn) return;

            const checked     = [...root.querySelectorAll('input[type="checkbox"]:checked')];
            const placeholder = btn.dataset.placeholder || '(Todos)';

            if (!checked.length) { btn.textContent = placeholder; return; }

            if (checked.length === 1) {
                // CAMBIO: para clientes, preferimos el data-nombre del label padre;
                // para otros multiselects seguimos usando el texto del <span>
                const label = checked[0].closest('[data-nombre]');
                if (label && label.dataset.nombre) {
                    btn.textContent = label.dataset.nombre;
                } else {
                    const txt = checked[0].closest('.multi-option, .multi-select-item')
                                    ?.querySelector('span')?.textContent?.trim()
                                || checked[0].value;
                    btn.textContent = txt;
                }
                return;
            }

            btn.textContent = `${checked.length} seleccionados`;
        }


 

function renderVendedoresMulti() {
    const wrap = document.getElementById('vendedorMultiOptions');
    if (!wrap) return;

    wrap.innerHTML = `
        <label class="multi-option">
            <input type="checkbox" class="vendedor-option-all">
            <strong>Seleccionar todo</strong>
        </label>
        ${(vendedoresData || []).map(v => `
            <label class="multi-option vendedor-item" data-text="${escapeHtml((v || '').toLowerCase())}">
                <input type="checkbox" value="${escapeHtml(v)}" class="vendedor-option">
                <span>${escapeHtml(v)}</span>
            </label>
        `).join('')}
    `;

    wrap.querySelector('.vendedor-option-all')?.addEventListener('change', function () {
        wrap.querySelectorAll('.vendedor-option').forEach(cb => cb.checked = this.checked);
        updateMultiSelectButton('vendedorMulti');
    });

    wrap.querySelectorAll('.vendedor-option').forEach(cb => {
        cb.addEventListener('change', () => {
            const all     = wrap.querySelectorAll('.vendedor-option');
            const checked = wrap.querySelectorAll('.vendedor-option:checked');
            const allCb   = wrap.querySelector('.vendedor-option-all');
            if (allCb) {
                allCb.checked       = all.length > 0 && checked.length === all.length;
                allCb.indeterminate = checked.length > 0 && checked.length < all.length;
            }
            updateMultiSelectButton('vendedorMulti');
            cargarProductos(1);
        });
    });

    updateMultiSelectButton('vendedorMulti');
}

    function renderClientesMulti() {
    const wrap    = document.getElementById('clienteMulti');
    const options = document.getElementById('clienteMultiOptions');
    if (!wrap || !options) return;

    const items = Array.isArray(clientesData) ? clientesData : [];

    if (!items.length) {
        options.innerHTML = `
            <div class="text-muted px-2 py-2" style="font-size:.85rem;">
                No hay clientes disponibles.
            </div>`;
        updateMultiSelectButton('clienteMulti');
        return;
    }

    options.innerHTML = `
        <label class="multi-select-item cliente-item" data-text="todos">
            <input type="checkbox" class="cliente-option-all">
            <span>(Todos)</span>
        </label>
        ${items.map(c => {
            const codigo = (c.cliente       || '').trim();
            const nombre = (c.nombreCliente || c.nombre || c.cliente || '').trim();
            const canal  = (c.canal         || '').trim();
            // texto de búsqueda sigue incluyendo código para que el filtro funcione
            const texto  = `${codigo} ${nombre} ${canal}`.toLowerCase();

            return `
                <label class="multi-select-item cliente-item" data-text="${texto}" data-nombre="${nombre.replace(/"/g,'&quot;')}">
                    <input type="checkbox" class="cliente-option" value="${codigo}">
                    <span>${nombre}</span>
                </label>`;
                // ↑ CAMBIO: solo mostramos nombre, sin código ni canal
        }).join('')}
    `;

    const allCb = wrap.querySelector('.cliente-option-all');

    allCb?.addEventListener('change', () => {
        const checked = allCb.checked;
        wrap.querySelectorAll('.cliente-option').forEach(cb => { cb.checked = checked; });
        allCb.indeterminate = false;
        updateMultiSelectButton('clienteMulti');
        cargarProductos(1);
    });

    wrap.querySelectorAll('.cliente-option').forEach(cb => {
        cb.addEventListener('change', () => {
            const all     = wrap.querySelectorAll('.cliente-option');
            const checked = wrap.querySelectorAll('.cliente-option:checked');

            if (allCb) {
                allCb.checked       = all.length > 0 && checked.length === all.length;
                allCb.indeterminate = checked.length > 0 && checked.length < all.length;
            }

            updateMultiSelectButton('clienteMulti');
            cargarProductos(1);
        });
    });

    updateMultiSelectButton('clienteMulti');
}



function initCanalMulti() {
    setupMultiSelect('canalMulti');
    updateMultiSelectButton('canalMulti');

    document.querySelectorAll('.canal-option').forEach(cb => {
        cb.addEventListener('change', () => {
            updateMultiSelectButton('canalMulti');
