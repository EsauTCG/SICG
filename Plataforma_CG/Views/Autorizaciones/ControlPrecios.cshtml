function renderReadTable(productos, clientesSeleccionados, canalesSeleccionados) {
    const tbody = document.getElementById('readTableBody');
    if (!tbody) return;

    tbody.innerHTML = '';

    if (!productos || !productos.length) {
        renderTableHead(null);
        tbody.innerHTML = `<tr><td colspan="11" class="empty-state">Sin resultados. Ajusta los filtros y presiona <b>Buscar</b>.</td></tr>`;
        return;
    }

    const clientesSet            = new Set(clientesSeleccionados || []);
    const canalClienteSeleccionado = getClienteCanalSeleccionado(productos, clientesSeleccionados);
    const canalVisible             = canalClienteSeleccionado || null;

    renderTableHead(canalVisible);

    productos.forEach(p => {
        const clienteCoincidente = (p.clientes || []).find(c =>
            clientesSet.has(c.codigoCliente || c.cliente || c.codigo || c.nombre)
        );

        const canalCliente = (clienteCoincidente?.canal || '').toUpperCase();

        const clienteTags = (p.clientes || []).map(c => {
            const cUp         = (c.canal || '').toUpperCase();
            const cls         = cUp === 'SPOT' ? 'tag-spot' : cUp === 'ACTIVO' ? 'tag-activo' : 'tag-estrategico';
            const seleccionado = clientesSet.has(c.codigoCliente || c.cliente || c.codigo || c.nombre);
            const bold         = seleccionado ? ' style="font-weight:700;border-width:2px;"' : '';
            return `<span class="client-tag ${cls}"${bold}>${escapeHtml(c.nombre)}
                        <span class="ct-canal">${labelCanal(c.canal)}</span>
                    </span>`;
        }).join('');

        const demCls = p.demanda === 'ALTA' ? 'dem-alta' : p.demanda === 'MEDIA' ? 'dem-media' : 'dem-baja';

        let celdas = '';

        if (canalVisible) {
            const keyMap = {
                SPOT:        p.precioSpot,
                ACTIVO:      p.precioActivo,
                ESTRATEGICO: p.precioEstrategico
            };

            celdas = renderCanalCell(keyMap[canalVisible], canalCliente === canalVisible, false);
        } else {
            const preciosCanal = [
                { canal: 'SPOT',        data: p.precioSpot,        border: true  },
                { canal: 'ACTIVO',      data: p.precioActivo,      border: true  },
                { canal: 'ESTRATEGICO', data: p.precioEstrategico, border: false }
            ];

            celdas = preciosCanal.map(x =>
                renderCanalCell(x.data, canalCliente === x.canal, x.border)
            ).join('');
        }

        tbody.insertAdjacentHTML('beforeend', `
            <tr class="row-product">
                <td class="ps-4" style="border-right:1px solid #dee2e6;">
                    <span class="sku-label">${escapeHtml(p.sku)}</span>
                    <span class="desc-label">${escapeHtml(p.descripcion)}</span>
                    <div class="client-tags">${clienteTags}</div>
                </td>
                <td><span class="vend-badge">${escapeHtml(p.vendedor || '—')}</span></td>
                <td class="text-center"><span class="demanda-badge ${demCls}">${escapeHtml(p.demanda)}</span></td>
                <td class="text-end fw-bold" style="border-right:1px solid #dee2e6;">${money(p.precioBase)}</td>
                ${celdas}
            </tr>
        `);
    });

    const ctx = document.getElementById('clientContext');
    if (!ctx) return;

    const partes = [];
    if (clientesSeleccionados?.length) partes.push(`Clientes seleccionados: <strong>${clientesSeleccionados.length}</strong>`);
    if (canalesSeleccionados?.length)  partes.push(`Canales: <strong>${canalesSeleccionados.map(labelCanal).join(', ')}</strong>`);
    if (canalVisible)                  partes.push(`Canal mostrado: <strong>${labelCanal(canalVisible)}</strong>`);

    if (partes.length) {
        ctx.innerHTML = partes.join(' &nbsp;·&nbsp; ');
        ctx.classList.add('visible');
    } else {
        ctx.innerHTML = '';
        ctx.classList.remove('visible');
    }
}

