@section Scripts {
<script>
const CANALES = ['SPOT', 'ACTIVO', 'ESTRATEGICO'];
const DEMANDAS = ['BAJA', 'MEDIA', 'ALTA'];
const AUTH_STEP = 0.50;

let reglas = [];
let autorizaciones = [];
let reportes = [];
let matrixDraft = null;
