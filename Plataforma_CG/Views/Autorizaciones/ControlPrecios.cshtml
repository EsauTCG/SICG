                    <td class="${tdCls} matrix-cell-edit" data-dem="${dem}" data-ci="${ci}">
                        <input type="${isNV ? 'text' : 'number'}" class="matrix-val-input"
                               data-dem="${dem}" data-ci="${ci}"
                               value="${isNV ? '' : val}"
                               min="0" max="999" step="0.5"
                               ${isNV ? 'disabled' : ''}
                               placeholder="${isNV ? 'NO VENDER' : '0'}">
                        <label class="matrix-nv-label">
                            <input type="checkbox" class="matrix-nv-cb"
                                   data-dem="${dem}" data-ci="${ci}"
                                   ${isNV ? 'checked' : ''}> No vender
                        </label>
                    </td>`;
            } else {
                const cls = getCellViewClass(val);
                const lbl = (val === null || val === undefined) ? 'NO VENDER'
                    : val === 0 ? '$ 0.00'
                    : `-$ ${Number(val).toFixed(2)}`;
                html += `<td class="${cls}">${lbl}</td>`;
            }
        });
        html += `</tr>`;
    });

    html += `</tbody></table>`;
    container.innerHTML = html;

    if (editMode) {
        container.querySelectorAll('.matrix-nv-cb').forEach(cb => {
            cb.addEventListener('change', function () {
                const dem   = this.dataset.dem;
                const ci    = parseInt(this.dataset.ci);
                const canal = CANALES[ci];
                const td    = container.querySelector(`td[data-dem="${dem}"][data-ci="${ci}"]`);
                const input = td?.querySelector('.matrix-val-input');
                const entry = matrixDraft.find(r => r.demanda === dem && r.canal === canal);
                if (!entry || !td || !input) return;

                if (this.checked) {
                    entry.descuentoMonto = null;
                    input.disabled       = true;
                    input.type           = 'text';
                    input.value          = '';
                    input.placeholder    = 'NO VENDER';
                    td.className         = td.className.replace(/mat-\w+/, 'mat-salmon') + ' matrix-cell-edit';
                } else {
                    entry.descuentoMonto = 0;
                    input.disabled       = false;
                    input.type           = 'number';
                    input.value          = '0';
                    input.placeholder    = '0';
                    td.className         = td.className.replace(/mat-\w+/, 'mat-peach') + ' matrix-cell-edit';
                }
            });
        });

        container.querySelectorAll('.matrix-val-input').forEach(input => {
            input.addEventListener('input', function () {
                if (this.disabled) return;
                const dem   = this.dataset.dem;
                const canal = CANALES[parseInt(this.dataset.ci)];
                const entry = matrixDraft.find(r => r.demanda === dem && r.canal === canal);
                if (entry) entry.descuentoMonto = parseFloat(this.value) || 0;
            });
        });

        document.getElementById('btnSaveMatrix')?.addEventListener('click', saveMatrix);
        document.getElementById('btnCancelMatrix')?.addEventListener('click', () => renderMatrix(false));
    } else {
        document.getElementById('btnEditMatrix')?.addEventListener('click', startEditMatrix);
    }
}

function startEditMatrix() {
    if (!permisosReglas.puedeEscribir) {
        alert('No tienes permiso para modificar reglas.');
        return;
    }

    matrixDraft = JSON.parse(JSON.stringify(reglas));
    renderMatrix(true);
}

async function saveMatrix() {
    if (!permisosReglas.puedeEscribir) {
        alert('No tienes permiso para guardar cambios.');
        return;
    }

    try {
        const result = await postJSON('/ControlPrecios/GuardarReglas', {
            reglas: matrixDraft,
            usuario: ''
        });

        if (result.ok) {
            reglas = JSON.parse(JSON.stringify(matrixDraft));
            renderMatrix(false);
            renderMatrix(false);
        } else {
            alert('Error al guardar: ' + (result.mensaje || 'Intente de nuevo.'));
        }
    } catch (e) {
        alert('Error de conexión al guardar reglas.');
        console.error(e);
    }
}

