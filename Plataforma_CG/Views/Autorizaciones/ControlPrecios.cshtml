            cargarTopDemanda(btn.dataset.demanda, sku);
        });
    });

    document.getElementById('btnRecalcularDemanda')?.addEventListener('click',
        () => recalcularDemanda({ silent: false, force: true }));

    document.getElementById('btnBuscarDemandaSku')?.addEventListener('click', () => {
        const sku = document.getElementById('demandaSkuBuscar')?.value.trim();
        if (!sku) return;
        cargarTopDemanda(demandaFiltroActual, sku);
    });

    document.getElementById('demandaSkuBuscar')?.addEventListener('keydown', e => {
        if (e.key === 'Enter') {
            const sku = e.target.value.trim();
            if (!sku) return;
            cargarTopDemanda(demandaFiltroActual, sku);
        }
    });

    document.getElementById('btnLimpiarDemandaSku')?.addEventListener('click', () => {
        const input = document.getElementById('demandaSkuBuscar');
        if (input) input.value = '';
        cargarTopDemanda(demandaFiltroActual);
    });

    document.getElementById('demandaPeriodo')?.addEventListener('change', async () => {
        ultimoRecalculoDemanda = 0;
        await asegurarDemandaActualizada({ force: true });
    });

    document.querySelectorAll('.grafica-tipo-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            graficaTipo = btn.dataset.tipo;
            document.querySelectorAll('.grafica-tipo-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            if (graficaDatosCache) {
                if (graficaVista === 'total')   renderGraficaTotal(graficaDatosCache);
                if (graficaVista === 'demanda') renderGraficaDemanda(graficaDatosCache);
                if (graficaVista === 'sku') {
                    const sku = document.getElementById('graficaSkuInput')?.value.trim() || '';
                    renderGraficaSku(graficaDatosCache, sku);
                }
            }
        });
    });

    document.querySelectorAll('.grafica-vista-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            graficaVista      = btn.dataset.vista;
            graficaDatosCache = null;

            document.querySelectorAll('.grafica-vista-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const skuWrap = document.getElementById('skuInputWrap');
            if (skuWrap) skuWrap.classList.toggle('d-none', graficaVista !== 'sku');

            if (graficaVista !== 'sku') {
                cargarGrafica();
            } else {
                document.getElementById('graficaResumen').innerHTML = '';
                document.getElementById('graficaEmpty').style.display = 'flex';
                document.getElementById('graficaEmpty').textContent   = 'Escribe un SKU para consultar.';
            }
        });
    });

    document.getElementById('graficaMeses')?.addEventListener('change',     cargarGrafica);
    document.getElementById('btnRefreshGrafica')?.addEventListener('click', cargarGrafica);
    document.getElementById('btnBuscarSku')?.addEventListener('click',      cargarGrafica);
    document.getElementById('graficaSkuInput')?.addEventListener('keydown', e => {
        if (e.key === 'Enter') cargarGrafica();
    });
});
</script>
}