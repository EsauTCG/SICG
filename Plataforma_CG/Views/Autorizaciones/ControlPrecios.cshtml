function obtenerPeriodoDemandaActual() {
    const periodoEl = document.getElementById('demandaPeriodo');
    return parseInt(periodoEl?.value || '90', 10);
}

function marcarDemandaComoActualizada() {
    ultimoRecalculoDemanda = Date.now();
}

async function asegurarDemandaActualizada({ force = false } = {}) {
    const ahora = Date.now();

    if (!force && (ahora - ultimoRecalculoDemanda < DEMANDA_TTL_MS)) {
        return true;
    }

    if (recalculoDemandaEnProceso) {
        return await recalculoDemandaEnProceso;
    }

    recalculoDemandaEnProceso = recalcularDemanda({ silent: true });

    try {
        const ok = await recalculoDemandaEnProceso;
        if (ok) marcarDemandaComoActualizada();
        return ok;
    } finally {
        recalculoDemandaEnProceso = null;
    }
}

async function cargarProductos(pagina = 1) {
    paginaActual = pagina;

    const loading = document.getElementById('loadingLista');
    const pagBar  = document.getElementById('paginacionBar');
    if (loading) loading.classList.add('show');
    if (pagBar)  pagBar.style.display = 'none';

    try {
        await asegurarDemandaActualizada();
    } catch (e) {
        console.warn('No fue posible actualizar demanda antes de cargar productos:', e);
    }

    const sku      = document.getElementById('searchSku')?.value.trim()      || '';
    const producto = document.getElementById('searchProducto')?.value.trim() || '';
    const demanda  = document.getElementById('listFilterDemanda')?.value      || '';

    const modoProductos = document.getElementById('listModoProductos')?.value || 'todos';
    const topCliente    = parseInt(document.getElementById('listTopCliente')?.value || '20', 10);

    const canales    = getSelectedValues('.canal-option');
    const vendedores = getSelectedValues('.vendedor-option');
    const clientes   = getSelectedValues('.cliente-option');

    const tbody = document.getElementById('readTableBody');

    if (modoProductos === 'topCliente' && clientes.length !== 1) {
        renderTableHead(null);
        if (tbody) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="11" class="empty-state text-warning">
                        Selecciona <b>un solo cliente</b> para ver sus productos más comprados.
                    </td>
                </tr>`;
        }
        totalRegistros = 0;
        totalPaginas   = 1;
        renderPaginacion();
        if (loading) loading.classList.remove('show');
        return;
    }

    const params = new URLSearchParams({ pagina, tamano: TAMANO_PAG });

    if (sku)      params.set('sku',      sku);
    if (producto) params.set('producto', producto);
    if (demanda)  params.set('demanda',  demanda);

    params.set('modoProductos', modoProductos);
    params.set('topCliente',    topCliente);

    canales.forEach(x    => params.append('canales',    x));
    vendedores.forEach(x => params.append('vendedores', x));
    clientes.forEach(x   => params.append('clientes',   x));

    try {
        const data = await fetchJSON(`/ControlPrecios/ObtenerProductos?${params.toString()}`);

        totalRegistros = data.total       || 0;
        totalPaginas   = data.totalPaginas || 1;

        renderReadTable(data.datos || [], clientes, canales);
        renderPaginacion();

        const lastRefresh = document.getElementById('lastRefresh');
        if (lastRefresh) {
            lastRefresh.textContent = 'Actualizado: ' + new Date().toLocaleTimeString('es-MX');
        }
    } catch (e) {
        console.error('Error cargando productos:', e);
        if (tbody) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="11" class="empty-state text-danger">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Error al cargar datos (${e.message}). Intente de nuevo.
                    </td>
                </tr>`;
        }
    } finally {
        if (loading) loading.classList.remove('show');
    }
}

function renderPaginacion() {
    const bar = document.getElementById('paginacionBar');
    if (!bar) return;

    if (totalRegistros === 0) { bar.style.display = 'none'; return; }

    bar.style.display = 'flex';

    document.getElementById('infoTotal').textContent =
        `${totalRegistros.toLocaleString()} registros · Página ${paginaActual} de ${totalPaginas}`;
    document.getElementById('paginaActualLabel').textContent = `Pág. ${paginaActual}`;

    document.getElementById('btnPrimeraPag').disabled   = paginaActual <= 1;
    document.getElementById('btnAnteriorPag').disabled  = paginaActual <= 1;
    document.getElementById('btnSiguientePag').disabled = paginaActual >= totalPaginas;
    document.getElementById('btnUltimaPag').disabled    = paginaActual >= totalPaginas;
}

function getClienteCanalSeleccionado(productos, clientesSeleccionados) {
    if (!clientesSeleccionados || clientesSeleccionados.length !== 1) return null;

    const clienteSel = clientesSeleccionados[0];

    for (const p of (productos || [])) {
        const cli = (p.clientes || []).find(c =>
            (c.codigoCliente || c.cliente || c.codigo || '') === clienteSel
        );
        if (cli?.canal) return (cli.canal || '').toUpperCase();
    }

    return null;
}

