async function cargarEstadoDemanda() {
    const div = document.getElementById('demandaEstado');
    if (!div) return;

    try {
        const data = await fetchJSON('/ControlPrecios/ObtenerEstadoDemanda');

        if (!data.calculado) {
            div.innerHTML = `
                <div class="alert alert-warning border mb-0">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Calculando demanda automáticamente. Si es la primera vez, espera un momento y vuelve a entrar.
                </div>`;
            return;
        }

        const total    = (data.totalBaja + data.totalMedia + data.totalAlta) || 1;
        const pctBaja  = Math.round((data.totalBaja  / total) * 100);
        const pctMedia = Math.round((data.totalMedia / total) * 100);
        const pctAlta  = Math.round((data.totalAlta  / total) * 100);
        const fmtKgEstado = v => v
            ? Number(v).toLocaleString('es-MX', { maximumFractionDigits: 0 }) + ' kg'
            : '—';

        div.innerHTML = `
            <div class="row g-3 mb-4">
                <div class="col-6 col-md-3">
                    <div class="demanda-stat-card">
                        <div class="stat-valor text-muted">${data.totalSkus.toLocaleString()}</div>
                        <div class="stat-label">Total SKUs</div>
                        <div class="stat-sub">${data.temporada} · ${data.periodoDias} días</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="demanda-stat-card" style="border-top:3px solid #198754;">
                        <div class="stat-valor" style="color:#198754;">${data.totalBaja.toLocaleString()}</div>
                        <div class="stat-label">Demanda BAJA</div>
                        <div class="stat-sub">≤ ${fmtKgEstado(data.umbralBaja)}</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="demanda-stat-card" style="border-top:3px solid #b38600;">
                        <div class="stat-valor" style="color:#b38600;">${data.totalMedia.toLocaleString()}</div>
                        <div class="stat-label">Demanda MEDIA</div>
                        <div class="stat-sub">Entre umbrales</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="demanda-stat-card" style="border-top:3px solid #dc3545;">
                        <div class="stat-valor" style="color:#dc3545;">${data.totalAlta.toLocaleString()}</div>
                        <div class="stat-label">Demanda ALTA</div>
                        <div class="stat-sub">≥ ${fmtKgEstado(data.umbralAlta)}</div>
                    </div>
                </div>
            </div>
            <div class="progress-demanda mb-2">
                <div class="progress-demanda-bar" style="width:${pctBaja}%;background:#198754;"></div>
                <div class="progress-demanda-bar" style="width:${pctMedia}%;background:#b38600;"></div>
                <div class="progress-demanda-bar" style="width:${pctAlta}%;background:#dc3545;"></div>
            </div>`;
    } catch (e) {
        div.innerHTML = `<div class="alert alert-danger border mb-0">Error al cargar estado: ${e.message}</div>`;
    }
}

async function recalcularDemanda({ silent = false, force = false } = {}) {
    const btn      = document.getElementById('btnRecalcularDemanda');
    const periodoEl = document.getElementById('demandaPeriodo');
    if (!periodoEl) return false;

    const periodo = parseInt(periodoEl.value || '90', 10);
    const orig    = btn ? btn.innerHTML : '';

    if (btn && !silent) {
        btn.disabled  = true;
        btn.innerHTML = `<i class="fas fa-spinner fa-spin me-1"></i> Calculando...`;
    }

    try {
        const data = await postJSON('/ControlPrecios/RecalcularDemanda', {
            periodoDias: periodo,
            usuario:     ''
        });

        if (data.ok) {
            marcarDemandaComoActualizada();

            await cargarEstadoDemanda();

            const skuActual = document.getElementById('demandaSkuBuscar')?.value.trim() || '';
            await cargarTopDemanda(demandaFiltroActual, skuActual);

            if (!silent) alert(`✓ ${data.mensaje}`);

            return true;
        } else {
            if (!silent) alert('Error: ' + (data.mensaje || 'No fue posible recalcular la demanda.'));
            return false;
        }
    } catch (e) {
        if (!silent) alert('Error de conexión: ' + e.message);
        return false;
    } finally {
        if (btn && !silent) {
            btn.disabled  = false;
            btn.innerHTML = orig;
        }
    }
}

async function cargarTopDemanda(demanda, sku = '') {
    demandaFiltroActual = demanda;

    const tbody = document.getElementById('demandaTopBody');
    if (!tbody) return;

    tbody.innerHTML = `
        <tr>
            <td colspan="7" class="empty-state">
                <i class="fas fa-spinner fa-spin me-2"></i>Cargando...
            </td>
        </tr>`;

    document.querySelectorAll('.demanda-filter-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.demanda === demanda);
    });

    try {
        const url = (sku && sku.trim() !== '')
            ? `/ControlPrecios/ObtenerTopDemanda?sku=${encodeURIComponent(sku.trim())}`
            : `/ControlPrecios/ObtenerTopDemanda?demanda=${encodeURIComponent(demanda)}&top=100`;

        const lista = await fetchJSON(url);

        if (!lista || !lista.length) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="7" class="empty-state">
                        No se encontraron resultados${sku ? ` para el SKU <b>${sku}</b>` : ''}.
                    </td>
                </tr>`;
            return;
        }

        tbody.innerHTML = '';

        lista.forEach((p, i) => {
            const demCls =
                p.demanda === 'ALTA'  ? 'dem-alta' :
                p.demanda === 'MEDIA' ? 'dem-media' :
                'dem-baja';

            const desde = p.fechaDesde ? new Date(p.fechaDesde).toLocaleDateString('es-MX') : '—';
            const hasta = p.fechaHasta ? new Date(p.fechaHasta).toLocaleDateString('es-MX') : '—';

            tbody.insertAdjacentHTML('beforeend', `
                <tr>
                    <td class="ps-4 text-muted">${i + 1}</td>
                    <td class="fw-bold">${p.productoCodigo || '—'}</td>
                    <td>${p.productoNombre || '—'}</td>
                    <td class="text-end fw-bold">${Number(p.kgTotales || 0).toLocaleString('es-MX', { maximumFractionDigits: 0 })} kg</td>
                    <td class="text-end">${Number(p.cajasTotales || 0).toLocaleString('es-MX')}</td>
                    <td class="text-center"><span class="demanda-badge ${demCls}">${p.demanda || '—'}</span></td>
                    <td class="text-center" style="font-size:.75rem;color:#888;">${desde} – ${hasta}</td>
                </tr>`);
        });
    } catch (e) {
        tbody.innerHTML = `
            <tr>
                <td colspan="7" class="empty-state text-danger">
                    Error: ${e.message}
                </td>
            </tr>`;
    }
}

function cargarChartJsSiFalta() {
    return new Promise((resolve, reject) => {
        if (window.Chart) return resolve();

        const script   = document.createElement('script');
        script.src     = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
        script.onload  = resolve;
        script.onerror = reject;
        document.head.appendChild(script);
    });
}

async function cargarGrafica() {
    const mesesEl = document.getElementById('graficaMeses');
    const loading = document.getElementById('graficaLoading');
    const empty   = document.getElementById('graficaEmpty');

    if (!mesesEl || !loading || !empty) return;

    await cargarChartJsSiFalta();

    const meses = parseInt(mesesEl.value);
    loading.style.display = 'flex';
    empty.style.display   = 'none';

    try {
        if (graficaVista === 'sku') {
            const sku = document.getElementById('graficaSkuInput')?.value.trim();

            if (!sku) {
                loading.style.display = 'none';
                empty.style.display   = 'flex';
                empty.textContent     = 'Escribe un SKU para consultar.';
                return;
            }

            const datos = await fetchJSON(`/ControlPrecios/ObtenerHistorialSku?sku=${encodeURIComponent(sku)}&meses=${meses}`);
            graficaDatosCache = datos;
            renderGraficaSku(datos, sku);
        } else {
            const datos = await fetchJSON(`/ControlPrecios/ObtenerHistorialDemanda?meses=${meses}`);
            graficaDatosCache = datos;

            if (!datos || !datos.length) {
                if (demandaChart) { demandaChart.destroy(); demandaChart = null; }
                document.getElementById('graficaResumen').innerHTML = '';
                loading.style.display = 'none';
                empty.style.display   = 'flex';
                empty.textContent     = 'Sin datos para el período seleccionado.';
                return;
            }

            if (graficaVista === 'demanda') renderGraficaDemanda(datos);
            else                            renderGraficaTotal(datos);
        }
    } catch (e) {
        if (demandaChart) { demandaChart.destroy(); demandaChart = null; }
        document.getElementById('graficaResumen').innerHTML = '';
        empty.style.display = 'flex';
        empty.textContent   = 'Error al cargar: ' + e.message;
    } finally {
        loading.style.display = 'none';
    }
}

function getTipoChart() {
    return graficaTipo === 'barra' ? 'bar' : 'line';
}

function buildDataset(label, datos, color, fill) {
    return {
        label,
        data:            datos,
        borderColor:     color.border,
        backgroundColor: fill ? color.bg : 'transparent',
        borderWidth:     graficaTipo === 'barra' ? 1 : 2,
        fill,
        tension:         0.35,
        pointRadius:     graficaTipo === 'barra' ? 0 : 3,
        pointHoverRadius: 6
    };
}

function renderGraficaTotal(datos) {
    const labels = datos.map(d => d.periodo);
    const values = datos.map(d => d.kgTotal || 0);
    const fill   = graficaTipo === 'area';

    dibujarChart(labels, [buildDataset('Kg Total', values, COLORES.total, fill)]);

    const total  = values.reduce((a, b) => a + b, 0);
    const max    = values.length ? Math.max(...values) : 0;
    const mesMax = datos[values.indexOf(max)]?.periodo || '—';

    document.getElementById('graficaResumen').innerHTML = `
        <span>📦 Total período: <strong>${fmtKg(total)}</strong></span>
        <span>📈 Pico: <strong>${fmtKg(max)}</strong> en <strong>${mesMax}</strong></span>
        <span>📊 Promedio mensual: <strong>${fmtKg(total / (datos.length || 1))}</strong></span>`;
}

function renderGraficaDemanda(datos) {
    const labels = datos.map(d => d.periodo);
    const fill   = graficaTipo === 'area';

    const datasets = [
        buildDataset('ALTA',  datos.map(d => d.kgAlta  || 0), COLORES.alta,  fill),
        buildDataset('MEDIA', datos.map(d => d.kgMedia || 0), COLORES.media, fill),
        buildDataset('BAJA',  datos.map(d => d.kgBaja  || 0), COLORES.baja,  fill)
    ];

    dibujarChart(labels, datasets);

    const totA = datos.reduce((a, d) => a + Number(d.kgAlta  || 0), 0);
    const totM = datos.reduce((a, d) => a + Number(d.kgMedia || 0), 0);
    const totB = datos.reduce((a, d) => a + Number(d.kgBaja  || 0), 0);

    document.getElementById('graficaResumen').innerHTML = `
        <span style="color:#dc3545;">● ALTA: <strong>${fmtKg(totA)}</strong></span>
        <span style="color:#b38600;">● MEDIA: <strong>${fmtKg(totM)}</strong></span>
        <span style="color:#198754;">● BAJA: <strong>${fmtKg(totB)}</strong></span>`;
}

function renderGraficaSku(datos, sku) {
    const empty = document.getElementById('graficaEmpty');

    if (!datos || !datos.length) {
        if (demandaChart) { demandaChart.destroy(); demandaChart = null; }
        document.getElementById('graficaResumen').innerHTML = '';
        empty.style.display = 'flex';
        empty.textContent   = `Sin datos para SKU: ${sku}`;
        return;
    }

    empty.style.display = 'none';

    const labels = datos.map(d => d.periodo);
    const values = datos.map(d => d.kgTotales || 0);
    const fill   = graficaTipo === 'area';

    dibujarChart(labels, [buildDataset(`SKU ${sku}`, values, COLORES.sku, fill)]);

    const total  = values.reduce((a, b) => a + b, 0);
    const max    = values.length ? Math.max(...values) : 0;
    const mesMax = datos[values.indexOf(max)]?.periodo || '—';

    document.getElementById('graficaResumen').innerHTML = `
        <span>SKU: <strong>${sku}</strong></span>
        <span>📦 Total: <strong>${fmtKg(total)}</strong></span>
        <span>📈 Pico: <strong>${fmtKg(max)}</strong> en <strong>${mesMax}</strong></span>`;
}

function dibujarChart(labels, datasets) {
    const canvas = document.getElementById('demandaChart');
    if (!canvas || !window.Chart) return;

    const ctx = canvas.getContext('2d');

    if (demandaChart) { demandaChart.destroy(); demandaChart = null; }

    demandaChart = new Chart(ctx, {
        type: getTipoChart(),
        data: { labels, datasets },
        options: {
            responsive:           true,
            maintainAspectRatio:  false,
            interaction:          { mode: 'index', intersect: false },
            plugins: {
                legend: { display: datasets.length > 1, position: 'top' },
                tooltip: {
                    callbacks: {
                        label: ctx => ` ${ctx.dataset.label}: ${fmtKg(ctx.parsed.y)}`
                    }
                }
            },
            scales: {
                x: { ticks: { maxRotation: 45 } },
                y: { beginAtZero: true, ticks: { callback: v => fmtKg(v) } }
            }
        }
    });
}

