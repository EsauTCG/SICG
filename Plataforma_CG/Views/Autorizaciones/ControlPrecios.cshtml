        });
    });

    document.getElementById('btnCanalTodos')?.addEventListener('click', () => {
        document.querySelectorAll('.canal-option').forEach(cb => cb.checked = true);
        updateMultiSelectButton('canalMulti');
        cargarProductos(1);
    });

    document.getElementById('btnCanalLimpiar')?.addEventListener('click', () => {
        document.querySelectorAll('.canal-option').forEach(cb => cb.checked = false);
        updateMultiSelectButton('canalMulti');
        cargarProductos(1);
    });
}

function initSearchMulti(inputId, itemSelector) {
    const input = document.getElementById(inputId);
    if (!input) return;

    input.addEventListener('input', () => {
        const q = input.value.trim().toLowerCase();
        document.querySelectorAll(itemSelector).forEach(item => {
            const text = item.dataset.text || '';
            item.style.display = !q || text.includes(q) ? '' : 'none';
        });
    });
}

function activarTab(tabId, btnActual) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('#preciosTabsContent .tab-pane').forEach(p => {
        p.classList.remove('show', 'active');
    });

    btnActual.classList.add('active');

    const tab = document.querySelector(tabId);
    if (tab) tab.classList.add('show', 'active');

    if (tabId === '#tab-demanda') {
        cargarEstadoDemanda();
        cargarTopDemanda(demandaFiltroActual);
        setTimeout(() => {
