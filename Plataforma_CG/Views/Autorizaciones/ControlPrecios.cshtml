function renderCanalCell(pc, highlight, addRightBorder = false) {
    const sep = addRightBorder ? 'border-right:1px solid #dee2e6;' : '';
    const hl  = highlight ? ' cell-highlight' : '';

    if (!pc || pc.status === 'NO VENDER') {
        return `
            <td class="price-cell cell-block${hl} text-center">—</td>
            <td class="price-cell cell-block${hl} text-center" style="${sep}">NO VENDER</td>
        `;
    }

    if (pc.descPermitido === 0) {
        return `
            <td class="price-cell cell-neutral${hl} text-end">$0</td>
            <td class="price-cell cell-neutral${hl} text-end" style="${sep}">${money(pc.precioFinal)}</td>
        `;
    }

    return `
        <td class="price-cell cell-ok${hl} text-end">-${money(pc.descPermitido)}</td>
        <td class="price-cell cell-ok${hl} text-end fw-bold" style="${sep}">${money(pc.precioFinal)}</td>
    `;
}

