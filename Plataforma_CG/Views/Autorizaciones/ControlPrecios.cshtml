@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Control Precios";
}

<style>
    :root {
        --bg: #f0dede;
        --panel: #f8eeee;
        --panel-2: #f1dede;
        --line: #c79d9d;
        --text: #3b1717;
        --muted: #6a3a3a;
        --white: #ffffff;
        --shadow: 0 1px 0 rgba(255,255,255,.55) inset;
        --brand: #8B0000;
        --vino-border: #9a5a5a;
        --vino-text-dark: #4a1111;
    }

    * { box-sizing: border-box; }

    body {
        margin: 0 !important;
        padding: 0 !important;
        font-family: Tahoma, Verdana, Arial, sans-serif;
        background: transparent !important;
        color: var(--text);
    }

    .container, .container-fluid {
        max-width: 100% !important;
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .window {
        width: 100%;
        max-width: 100%;
        margin: 0 !important;
        border: 1px solid #7e4a4a;
        background: var(--panel);
        box-shadow: 0 0 0 1px rgba(255,255,255,.45) inset, 0 8px 18px rgba(70,12,12,.14);
        overflow: hidden;
        padding: 0 !important;
    }

    .window > *:first-child, .titlebar { margin-top: 0 !important; }

    .titlebar {
        height: 34px;
        /* display: flex; */
        display: none !important;
        align-items: center;
        justify-content: space-between;
        padding: 0 10px;
        background: linear-gradient(180deg, #c00000 0%, #8b0000 60%, #5c0000 100%);
        border-bottom: 1px solid #5c0000;
        color: #fff;
        font-size: 13px;
        font-weight: bold;
    }

    .titlebar .actions { display: flex; gap: 6px; }

    .win-btn {
        width: 16px;
        height: 16px;
        border: 1px solid #7c4848;
        background: linear-gradient(#fff6f6, #ead0d0);
    }

    .toolbar {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 4px 6px;
        background: linear-gradient(#fff6f6, #ecd8d8);
        border-bottom: 1px solid var(--line);
        font-size: 12px;
        flex-wrap: wrap;
    }

    .tool-btn {
        min-width: 72px;
        text-align: center;
        background: linear-gradient(#fffefe, #ecd7d7);
        border: 1px solid var(--vino-border);
        box-shadow: var(--shadow);
        cursor: pointer;
        color: var(--vino-text-dark);
        height: 28px;
        font-size: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        padding: 0 8px;
        text-decoration: none;
    }

    .tool-btn:hover { filter: brightness(.98); }

    .content { padding: 8px; background: var(--bg); }

    .tabs {
        display: flex;
        gap: 4px;
        margin-bottom: 6px;
        flex-wrap: wrap;
    }

    .tab-btn {
        font-size: 12px;
        background: linear-gradient(#f7e7e7, #ead1d1);
        border: 1px solid #caa0a0;
        border-bottom: none;
        padding: 7px 12px;
        color: #5c1a1a;
        user-select: none;
        cursor: pointer;
    }

    .tab-btn.active {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        font-weight: bold;
        color: #fff;
        border-color: #7a2d2d;
    }

    .workspace {
        border: 1px solid var(--line);
        background: var(--panel);
        padding: 8px;
    }

    .section {
        border: 1px solid var(--line);
        background: var(--white);
        margin-bottom: 10px;
        position: relative;
    }

    .section-title {
        padding: 6px 8px;
        font-size: 12px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }

    .section-body {
        padding: 10px;
        background: #fffafa;
    }

    .pm-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        height: 26px;
        padding: 0 10px;
        border: 1px solid transparent;
        border-radius: 0;
        font-family: Tahoma, Verdana, Arial, sans-serif;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        box-shadow: var(--shadow);
        white-space: nowrap;
    }

    .pm-btn:hover { filter: brightness(.97); }
    .pm-btn:disabled { opacity: .6; cursor: not-allowed; }

    .pm-btn-primary {
        color: #fff;
        border-color: #7a2d2d;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
    }

    .pm-btn-secondary {
        background: linear-gradient(#fffefe, #ecd7d7);
        border-color: var(--vino-border);
        color: var(--vino-text-dark);
    }

    .pm-btn-success {
        color: #fff;
        border-color: #157347;
        background: linear-gradient(180deg, #27ae60 0%, #1f9a54 55%, #198754 100%);
    }

    /* DESPUÉS — agrega el bloque del botón PDF debajo */
    .pm-btn-outline {
        background: transparent;
        border-color: var(--vino-border);
        color: #5a0000;
    }

    #btnDescargarPdf {
        background: linear-gradient(180deg, #27ae60 0%, #1f9a54 55%, #198754 100%);
        border-color: #157347;
        color: #fff;
    }

        #btnDescargarPdf:hover {
            background: linear-gradient(180deg, #2ecc71 0%, #27ae60 55%, #1f9a54 100%);
        }

    .tab-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #dc3545;
        color: #fff;
        font-size: .7rem;
        font-weight: 700;
        border-radius: 999px;
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        margin-left: 6px;
        line-height: 1;
    }

  .filter-bar {
    padding: .85rem 1rem;
    border-bottom: 1px solid #d9b8b8;
    background: #f9eded;
    display: grid;
    grid-template-columns: 120px 220px 220px 220px 220px 150px 1fr;
    gap: .8rem;
    align-items: end;
}

    .filter-field {
        display: flex;
        flex-direction: column;
        gap: .28rem;
        min-width: 0;
    }

    .filter-field label {
        font-size: .72rem;
        color: #666;
        text-transform: uppercase;
        letter-spacing: .4px;
        margin: 0;
        font-weight: 600;
    }

    .filter-field input[type=text],
    .filter-field select,
    .form-select,
    .form-control {
        font-size: .82rem;
        padding: 6px 8px;
        border: 1px solid #c79d9d;
        border-radius: 2px;
        background: #fff;
        min-height: 36px;
        color: #401515;
    }

    .filter-field input[type=text]:focus,
    .filter-field select:focus,
    .form-select:focus,
    .form-control:focus {
        outline: none;
        border-color: #8b0000;
        box-shadow: 0 0 0 2px rgba(139,0,0,.08);
    }

    .filter-actions {
        display: flex;
        align-items: end;
        justify-content: flex-end; /* ← el cambio */
        gap: .5rem;
        flex-wrap: nowrap;
        grid-column: 1 / -1; /* ← ocupa todo el ancho del grid si hace falta */
        min-width: 0;
    }
.filter-actions .pm-btn {
    height: 36px;
    padding: 0 12px;
    min-width: auto;
}

#btnResetListFilters {
    min-width: 100px;
}

    .multi-select {
        position: relative;
        min-width: 0;
    }

    .multi-select-btn {
        width: 100%;
        min-height: 36px;
        border: 1px solid #c79d9d;
        background: #fff;
        color: #401515;
        border-radius: 2px;
        padding: 6px 34px 6px 10px;
        text-align: left;
        font-size: .82rem;
        position: relative;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .multi-select-btn::after {
        content: '▼';
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        font-size: .65rem;
        color: #666;
        pointer-events: none;
    }

    .multi-select.open .multi-select-btn {
        border-color: #8b0000;
        box-shadow: 0 0 0 2px rgba(139,0,0,.08);
    }

    .multi-select-menu {
        display: none;
        position: absolute;
        top: calc(100% + 2px);
        left: 0;
        width: 100%;
        min-width: 240px;
        max-height: 320px;
        background: #fff;
        border: 1px solid #cfcfcf;
        box-shadow: 0 10px 28px rgba(0,0,0,.12);
        z-index: 1200;
        border-radius: 3px;
        overflow: hidden;
    }

    .multi-select.open .multi-select-menu { display: block; }

    .multi-select-search {
        padding: .55rem;
        border-bottom: 1px solid #eee;
        background: #fafafa;
    }

    .multi-select-search input {
        width: 100%;
        border: 1px solid #ccc;
        border-radius: 2px;
        padding: 5px 8px;
        font-size: .8rem;
    }

    .multi-select-options {
        max-height: 240px;
        overflow: auto;
        background: #fff;
    }

    .multi-option {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .45rem .65rem;
        font-size: .82rem;
        border-bottom: 1px solid #f4f4f4;
        cursor: pointer;
        user-select: none;
    }

    .multi-option:hover { background: #faf7f7; }
    .multi-option input { accent-color: #8b0000; cursor: pointer; }

    .multi-select-footer {
        padding: .45rem .55rem;
        border-top: 1px solid #eee;
        background: #fafafa;
        display: flex;
        gap: .4rem;
        justify-content: flex-end;
    }

    .loading-overlay {
        display: none;
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,.75);
        z-index: 10;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        color: #555;
    }

    .loading-overlay.show { display: flex; }

    .table-responsive {
        border-top: 1px solid #d9b8b8;
        background: #fffafa;
    }

  .table-clean thead th:first-child {
    border-left: none !important;
}

.table-clean thead th {
    position: sticky;
    top: 0;
    z-index: 5;
    background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
    color: #fff !important;
    border-top: none !important;
    border-right: none !important;
    border-bottom: none !important;
    box-shadow: none !important;
    padding: 6px 5px !important;
    font-weight: 700 !important;
    font-size: 12px !important;
    white-space: nowrap;
    line-height: 1.2 !important;
    text-transform: none !important;
    vertical-align: middle;
}

 .table-clean thead th:first-child {
    border-left: none !important;
}

    .table-clean tbody td {
        background: #fffafa !important;
        border-right: 1px solid #e6d6d6 !important;
        border-bottom: 1px solid #e6d6d6 !important;
        padding: .6rem .7rem !important;
        vertical-align: middle;
        font-size: 12px !important;
        color: #401515 !important;
    }

        .table-clean tbody td:first-child {
            border-left: 1px solid #e6d6d6 !important;
        }

    .price-cell {
        padding: .55rem .8rem !important;
        border-right: 1px solid #e6d6d6 !important;
        border-bottom: 1px solid #e6d6d6 !important;
    }



    .table-clean tbody tr:hover td {
        background: #f4dddd !important;
    }

    .empty-state {
        text-align: center;
        padding: 2.5rem 1rem;
        color: #999;
        font-size: .9rem;
    }

    .canal-header {
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        padding: .5rem .8rem;
        border-bottom: 1px solid #dee2e6 !important;
    }

    .canal-spot        { background: #fff9ec !important; color: #856404 !important; border-left: 2px solid #ffc107 !important; }
    .canal-activo      { background: #e8f4fd !important; color: #0a4b8a !important; border-left: 2px solid #0d6efd !important; }
    .canal-estrategico { background: #eaf6ee !important; color: #0a5229 !important; border-left: 2px solid #198754 !important; }

  .canal-sub {
    border-left: none !important;
    border-right: none !important;
    border-bottom: none !important;
    box-shadow: none !important;
}

    .price-cell { padding: .55rem .8rem !important; }
    .price-cell.cell-ok { background: #d1e7dd !important; color: #0f5132 !important; }
    .price-cell.cell-neutral { background: #fff3cd !important; color: #856404 !important; }
    .price-cell.cell-block { background: #f8d9da !important; color: #842029 !important; font-weight: 700; }

        .price-cell.cell-highlight {
            outline: none !important;
        }
    .row-product td { border-bottom: 2px solid #e8e8e8 !important; }

    .sku-label { font-weight: 700; font-size: .85rem; display: block; }
    .desc-label { font-size: .8rem; color: #555; }

    .client-tags {
        display: flex;
        gap: 3px;
        flex-wrap: wrap;
        margin-top: 3px;
    }

    .client-tag {
        font-size: .68rem;
        padding: 2px 7px;
        border-radius: 3px;
        background: #f0f0f0;
        color: #555;
        border: 1px solid #ddd;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .client-tag.tag-spot        { background: #fff9ec; border-color: #ffc107; color: #856404; }
    .client-tag.tag-activo      { background: #e8f4fd; border-color: #0d6efd; color: #0a4b8a; }
    .client-tag.tag-estrategico { background: #eaf6ee; border-color: #198754; color: #0a5229; }
    .client-tag .ct-canal { font-size: .6rem; opacity: .7; font-weight: 700; }

    .canal-badge {
        display: inline-block;
        font-size: .65rem;
        padding: 1px 6px;
        border-radius: 2px;
        font-weight: 700;
        white-space: nowrap;
        vertical-align: middle;
        margin-left: 4px;
    }

    .cb-spot        { background: #fff9ec; border: 1px solid #ffc107; color: #856404; }
    .cb-activo      { background: #e8f4fd; border: 1px solid #0d6efd; color: #0a4b8a; }
    .cb-estrategico { background: #eaf6ee; border: 1px solid #198754; color: #0a5229; }
    .cb-unknown     { background: #f5f5f5; border: 1px solid #ccc; color: #666; }

    .demanda-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 3px;
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .dem-baja  { background: #d1e7dd; color: #0f5132; }
    .dem-media { background: #fff3cd; color: #856404; }
    .dem-alta  { background: #f8d7da; color: #842029; }

    .vend-badge {
        font-size: .7rem;
        padding: 1px 7px;
        border-radius: 2px;
        background: #f0eaff;
        color: #5b21b6;
        border: 1px solid #c4b5fd;
        white-space: nowrap;
    }

    .client-context {
        padding: .5rem 1rem;
        background: #f0f4ff;
        border-bottom: 1px solid #c5d3f5;
        font-size: .82rem;
        color: #333;
        display: none;
        align-items: center;
        gap: .5rem;
    }

    .client-context.visible { display: none !important; }
    .client-context strong { color: #0a4b8a; }

    .paginacion-bar {
        padding: .5rem 1rem;
        border-top: 1px solid #d3b0b0;
        background: #fafafa;
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
        font-size: .82rem;
        color: #555;
    }

    .paginacion-bar .info-total { margin-right: auto; }

    .paginacion-bar button {
        border: 1px solid #ccc;
        background: #fff;
        color: #333;
        border-radius: 3px;
        padding: 2px 10px;
        font-size: .82rem;
        cursor: pointer;
    }

    .paginacion-bar button:hover { background: #f0f0f0; }
    .paginacion-bar button:disabled { opacity: .4; cursor: not-allowed; }
    .paginacion-bar button.active { background: #8b0000; color: #fff; border-color: #8b0000; }

    .demanda-filter-btn.active,
    .grafica-tipo-btn.active,
    .grafica-vista-btn.active {
        background: #8b0000 !important;
        color: #fff !important;
        border-color: #8b0000 !important;
    }

    .demanda-stat-card {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 1rem 1.5rem;
        text-align: center;
        background: #fff;
    }

    .demanda-stat-card .stat-valor {
        font-size: 2rem;
        font-weight: 800;
        line-height: 1;
    }

    .demanda-stat-card .stat-label {
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .4px;
        color: #666;
        margin-top: .25rem;
    }

    .demanda-stat-card .stat-sub {
        font-size: .72rem;
        color: #888;
        margin-top: .15rem;
    }

    .progress-demanda {
        height: 10px;
        border-radius: 4px;
        background: #e9ecef;
        overflow: hidden;
        display: flex;
    }

    .progress-demanda-bar {
        height: 100%;
        transition: width .5s ease;
    }

    .modal-content {
        border: 1px solid #7d4949;
        border-radius: 0;
    }

    .modal-header {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        color: #fff !important;
        border-bottom: 1px solid #5c0000 !important;
        padding: .65rem 1rem !important;
        border-radius: 0;
    }

    .modal-title {
        color: #fff !important;
        font-weight: 700;
        font-size: 13px;
    }

    .btn-close {
        filter: invert(1) grayscale(100%) !important;
        opacity: .95 !important;
    }

    .modal-body {
        background: #f4e4e4;
        padding: .75rem !important;
    }

    .modal-footer {
        background: #f7eaea;
        border-top: 1px solid #d3b0b0;
    }

    .statusbar {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 6px 10px;
        font-size: 11px;
        color: #4a1a1a;
        border-top: 1px solid #b88c8c;
        background: linear-gradient(#f6e9e9, #ead5d5);
        flex-wrap: wrap;
    }

    .text-status-ok { color: #198754; font-weight: 600; }
    .text-status-warn { color: #b38600; font-weight: 600; }
    .text-status-error { color: #dc3545; font-weight: 600; }
    .text-muted-dark { color: #555; }

    .row-processed { background: #f0f9f4; opacity: .75; }
    .row-processed td, .row-rejected td { color: #6c757d; }
    .row-rejected { background: #fff5f5; opacity: .75; }

    @@media (max-width: 1400px) {
        .filter-bar {
            grid-template-columns: repeat(3, minmax(180px,1fr));
        }

        .filter-actions {
            grid-column: 1 / -1;
            justify-content: flex-start;
        }
    }

    @@media (max-width: 900px) {
        .filter-bar {
            grid-template-columns: 1fr;
        }

        .filter-actions {
            grid-column: auto;
        }

        .statusbar {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    .multi-option,
    .multi-select-item {
        padding-left: 12px; /* ← agrega esto, antes era sin padding izquierdo */
    }
</style>

<div class="window">

    <div class="titlebar">
        <div>Control Precios</div>
        <div class="actions">
            <div class="win-btn"></div>
            <div class="win-btn"></div>
            <div class="win-btn"></div>
        </div>
    </div>

    <div class="toolbar">
        @* <button class="tool-btn" type="button" id="btnRefreshListaTop">
            <i class="fas fa-sync-alt"></i> Actualizar
        </button> *@
    </div>

    <div class="content">

        <div class="tabs" role="tablist">
            <button class="tab-btn active" data-bs-toggle="tab" data-bs-target="#tab-lista" type="button" role="tab">
                Lista de Precios
            </button>
            <button class="tab-btn" data-bs-toggle="tab" data-bs-target="#tab-reglas" type="button" role="tab">
                Reglas Comerciales
            </button>
            <button class="tab-btn" data-bs-toggle="tab" data-bs-target="#tab-demanda" type="button" role="tab" id="btn-tab-demanda">
                <i class="fas fa-chart-bar me-1"></i> Demanda
            </button>
            <div style="margin-left:auto;font-size:11px;color:#6a3a3a;align-self:center;">
                 <span id="lastRefresh">—</span>
            </div>
        </div>

        <div class="workspace">

            <div class="tab-content" id="preciosTabsContent">

                <div class="tab-pane fade show active" id="tab-lista" role="tabpanel">
                    <div class="section">
                        <div class="section-title">
                            <span>Precios por Producto y Tipo de Cliente</span>
                        </div>

                        <div class="filter-bar">
                            <div class="filter-field">
                                <label>SKU</label>
                                <input type="text" id="searchSku" placeholder="SKU...">
                            </div>

                            <div class="filter-field">
                                <label>Producto</label>
                                <input type="text" id="searchProducto" placeholder="Descripción...">
                            </div>

                         @*    <div class="filter-field">
                                <label>Canal</label>
                                <div class="multi-select" id="canalMulti">
                                    <button type="button" class="multi-select-btn" data-placeholder="(Todos)">(Todos)</button>
                                    <div class="multi-select-menu">
                                        <div class="multi-select-options">
                                            <label class="multi-option">
                                                <input type="checkbox" value="SPOT" class="canal-option">
                                                <span>SPOT</span>
                                            </label>
                                            <label class="multi-option">
                                                <input type="checkbox" value="ACTIVO" class="canal-option">
                                                <span>ACTIVO</span>
                                            </label>
                                            <label class="multi-option">
                                                <input type="checkbox" value="ESTRATEGICO" class="canal-option">
                                                <span>ESTRATEGICO</span>
