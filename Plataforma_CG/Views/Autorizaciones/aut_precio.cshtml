@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Autorización de Precio";
}

<style>
    :root {
        --bg: #f0dede;
        --panel: #f8eeee;
        --panel-2: #f1dede;
        --line: #c79d9d;
        --text: #3b1717;
        --muted: #6a3a3a;
        --white: #ffffff;
        --shadow: 0 1px 0 rgba(255,255,255,.55) inset;
        --brand: #8B0000;
        --vino-border: #9a5a5a;
        --vino-text-dark: #4a1111;
    }

    * { box-sizing: border-box; }

    body {
        margin: 0 !important;
        padding: 0 !important;
        font-family: Tahoma, Verdana, Arial, sans-serif;
        background: transparent !important;
        color: var(--text);
    }

    .container, .container-fluid {
        max-width: 100% !important;
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .window {
        width: 100%;
        max-width: 100%;
        margin: 0 !important;
        border: 1px solid #7e4a4a;
        background: var(--panel);
        box-shadow: 0 0 0 1px rgba(255,255,255,.45) inset, 0 8px 18px rgba(70,12,12,.14);
        overflow: hidden;
        padding: 0 !important;
    }

    .window > *:first-child, .titlebar { margin-top: 0 !important; }

    .titlebar {
        height: 34px;
        /* display: flex; */
        display: none !important;
        align-items: center;
        justify-content: space-between;
        padding: 0 10px;
        background: linear-gradient(180deg, #c00000 0%, #8b0000 60%, #5c0000 100%);
        border-bottom: 1px solid #5c0000;
        color: #fff;
        font-size: 13px;
        font-weight: bold;
    }

    .titlebar .actions { display: flex; gap: 6px; }

    .win-btn {
        width: 16px; height: 16px;
        border: 1px solid #7c4848;
        background: linear-gradient(#fff6f6, #ead0d0);
    }

 .toolbar{
    display:flex;
    justify-content:flex-end;
    align-items:center;
    gap:4px;
    padding:4px 6px;
    background:linear-gradient(#fff6f6, #ecd8d8);
    border-bottom:1px solid var(--line);
    font-size:12px;
    flex-wrap:wrap;
    width:100%;
}

    .tool-btn {
        min-width: 72px;
        text-align: center;
        background: linear-gradient(#fffefe, #ecd7d7);
        border: 1px solid var(--vino-border);
        box-shadow: var(--shadow);
        cursor: pointer;
        color: var(--vino-text-dark);
        height: 28px;
        font-size: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        padding: 0 8px;
        text-decoration: none;
    }

    .tool-btn:hover { filter: brightness(.98); }

    .content { padding: 8px; background: var(--bg); }

    .tabs { display: flex; gap: 4px; margin-bottom: 6px; flex-wrap: wrap; }

    .tab {
        font-size: 12px;
        background: linear-gradient(#f7e7e7, #ead1d1);
        border: 1px solid #caa0a0;
        border-bottom: none;
        padding: 7px 12px;
        color: #5c1a1a;
        user-select: none;
    }

    .tab.active {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        font-weight: bold;
        color: #fff;
        border-color: #7a2d2d;
    }

    .workspace { border: 1px solid var(--line); background: var(--panel); padding: 8px; }

    .section { border: 1px solid var(--line); background: var(--white); margin-bottom: 10px; }

    .section-title {
        padding: 6px 8px;
        font-size: 12px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }

    /* ── Estado badge ── */
    .estado-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 2px 8px;
        font-size: 11px;
        font-weight: 700;
        border: 1px solid transparent;
        border-radius: 2px;
    }

    .est-dot { width: 7px; height: 7px; border-radius: 50%; background: #aaa; display: inline-block; }
    .est-ok   { background: #dff3e2; border-color: #6aa84f; color: #2f6b1f; }
    .est-ok   .est-dot { background: #16a34a; }
    .est-warn { background: #fff4cc; border-color: #d6b656; color: #7a5a00; }
    .est-warn .est-dot { background: #d97706; }
    .est-err  { background: #fde2e2; border-color: #d9534f; color: #b00000; }
    .est-err  .est-dot { background: #dc2626; }
    .est-info { background: #e8f4fd; border-color: #7ab8d4; color: #064b6b; }
    .est-info .est-dot { background: #2563eb; }
    .est-light { background: #f4f4f4; border-color: #ccc; color: #555; }

    /* ── Tabla principal ── */
    .table-wrap {
        overflow: auto;
        max-height: 65vh;
        background: #fffafa;
        width: 100%;
        border-top: 1px solid #d9b8b8;
    }

    .table-wrap table {
        width: 100%;
        border-collapse: separate !important;
        border-spacing: 0 !important;
        font-size: 12px;
        background: #fffafa;
    }

    .table-wrap thead th {
        position: sticky;
        top: -1px;
        z-index: 20;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        color: #fff !important;
        border-top: 1px solid #c46a6a !important;
        border-right: 1px solid #8e3b3b !important;
        border-bottom: 1px solid #5c0000 !important;
        padding: 6px 5px !important;
        font-weight: 700 !important;
        font-size: 12px !important;
        white-space: nowrap;
        line-height: 1.2 !important;
        box-shadow: 0 2px 0 #6f1d1d;
        text-transform: none !important;
    }

    .table-wrap thead th:first-child { border-left: 1px solid #8e3b3b !important; }

    .table-wrap tbody td {
        background: #fffafa !important;
        border-right: 1px solid #d8bcbc !important;
        border-bottom: 1px solid #d8bcbc !important;
        padding: 5px 5px !important;
        white-space: nowrap;
        vertical-align: middle;
        font-size: 12px !important;
        color: #401515 !important;
    }

    .table-wrap tbody td:first-child { border-left: 1px solid #d8bcbc !important; }
    .table-wrap tbody tr:hover td { background: #f4dddd !important; }
    .table-wrap tbody tr.row-ok td { background: #dff3e2 !important; color: #2f6b1f !important; }
    .table-wrap tbody tr.row-danger td { background: #fde2e2 !important; }

    /* ── Badges ── */
    .badge-ok {
        display: inline-block; padding: 3px 8px;
        background: #dff3e2; border: 1px solid #6aa84f;
        color: #2f6b1f; font-size: 11px; font-weight: 700; border-radius: 2px;
    }

    .badge-danger {
        display: inline-block; padding: 3px 8px;
        background: #fde2e2; border: 1px solid #d9534f;
        color: #b00000; font-size: 11px; font-weight: 700; border-radius: 2px;
    }

    /* ── Botones ── */
    .pm-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        height: 26px;
        padding: 0 10px;
        border: 1px solid transparent;
        border-radius: 0;
        font-family: Tahoma, Verdana, Arial, sans-serif;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        box-shadow: var(--shadow);
        white-space: nowrap;
    }

    .pm-btn:hover { filter: brightness(.97); }
    .pm-btn:disabled { opacity: .6; cursor: not-allowed; }

    .pm-btn-primary {
        color: #fff;
        border-color: #7a2d2d;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
    }

    .pm-btn-success {
        color: #fff;
        border-color: #157347;
        background: linear-gradient(180deg, #27ae60 0%, #1f9a54 55%, #198754 100%);
    }

    .pm-btn-warning {
        color: #3d2000;
        border-color: #c87800;
        background: linear-gradient(180deg, #ffc107 0%, #e6a800 100%);
    }

    .pm-btn-secondary {
        background: linear-gradient(#fffefe, #ecd7d7);
        border-color: var(--vino-border);
        color: var(--vino-text-dark);
    }

    .pm-btn-outline {
        background: transparent;
        border-color: var(--vino-border);
        color: #5a0000;
    }

    /* ── Filtros en modal ── */
    .filters-inline {
        display: flex;
        gap: 8px;
        align-items: flex-end;
        flex-wrap: wrap;
        margin-bottom: 10px;
        padding: 8px 10px;
        background: var(--panel-2);
        border: 1px solid var(--line);
    }

    .filters-inline label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        color: #5c1a1a;
        margin-bottom: 3px;
    }

    input[type="date"], input[type="text"], input[type="number"], select {
        height: 28px !important;
        padding: 3px 6px !important;
        border: 1px solid #b48787 !important;
        background: #fffdfd !important;
        font-family: inherit !important;
        font-size: 12px !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        color: #421414 !important;
    }

    /* ── Modal ── */
    .modal-content { border: 1px solid #7d4949; border-radius: 0; }

    .modal-header {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        color: #fff !important;
        border-bottom: 1px solid #5c0000 !important;
        padding: .65rem 1rem !important;
        border-radius: 0;
    }

    .modal-title { color: #fff !important; font-weight: 700; font-size: 13px; }
    .btn-close { filter: invert(1) grayscale(100%) !important; opacity: .95 !important; }
    .modal-body { background: #f4e4e4; padding: .75rem !important; }
    .modal-footer { background: #f7eaea; border-top: 1px solid #d3b0b0; }

    .modal-table-wrap {
        border: 1px solid #d8bcbc;
        background: #fffafa;
        overflow: auto;
        max-height: 55vh;
    }

    .modal-table-wrap table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 12px;
    }

    .modal-table-wrap table thead th {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        color: #fff !important;
        border-right: 1px solid #8e3b3b;
        border-bottom: 1px solid #5c0000;
        padding: 6px 5px;
        font-size: 12px;
        white-space: nowrap;
        position: sticky;
        top: 0;
        z-index: 5;
        text-transform: none !important;
    }

    .modal-table-wrap table tbody td {
        background: #fffafa;
        border-bottom: 1px solid #d8bcbc;
        border-right: 1px solid #d8bcbc;
        padding: 5px;
        font-size: 12px;
        color: #401515;
    }

    .modal-table-wrap table tbody tr:nth-child(even) td { background: #f9eded; }
    .modal-table-wrap table tbody tr:hover td { background: #f4dddd !important; }

    /* ── Statusbar ── */
    .statusbar {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 6px 10px;
        font-size: 11px;
        color: #4a1a1a;
        border-top: 1px solid #b88c8c;
        background: linear-gradient(#f6e9e9, #ead5d5);
        flex-wrap: wrap;
    }

    .text-end { text-align: right !important; }
    .text-center { text-align: center !important; }
    .text-danger { color: #b00000 !important; }
    .text-success { color: #2f6b1f !important; }

    /* =========================================
   COLUMNAS DESTACADAS - HISTÓRICO PRECIO
   ========================================= */

/* BODY (celdas) */
#modalReporteHistoricoPrecio table tbody td:nth-child(7),
#modalReporteHistoricoPrecio table tbody td:nth-child(9),
#modalReporteHistoricoPrecio table tbody td:nth-child(5) {
    background: #fff7cc !important;
    color: #5a4300 !important;
    font-weight: 700;
}

/* HEADER */
#modalReporteHistoricoPrecio table thead th:nth-child(7),
#modalReporteHistoricoPrecio table thead th:nth-child(9),
#modalReporteHistoricoPrecio table thead th:nth-child(5) {
    background: linear-gradient(180deg, #f4cc4d 0%, #d4a017 55%, #b88900 100%) !important;
    color: #ffffff !important;
    border-right: 1px solid #9c7800 !important;
    border-bottom: 1px solid #7e6100 !important;
    border-top: 1px solid #ffe08a !important;
}

/* HOVER (para que no se pierda el amarillo) */
#modalReporteHistoricoPrecio table tbody tr:hover td:nth-child(7),
#modalReporteHistoricoPrecio table tbody tr:hover td:nth-child(9),
#modalReporteHistoricoPrecio table tbody tr:hover td:nth-child(5) {
    background: #ffe999 !important;
    color: #4a3700 !important;
}

.tool-btn-historico{
    background: linear-gradient(180deg, #4da3ff 0%, #1f78d1 55%, #0f5ea8 100%);
    border: 1px solid #0d4f8c;
    color: #ffffff;
}

.tool-btn-historico:hover{
    filter: brightness(.95);
}

</style>

<div class="window">

