        <div class="actions">
            <div class="win-btn"></div>
            <div class="win-btn"></div>
            <div class="win-btn"></div>
        </div>
    </div>

<div class="toolbar">
   @*  <button class="tool-btn" type="button" onclick="cargar()">Actualizar</button> *@

    <button class="tool-btn tool-btn-historico" type="button" data-bs-toggle="modal" data-bs-target="#modalReporteHistoricoPrecio">
