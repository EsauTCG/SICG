</div>

@section Scripts {
<script>
    $(function () {
        const POLL_MS = 30000, MAX_BACKOFF = 120000;
        let timer = null, inFlight = false, backoff = POLL_MS;
        let cacheLineas = [];
        const authorizedPrecioLines = new Set();

        const safeNumber = v => Number.isFinite(+v) ? +v : 0;
        const fmtMx = n => safeNumber(n).toLocaleString('es-MX', { style:'currency', currency:'MXN' });
        const fmtKg = n => safeNumber(n).toLocaleString('es-MX', { minimumFractionDigits:2, maximumFractionDigits:2 });
        const esc = s => (s ?? '').toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

        function setStatus(t, cls) {
            $("#lastStatusPrecio").text(t);
            const $b = $("#badgeEstadoPrecio");
            $b.removeClass("est-ok est-warn est-err est-info est-light");
            const map = { ok:'est-ok', warn:'est-warn', err:'est-err', info:'est-info' };
            $b.addClass(map[cls] || 'est-light');
        }

        function setUpdatedNow() {
            $("#lastUpdatedPrecio").text(new Date().toLocaleTimeString('es-MX'));
        }

        function renderTablaOV(data) {
            const $tb = $("#tbodyOVPrecio").empty();

            if (!Array.isArray(data) || !data.length) {
                $tb.append(`<tr><td colspan="9" class="text-center" style="padding:16px;color:#6a3a3a;">No hay órdenes con precio excedido para tus series asignadas</td></tr>`);
                return;
            }

            const grupos = new Map();

            for (const x of data) {
                const ovId = Number(x.ovId ?? 0) || -1;
                if (!grupos.has(ovId)) grupos.set(ovId, []);
                grupos.get(ovId).push(x);
            }

            for (const [ovId, grupo] of grupos) {
                const first = grupo[0] ?? {};
                const folio = (first.ordenVenta ?? '-').toString();
                const serie = (first.serie ?? '-').toString();
                const clienteNombre = first.clienteNombre ?? first.clienteId ?? first.cliente ?? '-';
                const vendedor = (first.vendedor ?? '-').toString();

                const total = grupo.length;
                const excedidas = grupo.filter(g => (g.estadoPrecio ?? '').toLowerCase() === 'excedido').length;

                const todasAut = grupo.every(g =>
                    authorizedPrecioLines.has(Number(g.lineaId)) ||
                    (g.estadoPrecio ?? '').toLowerCase() !== 'excedido'
                );

                const cls = todasAut ? 'row-ok' : 'row-danger';

                const badge = todasAut
                    ? `<span class="badge-ok">Sin pendientes</span>`
                    : `<span class="badge-danger">Pendientes ${excedidas}/${total}</span>`;

                $tb.append(`
                  <tr class="${cls}">
                    <td><b>${esc(folio)}</b></td>
                    <td><b>${esc(serie)}</b></td>
                    <td>${esc(clienteNombre)}</td>
                    <td>${esc(vendedor)}</td>
                    <td colspan="3" class="text-center" style="color:#6a3a3a;font-style:italic;">${total} partida(s)</td>
                    <td class="text-center">${badge}</td>
                    <td class="text-center">
                        <button type="button" class="pm-btn pm-btn-outline"
                                onclick="abrirModalOVPrecio(${ovId}, &quot;${esc(folio)}&quot;)">
                            Ver OV
                        </button>
                    </td>
                  </tr>`);
            }
        }

        window.cargar = function() {
            if (inFlight) return;
            inFlight = true;
            setStatus("Actualizando…", "info");
            $.ajax({ url:'/Comercial/ObtenerProductosPrecioExcedido', type:'GET', cache:false })
                .done(function(data) {
                    cacheLineas = Array.isArray(data) ? data : [];
                    renderTablaOV(cacheLineas);
                    setUpdatedNow();
                    setStatus("Al día", "ok");
                    backoff = POLL_MS;
                })
                .fail(function(xhr) {
                    console.error("Error AJAX (precio):", xhr.responseText);
                    setStatus("Error. Reintentando…", "err");
                    backoff = Math.min(backoff * 2, MAX_BACKOFF);
                    if (timer) clearInterval(timer);
                    timer = setInterval(window.cargar, backoff);
                })
                .always(() => { inFlight = false; });
        };

        $('#modalReporteHistoricoPrecio').on('shown.bs.modal', function() {
            const hoy = new Date();
            const yyyy = hoy.getFullYear();
            const mm = String(hoy.getMonth()+1).padStart(2,'0');
            const dd = String(hoy.getDate()).padStart(2,'0');
            const fechaHoy = `${yyyy}-${mm}-${dd}`;
            if (!$("#filtroFechaInicioHistPrecio").val()) $("#filtroFechaInicioHistPrecio").val(fechaHoy);
            if (!$("#filtroFechaFinHistPrecio").val()) $("#filtroFechaFinHistPrecio").val(fechaHoy);
            cargarHistoricoPrecio();
        });

        $("#btnDescargarHistPrecioExcel").on("click", function () {
    const fechaInicio = $("#filtroFechaInicioHistPrecio").val();
    const fechaFin = $("#filtroFechaFinHistPrecio").val();

    if (!fechaInicio || !fechaFin) {
        alert("Selecciona fecha inicio y fecha fin.");
        return;
    }

    const url = `/Comercial/DescargarHistoricoAutorizacionPrecioExcel?fechaInicio=${encodeURIComponent(fechaInicio)}&fechaFin=${encodeURIComponent(fechaFin)}`;
    window.open(url, "_blank");
});

        function cargarHistoricoPrecio() {
            const $tb = $("#tbodyHistoricoPrecio");
            $tb.html(`<tr><td colspan="11" class="text-center" style="color:#6a3a3a;">Cargando...</td></tr>`);
            $.ajax({
                url:'/Comercial/ObtenerHistoricoAutorizacionPrecio', type:'GET',
                data:{ fechaInicio:$("#filtroFechaInicioHistPrecio").val(), fechaFin:$("#filtroFechaFinHistPrecio").val() }
            })
            .done(function(data) {
                $tb.empty();
                if (!Array.isArray(data) || !data.length) {
                    $tb.append(`<tr><td colspan="11" class="text-center" style="color:#6a3a3a;">No hay registros para ese rango.</td></tr>`);
                    return;
                }
                data.forEach(x => {
                    const fechaTxt = x.fechaRegistro ? new Date(x.fechaRegistro).toLocaleString('es-MX') : '-';
                    $tb.append(`
                        <tr>
                            <td>${esc(x.ordenVentaConsecutivo??'-')}</td>
                            <td>${esc(x.clienteNombre??'-')}</td>
                            <td>${esc(x.productoCodigo??'-')}</td>
                            <td>${esc(x.productoNombre??'-')}</td>
                            <td class="text-end">${fmtMx(x.precioLista)}</td>
                            <td class="text-end">${fmtMx(x.precioOVAntes)}</td>
                            <td class="text-end">${fmtMx(x.precioAutorizado)}</td>
                            <td class="text-end">${fmtMx(x.diferencia)}</td>
                            <td>${esc(x.usuario??'-')}</td>
                            <td>${esc(x.motivo??'-')}</td>
                            <td>${fechaTxt}</td>
                        </tr>`);
                });
            })
            .fail(function(xhr) {
                console.error(xhr);
                $tb.html(`<tr><td colspan="11" class="text-center text-danger">Error al consultar histórico.</td></tr>`);
            });
        }

        $("#btnBuscarHistPrecio").on("click", cargarHistoricoPrecio);

        function startPolling() {
            if (timer) clearInterval(timer);
            timer = setInterval(window.cargar, POLL_MS);
        }

        window.abrirModalOVPrecio = function(ovId, folio) {
            $("#ovPrecioFolio").text(folio || '');
            const $tb = $("#tbodyPartidasOVPrecio").empty();
            const lineas = (cacheLineas || []).filter(x => Number(x.ovId) === Number(ovId));

            if (!lineas.length) {
                $tb.append(`<tr><td colspan="8" class="text-center" style="color:#6a3a3a;">Sin partidas</td></tr>`);
            } else {
                lineas.forEach((it, idx) => {
                    const lineaId = Number(it.lineaId ?? 0);
                    const kilosOV = safeNumber(it.kilosOV ?? it.kgOV ?? it.cantidadKg ?? it.kilos ?? 0);
                    const precioLista = safeNumber(it.precioLista);
                    const precioOV = safeNumber(it.precioOV);
                    const diff = precioLista - precioOV;
                    const pendiente = (it.estadoPrecio ?? '').toLowerCase() === 'excedido' && !authorizedPrecioLines.has(lineaId);
                    const badge = pendiente ? `<span class="badge-danger">Excedido</span>` : `<span class="badge-ok">Dentro/Autorizado</span>`;
                    const btnAuth = pendiente
                        ? `<button type="button" class="pm-btn pm-btn-success" onclick="autorizarPrecioLinea(${lineaId},this)">✔ Autorizar</button>`
                        : `<button type="button" class="pm-btn pm-btn-success" disabled>✔ Autorizado</button>`;
                    $tb.append(`
                      <tr data-linea-id="${lineaId}" data-ov-id="${ovId}">
                        <td>${idx+1}</td>
                        <td><div style="font-size:11px;color:#6a3a3a;">${esc(it.producto??'-')}</div></td>
                        <td class="text-end col-kgov">${fmtKg(kilosOV)}</td>
                        <td class="text-end col-pl">${fmtMx(precioLista)}</td>
                        <td class="text-end col-pov">${fmtMx(precioOV)}</td>
                        <td class="text-end col-diff"><span class="${diff>0?'text-danger':'text-success'}">${fmtMx(diff)}</span></td>
                        <td class="text-center col-estado">${badge}</td>
                        <td class="text-center">
                            ${btnAuth}
                            <button type="button" class="pm-btn pm-btn-warning" style="margin-left:4px;"
                                    onclick="editarPrecioLinea(${lineaId},${precioOV})">
                                Editar Precio
                            </button>
                        </td>
                      </tr>`);
                });
            }

            $("#btnAutorizarTodoPrecio").off('click').on('click', async function() {
                const motivo = prompt("Captura el motivo general de autorización para todas las líneas pendientes:");
                if (motivo === null) return;
                const motivoLimpio = (motivo || "").trim();
                if (!motivoLimpio) { alert("Debe capturar un motivo."); return; }
                const $btn = $(this).prop('disabled', true);
                try {
                    const pendientes = $("#tbodyPartidasOVPrecio tr").toArray()
                        .map(tr => ({ id:Number($(tr).data('linea-id')), $tr:$(tr) }))
                        .filter(o => o.id && !authorizedPrecioLines.has(o.id) && o.$tr.find(".pm-btn-success:not(:disabled)").length);
                    for (const o of pendientes) {
                        await postAutorizarLinea(o.id, motivoLimpio);
                        authorizedPrecioLines.add(o.id);
                        o.$tr.find(".col-estado").html(`<span class="badge-ok">Dentro/Autorizado</span>`);
                        o.$tr.find(".pm-btn-success").prop('disabled', true).text('✔ Autorizado');
                    }
                    window.cargar();
                } catch(e) { console.error(e); alert(e.message || "Error al autorizar las líneas."); }
                finally { $btn.prop('disabled', false); }
            });

            new bootstrap.Modal(document.getElementById('modalOVPrecio'), { backdrop:'static' }).show();
        };

        function postAutorizarLinea(idLinea, motivo) {
            const token = $('input[name="__RequestVerificationToken"]').val();
            return new Promise((resolve, reject) => {
                $.ajax({ url:'/Comercial/AutorizarPrecioLinea', type:'POST',
                    data:{ __RequestVerificationToken:token, idLinea, motivo },
                    headers:{ 'RequestVerificationToken':token }
                }).done(res => resolve(res)).fail(xhr => { reject(new Error(xhr.responseJSON?.mensaje || xhr.responseJSON?.error || xhr.responseText || 'Error')); });
            });
        }

        function postActualizarPrecioLinea(idLinea, nuevoPrecio) {
            const token = $('input[name="__RequestVerificationToken"]').val();
            return new Promise((resolve, reject) => {
                $.ajax({ url:'/Comercial/ActualizarPrecioLinea', type:'POST',
                    data:{ __RequestVerificationToken:token, idLinea, precioOV:nuevoPrecio },
                    headers:{ 'RequestVerificationToken':token }
                }).done(res => resolve(res)).fail(xhr => { reject(new Error(xhr.responseJSON?.mensaje || xhr.responseJSON?.error || xhr.responseText || 'Error')); });
            });
        }

        window.autorizarPrecioLinea = async function(lineaId, btn) {
            const motivo = prompt("Captura el motivo de autorización:");
            if (motivo === null) return;
            const motivoLimpio = (motivo || "").trim();
            if (!motivoLimpio) { alert("Debe capturar un motivo."); return; }
            const $btn = $(btn).prop('disabled', true);
            try {
                await postAutorizarLinea(lineaId, motivoLimpio);
                authorizedPrecioLines.add(lineaId);
                const $tr = $btn.closest('tr');
                $tr.find(".col-estado").html(`<span class="badge-ok">Dentro/Autorizado</span>`);
                $btn.text('✔ Autorizado');
                window.cargar();
            } catch(e) { console.error(e); alert(e.message || "Error al autorizar."); $btn.prop('disabled', false); }
        };

        window.editarPrecioLinea = function(idLinea, precioActual) {
            const $fila = $(`#tbodyPartidasOVPrecio tr[data-linea-id='${idLinea}']`);
            if (!$fila.length) { alert("No se encontró la línea."); return; }
            const input = prompt("Nuevo Precio OV:", precioActual);
            if (input === null) return;
            const valor = parseFloat(input.toString().replace(/\./g,'').replace(/,/g,'.'));
            if (!Number.isFinite(valor) || valor < 0) { alert("Valor inválido"); return; }
            postActualizarPrecioLinea(idLinea, valor)
                .then(() => {
                    $fila.find(".col-pov").text(fmtMx(valor));
                    const plTxt = $fila.find(".col-pl").text().replace(/[^0-9.-]+/g,"");
                    const pl = parseFloat(plTxt) || 0;
                    const diff = pl - valor;
                    $fila.find(".col-diff").html(`<span class="${diff>0?'text-danger':'text-success'}">${fmtMx(diff)}</span>`);
                    if (diff > 0) {
                        $fila.find(".col-estado").html(`<span class="badge-danger">Excedido</span>`);
                        $fila.find(".pm-btn-success").prop('disabled', false).text('✔ Autorizar');
                    } else {
                        $fila.find(".col-estado").html(`<span class="badge-ok">Dentro/Autorizado</span>`);
                        $fila.find(".pm-btn-success").prop('disabled', true).text('✔ Autorizado');
                    }
                    setTimeout(window.cargar, 500);
                    alert("Precio actualizado correctamente");
                })
                .catch(err => { console.error(err); alert(err.message || "Error al actualizar el precio."); });
        };

        window.cargar();
        startPolling();

        document.addEventListener('visibilitychange', () => {
            if (document.hidden) { clearInterval(timer); timer = null; }
            else { window.cargar(); startPolling(); }
        });
    });
</script>
}
