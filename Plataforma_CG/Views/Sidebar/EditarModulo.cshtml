@model Plataforma_CG.Models.ViewModels.SideAdminViewModel
@{
    ViewData["Title"] = "Editar Módulo";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<style>
    :root {
        --brand-grad: linear-gradient(90deg,#8B0000 0%,#5a0000 50%,#1a0000 100%);
        --bg: linear-gradient(135deg,#eef2f6 0%,#e9edf2 50%,#d7dde3 100%);
        --pane: #fff;
        --bar: #e6e9ef;
        --bar-2: #dde2ea;
        --line: #d8dce3;
        --ink: #20262e;
        --muted: #636d7b;
        --radius: 10px;
        --shadow: 0 1px 0 rgba(0,0,0,.05),0 12px 24px rgba(0,0,0,.06);
        --shadow-sm: 0 6px 16px rgba(0,0,0,.06);
        --focus: 0 0 0 .2rem rgba(45,108,223,.25);
        --accent: #2d6cdf;
    }

    .container-sap {
        max-width: 980px;
        margin: 1.25rem auto 2rem;
    }

    /* Titlebar */
    .sap-titlebar {
        background: linear-gradient(#eef1f6,#e7ebf2);
        border: 1px solid var(--bar-2);
        border-radius: var(--radius);
        padding: .85rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        flex-wrap: wrap;
        box-shadow: var(--shadow);
    }

        .sap-titlebar .title {
            margin: 0;
            display: flex;
            align-items: center;
            gap: .55rem;
            font-weight: 800;
            letter-spacing: .2px;
            color: #2b3642;
        }

            .sap-titlebar .title i {
                color: var(--brand);
            }

        .sap-titlebar .sub {
            margin: 0;
            font-size: .92rem;
            color: var(--muted);
        }

        .sap-titlebar .actions .btn {
            border-radius: 999px;
            font-weight: 700;
        }

    /* Card / Panel */
    .sap-card {
        background: var(--pane);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    .sap-card-head {
        padding: .75rem 1rem;
        border-bottom: 1px solid var(--line);
        background: linear-gradient(#f6f8fb,#eef2f7);
        font-weight: 800;
        color: #2b3642;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .form-wrap {
        padding: 1.2rem;
    }

    /* Form grid */
    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: .8rem;
    }

    @@media (min-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    .grid-full {
        grid-column: 1 / -1;
    }

    /* Field cards */
    .field-card {
        display: flex;
        gap: .85rem;
        align-items: stretch;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 10px;
        padding: .9rem 1rem;
        box-shadow: var(--shadow-sm);
    }

    .field-icon {
        width: 42px;
        min-width: 42px;
        height: 42px;
        border-radius: 50%;
        background: var(--brand-grad);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        box-shadow: 0 6px 16px rgba(139,0,0,.18);
    }

    .field-body {
        flex: 1;
    }

    .field-label {
        font-weight: 600;
        color: #1e2a35;
        margin-bottom: .35rem;
    }

    .form-control, .form-select {
        border: 1px solid var(--line);
        border-radius: 8px;
        font-size: .95rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--accent);
            box-shadow: var(--focus);
            outline: none;
        }

    .btn {
        border-radius: 8px;
        font-weight: 600;
        padding: .6rem 1.1rem;
    }

    .btn-reflejo {
        background: var(--brand-grad);
        color: #fff;
        border: none;
    }

        .btn-reflejo:hover {
            filter: brightness(1.06);
        }

    .btn-secondary {
        background: #5b6478;
        border: none;
        color: #fff;
    }

        .btn-secondary:hover {
            filter: brightness(1.05);
        }

    .actions-row {
        display: flex;
        gap: .6rem;
        justify-content: center;
        margin-top: 1rem;
    }
</style>

<div class="container-sap">
    <!-- Titlebar -->
    <div class="sap-titlebar">
        <div>
            <h4 class="title"><i class="bi bi-pencil-square"></i> Editar Módulo</h4>
            <p class="sub mb-0">Actualiza nombre, ícono, URL o jerarquía del módulo.</p>
        </div>
        <div class="actions">
            <a href="@Url.Action("Administrar", "Sidebar")" class="btn btn-secondary btn-sm">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver
            </a>
        </div>
    </div>

    <!-- Card -->
    <div class="sap-card mt-3">
        <div class="sap-card-head">
            <span class="d-flex align-items-center gap-2">
                <i class="bi bi-window"></i> Datos del Módulo
            </span>
        </div>

        <div class="form-wrap">
            <form asp-action="EditarModuloGuardar" method="post">
                <input type="hidden" name="Id" value="@Model.ModuloActual.Id" />
                @Html.AntiForgeryToken()

                <div class="form-grid">
                    <!-- Nombre -->
                    <div class="field-card">
                        <div class="field-icon"><i class="bi bi-card-text"></i></div>
                        <div class="field-body">
                            <div class="field-label">Nombre del módulo</div>
                            <input type="text" name="Nombre" class="form-control" value="@Model.ModuloActual.Nombre" required>
                        </div>
                    </div>

                    <!-- Icono -->
                    <div class="field-card">
                        <div class="field-icon"><i class="bi bi-palette"></i></div>
                        <div class="field-body">
                            <div class="field-label">Ícono (clase FontAwesome)</div>
                            <input type="text" name="Icono" class="form-control" value="@Model.ModuloActual.Icono" placeholder="fas fa-box">
                        </div>
                    </div>

                    <!-- URL -->
                    <div class="field-card">
                        <div class="field-icon"><i class="bi bi-link-45deg"></i></div>
                        <div class="field-body">
                            <div class="field-label">URL (opcional)</div>
                            <input type="text" name="Url" class="form-control" value="@Model.ModuloActual.Url" placeholder="/Controlador/Acción">
                        </div>
                    </div>

                    <!-- Categoría -->
                    <div class="field-card">
                        <div class="field-icon"><i class="bi bi-folder"></i></div>
                        <div class="field-body">
                            <div class="field-label">Categoría</div>
                            <select name="CategoriaId" class="form-select">
                                <option value="">(Sin categoría)</option>
                                @foreach (var c in Model.CategoriasExistentes)
                                {
                                    <option value="@c.Id" selected="@(c.Id == Model.ModuloActual.CategoriaId)">
                                        @c.Nombre
                                    </option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Módulo Padre -->
                    <div class="field-card grid-full">
                        <div class="field-icon"><i class="bi bi-diagram-3"></i></div>
                        <div class="field-body">
                            <div class="field-label">Módulo Padre</div>
                            <select name="PadreId" class="form-select">
                                <option value="">(Ninguno, será módulo principal)</option>
                                @foreach (var m in Model.ModulosExistentes)
                                {
                                    <option value="@m.Id" selected="@(m.Id == Model.ModuloActual.PadreId)">
                                        @m.Nombre
                                    </option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="actions-row">
                    <button type="submit" class="btn btn-reflejo">
                        <i class="bi bi-save me-1"></i> Guardar cambios
                    </button>
                    <a href="@Url.Action("Administrar", "Sidebar")" class="btn btn-secondary">
                        <i class="bi bi-x-circle me-1"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
}
