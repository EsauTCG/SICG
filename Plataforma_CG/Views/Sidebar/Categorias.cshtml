@model IEnumerable<Plataforma_CG.Models.ViewModels.CategoriaViewModel>
@{
    ViewData["Title"] = "Administrar Categorías";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<style>
    :root {
        --brand-grad: linear-gradient(90deg,#8B0000 0%,#5a0000 50%,#1a0000 100%);
        --bar: #e6e9ef;
        --bar-2: #dde2ea;
        --line: #d8dce3;
        --pane: #fff;
        --radius: 10px;
        --shadow: 0 1px 0 rgba(0,0,0,.05), 0 12px 24px rgba(0,0,0,.06);
        --shadow-sm: 0 6px 16px rgba(0,0,0,.06);
    }

    .container-sap {
        max-width: 900px;
        margin: 1.25rem auto 2rem;
    }

    .sap-titlebar {
        background: linear-gradient(#eef1f6,#e7ebf2);
        border: 1px solid var(--bar-2);
        border-radius: var(--radius);
        padding: .85rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        box-shadow: var(--shadow);
    }

    .sap-card {
        background: var(--pane);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        margin-top: 1rem;
    }

    .sap-card-head {
        padding: .75rem 1rem;
        border-bottom: 1px solid var(--line);
        background: linear-gradient(#f6f8fb,#eef2f7);
        font-weight: 800;
        color: #2b3642;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
</style>

<div class="container-sap">

    <!-- Titlebar -->
    <div class="sap-titlebar">
        <div>
            <h4 class="m-0"><i class="bi bi-folder2-open"></i> Administración de Categorías</h4>
            <p class="mb-0 text-muted small">Crea, edita o elimina categorías que agrupan los módulos del sidebar.</p>
        </div>
        <div>
            <a class="btn btn-secondary btn-sm" href="@Url.Action("Administrar", "Sidebar")">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver a módulos
            </a>
        </div>
    </div>

    <!-- Formulario -->
    <div class="sap-card p-3 mt-3">
        <h6 class="fw-bold mb-3"><i class="bi bi-plus-circle"></i> Crear nueva categoría</h6>

        <form id="formCategoria">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Nombre de la categoría</label>
                    <input type="text" id="nombre" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Ícono (Bootstrap Icons)</label>
                    <input type="text" id="icono" class="form-control" placeholder="bi bi-folder">
                </div>
            </div>

            <div class="text-end mt-3">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-save me-1"></i> Guardar categoría
                </button>
            </div>
        </form>
    </div>

    <!-- Lista -->
    <div class="sap-card mt-4">
        <div class="sap-card-head">
            <span><i class="bi bi-list-ul me-2"></i> Categorías existentes</span>
        </div>
        <ul class="list-group list-group-flush" id="lista-categorias">
            @foreach (var cat in Model)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap" data-id="@cat.Id">
                    <div class="d-flex align-items-center gap-2">
                        <i class="@cat.Icono"></i>
                        <strong>@cat.Nombre</strong>
                    </div>
                    <button class="btn btn-sm btn-outline-danger btn-eliminar">
                        <i class="bi bi-trash"></i>
                    </button>
                </li>
            }
        </ul>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <script>
        document.getElementById("formCategoria").addEventListener("submit", async e => {
            e.preventDefault();

            const data = {
                Nombre: document.getElementById("nombre").value,
                Icono: document.getElementById("icono").value
            };

            const res = await fetch("/Sidebar/CrearCategoria", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data)
            });

            const result = await res.json();
            alert(result.mensaje);
            if (res.ok) location.reload();
        });

        document.querySelectorAll(".btn-eliminar").forEach(btn => {
            btn.addEventListener("click", async () => {
                const li = btn.closest("li");
                const id = li.dataset.id;
                const nombre = li.querySelector("strong").innerText;

                if (!confirm(`¿Seguro que deseas eliminar la categoría "${nombre}"?`)) return;

                const res = await fetch(`/Sidebar/EliminarCategoria?id=${id}`, { method: "POST" });
                const result = await res.json();
                alert(result.mensaje);
                if (res.ok) li.remove();
            });
        });
    </script>
}
