@model Plataforma_CG.Models.AsignarKpisVM
@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Asignar KPIs";
}

<style>
    /* === Tema SAP-like (CARNES G) === */
    :root {
        --brand-grad: linear-gradient(90deg,#8B0000 0%,#5a0000 50%,#1a0000 100%);
        --brand: #8B0000;
        --pane: #fff;
        --bar: #e6e9ef;
        --bar-2: #dde2ea;
        --line: #d8dce3;
        --ink: #20262e;
        --muted: #636d7b;
        --radius: 10px;
        --shadow: 0 1px 0 rgba(0,0,0,.05), 0 12px 24px rgba(0,0,0,.06);
        --shadow-sm: 0 6px 16px rgba(0,0,0,.06);
        --focus: 0 0 0 .2rem rgba(139,0,0,.18);
    }

    .container-sap {
        max-width: 1200px;
        margin: 1.25rem auto 2rem;
    }

    /* Titlebar */
    .sap-titlebar {
        background: linear-gradient(#eef1f6,#e7ebf2);
        border: 1px solid var(--bar-2);
        border-radius: var(--radius);
        padding: .85rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        flex-wrap: wrap;
        box-shadow: var(--shadow);
    }

        .sap-titlebar .title {
            margin: 0;
            display: flex;
            align-items: center;
            gap: .55rem;
            font-weight: 800;
            color: #2b3642;
        }

        .sap-titlebar .sub {
            margin: 0;
            font-size: .92rem;
            color: var(--muted);
        }

    /* Toolbar */
    .sap-toolbar {
        background: var(--bar);
        border: 1px solid var(--bar-2);
        border-top: none;
        border-radius: 0 0 var(--radius) var(--radius);
        padding: .45rem .65rem;
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
        box-shadow: var(--shadow);
    }

    .tbtn {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        height: 34px;
        padding: 0 .65rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #fff;
        color: #1e2a35;
        font-size: .92rem;
        transition: .15s ease;
        cursor: pointer;
        text-decoration: none;
    }

        .tbtn:hover {
            background: #f8fafc;
            border-color: #cfd6e2;
        }

        .tbtn.primary {
            background: var(--brand-grad);
            color: #fff;
            border: none;
        }

            .tbtn.primary:hover {
                filter: brightness(1.05);
            }

    /* Card */
    .sap-card {
        background: var(--pane);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
    }

    .sap-card-head {
        padding: .75rem 1rem;
        border-bottom: 1px solid var(--line);
        background: linear-gradient(#f6f8fb,#eef2f7);
        font-weight: 800;
        color: #2b3642;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .5rem;
        flex-wrap: wrap;
    }

    /* Search */
    .filters {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
        align-items: center;
    }

        .filters .input-group {
            max-width: 420px;
        }

    .form-control:focus {
        border-color: rgba(139,0,0,.35);
        box-shadow: var(--focus);
    }

    /* Lists */
    .list-wrap {
        border: 1px solid var(--line);
        border-radius: 10px;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
    }

    .list-group-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .75rem;
    }

    .kpi-meta {
        min-width: 0;
    }

    .kpi-title {
        font-weight: 800;
        color: #2b3642;
        margin: 0;
        line-height: 1.15;
    }

    .kpi-sub {
        margin: 2px 0 0;
        color: var(--muted);
        font-size: .86rem;
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        border: 1px solid rgba(139,0,0,.22);
        background: rgba(139,0,0,.06);
        color: #8B0000;
        border-radius: 999px;
        padding: 2px 10px;
        font-weight: 900;
        font-size: .75rem;
        white-space: nowrap;
    }

    .btn-sm {
        border-radius: 8px;
        font-weight: 800;
    }

    .btn-outline-primary {
        border-color: #8B0000;
        color: #8B0000;
    }

        .btn-outline-primary:hover {
            background: #8B0000;
            color: #fff;
        }
</style>

<div class="container-sap">

    <!-- Titlebar -->
    <div class="sap-titlebar">
        <div>
            <h4 class="title"><i class="bi bi-kanban"></i> Asignación de KPIs</h4>
            <p class="sub">Administra qué KPIs puede ver el usuario seleccionado.</p>
            <p class="sub mb-0"><b>Usuario:</b> @Model.DisplayName</p>
        </div>
        <div class="actions">
            <a class="btn btn-secondary btn-sm" href="@Url.Action("UsuariosConfiguracion", "Usuarios")">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver a Usuarios
            </a>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="sap-toolbar">
        <button type="button" class="tbtn" onclick="location.reload()">
            <i class="bi bi-arrow-clockwise"></i><span>Refrescar</span>
        </button>

        <div class="filters ms-auto">
            <div class="input-group input-group-sm">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input id="txtBuscarKpi" type="search" class="form-control" placeholder="Buscar KPI por título o categoría…">
            </div>
        </div>
    </div>

    <div class="row mt-3 g-3">

        <!-- Disponibles -->
        <div class="col-lg-6">
            <div class="sap-card">
                <div class="sap-card-head">
                    <span><i class="bi bi-inbox me-1"></i> Disponibles</span>
                    <span class="text-muted small">@Model.Disponibles.Count KPI(s)</span>
                </div>

                <div class="p-2">
                    <div class="list-wrap">
                        <ul class="list-group list-group-flush" id="listaDisponibles">
                            @if (!Model.Disponibles.Any())
                            {
                                <li class="list-group-item text-muted">No hay KPIs disponibles.</li>
                            }
                            else
                            {
                                foreach (var k in Model.Disponibles)
                                {
                                    <li class="list-group-item"
                                        data-title="@k.Titulo.ToLowerInvariant()"
                                        data-cat="@k.Categoria.ToLowerInvariant()">

                                        <div class="kpi-meta">
                                            <p class="kpi-title">@k.Titulo</p>
                                            <p class="kpi-sub">
                                                <span class="chip"><i class="bi bi-tags"></i> @k.Categoria</span>
                                            </p>
                                        </div>

                                        <form method="post" asp-action="Agregar" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="usuarioKey" value="@Model.UsuarioKey" />
                                            <input type="hidden" name="kpiId" value="@k.Id" />
                                            <button class="btn btn-sm btn-success">
                                                <i class="bi bi-plus-circle me-1"></i> Agregar
                                            </button>
                                        </form>
                                    </li>
                                }
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Asignados -->
        <div class="col-lg-6">
            <div class="sap-card">
                <div class="sap-card-head">
                    <span><i class="bi bi-check2-square me-1"></i> Asignados</span>
                    <span class="text-muted small">@Model.Asignados.Count KPI(s)</span>
                </div>

                <div class="p-2">
                    <div class="list-wrap">
                        <ul class="list-group list-group-flush" id="listaAsignados">
                            @if (!Model.Asignados.Any())
                            {
                                <li class="list-group-item text-muted">No hay KPIs asignados.</li>
                            }
                            else
                            {
                                foreach (var k in Model.Asignados)
                                {
                                    <li class="list-group-item"
                                        data-title="@k.Titulo.ToLowerInvariant()"
                                        data-cat="@k.Categoria.ToLowerInvariant()">

                                        <div class="kpi-meta">
                                            <p class="kpi-title">@k.Titulo</p>
                                            <p class="kpi-sub">
                                                <span class="chip"><i class="bi bi-tags"></i> @k.Categoria</span>
                                            </p>
                                        </div>

                                        <form method="post" asp-action="Quitar" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="usuarioKey" value="@Model.UsuarioKey" />
                                            <input type="hidden" name="kpiId" value="@k.Id" />
                                            <button class="btn btn-sm btn-danger">
                                                <i class="bi bi-dash-circle me-1"></i> Quitar
                                            </button>
                                        </form>
                                    </li>
                                }
                            }
                        </ul>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

    <script>
        // filtro rápido por texto (título o categoría) en ambas listas
        const input = document.getElementById('txtBuscarKpi');

        function applyFilter(){
            const q = (input.value || '').toLowerCase().trim();

            ['listaDisponibles','listaAsignados'].forEach(id => {
                const ul = document.getElementById(id);
                if(!ul) return;

                Array.from(ul.querySelectorAll('li.list-group-item')).forEach(li => {
                    // ignora placeholders sin dataset
                    const t = li.getAttribute('data-title') || '';
                    const c = li.getAttribute('data-cat') || '';
                    const show = !q || t.includes(q) || c.includes(q);
                    li.style.display = show ? '' : 'none';
                });
            });
        }

        input?.addEventListener('input', applyFilter);
    </script>
}
