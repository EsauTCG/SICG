            // === Productos y totales dinámicos ===
              function actualizarTotales() {
                const tbody = document.getElementById('productosBody');
                let totalPeso = 0;
                let totalImporte = 0;

                for (let i = 0; i < tbody.rows.length; i++) {
                    const row = tbody.rows[i];
                    const pesoInput = row.querySelector('input[name$=".Peso"]');
                    const precioInput = row.querySelector('input[name$=".Precio"]');
                    const subtotalInput = row.querySelector('input[type="text"], .subtotal');

                    const peso = parseFloat(pesoInput?.value) || 0;
                    const precio = parseFloat(precioInput?.value) || 0;
                    const subtotal = peso * precio;

                    if(subtotalInput) subtotalInput.value = subtotal.toFixed(2);

                    totalPeso += peso;
                    totalImporte += subtotal;

                    // Actualiza el índice visible y los nombres
                    row.cells[0].textContent = i + 1;
                    row.querySelectorAll('input, textarea').forEach(input => {
                        if (input.name) {
                            const campo = input.name.split('.').pop();
                            input.name = `Productos[${i}].${campo}`;
                        }
                    });
                }

                document.getElementById('totalPeso').textContent = totalPeso.toFixed(2);
                document.getElementById('totalImporte').textContent = '$' + totalImporte.toFixed(2);
            }


