            async function cargarArticulosMasivos() {
                const cardCode = $("#clienteHidden").val();
                if (!cardCode) { alert("Selecciona un cliente primero."); return; }

                const codigos = $("#articulosMasivos").val()
                    .trim()
                    .toUpperCase()
                    .split(/\r?\n/)
                    .map(c => c.trim())
                    .filter(c => c !== "");

                if (codigos.length === 0) { alert("No hay SKUs para agregar."); return; }

                // Buscar todos los productos en paralelo
                const promesas = codigos.map(code =>
                    $.getJSON('/Comercial/ObtenerPrecioArticuloCliente', { cardCode, itemCode: code })
                        .catch(err => { console.warn("Error al buscar artículo:", code, err); return null; })
                );

                const productos = (await Promise.all(promesas)).filter(p => p && p.itemCode);

                // Agregar filas en paralelo y obtener presupuestos
                await Promise.all(productos.map(p => agregarFilaArticuloConPresupuesto(p, cardCode)));

                actualizarTotales();
                $("#articulosMasivos").val("");
            }

            // Función para agregar fila y asignar presupuesto
            async function agregarFilaArticuloConPresupuesto(producto, cardCode) {
                const tbody = $('#productosBody');
                const row = $('<tr></tr>');

                const precio = producto.precio || 0;
                const kilosCaja = producto.kilosCaja || 1;

                row.data('kilosCaja', kilosCaja);

                const nombreConcatenado = `${(producto.itemName || "").toUpperCase()} (${(producto.itemCode || "").toUpperCase()})`;

                row.html(`
                    <td>${articuloIndex + 1}</td>
                    <td>
                        <input type="hidden" name="Productos[${articuloIndex}].ProductoCodigo" value="${(producto.itemCode || "").toUpperCase()}" />
                        <input type="hidden" name="Productos[${articuloIndex}].ProductoNombre" value="${(producto.itemName || "").toUpperCase()}" />
                        ${nombreConcatenado}
                    </td>
                    <td><input name="Productos[${articuloIndex}].Presupuesto" class="form-control presupuesto" type="number" step="0.01" value="0" readonly /></td>
                    <td><input name="Productos[${articuloIndex}].VariacionPresupuesto" class="form-control variacionPresupuesto" type="number" step="0.01" value="0" readonly /></td>
                    <td><input name="Productos[${articuloIndex}].Peso" class="form-control peso" type="number" step="0.01" value="0" /></td>
                    <td><input name="Productos[${articuloIndex}].Precio" class="form-control precio" type="number" step="0.01" value="${precio}" /></td>
                    <td><input name="Productos[${articuloIndex}].Cajas" class="form-control cajas" type="number" step="0.01" value="0" /></td>
                    <td><input class="form-control subtotal" type="text" value="0.00" readonly /></td>
                                <td> <a href="#" class="text-primary btn-inventario"data-codigo="CODIGO_DEL_PRODUCTO"data-nombre="NOMBRE_DEL_PRODUCTO">Inventario</a></td>
                    <td><a href="#" class="text-danger" onclick="eliminarProducto(this); return false;">Eliminar</a></td>
                `);

                tbody.append(row);

                const inputPresupuesto = row.find('.presupuesto');
                const inputVariacion = row.find('.variacionPresupuesto');
                const inputPrecio = row.find('.precio');

                // 🔹 Obtener mes y año según fecha de entrega
                let fechaEntrega = $("#FechaEntrega").val();
                let mes = new Date().getMonth() + 1;
                let anio = new Date().getFullYear();

                if (fechaEntrega) {
                    const f = new Date(fechaEntrega);
                    if (!isNaN(f)) {
                        mes = f.getMonth() + 1;
                        anio = f.getFullYear();
                    }
                }

                console.log("Buscando presupuesto:", producto.itemCode, cardCode, "Mes:", mes, "Año:", anio);

                // 🔹 Llamada al backend para obtener presupuesto
                try {
                    const data = await $.getJSON('/Comercial/ObtenerPresupuestoCliente', {
                        cardCode,
                        productoCodigo: producto.itemCode,
                        mes,
                        anio
                    });

                    if (data && data.length > 0 && data[0].PresupuestoAsignado != null) {
                        const pres = parseFloat(data[0].PresupuestoAsignado) || 0;
                        inputPresupuesto.val(pres.toFixed(2));
                        // Variación respecto al precio actual
                        inputVariacion.val((parseFloat(inputPrecio.val()) - pres).toFixed(2));
                    } else {
                        inputPresupuesto.val("0.00");
                        inputVariacion.val("0.00");
                    }
                } catch (err) {
                    console.error("Error al obtener presupuesto:", err);
                    inputPresupuesto.val("0.00");
                    inputVariacion.val("0.00");
                }

                // Eventos dinámicos Peso ↔ Cajas ↔ Subtotal
                row.find('.peso').on('input', function () {
                    const r = $(this).closest('tr');
                    const peso = parseFloat($(this).val()) || 0;
                    const precio = parseFloat(r.find('.precio').val()) || 0;
                    const kilosCaja = parseFloat(r.data('kilosCaja')) || 1;

                    r.find('.cajas').val((peso / kilosCaja).toFixed(2));
                    r.find('.subtotal').val((peso * precio).toFixed(2));
                    actualizarTotales();
                });

                row.find('.cajas').on('input', function () {
                    const r = $(this).closest('tr');
                    const cajas = parseFloat($(this).val()) || 0;
                    const precio = parseFloat(r.find('.precio').val()) || 0;
                    const kilosCaja = parseFloat(r.data('kilosCaja')) || 1;

                    r.find('.peso').val((cajas * kilosCaja).toFixed(2));
                    r.find('.subtotal').val((cajas * kilosCaja * precio).toFixed(2));
                    actualizarTotales();
                });

                articuloIndex++;
            }

