@using Plataforma_CG.ViewModels

@model Plataforma_CG.ViewModels.PedidoViewModel

@{
    var productos = Model?.Productos ?? new List<PedidoProductoViewModel>();
}

@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Nuevo Orden de Venta";
}


<style>

    #propiedadesCliente .form-check {
        margin-bottom: 4px; /* un poco de aire si saltan de línea */
    }

   


   
</style>

<div class="container-fluid p-4 mt-3" style="border: 2px solid #8B0000; border-radius: 12px; background-color: #fff;">
    <h4 class="mb-4 text-center text-dark fw-bold">NUEVA ORDEN DE VENTA</h4>

    <form asp-action="GuardarPedido" method="post">
        <!-- Encabezado -->
        <div class="row">
            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Consecutivo</label>
                <input asp-for="Consecutivo" class="form-control" readonly />
            </div>
            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Serie</label>
                <select asp-for="Serie" asp-items="Model.Series" class="form-select">
                    <option value="">Selecciona serie</option>
                </select>
            </div>
            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Fecha Entrega</label>
                <input asp-for="FechaEntrega" type="date" class="form-control" />
            </div>
            @*     <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Fecha de Embarque</label>
                <input asp-for="FechaEmbarque" type="date" class="form-control" />
                <input asp-for="HoraEmbarque" type="time" class="form-control mt-1" />
            </div> *@
        </div>

        <div class="row">
            <div class="mb-3">
                <label class="form-label">Cliente</label>
                <input id="clienteInput" class="form-control" placeholder="Escribe para buscar cliente" />
                <input type="hidden" id="clienteHidden" name="Cliente" />
            </div>


            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Vendedor</label>
                <input asp-for="Vendedor" class="form-control" readonly />
            </div>

            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Dirección</label>
                <select id="rutaSelect" name="Ruta" class="form-select">
                    <option value="">Selecciona ruta</option>
                </select>

                <br />

                <!-- PROPIEDADES DE CLIENTES -->
                <!-- Modal -->
                <div class="modal fade" id="modalPropiedades" tabindex="-1" aria-labelledby="modalPropiedadesLabel" aria-hidden="activo">
                    <div class="modal-dialog modal-lg modal-dialog-scrollable">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="modalPropiedadesLabel">Documentación del Cliente</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                            </div>
                            <div class="modal-body" id="modalPropiedadesBody">
                                <!-- Aquí se llenará dinámicamente con JS -->
                                <p>Cargando información...</p>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- PROPIEDADES DE CLIENTES -->


            </div>
            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Presentación</label>
                <select asp-for="Presentacion" asp-items="Model.Presentaciones" class="form-select">
                    <option value="">Selecciona Presentación</option>
                </select>
            </div>

            <div class="col-12 col-md-3 mb-3 d-flex align-items-center">
                <button type="button" class="btn btn-info w-100" data-bs-toggle="modal" data-bs-target="#modalPropiedades" style="margin-bottom: -5px;">
                    Ver Documentación
                </button>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Observación</label>
            <textarea asp-for="Observacion" class="form-control"></textarea>
        </div>

        <!-- Totales -->
        <div class="row">
            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Saldo</label>
                <input id="saldoInput" asp-for="Saldo" class="form-control" readonly />
            </div>
            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Saldo Vencido</label>
                <input id="saldoVencidoInput" asp-for="SaldoVencido" class="form-control" readonly />
            </div>
            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Otros Pedidos</label>
                <input id="otrosPedidosInput" asp-for="OtrosPedidos" class="form-control" readonly />
            </div>
            <div class="col-12 col-md-3 mb-3">
                <label class="form-label">Crédito</label>
                <input id="creditoInput" asp-for="Credito" class="form-control" readonly />
            </div>
        </div>

        <hr />

        <!-- Inicio Productos -->
        <h5 class="mb-3">Productos</h5>

        <!-- Spinner flotante de carga de productos -->
        
<!-- Spinner de carga fullscreen -->
<div id="loadingSpinner" style="display:none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(255,255,255,0.8);
    z-index: 2000;
    flex-direction: column;
    justify-content: center;
    align-items: center;
">
    <div class="spinner-border text-danger" role="status" style="width:4rem; height:4rem;">
        <span class="visually-hidden">Cargando...</span>
    </div>
    <p class="mt-3 fw-bold text-danger fs-5">Cargando productos, por favor espera...</p>
</div>

        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead style="background-color:#8B0000; color:white;" class="text-center fw-bold">
                    <tr>
                        <th>#</th>
                        <th>Producto</th>
                        <th>Presupuesto</th>
                        <th>Disponible</th>
                        <th>Peso (kg)</th>
                        <th>Precio</th>
                        <th>Cajas</th>
                        <th>Importe</th>
                        <th>Inventario</th> <!-- Nueva columna -->
                        <th></th>
                    </tr>
                </thead>
                <tbody id="productosBody">
                    @for (int i = 0; i < productos.Count; i++)
                    {
                        <tr>
                            <td>@(i + 1)</td>
                            <td>
                                <input name="Productos[@i].ProductoNombre" class="form-control productoInput" placeholder="Buscar producto..." />
                                <input type="hidden" name="Productos[@i].ProductoCodigo" class="productoCodigo" />
                            </td>
                            <td>
                                <input asp-for="Productos[@i].Presupuesto" type="number" step="0.01" class="form-control presupuesto" readonly />
                            </td>
                            <td>
                                <input asp-for="Productos[@i].VariacionPresupuesto" type="number" step="0.01" class="form-control" readonly />
                            </td>
                            <td>
                                <input asp-for="Productos[@i].Peso" type="number" step="0.01" class="form-control" />
                            </td>
                            <td>
                                <input asp-for="Productos[@i].Precio" class="form-control" />
                            </td>
                            <td>
                                <input asp-for="Productos[@i].Cajas" type="number" step="0.01" class="form-control" />
                            </td>
                            <td>
                                <input class="form-control" type="text" value="@productos[i].Importe" readonly />
                            </td>
                            <td class="text-center">
                                <!-- Botón para ver inventario -->
                                <button type="button" class="btn btn-sm btn-info"  onclick="verInventario('@productos[i].ProductoCodigo', '@productos[i].ProductoNombre')">
                                    Inventario
                                </button>
                            </td>
                            <td>
                                <a href="#" class="text-danger" onclick="eliminarProducto(this); return false;">Eliminar</a>
                            </td>
                        </tr>
                    }

                    @if (!productos.Any())
                    {
                        <tr>
                            <td>1</td>
                            <td>
                                <input name="Productos[0].ProductoNombre" class="form-control productoInput" placeholder="Buscar producto..." />
                                <input type="hidden" name="Productos[0].ProductoCodigo" class="productoCodigo" />
                            </td>
                            <td><input name="Productos[0].Presupuesto" class="form-control presupuesto" type="number" step="0.01" value="0" readonly /></td>
                            <td><input name="Productos[${index}].VariacionPresupuesto" class="form-control variacionPresupuesto" type="number" step="0.01" value="${prod.PresupuestoDisponible || 0}" readonly /></td>
                            <td><input name="Productos[0].Peso" class="form-control" type="number" step="0.01" value="0" /></td>
                            <td><input name="Productos[0].Precio" class="form-control" type="number" step="0.01" value="0" /></td>
                            <td><input name="Productos[0].Cajas" type="number" min="0" step="1" class="form-control cajas" value="0" /></td>
                            <td><input class="form-control subtotal" type="text" value="0.00" readonly /></td>
                            <td><a href="#" class="text-primary btn-inventario" data-codigo="@productos.ElementAtOrDefault(0)?.ProductoCodigo ?? ''" data-nombre="@productos.ElementAtOrDefault(0)?.ProductoNombre ?? ''">Inventario</a> </td>
                            <td> <a href="#" class="text-danger" onclick="eliminarProducto(this); return false;">Eliminar</a></td>
                           
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between mb-3">
            <a href="#" style="color: #8B0000; font-weight: bold; text-decoration: none;" onclick="agregarProducto(); return false;">
                [ Agregar Nuevo Producto ]
            </a>
        </div>

        <!-- Final Productos -->



        <!-- Totales dinámicos -->
        <div class="mt-3 p-3 border rounded" style="background-color:#f8f9fa;">
            <div class="d-flex justify-content-between">
                <strong>Total Peso: </strong> <span id="totalPeso">0.00</span>
                <strong>Total Importe: </strong> <span id="totalImporte">$0.00</span>
            </div>
        </div>
        <br />
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <button type="submit" name="accion" value="salir" class="btn btn-primary">Guardar/Salir</button>
                <button type="submit" name="accion" value="nuevo" class="btn btn-primary">Guardar/Nuevo</button>
                <button type="button" class="btn btn-secondary" onclick="window.location='/Home/inicio'">Cancelar</button>
            </div>
            <div>
                <button type="button" class="btn btn-success"
                        data-bs-toggle="modal"
                        data-bs-target="#modalCargaMasiva"
                        style="background-color: #28a745; border-color: #28a745;">
                    Carga masiva por SKU
                </button>
            </div>
        </div>
    </form>

    <!-- CARGA MASIVA PRODUCTOS -->
    <!-- Botón para abrir modal -->
    @* <div class="d-flex justify-content-end mb-3">
        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#modalCargaMasiva">
            Carga masiva por SKU
        </button>
    </div> *@

    <!-- Modal -->
    <div class="modal fade" id="modalCargaMasiva" tabindex="-1" aria-labelledby="modalCargaMasivaLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalCargaMasivaLabel">Carga masiva de artículos</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Pega los SKUs separados por ENTER</label>
                        <textarea id="articulosMasivos" class="form-control" rows="8" placeholder="SKU1&#10;SKU2&#10;SKU3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button id="btnAgregarArticulos" type="button" class="btn btn-success">
                        <span id="btnText">Agregar artículos</span>
                        <span id="btnSpinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                    </button>
                </div>
            </div>
        </div>
    </div>


    <!-- Modal de Inventario -->
    <div class="modal fade" id="inventarioModal" tabindex="-1" aria-labelledby="inventarioModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #8B0000; color: white;">
                    <h5 class="modal-title" id="inventarioModalLabel">Inventario de Producto</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <p><strong>Producto:</strong> <span id="modalProductoNombre"></span></p>
                    <p><strong>Código:</strong> <span id="modalProductoCodigo"></span></p>
                    <hr />
                    <div id="modalInventarioContenido">
                        <!-- Aquí se cargarán los datos de inventario via JS / AJAX -->
                        Cargando inventario...
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>


    <!-- CARGA MASIVA PRODUCTOS -->
    @section Scripts {
        <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

        <!-- SOLO UNA VERSIÓN DE jQuery -->
    @* <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script> *@
        <!-- jQuery UI -->
        <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
        <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>


        <script>

               //AUTORIZACION PARA NO DEJAR VACIO CAMPOS

              $(document).ready(function() {
                $("form").on("submit", function(e) {
                    let valido = true;
                    let mensaje = "";

                    // 🔹 Validar cliente, fecha, serie, ruta, presentación y vendedor
                    if (!$("#clienteHidden").val()) { valido = false; mensaje += "- Debes seleccionar un cliente.\n"; }
                    if (!$("#FechaEntrega").val()) { valido = false; mensaje += "- Debes ingresar la fecha de entrega.\n"; }
                    if (!$("#Serie").val()) { valido = false; mensaje += "- Debes seleccionar una serie.\n"; }
                    if (!$("#rutaSelect").val()) { valido = false; mensaje += "- Debes seleccionar una ruta.\n"; }
                    if (!$("#Presentacion").val()) { valido = false; mensaje += "- Debes seleccionar una presentación.\n"; }
                    if (!$("#Vendedor").val()) { valido = false; mensaje += "- Debes ingresar un vendedor.\n"; }

                    // 🔹 Validar productos (manuales o de servidor)
                    $("#productosBody tr").each(function(index, tr) {
                        const producto = $(tr).find(".productoInput").val();
                        const peso = parseFloat($(tr).find(".peso").val()) || 0;
                        const precio = parseFloat($(tr).find(".precio").val()) || 0;
                        const cajas = parseFloat($(tr).find(".cajas").val()) || 0;

                        // if (!producto) { valido = false; mensaje += `- Producto en fila ${index + 1} no está seleccionado.\n`; }
                        // if (peso <= 0) { valido = false; mensaje += `- Peso debe ser mayor a 0 en fila ${index + 1}.\n`; }
                        // if (precio <= 0) { valido = false; mensaje += `- Precio debe ser mayor a 0 en fila ${index + 1}.\n`; }
                        // if (cajas <= 0) { valido = false; mensaje += `- Cajas debe ser mayor a 0 en fila ${index + 1}.\n`; }
                    });

                    if (!valido) {
                        e.preventDefault(); // ❌ Evita que se envíe el formulario
                        alert("Por favor corrige los siguientes errores:\n\n" + mensaje);
                    }
                });
            });

            // FIN AUTORIZACION PARA NO DEJAR VACIO CAMPOS


        // === Bloquear fechas pasadas en #FechaEntrega ===
                const hoy = new Date();
                const anio = hoy.getFullYear();
                const mes = (hoy.getMonth() + 1).toString().padStart(2, '0');
                const dia = hoy.getDate().toString().padStart(2, '0');
                const fechaMinima = `${anio}-${mes}-${dia}`;
                $("#FechaEntrega").attr("min", fechaMinima);

                $("#FechaEntrega").on("change", function() {
                    const fechaSeleccionada = new Date($(this).val());
                    if (fechaSeleccionada < hoy.setHours(0,0,0,0)) {
                        alert("No se pueden seleccionar fechas pasadas.");
                        $(this).val(fechaMinima);
                    }
                });
             // === Bloquear fechas pasadas en #FechaEntrega ===



            // === Autocompletado de clientes ===
            $(function () {
                $("#clienteInput").autocomplete({
                    source: function (request, response) {
                        $.ajax({
                            url: '/Comercial/BuscarClientesAutocomplete',
                            data: { term: request.term },
                            success: function (data) {
                                response(data);
                            },
                            error: function () {
                                response([]);
                            }
                        });
                    },
                    minLength: 2,
                    select: function (event, ui) {
                        // Evitar que se escriba en el input el valor original del item
                        event.preventDefault();

                        // Asignar nombre y código del cliente
                        $("#clienteInput").val(ui.item.label);
                        $("#clienteHidden").val(ui.item.value);

                        // 🔹 Saldos y créditos
                        $("input[name='Saldo']").val(Number(ui.item.saldo || 0).toLocaleString('es-MX', { minimumFractionDigits: 2 }));
                        $("input[name='Credito']").val(Number(ui.item.credito || 0).toLocaleString('es-MX', { minimumFractionDigits: 2 }));
                        $("input[name='OtrosPedidos']").val(Number(ui.item.sumpedidos || 0).toLocaleString('es-MX', { minimumFractionDigits: 2 }));
                        $("input[name='SaldoVencido']").val(Number(ui.item.saldoVencido || 0).toLocaleString('es-MX', { minimumFractionDigits: 2 }));

                        // 🔹 Obtener vendedor
                        $.getJSON('/Comercial/ObtenerVendedorCliente', { cardCode: ui.item.value }, function (vendedorData) {
                            $("input[name='Vendedor']").val(vendedorData.vendedorNombre || 'No asignado');
                        });

                        // 🔹 Traer propiedades dinámicas
                        $.getJSON('/Comercial/ObtenerPropiedadesCliente', { cardCode: ui.item.value }, function (propData) {
                            let html = '<div class="d-flex flex-wrap gap-2">';
                            propData.forEach(p => {
                                html += `
                                    <div class="form-check form-check-inline">
                                        <input type="checkbox" class="form-check-input" name="Propiedades" value="${p.nombre}" ${p.valor ? 'checked' : ''} />
                                        <label class="form-check-label">${p.nombre}</label>
                                    </div>`;
                            });
                            html += '</div>';
                            $("#propiedadesCliente").html(html);
                        });

                        // 🔹 Traer rutas desde SAP
                                    $.getJSON('/Comercial/ObtenerDireccionesLocal', { cardCode: ui.item.value }, function (rutaData) {
                            const rutaSelect = $("#rutaSelect");
                            rutaSelect.empty();
                            rutaSelect.append('<option value="">Selecciona ruta</option>');
                            rutaData.forEach(r => {
                                rutaSelect.append(`<option value="${r.value}">${r.text}</option>`);
                            });
                        });

                        // ✅ Ahora sí: cargar productos con la fecha ya establecida
                        cargarProductos();

                        return false; // Evita que el valor original se escriba de nuevo
                    }
                });

                // 🔹 Convertir lo escrito a mayúsculas
                $("#clienteInput").on("input", function () {
                    const start = this.selectionStart;
                    const end = this.selectionEnd;
                    this.value = this.value.toUpperCase();
                    this.setSelectionRange(start, end);
                });
            });


            // === Autocompletado de clientes ===



            // === Inicializar autocomplete de productos ===
            function initProductoAutocomplete(element) {
                $(element).autocomplete({
                    source: function (request, response) {
                        $.ajax({
                            url: '/Comercial/BuscarProductosAutocomplete',
                            data: { term: request.term },
                            success: function (data) {
                                response($.map(data, function (item) {
                                    return {
                                        label: item.label.toUpperCase(),
                                        value: item.value
                                    };
                                }));
                            }
                        });
                    },
                    minLength: 2,

              select: function (event, ui) {
                const row = $(element).closest("tr");
                const precioInput = row.find("input[name$='.Precio']");
                const cajasInput = row.find("input[name$='.Cajas']");
                const pesoInput = row.find("input[name$='.Peso']");
                const presupuestoInput = row.find("input[name$='.Presupuesto']");
                const variacionInput = row.find("input[name$='.VariacionPresupuesto']");

                $(element).val(ui.item.label);
                $(element).siblings(".productoCodigo").val(ui.item.value);

                const cardCode = $("#clienteHidden").val();
                const productoCodigo = ui.item.value;

                if (cardCode) {
                    // 🔹 Obtener mes y año actuales automáticamente
                    const fechaActual = new Date();
                    const mes = fechaActual.getMonth() + 1; // Enero = 0
                    const anio = fechaActual.getFullYear();

                    // ✅ Obtener presupuesto del cliente/producto
                    $.getJSON('/Comercial/ObtenerPresupuestoProducto', {
                        cardCode: cardCode,
                        productoCodigo: productoCodigo,
                        mes: mes,
                        anio: anio
                    }, function(presupuesto) {
                        if (presupuesto && presupuesto.presupuestoAsignado != null) {
                            presupuestoInput.val(parseFloat(presupuesto.presupuestoAsignado).toFixed(2));
                            variacionInput.val('0.00');
                        } else {
                            presupuestoInput.val('0.00');
                            variacionInput.val('0.00');
                        }
                    });

                    // 🔹 Obtener precio del artículo
                    $.getJSON('/Comercial/ObtenerPrecioArticuloCliente', { cardCode: cardCode, itemCode: productoCodigo }, function (data) {
                        if (data) {
                            precioInput.val(parseFloat(data.precio || 0).toFixed(2));
                            row.data("kilosCaja", parseFloat(data.kilosCaja || 0));

                            const peso = parseFloat(pesoInput.val()) || 0;
                            const kilosCaja = parseFloat(row.data("kilosCaja")) || 0;
                            const cajas = kilosCaja > 0 ? peso / kilosCaja : 0;
                            const importe = peso * (parseFloat(data.precio) || 0);

                            cajasInput.val(cajas.toFixed(2));
                            row.find("input[type='text']").val(importe.toFixed(2));
                        }
                    });
                }

                return false;
            }
                });

                // Convertir a mayúsculas mientras escribes
                $(element).on('input', function () {
                    const start = this.selectionStart;
                    const end = this.selectionEnd;
                    this.value = this.value.toUpperCase();
                    this.setSelectionRange(start, end);
                });
            }

            // Calcular cajas e importe al cambiar peso
            $(document).on("input", "input[name$='.Peso']", function () {
                const row = $(this).closest("tr");
                const peso = parseFloat($(this).val()) || 0;
                const precio = parseFloat(row.find("input[name$='.Precio']").val()) || 0;
                const kilosCaja = parseFloat(row.data("kilosCaja")) || 1;

                const cajas = kilosCaja > 0 ? peso / kilosCaja : 0;
                const cajasRedondeadas = Math.round(cajas); // 🔹 redondeo a entero
                const importe = peso * precio;

