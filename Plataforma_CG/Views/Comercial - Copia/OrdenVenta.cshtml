                        <td><input name="Productos[${index}].Presupuesto" class="form-control presupuesto" type="number" step="0.01" value="0" readonly /></td>
                        <td><input name="Productos[${index}].VariacionPresupuesto" class="form-control variacionPresupuesto" type="number" step="0.01" value="0" readonly /></td>
                        <td><input name="Productos[${index}].Peso" class="form-control peso" type="number" step="0.01" value="0" /></td>
                        <td><input name="Productos[${index}].Precio" class="form-control precio" type="number" step="0.01" value="0" /></td>
                        <td><input name="Productos[${index}].Cajas" class="form-control cajas" type="number" step="0.01" value="0" /></td>
                        <td><input class="form-control subtotal" type="text" value="0.00" readonly /></td>
                        <td><a href="#" class="text-primary btn-inventario">Inventario</a></td>
                        <td><a href="#" class="text-danger" onclick="eliminarProducto(this); return false;">Eliminar</a></td>                       
                        
                    </td>
                `);

                tbody.append(fila);

                // Inicializar autocomplete
                initProductoAutocomplete(fila.find(".productoInput")[0]);

                // Recalcular variación y subtotal
                fila.find(".precio, .peso, .cajas").on("input", function () {
                    const precio = parseFloat(fila.find(".precio").val()) || 0;
                    const presupuesto = parseFloat(fila.find(".presupuesto").val()) || 0;
                    const peso = parseFloat(fila.find(".peso").val()) || 0;
                    const cajas = parseFloat(fila.find(".cajas").val()) || 0;

                    fila.find(".variacionPresupuesto").val((precio - presupuesto).toFixed(2));
                    fila.find(".subtotal").val((precio * peso * cajas).toFixed(2));
                });

                actualizarIndices();
            }

            // === Actualiza la columna # y los índices de name para model binding ===
            function actualizarIndices() {
                $("#productosBody tr").each(function (i, tr) {
                    $(tr).find("td:first").text(i + 1);

                    $(tr).find("input").each(function () {
                        const name = $(this).attr("name");
                        if (name) {
                            const nuevoName = name.replace(/Productos\[\d+\]/, `Productos[${i}]`);
                            $(this).attr("name", nuevoName);
                        }
                    });
                });
            }

            // === Función para eliminar una fila ===
            function eliminarProducto(link) {
                $(link).closest("tr").remove();
                actualizarIndices();
            }



            function verInventario(codigo, nombre) {
                // Mostrar nombre y código en el modal
                document.getElementById('modalProductoNombre').textContent = nombre;
                document.getElementById('modalProductoCodigo').textContent = codigo;
                document.getElementById('modalInventarioContenido').innerHTML = 'Cargando inventario...';

                // Mostrar modal
                var modal = new bootstrap.Modal(document.getElementById('inventarioModal'));
                modal.show();

                // Hacer llamada AJAX para obtener inventario
                fetch(`/Inventario/ObtenerStock?codigo=${codigo}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data && data.length > 0) {
                            let html = '<ul class="list-group">';
                            data.forEach(item => {
                                html += `<li class="list-group-item d-flex justify-content-between align-items-center">
                                            ${item.Almacen} - ${item.Ubicacion}
                                            <span class="badge bg-primary rounded-pill">${item.Cantidad}</span>
                                         </li>`;
                            });
                            html += '</ul>';
                            document.getElementById('modalInventarioContenido').innerHTML = html;
                        } else {
                            document.getElementById('modalInventarioContenido').innerHTML = '<p>No hay stock disponible.</p>';
                        }
                    })
                    .catch(err => {
                        console.error(err);
                        document.getElementById('modalInventarioContenido').innerHTML = '<p>Error al cargar inventario.</p>';
                    });
            }

            // Evento delegado para botones de inventario
            $(document).on('click', '.btn-inventario', function(e) {
                e.preventDefault();
                const codigo = $(this).data('codigo');
                const nombre = $(this).data('nombre');
                verInventario(codigo, nombre);
            });

        </script>

        <input type="hidden" id="productoCodigo" name="ProductoCodigo" />
    }
