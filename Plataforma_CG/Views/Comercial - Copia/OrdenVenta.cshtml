   // === Función para cargar productos del servidor ===
            // === Función para cargar productos y presupuesto del servidor ===
            function cargarProductos() {
                const fecha = $("#FechaEntrega").val();
                const cardCode = $("#clienteHidden").val();
                const tbody = $("#productosBody");

                if (!fecha || !cardCode) return;

                // Mostrar spinner con texto dinámico
                $("#loadingSpinner p").text(`Cargando productos y presupuesto del cliente ${cardCode}...`);
                $("#loadingSpinner").css("display", "flex");

                // Eliminar filas previas de servidor
                tbody.find("tr[data-origen='servidor']").remove();

                // Eliminar la primera fila vacía si existe (de origen manual)
                const primeraFila = tbody.find("tr").first();
                if (primeraFila.length && !primeraFila.data('origen')) {
                    primeraFila.remove();
                }

                // 🔹 Cargar productos
                $.getJSON("/Comercial/ObtenerProductosPorClienteFecha", { cardCode, fechaEntrega: fecha })
                    .done(function (productos) {
                        productos.forEach((prod, index) => {
                            const fila = $(`
                                <tr data-origen="servidor">
                                    <td>${tbody.find("tr").length + 1}</td>
                                    <td>
                                        <input type="hidden" name="Productos[${index}].ProductoCodigo" value="${prod.productoCodigo}" />
                                        <input type="hidden" name="Productos[${index}].ProductoNombre" value="${prod.productoNombre}" />
                                        ${prod.productoNombre}
                                    </td>
                                    <td><input name="Productos[${index}].Presupuesto" class="form-control presupuesto" type="number" step="0.01" value="${prod.presupuesto || 0}" readonly /></td>
                                    <td><input name="Productos[${index}].VariacionPresupuesto" class="form-control variacionPresupuesto" type="number" step="0.01" value="0" readonly /></td>
                                    <td><input name="Productos[${index}].Peso" class="form-control peso" type="number" step="0.01" value="0" /></td>
                                    <td><input name="Productos[${index}].Precio" class="form-control precio" type="number" step="0.01" value="${prod.precio || 0}" /></td>
                                    <td><input name="Productos[${index}].Cajas" class="form-control cajas" type="number" step="0.01" value="0" /></td>
                                    <td><input class="form-control subtotal" type="text" value="0.00" readonly /></td>
                                    <td><a href="#" class="text-primary btn-inventario" data-codigo="${prod.productoCodigo}" data-nombre="${prod.productoNombre}">Inventario</a></td>
                                    <td><a href="#" class="text-danger" onclick="eliminarProducto(this); return false;">Eliminar</a></td>
                                </tr>
                            `);

                            tbody.append(fila);

                            const kilosCaja = parseFloat(prod.kilosCaja || 1);
                            fila.data('kilosCaja', kilosCaja);

                            // Función para calcular subtotal
                            function actualizarSubtotalYVariacion(peso, precio) {
                                const subtotal = peso * precio;
                                fila.find(".subtotal").val(subtotal.toFixed(2));
                            }

                            // Asignar valores iniciales: 1 caja y peso según kilosCaja
                            fila.find(".cajas").val(1);
                            fila.find(".peso").val(kilosCaja.toFixed(2));

                            // Eventos Peso ↔ Cajas ↔ Precio
                            fila.find('.peso').on('input', function () {
                                const peso = parseFloat($(this).val()) || 0;
                                const precio = parseFloat(fila.find('.precio').val()) || 0;
                                fila.find('.cajas').val((peso / kilosCaja).toFixed(2));
                                actualizarSubtotalYVariacion(peso, precio);
                                actualizarTotales();
                            });

                            fila.find('.cajas').on('input', function () {
                                const cajas = parseFloat($(this).val()) || 0;
                                const precio = parseFloat(fila.find('.precio').val()) || 0;
                                const peso = cajas * kilosCaja;
                                fila.find('.peso').val(peso.toFixed(2));
                                actualizarSubtotalYVariacion(peso, precio);
                                actualizarTotales();
                            });

                            fila.find('.precio').on('input', function () {
                                const peso = parseFloat(fila.find('.peso').val()) || 0;
                                const precio = parseFloat($(this).val()) || 0;
                                actualizarSubtotalYVariacion(peso, precio);
                                actualizarTotales();
                            });

                            // Disparar cálculo inicial
                            fila.find(".peso").trigger("input");
                        });

                        // 🔹 Una vez cargadas las filas, actualizar presupuesto disponible
                        $.getJSON("/Comercial/ObtenerProductosConPresupuestoDisponible", { cardCode, fechaEntrega: fecha })
                            .done(function (productosPresupuesto) {
                                productosPresupuesto.forEach(prod => {
                                    const fila = tbody.find(`input[name$='ProductoCodigo'][value='${prod.productoCodigo}']`).closest('tr');
                                    if (fila.length) {
                                        fila.find(".variacionPresupuesto").val(prod.presupuestoDisponible.toFixed(2));
                                    }
                                });
                            });

                        actualizarIndices();
                        actualizarTotales();
                    })
                    .fail(function () {
                        alert("Error al cargar productos");
                    })
                    .always(function () {
                        $("#loadingSpinner").hide();
                    });
            }

