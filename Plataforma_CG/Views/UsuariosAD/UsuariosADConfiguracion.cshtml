@model IEnumerable<Plataforma_CG.Models.UsuarioAD>

@{
    ViewData["Title"] = "Configuración de Usuarios AD";
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<style>
    /* ================================
       SAP-LIKE THEME (Paleta CEDIS)
       ================================ */
    :root {
        /* Marca */
        --brand-grad: linear-gradient(90deg,#8B0000 0%,#5a0000 50%,#1a0000 100%);
        --brand: #8B0000; /* sólido para bordes/inputs */
        /* Cromado / UI */
        --brand: linear-gradient(90deg, #8B0000 0%, #5a0000 50%, #1a0000 100%);
        --pane: #fff;
        --bar: #e6e9ef;
        --bar-2: #dde2ea;
        --line: #d8dce3;
        --ink: #20262e;
        --muted: #636d7b;
        --accent: #2d6cdf;
        --radius: 10px;
        --shadow: 0 1px 0 rgba(0,0,0,.05), 0 12px 24px rgba(0,0,0,.06);
        --shadow-sm: 0 6px 16px rgba(0,0,0,.06);
        --focus: 0 0 0 .2rem rgba(45,108,223,.25);
    }

    /* Fondo de la página */
    body {
        background: var(--bg) !important;
        color: var(--ink);
    }

    .container-sap {
        max-width: 1200px;
        margin: 1.25rem auto 2rem;
    }

    /* Titlebar */
    .sap-titlebar {
        background: linear-gradient(#eef1f6,#e7ebf2);
        border: 1px solid var(--bar-2);
        border-radius: var(--radius);
        padding: .85rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        flex-wrap: wrap;
        box-shadow: var(--shadow);
    }

        .sap-titlebar .title {
            margin: 0;
            display: flex;
            align-items: center;
            gap: .55rem;
            font-weight: 800;
            letter-spacing: .2px;
            color: #2b3642;
        }

            .sap-titlebar .title i {
                color: var(--brand);
            }

        .sap-titlebar .sub {
            margin: 0;
            font-size: .92rem;
            color: var(--muted);
        }

        .sap-titlebar .actions .btn {
            border-radius: 999px;
            font-weight: 700;
        }

    /* Toolbar */
    .sap-toolbar {
        background: var(--bar);
        border: 1px solid var(--bar-2);
        border-top: none;
        border-radius: 0 0 var(--radius) var(--radius);
        padding: .45rem .65rem;
        display: flex;
        flex-wrap: wrap;
        gap: .45rem;
        box-shadow: var(--shadow);
    }

    .tbtn {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        height: 34px;
        padding: 0 .65rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #fff;
        color: #1e2a35;
        font-size: .92rem;
        transition: .15s ease;
    }

        .tbtn:hover {
            background: #f8fafc;
            border-color: #cfd6e2;
        }

        .tbtn:active {
            background: #edf1f7;
            transform: translateY(.5px);
        }

        .tbtn.primary {
            background: var(--brand-grad);
            color: #fff;
            border-color: transparent;
        }

            .tbtn.primary:hover {
                filter: brightness(1.05);
            }

    /* Card/Panel */
    .sap-card {
        background: var(--pane);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
    }

    .sap-card-head {
        padding: .75rem 1rem;
        border-bottom: 1px solid var(--line);
        background: linear-gradient(#f6f8fb,#eef2f7);
        font-weight: 800;
        color: #2b3642;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .5rem;
        flex-wrap: wrap;
    }

    /* Table */
    .table-wrap {
        border: 1px solid var(--line);
        border-radius: 10px;
        box-shadow: var(--shadow-sm);
        overflow: auto;
        max-height: 65vh;
    }

    .table {
        margin-bottom: 0;
    }

        .table thead th {
            position: sticky;
            top: 0;
            z-index: 1;
            background: #f3f6fb !important;
            color: #2b3642;
            border-bottom: 1px solid var(--line) !important;
            text-transform: uppercase;
            font-size: .85rem;
            font-weight: 800;
        }

    .table-hover tbody tr:hover {
        background: #f9fbff;
    }

    /* Badges estados */
    .estado-activo {
        color: #198754;
        font-weight: 600;
    }

    .estado-inactivo {
        color: #dc3545;
        font-weight: 600;
    }

    /* Botones secundarios */
    .btn-secondary {
        background: #5b6478;
        border: none;
        color: #fff;
        border-radius: 8px;
    }

        .btn-secondary:hover {
            filter: brightness(1.05);
        }

    /* Toast / alerts spacing */
    .alert {
        box-shadow: var(--shadow-sm);
    }
</style>

<div class="container-sap">

    <!-- Titlebar -->
    <div class="sap-titlebar">
        <div>
            <h4 class="title"><i class="bi bi-people-gear"></i> Configuración de Usuarios AD</h4>
            <p class="sub mb-0">Administra usuarios sincronizados desde Active Directory y sus perfiles.</p>
        </div>
        <div class="actions">
            <a class="btn btn-secondary btn-sm" href="@Url.Action("PermisosConfiguracion", "Permisos")">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver a Permisos
            </a>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="sap-toolbar">
        <button id="btnMigrar" class="tbtn primary">
            <i class="bi bi-cloud-arrow-down"></i><span>Migrar desde Active Directory</span>
        </button>
        <button type="button" class="tbtn" onclick="location.reload()">
            <i class="bi bi-arrow-clockwise"></i><span>Refrescar</span>
        </button>
    </div>

    <!-- Alerts -->
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success mt-3"><i class="bi bi-check-circle me-2"></i>@TempData["Exito"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mt-3"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]</div>
    }

    <!-- Card con tabla -->
    <div class="sap-card mt-3">
        <div class="sap-card-head">
            <span class="d-flex align-items-center gap-2">
                <i class="bi bi-table"></i> Usuarios Registrados
            </span>
        </div>

        <div class="p-2 table-wrap">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Usuario AD</th>
                        <th>Nombre</th>
                        <th>Puesto</th>
                        <th>Perfil</th>
                        <th>¿Es Vendedor?</th>
                        <th>ID Vendedor</th>
                        <th style="width:100px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>@u.Id</td>
                            <td>@u.UsuarioAd</td>
                            <td>@u.Nombre</td>
                            <td>@u.Puesto</td>
                            <td>@(u.Perfil != null ? u.Perfil.Nombre : "Sin asignar")</td>
                            <td>@(u.EsVendedor ? "✅ Sí" : "❌ No")</td>
                            <td>@(u.EsVendedor ? u.VendedorId?.ToString() ?? "-" : "-")</td>
                            <td>
                                <a asp-action="Editar" asp-route-id="@u.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <script>
        document.getElementById("btnMigrar").addEventListener("click", async () => {
            if (!confirm("¿Deseas migrar los usuarios desde Active Directory?")) return;

            const btn = document.getElementById("btnMigrar");
            btn.disabled = true;
            const original = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Migrando…';

            try {
                const response = await fetch("/api/Migracion/migrar", { method: "POST" });

                let data;
                try { data = await response.json(); } catch { data = await response.text(); }

                if (response.ok) {
                    if (typeof data === "object" && data?.Mensaje) {
                        alert(`${data.Mensaje}\nTotal de usuarios migrados: ${data.TotalUsuarios ?? 0}`);
                    } else if (typeof data === "string") {
                        alert(data);
                    } else {
                        alert("✅ Migración completada correctamente.");
                    }
                    location.reload();
                } else {
                    let mensajeError = "⚠️ Error durante la migración.\n";
                    if (typeof data === "object" && data?.Error)      mensajeError += data.Error;
                    else if (typeof data === "string")                mensajeError += data;
                    else                                              mensajeError += "Ocurrió un error desconocido.";
                    alert(mensajeError);
                }
            } catch (err) {
                alert(`❌ Error en la migración:\n${err.message}`);
            } finally {
                btn.disabled = false;
                btn.innerHTML = original;
            }
        });
    </script>
}
