@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Acceso Denegado";
}

<style>
    :root {
        --brand: linear-gradient(90deg, #8B0000 0%, #5a0000 50%, #1a0000 100%);
        --brand-dark: #5f0000;
        --page-bg: #f7f9fb;
        --panel-bg: #ffffff;
        --border: #e5e8eb;
        --text: #1d232a;
        --subtle: #6a7682;
        --radius: 12px;
        --shadow: 0 2px 10px rgba(16,24,40,.06);
    }

    body {
        background: var(--page-bg);
        color: var(--text);
        font-family: "Segoe UI", Roboto, system-ui, sans-serif;
    }

    .sap-page {
        min-height: calc(100vh - 120px);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 24px;
    }

    .sap-panel {
        background: var(--panel-bg);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        width: 100%;
        max-width: 520px;
        overflow: hidden;
    }

    .sap-bar {
        background: linear-gradient(180deg, var(--brand) 0%, var(--brand-dark) 100%);
        color: #fff;
        padding: 14px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .sap-bar h4 {
            margin: 0;
            font-weight: 800;
            letter-spacing: .3px;
        }

    .sap-content {
        padding: 32px 28px;
        text-align: center;
    }

    .sap-icon {
        font-size: 70px;
        color: var(--brand);
        margin-bottom: 16px;
    }

    .sap-heading {
        font-weight: 800;
        font-size: 1.6rem;
        margin-bottom: 10px;
        color: var(--brand-dark);
    }

    .sap-text {
        font-size: .95rem;
        color: var(--subtle);
        margin-bottom: 24px;
    }

    .sap-actions {
        display: flex;
        justify-content: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-sap {
        border-radius: 999px;
        font-weight: 700;
        border: 1px solid transparent;
        padding: .6rem 1.2rem;
        transition: all .15s ease;
    }

        .btn-sap:active {
            transform: translateY(1px);
        }

    .btn-emphasized {
        background: var(--brand);
        color: #fff;
        border-color: var(--brand);
    }

        .btn-emphasized:hover {
            background: var(--brand-dark);
            border-color: var(--brand-dark);
        }

    .btn-transparent {
        background: #fff;
        color: var(--brand);
        border-color: var(--border);
    }

        .btn-transparent:hover {
            background: #fff7f7;
            border-color: #e0c5c5;
        }
</style>

<div class="sap-page">
    <div class="sap-panel">
        <!-- Barra de título -->
        <div class="sap-bar">
            <h4>Acceso denegado</h4>
            <span style="opacity:.9;">SIGO</span>
        </div>

        <div class="sap-content">
            <div class="sap-icon">🚫</div>
            <h1 class="sap-heading">Acceso denegado</h1>
            <p class="sap-text">No tienes permisos para acceder a esta sección.</p>

            <div class="sap-actions">
                <a href="@Url.Action("Inicio", "Home")" class="btn-sap btn-emphasized">🏠 Volver al inicio</a>
                <a href="@Url.Action("Logout", "Acceso")" class="btn-sap btn-transparent">🚪 Cerrar sesión</a>
            </div>
        </div>
    </div>
</div>
