@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
}

<style>
    /* ===== Tokens “SAP-like” con marca Carnes G (rojos) ===== */
    :root {
        --brand: linear-gradient(90deg, #8B0000 0%, #5a0000 50%, #1a0000 100%);
        --brand-600: #7b0000; /* hover/active */
        --brand-100: #fff1f1; /* sutil bg */
        --text: #1d232a;
        --subtle: #6a7682;
        --border: #e6e9ef;
        --panel: #ffffff;
        --page: #f7f9fb;
        --ok: #0f7d3d;
        --bad: #bb0000;
        --warn: #d98300;
        --shadow: 0 2px 10px rgba(16,24,40,.06);
        --radius: 12px;
    }

    body {
        background: var(--page);
        color: var(--text);
    }

    .page-wrap {
        min-height: calc(100vh - 120px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    /* ===== Panel / Tarjeta principal ===== */
    .fx-panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        width: 100%;
        max-width: 720px;
        box-shadow: var(--shadow);
        overflow: hidden;
    }

    /* ===== Barra de título (SAP Bar) con marca ===== */
    .fx-bar {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: 14px 18px;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, #8B0000 0%, #5f0000 100%);
        color: #fff;
    }

    .fx-title {
        margin: 0;
        font-weight: 800;
        letter-spacing: .2px;
    }

    .fx-sub {
        margin-left: auto;
        opacity: .85;
        font-size: .92rem;
    }

    .fx-content {
        padding: 22px 24px 26px;
    }

    /* Icono “message strip” */
    .fx-hero {
        display: grid;
        place-items: center;
        width: 66px;
        height: 66px;
        border-radius: 14px;
        background: #ffecec;
        color: var(--brand);
        border: 1px solid #ffd2d2;
        font-size: 34px;
        box-shadow: 0 1px 3px rgba(0,0,0,.04) inset;
        margin: 0 auto 12px;
    }

    .fx-heading {
        font-weight: 800;
        font-size: 1.25rem;
        margin: 6px 0 14px;
        text-align: center;
    }

    /* Tira informativa / message strip */
    .fx-strip {
        border: 1px solid #ffd2d2;
        background: #fff4f4;
        color: #5a1d1d;
        border-radius: 10px;
        padding: 12px 14px;
        margin-bottom: 12px;
    }

        .fx-strip strong {
            font-weight: 800;
        }

    /* Object Status (lista) */
    .fx-status {
        border: 1px solid var(--border);
        border-radius: 10px;
        background: #fff;
        padding: 14px 16px;
        margin-top: 14px;
    }

        .fx-status h6 {
            margin: 0 0 8px;
            font-weight: 700;
        }

        .fx-status ul {
            list-style: none;
            padding-left: 0;
            margin: 0;
        }

        .fx-status li {
            display: flex;
            align-items: center;
            gap: .5rem;
            padding: 6px 0;
            border-bottom: 1px dashed #edf0f4;
        }

            .fx-status li:last-child {
                border-bottom: 0;
            }

    .st-ok {
        color: var(--ok);
        font-weight: 700;
    }

    .st-bad {
        color: var(--bad);
        font-weight: 700;
    }

    .st-warn {
        color: var(--warn);
        font-weight: 700;
    }

    /* Panel info secundario */
    .fx-info {
        margin-top: 16px;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: #fafbff;
        padding: 14px 16px;
    }

    /* ===== Acciones (botones SAP-like) ===== */
    .fx-actions {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
        margin-top: 18px;
    }

    .btn-sap {
        border-radius: 999px;
        padding: .55rem 1rem;
        font-weight: 700;
        border: 1px solid transparent;
        transition: background .15s ease, border-color .15s ease, color .15s ease, transform .04s ease;
    }

        .btn-sap:active {
            transform: translateY(1px);
        }

    .btn-emphasized {
        background: var(--brand);
        color: #fff;
        border-color: var(--brand);
    }

        .btn-emphasized:hover {
            background: var(--brand-600);
            border-color: var(--brand-600);
        }

    .btn-transparent {
        background: #fff;
        color: var(--brand);
        border-color: var(--border);
    }

        .btn-transparent:hover {
            background: #fff8f8;
            border-color: #e2c5c5;
        }

    .user-name {
        color: var(--brand);
        font-weight: 800;
    }
</style>

<div class="page-wrap">
    <div class="fx-panel">
        <!-- Barra de título -->
        <div class="fx-bar">
            <h5 class="fx-title">Modo limitado</h5>
            <span class="fx-sub">SIGO · Estado del sistema</span>
        </div>

        <div class="fx-content">
            <div class="fx-hero">⚠️</div>
            <h2 class="fx-heading">Acceso en modo limitado</h2>

            <!-- Tira informativa -->
            <div class="fx-strip">
                <p class="mb-2">
                    Bienvenido <span class="user-name">@User.Identity?.Name</span>
                </p>
                <p class="mb-0"><strong>Has iniciado sesión correctamente</strong>, pero el sistema presenta problemas temporales con la base de datos.</p>
            </div>

            <!-- Object status -->
            <div class="fx-status">
                <h6>Estado del sistema</h6>
                <ul>
                    <li>✅ <strong>Active Directory:</strong> <span class="st-ok">Operativo</span></li>
                    <li>❌ <strong>Base de datos:</strong> <span class="st-bad">No disponible</span></li>
                    <li>⚠️ <strong>Servicios dependientes:</strong> <span class="st-warn">Degradado</span></li>
                </ul>
            </div>

            <!-- Info secundaria -->
            <div class="fx-info mt-3">
                <strong>Funcionalidades limitadas:</strong>
                <ul class="mb-0">
                    <li>No puedes acceder a módulos que requieren datos</li>
                    <li>Configuraciones y permisos no disponibles</li>
                    <li>Espera a que el servicio se restablezca</li>
                </ul>
            </div>

            <!-- Acciones -->
            <div class="fx-actions">
                <button onclick="location.reload()" class="btn-sap btn-emphasized">
                    🔄 Reintentar conexión
                </button>
                <a href="@Url.Action("Logout", "Acceso")" class="btn-sap btn-transparent">
                    🚪 Cerrar sesión
                </a>
            </div>
        </div>
    </div>
</div>
