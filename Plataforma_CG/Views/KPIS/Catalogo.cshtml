			height: 100vh !important;
		}
	}

	footer,
	.footer {
		background: #141414 !important;
		color: #ffffff !important;
		border: none !important;
		margin: 0 !important;
	}

	body,
	html {
		background: #141414 !important;
	}

	main,
	.container,
	.container-fluid,
	.body-content {
		background: #141414 !important;
		padding-bottom: 0 !important;
		margin-bottom: 0 !important;
	}

</style> 
<div class="dashboard-container">

    <!-- VISTA CATÁLOGO -->
    <div id="vistaCatalogo">

        <div class="sticky-header">
            <div class="hero-card">

                <div class="search-container">
                    <div class="search-pill">
                        <i class="fas fa-search"></i>
                        <input type="text" id="inputBusqueda" placeholder="Buscar KPI´s..." onkeyup="filtrar()">
                    </div>
                </div>

                <div class="hero-bg-layer" id="heroBg"></div>
                <div class="hero-gradient-layer"></div>

                <div class="hero-content">
                    <div class="anim-text" id="boxText">
                        <div class="hero-tag" id="lblCat">KPI SELECCIONADO</div>
                        <h1 class="hero-title" id="lblTitle">Cargando...</h1>
                        <p class="hero-desc" id="lblDesc">Selecciona un KPI de la lista inferior para ver los detalles.</p>

                        <div>
                            <button class="btn-hero-action" type="button" onclick="abrirVisor()">
                                <i class="fas fa-play"></i> ABRIR KPI
                            </button>
                            <button id="btnMoreInfo" class="btn-hero-secondary" type="button" onclick="toggleMasInfo()" style="display: none;">
                                Más info
                            </button>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <div class="catalog-body" id="contenedorFilas">
            <div id="msgNoResult" class="no-results"><i class="fas fa-ghost"></i> Sin resultados</div>
        </div>

    </div>

    <!-- VISTA VISOR -->
    <div id="vistaVisor" class="viewer-panel">
        <div class="viewer-topbar">
            <h3 id="viewerTitle" style="margin:0; font-weight:900; color:#333;">...</h3>
            <div>
                <button class="viewer-btn" onclick="recargarFrame()"><i class="fas fa-sync-alt"></i> Actualizar</button>
                <button class="viewer-btn" onclick="cerrarVisor()"><i class="fas fa-arrow-left"></i> Volver al Catálogo</button>
            </div>
        </div>
        <iframe id="mainFrame" style="width:100%; height:100%; border:none;" src=""></iframe>
    </div>

</div>

@section Scripts {
    <script>
        // ==========
        // 1) Construir DB desde el Model (Razor -> JS)
        // ==========
        const db = [
        @foreach (var cat in Model.Keys.OrderBy(x => x))
        {
                    foreach (var k in Model[cat])
                    {
                                var img = string.IsNullOrWhiteSpace(k.ImagenUrl) ? "/img/kpi/kpi-default.png" : k.ImagenUrl;
                                <text>
                                {
                                    id: @k.Id,
                                    title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(k.Titulo ?? "")),
                                    desc: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(k.Descripcion ?? "")),
                                    cat:  @Html.Raw(System.Text.Json.JsonSerializer.Serialize(cat ?? "")),
                                    img:  @Html.Raw(System.Text.Json.JsonSerializer.Serialize(img)),
                                    // url del iframe NO va aquí (para no exponer EmbedUrl).
                                    // Usamos endpoint seguro que retorna el embed sólo si tiene permiso:
                                    getUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Action("GetEmbedUrl", "Kpis", new { id = k.Id })))
                                },
                                </text>
                    }
        }
        ];

        let currentItem = null;

        document.addEventListener("DOMContentLoaded", () => {
            renderizar(db);
            if (db.length > 0) updateHero(db[0]);
        });

        // ==========
        // 2) Render por categorías (misma idea de tu diseño esperado)
        // ==========
        function renderizar(datos) {
            const container = document.getElementById("contenedorFilas");

            // limpia filas previas
            container.querySelectorAll(".category-row").forEach(el => el.remove());

            const cats = [...new Set(datos.map(x => x.cat))];
            const msg = document.getElementById("msgNoResult");

            if (cats.length === 0) {
                if (msg) msg.style.display = "block";
                return;
            }
            if (msg) msg.style.display = "none";

            cats.forEach(c => {
                const items = datos.filter(x => x.cat === c);
                const row = document.createElement("div");
                row.className = "category-row";

                const scrollId = `scroll-${(c || '').replace(/\s/g,'')}`;

                const cardsHtml = items.map(i => `
                    <div class="report-card" id="card-${i.id}" onclick="selectItem(${i.id})">
                        <div class="card-thumb" style="background-image: url('${i.img}')"></div>
                        <div class="card-meta">
                            <div class="card-name">${escapeHtml(i.title)}</div>
                        </div>
                    </div>
                `).join('');

                row.innerHTML = `
                    <div class="cat-title">${escapeHtml(c)}</div>
                    <div class="scroll-wrapper">
                        <div class="nav-arrow nav-prev" onclick="slide('${scrollId}', -1)">
                            <i class="fas fa-chevron-left"></i>
                        </div>
                        <div class="cards-track" id="${scrollId}">
                            ${cardsHtml}
                        </div>
                        <div class="nav-arrow nav-next" onclick="slide('${scrollId}', 1)">
                            <i class="fas fa-chevron-right"></i>
                        </div>
                    </div>
                `;
                container.appendChild(row);
            });
        }

        // ==========
        // 3) Selección + hero animado
        // ==========
        function selectItem(id) {
            const item = db.find(x => x.id === id);
            if (!item) return;

            document.querySelectorAll('.report-card').forEach(el => el.classList.remove('active-selection'));
            const card = document.getElementById(`card-${id}`);
            if (card) card.classList.add('active-selection');

            updateHero(item);
        }

        function updateHero(item) {
            currentItem = item;

            const bg = document.getElementById("heroBg");
            const boxText = document.getElementById("boxText");

            // Reset estado de la descripción y botón
            const desc = document.getElementById("lblDesc");
            const moreBtn = document.getElementById("btnMoreInfo");
            if (moreBtn) {
                moreBtn.textContent = "Más info";
                moreBtn.style.display = "none"; // Ocultar mientras hacemos la transición
            }
            desc.classList.remove("expanded");

            bg.style.opacity = 0;
            boxText.classList.add('exiting');

            setTimeout(() => {
                bg.style.backgroundImage = `url('${item.img}')`;
                document.getElementById("lblTitle").innerText = item.title || "";
                document.getElementById("lblDesc").innerText = item.desc || "";
                document.getElementById("lblCat").innerText = (item.cat || "KPI SELECCIONADO").toUpperCase();

                boxText.classList.remove('exiting');
                boxText.classList.add('entering');
                void boxText.offsetWidth;

                bg.style.opacity = 0.6;
                boxText.classList.remove('entering');

                // Damos un milisegundo para que el navegador dibuje el texto y luego medimos
                setTimeout(verificarBotonMasInfo, 50);

            }, 350);
        }

        // ==========
        // 4) Navegación carrusel
        // ==========
        function slide(id, dir) {
            const el = document.getElementById(id);
            if (!el) return;
            el.scrollBy({ left: dir * 360, behavior: 'smooth' });
        }

        // ==========
        // 5) Buscador (título o categoría)
        // ==========
        function filtrar() {
            const txt = (document.getElementById("inputBusqueda").value || "").toLowerCase().trim();
            if (!txt) renderizar(db);
            else renderizar(db.filter(x =>
                (x.title || '').toLowerCase().includes(txt) ||
                (x.cat || '').toLowerCase().includes(txt)
            ));

            // auto-select first visible
            const first = document.querySelector(".report-card");
            if (first) {
                const id = parseInt(first.id.replace("card-", ""), 10);
                if (!isNaN(id)) selectItem(id);
            }
        }

        // ==========
        // 6) Más info (clamp/unclamp)
        // ==========
        function toggleMasInfo(){
            const desc = document.getElementById("lblDesc");
            const btn = document.getElementById("btnMoreInfo");
            const expanded = desc.classList.contains("expanded");

            if(expanded){
                desc.classList.remove("expanded");
                if(btn) btn.textContent = "Más info";

                // Si lo volvemos a contraer, verificamos si de verdad hay que ocultarlo o dejarlo
                setTimeout(verificarBotonMasInfo, 50);
            } else {
                desc.classList.add("expanded");
                if(btn) btn.textContent = "Menos";
            }
        }
        //verificar si es necesario mas info
        function verificarBotonMasInfo() {
            const desc = document.getElementById("lblDesc");
            const btn = document.getElementById("btnMoreInfo");
            if (!desc || !btn) return;

            if (desc.scrollHeight > desc.clientHeight) {
                btn.style.display = "inline-block"; // Si el texto es muy largo, mostramos el botón
            } else {
                btn.style.display = "none"; // Si cabe perfectamente, lo ocultamos
            }
        }


        // ==========
        // 7) Abrir visor (carga embed de forma segura)
        // ==========
        async function abrirVisor() {
            if (!currentItem) return;

            document.getElementById("viewerTitle").innerText = currentItem.title || "";

            // Pide el embedUrl al server (solo si tiene permiso)
            const res = await fetch(currentItem.getUrl, { headers: { "X-Requested-With": "XMLHttpRequest" } });

            if (!res.ok) {
                alert("No se pudo abrir el KPI (sin permiso o error).");
                return;
            }

            const data = await res.json();
            if (!data || !data.url) {
                alert("No se pudo obtener el enlace del KPI.");
                return;
            }

            document.getElementById("mainFrame").src = data.url;

            document.getElementById("vistaCatalogo").style.display = "none";
            document.getElementById("vistaVisor").style.display = "flex";
            window.scrollTo(0, 0);
        }

        function cerrarVisor() {
            document.getElementById("vistaVisor").style.display = "none";
            document.getElementById("mainFrame").src = "";
            document.getElementById("vistaCatalogo").style.display = "block";
        }

        function recargarFrame() {
            const f = document.getElementById("mainFrame");
            f.src = f.src;
        }

        // ==========
        // Utils
        // ==========
        function escapeHtml(str){
            return (str || "").toString()
                .replaceAll("&","&amp;")
                .replaceAll("<","&lt;")
                .replaceAll(">","&gt;")
                .replaceAll('"',"&quot;")
                .replaceAll("'","&#039;");
        }
    </script>
}
