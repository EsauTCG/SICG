@model Plataforma_CG.Models.KpiCatalogo

<div style="padding:18px; background:linear-gradient(90deg,#8B0000 0%,#5a0000 55%,#1a0000 100%); color:#fff;">
    <div style="opacity:.9; font-weight:700;">@Model.Categoria</div>
    <h3 style="margin:6px 0 0; font-weight:900;">@Model.Titulo</h3>
</div>

<div class="p-4 bg-white">
    <div style="font-weight:800; margin-bottom:6px;">Descripción</div>
    <div style="color:#6b7280;">@Model.Descripcion</div>

    <div class="d-flex gap-2 mt-4">
        <a class="btn btn-danger" href="@Url.Action("Ver", "Kpis", new { id = Model.Id })">Ver KPI</a>
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cerrar</button>
    </div>
</div>
