@model Plataforma_CG.Models.LoginViewModel
@{
    ViewData["Title"] = "";
    Layout = null;
}
<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] SIGO</title>
    <link rel="icon" type="image/png" href="~/images/ico_sigo.ico" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/fonts/fonts.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/fonts/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;700;800;900&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
        --red:       #c0001a;
        --red-dark:  #8b0000;
        --red-deep:  #1e0000;
        --bg-dark:   #0a0000;
        --txt-white: #ffffff;
        --txt-soft:  rgba(255,255,255,0.82);
        --txt-muted: rgba(255,255,255,0.55);
        --font-head: 'Barlow Condensed', sans-serif;
        --font-body: 'Barlow', sans-serif;
    }

    html, body {
        height: 100%;
        width: 100%;
        overflow: hidden;
        background: var(--bg-dark);
        font-family: var(--font-body);
        color: var(--txt-white);
    }

    /* ── VISTAS ── */
    .cg-view-section {
        display: none;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity .4s ease, transform .4s ease;
        position: absolute;
        inset: 0;
        overflow: hidden;
    }
    .cg-view-section.active-view { opacity: 1; transform: translateY(0); }

    /* ══════════════════════════════════════════════
       VISTA HOME  — replica fiel del mockup
    ══════════════════════════════════════════════ */
    #view-home {
        display: flex;
        flex-direction: column;
        height: 100vh;
        background: var(--bg-dark);
        overflow: hidden;
    }

    /* Curva roja decorativa */
    #view-home::before {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 58%;
        height: 100%;
        background: radial-gradient(ellipse 85% 110% at -5% 50%,
            rgba(160,0,20,0.92) 0%,
            rgba(110,0,10,0.72) 38%,
            transparent 68%);
        pointer-events: none;
        z-index: 0;
    }

  

    .cg-logo-wrap { display: flex; flex-direction: column; align-items: center; gap: 2px; }
    .cg-logo { height: 70px; object-fit: contain; }
    .cg-logo-brand {
        font-family: var(--font-head);
        font-weight: 900;
        font-size: 1.15rem;
        letter-spacing: 0.22em;
        color: #fff;
        text-transform: uppercase;
        line-height: 1;
    }
    .cg-logo-sub {
        font-size: 0.48rem;
        letter-spacing: 0.35em;
        color: rgba(255,255,255,0.55);
        text-transform: uppercase;
    }

    .cg-topnav { display: none; }

    .cg-quote {
        max-width: 280px;
        text-align: right;
        font-style: italic;
        font-size: 0.88rem;
        line-height: 1.6;
        color: rgba(255,255,255,0.80);
    }
    .cg-quote::before { content: '\201C'; font-size: 1.6rem; color: var(--red); line-height: 0; vertical-align: -0.5rem; margin-right: 4px; }
    .cg-quote::after  { content: '\201D'; font-size: 1.6rem; color: var(--red); line-height: 0; vertical-align: -0.5rem; margin-left: 4px; }

    /* ── Main stage ── */
    .cg-stage {
        position: relative;
        z-index: 2;
        flex: 1;
        display: grid;
        grid-template-columns: 52% 48%;
        align-items: stretch;
        overflow: hidden;
    }

    /* ── LEFT COLUMN ── */
    .cg-copy {
        position: relative;
        z-index: 5;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 0 56px 0 60px;
        gap: 20px;
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        backdrop-filter: none !important;
    }

    .cg-tagline-sub {
        font-family: var(--font-head);
        font-weight: 700;
        font-size: 1.1rem;
        letter-spacing: 0.06em;
        color: rgba(255,255,255,0.85);
        text-transform: uppercase;
    }

    .cg-hero-title {
        font-family: var(--font-head);
        font-weight: 900;
        font-size: clamp(3.2rem, 5.5vw, 5rem);
        line-height: 1;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        color: #fff;
    }
    .cg-hero-title span { color: var(--red); }

    /* hide original slideshow text elements */
    .cg-title, .cg-kicker, .cg-price, .cg-desc { display: none !important; }

    .cg-hero-desc {
        font-size: 0.96rem;
        line-height: 1.65;
        color: rgba(255,255,255,0.78);
        max-width: 52ch;
    }

    /* Feature icons row */
    .cg-features {
        display: flex;
        gap: 36px;
        margin-top: 4px;
    }

    .cg-feature {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        text-align: center;
    }

    .cg-feature-icon {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        border: 2px solid var(--red);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: var(--red);
        background: rgba(192,0,26,0.08);
        transition: background .2s;
    }
    .cg-feature:hover .cg-feature-icon { background: rgba(192,0,26,0.20); }

    .cg-feature-label {
        font-family: var(--font-head);
        font-weight: 800;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #fff;
        line-height: 1;
    }
    .cg-feature-sub {
        font-size: 0.62rem;
        color: rgba(255,255,255,0.50);
        margin-top: -4px;
    }

    .cg-divider {
        width: 56px;
        height: 2px;
        background: var(--red);
        flex-shrink: 0;
    }

    /* CTA buttons */
    .cg-cta-area { display: flex; flex-direction: column; gap: 14px; margin-top: 4px; }

    .cg-btn-row {
        display: flex !important;
        gap: 14px;
        align-items: center;
    }

    .cg-btn {
        border: 0;
        border-radius: 8px;
        padding: 14px 28px;
        font-family: var(--font-head);
        font-weight: 800;
        font-size: 0.92rem;
        letter-spacing: 0.12em;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        transition: all 0.18s ease;
        white-space: nowrap;
        text-transform: uppercase;
    }

    .cg-btn-primary {
        background: var(--red) !important;
        color: #fff !important;
        border: 2px solid var(--red) !important;
        box-shadow: 0 6px 22px rgba(192,0,26,0.38);
    }
    .cg-btn-primary:hover { background: #e0001e !important; transform: translateY(-1px); box-shadow: 0 10px 28px rgba(192,0,26,0.50); }

    .cg-btn-outline {
        background: transparent !important;
        color: rgba(255,255,255,0.88) !important;
        border: 2px solid rgba(255,255,255,0.38) !important;
    }
    .cg-btn-outline:hover { border-color: rgba(255,255,255,0.70) !important; transform: translateY(-1px); }

    /* hide unused elements */
    .cg-cats, .cg-badges, .cg-stats { display: none !important; }

    /* ── RIGHT COLUMN ── */
    .cg-visual-col {
        position: relative;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .cg-visual {
        flex: 1;
        position: relative;
        overflow: hidden;
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        backdrop-filter: none !important;
        padding: 0 !important;
        border-radius: 0 !important;
    }

    .cg-glow { display: none; }

    .cg-product-wrap {
        width: 100%;
        height: 100%;
        background: transparent !important;
        border-radius: 0 !important;
    }

    .cg-img-main {
        position: absolute !important;
        inset: 0 !important;
        width: 100% !important;
        height: 100% !important;
        object-fit: cover !important;
        object-position: center 40% !important;
        top: auto !important;
        left: auto !important;
        transform: none !important;
        filter: brightness(0.88) saturate(1.1) !important;
        transition: opacity 0.35s ease !important;
    }

    .cg-img-next, .cg-caption, .cg-visual-tag { display: none !important; }

    /* Clock card */
    .cg-clock-card {
        position: absolute;
        bottom: 28px;
        right: 32px;
        z-index: 20;
        background: rgba(18,0,0,0.78);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 14px;
        padding: 14px 22px;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        min-width: 180px;
    }

    .cg-clock-date {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 0.76rem;
        color: rgba(255,255,255,0.65);
        margin-bottom: 4px;
    }
    .cg-clock-date i { font-size: 0.72rem; }

    .cg-clock-time {
        font-family: var(--font-head);
        font-weight: 900;
        font-size: 2.6rem;
        line-height: 1;
        color: #fff;
        letter-spacing: 0.02em;
    }
    .cg-clock-ampm {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--red);
        margin-left: 4px;
    }

    .cg-thumbs { display: none !important; }
    .cg-controls { display: none !important; }

    /* ── TRUST BAR ── */
    .cg-trust-bar {
        position: relative;
        z-index: 10;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 60px;
        background: rgba(0,0,0,0.55);
        border-top: 1px solid rgba(255,255,255,0.07);
        flex-shrink: 0;
    }

    .cg-trust-items {
        display: flex;
        align-items: center;
        gap: 40px;
    }

    .cg-trust-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.74rem;
        font-weight: 600;
        color: rgba(255,255,255,0.50);
        white-space: nowrap;
    }
    .cg-trust-item i { font-size: 0.78rem; color: rgba(255,255,255,0.35); }

    .cg-trust-copyright {
        font-size: 0.70rem;
        color: rgba(255,255,255,0.30);
        white-space: nowrap;
    }

    .cg-nav-dots { display: none; }

    /* image animation helpers */
    .cg-img-out { opacity: 0 !important; }
    .cg-img-in  { opacity: 1 !important; }

    /* ══════════════════════════════════════════════
       VISTA ABOUT
    ══════════════════════════════════════════════ */
    #view-about {
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-dark);
        padding-top: 0;
    }

    .carousel-wrap {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 25px 50px rgba(0,0,0,0.28);
        width: 100%;
        height: calc(100vh - 60px);
        max-height: 560px;
        min-height: 260px;
        border: 1px solid rgba(255,255,255,0.10);
    }

    .carousel, .carousel-inner, .carousel-item, .carousel-item img {
        height: 100%;
        width: 100%;
        object-fit: cover;
    }

    .about-content-wrap {
        padding: 0 30px 0 44px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        height: 100%;
        overflow-y: auto;
    }

    .cg-kicker-red {
        font-family: var(--font-head);
        font-weight: 900;
        letter-spacing: 0.18em;
        font-size: 0.82rem;
        text-transform: uppercase;
        color: var(--red);
        margin-bottom: 6px;
        display: block;
    }

    .cg-title-about {
        font-family: var(--font-head);
        font-size: clamp(2.2rem, 4vw, 3.6rem);
        color: #fff;
        font-weight: 900;
        margin-bottom: 18px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .cg-desc-about {
        font-size: clamp(0.84rem, 1vw, 1rem);
        line-height: 1.65;
        color: rgba(255,255,255,0.80);
        text-align: justify;
        margin-bottom: 26px;
    }

    .cards-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
    }

    .mini-card {
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.10);
        border-radius: 16px;
        padding: 20px 14px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        backdrop-filter: blur(8px);
        transition: transform .2s, background .2s;
    }
    .mini-card:hover { transform: translateY(-4px); background: rgba(255,255,255,0.11); }
    .mini-card-icon { font-size: 1.8rem; color: var(--red); margin-bottom: 10px; }
    .mini-card h4 { font-family: var(--font-head); font-size: 1.05rem; font-weight: 800; margin-bottom: 8px; color: #fff; letter-spacing: 0.04em; }
    .mini-card p  { font-size: 0.80rem; line-height: 1.45; margin: 0; color: rgba(255,255,255,0.72); }

    /* ══════════════════════════════════════════════
       MODAL LOGIN
    ══════════════════════════════════════════════ */
    .modal-content.cg-modal {
        background: transparent !important;
        border: 1px solid rgba(255,255,255,0.18) !important;
        border-radius: 16px !important;
        overflow: hidden;
        box-shadow: 0 22px 60px rgba(0,0,0,0.50);
    }
    .modal-backdrop { background: #110000 !important; }
    .modal-backdrop.show { opacity: 0.72 !important; }

    .cg-login { display: flex; flex-wrap: wrap; }

    .cg-login-left {
        flex: 1 1 40%;
        min-height: 320px;
        position: relative;
        background: linear-gradient(135deg, var(--red-dark) 0%, var(--red-deep) 100%);
        overflow: hidden;
    }
    .cg-login-left::before {
        content: "";
        position: absolute;
        inset: 0;
        background: url('images/sigo-anim.webp') center/cover no-repeat;
        opacity: 0.14;
    }
    .cg-login-left::after {
        content: "";
        position: absolute;
        inset: 0;
        background: url('images/logo_sigo_cg2_1.png') center/contain no-repeat;
        opacity: 0.55;
    }
    .cg-social {
        position: absolute;
        left: 18px;
        bottom: 18px;
        display: flex;
        gap: 14px;
        z-index: 2;
    }
    .cg-social a { color: #fff; font-size: 1.25rem; opacity: 0.90; }

    .cg-login-right {
        flex: 1 1 55%;
        padding: 36px 34px;
        background: rgba(255,255,255,0.96);
        border-left: 1px solid rgba(0,0,0,0.06);
    }

    .cg-login-logo { width: 68px; height: 68px; display: block; margin: 0 auto 12px; }
    .cg-login-right .input-group-text { background: #0b0b0b; border: none; color: #fff; }
    .cg-login-right .form-control:focus {
        border-color: rgba(139,0,0,0.40);
        box-shadow: 0 0 0 0.2rem rgba(139,0,0,0.14) !important;
    }
    .cg-login-btn {
        background: linear-gradient(90deg, #1a0000, var(--red)) !important;
        border: none;
        color: #fff;
        font-family: var(--font-head);
        font-weight: 900;
        letter-spacing: 0.08em;
        padding: 0.72rem;
        border-radius: 10px;
        font-size: 0.96rem;
        box-shadow: 0 8px 22px rgba(0,0,0,0.20);
    }
    .cg-login-btn:hover { filter: brightness(1.08); }

    /* ══════════════════════════════════════════════
       RESPONSIVE
    ══════════════════════════════════════════════ */
    @@media (max-width: 900px) {
        html, body { overflow-y: auto !important; overflow-x: hidden !important; height: auto !important; }

        .cg-view-section {
            position: relative !important;
            height: auto !important;
            inset: auto;
            overflow: visible !important;
            opacity: 1 !important;
            transform: none !important;
        }
        .cg-view-section.active-view { display: block !important; }

        #view-home { flex-direction: column; height: auto; min-height: 100svh; overflow: visible; }
        #view-home::before { width: 100%; height: 60%; background: radial-gradient(ellipse 100% 60% at 50% 0%, rgba(140,0,16,0.85) 0%, transparent 70%); }

        .cg-topbar { padding: 14px 20px 0; }
        .cg-quote { display: none; }

        .cg-stage { display: flex; flex-direction: column; height: auto; }

        .cg-copy { padding: 28px 20px 22px; align-items: center; text-align: center; }
        .cg-hero-desc { text-align: center; }
        .cg-features { justify-content: center; flex-wrap: wrap; gap: 20px; }
        .cg-btn-row { justify-content: center; flex-wrap: wrap; }
        .cg-btn { width: 100%; justify-content: center; }

        .cg-visual-col { min-height: 280px; }
        .cg-visual { min-height: 280px; }
        .cg-clock-card { bottom: 14px; right: 14px; padding: 10px 14px; min-width: 140px; }
        .cg-clock-time { font-size: 1.9rem; }

        .cg-trust-bar { padding: 10px 20px; height: auto; flex-wrap: wrap; gap: 8px; }
        .cg-trust-items { gap: 16px; flex-wrap: wrap; }
        .cg-trust-copyright { width: 100%; text-align: center; }

        #view-about { display: block !important; padding: 14px !important; }
        .carousel-wrap { height: 52vw; max-height: 320px; margin-bottom: 20px; }
        .about-content-wrap { padding: 0 4px 16px; height: auto; }
        .cards-row { grid-template-columns: 1fr 1fr; }

        .cg-login-left { display: none; }
        .cg-login-right { flex: 1 1 100%; }
    }

    @@media (max-width: 580px) {
        .cg-hero-title { font-size: 2.8rem; }
        .cg-features { gap: 12px; }
        .cg-feature-icon { width: 44px; height: 44px; font-size: 1.1rem; }
        .cards-row { grid-template-columns: 1fr; }
    }

            /* FIX: que una vista oculta no tape los botones */
            .cg-view-section:not(.active-view) {
                display: none !important;
                pointer-events: none !important;
                z-index: 0 !important;
            }

            .cg-view-section.active-view {
                pointer-events: auto !important;
                z-index: 50 !important;
            }

            #view-home.active-view {
                display: flex !important;
            }

            #view-about.active-view {
                display: flex !important;
            }

            .cg-topbar {
                justify-content: center !important;
                padding-top: 38px !important;
            }

      

     

            .cg-quote {
                position: absolute;
                right: 48px;
                top: 34px;
            }

            .cg-logo-hero {
                position: absolute;
                top: 34px;
                left: 24%;
                transform: translateX(-50%);
                z-index: 30;
            }

                .cg-logo-hero img {
                    width: 230px;
                    height: auto;
                    object-fit: contain;
                    filter: drop-shadow(0 16px 30px rgba(0,0,0,.45));
                }

            .cg-copy {
                padding-top: 145px !important;
            }

            .modal-content.cg-modal {
                background: linear-gradient(135deg, #160000, #050505) !important;
                border: 1px solid rgba(255,255,255,.14) !important;
                border-radius: 22px !important;
                overflow: hidden;
                box-shadow: 0 28px 80px rgba(0,0,0,.65);
            }

            .cg-login-left {
                background: radial-gradient(circle at center, rgba(192,0,26,.35), transparent 55%), linear-gradient(135deg, #7a0000, #210000) !important;
            }

                .cg-login-left::after {
                    opacity: .75 !important;
                }

            .cg-login-right {
                background: radial-gradient(circle at top, rgba(192,0,26,.18), transparent 45%), linear-gradient(180deg, #120000, #050505) !important;
                color: #fff;
                padding: 42px 38px !important;
            }

            .cg-login-logo {
                width: 86px !important;
                height: 86px !important;
                filter: drop-shadow(0 12px 24px rgba(0,0,0,.45));
            }

            #loginModalLabel {
                color: #fff;
                font-family: var(--font-head);
                font-size: 2rem;
                font-weight: 900;
                letter-spacing: .04em;
            }

            .cg-login-right .input-group {
                margin-bottom: 18px !important;
            }

            .cg-login-right .input-group-text {
                background: #0b0b0b !important;
                border: 1px solid rgba(255,255,255,.12) !important;
                color: #fff !important;
                width: 52px;
                justify-content: center;
            }

            .cg-login-right .form-control {
                height: 52px;
                background: rgba(255,255,255,.08) !important;
                border: 1px solid rgba(255,255,255,.14) !important;
                color: #fff !important;
                font-weight: 600;
            }

                .cg-login-right .form-control::placeholder {
                    color: rgba(255,255,255,.45);
                }

                .cg-login-right .form-control:focus {
                    background: rgba(255,255,255,.12) !important;
                    border-color: #c0001a !important;
                    box-shadow: 0 0 0 .2rem rgba(192,0,26,.22) !important;
                }

            .cg-login-btn {
                height: 56px;
                border-radius: 14px !important;
                background: linear-gradient(90deg, #4a0000, #c0001a) !important;
                box-shadow: 0 16px 36px rgba(192,0,26,.30);
            }

            .cg-login-right p,
            .cg-login-right a {
                color: rgba(255,255,255,.72);
            }

            .cg-login-right a {
                color: #ff3348 !important;
                font-weight: 700;
            }

            @@media (max-width: 900px) {
                .cg-topbar {
                    position: relative !important;
                    padding: 12px 0 0 !important;
                    display: flex !important;
                    justify-content: center !important;
                    align-items: flex-start !important;
                }

                .cg-logo-hero {
                    position: relative !important;
                    top: auto !important;
                    left: auto !important;
                    transform: none !important;
                    width: 100% !important;
                    display: flex !important;
                    justify-content: center !important;
                    z-index: 30;
                }

                    .cg-logo-hero img {
                        width: 150px !important;
                        max-width: 45vw !important;
                        height: auto !important;
                        object-fit: contain !important;
                    }

                .cg-copy {
                    padding-top: 15px !important;
