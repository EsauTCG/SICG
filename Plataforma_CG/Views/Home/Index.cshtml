    (function () {
        const MONTHS = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];

        function tick() {
            const now    = new Date();
            const dateEl = document.getElementById('clockDate');
            const timeEl = document.getElementById('clockTime');
            const ampmEl = document.getElementById('clockAmpm');
            if (!dateEl) return;

            dateEl.textContent = `${now.getDate()} de ${MONTHS[now.getMonth()]} de ${now.getFullYear()}`;

            let h  = now.getHours();
            const min  = String(now.getMinutes()).padStart(2,'0');
            const ampm = h < 12 ? 'a. m.' : 'p. m.';
            h = h % 12 || 12;
            timeEl.textContent = `${String(h).padStart(2,'0')}:${min}`;
            ampmEl.textContent = ampm;
        }

        tick();
        setInterval(tick, 1000);
    })();

        function switchView(viewName) {
            const viewHome = document.getElementById('view-home');
            const viewAbout = document.getElementById('view-about');

            const linkHome = document.getElementById('linkHome');
            const linkAbout = document.getElementById('linkAbout');

            const entering = viewName === 'about' ? viewAbout : viewHome;
            const leaving = viewName === 'about' ? viewHome : viewAbout;

            if (!entering || !leaving) return;
            if (entering.classList.contains('active-view')) return;

            if (viewName === 'about') {
                if (linkHome) linkHome.classList.remove('active');
                if (linkAbout) linkAbout.classList.add('active');
            } else {
                if (linkAbout) linkAbout.classList.remove('active');
                if (linkHome) linkHome.classList.add('active');
            }

            leaving.classList.remove('active-view');
            leaving.style.display = 'none';

            entering.style.display = viewName === 'home' ? 'flex' : 'block';

            requestAnimationFrame(() => {
                entering.classList.add('active-view');
                window.scrollTo({ top: 0, behavior: 'instant' });
            });
        }

