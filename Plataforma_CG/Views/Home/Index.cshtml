        /* =========================================================
           LOGIN ONLINE + AUTORIZACIÓN OFFLINE POR TERMINAL
           - Con red: valida contra el servidor.
           - Si valida correctamente: guarda permiso offline local.
           - Sin red: permite entrar a Báscula solo si el usuario/contraseña
             coinciden con la última autorización offline vigente.
           ========================================================= */

        const OFFLINE_AUTH_KEY = "SIGO_OFFLINE_AUTH";
        const OFFLINE_AUTH_DIAS = 3;
        const INICIO_OFFLINE_URL = "/Home/Inicio?offline=1";

        function getTerminalIdOffline() {
            let terminal = localStorage.getItem("basculaTerminalId");

            if (!terminal) {
                terminal = "CASETA-01";
                localStorage.setItem("basculaTerminalId", terminal);
            }

            return terminal;
        }

        function normalizarUsuario(usuario) {
            return String(usuario || "").trim().toLowerCase();
        }

        async function sha256Texto(texto) {
            if (!window.crypto || !window.crypto.subtle) {
                // Fallback sencillo para navegadores viejos. No es criptográfico fuerte,
                // pero evita guardar contraseña en texto si WebCrypto no está disponible.
                let hash = 0;
                const value = String(texto || "");
                for (let i = 0; i < value.length; i++) {
                    hash = ((hash << 5) - hash) + value.charCodeAt(i);
                    hash |= 0;
                }
                return "legacy-" + String(hash);
            }

            const buffer = new TextEncoder().encode(String(texto || ""));
            const digest = await crypto.subtle.digest("SHA-256", buffer);
            return Array.from(new Uint8Array(digest))
                .map(b => b.toString(16).padStart(2, "0"))
                .join("");
        }

        async function crearHashPasswordOffline(usuario, password, terminalId) {
            const base = [
                "SIGO_OFFLINE_LOGIN",
                terminalId || getTerminalIdOffline(),
                normalizarUsuario(usuario),
                String(password || "")
            ].join("|");

            return await sha256Texto(base);
        }

        async function guardarAutorizacionOffline(usuario, password, redirectUrl) {
            const terminalId = getTerminalIdOffline();
            const expira = new Date();
            expira.setDate(expira.getDate() + OFFLINE_AUTH_DIAS);

            const auth = {
                usuario: String(usuario || "Usuario SIGO").trim(),
                usuarioKey: normalizarUsuario(usuario),
                terminalId: terminalId,
                passwordHash: await crearHashPasswordOffline(usuario, password, terminalId),
                redirectUrl: redirectUrl || INICIO_OFFLINE_URL,
                fechaAlta: new Date().toISOString(),
                expira: expira.toISOString(),
                moduloPermitido: "BASCULA_CAMIONERA",
                version: 1
            };

            localStorage.setItem(OFFLINE_AUTH_KEY, JSON.stringify(auth));
        }

        function obtenerAutorizacionOffline() {
            try {
                const raw = localStorage.getItem(OFFLINE_AUTH_KEY);
                if (!raw) return null;

                const auth = JSON.parse(raw);
                if (!auth || !auth.expira || !auth.passwordHash) return null;

                const expira = new Date(auth.expira);
                if (isNaN(expira.getTime())) return null;

                if (new Date() > expira) {
                    localStorage.removeItem(OFFLINE_AUTH_KEY);
                    return null;
                }

                return auth;
            } catch {
                return null;
            }
        }

        async function validarCredencialesOffline(usuario, password) {
            const auth = obtenerAutorizacionOffline();
            if (!auth) return null;

            const usuarioKey = normalizarUsuario(usuario);
            if (usuarioKey !== auth.usuarioKey) return null;

            const passwordHash = await crearHashPasswordOffline(usuario, password, auth.terminalId);
            if (passwordHash !== auth.passwordHash) return null;

            return auth;
        }

        function mostrarErrorLogin(msg) {
            const errorBox = document.getElementById("loginError");
            if (!errorBox) return;

            errorBox.textContent = msg || "Usuario o contraseña incorrectos.";
            errorBox.classList.remove("d-none");
        }

        function ocultarMensajesLogin() {
            const errorBox = document.getElementById("loginError");
            const offlineBox = document.getElementById("offlineAccessBox");

            if (errorBox) {
                errorBox.textContent = "";
                errorBox.classList.add("d-none");
            }

            if (offlineBox) {
                offlineBox.classList.add("d-none");
            }
        }

        function mostrarAccesoOffline(auth) {
            window.__SIGO_OFFLINE_AUTH_VALIDADA = auth || null;

            const offlineBox = document.getElementById("offlineAccessBox");
            if (offlineBox) {
                offlineBox.classList.remove("d-none");
            }
        }

function entrarSistemaOffline() {
    const auth = obtenerAutorizacionOffline();

    if (!auth) {
        mostrarErrorLogin("No existe autorización offline vigente para esta terminal. Primero inicia sesión con red.");
        return;
    }

    sessionStorage.setItem("SIGO_MODO_OFFLINE", "1");
    sessionStorage.setItem("SIGO_USUARIO_OFFLINE", auth.usuario || "Usuario offline");
    sessionStorage.setItem("SIGO_TERMINAL_OFFLINE", auth.terminalId || "CASETA-01");

    window.location.href = INICIO_OFFLINE_URL;
}

        const formEl = document.getElementById("loginForm");

        if (formEl) {
            formEl.addEventListener("submit", async function (e) {
                e.preventDefault();
                ocultarMensajesLogin();

                const form = e.target;
                const data = {
                    Usuario: form.Usuario.value,
                    Password: form.Password.value,
                    ReturnUrl: form.querySelector('input[name="ReturnUrl"]')?.value || ""
                };

                try {
                    const response = await fetch('@Url.Action("Login", "Acceso")', {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(data)
                    });

                    const res = await response.json();

                    if (res.success) {
                        await guardarAutorizacionOffline(data.Usuario, data.Password, res.redirectUrl);
                        window.location.href = res.redirectUrl;
                        return;
                    }

                    // Si el servidor respondió, respetamos su respuesta. No abrimos offline
                    // con credenciales que el servidor acaba de rechazar.
                    mostrarErrorLogin(res.message || "Usuario o contraseña incorrectos.");
                } catch (err) {
                    const auth = await validarCredencialesOffline(data.Usuario, data.Password);

                    if (auth) {
                        mostrarErrorLogin("No hay comunicación con el servidor. Puedes entrar a Báscula en modo offline.");
                        mostrarAccesoOffline(auth);
                    } else {
                        mostrarErrorLogin("No hay comunicación con el servidor y esta terminal no tiene autorización offline válida para ese usuario. Inicia sesión una vez con red.");
                    }
                }
            });
        }

        document.addEventListener("click", function (e) {
            const btn = e.target.closest("#btnEntrarOfflineBascula");
            if (!btn) return;

            entrarSistemaOffline();
        });

        if ("serviceWorker" in navigator) {
            window.addEventListener("load", function () {
                navigator.serviceWorker.register("/service-worker.js")
                    .then(function () {
                        console.log("Service Worker registrado para modo offline.");
                    })
                    .catch(function (err) {
                        console.warn("No se pudo registrar Service Worker:", err);
                    });
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            const sesionExpirada = '@(ViewBag.SesionExpirada == true ? "true" : "false")';

            if (sesionExpirada === 'true') {
                const modalEl = document.getElementById('loginModal');

                if (modalEl && window.bootstrap && bootstrap.Modal) {
                    bootstrap.Modal.getOrCreateInstance(modalEl).show();
                } else if (modalEl && window.jQuery) {
                    $('#loginModal').modal('show');
                }
            }
        });
