                                <polygon class="cut-zone" points="320,280 540,270 585,330 520,380 350,370" data-part="Lomo" data-cuts='[{"name":"Top Sirloin","img":"/images/Top Sirlon.png"},{"name":"Sirloin ","img":"/images/sirlon.png"},{"name":"Strep loin","img":"/images/strip loin.png"},{"name":"Filete","img":"/images/filete.jpg"},{"name":"Riñon","img":"/images/riñon.png"},{"name":"Arrachera a Gallo","img":"/images/arrachera gallo.png"},{"name":"T-bone","img":"/images/tbone.jpg"},{"name":"Rib-Eye","img":"/images/ribeye.jpg"},{"name":"Chuleton","img":"/images/Chuleton.png"},{"name":"Costilla Rib","img":"/images/Costilla Cargada.jpg"},{"name":"Falda","img":"/images/Falda.jpg"}]'></polygon>
