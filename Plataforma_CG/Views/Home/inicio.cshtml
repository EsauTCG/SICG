        #layoutManualModal .manual-overlay.show { display: block !important; }
        #layoutManualModal input, #layoutManualModal select, #layoutManualModal textarea, #layoutManualModal button { position: relative !important; transform: none !important; top: auto !important; left: auto !important; right: auto !important; bottom: auto !important; }
