        #layoutManualModal .modal-footer { display: none !important; }
        #layoutManualModal .manual-container { position: relative !important; display: flex !important; width: 100% !important; height: 100% !important; background: #f8f9fa !important; margin: 0 !important; padding: 0 !important; }
        #layoutManualModal .manual-sidebar { position: relative !important; width: 260px !important; height: 100% !important; background: linear-gradient(180deg, #8B0000 0%, #a50000 100%) !important; color: white !important; overflow-y: auto !important; overflow-x: hidden !important; flex-shrink: 0 !important; box-shadow: 2px 0 10px rgba(0,0,0,0.1) !important; margin: 0 !important; padding: 0 !important; }
        #layoutManualModal .manual-sidebar-header { position: relative !important; padding: 1.5rem 1rem !important; margin: 0 !important; border-bottom: 1px solid rgba(255,255,255,0.2) !important; background: rgba(0,0,0,0.1) !important; }
        #layoutManualModal .manual-sidebar-header h6 { margin: 0 !important; padding: 0 !important; font-weight: 700 !important; font-size: 0.95rem !important; text-transform: uppercase !important; letter-spacing: 0.5px !important; color: white !important; }
        #layoutManualModal .manual-toc { position: relative !important; padding: 1rem 0.5rem !important; margin: 0 !important; }
