                                <polygon class="cut-zone" points="560,190 650,151 720,220 690,280 585,265" data-part="Piña" data-cuts='[{"name":"Chambarete","img":"/images/Chamberete.png"},{"name":"Pulpa Blanca","img":"/images/Pulpa Blanca.jpeg"},{"name":"Pulpa Bola","img":"/images/Pulpa Bola.jpg"},{"name":"Pulpa Negra","img":"/images/Pulpa Negra.jpeg"},{"name":"Cola","img":"/images/Cola.png"}]'></polygon>
                                <polygon class="cut-zone" data-part="Cuarto" points="540,330 740,310 820,380 760,520 560,540 500,450" data-cuts='[{"name":"Pecho","img":"/images/Pecho.png"},{"name":"Short Rib","img":"/images/short-rib.png"},{"name":"Cuña o Juil","img":"/images/Cuña.jpeg"},{"name":"Giba","img":"/images/giba.png"},{"name":"Tapa de pescuezo","img":"/images/Tapapescue.png"},{"name":"Paleta","img":"/images/Paleta.jpeg"},{"name":"Diezmillo","img":"/images/Diezmillo.jpg"},{"name":"Pescuezo","img":"/images/Pescuezo.jpg"}]'></polygon>
