        #layoutManualModal.modal.show { display: block !important; }
        #layoutManualModal .modal-dialog { position: relative !important; width: 95vw !important; max-width: 95vw !important; height: 90vh !important; max-height: 90vh !important; margin: 2.5vh auto !important; padding: 0 !important; pointer-events: none !important; transform: none !important; top: auto !important; left: auto !important; right: auto !important; bottom: auto !important; border: none !important; background: transparent !important; border-radius: 0.75rem !important; box-shadow: none !important; }
