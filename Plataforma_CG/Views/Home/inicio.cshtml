    <!-- Modal Reporte -->
    <div class="modal fade" id="reporteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content shadow" style="overflow:hidden;">
                <div class="modal-header" style="background:var(--brand);">
                    <h5 class="modal-title text-white"><i class="fa-solid fa-headset me-2"></i> Solicitud Sistemas</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body p-0" style="height: 85vh;">
                    <iframe src="https://forms.monday.com/forms/embed/7e2f46f5a3bb77bd42b6b28ee3a8317b?r=use1"
                            style="width: 100%; height: 100%; border: 0;" title="Formulario de Solicitud"></iframe>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/fonts/fonts.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.js"></script>
    <script src="~/js/manual.js" asp-append-version="true"></script>

    <script>

        function isMobile() {
            return window.matchMedia("(max-width: 768px)").matches;
        }

        // ===== SIDEBAR MÓVIL =====
        const sidebar = document.getElementById('sidebar-dinamico');
        const backdrop = document.getElementById('sidebarBackdrop');

        function openMobileSidebar() {
            sidebar.classList.add('open');
            backdrop.style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        function closeMobileSidebar() {
            sidebar.classList.remove('open');
            backdrop.style.display = 'none';
            document.body.style.overflow = '';
        }

        backdrop && backdrop.addEventListener('click', closeMobileSidebar);
        window.addEventListener('resize', () => { if (!isMobile()) closeMobileSidebar(); });

        // ===== RELOJ =====
        (function initLiveClock() {
            const elTime = document.getElementById('clock-time');
            const elDate = document.getElementById('clock-date');
            if (!elTime || !elDate) return;

            function tick() {
                const now = new Date();
                elTime.textContent = new Intl.DateTimeFormat('es-MX', { hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:true, timeZone:'America/Mexico_City' }).format(now);
                elDate.textContent = new Intl.DateTimeFormat('es-MX', { weekday:'short', year:'numeric', month:'short', day:'2-digit', timeZone:'America/Mexico_City' }).format(now);
            }

            tick();
            setInterval(tick, 1000);
        })();

        // ===== SALUDO DINÁMICO =====
        (function initDynamicGreeting() {
            const greetingEl = document.getElementById('dynamic-greeting');
            const messageEl  = document.getElementById('dynamic-message');
            if (!greetingEl || !messageEl) return;

            const hora = new Date().getHours();
            const saludo = hora >= 5 && hora < 12 ? 'Buenos días' : hora >= 12 && hora < 19 ? 'Buenas tardes' : 'Buenas noches';

            const msgs = hora >= 5 && hora < 12
                ? ['¡Que tengas un excelente día!','¡Mucho éxito hoy!','¡Listo para conquistar el día!','¡A darle con todo!']
                : hora >= 12 && hora < 19
                ? ['¡Sigue así!','¡Vas muy bien!','¡Ánimo con la tarde!','¡A terminar fuerte!']
                : ['¡Buen trabajo hoy!','¡A descansar!','¡Casi terminas!','¡Gran esfuerzo!'];

            greetingEl.textContent = saludo;
            messageEl.textContent  = msgs[Math.floor(Math.random() * msgs.length)];
        })();

        // ===== SIDEBAR DINÁMICO =====
        // Grupos de sección para poner etiquetas separadoras
        const SECTION_ORDER = [
        "Principal",
        "Operaciones",
        "Almacén",
        "Gestión",
        "Calidad",
        "Auditoria y Procesos",
        "Sistema"
        ];

        // Mapeo icono → icono dentro de sb-icon-wrap
        const ICON_MAP = {
    'Mercados':        'fas fa-chart-line',
    'Comercial':       'fas fa-handshake',
    'Autorizaciones':  'fas fa-lock',
    'Operaciones':     'fas fa-cogs',
    'Logística':       'fas fa-truck-fast',
    'Logistica':       'fas fa-truck-fast',
    'Carnes G':        'fas fa-drumstick-bite',
    'Administración':  'fas fa-folder-open',
    'Administracion':  'fas fa-folder-open',
    'Reportes':        'fas fa-chart-bar',
    "KPI'S":           'fas fa-chart-pie',
    'KPI':             'fas fa-chart-pie',
    'Configuración':   'fas fa-sliders',
    'Configuracion':   'fas fa-sliders',
    'SIGO Chat':       'fas fa-comments',
    'SIGO Core':       'fas fa-layer-group'
};

        // Badges estáticos de demostración (puedes hacerlos dinámicos desde el backend)
        const BADGE_MAP = {
            'Autorizaciones': { text: '!', cls: '' },
            'SIGO Chat':      { text: 'Chat', cls: '' },
            'Carnes G':       { text: 'Nuevo', cls: 'sb-badge-new' },
        };

        function normalizeText(text) {
        return (text || "")
        .toString()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .toLowerCase()
        .trim();
        }

        function getIconForMod(nombre) {
        const cleanNombre = normalizeText(nombre);

        for (const [key, val] of Object.entries(ICON_MAP)) {
        if (cleanNombre.includes(normalizeText(key))) {
        return val;
        }
        }

        return 'fas fa-folder';
        }

        const SECTION_ALIAS = {
        "mercados": "Principal",
        "area comercial": "Principal",
        "área comercial": "Principal",
        "comercial": "Principal",
        "autorizaciones": "Principal",

        "operaciones": "Operaciones",
        "logistica": "Operaciones",
        "logística": "Operaciones",
        "procesos cg": "Operaciones",
        "integraciones": "Operaciones",

        "almacen": "Almacén",
        "almacén": "Almacén",
        "almacenes": "Almacén",
        "inventario": "Almacén",
        "inventarios": "Almacén",

        "administracion": "Gestión",
        "administración": "Gestión",
        "reporteadores": "Gestión",
        "reportes": "Gestión",
        "kpi": "Gestión",
        "kpi's": "Gestión",

        "calidad": "Calidad",

        "configuracion": "Sistema",
        "configuración": "Sistema",
        "chat": "Sistema",
        "sigo chat": "Sistema",
        "sistema": "Sistema",
        "sistemas": "Sistema",
        "gestion de sistemas": "Sistema",
        "gestión de sistemas": "Sistema"
        };

        function getSectionForMod(mod) {
        const raw = mod.categoriaNombre || mod.categoria || "Principal";
        const normalized = normalizeText(raw);

        return SECTION_ALIAS[normalized] || raw.trim();
        }
        document.addEventListener("DOMContentLoaded", async () => {
            try {
                const res = await fetch("/Sidebar/CargarModulos", {
                    method: "GET",
                    headers: { "X-Requested-With": "XMLHttpRequest", "Accept": "application/json" },
                    cache: "no-store"
                });

                if (res.redirected) { window.location.href = "/Home/Inicio"; return; }
                if (!res.ok) {
                    if (res.status === 401 || res.status === 403) window.location.href = "/Home/Inicio";
                    return;
                }

                const ct = (res.headers.get("content-type") || "").toLowerCase();
                if (!ct.includes("application/json")) { window.location.href = "/Home/Inicio"; return; }

                const modulos = await res.json();
                if (!Array.isArray(modulos)) return;

                const contenedor = document.getElementById("menu-contenedor");
                if (!contenedor) return;
               


                function crearItemModulo(mod) {
    const modItem = document.createElement("div");
    modItem.classList.add("menu-item");

    const iconClass = mod.icono || getIconForMod(mod.nombre || "");
    const badgeInfo = BADGE_MAP[mod.nombre] || null;

    const modLink = document.createElement("a");
    modLink.classList.add("dropdown-btn");
    modLink.href = mod.url || "#";

    const iconWrap = document.createElement("div");
    iconWrap.className = "sb-icon-wrap";
    iconWrap.innerHTML = `<i class="${iconClass}"></i>`;
    modLink.appendChild(iconWrap);

    const labelSpan = document.createElement("span");
    labelSpan.className = "sb-item-label";
    labelSpan.textContent = mod.nombre || "";
    modLink.appendChild(labelSpan);

    if (badgeInfo) {
        const badge = document.createElement("span");
        badge.className = "sb-badge " + (badgeInfo.cls || "");
        badge.textContent = badgeInfo.text;
        modLink.appendChild(badge);
    }

    const subModulos = mod.subModulos || mod.submodulos || [];

    if (Array.isArray(subModulos) && subModulos.length > 0) {
        modLink.href = "#";

        const arrow = document.createElement("i");
        arrow.classList.add("fas", "fa-chevron-down", "arrow");
        modLink.appendChild(arrow);

        const subContainer = document.createElement("div");
        subContainer.classList.add("dropdown-container");

        subModulos.forEach(sub => {
            const subLink = document.createElement("a");
            subLink.href = sub.url || "#";

            const subIcon = sub.icono || "fas fa-caret-right";
            subLink.innerHTML = `<i class="${subIcon} me-1"></i>${sub.nombre || ""}`;

            subLink.addEventListener("click", () => {
                if (isMobile()) closeMobileSidebar();
            });

            subContainer.appendChild(subLink);
        });

        modItem.appendChild(modLink);
        modItem.appendChild(subContainer);
    } else {
        modLink.addEventListener("click", () => {
            if (isMobile()) closeMobileSidebar();
        });

        modItem.appendChild(modLink);
    }

    return modItem;
}

const grouped = {};

modulos.forEach(mod => {
    const section = getSectionForMod(mod);

    if (!grouped[section]) {
        grouped[section] = [];
    }

    grouped[section].push(mod);
});

const sectionNames = [
    ...SECTION_ORDER.filter(section => grouped[section]?.length),
    ...Object.keys(grouped)
        .filter(section => !SECTION_ORDER.includes(section))
        .sort((a, b) => a.localeCompare(b))
];

sectionNames.forEach((section, index) => {
    const items = grouped[section];

    if (index > 0) {
        const div = document.createElement("div");
        div.className = "sb-divider";
        contenedor.appendChild(div);
    }

    const lbl = document.createElement("div");
    lbl.className = "sb-section-label";
    lbl.textContent = section.toUpperCase();
    contenedor.appendChild(lbl);

    items.forEach(mod => {
        contenedor.appendChild(crearItemModulo(mod));
    });
});

                // Activar dropdowns
                document.querySelectorAll(".menu-item > .dropdown-btn").forEach(btn => {
                    btn.addEventListener("click", e => {
                        const item = btn.parentElement;
                        const hasSub = item.querySelector(".dropdown-container");
                        if (hasSub) {
                            e.preventDefault();
                            document.querySelectorAll(".menu-item").forEach(mi => { if (mi !== item) mi.classList.remove("open"); });
                            item.classList.toggle("open");
                        }
                    });
                });

                // Búsqueda en tiempo real
                const searchInput = document.getElementById("sbSearchInput");
                if (searchInput) {
                    searchInput.addEventListener("input", function () {
                        const q = this.value.trim().toLowerCase();
                        document.querySelectorAll(".menu-item").forEach(item => {
                            const label = item.querySelector(".sb-item-label");
                            const text = label ? label.textContent.toLowerCase() : "";
                            const subTexts = Array.from(item.querySelectorAll(".dropdown-container a"))
                                .map(a => a.textContent.toLowerCase()).join(" ");
                            const match = !q || text.includes(q) || subTexts.includes(q);
                            item.style.display = match ? "" : "none";
                            if (q && subTexts.includes(q)) item.classList.add("open");
                            else if (!q) item.classList.remove("open");
                        });
                        // Ocultar etiquetas de sección huérfanas
                        document.querySelectorAll(".sb-section-label").forEach(lbl => {
                            let next = lbl.nextElementSibling;
                            let hasVisible = false;
                            while (next && !next.classList.contains("sb-section-label") && !next.classList.contains("sb-divider")) {
                                if (next.classList.contains("menu-item") && next.style.display !== "none") hasVisible = true;
                                next = next.nextElementSibling;
                            }
                            lbl.style.display = hasVisible ? "" : "none";
                        });
                        document.querySelectorAll(".sb-divider").forEach(d => {
                            d.style.display = "";
                        });
                    });
                }

            } catch (e) {
                console.error("Error cargando el sidebar dinámico:", e);
            }
        });

        // ===== AUTO-FIT SVG =====
        (function fitCutmapToViewport() {
            const svg = document.getElementById("cutmapSvg");
            const contentEl = document.getElementById("content");
            const panel = document.getElementById("cutPanel");
            if (!svg || !contentEl || !panel) return;

            function resize() {
                if (isMobile()) { panel.style.height = ""; svg.style.height = ""; return; }
                const appbarH = parseInt(getComputedStyle(document.documentElement).getPropertyValue("--appbar-h")) || 72;
                const viewportH = window.innerHeight;
                const contentStyles = getComputedStyle(contentEl);
                const padTop = parseFloat(contentStyles.paddingTop) || 0;
                const padBottom = parseFloat(contentStyles.paddingBottom) || 0;
                const available = (viewportH - appbarH) - (padTop + padBottom) - 10;
                panel.style.height = Math.max(320, available) + "px";
                const header = panel.querySelector(".cutmap-header");
                const headerH = header ? header.getBoundingClientRect().height : 0;
                const svgH = Math.max(300, (panel.getBoundingClientRect().height - headerH - 14));
                svg.style.height = svgH + "px";
            }

            window.addEventListener("resize", resize);
            resize();
        })();

        // ===== MODAL CORTES DOBLE CLICK =====
        (function initCutMapSvgModal() {
            const svg = document.getElementById("cutmapSvg");
            if (!svg) return;
            const modalEl = document.getElementById("cutModal");
            const modalTitle = document.getElementById("cutModalTitle");
            const grid = document.getElementById("cutModalGrid");
            const bsModal = modalEl ? new bootstrap.Modal(modalEl) : null;
            function safeParseCuts(raw) { try { return JSON.parse(raw || "[]"); } catch { return []; } }
            function renderCuts(cuts) {
                grid.innerHTML = "";
                if (!cuts.length) { grid.innerHTML = `<div class="col-12"><div class="alert alert-light border mb-0">No hay cortes configurados.</div></div>`; return; }
                cuts.forEach(c => {
                    const col = document.createElement("div");
                    col.className = "col-12 col-sm-6 col-lg-4";
                    col.innerHTML = `<div class="card h-100 shadow-sm"><div class="ratio ratio-4x3 bg-light">${c.img ? `<img src="${c.img}" class="card-img-top" style="object-fit:cover;" alt="${c.name||''}" onerror="this.onerror=null;this.src='/images/cortes/no-image.png';">` : `<div class="d-flex align-items-center justify-content-center text-muted small">Sin imagen</div>`}</div><div class="card-body py-2"><div class="fw-bold">${c.name||''}</div></div></div>`;
                    grid.appendChild(col);
                });
            }
            svg.querySelectorAll(".cut-zone").forEach(zone => {
                zone.addEventListener("dblclick", () => { modalTitle.textContent = zone.dataset.part || "Cortes"; renderCuts(safeParseCuts(zone.dataset.cuts)); bsModal?.show(); });
            });
        })();

        // ===== HOVER CARD CORTES =====
        (function initCutMapHoverCard() {
            const stage = document.getElementById("cutmapStage");
            const svg = document.getElementById("cutmapSvg");
            const card = document.getElementById("cutHoverCard");
            const title = document.getElementById("cutHoverTitle");
            const grid = document.getElementById("cutHoverGrid");
            if (!stage || !svg || !card || !title || !grid) return;
            const isCoarse = window.matchMedia("(pointer: coarse)").matches;
            let pinned = false;
            function safeParseCuts(raw) { try { return JSON.parse(raw || "[]"); } catch { return []; } }
            function renderCuts(cuts) {
                grid.innerHTML = "";
                const list = (cuts || []).slice(0, 6);
                if (!list.length) { grid.innerHTML = `<div class="text-muted small">No hay cortes configurados.</div>`; return; }
                list.forEach(c => {
                    const div = document.createElement("div");
                    div.className = "cut-hover-item";
                    div.innerHTML = `${c.img ? `<img src="${c.img}" alt="${c.name||''}" onerror="this.onerror=null;this.src='/images/cortes/no-image.png';">` : `<div style="height:82px;display:flex;align-items:center;justify-content:center;font-size:.75rem;color:#64748b;">Sin imagen</div>`}<div class="name">${c.name||''}</div>`;
                    grid.appendChild(div);
                });
            }
            function placeCard(clientX, clientY) {
                const rect = stage.getBoundingClientRect();
                let x = clientX - rect.left + 14;
                let y = clientY - rect.top + 14;
                card.classList.add("show"); card.setAttribute("aria-hidden","false");
                const cr = card.getBoundingClientRect();
                if (x > rect.width - cr.width - 10) x = Math.max(10, rect.width - cr.width - 10);
                if (y > rect.height - cr.height - 10) y = Math.max(10, rect.height - cr.height - 10);
                card.style.left = x + "px"; card.style.top = y + "px";
            }
            function showForZone(zone, evt) {
                title.textContent = zone.dataset.part || "Cortes";
                renderCuts(safeParseCuts(zone.dataset.cuts));
                if (evt && evt.clientX) placeCard(evt.clientX, evt.clientY);
                else { const r = stage.getBoundingClientRect(); placeCard(r.left + r.width * .5, r.top + r.height * .35); }
            }
            function hideCard(force = false) { if (pinned && !force) return; card.classList.remove("show"); card.setAttribute("aria-hidden","true"); }
            svg.querySelectorAll(".cut-zone").forEach(zone => {
                zone.addEventListener("pointerenter", e => { if (!isCoarse && !pinned) showForZone(zone, e); });
                zone.addEventListener("pointermove", e => { if (!isCoarse && !pinned && card.classList.contains("show")) placeCard(e.clientX, e.clientY); });
                zone.addEventListener("pointerleave", () => { if (!isCoarse) hideCard(); });
                zone.addEventListener("click", e => { if (!isCoarse) return; e.preventDefault(); pinned = true; showForZone(zone, e); });
            });
            document.addEventListener("click", e => { if (!card.classList.contains("show")) return; if (stage.contains(e.target) && e.target.closest(".cut-zone")) return; if (card.contains(e.target)) return; pinned = false; hideCard(true); });
            document.addEventListener("keydown", e => { if (e.key === "Escape") { pinned = false; hideCard(true); } });
        })();

        // ===== CHAT INTERNO =====
        (function initInternalChat() {
            const fab = document.getElementById("chat-fab");
            const panel = document.getElementById("chat-panel");
            const closeBtn = document.getElementById("chat-close-btn");
            const areaSelect = document.getElementById("chat-area");
            const areaLabel = document.getElementById("chat-area-label");
            const messages = document.getElementById("chat-messages");
            const txt = document.getElementById("chat-text");
            const btnSend = document.getElementById("chat-send");
            if (!fab || !panel) return;
            let currentConversationId = null, pollTimer = null, currentAreaName = "";
            function togglePanel(show) { show ? panel.classList.remove("d-none") : panel.classList.add("d-none"); }
            fab.addEventListener("click", () => togglePanel(panel.classList.contains("d-none")));
            closeBtn.addEventListener("click", () => togglePanel(false));
            async function cargarAreas() {
                try {
                    const res = await fetch("/Chat/Areas");
                    if (!res.ok) throw new Error();
                    const data = await res.json();
                    areaSelect.innerHTML = `<option value="">-- Selecciona área --</option>`;
                    data.forEach(a => { const opt = document.createElement("option"); opt.value = a.idArea; opt.textContent = a.nombre; areaSelect.appendChild(opt); });
                } catch { areaSelect.innerHTML = `<option value="">(Error al cargar áreas)</option>`; }
            }
            cargarAreas();
            areaSelect.addEventListener("change", async () => {
                if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
                currentConversationId = null; messages.innerHTML = "";
                const val = areaSelect.value;
                if (!val) { areaLabel.textContent = "Selecciona un área para comenzar"; txt.value = ""; txt.disabled = true; btnSend.disabled = true; messages.innerHTML = `<div class="text-muted small text-center mt-2">Selecciona un área para iniciar.</div>`; return; }
                currentAreaName = areaSelect.options[areaSelect.selectedIndex].text;
                try {
                    const res = await fetch("/Chat/NuevaConversacion", { method:"POST", headers:{"Content-Type":"application/json"}, body: JSON.stringify({ idArea: parseInt(val,10) }) });
                    const data = await res.json();
                    if (!res.ok || !data.ok) throw new Error(data.mensaje || "Error");
                    currentConversationId = data.idConversacion; areaLabel.textContent = `Conversando con: ${currentAreaName}`; txt.disabled = false; btnSend.disabled = false;
                    await cargarMensajes(); pollTimer = setInterval(cargarMensajes, 5000);
                } catch (e) { alert(e.message || "Error"); areaSelect.value = ""; areaLabel.textContent = "Selecciona un área"; txt.disabled = true; btnSend.disabled = true; }
            });
            function renderMensajes(lista) {
                messages.innerHTML = "";
                if (!lista || !lista.length) { messages.innerHTML = `<div class="text-muted small text-center mt-2">No hay mensajes aún 👋</div>`; return; }
                lista.forEach(m => { const w = document.createElement("div"); w.classList.add("chat-msg", m.esMio ? "me" : "other"); const b = document.createElement("div"); b.classList.add("bubble"); const h = new Date(m.fecha).toLocaleTimeString("es-MX",{hour:"2-digit",minute:"2-digit"}); b.innerHTML = `<div>${m.texto}</div><span class="meta">${m.esMio?"Tú":"Área "+currentAreaName} · ${h}</span>`; w.appendChild(b); messages.appendChild(w); });
                messages.scrollTop = messages.scrollHeight;
            }
            async function cargarMensajes() {
                if (!currentConversationId) return;
                try { const res = await fetch(`/Chat/Mensajes/${currentConversationId}`); if (!res.ok) throw new Error(); const data = await res.json(); if (!data.ok) throw new Error(); renderMensajes(data.mensajes); } catch {}
            }
            btnSend.addEventListener("click", async () => {
                if (!currentConversationId) return; const raw = txt.value.trim(); if (!raw) return;
                try { const res = await fetch("/Chat/Enviar",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({idConversacion:currentConversationId,texto:raw})}); const data = await res.json(); if (!res.ok || !data.ok) throw new Error(data.mensaje||"Error"); txt.value=""; txt.focus(); await cargarMensajes(); } catch(e) { alert(e.message||"No se pudo enviar."); }
            });
            txt.addEventListener("keydown", e => { if (e.key==="Enter" && !e.shiftKey) { e.preventDefault(); btnSend.click(); } });
        })();

        // ===== CARRUSEL DINÁMICO =====
        document.addEventListener("DOMContentLoaded", async () => {
            const track = document.getElementById("carouselTrack");
            const dotsContainer = document.querySelector(".carousel-dots");
            if (!track || !dotsContainer) return;
            function renderFallback() { track.innerHTML = ""; dotsContainer.innerHTML = ""; const slide = document.createElement("div"); slide.className = "carousel-slide"; slide.innerHTML = `<img src="/images/default-banner.jpg" alt="Banner">`; track.appendChild(slide); initCarousel(); }
            try {
                const res = await fetch("/Home/ObtenerCarouselInicio",{method:"GET",headers:{"X-Requested-With":"XMLHttpRequest","Accept":"application/json"},cache:"no-store"});
                if (res.redirected || !res.ok) { renderFallback(); return; }
                const ct = (res.headers.get("content-type")||"").toLowerCase();
                if (!ct.includes("application/json")) { renderFallback(); return; }
                const banners = await res.json();
                const lista = Array.isArray(banners) ? banners : [];
                track.innerHTML = ""; dotsContainer.innerHTML = "";
                if (!lista.length) lista.push({ imagen: "/images/default-banner.jpg" });
                lista.forEach((b,i) => { const slide = document.createElement("div"); slide.className="carousel-slide"; slide.innerHTML=`<img src="${b&&b.imagen?b.imagen:'/images/default-banner.jpg'}" alt="Banner ${i+1}" onerror="this.onerror=null;this.src='/images/default-banner.jpg';">`; track.appendChild(slide); });
                initCarousel();
            } catch { renderFallback(); }
        });

        function initCarousel() {
            const track = document.querySelector('.carousel-track');
            const slides = Array.from(track.children);
            const nextBtn = document.querySelector('.carousel-btn.next');
            const prevBtn = document.querySelector('.carousel-btn.prev');
            const dotsContainer = document.querySelector('.carousel-dots');
            if (!slides.length) return;
            let index = 0, interval;
            dotsContainer.innerHTML = "";
            slides.forEach((_,i) => { const dot = document.createElement('button'); if (i===0) dot.classList.add('active'); dot.addEventListener('click',()=>{index=i;update();resetAuto();}); dotsContainer.appendChild(dot); });
            const dots = Array.from(dotsContainer.children);
            function update() { track.style.transform=`translateX(-${index*100}%)`; dots.forEach(d=>d.classList.remove('active')); dots[index].classList.add('active'); }
            function next() { index=(index+1)%slides.length; update(); }
            function prev() { index=(index-1+slides.length)%slides.length; update(); }
            function startAuto() { interval=setInterval(next,4000); }
            function resetAuto() { clearInterval(interval); startAuto(); }
            nextBtn.addEventListener('click',()=>{next();resetAuto();});
            prevBtn.addEventListener('click',()=>{prev();resetAuto();});
            let startX=0;
            track.addEventListener('touchstart',e=>startX=e.touches[0].clientX);
            track.addEventListener('touchend',e=>{const endX=e.changedTouches[0].clientX;if(startX-endX>50)next();if(endX-startX>50)prev();resetAuto();});
            startAuto();
        }

    </script>

</body>
</html>
