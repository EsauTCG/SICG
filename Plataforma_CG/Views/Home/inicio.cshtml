    <!-- Modal Acerca de -->
    <div class="modal fade" id="aboutModal" tabindex="-1" aria-labelledby="aboutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow">
                <div class="modal-header" style="background:var(--brand);">
                    <h5 class="modal-title text-white" id="aboutModalLabel"><i class="fa-solid fa-circle-info me-2"></i> Acerca de SIGO</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <h6 class="mb-1">SIGO — Sistema Integral de Gestión Operativa</h6>
                    <p>Plataforma interna para visualizar, controlar y autorizar procesos clave de la organización: mercados, área comercial, administración, operaciones y autorizaciones. Su objetivo es estandarizar la información y agilizar la toma de decisiones.</p>
                    <hr>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <h6>Desarrollador</h6>
                            <ul class="list-unstyled small mb-0">
                                <li><i class="fa-regular fa-id-badge me-1"></i><strong>Nombre:</strong> Sistemas Carnes G</li>
                                <li><i class="fa-regular fa-envelope me-1"></i><strong>Correo:</strong> sistemascg@carnesg.net</li>
                                <li><i class="fa-solid fa-gear me-1"></i><strong>Versión:</strong> 1.1.0</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h6>Tecnologías</h6>
                            <ul class="list-unstyled small mb-0">
                                <li>ASP.NET Core MVC</li>
                                <li>Bootstrap 5 · Font Awesome · Bootstrap Icons</li>
                                <li>jQuery / JavaScript</li>
                                <li>SQL Server</li>
                            </ul>
                        </div>
                    </div>
                    <div class="alert alert-light border mt-3 mb-0 small">© 2026 Carnes G — Todos los derechos reservados.</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Cortes -->
    <div class="modal fade" id="cutModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content shadow">
                <div class="modal-header" style="background:var(--brand);">
                    <h5 class="modal-title text-white" id="cutModalTitle">Cortes</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <div id="cutModalGrid" class="row g-3"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Chat FAB -->
    <button id="chat-fab" class="chat-fab" type="button" title="Abrir chat interno">
        <i class="fas fa-comments"></i>
    </button>

    <div id="chat-panel" class="chat-panel d-none">
        <div class="chat-panel-header">
            <i class="fas fa-headset"></i>
            <div class="chat-title">
                Chat interno
                <small id="chat-area-label">Selecciona un área para comenzar</small>
            </div>
            <button type="button" id="chat-close-btn"><i class="fas fa-times"></i></button>
        </div>
        <div class="chat-panel-body">
            <div class="chat-area-select">
                <label for="chat-area">Área / responsable</label>
                <select id="chat-area" class="form-select form-select-sm">
                    <option value=""> Selecciona área </option>
                    <option value="presupuestos">Presupuestos</option>
                    <option value="precios">Precios</option>
                    <option value="logistica">Logística</option>
                </select>
            </div>
            <div class="chat-hint">Este chat enviará los mensajes sólo al área seleccionada.</div>
        </div>
        <div id="chat-messages" class="chat-messages">
            <div class="text-muted small text-center mt-2">Selecciona un área para iniciar la conversación.</div>
        </div>
        <div class="chat-input">
            <textarea id="chat-text" rows="1" placeholder="Escribe un mensaje..." disabled></textarea>
            <button id="chat-send" class="btn btn-primary btn-sm" disabled>
                <i class="fas fa-paper-plane"></i>
            </button>
