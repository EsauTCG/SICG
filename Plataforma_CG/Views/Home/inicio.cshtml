@using Microsoft.EntityFrameworkCore;

@{
    Layout = null;
}

@inject Plataforma_CG.Data.AppDbContextUsuarios _db

@{
    var perfilId = int.Parse(User.Claims.FirstOrDefault(c => c.Type == "PerfilId")?.Value ?? "0");
    var vistasPermitidas = _db.Permisos
        .Include(p => p.Vista)
        .Where(p => p.PerfilId == perfilId)
        .Select(p => p.Vista.Nombre)
        .ToList();
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>SIGO | Sistema Integral De Gestión Operativa</title>
    <link rel="icon" type="image/png" href="~/images/ico_sigo.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/fonts/fonts.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/fonts/bootstrap-icons.css" />
    @* <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" /> *@

    <style>

        @@font-face {
            font-family: "SAP72";
            src: url("/fonts/sap/72-Regular-full.woff2") format("woff2");
            font-weight: 200;
            font-style: normal;
            font-display: swap;
        }

        :root {
            --brand: linear-gradient(90deg,#8B0000 0%,#5a0000 50%,#1a0000 100%);
            --brand-solid: #8B0000;
            --bg: #f4f6f8;
            --brand-hover: rgba(255,255,255,.15);
            --text-on-brand: #fff;
            --line: #e3e7ee;
            --panel: #fff;
            --radius: 8px;
            --shadow: 0 12px 24px rgba(16,24,40,.08);
            --shadow-sm: 0 6px 18px rgba(16,24,40,.06);
            --appbar-h: 72px;
            --page-padding: 18px;
         --sidebar-width: clamp(220px, 17vw, 260px);
--sidebar-font-size: clamp(11px, 0.78vw, 12.5px);
--sidebar-icon-size: clamp(12px, 0.85vw, 14px);
--sidebar-item-padding-y: clamp(6px, 0.5vw, 8px);
--sidebar-item-padding-x: clamp(9px, 0.75vw, 12px);
--sidebar-gap: 7px;
            --brand-logo-h: 40px;
            --brand-logo-maxw: 170px;
        }

        * { box-sizing: border-box; }

        html, body {
            height: 100%;
            width: 100%;
            overflow-x: hidden;
        }

        body {
            margin: 0;
            font-family: "SAP72", Inter, system-ui, "Segoe UI", Roboto, Arial, sans-serif;
            background: var(--bg);
            color: #1f2a35;
        }

        /* ===== APP BAR ===== */
        .appbar {
            position: fixed;
            inset: 0 0 auto 0;
            height: var(--appbar-h);
            z-index: 110;
            background: var(--brand);
            color: #fff;
            display: flex;
            align-items: center;
            gap: .8rem;
            padding: 0 18px;
            box-shadow: 0 2px 0 rgba(0,0,0,.05);
        }

        .appbar .tools {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: .6rem;
        }

        #mobileMenuBtn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            border-radius: 6px;
            border: 1px solid rgba(255,255,255,.4);
            background: rgba(255,255,255,.15);
            color: #fff;
        }

        .brand-link {
            display: flex;
            align-items: center;
            color: #fff;
            text-decoration: none;
            height: 100%;
            flex-shrink: 0;
            margin-left: 23px;
        }

        .logo-navbar {
            height: var(--brand-logo-h);
            width: auto;
            max-width: var(--brand-logo-maxw);
            object-fit: contain;
            display: block;
        }

        .clock-top {
            line-height: 1.05;
            text-align: right;
            white-space: nowrap;
            display: none;
            flex-direction: column;
        }

        .clock-top #clock-time { font-weight: 700; letter-spacing: .3px; }
        .clock-top #clock-date { font-size: .8rem; opacity: .85; }

        @@media (min-width:576px) { .clock-top { display: flex; } }

        .vr-light {
            width: 1px;
            height: 22px;
            background: rgba(255,255,255,.35);
            display: none;
        }

        @@media (min-width:576px) { .vr-light { display: block; } }

        .btn-about.btn {
            --bs-btn-color: #fff;
            --bs-btn-border-color: rgba(255,255,255,.45);
            --bs-btn-hover-color: #fff;
            --bs-btn-hover-bg: rgba(255,255,255,.12);
            --bs-btn-hover-border-color: rgba(255,255,255,.7);
            --bs-btn-active-bg: rgba(255,255,255,.2);
            --bs-btn-active-border-color: rgba(255,255,255,.85);
            padding: .2rem .6rem;
        }

        /* ===================================================================
           SIDEBAR MEJORADO
           =================================================================== */
        .sidebar {
            width: var(--sidebar-width);
            background: linear-gradient(180deg, #1a0000 0%, #0e0000 100%);
            color: #fff;
            position: fixed;
            top: var(--appbar-h);
            left: 0;
            bottom: 0;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: transform .25s ease;
            z-index: 999;
            border-right: 1px solid rgba(255,255,255,0.06);
            font-size: var(--sidebar-font-size);
        }

        .toggle-sidebar-btn { display: none !important; }
        .sidebar-hover-zone { display: none; }

        /* --- Cabecera del usuario --- */
        .sb-user-section {
            flex-shrink: 0;
            padding: 14px 12px 10px;
            background: linear-gradient(180deg, rgba(139,0,0,0.40), rgba(139,0,0,0.12));
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .sb-user-card {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.10);
            border-radius: 12px;
            padding: 10px 12px;
        }

        .sb-avatar {
            width: clamp(36px, 2.8vw, 44px);
            height: clamp(36px, 2.8vw, 44px);
            border-radius: 50%;
            flex-shrink: 0;
            object-fit: contain;
            border: 2px solid rgba(255,140,120,0.28);
            background: rgba(139,0,0,0.5);
        }

        .sb-user-info { flex: 1; min-width: 0; }

       .sb-user-name {
    font-size: 11.5px !important;
    font-weight: 700;
    white-space: normal !important;
    overflow: visible !important;
    text-overflow: unset !important;
    line-height: 1.1;
    display: -webkit-box !important;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}

        .sb-user-greeting {
            font-size: 9.5px !important;
    line-height: 1.1;
            color: rgba(255,255,255,0.55);        

            margin-top: 1px;
            display: block;
        }

        .sb-user-status {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #5dcaa5;
            flex-shrink: 0;
            box-shadow: 0 0 5px rgba(93,202,165,0.55);
        }

        /* --- Búsqueda --- */
        .sb-search {
            flex-shrink: 0;
            margin: 8px 10px 0;
            background: rgba(255,255,255,0.055);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 7px;
            padding: 6px 10px;
        }

        .sb-search-icon {
            color: rgba(255,255,255,0.30);
            font-size: 12px;
            flex-shrink: 0;
        }

        .sb-search-input {
            background: none;
            border: none;
            outline: none;
            font-size: clamp(11px, 0.85vw, 12.5px);
            color: rgba(255,255,255,0.7);
            width: 100%;
            font-family: inherit;
        }

        .sb-search-input::placeholder { color: rgba(255,255,255,0.28); }

        /* --- Etiquetas de sección --- */
        .sb-section-label {
            font-size: clamp(9px, 0.68vw, 10px);
            font-weight: 800;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.28);
            padding: 10px 10px 4px;
            flex-shrink: 0;
        }

        /* --- Nav scrolleable --- */
        .sb-nav {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 6px 8px;
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,0.10) transparent;
        }

        .sb-nav::-webkit-scrollbar { width: 4px; }
        .sb-nav::-webkit-scrollbar-track { background: transparent; }
        .sb-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 4px; }

        /* --- Items del menú --- */
        .menu-item {
            display: flex;
            flex-direction: column;
            margin-bottom: 2px;
        }

        .sidebar a,
        .sidebar .dropdown-btn {
            color: rgba(255,255,255,0.78) !important;
            text-decoration: none !important;
            padding: var(--sidebar-item-padding-y) var(--sidebar-item-padding-x) !important;
            border-radius: 9px !important;
            display: flex !important;
            align-items: center !important;
            gap: var(--sidebar-gap) !important;
            transition: background .18s ease, border-color .18s ease !important;
            cursor: pointer !important;
            font-size: var(--sidebar-font-size) !important;
            font-weight: 700 !important;
            line-height: 1.3 !important;
            min-height: clamp(38px, 3vw, 46px);
            width: 100%;
            white-space: normal;
            word-break: break-word;
            border: 1px solid transparent !important;
        }

        .sidebar a:hover,
        .sidebar .dropdown-btn:hover {
            background: rgba(255,255,255,0.07) !important;
            border-color: rgba(255,255,255,0.08) !important;
            color: #fff !important;
        }

        .sidebar a.active,
        .menu-item.open > .dropdown-btn {
            background: rgba(139,0,0,0.50) !important;
            border-color: rgba(255,100,80,0.18) !important;
            color: #fff !important;
        }

        /* Icono con fondo */
        .sb-icon-wrap {
            width: clamp(26px, 1.8vw, 30px);
            height: clamp(26px, 1.8vw, 30px);
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.08);
            flex-shrink: 0;
            transition: background .18s, border-color .18s;
        }

        .sidebar a:hover .sb-icon-wrap,
        .sidebar .dropdown-btn:hover .sb-icon-wrap {
            background: rgba(255,255,255,0.11);
            border-color: rgba(255,255,255,0.13);
        }

        .menu-item.open > .dropdown-btn .sb-icon-wrap,
        .sidebar a.active .sb-icon-wrap {
            background: rgba(139,0,0,0.65);
            border-color: rgba(255,120,100,0.25);
        }

        .sidebar a i,
        .sidebar .dropdown-btn i {
            font-size: var(--sidebar-icon-size) !important;
            color: rgba(255,255,255,0.65);
            transition: color .18s;
        }

        .sidebar a:hover i,
        .sidebar .dropdown-btn:hover i,
        .menu-item.open > .dropdown-btn i,
        .sidebar a.active i {
            color: #ffd2c7 !important;
        }

        /* Texto del item */
        .sb-item-label {
            flex: 1;
            min-width: 0;
            white-space: normal;
            overflow-wrap: anywhere;
            word-break: break-word;
        }

        /* Badge de notificación */
        .sb-badge {
            background: rgba(139,0,0,0.85);
            border: 1px solid rgba(255,120,100,0.22);
            border-radius: 999px;
            padding: 1px 7px;
            font-size: clamp(9px, 0.65vw, 10px);
            font-weight: 800;
            color: #ffd2c7;
            flex-shrink: 0;
            line-height: 1.6;
        }

        .sb-badge.sb-badge-new {
            background: rgba(93,202,165,0.18);
            color: #5dcaa5;
            border-color: rgba(93,202,165,0.25);
        }

        /* Flecha dropdown */
        .menu-item > .dropdown-btn > .arrow {
            transition: transform .2s ease;
            margin-left: auto;
            font-size: clamp(9px, 0.7vw, 10px) !important;
            width: auto !important;
            min-width: auto !important;
            color: rgba(255,255,255,0.35) !important;
            flex-shrink: 0;
        }

        .menu-item.open > .dropdown-btn > .arrow {
            transform: rotate(180deg);
            color: rgba(255,255,255,0.65) !important;
        }

        /* Submenú */
        .dropdown-container {
            max-height: 0;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: max-height .3s ease;
            margin: 2px 0 4px 10px;
            border-left: 2px solid rgba(255,255,255,0.10);
            border-radius: 0 0 0 6px;
        }

        .menu-item.open > .dropdown-container { max-height: 900px; }

        .dropdown-container a {
            padding: clamp(7px, 0.6vw, 9px) clamp(10px, 0.9vw, 14px) clamp(7px, 0.6vw, 9px) clamp(14px, 1.1vw, 18px) !important;
            font-size: clamp(11px, 0.85vw, 13px) !important;
            font-weight: 600 !important;
            line-height: 1.3 !important;
            min-height: clamp(34px, 2.6vw, 40px);
            border-radius: 7px !important;
            white-space: normal;
            word-break: break-word;
            color: rgba(255,255,255,0.60) !important;
            border: 1px solid transparent !important;
        }

        .dropdown-container a:hover {
            background: rgba(255,255,255,0.07) !important;
            border-left-color: rgba(255,100,80,0.30) !important;
            color: rgba(255,255,255,0.92) !important;
        }

        .dropdown-container a i {
            color: rgba(255,255,255,0.35) !important;
            font-size: clamp(10px, 0.78vw, 12px) !important;
        }

        .dropdown-container a:hover i { color: #ffd2c7 !important; }

        /* --- Divisor --- */
        .sb-divider {
            height: 1px;
            background: rgba(255,255,255,0.06);
            margin: 4px 8px;
        }

        /* --- Footer logout --- */
        .sb-footer {
            flex-shrink: 0;
            padding: 8px 8px 10px;
            border-top: 1px solid rgba(255,255,255,0.07);
        }

        .sb-footer a {
            color: rgba(255,130,120,0.75) !important;
            background: rgba(255,50,50,0.07) !important;
            border: 1px solid rgba(255,50,50,0.10) !important;
            border-radius: 9px !important;
            padding: 9px 12px !important;
            font-weight: 700 !important;
            transition: background .18s, border-color .18s, color .18s !important;
        }

        .sb-footer a:hover {
            background: rgba(255,50,50,0.14) !important;
            border-color: rgba(255,50,50,0.20) !important;
            color: rgba(255,160,150,0.95) !important;
        }

        .sb-footer a i { color: rgba(255,130,120,0.75) !important; }
        .sb-footer a:hover i { color: rgba(255,160,150,0.95) !important; }

        /* ===== CONTENT ===== */
        .content {
            margin: var(--appbar-h) 0 0 var(--sidebar-width);
            min-height: calc(100vh - var(--appbar-h));
            padding: 8px 10px;
            background: var(--bg);
        }

        .page-shell { max-width: 100%; margin: 0 auto; }

        /* ===== PANEL ===== */
        .page-panel {
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 12px;
            box-shadow: var(--shadow);
            padding: 10px;
        }

        /* ===== MAPA ===== */
        .cutmap-wrap { margin-top: 6px; }
        .cutmap-card { background: #fff; border: 1px solid var(--line); border-radius: 14px; box-shadow: var(--shadow); overflow: hidden; }
        .cutmap-header { padding: 10px 14px; border-bottom: 1px solid var(--line); display: flex; align-items: baseline; justify-content: space-between; gap: 10px; flex-wrap: wrap; min-height: 10px; }
        .cutmap-stage { position: relative; width: 100%; margin: 0; padding: 0; overflow: hidden; }
        .cutmap-svg { width: 100%; height: 100%; display: block; background: #0b0b0b; user-select: none; }
        .cut-zone { fill: rgba(139,0,0,.12); stroke: rgba(255,255,255,.65); stroke-width: 2; cursor: pointer; transition: fill .15s ease; }
        .cut-zone:hover { fill: rgba(139,0,0,.26); }
        .cut-zone:active { fill: rgba(139,0,0,.45); }

        .cut-hover-card { position: absolute; z-index: 50; width: min(25%, calc(80vw - 20px)); background: rgba(255,255,255,.98); border: 1px solid rgba(15,23,42,.12); border-radius: 14px; box-shadow: 0 18px 40px rgba(15,23,42,.25); padding: 10px; display: none; }
        .cut-hover-card.show { display: block; }
        .cut-hover-title { font-weight: 900; font-size: 0.9rem; margin: 0 0 8px 0; color: #111827; }
        .cut-hover-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
        .cut-hover-item { border: 1px solid rgba(15,23,42,.10); border-radius: 12px; overflow: hidden; background: #f8fafc; }
        .cut-hover-item img { width: 90%; height: 75%; object-fit: contain; display: block; }
        .cut-hover-item .name { padding: 5px 7px; font-size: .78rem; font-weight: 800; color: #111827; line-height: 1.1; }

        /* ===== CHAT ===== */
        .chat-fab { position: fixed; right: 24px; bottom: 24px; width: 56px; height: 56px; border-radius: 50%; border: none; background: radial-gradient(circle at 30% 30%, #ffefef, #8B0000); color: #fff; box-shadow: 0 10px 24px rgba(0,0,0,.25); display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 1600; transition: transform .15s ease, box-shadow .15s ease; }
        .chat-fab:hover { transform: translateY(-2px); box-shadow: 0 14px 30px rgba(0,0,0,.3); }
        .chat-fab i { font-size: 22px; }
        .chat-panel { position: fixed; right: 24px; bottom: 90px; width: 360px; max-height: 520px; background: #fff; border-radius: 14px; box-shadow: 0 18px 40px rgba(15,23,42,.30); border: 1px solid rgba(148,163,184,.6); display: flex; flex-direction: column; overflow: hidden; z-index: 1600; }

        /* ===== CAROUSEL ===== */
        .carousel { position: relative; width: 100%; margin: auto; overflow: hidden; border-radius: 16px; }
        .carousel-track { display: flex; transition: transform 0.6s ease-in-out; }
        .carousel-slide { min-width: 100%; height: 250px; }
        .carousel-slide img { width: 100%; height: 100%; object-fit: fill; object-position: center; }
        .carousel-btn { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(0,0,0,0.5); border: none; color: white; font-size: 32px; padding: 8px 14px; cursor: pointer; border-radius: 50%; z-index: 10; }
        .carousel-btn:hover { background: rgba(0,0,0,0.75); }
        .prev { left: 15px; }
        .next { right: 15px; }
        .carousel-dots { position: absolute; bottom: 12px; width: 100%; display: flex; justify-content: center; gap: 8px; }
        .carousel-dots button { width: 10px; height: 10px; border-radius: 50%; border: none; background: rgba(255,255,255,0.5); cursor: pointer; }
        .carousel-dots button.active { background: white; }

        /* ===== RESPONSIVE MOBILE ===== */
        @@media (max-width:768px) {
            :root {
                --appbar-h: 64px;
                --sidebar-width: min(84vw, 300px);
                --sidebar-font-size: 14px;
                --sidebar-icon-size: 16px;
                --brand-logo-h: 36px;
                --brand-logo-maxw: 155px;
            }

            body { overflow: auto !important; }

            .content {
                margin-left: 0 !important;
                height: auto !important;
                min-height: calc(100vh - var(--appbar-h));
                overflow: visible !important;
            }

            .sidebar {
                width: var(--sidebar-width) !important;
                transform: translateX(-105%);
                box-shadow: 0 18px 40px rgba(15,23,42,.30);
            }

            .sidebar.open { transform: translateX(0); }
            .sidebar-hover-zone { display: none; }
            .toggle-sidebar-btn { display: none !important; }
            .cut-hover-card { width: min(25%, calc(50vw - 24px)); }
            .carousel-slide { height: 140px; aspect-ratio: 16/7; }
        }

        @@media (max-width:576px) {
            :root {
                --appbar-h: 58px;
                --sidebar-width: min(88vw, 290px);
                --sidebar-font-size: 13px;
                --sidebar-icon-size: 15px;
                --brand-logo-h: 30px;
                --brand-logo-maxw: 130px;
            }

            .chat-panel { right: 8px; left: 8px; width: auto; }
            .chat-fab { right: 12px; bottom: 12px; }
            .cut-hover-grid { grid-template-columns: repeat(2, 1fr); }
        }

        /* ===== DESKTOP SIN SCROLL + MAPA COMPLETO ===== */
        @@media (min-width: 769px) {
            html, body { height: 100%; overflow: hidden; }

            .content {
                height: calc(100vh - var(--appbar-h)) !important;
                overflow: hidden !important;
                padding: 8px 10px !important;
                margin-left: var(--sidebar-width) !important;
            }

            .page-shell { height: 100%; display: flex; flex-direction: column; min-height: 0; gap: 6px; }
            .carousel { flex: 0 0 auto; margin: 0 !important; }

            #cutPanel { flex: 1 1 auto; min-height: 0; overflow: hidden !important; padding: 0 !important; display: flex; flex-direction: column; }
            .cutmap-wrap { margin-top: 0 !important; flex: 1; display: flex; flex-direction: column; min-height: 0; }
            .cutmap-card { height: 100% !important; display: flex !important; flex-direction: column !important; overflow: hidden !important; flex: 1; }
            .cutmap-header { display: none !important; }
            .cutmap-stage { flex: 1 1 auto !important; min-height: 0 !important; overflow: hidden !important; display: flex !important; align-items: center !important; justify-content: center !important; }
            .cutmap-svg { width: 100% !important; height: 100% !important; max-width: 100% !important; max-height: 100% !important; display: block !important; }
        }

        /* ===== CHAT PANEL INTERIOR ===== */
        .chat-panel-header { padding: .6rem .8rem; background: linear-gradient(135deg, #8B0000, #5a0000); color: #fff; display: flex; align-items: center; gap: .5rem; }
        .chat-panel-header .chat-title { font-size: .95rem; font-weight: 700; flex: 1; line-height: 1.1; }
        .chat-panel-header small { display: block; font-size: .7rem; opacity: .8; }
        .chat-panel-header button { border: none; background: transparent; color: #fff; opacity: .8; }
        .chat-panel-header button:hover { opacity: 1; }
        .chat-panel-body { padding: .6rem .7rem .3rem; display: flex; flex-direction: column; gap: .4rem; border-bottom: 1px solid #e2e8f0; background: #f8fafc; }
        .chat-area-select { display: flex; flex-direction: column; gap: .25rem; }
        .chat-area-select label { font-size: .75rem; color: #64748b; font-weight: 600; text-transform: uppercase; }
        .chat-area-select select { font-size: .85rem; padding: .2rem .35rem; border-radius: 6px; border: 1px solid #cbd5e1; }
        .chat-hint { font-size: .72rem; color: #64748b; }
        .chat-messages { flex: 1; padding: .5rem .7rem; overflow-y: auto; background: #fff; font-size: .85rem; }
        .chat-msg { margin-bottom: .35rem; display: flex; }
        .chat-msg.me { justify-content: flex-end; }
        .chat-msg .bubble { max-width: 80%; padding: .35rem .55rem; border-radius: 12px; box-shadow: 0 2px 6px rgba(15,23,42,.12); }
        .chat-msg.me .bubble { background: #8B0000; color: #fff; border-bottom-right-radius: 2px; }
        .chat-msg.other .bubble { background: #e2e8f0; color: #111827; border-bottom-left-radius: 2px; }
        .chat-msg .meta { display: block; font-size: .65rem; opacity: .7; margin-top: 2px; }
        .chat-input { padding: .4rem .5rem; display: flex; align-items: center; gap: .35rem; background: #f8fafc; }
        .chat-input textarea { resize: none; flex: 1; border-radius: 8px; border: 1px solid #cbd5e1; padding: .3rem .4rem; font-size: .85rem; max-height: 80px; min-height: 34px; }
        .chat-input button { border-radius: 999px; padding-inline: .75rem; font-size: .85rem; display: inline-flex; align-items: center; gap: .25rem; }

        #font { font-family: "Orbitron", sans-serif; font-optical-sizing: auto; font-style: normal; }

        /* ===== MANUAL MODAL ===== */
