        <a class="brand-link" asp-controller="Home" asp-action="Inicio">
            <img src="~/images/sigoL.png" alt="SIGO" class="logo-navbar" />
        </a>

        <div class="tools">
            <div class="clock-top me-2">
                <span id="clock-time"></span>
                <span id="clock-date"></span>
            </div>
            <span class="vr-light"></span>
            <button class="btn btn-sm btn-outline-light btn-about" data-bs-toggle="modal" data-bs-target="#aboutModal">
                <i class="fa-solid fa-circle-info me-1"></i>
                <span class="d-none d-sm-inline">Acerca de</span><span class="d-inline d-sm-none">Info</span>
            </button>
            <button class="btn btn-sm text-white border-0" data-bs-toggle="modal" data-bs-target="#reporteModal" title="Levantar Reporte">
                <i class="fa-solid fa-headset fa-lg"></i>
            </button>
