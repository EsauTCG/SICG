                <div class="sb-user-info">
                    <div class="sb-user-name">@User.Identity.Name</div>
                    <small id="dynamic-greeting" class="sb-user-greeting"></small>
                    <small id="dynamic-message" class="sb-user-greeting" style="margin-top:1px;"></small>
                </div>
                <div class="sb-user-status"></div>
            </div>
        </div>

        <!-- Buscador -->
