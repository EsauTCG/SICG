/* ============================================================
   CENTRO DE OPERACIONES DE RED
   ============================================================ */
.network-banner-status {
    min-width: 245px;
    padding: 9px 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid rgba(255,255,255,.28);
    background: rgba(255,255,255,.09);
    color: #fff;
}

.network-banner-status > i {
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(255,255,255,.24);
    background: rgba(0,0,0,.13);
    font-size: 16px;
}

.network-banner-status span,
.network-banner-status strong {
    display: block;
}

.network-banner-status span {
    font-size: 8px;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
    opacity: .78;
}

.network-banner-status strong {
    margin-top: 2px;
    font-size: 10px;
}

.network-operation-center {
    margin: 0 0 12px;
    padding: 14px;
    border: 1px solid #d7c2c2;
    border-radius: 16px;
    background:
        radial-gradient(circle at 92% 0%, rgba(139,0,0,.09), transparent 28%),
        linear-gradient(145deg, #fffefe 0%, #f8eeee 100%);
    box-shadow: 0 12px 28px rgba(71,17,17,.09);
}

.network-operation-center__header {
    margin-bottom: 12px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 18px;
}

.network-operation-center__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 4px;
    color: #8b0000;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: .09em;
    text-transform: uppercase;
}

.network-operation-center__header h3 {
    margin: 0;
    color: #3f1616;
    font-size: clamp(15px, 1.2vw, 19px);
    font-weight: 900;
}

.network-operation-center__header p {
    margin: 4px 0 0;
    color: #7a6262;
    font-size: 11px;
}

.network-active-context {
    min-width: 190px;
    padding: 8px 11px;
    border: 1px solid #decaca;
    border-radius: 10px;
    background: rgba(255,255,255,.72);
    text-align: right;
}

.network-active-context span,
.network-active-context strong {
    display: block;
}

.network-active-context span {
    color: #947a7a;
    font-size: 8px;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
}

.network-active-context strong {
    margin-top: 2px;
    color: #6f1010;
    font-size: 11px;
}

.network-operation-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 10px;
}

.network-operation-card {
    --operation-accent: #8b0000;
    --operation-soft: #f7dddd;
    position: relative;
    isolation: isolate;
    min-width: 0;
    min-height: 136px;
    padding: 13px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 9px;
    border: 1px solid #d8c7c7;
    border-radius: 13px;
    background: linear-gradient(155deg, #fff 0%, #fffafa 100%);
    color: #452222;
    text-align: left;
    box-shadow: 0 5px 14px rgba(52,15,15,.06);
    transition: transform .18s ease, border-color .18s ease, box-shadow .18s ease;
}

.network-operation-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    z-index: -1;
    width: 4px;
    background: var(--operation-accent);
}

.network-operation-card::after {
    content: "";
    position: absolute;
    right: -34px;
    top: -40px;
    z-index: -1;
    width: 112px;
    height: 112px;
    border-radius: 50%;
    background: var(--operation-soft);
    opacity: .68;
}

.network-operation-card:hover {
    transform: translateY(-3px);
    border-color: var(--operation-accent);
    box-shadow: 0 13px 25px rgba(74,14,14,.13);
}

.network-operation-card.active {
    border-color: var(--operation-accent);
    background:
        radial-gradient(circle at 92% 6%, rgba(255,255,255,.18), transparent 28%),
        linear-gradient(145deg, var(--operation-accent) 0%, #4d0909 100%);
    color: #fff;
}

.network-operation-card.active::before {
    width: 6px;
    background: #fff;
}

.network-operation-icon {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--operation-accent) 28%, #fff);
    border-radius: 12px;
    background: var(--operation-soft);
    color: var(--operation-accent);
    font-size: 20px;
}

.network-operation-card.active .network-operation-icon {
    border-color: rgba(255,255,255,.28);
    background: rgba(255,255,255,.15);
    color: #fff;
}

.network-operation-copy strong,
.network-operation-copy small {
    display: block;
}

.network-operation-copy strong {
    color: inherit;
    font-size: 12px;
    font-weight: 900;
}

.network-operation-copy small {
    margin-top: 4px;
    color: #806c6c;
    font-size: 9px;
    line-height: 1.35;
}

.network-operation-card.active .network-operation-copy small {
    color: rgba(255,255,255,.78);
}

.network-operation-action {
    margin-top: auto;
    padding-top: 8px;
    display: flex;
    justify-content: space-between;
    gap: 8px;
    border-top: 1px solid rgba(118,74,74,.13);
    color: var(--operation-accent);
    font-size: 8px;
    font-weight: 900;
    text-transform: uppercase;
}

.network-operation-card.active .network-operation-action {
    border-top-color: rgba(255,255,255,.17);
    color: #fff;
}

.operation-ip { --operation-accent: #8b0000; --operation-soft: #f7dddd; }
.operation-topology { --operation-accent: #176b82; --operation-soft: #dff2f7; }
.operation-vlan { --operation-accent: #6c4aa0; --operation-soft: #eee5fb; }
.operation-register { --operation-accent: #176b46; --operation-soft: #ddf4e8; }
.operation-audit { --operation-accent: #b56d05; --operation-soft: #fff0d5; }

.network-filter-panel {
    border-radius: 14px !important;
}

/* VLAN visual */
.vlan-navigation {
    margin-top: 12px;
    padding: 10px;
    border: 1px solid #ddc4c4;
    border-radius: 12px;
    background: rgba(255,255,255,.62);
}

.vlan-navigation__header {
    margin-bottom: 8px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
}

.vlan-navigation__eyebrow {
    display: block;
    color: #9a6b6b;
    font-size: 8px;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
}

.vlan-navigation__header strong {
    display: block;
    margin-top: 1px;
    color: #531b1b;
    font-size: 12px;
}

.vlan-navigation__header small {
    color: #8a7070;
    font-size: 9px;
}

.vlan-card-grid {
    display: grid !important;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 8px;
    width: 100%;
    margin: 0 !important;
    padding: 0 !important;
    border: 0 !important;
    background: transparent !important;
}

.vlan-card-grid .nav-item {
    min-width: 0;
}

.vlan-nav-card {
    --vlan-accent: #7a1c1c;
    width: 100%;
    min-height: 72px;
    margin: 0 !important;
    padding: 9px 10px !important;
    display: grid !important;
    grid-template-columns: 34px minmax(0, 1fr);
    grid-template-rows: auto auto;
    gap: 3px 8px;
    align-items: center;
    border: 1px solid #d8c2c2 !important;
    border-radius: 10px !important;
    background: linear-gradient(145deg, #fff 0%, #fbf1f1 100%) !important;
    color: #4d2323 !important;
    text-align: left !important;
    white-space: normal !important;
    box-shadow: 0 4px 10px rgba(63,19,19,.05);
}

.vlan-nav-card:hover {
    border-color: var(--vlan-accent) !important;
    transform: translateY(-1px);
}

.vlan-nav-card.active {
    border-color: var(--vlan-accent) !important;
    background: linear-gradient(145deg, var(--vlan-accent), #4d0909) !important;
    color: #fff !important;
}

.vlan-nav-icon {
    grid-row: 1 / 3;
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border-radius: 9px;
    background: rgba(139,0,0,.09);
    color: var(--vlan-accent);
    font-size: 16px;
}

.vlan-nav-card.active .vlan-nav-icon {
    background: rgba(255,255,255,.15);
    color: #fff;
}

.vlan-nav-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: inherit;
    font-size: 10px;
    font-weight: 900;
}

.vlan-nav-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 7px;
    color: #8a7070;
    font-size: 8px;
}

.vlan-nav-card.active .vlan-nav-stats {
    color: rgba(255,255,255,.78);
}

.vlan-nav-empty {
    grid-column: 1 / -1;
    padding: 16px;
    border: 1px dashed #cdaaaa;
    border-radius: 10px;
    color: #826767;
    text-align: center;
    font-size: 10px;
}

/* Dark mode */
body[data-theme="dark"] .network-operation-center,
body[data-theme="dark"] .vlan-navigation {
    border-color: rgba(255,255,255,.12) !important;
    background: linear-gradient(145deg, #111827, #172033) !important;
}

body[data-theme="dark"] .network-operation-center__header h3,
body[data-theme="dark"] .vlan-navigation__header strong {
    color: #f9fafb !important;
}

body[data-theme="dark"] .network-operation-center__header p,
body[data-theme="dark"] .vlan-navigation__header small,
body[data-theme="dark"] .vlan-navigation__eyebrow {
    color: #cbd5e1 !important;
}

body[data-theme="dark"] .network-active-context {
    border-color: rgba(255,255,255,.12);
    background: #0b1220;
}

body[data-theme="dark"] .network-active-context strong {
    color: #f9fafb;
}

body[data-theme="dark"] .network-operation-card,
body[data-theme="dark"] .vlan-nav-card {
    border-color: rgba(255,255,255,.12) !important;
    background: linear-gradient(145deg, #111827, #0b1220) !important;
    color: #f9fafb !important;
}

body[data-theme="dark"] .network-operation-copy small,
body[data-theme="dark"] .vlan-nav-stats {
    color: #cbd5e1;
}

/* Responsivo */
@@media (max-width: 1180px) {
    .network-operation-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }
}

@@media (max-width: 820px) {
    .network-operation-center {
        padding: 10px;
    }

    .network-operation-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}

@@media (max-width: 560px) {
    .network-banner-status {
        width: 100%;
    }

    .network-operation-center__header {
        display: block;
    }

    .network-active-context,
    .network-operation-center__header p,
    .vlan-navigation__header small {
        display: none;
    }

    .network-operation-grid {
        display: flex;
        gap: 8px;
        overflow-x: auto;
        padding-bottom: 7px;
        scroll-snap-type: x mandatory;
    }

    .network-operation-card {
        flex: 0 0 245px;
        min-height: 112px;
        scroll-snap-align: start;
    }

    .vlan-navigation__header {
        display: block;
    }

    .vlan-card-grid {
        display: flex !important;
        gap: 7px;
        overflow-x: auto;
        padding-bottom: 5px !important;
    }

    .vlan-card-grid .nav-item {
        flex: 0 0 210px;
    }
}

</style>

<div id="controlIPsApp" class="container-fluid py-4">
    @Html.AntiForgeryToken()

    <div class="top-banner d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1">Control de Direcciones IP</h2>
            <p class="mb-0" style="font-size: 0.85rem; opacity: 0.85;">Gestión dinámica de red y VLANs por planta.</p>
        </div>
        <div class="network-banner-status">
            <i class="bi bi-hdd-network-fill"></i>
            <div>
                <span>Administración centralizada</span>
                <strong>Red, VLAN, topología y auditoría</strong>
            </div>
        </div>
    </div>

    <section class="network-operation-center" aria-label="Centro de operaciones de red">
        <div class="network-operation-center__header">
            <div>
                <span class="network-operation-center__eyebrow">
                    <i class="bi bi-grid-1x2-fill"></i>
                    Centro de operaciones
                </span>
                <h3>¿Qué deseas administrar?</h3>
                <p>Accede a IP, topología, VLAN, altas y auditoría sin perder tus controles actuales.</p>
            </div>

            <div class="network-active-context">
                <span>Vista actual</span>
                <strong id="networkActiveContext">Direcciones IP</strong>
            </div>
        </div>

        <div class="network-operation-grid">
            <button type="button"
                    class="network-operation-card operation-ip active"
                    id="btnInventarioIP"
                    onclick="enfocarInventarioIP()">
                <span class="network-operation-icon"><i class="bi bi-ethernet"></i></span>
                <span class="network-operation-copy">
                    <strong>Direcciones IP</strong>
                    <small>Consulta disponibilidad, asignaciones, usuarios, áreas y conexión.</small>
                </span>
                <span class="network-operation-action">
                    <span>Ver inventario IP</span>
                    <i class="bi bi-arrow-down"></i>
                </span>
            </button>

            <button type="button"
                    class="network-operation-card operation-topology"
                    id="btnTopologiaRed"
                    onclick="abrirTopologiaRed()">
                <span class="network-operation-icon"><i class="bi bi-bezier2"></i></span>
                <span class="network-operation-copy">
                    <strong>Topología de red</strong>
                    <small>Visualiza Internet, Fortinet, VPN, core, VLAN y equipos.</small>
                </span>
                <span class="network-operation-action">
                    <span>Abrir mapa lógico</span>
                    <i class="bi bi-arrows-fullscreen"></i>
                </span>
            </button>

            <button type="button"
                    class="network-operation-card operation-vlan"
                    id="btnNuevaVlanVisual"
