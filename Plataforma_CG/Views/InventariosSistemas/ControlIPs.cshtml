                    <h5 class="modal-title m-0"><i class="bi bi-clock-history me-2"></i> Trazabilidad de IP: <span id="lblHistorialIP" class="fw-bold"></span></h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
