    .topologia-shell {
        width: 100%;
        height: 100%;
        min-height: 0;
        display: grid;
        grid-template-columns: clamp(210px, 16vw, 275px) minmax(0, 1fr) clamp(230px, 19vw, 315px);
        overflow: hidden;
        background: var(--topo-bg);
    }

    .topologia-sidebar,
    .topologia-inspector {
        min-width: 0;
        min-height: 0;
        display: flex;
        flex-direction: column;
        background:
            linear-gradient(180deg, rgba(255,255,255,.025), transparent 130px),
            var(--topo-panel);
    }

    .topologia-sidebar {
        border-right: 1px solid var(--topo-border);
    }

    .topologia-inspector {
        border-left: 1px solid var(--topo-border);
    }

    .topologia-side-title {
        flex: 0 0 auto;
        padding: 13px;
        border-bottom: 1px solid var(--topo-border);
        background: linear-gradient(135deg, #14384b, #0b202c);
    }

    .topologia-side-title strong {
        display: block;
        color: #fff;
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .07em;
    }

    .topologia-side-title small {
        display: block;
        margin-top: 3px;
        color: var(--topo-muted);
        font-size: 10px;
    }

    .topologia-controls {
        flex: 0 0 auto;
        display: grid;
        gap: 8px;
        padding: 11px;
        border-bottom: 1px solid var(--topo-border);
    }

    .topologia-controls label,
    .topologia-inspector label {
        display: block;
        margin-bottom: 3px;
        color: #7798aa;
        font-size: 9px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .07em;
    }

    .topologia-controls select,
    .topologia-controls input,
    .topologia-inspector select,
    .topologia-inspector input {
        width: 100%;
        height: 35px !important;
        min-width: 0;
        padding: 6px 8px !important;
        border: 1px solid #315b70 !important;
        border-radius: 7px !important;
        background: #071722 !important;
        color: #eefaff !important;
        font-size: 11px !important;
        box-shadow: none !important;
    }

    .topologia-check {
        min-height: 34px;
        padding: 7px 9px;
        display: flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #294e62;
        border-radius: 7px;
        background: #0a1d29;
        color: #c4d7e0;
        font-size: 10px;
        cursor: pointer;
    }

    .topologia-check input {
        width: 15px !important;
        height: 15px !important;
        margin: 0;
        accent-color: #28b6e6;
    }

    .topologia-summary {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
        padding: 10px;
    }

    .topologia-stat {
        display: grid;
        grid-template-columns: 34px minmax(0, 1fr) auto;
        gap: 8px;
        align-items: center;
        margin-bottom: 7px;
        padding: 8px;
        border: 1px solid #24495c;
        border-radius: 8px;
        background: linear-gradient(135deg, #122c3a, #0a1c27);
    }

    .topologia-stat-icon {
        width: 34px;
        height: 34px;
        display: grid;
        place-items: center;
        border: 1px solid #32657d;
        border-radius: 8px;
        background: #07151e;
        color: #57dbff;
        font-size: 17px;
    }

    .topologia-stat strong,
    .topologia-stat small {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .topologia-stat strong {
        color: #f2fbff;
        font-size: 10px;
    }

    .topologia-stat small {
        margin-top: 2px;
        color: #809ead;
        font-size: 9px;
    }

    .topologia-stat-value {
        color: #fff;
        font-size: 17px;
        font-weight: 900;
    }

    .topologia-center {
        min-width: 0;
        min-height: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: #040d13;
    }

    .topologia-toolbar {
        flex: 0 0 auto;
        min-height: 52px;
        padding: 7px 9px;
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
        border-bottom: 1px solid var(--topo-border);
        background: linear-gradient(180deg, #143043, #0b202c);
    }

    .topologia-toolbar-title {
        min-width: 190px;
        margin-right: auto;
    }

    .topologia-toolbar-title strong {
        display: block;
        color: #fff;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .06em;
    }

    .topologia-toolbar-title small {
        display: block;
        margin-top: 1px;
        color: #7f9baa;
        font-size: 9px;
    }

    .topologia-btn {
        min-height: 32px;
        padding: 0 10px;
        border: 1px solid #315d72;
        border-radius: 7px;
        background: linear-gradient(180deg, #183b4e, #102735);
        color: #eafaff;
        font-size: 10px;
        font-weight: 850;
        cursor: pointer;
        white-space: nowrap;
    }

    .topologia-btn:hover {
        border-color: #58d7ff;
        background: #17435a;
    }

    .topologia-btn.primary {
        border-color: #007ba4;
        background: linear-gradient(135deg, #008bb7, #07536d);
    }

    .topologia-btn.success {
        border-color: #17834b;
        background: linear-gradient(135deg, #1a9c58, #11633a);
    }

    .topologia-btn.warning {
        border-color: #a86b12;
        background: linear-gradient(135deg, #c1811b, #75460a);
    }

    .topologia-kpis {
        flex: 0 0 auto;
        display: grid;
        grid-template-columns: repeat(5, minmax(80px, 1fr));
        gap: 6px;
        padding: 7px 9px;
        border-bottom: 1px solid #1c3a4a;
        background: #081923;
    }

    .topologia-kpi {
        min-width: 0;
        padding: 7px 8px;
        border: 1px solid #21475a;
        border-radius: 7px;
        background: #0d2230;
    }

    .topologia-kpi span,
    .topologia-kpi strong {
        display: block;
    }

    .topologia-kpi span {
        color: #7895a4;
        font-size: 8px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .topologia-kpi strong {
        margin-top: 2px;
        color: #fff;
        font-size: 16px;
        line-height: 1;
    }

    .topologia-viewport {
        position: relative;
        flex: 1 1 auto;
        min-height: 0;
        overflow: auto;
        background: #030a0f;
        scrollbar-color: #285a70 #07121a;
    }

    .topologia-world {
        position: relative;
        min-width: 100%;
        min-height: 100%;
    }

    .topologia-stage {
        position: absolute;
        left: 0;
        top: 0;
        transform-origin: 0 0;
        overflow: hidden;
        background-color: #06141d;
        background-image:
            linear-gradient(rgba(65, 170, 210, .13) 1px, transparent 1px),
            linear-gradient(90deg, rgba(65, 170, 210, .13) 1px, transparent 1px),
            radial-gradient(circle at 28% 10%, rgba(25, 138, 178, .16), transparent 35%),
            linear-gradient(145deg, #092635 0%, #06151f 55%, #040d13 100%);
        background-size: 26px 26px, 26px 26px, auto, auto;
    }

    .topologia-stage::after {
        content: "SIGO · NETWORK DIGITAL TWIN";
        position: absolute;
        right: 18px;
        bottom: 12px;
        z-index: 1;
        color: rgba(93, 214, 255, .17);
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .18em;
        pointer-events: none;
    }

    .topologia-links {
        position: absolute;
        inset: 0;
        z-index: 2;
        width: 100%;
        height: 100%;
        pointer-events: none;
        overflow: visible;
    }

    .topologia-link {
        fill: none;
        stroke: #4ed4ff;
        stroke-width: 2;
        opacity: .64;
        filter: drop-shadow(0 0 3px rgba(78,212,255,.34));
    }

    .topologia-link.wifi {
        stroke: #ffbf47;
        stroke-dasharray: 7 5;
    }

    .topologia-link.backbone {
        stroke: #47e18c;
        stroke-width: 3;
        opacity: .82;
    }

    .topologia-link.offline {
        stroke: #ff5d68;
        stroke-dasharray: 5 5;
    }

    .topologia-link-label {
        fill: #a7cfdf;
        font-size: 9px;
        font-weight: 800;
        paint-order: stroke;
        stroke: #06141d;
        stroke-width: 3px;
        stroke-linejoin: round;
    }

    .topologia-vlan-zone {
        position: absolute;
        z-index: 1;
        border: 1px dashed var(--zone-color, #3ec8f2);
        border-radius: 13px;
        background:
            linear-gradient(135deg, color-mix(in srgb, var(--zone-color) 9%, transparent), rgba(3, 15, 22, .34));
        box-shadow: inset 0 0 30px color-mix(in srgb, var(--zone-color) 6%, transparent);
        pointer-events: none;
    }

    .topologia-vlan-zone-title {
        position: absolute;
        left: 10px;
        top: 7px;
        color: var(--zone-color, #3ec8f2);
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .topologia-node {
        position: absolute;
        z-index: 10;
        width: 112px;
        min-height: 82px;
        padding: 8px 6px 7px;
        border: 1px solid #35677d;
        border-radius: 10px;
        background: linear-gradient(145deg, rgba(24, 57, 74, .98), rgba(7, 22, 31, .98));
        color: #fff;
        text-align: center;
        cursor: grab;
        user-select: none;
        touch-action: none;
        box-shadow: 0 10px 20px rgba(0,0,0,.34);
    }

    .topologia-node:hover {
        border-color: #5cddff;
        box-shadow: 0 12px 24px rgba(0,0,0,.42), 0 0 18px rgba(79,211,255,.12);
    }

    .topologia-node:active {
        cursor: grabbing;
    }

    .topologia-node.selected {
        border-color: #fff;
        outline: 2px solid #4fd7ff;
        outline-offset: 2px;
    }

    .topologia-node.infrastructure {
        width: 126px;
        min-height: 88px;
        border-color: #2a8fb3;
        background: linear-gradient(145deg, #164c65, #092735);
    }

    .topologia-node.vlan {
        width: 132px;
        min-height: 88px;
        border-color: var(--node-color, #42d6ff);
        background:
            linear-gradient(145deg, color-mix(in srgb, var(--node-color) 29%, #0a2735), #071923);
    }

    .topologia-node.access-point {
        border-color: #df9628;
        background: linear-gradient(145deg, #654512, #211907);
    }

    .topologia-node.free-ip {
        opacity: .62;
        border-style: dashed;
    }

    .topologia-node-icon {
        width: 38px;
        height: 34px;
        margin: 0 auto 5px;
        display: grid;
        place-items: center;
        border-radius: 8px;
        background: rgba(0,0,0,.22);
        color: #60ddff;
        font-size: 22px;
    }

    .topologia-node.access-point .topologia-node-icon {
        color: #ffc65c;
    }

    .topologia-node strong,
    .topologia-node small {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .topologia-node strong {
        font-size: 9px;
        line-height: 1.15;
    }

    .topologia-node small {
        margin-top: 2px;
        color: #9cb9c7;
        font-family: Consolas, monospace;
        font-size: 8px;
    }

    .topologia-node-status {
        position: absolute;
        right: 6px;
        top: 6px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #718b99;
        box-shadow: 0 0 10px currentColor;
    }

    .topologia-node-status.online {
        color: var(--topo-green);
        background: var(--topo-green);
    }

    .topologia-node-status.offline {
        color: var(--topo-red);
        background: var(--topo-red);
    }

    .topologia-node-status.checking {
        color: var(--topo-amber);
        background: var(--topo-amber);
        animation: topoPulse 1s infinite;
    }

    .topologia-node-status.free,
    .topologia-node-status.unknown {
        color: #718b99;
        background: #718b99;
