                            <div><span class="topologia-node-status checking" style="position:static"></span> Comprobando</div>
                            <div><span class="topologia-node-status unknown" style="position:static"></span> Sin comprobar</div>
                        </div>
                    </div>
                `;
            }

            function topoPointerDown(ev) {
                if (ev.button !== undefined && ev.button !== 0) return;

                const el = ev.currentTarget;
                const id = el.dataset.topoNode;
                const pos = topoPositions[id];
                if (!id || !pos) return;

                ev.preventDefault();

                topoSelectedId = id;
                topoDrag = {
                    id,
                    startClientX: ev.clientX,
                    startClientY: ev.clientY,
                    startX: Number(pos.x),
                    startY: Number(pos.y),
                    moved: false
                };

                el.setPointerCapture?.(ev.pointerId);
                topoRenderInspector();
            }

            document.addEventListener('pointermove', ev => {
                if (!topoDrag) return;

                const dx = (ev.clientX - topoDrag.startClientX) / topoZoom;
                const dy = (ev.clientY - topoDrag.startClientY) / topoZoom;
                const node = topoModel.nodes.find(n => n.id === topoDrag.id);
                if (!node) return;

                const maxX = topoModel.width - 120;
                const maxY = topoModel.height - 90;

                topoPositions[topoDrag.id] = {
                    x: Math.max(0, Math.min(maxX, topoDrag.startX + dx)),
                    y: Math.max(0, Math.min(maxY, topoDrag.startY + dy))
                };

                topoDrag.moved = Math.abs(dx) > 2 || Math.abs(dy) > 2;

                const el = document.querySelector(`[data-topo-node="${CSS.escape(topoDrag.id)}"]`);
                if (el) {
                    el.style.left = `${topoPositions[topoDrag.id].x}px`;
                    el.style.top = `${topoPositions[topoDrag.id].y}px`;
                }

                topoRenderEdges();
            });

            document.addEventListener('pointerup', async () => {
                if (!topoDrag) return;
                topoDrag = null;
                await topoGuardarDiseno(true);
            });

            function topoAplicarZoom() {
                const stage = document.getElementById('topoStage');
                const world = document.getElementById('topoWorld');
                const label = document.getElementById('topoZoomLabel');
                if (!stage || !world) return;

                stage.style.transform = `scale(${topoZoom})`;
                world.style.width = `${Math.max(1, topoModel.width * topoZoom)}px`;
                world.style.height = `${Math.max(1, topoModel.height * topoZoom)}px`;

                if (label) label.textContent = `${Math.round(topoZoom * 100)}%`;
            }

            function topoCambiarZoom(delta) {
                topoZoom = Math.max(.45, Math.min(1.6, topoZoom + delta));
                topoAplicarZoom();
            }

            function topoResetZoom() {
                topoZoom = 1;
                topoAplicarZoom();

                const viewport = document.getElementById('topoViewport');
                if (viewport) {
                    viewport.scrollLeft = 0;
                    viewport.scrollTop = 0;
                }
            }

            async function topoPingUno(nodeId) {
                const node = topoModel.nodes.find(n => n.id === nodeId);
                if (!node?.ip) return;

                topoStatus[nodeId] = 'checking';
                topoRenderNodes();
                topoRenderEdges();
                topoRenderInspector();

                try {
                    const res = await fetch(`@Url.Action("VerificarPing", "InventariosSistemas")?ipAddress=${encodeURIComponent(node.ip)}`);
                    const data = await res.json();
                    topoStatus[nodeId] = data.ok && data.responde ? 'online' : 'offline';
                } catch {
                    topoStatus[nodeId] = 'offline';
                }

                topoRenderNodes();
                topoRenderEdges();
                topoActualizarKpis();
                topoRenderInspector();
            }

            async function topoComprobarRed() {
                if (topoPingEnCurso) return;

                const targets = topoModel.nodes.filter(n => n.kind === 'device' && !n.free && n.ip);
                if (!targets.length) {
                    alert('No hay equipos asignados visibles para comprobar.');
                    return;
                }

                topoPingEnCurso = true;
                targets.forEach(n => topoStatus[n.id] = 'checking');
                topoRenderNodes();
                topoRenderEdges();
                topoRenderInspector();

                let completed = 0;
                const progress = () => {
                    const bar = document.getElementById('topoPingProgress');
                    const txt = document.getElementById('topoPingTexto');
                    const pct = Math.round((completed / targets.length) * 100);

                    if (bar) bar.style.width = `${pct}%`;
                    if (txt) txt.textContent = `Comprobando ${completed} de ${targets.length} equipos (${pct}%).`;
                };

                progress();

                const queue = [...targets];
                const workers = Array.from({ length: Math.min(5, queue.length) }, async () => {
                    while (queue.length) {
                        const node = queue.shift();
                        if (!node) break;

                        try {
                            const res = await fetch(`@Url.Action("VerificarPing", "InventariosSistemas")?ipAddress=${encodeURIComponent(node.ip)}`);
                            const data = await res.json();
                            topoStatus[node.id] = data.ok && data.responde ? 'online' : 'offline';
                        } catch {
                            topoStatus[node.id] = 'offline';
                        }

                        completed++;
                        progress();
                        topoRenderNodes();
                        topoRenderEdges();
                        topoActualizarKpis();
                    }
                });

                await Promise.all(workers);

                topoPingEnCurso = false;
                topoRenderNodes();
                topoRenderEdges();
                topoActualizarKpis();
                topoRenderInspector();

                const online = targets.filter(n => topoStatus[n.id] === 'online').length;
                const offline = targets.length - online;

                const txt = document.getElementById('topoPingTexto');
                const bar = document.getElementById('topoPingProgress');
                if (bar) bar.style.width = '100%';
                if (txt) txt.textContent = `Comprobación terminada: ${online} en línea y ${offline} sin respuesta.`;
            }

