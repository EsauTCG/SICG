@section Scripts {
        <script>
            let modalEditar;
            let modalLog;
            let modalVlanObj;
            let vlanActiva = '21';
            let modoCreacion = false;

            let baseVlans = [];
            let baseIPs = [];
            let historialLogs = [];
                        let permisosIPs = { puedeLeer: false, puedeEscribir: false, puedeEliminar: false };

            $(document).ready(function () {
                cargarPermisosIPs();
                // ... el resto del código existente ...
            });

            async function cargarPermisosIPs() {
                try {
                    const res = await fetch('@Url.Action("ObtenerPermisosVistaControlIPs", "InventariosSistemas")');
                    if (res.ok) {
                        permisosIPs = await res.json();
                        aplicarPermisosIPs();
                    }
                } catch (e) {
                    console.error("Error permisos IPs:", e);
                }
            }

            function aplicarPermisosIPs() {
                if (!permisosIPs.puedeEscribir) {
                    document.querySelectorAll(
                        '[onclick*="abrirNuevaIP"], ' +
                        '[onclick*="abrirModalVlan"], ' +
                        '[onclick*="abrirEdicion"], ' +
                        '[onclick*="eliminarIP"], ' +
                        '#btnLiberarIP, ' +
                        '#btnGuardarIP'
                    ).forEach(el => el.style.display = 'none');
                }
            }


            $(document).ready(function () {
                modalEditar = new bootstrap.Modal(document.getElementById('modalEditarIP'));
                modalLog = new bootstrap.Modal(document.getElementById('modalLog'));
                modalVlanObj = new bootstrap.Modal(document.getElementById('modalVlan'));

                cargarTodoDesdeServidor();
            });

            async function cargarTodoDesdeServidor() {
                try {
                    // 1. Cargar VLANs
                    const responseVlans = await fetch('@Url.Action("GetVlans", "InventariosSistemas")');
                    const dataVlans = await responseVlans.json();
                    if (dataVlans.ok) { baseVlans = dataVlans.vlans; }

                    // 2. Cargar Historial (Log General)
                    const responseLogs = await fetch('@Url.Action("GetLogsRed", "InventariosSistemas")');
                    const dataLogs = await responseLogs.json();
                    if (dataLogs.ok) {
                        historialLogs = dataLogs.logs;
                        renderLogs();
                        // VERIFICAR SI HAY NOVEDADES PARA ESTE USUARIO
                        verificarNuevosLogs();
                    }

                    // 3. Cargar IPs
                    const responseIPs = await fetch('@Url.Action("GetIPs", "InventariosSistemas")');
                    const dataIPs = await responseIPs.json();

                    if (dataIPs.ok) {
                        baseIPs = dataIPs.ips;
                        baseIPs.forEach(i => {
                            i.fAlta = new Date(i.fechaAlta).toLocaleDateString('es-MX');
                            i.fMod = new Date(i.fechaModificacion).toLocaleDateString('es-MX');
                            i.ip = i.ipAddress;
                            i.equipo = i.equipoAsignado;
                            i.usuario = i.usuario || i.Usuario || '';
                            i.area = i.area || i.Area || '';
                            i.tipo = i.tipoConexion;
                            i.modPor = i.modificadoPor;
                            i.vlan = i.vlanId;
                        });
                    }

                    cambioPlanta();

                } catch (error) {
                    console.error("Error al sincronizar con el servidor", error);
                }
            }

            // --- LÓGICA DE NOTIFICACIONES INTELIGENTES ---

            function verificarNuevosLogs() {
                if (historialLogs.length === 0) return;

                // Obtenemos el ID del registro más reciente (el primero de la lista)
                const ultimoIdBase = historialLogs[0].idLog || historialLogs[0].IdLog;

                // Consultamos qué ID fue el último que este navegador marcó como "visto"
                const ultimoVisto = localStorage.getItem('ultimo_log_visto_id');

                // Si el ID en la base es mayor al que tenemos guardado, hay movimientos nuevos
                if (!ultimoVisto || parseInt(ultimoIdBase) > parseInt(ultimoVisto)) {
                    encenderAlertaLog();
                }
            }

            function encenderAlertaLog() {
                let btn = $('#btnLog');
                let badge = $('#badgeLog');
                btn.removeClass('btn-outline-light').addClass('btn-log-alert');
                badge.removeClass('d-none');
            }

                function abrirLogMovimientos() {
                let btn = $('#btnLog');
                let badge = $('#badgeLog');

                btn.removeClass('btn-log-alert').addClass('btn-outline-light');
                badge.addClass('d-none');

                // MARCAR COMO VISTO
                if (historialLogs.length > 0) {
                    const ultimoId = historialLogs[0].idLog || historialLogs[0].IdLog;
                    localStorage.setItem('ultimo_log_visto_id', ultimoId);
                }

                // Limpiamos los filtros cada que se abre
                $('#filtroLogTexto').val('');
                $('#filtroLogFecha').val('');
                $('#filtroLogPlanta').val('');

                renderLogs();
                modalLog.show();
            }

            // --- LÓGICA DE REGISTRO Y RENDER ---

            async function registrarEnLog(ip, accion) {
                let fechaActual = new Date().toLocaleString('es-MX', { dateStyle: 'short', timeStyle: 'short' });

                let nuevoLog = {
                    Fecha: fechaActual,
                    Ip: ip,
                    Accion: accion
                };

                try {
                    await fetch('@Url.Action("AddLogRed", "InventariosSistemas")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(nuevoLog)
                    });

                    const responseLogs = await fetch('@Url.Action("GetLogsRed", "InventariosSistemas")');
                    const dataLogs = await responseLogs.json();

                    if (dataLogs.ok) {
                        historialLogs = dataLogs.logs;
                        renderLogs();
                        // Alerta para todos (se activará en el siguiente refresh de otros usuarios)
                        encenderAlertaLog();
                    }
                } catch(e) {
                    console.error("No se pudo guardar el log en el servidor.", e);
                }
            }

                function renderLogs() {
                //  filtros
                let texto = ($('#filtroLogTexto').val() || '').toLowerCase();
                let fDate = $('#filtroLogFecha').val(); 
                let fPlanta = $('#filtroLogPlanta').val();

                let html = '';

                historialLogs.forEach(log => {
                    let dFechaStr = log.fecha || log.Fecha || '';
                    let dIp = log.ip || log.Ip || '';
                    let dAccion = log.accion || log.Accion || '';
                    let dUsu = log.usuario || log.Usuario || '';

                    let ipInfo = baseIPs.find(i => i.ip === dIp);
                    let plantaIp = ipInfo ? ipInfo.planta : 'N/A';

                    // --- Filtro Planta ---
                    if (fPlanta && plantaIp !== fPlanta) return;

                   // ---  Filtro Fecha ---
                if (fDate) {
                    let fechaSolo = dFechaStr.split(' ')[0].replace(',', '');
                    let partes = fechaSolo.split('/');

                    if (partes.length === 3) {
                        let anio = partes[2];
                        if (anio.length === 2) {
                            anio = '20' + anio;
                        }

                        let logDateISO = `${anio}-${partes[1].padStart(2, '0')}-${partes[0].padStart(2, '0')}`;

                        if (logDateISO !== fDate) return;
                    }
                }

                    let stringBusqueda = `${dFechaStr} ${dIp} ${dAccion} ${dUsu} ${plantaIp}`.toLowerCase();
                    if (texto && !stringBusqueda.includes(texto)) return;

                    html += `<tr>
                                <td class="px-3 text-muted">${dFechaStr}</td>
                                <td><span class="ip-badge py-1 px-2" style="font-size:0.75rem;">${dIp}</span></td>
                                <td class="fw-bold text-dark">${dAccion}</td>
                                <td><span class="badge bg-secondary px-2">${plantaIp}</span></td>
                                <td>${dUsu}</td>
                             </tr>`;
                });

                if (html === '') {
                    html = '<tr><td colspan="5" class="text-center py-4 text-muted">No se encontraron movimientos con esos filtros.</td></tr>';
                }

                $('#tbodyLogs').html(html);
            }


            function cambioPlanta() {
                let p = $('#selectPlanta').val();
                let vlansPlanta = baseVlans.filter(v => v.planta === p);
                let h = '';
                let opt = '';

                if (vlansPlanta.length > 0 && !vlansPlanta.some(v => v.id === vlanActiva)) {
                    vlanActiva = vlansPlanta[0].id;
                }

                vlansPlanta.forEach((v) => {
                    let active = v.id === vlanActiva ? 'active' : '';
                    h += `<li class="nav-item"><button class="nav-link ${active}" data-vlan-id="${v.id}" onclick="cambiarVlan('${v.id}')">${v.nombre}</button></li>`;
                    opt += `<option value="${v.id}">${v.nombre}</option>`;
                });

                $('#vlanTabs').html(h || '<li class="nav-item"><span class="nav-link text-muted">Sin VLANs configuradas</span></li>');
                $('#inputNuevaVlan').html(opt);
                renderTabla();
            }

            function cambiarVlan(vlanId) {
                vlanActiva = vlanId;
                $('.nav-tabs .nav-link').removeClass('active');
                $(`.nav-tabs .nav-link[data-vlan-id="${vlanId}"]`).addClass('active');
                renderTabla();
            }

            function abrirModalVlan() {
                let p = $('#selectPlanta option:selected').text();
                $('#vlanPlantaText').val(p);
                $('#inVlanId').val('');
                $('#inVlanNombre').val('');
                modalVlanObj.show();
            }

            async function guardarNuevaVlan() {
                let p = $('#selectPlanta').val();
                let idVlan = $('#inVlanId').val().trim();
                let nomRaw = $('#inVlanNombre').val().trim();

                if(!idVlan || !nomRaw) { alert("Completa el ID y el Nombre de la VLAN."); return; }

                let nombreFormateado = `VLAN ${idVlan} (${nomRaw})`;

                try {
                    const url = `@Url.Action("GuardarVlan", "InventariosSistemas")` +
                                `?planta=${encodeURIComponent(p)}` +
                                `&id=${encodeURIComponent(idVlan)}` +
                                `&nombre=${encodeURIComponent(nombreFormateado)}`;

                    const response = await fetch(url, { method: 'POST' });
                    const data = await response.json();

                    if (data.ok) {
                        modalVlanObj.hide();
                        vlanActiva = idVlan;
                        await cargarTodoDesdeServidor();
                        alert("VLAN creada exitosamente.");
                    } else {
                        alert("Error del servidor: " + data.mensaje);
                    }
                } catch (error) {
                    alert("Error de comunicación: " + error.message);
                }
            }

                    function renderTabla() {
                    let plantaActiva = $('#selectPlanta').val();
                    let textoFiltro = ($('#buscadorIP').val() || '').toLowerCase();
                    let estatusFiltro = $('#filtroEstatus').val();
                    let tbody = '';

                    let filtrados = baseIPs.filter(i => {
                        let coincidePlanta = i.planta === plantaActiva;
                        let coincideVlan = i.vlan === vlanActiva;
                        let eq = (i.equipo || '').toLowerCase();
                        let ip = (i.ip || '').toLowerCase();
                        let coincideTexto = !textoFiltro || ip.includes(textoFiltro) || eq.includes(textoFiltro);

                        let estaLibre = !i.equipo || i.equipo.trim() === '';
                        let coincideEstatus = true;
                        if (estatusFiltro === "DISPONIBLE") coincideEstatus = estaLibre;
                        if (estatusFiltro === "ASIGNADO") coincideEstatus = !estaLibre;

                        return coincidePlanta && coincideVlan && coincideTexto && coincideEstatus;
                    });
                    filtrados.sort((a, b) => {
                let numA = (a.ip || "0.0.0.0").split('.').reduce((acc, octeto) => acc * 256 + parseInt(octeto || 0), 0);
                let numB = (b.ip || "0.0.0.0").split('.').reduce((acc, octeto) => acc * 256 + parseInt(octeto || 0), 0);
                return numA - numB;
            });
                    // --- LÓGICA DEL CONTADOR ---
                    let asignadas = filtrados.filter(x => x.equipo && x.equipo.trim() !== '').length;
                    let disponibles = filtrados.length - asignadas;

                    let htmlContador = `
                        <span class="me-3"><i class="bi bi-list-ul"></i> Total: ${filtrados.length}</span>
                        <span class="text-success me-3"><i class="bi bi-check-circle"></i> Disponibles: ${disponibles}</span>
                        <span class="text-primary"><i class="bi bi-pc-display"></i> Asignadas: ${asignadas}</span>
                    `;
                    $('#contadorResultados').html(htmlContador);
                    // ---------------------------

                    if(filtrados.length === 0) {
                        $('#tbodyIPs').html('<tr><td colspan="6" class="text-center py-4 text-muted">No se encontraron registros con los filtros aplicados.</td></tr>');
                        return;
                    }

                    filtrados.forEach(i => {
                let estaLibre = !i.equipo || i.equipo.trim() === '';
                let equipoDisplay = estaLibre ? '<span class="badge-disponible">DISPONIBLE</span>' : `<b>${i.equipo}</b>`;

                let usuarioAreaDisplay = '<span class="text-muted small">-</span>';
                if (i.usuario || i.area) {
                    let extraInfo = [];
                    if (i.usuario) extraInfo.push(`<div class="text-dark fw-bold" style="font-size:0.8rem;"><i class="bi bi-person text-muted"></i> ${i.usuario}</div>`);
                    if (i.area) extraInfo.push(`<div class="text-muted" style="font-size:0.75rem;"><i class="bi bi-building"></i> ${i.area}</div>`);
                    usuarioAreaDisplay = extraInfo.join('');
                }

                let badgeTipo = '-';
                if(i.tipo === 'Cable') badgeTipo = '<span class="tipo-cable"><i class="bi bi-ethernet"></i> Cable</span>';
                if(i.tipo === 'WiFi') badgeTipo = '<span class="tipo-wifi"><i class="bi bi-wifi"></i> WiFi</span>';

                tbody += `
                <tr>
                    <td><span class="ip-badge ip-clickable" onclick="verHistorialEspecifico('${i.ip}')">${i.ip}</span></td>
                    <td>${equipoDisplay}</td>
                    <td>${usuarioAreaDisplay}</td> <td>${badgeTipo}</td>
                    <td>
                        <small class="text-muted d-block" style="font-size:0.7rem;">Alta: ${i.fAlta}</small>
                        <small class="fw-bold d-block" style="font-size:0.7rem;">Mod: ${i.fMod}</small>
                    </td>
                    <td><span class="text-muted small">${i.modPor}</span></td>
                               // En renderTabla(), alrededor de la línea 1177, cambia:
            <td class="text-center">
                <div class="d-flex flex-wrap justify-content-center gap-1">
                    ${permisosIPs.puedeEscribir ? `
                        <button class="btn-sm-action fw-bold" onclick="abrirEdicion(${i.id})">Editar</button>
                        <button class="btn-sm-action fw-bold text-danger border-danger" onclick="eliminarIP(${i.id}, '${i.ip}')" title="Eliminar IP">
                            <i class="bi bi-trash3"></i>
                        </button>
                    ` : ''}
                </div>
            </td>

                </tr>`;
            });
            $('#tbodyIPs').html(tbody);
                }

            function abrirNuevaIP() {
                modoCreacion = true;
                $('#tituloModalIP').text("Registrar Nueva IP");
                $('#divDisplayIP').addClass('d-none');
                $('#divConfigNuevaIP').removeClass('d-none');
                $('#btnLiberarIP').hide();
                $('#inputNuevaIP').val('');
                $('#inputNuevaPlanta').val($('#selectPlanta option:selected').text());
                if (baseVlans.filter(v => v.planta === $('#selectPlanta').val()).length === 0) {
                    alert("Primero debes crear una VLAN para esta planta.");
                    return;
                }
                $('#inputNuevaVlan').val(vlanActiva);
                $('#editEquipo').val('');
                $('#editUsuarioIP').val('');
                $('#editAreaIP').val('');
                $('#editTipo').val('-');
                $('#editNotas').val('');
                modalEditar.show();
            }

            function abrirEdicion(id) {
                modoCreacion = false;
                $('#tituloModalIP').text("Asignar Dirección IP");
                $('#divConfigNuevaIP').addClass('d-none');
                $('#divDisplayIP').removeClass('d-none');
                $('#btnLiberarIP').show();
                let ipObj = baseIPs.find(x => x.id === id);
                $('#editIdIP').val(ipObj.id);
                $('#editIPDisplay').text(ipObj.ip);
                $('#editEquipo').val(ipObj.equipo);
                $('#editUsuarioIP').val(ipObj.usuario || '');
                $('#editAreaIP').val(ipObj.area || '');
                $('#editTipo').val(ipObj.tipo);
                $('#editNotas').val('');
                if(!ipObj.equipo || ipObj.equipo.trim() === '') $('#btnLiberarIP').hide();
                $('#modalEditarIP .btn-brand').attr('data-id-editar', id);
                modalEditar.show();
            }

            async function guardarIP() {
                let equipo = $('#editEquipo').val().trim();
                let tipo = $('#editTipo').val();
                let accionString = "";
                let ipParaValidar = "";

                let objEnvio = {
                    EquipoAsignado: equipo,
                    TipoConexion: tipo,
                    Observaciones: $('#editNotas').val(),
                    Usuario: $('#editUsuarioIP').val().trim(),
                    Area: $('#editAreaIP').val().trim()
                };

                // Determinar si es nueva o edición
                if (modoCreacion) {
                    let ipN = $('#inputNuevaIP').val().trim();
                    if(ipN === "") { alert("Por favor ingresa la dirección IP."); return; }
                    const regexIP = /^(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$/;
                    if (!regexIP.test(ipN)) { alert("Formato de IP inválido."); return; }

                    ipParaValidar = ipN;
                    objEnvio.Id = 0;
                    objEnvio.Planta = $('#selectPlanta').val();
                    objEnvio.VlanId = $('#inputNuevaVlan').val();
                    objEnvio.IpAddress = ipN;
                    accionString = `Registro de nueva IP. Asignado a: ${equipo || 'Libre'}`;
                } else {
                    let idEditando = $('#modalEditarIP .btn-brand').attr('data-id-editar');
                    let itemAntiguo = baseIPs.find(x => x.id == idEditando);
                    ipParaValidar = itemAntiguo.ip;
                    objEnvio.Id = idEditando;
                    objEnvio.Planta = itemAntiguo.planta;
                    objEnvio.VlanId = itemAntiguo.vlan;
                    objEnvio.IpAddress = itemAntiguo.ip;
                    accionString = equipo === "" ? `Se dejó la IP Disponible (Antes: ${itemAntiguo.equipo})` : `Actualizado. Asignado a: ${equipo}`;
                }

                const btn = document.getElementById('btnGuardarIP');
                const btnOriginalText = btn.innerHTML;

                try {
                    let requierePing = modoCreacion || (!modoCreacion && equipo === "");

                    if (requierePing) {
                        btn.disabled = true;
                        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Verificando Red...';

                        const resPing = await fetch(`@Url.Action("VerificarPing", "InventariosSistemas")?ipAddress=${ipParaValidar}`);
                        const dataPing = await resPing.json();

                        if (dataPing.ok && dataPing.responde) {
                            btn.disabled = false;
                            btn.innerHTML = btnOriginalText;

                            if (equipo === "") {
                                alert(`OPERACIÓN RECHAZADA (Ping: ${dataPing.tiempoMs}ms)\n\nLa IP ${ipParaValidar} responde en la red. No se puede dejar libre.`);
                                return;
                            } else {
                                let continuar = confirm(`ADVERTENCIA (Ping: ${dataPing.tiempoMs}ms)\n\nLa IP ${ipParaValidar} ya responde. ¿Registrar de todos modos?`);
                                if (!continuar) return;
                                accionString += " [Forzado con advertencia de red]";
                            }
                        }
                    }

                    btn.disabled = true;
                    btn.innerHTML = "Guardando...";

                    const res = await fetch('@Url.Action("GuardarIP", "InventariosSistemas")', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(objEnvio)
                    });

                    const data = await res.json();
                    if (data.ok) {
                        await registrarEnLog(objEnvio.IpAddress, accionString);
                        modalEditar.hide();
                        cargarTodoDesdeServidor();
                    } else { alert(data.mensaje); }

                } catch(e) {
                    alert("Error: " + e.message);
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = btnOriginalText;
                }
            }

            async function liberarIP() {
                let idEditando = $('#modalEditarIP .btn-brand').attr('data-id-editar');
                let item = baseIPs.find(x => x.id == idEditando);

                if(confirm(`¿Liberar la IP ${item.ip}? El sistema verificará que esté disponible.`)){
                    const btn = document.getElementById('btnLiberarIP');
                    const btnText = btn.innerHTML;

                    try {
                        btn.disabled = true;
                        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Haciendo Ping...';

                        const resPing = await fetch(`@Url.Action("VerificarPing", "InventariosSistemas")?ipAddress=${item.ip}`);
                        const dataPing = await resPing.json();

                        if (dataPing.ok && dataPing.responde) {
                            alert(`OPERACIÓN RECHAZADA:\n\nEl equipo respondió en ${dataPing.tiempoMs}ms. No se puede marcar como disponible.`);
                            return;
                        }

                        btn.innerHTML = "Liberando...";
                        let objEnvio = {
                            Id: item.id,
                            Planta: item.planta,
                            IpAddress: item.ip,
                            VlanId: item.vlan,
                            EquipoAsignado: "",
                            TipoConexion: "-",
                            Observaciones: "Liberación validada (Ping fallido)",
                            Usuario: "",
                            Area: ""
                        };

                        const resGuardar = await fetch('@Url.Action("GuardarIP", "InventariosSistemas")', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(objEnvio)
                        });

                        if(resGuardar.ok) {
                            await registrarEnLog(item.ip, `Liberación de IP (Antes: ${item.equipo})`);
                            modalEditar.hide();
                            cargarTodoDesdeServidor();
                        }
                    } catch(e) {
                        alert("Error en validación: " + e.message);
                    } finally {
                        btn.disabled = false;
                        btn.innerHTML = btnText;
                    }
                }
            }

            function filtrarLog() {
                let v = $('#filtroLog').val().toLowerCase();
                $("#tablaLog tbody tr").filter(function() { $(this).toggle($(this).text().toLowerCase().indexOf(v) > -1) });
            }

            function verHistorialEspecifico(ip) {
                $('#lblHistorialIP').text(ip);
                let logsFiltrados = historialLogs.filter(log => (log.ip || log.Ip) === ip);
                let html = '';
                if (logsFiltrados.length === 0) {
                    html = '<tr><td colspan="3" class="text-center py-4 text-muted">Sin historial.</td></tr>';
                } else {
                    logsFiltrados.forEach(log => {
                        html += `<tr><td class="px-3 text-muted">${log.fecha || log.Fecha}</td><td class="fw-bold">${log.accion || log.Accion}</td><td>${log.usuario || log.Usuario}</td></tr>`;
                    });
                }
                $('#tbodyHistorialIP').html(html);
                new bootstrap.Modal(document.getElementById('modalHistorialIP')).show();
            }

            async function eliminarIP(id, direccionIP) {
                   if (!confirm(` ALERTA ⚠\n\n¿Estás seguro de que deseas eliminar  la IP ${direccionIP} del sistema?.`)) {
                       return;
                   }

                   try {
                       // Cambiamos el cursor o mostramos que está pensando
                       document.body.style.cursor = 'wait';

                       const resPing = await fetch(`@Url.Action("VerificarPing", "InventariosSistemas")?ipAddress=${direccionIP}`);
                       const dataPing = await resPing.json();

                       if (dataPing.ok && dataPing.responde) {
                           document.body.style.cursor = 'default';
                           alert(` ELIMINACIÓN RECHAZADA \n\nLa IP ${direccionIP} está ACTIVA y respondió en la red (Ping: ${dataPing.tiempoMs}ms).\n\nNo puedes borrar un registro de IP que está siendo utilizado físicamente por un equipo.`);
                           return; // Detenemos la eliminación
                       }

                       const res = await fetch(`@Url.Action("EliminarIP", "InventariosSistemas")?id=${id}`, { method: 'POST' });
                       const data = await res.json();

                       if (data.ok) {
                           // Guardamos el rastro en el Log General
                           await registrarEnLog(direccionIP, `Eliminación permanente del registro IP`);

                           // Recargamos la información desde cero
                           await cargarTodoDesdeServidor();
                           alert("✅ " + data.mensaje);
                       } else {
                           alert("Error: " + data.mensaje);
                       }
                   } catch (error) {
                       alert("Error de conexión al intentar eliminar: " + error.message);
                   } finally {
                       document.body.style.cursor = 'default';
                   }
               }
        </script>
}
