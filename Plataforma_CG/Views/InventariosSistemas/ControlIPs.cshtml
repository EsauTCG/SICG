            function topoRenderZones() {
                const host = document.getElementById('topoZones');
                const stage = document.getElementById('topoStage');
                const world = document.getElementById('topoWorld');
                if (!host || !stage || !world) return;

                stage.style.width = `${topoModel.width}px`;
                stage.style.height = `${topoModel.height}px`;

                host.innerHTML = topoModel.zones.map(zone => `
                    <div class="topologia-vlan-zone"
                         style="left:${zone.x}px;top:${zone.y}px;width:${zone.w}px;height:${zone.h}px;--zone-color:${zone.color}">
                        <div class="topologia-vlan-zone-title">${topoEsc(zone.title)}</div>
                    </div>
                `).join('');
            }

            function topoRenderNodes() {
                const host = document.getElementById('topoNodes');
                if (!host) return;

                host.innerHTML = topoModel.nodes.map(node => {
                    const pos = topoPositions[node.id] || { x: node.x, y: node.y };
                    const selected = node.id === topoSelectedId ? 'selected' : '';
                    const classes = [
                        'topologia-node',
                        selected,
                        node.infrastructure ? 'infrastructure' : '',
                        node.kind === 'vlan' ? 'vlan' : '',
                        node.kind === 'ap' ? 'access-point' : '',
                        node.role ? `role-${node.role}` : '',
                        node.free ? 'free-ip' : ''
                    ].filter(Boolean).join(' ');

                    const status = node.kind === 'device'
                        ? (topoStatus[node.id] || node.status || 'unknown')
                        : (node.status || 'online');

                    return `
                        <div class="${classes}"
                             data-topo-node="${topoEsc(node.id)}"
                             style="left:${pos.x}px;top:${pos.y}px;--node-color:${node.color || '#42d6ff'}"
                             title="${topoEsc(node.title)}">
                            <span class="topologia-node-status ${topoEsc(status)}"></span>
                            <div class="topologia-node-icon"><i class="bi ${topoEsc(node.icon)}"></i></div>
                            <strong>${topoEsc(node.title)}</strong>
                            <small>${topoEsc(node.subtitle)}</small>
                        </div>
                    `;
                }).join('');

                host.querySelectorAll('[data-topo-node]').forEach(el => {
                    el.addEventListener('pointerdown', topoPointerDown);
                    el.addEventListener('click', ev => {
                        if (topoDrag?.moved) return;
                        topoSelectedId = el.dataset.topoNode;
                        topoRenderNodes();
                        topoRenderInspector();
                    });
                    el.addEventListener('dblclick', () => {
                        const node = topoModel.nodes.find(n => n.id === el.dataset.topoNode);
                        if (node?.kind === 'device' && node.ipId) {
                            topoEditarIP(node.ipId);
                        }
                    });
                });
            }

            function topoNodeCenter(nodeId) {
                const node = topoModel.nodes.find(n => n.id === nodeId);
                const pos = topoPositions[nodeId];
                if (!node || !pos) return null;

                const width = node.kind === 'vlan' ? 132 : (node.infrastructure ? 126 : 112);
                const height = node.kind === 'vlan' || node.infrastructure ? 88 : 82;

                return {
                    x: pos.x + width / 2,
                    y: pos.y + height / 2
                };
            }

            function topoRenderEdges() {
                const svg = document.getElementById('topoLinks');
                if (!svg) return;

                svg.setAttribute('viewBox', `0 0 ${topoModel.width} ${topoModel.height}`);
                svg.setAttribute('width', topoModel.width);
                svg.setAttribute('height', topoModel.height);

                const mostrarLabels = !!document.getElementById('topoEtiquetasEnlaces')?.checked;

                svg.innerHTML = topoModel.edges.map(edge => {
                    const a = topoNodeCenter(edge.from);
                    const b = topoNodeCenter(edge.to);
                    if (!a || !b) return '';

                    const dx = Math.max(60, Math.abs(b.x - a.x) * .42);
                    const d = `M ${a.x} ${a.y} C ${a.x + dx} ${a.y}, ${b.x - dx} ${b.y}, ${b.x} ${b.y}`;
                    const targetStatus = topoStatus[edge.to] || '';
                    const statusClass = targetStatus === 'offline' ? 'offline' : '';
                    const typeClass = ({
                        wifi: 'wifi',
                        backbone: 'backbone',
                        vpn: 'vpn',
                        ha: 'ha',
                        'wan-secondary': 'wan-secondary'
                    })[edge.type] || '';
                    const labelX = (a.x + b.x) / 2;
                    const labelY = (a.y + b.y) / 2 - 6;

                    return `
                        <path class="topologia-link ${typeClass} ${statusClass}" d="${d}"></path>
                        ${mostrarLabels && edge.label
                            ? `<text class="topologia-link-label" x="${labelX}" y="${labelY}" text-anchor="middle">${topoEsc(edge.label)}</text>`
                            : ''}
                    `;
                }).join('');
            }

