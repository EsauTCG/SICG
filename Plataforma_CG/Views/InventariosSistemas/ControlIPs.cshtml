            /* =========================================================
               FULLSCREEN SEGURO DE TOPOLOGÍA
               ========================================================= */

            function topoAjustarAlturaViewport() {
                const modal = document.getElementById('modalTopologiaRed');
                if (!modal) return;

                const altura = Math.max(
                    480,
                    window.visualViewport?.height ||
                    window.innerHeight ||
                    document.documentElement.clientHeight
                );

                modal.style.setProperty('--topo-viewport-height', `${Math.round(altura)}px`);
            }

            async function topoToggleFullscreen() {
                /*
                 * Fullscreen TOTAL:
                 * se aplica al documento completo, no solamente al modal.
                 * De esta forma desaparecen la barra del navegador y los
                 * límites visuales del layout mientras la topología está abierta.
                 */
                const root = document.documentElement;
                const actual = document.fullscreenElement || document.webkitFullscreenElement;

                try {
                    if (!actual) {
                        if (root.requestFullscreen) {
                            await root.requestFullscreen();
                        } else if (root.webkitRequestFullscreen) {
                            root.webkitRequestFullscreen();
                        }
                    } else {
                        if (document.exitFullscreen) {
                            await document.exitFullscreen();
                        } else if (document.webkitExitFullscreen) {
                            document.webkitExitFullscreen();
                        }
                    }
                } catch (error) {
                    console.warn('No fue posible activar pantalla completa total:', error);
                }

                topoActualizarBotonFullscreen();
            }

            function topoActualizarBotonFullscreen() {
                const modal = document.getElementById('modalTopologiaRed');
                const btnToolbar = document.getElementById('btnTopoFullscreen');
                const btnHeader = document.getElementById('btnTopoFullscreenHeader');
                if (!modal) return;

                const activo = !!(
                    document.fullscreenElement ||
                    document.webkitFullscreenElement
                );

                if (btnToolbar) {
                    btnToolbar.innerHTML = activo
                        ? '<i class="bi bi-fullscreen-exit me-1"></i> Salir de fullscreen'
                        : '<i class="bi bi-arrows-fullscreen me-1"></i> Fullscreen total';
                }

                if (btnHeader) {
                    btnHeader.innerHTML = activo
                        ? '<i class="bi bi-fullscreen-exit"></i><span>Salir de fullscreen</span>'
                        : '<i class="bi bi-arrows-fullscreen"></i><span>Fullscreen total</span>';
                }
            }

            async function topoSalirFullscreenSiAplica() {
                const actual = document.fullscreenElement || document.webkitFullscreenElement;
                if (!actual) return;

                try {
                    if (document.exitFullscreen) {
                        await document.exitFullscreen();
                    } else if (document.webkitExitFullscreen) {
                        document.webkitExitFullscreen();
                    }
                } catch (error) {
                    console.warn('No fue posible cerrar pantalla completa total:', error);
                }
            }

            window.addEventListener('resize', topoAjustarAlturaViewport);
            window.visualViewport?.addEventListener('resize', topoAjustarAlturaViewport);

            document.addEventListener('fullscreenchange', () => {
                topoActualizarBotonFullscreen();
                topoAjustarAlturaViewport();
                setTimeout(() => {
