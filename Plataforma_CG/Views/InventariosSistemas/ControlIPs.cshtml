                <span class="network-operation-copy">
                    <strong>Nueva VLAN</strong>
                    <small>Crea segmentos por planta para servidores, oficinas o producción.</small>
                </span>
                <span class="network-operation-action">
                    <span>Crear segmento</span>
                    <i class="bi bi-plus-circle-fill"></i>
                </span>
            </button>

            <button type="button"
                    class="network-operation-card operation-register"
