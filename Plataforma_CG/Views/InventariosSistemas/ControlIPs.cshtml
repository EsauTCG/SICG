            async function eliminarIP(id, direccionIP) {
                   if (!confirm(` ALERTA ⚠\n\n¿Estás seguro de que deseas eliminar  la IP ${direccionIP} del sistema?.`)) {
                       return;
                   }

                   try {
                       // Cambiamos el cursor o mostramos que está pensando
                       document.body.style.cursor = 'wait';

                       const resPing = await fetch(`@Url.Action("VerificarPing", "InventariosSistemas")?ipAddress=${direccionIP}`);
                       const dataPing = await resPing.json();

                       if (dataPing.ok && dataPing.responde) {
                           document.body.style.cursor = 'default';
                           alert(` ELIMINACIÓN RECHAZADA \n\nLa IP ${direccionIP} está ACTIVA y respondió en la red (Ping: ${dataPing.tiempoMs}ms).\n\nNo puedes borrar un registro de IP que está siendo utilizado físicamente por un equipo.`);
                           return; // Detenemos la eliminación
                       }

                       const res = await fetch(`@Url.Action("EliminarIP", "InventariosSistemas")?id=${id}`, { method: 'POST' });
                       const data = await res.json();

                       if (data.ok) {
                           // Guardamos el rastro en el Log General
                           await registrarEnLog(direccionIP, `Eliminación permanente del registro IP`);

                           // Recargamos la información desde cero
                           await cargarTodoDesdeServidor();
                           alert("✅ " + data.mensaje);
                       } else {
                           alert("Error: " + data.mensaje);
                       }
                   } catch (error) {
                       alert("Error de conexión al intentar eliminar: " + error.message);
                   } finally {
                       document.body.style.cursor = 'default';
                   }
               }
        

            /* =========================================================
               TOPOLOGÍA AUTOMÁTICA DE RED
               Utiliza baseVlans y baseIPs ya cargados por esta pantalla.
               ========================================================= */

            const TOPO_STORAGE_PREFIX = 'SIGO_TOPOLOGIA_RED_V2_';
            const TOPO_CONFIG_PREFIX = 'SIGO_TOPOLOGIA_WAN_VPN_V1_';
            let topoNetworkConfig = null;
            let topoModalObj = null;
            let topoModel = { nodes: [], edges: [], zones: [], width: 1500, height: 850 };
            let topoPositions = {};
            let topoStatus = {};
            let topoSelectedId = null;
            let topoDrag = null;
            let topoZoom = 1;
            let topoPingEnCurso = false;

            function topoEsc(value) {
                return String(value == null ? '' : value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function topoSafeId(value) {
                return String(value == null ? '' : value).replace(/[^a-zA-Z0-9_-]/g, '_');
            }

            function topoColorVlan(vlanId) {
                const colors = [
                    '#38bdf8', '#22c55e', '#f59e0b', '#a78bfa',
                    '#f472b6', '#fb7185', '#2dd4bf', '#60a5fa',
                    '#e879f9', '#84cc16', '#f97316', '#14b8a6'
                ];

                let hash = 0;
                const txt = String(vlanId || '0');
                for (let i = 0; i < txt.length; i++) {
                    hash = ((hash << 5) - hash) + txt.charCodeAt(i);
                    hash |= 0;
                }

                return colors[Math.abs(hash) % colors.length];
            }


            function topoTextoEquipo(item) {
                return [
                    item?.equipo,
                    item?.usuario,
                    item?.area,
                    item?.tipo
                ].filter(Boolean).join(' ').toLowerCase();
            }

            function topoEsFirewall(item) {
                const txt = topoTextoEquipo(item);
                return [
                    'fortinet',
                    'fortigate',
                    'firewall',
                    'palo alto',
                    'sophos',
                    'sonicwall',
                    'checkpoint',
                    'check point'
                ].some(token => txt.includes(token));
            }

            function topoEsCore(item) {
                const txt = topoTextoEquipo(item);
                const esSwitch = txt.includes('switch') || txt.includes('core');
                const esPrincipal = [
                    'core',
                    'principal',
                    'distribucion',
                    'distribución',
                    'distribution',
                    'backbone'
                ].some(token => txt.includes(token));

                return esSwitch && esPrincipal && !topoEsFirewall(item);
            }

            function topoRegistrosAsignadosPlanta(planta) {
                return baseIPs.filter(item =>
                    String(item.planta) === String(planta) &&
                    !!String(item.equipo || '').trim()
                );
            }

            function topoFirewallsPlanta(planta) {
                return topoRegistrosAsignadosPlanta(planta).filter(topoEsFirewall);
            }

            function topoCorePlanta(planta) {
                return topoRegistrosAsignadosPlanta(planta).find(topoEsCore) || null;
            }

            function topoConfigKey(planta) {
                return TOPO_CONFIG_PREFIX + String(planta || 'SIN_PLANTA').toUpperCase();
            }

            function topoConfigDefault(planta, plantas = []) {
                const peer = plantas.find(p => String(p) !== String(planta)) || '';

                return {
                    internetCount: 1,
                    isp1Name: 'INTERNET 1',
                    isp1Detail: 'WAN principal',
                    isp2Name: 'INTERNET 2',
                    isp2Detail: 'WAN respaldo',
                    vpnEnabled: false,
                    vpnPeer: peer
                };
            }

            function topoParseJsonSeguro(value, fallback) {
                try {
                    if (!value) return fallback;
                    const parsed = typeof value === 'string'
                        ? JSON.parse(value)
                        : value;

                    return parsed && typeof parsed === 'object'
                        ? parsed
                        : fallback;
                } catch {
                    return fallback;
                }
            }

            function topoTokenAntiforgery() {
                return document.querySelector(
                    'input[name="__RequestVerificationToken"]'
                )?.value || '';
            }

            async function topoSolicitarEstadoServidor(planta, plantas = []) {
                const fallbackConfig = topoConfigDefault(planta, plantas);
                const fallbackPositions = {};

                try {
                    const url = '@Url.Action("ObtenerTopologiaRed", "InventariosSistemas")'
                        + '?planta=' + encodeURIComponent(planta);

                    const response = await fetch(url, {
                        method: 'GET',
                        headers: {
                            'Accept': 'application/json'
                        },
                        cache: 'no-store'
                    });

                    const data = await response.json();

                    if (!response.ok || !data.ok) {
                        throw new Error(data.mensaje || 'No fue posible consultar la topología.');
                    }

                    return {
                        existe: !!data.existe,
                        config: {
                            ...fallbackConfig,
                            ...topoParseJsonSeguro(data.configuracionJson, {})
                        },
                        positions: topoParseJsonSeguro(
                            data.posicionesJson,
                            fallbackPositions
                        ),
                        fechaModificacion: data.fechaModificacion || null,
                        modificadoPor: data.modificadoPor || ''
                    };
                } catch (error) {
                    console.warn(
                        'SQL no disponible; se utilizará respaldo local:',
                        error
                    );

                    let config = fallbackConfig;
                    let positions = fallbackPositions;

                    try {
                        const localConfig = localStorage.getItem(
                            topoConfigKey(planta)
                        );
                        const localPositions = localStorage.getItem(
                            topoStorageKey(planta)
                        );

                        config = {
                            ...fallbackConfig,
                            ...topoParseJsonSeguro(localConfig, {})
                        };
                        positions = topoParseJsonSeguro(
                            localPositions,
                            fallbackPositions
                        );
                    } catch {
                        // Se conservan los valores predeterminados.
                    }

                    return {
                        existe: false,
                        config,
                        positions,
                        fechaModificacion: null,
                        modificadoPor: '',
                        usandoRespaldoLocal: true
                    };
                }
            }

            async function topoCargarEstadoServidor(planta, plantas = []) {
                const estado = await topoSolicitarEstadoServidor(
                    planta,
                    plantas
                );

                topoNetworkConfig = estado.config;
                topoPositions = estado.positions;

                if (!topoPositions || typeof topoPositions !== 'object') {
                    topoPositions = {};
                }

                return estado;
            }

            async function topoGuardarEstadoServidor(
                planta,
                config,
                positions,
                silencioso = false
            ) {
                const payload = {
                    planta: String(planta || '').trim(),
                    configuracionJson: JSON.stringify(config || {}),
                    posicionesJson: JSON.stringify(positions || {})
                };

                try {
                    const response = await fetch(
                        '@Url.Action("GuardarTopologiaRed", "InventariosSistemas")',
                        {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'Accept': 'application/json',
                                'RequestVerificationToken': topoTokenAntiforgery()
                            },
                            body: JSON.stringify(payload)
                        }
                    );

                    const data = await response.json();

                    if (!response.ok || !data.ok) {
                        throw new Error(data.mensaje || 'No se pudo guardar en SQL Server.');
                    }

                    /*
                     * Se conserva una copia local solamente como respaldo.
                     * SQL Server es la fuente oficial compartida.
                     */
                    localStorage.setItem(
                        topoConfigKey(planta),
                        JSON.stringify(config || {})
                    );
                    localStorage.setItem(
                        topoStorageKey(planta),
                        JSON.stringify(positions || {})
                    );

                    if (!silencioso) {
                        alert(
                            'Configuración guardada en SQL Server.\n\n' +
                            'Ya estará disponible desde cualquier computadora.'
                        );
                    }

                    return true;
                } catch (error) {
                    console.error('Error guardando topología en SQL:', error);

                    /*
                     * El respaldo local evita perder el trabajo si el servidor
                     * está temporalmente fuera de línea.
                     */
                    try {
                        localStorage.setItem(
                            topoConfigKey(planta),
                            JSON.stringify(config || {})
                        );
                        localStorage.setItem(
                            topoStorageKey(planta),
                            JSON.stringify(positions || {})
                        );
                    } catch {
                        // No se pudo usar tampoco el respaldo local.
                    }

                    if (!silencioso) {
                        alert(
                            'No se pudo guardar en SQL Server.\n\n' +
                            'La configuración quedó únicamente como respaldo local.\n\n' +
                            error.message
                        );
                    }

                    return false;
                }
            }

            function topoCargarConfiguracionRed(planta, plantas = []) {
                return topoNetworkConfig || topoConfigDefault(planta, plantas);
            }

            function topoPoblarConfiguracionRed(plantas = []) {
                const planta = document.getElementById('topoPlanta')?.value || '';
                const config =
                    topoNetworkConfig ||
                    topoConfigDefault(planta, plantas);

                const peerSelect = document.getElementById('topoVpnPeer');
                if (peerSelect) {
                    const remotas = plantas.filter(p => String(p) !== String(planta));
                    peerSelect.innerHTML = remotas.length
                        ? remotas.map(p => `<option value="${topoEsc(p)}">${topoEsc(p)}</option>`).join('')
                        : '<option value="">Sin otra planta</option>';
                    peerSelect.value = remotas.includes(config.vpnPeer)
                        ? config.vpnPeer
                        : (remotas[0] || '');
                }

                const setValue = (id, value) => {
                    const el = document.getElementById(id);
                    if (el) el.value = value ?? '';
                };

                setValue('topoInternetCount', String(config.internetCount || 1));
                setValue('topoISP1Nombre', config.isp1Name);
                setValue('topoISP1Detalle', config.isp1Detail);
                setValue('topoISP2Nombre', config.isp2Name);
                setValue('topoISP2Detalle', config.isp2Detail);

                const vpn = document.getElementById('topoVpnEnabled');
                if (vpn) vpn.checked = !!config.vpnEnabled;

                topoActualizarControlesWAN();
            }

            function topoActualizarControlesWAN() {
                const count = Number(document.getElementById('topoInternetCount')?.value || 1);
                const vpnEnabled = !!document.getElementById('topoVpnEnabled')?.checked;

                const isp2 = document.getElementById('topoISP2Group');
                const peer = document.getElementById('topoVpnPeerGroup');

                if (isp2) isp2.style.display = count >= 2 ? 'grid' : 'none';
                if (peer) peer.style.display = vpnEnabled ? 'block' : 'none';
            }

            async function topoGuardarConfiguracionRed() {
                const planta = document.getElementById('topoPlanta')?.value || '';
                const peer = document.getElementById('topoVpnPeer')?.value || '';

                topoNetworkConfig = {
                    internetCount: Math.max(
                        1,
                        Math.min(
                            2,
                            Number(
                                document.getElementById('topoInternetCount')?.value || 1
                            )
                        )
                    ),
                    isp1Name:
                        document.getElementById('topoISP1Nombre')?.value?.trim()
                        || 'INTERNET 1',
                    isp1Detail:
                        document.getElementById('topoISP1Detalle')?.value?.trim()
                        || 'WAN principal',
                    isp2Name:
                        document.getElementById('topoISP2Nombre')?.value?.trim()
                        || 'INTERNET 2',
                    isp2Detail:
                        document.getElementById('topoISP2Detalle')?.value?.trim()
                        || 'WAN respaldo',
                    vpnEnabled:
                        !!document.getElementById('topoVpnEnabled')?.checked,
                    vpnPeer: peer
                };

                const guardadoLocal = await topoGuardarEstadoServidor(
                    planta,
                    topoNetworkConfig,
                    topoPositions,
                    false
                );

                /*
                 * La relación VPN se guarda también en la planta remota,
                 * conservando su propia configuración WAN y sus posiciones.
                 */
                if (guardadoLocal && topoNetworkConfig.vpnEnabled && peer) {
                    const plantas = [...new Set([
                        ...baseVlans.map(v => String(v.planta || '').trim()),
                        ...baseIPs.map(i => String(i.planta || '').trim())
                    ].filter(Boolean))];

                    const estadoPeer = await topoSolicitarEstadoServidor(
                        peer,
                        plantas
                    );

                    const peerConfig = {
                        ...topoConfigDefault(peer, plantas),
                        ...estadoPeer.config,
                        vpnEnabled: true,
                        vpnPeer: planta
                    };

                    await topoGuardarEstadoServidor(
                        peer,
                        peerConfig,
                        estadoPeer.positions,
                        true
                    );
                }

                topoGenerar(true);
                await topoGuardarDiseno(true);
            }

            function topoCrearNodoDispositivo(item, options = {}) {
                const nodeId = options.id || `ip-${item.id}`;
                const role = options.role || '';

                return {
                    id: nodeId,
                    kind: 'device',
                    role,
                    title: String(item.equipo || '').trim() || options.fallbackTitle || 'EQUIPO',
                    subtitle: item.ip || item.ipAddress || options.subtitle || '',
                    icon: options.icon || topoIconoEquipo(item),
                    x: options.x || 0,
                    y: options.y || 0,
                    color: options.color || '#42d6ff',
                    vlanId: String(item.vlan || ''),
                    ipId: item.id,
                    ip: item.ip || item.ipAddress || '',
                    data: item,
                    status: topoStatus[nodeId] || 'unknown',
                    infrastructure: !!options.infrastructure,
                    remote: !!options.remote,
                    free: false
                };
            }

            function topoIconoEquipo(item) {
                const txt = `${item?.equipo || ''} ${item?.area || ''}`.toLowerCase();

                if (txt.includes('firewall') || txt.includes('fortigate') || txt.includes('palo alto')) return 'bi-shield-lock-fill';
                if (txt.includes('router') || txt.includes('gateway')) return 'bi-router-fill';
                if (txt.includes('switch')) return 'bi-hdd-network-fill';
                if (txt.includes('access point') || txt.includes('antena') || txt.includes('wifi') || txt.includes('ap-')) return 'bi-wifi';
                if (txt.includes('impresora') || txt.includes('printer') || txt.includes('zebra') || txt.includes('epson')) return 'bi-printer-fill';
                if (txt.includes('cámara') || txt.includes('camara') || txt.includes('cctv') || txt.includes('nvr') || txt.includes('dvr')) return 'bi-camera-video-fill';
                if (txt.includes('servidor') || txt.includes('server') || txt.includes('nas')) return 'bi-server';
                if (txt.includes('laptop') || txt.includes('notebook')) return 'bi-laptop-fill';
                if (txt.includes('teléfono') || txt.includes('telefono') || txt.includes('voip')) return 'bi-telephone-fill';
                if (txt.includes('tablet')) return 'bi-tablet-fill';
                if (txt.includes('báscula') || txt.includes('bascula')) return 'bi-speedometer2';
                if (txt.includes('checador') || txt.includes('biometrico') || txt.includes('biométrico')) return 'bi-fingerprint';
                if (txt.includes('ups') || txt.includes('nobreak') || txt.includes('no break')) return 'bi-battery-charging';
                return 'bi-pc-display-horizontal';
            }

            function topoNombreVlan(vlan) {
                return vlan?.nombre || `VLAN ${vlan?.id || ''}`;
            }

            function topoStorageKey(planta) {
                return TOPO_STORAGE_PREFIX + String(planta || 'SIN_PLANTA').toUpperCase();
            }

            async function topoCargarPosiciones(planta) {
                const plantas = [...new Set([
                    ...baseVlans.map(v => String(v.planta || '').trim()),
                    ...baseIPs.map(i => String(i.planta || '').trim())
                ].filter(Boolean))];

                return await topoCargarEstadoServidor(planta, plantas);
            }

            async function topoGuardarDiseno(silencioso = false) {
                const planta =
                    document.getElementById('topoPlanta')?.value
                    || $('#selectPlanta').val()
                    || 'TIF';

                return await topoGuardarEstadoServidor(
                    planta,
                    topoNetworkConfig || topoConfigDefault(planta),
                    topoPositions,
                    silencioso
                );
            }

            function topoPrepararModalEnBody() {
                const modalEl = document.getElementById('modalTopologiaRed');
                if (!modalEl) return null;

                /*
                 * Un padre con transform, overflow o position puede limitar
                 * un elemento fixed. Al colocarlo directamente en BODY,
                 * el modal usa el viewport completo sin tocar la vista actual.
                 */
                if (modalEl.parentElement !== document.body) {
                    document.body.appendChild(modalEl);
                }

                return modalEl;
            }

            async function abrirTopologiaRed() {
                const modalEl = topoPrepararModalEnBody();
                if (!modalEl) return;

                /*
                 * Como esta función nace directamente del clic del usuario,
                 * el navegador permite solicitar fullscreen para TODA la página.
                 * Si el navegador lo bloquea, el modal igualmente se abre.
                 */
                try {
                    const root = document.documentElement;
                    const actual = document.fullscreenElement || document.webkitFullscreenElement;

                    if (!actual) {
                        if (root.requestFullscreen) {
                            await root.requestFullscreen();
                        } else if (root.webkitRequestFullscreen) {
                            root.webkitRequestFullscreen();
                        }
                    }
                } catch (error) {
                    console.warn('El navegador no permitió fullscreen automático:', error);
                }

                topoAjustarAlturaViewport();
                topoModalObj = bootstrap.Modal.getOrCreateInstance(modalEl, {
                    backdrop: true,
                    keyboard: true,
                    focus: true
                });

                await topoPrepararSelectores();
                topoGenerar(false);
                topoModalObj.show();
                topoActualizarBotonFullscreen();
            }

            async function topoPrepararSelectores() {
                const plantaSelect = document.getElementById('topoPlanta');
                const vlanSelect = document.getElementById('topoVlan');
                if (!plantaSelect || !vlanSelect) return;

                const plantas = [...new Set([
                    ...baseVlans.map(v => String(v.planta || '').trim()),
                    ...baseIPs.map(i => String(i.planta || '').trim())
                ].filter(Boolean))].sort();

                const plantaActual =
                    $('#selectPlanta').val()
                    || plantas[0]
                    || 'TIF';

                plantaSelect.innerHTML = plantas
                    .map(
                        p => `<option value="${topoEsc(p)}">${topoEsc(p)}</option>`
                    )
                    .join('');

                plantaSelect.value = plantas.includes(plantaActual)
                    ? plantaActual
                    : (plantas[0] || '');

                plantaSelect.onchange = async () => {
                    topoLlenarVlans();

                    await topoCargarEstadoServidor(
                        plantaSelect.value,
                        plantas
                    );

                    topoPoblarConfiguracionRed(plantas);
                    topoGenerar(false);
                };

                vlanSelect.onchange = () => topoGenerar(false);

                document.getElementById('topoMostrarLibres').onchange =
                    () => topoGenerar(false);

                document.getElementById('topoEtiquetasEnlaces').onchange =
                    () => topoRenderEdges();

                topoLlenarVlans();

                await topoCargarEstadoServidor(
                    plantaSelect.value,
                    plantas
                );

                topoPoblarConfiguracionRed(plantas);
            }

            function topoLlenarVlans() {
                const planta = document.getElementById('topoPlanta')?.value || '';
                const select = document.getElementById('topoVlan');
                if (!select) return;

                const current = select.value;
                const vlans = baseVlans
                    .filter(v => String(v.planta) === String(planta))
                    .sort((a, b) => String(a.id).localeCompare(String(b.id), undefined, { numeric: true }));

                select.innerHTML = '<option value="">Todas las VLAN</option>' +
                    vlans.map(v => `<option value="${topoEsc(v.id)}">${topoEsc(topoNombreVlan(v))}</option>`).join('');

                if (vlans.some(v => String(v.id) === String(current))) {
                    select.value = current;
                }
            }

            function topoRegistrosVisibles() {
                const planta = document.getElementById('topoPlanta')?.value || '';
                const vlanFiltro = document.getElementById('topoVlan')?.value || '';
                const mostrarLibres = !!document.getElementById('topoMostrarLibres')?.checked;

                return baseIPs.filter(item => {
                    const mismaPlanta = String(item.planta) === String(planta);
                    const mismaVlan = !vlanFiltro || String(item.vlan) === String(vlanFiltro);
                    const asignado = !!String(item.equipo || '').trim();
                    return mismaPlanta && mismaVlan && (mostrarLibres || asignado);
                });
            }

            function topoVlansVisibles() {
                const planta = document.getElementById('topoPlanta')?.value || '';
                const vlanFiltro = document.getElementById('topoVlan')?.value || '';

                let vlans = baseVlans.filter(v => String(v.planta) === String(planta));

                if (vlanFiltro) {
                    vlans = vlans.filter(v => String(v.id) === String(vlanFiltro));
                }

                const vlanIdsIPs = [...new Set(
                    topoRegistrosVisibles().map(i => String(i.vlan || '')).filter(Boolean)
                )];

                vlanIdsIPs.forEach(id => {
                    if (!vlans.some(v => String(v.id) === id)) {
                        vlans.push({ id, planta, nombre: `VLAN ${id}` });
                    }
                });

                return vlans.sort((a, b) =>
                    String(a.id).localeCompare(String(b.id), undefined, { numeric: true })
                );
            }

            function topoGenerar(forzarAutoLayout = false) {
                const planta =
                    document.getElementById('topoPlanta')?.value ||
                    $('#selectPlanta').val() ||
                    'TIF';

                const todasPlantas = [...new Set([
                    ...baseVlans.map(v => String(v.planta || '').trim()),
                    ...baseIPs.map(i => String(i.planta || '').trim())
                ].filter(Boolean))].sort();

                const config =
                    topoNetworkConfig ||
                    topoCargarConfiguracionRed(planta, todasPlantas);

                const registrosRaw = topoRegistrosVisibles();
                const vlans = topoVlansVisibles();

                const firewallsLocales = topoFirewallsPlanta(planta);
                const coreLocal = topoCorePlanta(planta);

                /*
                 * Los Fortinet/firewalls y el core real ya no se duplican
                 * dentro de su VLAN: se colocan en el perímetro.
                 */
                const idsInfraestructura = new Set([
                    ...firewallsLocales.map(i => String(i.id)),
                    ...(coreLocal ? [String(coreLocal.id)] : [])
                ]);

                const registros = registrosRaw.filter(
                    item => !idsInfraestructura.has(String(item.id))
                );

                const nodes = [];
                const edges = [];
                const zones = [];

                const bandGap = 22;
                const bandTop = 260;
                const deviceCols = 6;
                const deviceGapX = 140;
                const deviceGapY = 112;
                const deviceStartX = 890;

                let totalHeight = bandTop + 100;

                const vlanLayouts = vlans.map(vlan => {
                    const rows = registros.filter(i => String(i.vlan) === String(vlan.id));
                    const cable = rows.filter(i => String(i.tipo || '').toLowerCase() !== 'wifi');
                    const wifi = rows.filter(i => String(i.tipo || '').toLowerCase() === 'wifi');
                    const visualCount = cable.length + wifi.length + (wifi.length ? 1 : 0);
                    const rowCount = Math.max(1, Math.ceil(Math.max(visualCount, 1) / deviceCols));
                    const bandHeight = Math.max(180, 72 + rowCount * deviceGapY);

                    const result = {
                        vlan,
                        rows,
                        cable,
                        wifi,
                        y: totalHeight,
                        h: bandHeight
                    };

                    totalHeight += bandHeight + bandGap;
                    return result;
                });

                const maxDevices = Math.max(
                    1,
                    ...vlanLayouts.map(x => x.rows.length + (x.wifi.length ? 1 : 0))
                );

                const neededCols = Math.min(deviceCols, Math.max(1, maxDevices));
                const stageWidth = Math.max(
                    1680,
                    deviceStartX + neededCols * deviceGapX + 160
                );
                const stageHeight = Math.max(820, totalHeight + 20);

                /* ---------------- INTERNET / ISP ---------------- */
                const internetCount = Math.max(1, Math.min(2, Number(config.internetCount || 1)));
                const internetIds = [];

                for (let i = 0; i < internetCount; i++) {
                    const number = i + 1;
                    const nodeId = `internet-${planta}-${number}`;
                    const name = i === 0 ? config.isp1Name : config.isp2Name;
                    const detail = i === 0 ? config.isp1Detail : config.isp2Detail;

                    internetIds.push(nodeId);
                    nodes.push({
                        id: nodeId,
                        kind: 'internet',
                        role: 'internet',
                        title: name || `INTERNET ${number}`,
                        subtitle: detail || `WAN ${number}`,
                        icon: 'bi-cloud-fill',
                        x: 35,
                        y: 35 + i * 112,
                        status: 'online',
                        infrastructure: true
                    });
                }

                /* ---------------- FIREWALL PERIMETRAL REAL ---------------- */
                const firewallNodeIds = [];

                if (firewallsLocales.length) {
                    firewallsLocales.forEach((item, index) => {
                        const nodeId = `firewall-real-${item.id}`;
                        firewallNodeIds.push(nodeId);

                        nodes.push(
                            topoCrearNodoDispositivo(item, {
                                id: nodeId,
                                role: 'firewall',
                                icon: 'bi-shield-lock-fill',
                                x: 245,
                                y: 35 + index * 112,
                                infrastructure: true
                            })
                        );
                    });
                } else {
                    const nodeId = `firewall-pendiente-${planta}`;
                    firewallNodeIds.push(nodeId);

                    nodes.push({
                        id: nodeId,
                        kind: 'firewall',
                        role: 'firewall',
                        title: `FIREWALL ${planta}`,
                        subtitle: 'No identificado en inventario IP',
                        icon: 'bi-shield-exclamation',
                        x: 245,
                        y: 75,
                        status: 'unknown',
                        infrastructure: true
                    });
                }

                /*
                 * WAN 1 y WAN 2 se distribuyen entre los firewalls.
                 * Con un solo Fortinet, ambos enlaces llegan al mismo equipo.
                 */
                internetIds.forEach((internetId, index) => {
                    const firewallId =
                        firewallNodeIds.length === 1
                            ? firewallNodeIds[0]
                            : firewallNodeIds[index % firewallNodeIds.length];

                    edges.push({
                        from: internetId,
                        to: firewallId,
                        type: index === 0 ? 'backbone' : 'wan-secondary',
                        label: `WAN ${index + 1}`
                    });
                });

                if (firewallNodeIds.length > 1) {
                    for (let i = 0; i < firewallNodeIds.length - 1; i++) {
                        edges.push({
                            from: firewallNodeIds[i],
                            to: firewallNodeIds[i + 1],
                            type: 'ha',
                            label: 'HA / SYNC'
                        });
                    }
                }

                /* ---------------- CORE REAL O LÓGICO ---------------- */
                let coreNodeId;

                if (coreLocal) {
                    coreNodeId = `core-real-${coreLocal.id}`;
                    nodes.push(
                        topoCrearNodoDispositivo(coreLocal, {
                            id: coreNodeId,
                            role: 'core',
                            icon: 'bi-hdd-network-fill',
                            x: 485,
                            y: 75,
                            infrastructure: true
                        })
                    );
                } else {
                    coreNodeId = `core-${planta}`;
                    nodes.push({
                        id: coreNodeId,
                        kind: 'core',
                        role: 'core',
                        title: `CORE ${planta}`,
                        subtitle: 'Switch principal lógico',
                        icon: 'bi-hdd-network-fill',
                        x: 485,
                        y: 75,
                        status: 'online',
                        infrastructure: true
                    });
                }

                firewallNodeIds.forEach(firewallId => {
                    edges.push({
                        from: firewallId,
                        to: coreNodeId,
                        type: 'backbone',
                        label: 'LAN / TRUNK'
                    });
                });

                /* ---------------- VPN SITE-TO-SITE ---------------- */
                if (config.vpnEnabled && config.vpnPeer) {
                    const peer = config.vpnPeer;
                    const remoteFirewalls = topoFirewallsPlanta(peer);
                    const remoteFirewallItem = remoteFirewalls[0] || null;
                    const remoteCoreItem = topoCorePlanta(peer);

                    let remoteFirewallId;

                    if (remoteFirewallItem) {
                        remoteFirewallId = `remote-firewall-${remoteFirewallItem.id}`;
                        nodes.push(
                            topoCrearNodoDispositivo(remoteFirewallItem, {
                                id: remoteFirewallId,
                                role: 'remote-firewall',
                                icon: 'bi-shield-lock-fill',
                                x: 790,
                                y: 35,
                                infrastructure: true,
                                remote: true
                            })
                        );
                    } else {
                        remoteFirewallId = `remote-firewall-${topoSafeId(peer)}`;
                        nodes.push({
                            id: remoteFirewallId,
                            kind: 'firewall',
                            role: 'remote-firewall',
                            title: `FIREWALL ${peer}`,
                            subtitle: 'Equipo remoto no identificado',
                            icon: 'bi-shield-exclamation',
                            x: 790,
                            y: 35,
                            status: 'unknown',
                            infrastructure: true,
                            remote: true
                        });
                    }

                    const remoteCoreId = remoteCoreItem
                        ? `remote-core-${remoteCoreItem.id}`
                        : `remote-core-${topoSafeId(peer)}`;

                    if (remoteCoreItem) {
                        nodes.push(
                            topoCrearNodoDispositivo(remoteCoreItem, {
                                id: remoteCoreId,
                                role: 'remote-core',
                                icon: 'bi-hdd-network-fill',
                                x: 1010,
                                y: 35,
                                infrastructure: true,
                                remote: true
                            })
                        );
                    } else {
                        nodes.push({
                            id: remoteCoreId,
                            kind: 'core',
                            role: 'remote-core',
                            title: `CORE ${peer}`,
                            subtitle: 'Sitio remoto',
                            icon: 'bi-hdd-network-fill',
                            x: 1010,
                            y: 35,
                            status: 'online',
                            infrastructure: true,
                            remote: true
                        });
                    }

                    edges.push({
                        from: firewallNodeIds[0],
                        to: remoteFirewallId,
                        type: 'vpn',
                        label: `VPN IPsec ${planta} ↔ ${peer}`
                    });

                    edges.push({
                        from: remoteFirewallId,
                        to: remoteCoreId,
                        type: 'backbone',
                        label: `LAN ${peer}`
                    });
                }

                /* ---------------- VLAN Y EQUIPOS ---------------- */
                vlanLayouts.forEach(layout => {
                    const vlan = layout.vlan;
                    const vlanId = String(vlan.id);
                    const vlanNodeId = `vlan-${planta}-${topoSafeId(vlanId)}`;
                    const color = topoColorVlan(vlanId);
                    const centerY = layout.y + Math.max(50, layout.h / 2 - 44);

                    zones.push({
                        id: `zone-${vlanNodeId}`,
                        title: topoNombreVlan(vlan),
                        color,
                        x: 610,
                        y: layout.y,
                        w: stageWidth - 650,
                        h: layout.h
                    });

                    nodes.push({
                        id: vlanNodeId,
                        kind: 'vlan',
                        title: topoNombreVlan(vlan),
                        subtitle: `VLAN ${vlanId}`,
                        icon: 'bi-diagram-3-fill',
                        x: 650,
                        y: centerY,
                        color,
                        vlanId,
                        status: 'online'
                    });

                    edges.push({
                        from: coreNodeId,
                        to: vlanNodeId,
                        type: 'backbone',
                        label: `802.1Q · VLAN ${vlanId}`
                    });

                    let wifiAnchorId = vlanNodeId;

                    if (layout.wifi.length > 0) {
                        wifiAnchorId = `ap-${planta}-${topoSafeId(vlanId)}`;

                        nodes.push({
                            id: wifiAnchorId,
                            kind: 'ap',
                            title: `AP · VLAN ${vlanId}`,
                            subtitle: `${layout.wifi.length} cliente(s)`,
                            icon: 'bi-wifi',
                            x: 805,
                            y: centerY,
                            color,
                            vlanId,
                            status: 'online'
                        });

                        edges.push({
                            from: vlanNodeId,
                            to: wifiAnchorId,
                            type: 'wifi',
                            label: 'WLAN'
                        });
                    }

                    const devices = [
                        ...layout.cable.map(i => ({
                            item: i,
                            via: vlanNodeId,
                            type: 'cable'
                        })),
                        ...layout.wifi.map(i => ({
                            item: i,
                            via: wifiAnchorId,
                            type: 'wifi'
                        }))
                    ];

                    devices.forEach((entry, index) => {
                        const item = entry.item;
                        const col = index % deviceCols;
                        const row = Math.floor(index / deviceCols);
                        const nodeId = `ip-${item.id}`;

                        nodes.push({
                            id: nodeId,
                            kind: 'device',
                            title: String(item.equipo || '').trim() || 'IP DISPONIBLE',
                            subtitle: item.ip || item.ipAddress || '',
                            icon: String(item.equipo || '').trim()
                                ? topoIconoEquipo(item)
                                : 'bi-record-circle',
                            x: deviceStartX + col * deviceGapX,
                            y: layout.y + 48 + row * deviceGapY,
                            color,
                            vlanId,
                            ipId: item.id,
                            ip: item.ip || item.ipAddress || '',
                            data: item,
                            status: String(item.equipo || '').trim()
                                ? (topoStatus[nodeId] || 'unknown')
                                : 'free',
                            free: !String(item.equipo || '').trim()
                        });

                        edges.push({
                            from: entry.via,
                            to: nodeId,
                            type: entry.type === 'wifi' ? 'wifi' : 'normal',
                            label: entry.type === 'wifi' ? 'WiFi' : 'Ethernet'
                        });
                    });
                });

                topoModel = {
                    nodes,
                    edges,
                    zones,
                    width: stageWidth,
                    height: stageHeight,
                    planta,
                    config,
                    detectedFirewalls: firewallsLocales,
                    detectedCore: coreLocal
                };

                if (forzarAutoLayout) {
                    topoPositions = {};
                }

                topoModel.nodes.forEach(node => {
                    if (!topoPositions[node.id] || forzarAutoLayout) {
                        topoPositions[node.id] = { x: node.x, y: node.y };
                    }
                });

                topoRender();
            }

            async function topoAutoAcomodar() {
                if (!confirm('¿Reacomodar automáticamente todos los nodos visibles?')) return;
                topoGenerar(true);
                await topoGuardarDiseno(false);
            }

            function topoRender() {
                topoRenderZones();
                topoRenderNodes();
                topoRenderEdges();
                topoRenderResumen();
                topoActualizarKpis();
                topoAplicarZoom();
                topoRenderInspector();
