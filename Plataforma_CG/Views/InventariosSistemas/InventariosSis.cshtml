        // =====================================================
        // CONTROL PREVENTIVO DE FUGAS Y TRAZABILIDAD
        // =====================================================
        let controlFugasUltimo = {
            hallazgos: [],
            metricas: {}
        };

        function controlTexto(valor) {
            return (valor === null || valor === undefined) ? '' : String(valor).trim();
        }

        function controlEscape(valor) {
            return controlTexto(valor)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        function controlMoneda(valor) {
            const numero = Number(valor) || 0;
            return new Intl.NumberFormat('es-MX', {
                style: 'currency',
                currency: 'MXN',
                maximumFractionDigits: 0
            }).format(numero);
        }


        function actualizarBotonControlFugas() {
            const boton = document.getElementById('controlFugasTrigger');
            const contador = document.getElementById('controlFugasTriggerCount');
            if (!boton || !contador) return;

            const hallazgos = (controlFugasUltimo && controlFugasUltimo.hallazgos) || [];
            const metricas = (controlFugasUltimo && controlFugasUltimo.metricas) || {};
            const total = hallazgos.length;
            const indice = Number(metricas.indiceRiesgo) || 0;
            const criticos = hallazgos.filter(x => x.nivel === 'CRITICO').length;

            contador.textContent = total > 999 ? '999+' : String(total);
            boton.classList.remove('is-clear', 'is-warning', 'is-danger');

            if (total === 0) {
                boton.classList.add('is-clear');
            } else if (criticos > 0 || indice > 25) {
                boton.classList.add('is-danger');
            } else {
                boton.classList.add('is-warning');
            }

            const descripcion = total === 0
                ? 'sin hallazgos detectados'
                : total + ' hallazgo(s), índice de riesgo ' + indice;

            boton.setAttribute('aria-label', 'Abrir control de fugas; ' + descripcion);
            boton.setAttribute('title', 'Control de fugas: ' + descripcion);
        }

        function controlEsBaja(item) {
            const asignacion = controlTexto(item && item.asignacion).toUpperCase();
            const tipo = controlTexto(item && item.tipoArticulo).toUpperCase();

            return asignacion === 'BAJA DEFINITIVA' ||
                   asignacion === 'PARA PIEZAS' ||
                   tipo === 'CHATARRA/PIEZAS';
        }

        function controlEsConsumible(item) {
            return controlTexto(item && item.tipoArticulo).toUpperCase() === 'CONSUMIBLE';
        }

        function controlEstaAsignado(item) {
            const asignacion = controlTexto(item && item.asignacion);
            return !controlEsBaja(item) && asignacion !== '';
        }

        function controlReferenciaValida(referencia) {
            const texto = controlTexto(referencia).toUpperCase();
            if (texto.length < 5) return false;

            const invalidas = [
                '-', 'N/A', 'NA', 'NINGUNA', 'NINGUNO', 'SIN REFERENCIA',
                'SIN EVIDENCIA', 'NO APLICA', 'S/R'
            ];

            return !invalidas.includes(texto);
        }

        function controlFechaValida(valor) {
            if (!valor) return null;
            const fecha = new Date(valor);
            return Number.isNaN(fecha.getTime()) ? null : fecha;
        }

        function controlClaveMovimiento(movimiento) {
            return controlTexto(
                movimiento.articuloSap ||
                movimiento.idArticuloSap ||
                movimiento.sku ||
                movimiento.articulo ||
                movimiento.idArticulo
            ).toUpperCase();
        }

        function controlCalcularConsumosAnormales(activos) {
            const consumiblesPorClave = new Map();

            activos.filter(controlEsConsumible).forEach(item => {
                const claves = [
                    controlTexto(item.idArticuloSap).toUpperCase(),
                    controlTexto(item.id).toUpperCase()
                ].filter(Boolean);

                claves.forEach(clave => consumiblesPorClave.set(clave, item));
            });

            const hoy = new Date();
            const inicioMesActual = new Date(hoy.getFullYear(), hoy.getMonth(), 1);
            const inicioHistorico = new Date(hoy.getFullYear(), hoy.getMonth() - 3, 1);
            const consumos = new Map();

            (movimientosInventario || []).forEach(movimiento => {
                const tipo = controlTexto(movimiento.tipoMovimiento).toUpperCase();
                if (!tipo.includes('SALIDA')) return;

                const fecha = controlFechaValida(movimiento.fecha);
                if (!fecha || fecha < inicioHistorico) return;

                const clave = controlClaveMovimiento(movimiento);
                const item = consumiblesPorClave.get(clave);
                if (!item) return;

                const llave = controlTexto(item.id || item.idArticuloSap);
                if (!consumos.has(llave)) {
                    consumos.set(llave, {
                        item: item,
                        actual: 0,
                        anteriores: [0, 0, 0]
                    });
                }

                const registro = consumos.get(llave);
                const cantidad = Math.abs(Number(movimiento.cantidad) || 0);

                if (fecha >= inicioMesActual) {
                    registro.actual += cantidad;
                    return;
                }

                const diferenciaMeses =
                    (inicioMesActual.getFullYear() - fecha.getFullYear()) * 12 +
                    (inicioMesActual.getMonth() - fecha.getMonth());

                if (diferenciaMeses >= 1 && diferenciaMeses <= 3) {
                    registro.anteriores[diferenciaMeses - 1] += cantidad;
                }
            });

            const resultados = [];

            consumos.forEach(registro => {
                const mesesConDato = registro.anteriores.filter(x => x > 0);
                if (!mesesConDato.length) return;

                const promedio = registro.anteriores.reduce((a, b) => a + b, 0) / 3;
                const exceso = registro.actual - promedio;
                const variacion = promedio > 0 ? (exceso / promedio) * 100 : 0;

                if (promedio >= 1 && registro.actual > promedio * 1.25 && exceso >= 2) {
                    resultados.push({
                        item: registro.item,
                        actual: registro.actual,
                        promedio: promedio,
                        exceso: exceso,
                        variacion: variacion
                    });
                }
            });

            return resultados.sort((a, b) => b.variacion - a.variacion);
        }

        function controlAgregarHallazgo(lista, datos) {
            lista.push({
                nivel: datos.nivel || 'MEDIO',
                tipo: datos.tipo || 'Revisión',
                itemId: Number(datos.itemId) || 0,
                sap: controlTexto(datos.sap) || 'SIN SAP',
                nombre: controlTexto(datos.nombre) || 'Sin nombre',
                responsable: controlTexto(datos.responsable) || 'Sin responsable',
                ubicacion: controlTexto(datos.ubicacion) || 'Sin ubicación',
                valor: Math.max(Number(datos.valor) || 0, 0),
                accion: controlTexto(datos.accion) || 'Revisar y documentar.'
            });
        }

        function controlActualizarClaseKpi(selector, valor, limiteAdvertencia, limitePeligro) {
            const card = document.querySelector(selector);
            if (!card) return;

            card.classList.remove('ok', 'warning', 'danger', 'info');

            if (valor >= limitePeligro) card.classList.add('danger');
            else if (valor >= limiteAdvertencia) card.classList.add('warning');
            else card.classList.add('ok');
        }

        function generarControlFugas() {
            const activos = (datosInventario || []).filter(item => !controlEsBaja(item));
            const equipos = activos.filter(item => !controlEsConsumible(item));
            const asignados = equipos.filter(controlEstaAsignado);
            const hallazgos = [];
            const itemsDocumentalmenteIncompletos = new Set();
            const itemsValorEnRiesgo = new Map();

            equipos.forEach(item => {
                const sap = controlTexto(item.idArticuloSap);
                const nombre = controlTexto(item.nombre);
                const responsable = controlTexto(item.asignacion);
                const ubicacion = [controlTexto(item.planta), controlTexto(item.ubicacion)]
                    .filter(Boolean)
                    .join(' / ');
                const costo = Number(item.costo) || 0;
                const idLlave = controlTexto(item.id || item.idArticuloSap || sap);

                const faltantesBase = [];
                if (!sap) faltantesBase.push('SAP');
                if (!nombre) faltantesBase.push('nombre');
                if (!controlTexto(item.numeroSerie)) faltantesBase.push('serie');
                if (!controlTexto(item.planta)) faltantesBase.push('planta');
                if (!controlTexto(item.ubicacion)) faltantesBase.push('ubicación');

                if (faltantesBase.length) {
                    itemsDocumentalmenteIncompletos.add(idLlave);
                    itemsValorEnRiesgo.set(idLlave, costo);

                    controlAgregarHallazgo(hallazgos, {
                        nivel: faltantesBase.includes('serie') ? 'ALTO' : 'MEDIO',
                        tipo: 'Trazabilidad incompleta: ' + faltantesBase.join(', '),
                        itemId: item.id,
                        sap: sap,
                        nombre: nombre,
                        responsable: responsable,
                        ubicacion: ubicacion,
                        valor: costo,
                        accion: 'Completar los datos maestros y validar físicamente el equipo.'
                    });
                }

                if (controlEstaAsignado(item)) {
                    const tieneFoto = controlTexto(item.fotoUsuario) !== '';
                    const tieneDocumento =
                        controlTexto(item.firmaDigital) !== '' ||
                        controlTexto(item.documentoComodato) !== '';

                    if (!tieneFoto || !tieneDocumento) {
                        itemsDocumentalmenteIncompletos.add(idLlave);
                        itemsValorEnRiesgo.set(idLlave, costo);

                        const faltantes = [];
                        if (!tieneFoto) faltantes.push('foto');
                        if (!tieneDocumento) faltantes.push('firma o comodato');

                        controlAgregarHallazgo(hallazgos, {
                            nivel: 'ALTO',
                            tipo: 'Resguardo incompleto: ' + faltantes.join(' y '),
                            itemId: item.id,
                            sap: sap,
                            nombre: nombre,
                            responsable: responsable,
                            ubicacion: ubicacion,
                            valor: costo,
                            accion: 'Actualizar expediente del responsable y obtener evidencia.'
                        });
                    }
                }

                if (item.enRecuperacion) {
                    itemsDocumentalmenteIncompletos.add(idLlave);
                    itemsValorEnRiesgo.set(idLlave, costo);

                    controlAgregarHallazgo(hallazgos, {
                        nivel: 'CRITICO',
                        tipo: 'Equipo pendiente de recuperación',
                        itemId: item.id,
                        sap: sap,
                        nombre: nombre,
                        responsable: responsable,
                        ubicacion: ubicacion,
                        valor: costo,
                        accion: 'Recuperar físicamente, validar serie y cerrar la devolución.'
                    });
                }
            });

            const salidas = (movimientosInventario || []).filter(m =>
                controlTexto(m.tipoMovimiento).toUpperCase().includes('SALIDA')
            );

            const salidasSinEvidencia = salidas.filter(m =>
                !controlReferenciaValida(m.referencia)
            );

            salidasSinEvidencia.slice(0, 20).forEach(movimiento => {
                controlAgregarHallazgo(hallazgos, {
                    nivel: 'ALTO',
                    tipo: 'Salida sin referencia suficiente',
                    itemId: movimiento.idArticulo || 0,
                    sap: movimiento.articuloSap || movimiento.idArticuloSap,
                    nombre: movimiento.nombreArticulo,
                    responsable: movimiento.usuario || movimiento.usuarioRegistro || 'No informado',
                    ubicacion: movimiento.planta || movimiento.ubicacion || '',
                    valor: 0,
                    accion: 'Identificar solicitante, autorización, motivo y evidencia de entrega.'
                });
            });

            const consumosAnormales = controlCalcularConsumosAnormales(activos);

            consumosAnormales.forEach(registro => {
                const item = registro.item;
                const costoUnitario = Number(item.costo) || 0;
                const valorExceso = Math.max(registro.exceso, 0) * costoUnitario;
                const idLlave = controlTexto(item.id || item.idArticuloSap);

                if (valorExceso > 0) {
                    const previo = itemsValorEnRiesgo.get(idLlave) || 0;
                    itemsValorEnRiesgo.set(idLlave, Math.max(previo, valorExceso));
                }

                controlAgregarHallazgo(hallazgos, {
                    nivel: registro.variacion >= 75 ? 'CRITICO' : 'ALTO',
                    tipo: 'Consumo anormal: +' + Math.round(registro.variacion) + '%',
                    itemId: item.id,
                    sap: item.idArticuloSap,
                    nombre: item.nombre,
                    responsable: 'Consumo mensual',
                    ubicacion: [item.planta, item.ubicacion].filter(Boolean).join(' / '),
                    valor: valorExceso,
                    accion:
                        'Revisar salidas del mes. Actual: ' +
                        Math.round(registro.actual * 100) / 100 +
                        '; promedio: ' +
                        Math.round(registro.promedio * 100) / 100 + '.'
                });
            });

            const sinResguardo = asignados.filter(item => {
                const tieneFoto = controlTexto(item.fotoUsuario) !== '';
                const tieneDocumento =
                    controlTexto(item.firmaDigital) !== '' ||
                    controlTexto(item.documentoComodato) !== '';

                return !tieneFoto || !tieneDocumento;
            }).length;

            const recuperaciones = equipos.filter(item => item.enRecuperacion).length;
            const completos = Math.max(equipos.length - itemsDocumentalmenteIncompletos.size, 0);
            const exactitud = equipos.length ? (completos / equipos.length) * 100 : 100;
            const valorRiesgo = Array.from(itemsValorEnRiesgo.values())
                .reduce((total, valor) => total + (Number(valor) || 0), 0);

            const proporcionDocumental = equipos.length
                ? itemsDocumentalmenteIncompletos.size / equipos.length
                : 0;
            const proporcionRecuperacion = equipos.length
                ? recuperaciones / equipos.length
                : 0;
            const proporcionSalidas = salidas.length
                ? salidasSinEvidencia.length / salidas.length
                : 0;
            const consumibles = activos.filter(controlEsConsumible);
            const proporcionConsumo = consumibles.length
                ? consumosAnormales.length / consumibles.length
                : 0;

            const indiceRiesgo = Math.min(100, Math.round(
                proporcionDocumental * 40 +
                proporcionRecuperacion * 25 +
                proporcionSalidas * 20 +
                proporcionConsumo * 15
            ));

            let nivelRiesgo = 'Bajo';
            let claseRiesgo = '';

            if (indiceRiesgo > 50) {
                nivelRiesgo = 'Crítico';
                claseRiesgo = 'riesgo-critico';
            } else if (indiceRiesgo > 25) {
                nivelRiesgo = 'Alto';
                claseRiesgo = 'riesgo-alto';
            } else if (indiceRiesgo > 10) {
                nivelRiesgo = 'Preventivo';
                claseRiesgo = 'riesgo-preventivo';
            }

            const prioridad = { CRITICO: 0, ALTO: 1, MEDIO: 2, BAJO: 3 };
            hallazgos.sort((a, b) =>
                (prioridad[a.nivel] - prioridad[b.nivel]) ||
                (b.valor - a.valor)
            );

            controlFugasUltimo = {
                hallazgos: hallazgos,
                metricas: {
                    exactitud: exactitud,
                    valorRiesgo: valorRiesgo,
                    sinResguardo: sinResguardo,
                    salidasSinEvidencia: salidasSinEvidencia.length,
                    recuperaciones: recuperaciones,
                    consumosAnormales: consumosAnormales.length,
                    indiceRiesgo: indiceRiesgo,
                    nivelRiesgo: nivelRiesgo
                }
            };

            $('#controlExactitud').text(exactitud.toFixed(1) + '%');
            $('#controlValorRiesgo').text(controlMoneda(valorRiesgo));
            $('#controlSinResguardo').text(sinResguardo);
            $('#controlSalidasSinEvidencia').text(salidasSinEvidencia.length);
            $('#controlRecuperaciones').text(recuperaciones);
            $('#controlConsumosAnormales').text(consumosAnormales.length);
            $('#controlRiesgoValor').text(indiceRiesgo);
            $('#controlRiesgoNivel').text(nivelRiesgo);

            const riesgoCard = document.getElementById('controlRiesgoCard');
            if (riesgoCard) {
                riesgoCard.classList.remove(
                    'riesgo-preventivo',
                    'riesgo-alto',
                    'riesgo-critico'
                );
                if (claseRiesgo) riesgoCard.classList.add(claseRiesgo);
            }

            controlActualizarClaseKpi(
                '#controlExactitudCard',
                100 - exactitud,
                1,
                10
            );
            controlActualizarClaseKpi(
                '#controlResguardoCard',
                sinResguardo,
                1,
                Math.max(3, Math.ceil(asignados.length * .10))
            );
            controlActualizarClaseKpi(
                '#controlSalidaCard',
                salidasSinEvidencia.length,
                1,
                3
            );
            controlActualizarClaseKpi(
                '#controlRecuperacionCard',
                recuperaciones,
                1,
                3
            );
            controlActualizarClaseKpi(
                '#controlConsumoCard',
                consumosAnormales.length,
                1,
                3
            );

            renderControlFugasHallazgos(hallazgos);

            const resumen = hallazgos.length
                ? hallazgos.length + ' hallazgo(s) detectados; ' +
                  hallazgos.filter(x => x.nivel === 'CRITICO').length + ' crítico(s) y ' +
                  hallazgos.filter(x => x.nivel === 'ALTO').length + ' alto(s).'
                : 'Sin incidencias detectadas con la información disponible.';

            $('#controlFugasResumen').text(resumen);
            actualizarBotonControlFugas();
        }

        function renderControlFugasHallazgos(hallazgos) {
            const tbody = document.getElementById('controlFugasTbody');
            if (!tbody) return;

            if (!hallazgos.length) {
                tbody.innerHTML =
                    '<tr><td colspan="6" class="text-center py-3 text-success fw-bold">' +
                    '<i class="bi bi-check-circle-fill me-1"></i>' +
                    'Sin hallazgos preventivos con la información disponible.' +
                    '</td></tr>';
                return;
            }

            tbody.innerHTML = hallazgos.slice(0, 40).map(hallazgo => {
                const clase = controlTexto(hallazgo.nivel).toLowerCase();
                const responsableUbicacion =
                    controlEscape(hallazgo.responsable) +
                    '<br><small class="text-muted">' +
                    controlEscape(hallazgo.ubicacion) +
                    '</small>';

                return '<tr>' +
                    '<td><span class="control-risk-badge ' + clase + '">' +
                    controlEscape(hallazgo.nivel) +
                    '</span></td>' +
                    '<td><strong>' + controlEscape(hallazgo.tipo) + '</strong></td>' +
                    '<td><strong style="color:#7b1113;">' +
                    controlEscape(hallazgo.sap) +
                    '</strong><br><small>' +
                    controlEscape(hallazgo.nombre) +
                    '</small></td>' +
                    '<td>' + responsableUbicacion + '</td>' +
                    '<td><strong>' + controlMoneda(hallazgo.valor) + '</strong></td>' +
                    '<td>' + controlEscape(hallazgo.accion) + '</td>' +
                    '</tr>';
            }).join('');
        }

        function exportarControlFugasCsv() {
            const hallazgos = (controlFugasUltimo && controlFugasUltimo.hallazgos) || [];
            const metricas = (controlFugasUltimo && controlFugasUltimo.metricas) || {};

            if (!hallazgos.length) {
                alert('No hay hallazgos para exportar.');
                return;
            }

            const filas = [
                ['REPORTE DE CONTROL PREVENTIVO DE FUGAS'],
                ['Fecha', new Date().toLocaleString('es-MX')],
                ['Índice de riesgo', metricas.indiceRiesgo || 0],
                ['Nivel', metricas.nivelRiesgo || 'Bajo'],
                ['Exactitud documental', (Number(metricas.exactitud) || 0).toFixed(1) + '%'],
                ['Valor expuesto MXN', Number(metricas.valorRiesgo) || 0],
                [],
                ['Riesgo', 'Hallazgo', 'SAP', 'Artículo', 'Responsable', 'Ubicación', 'Valor expuesto', 'Acción']
            ];

            hallazgos.forEach(h => {
                filas.push([
                    h.nivel,
                    h.tipo,
                    h.sap,
                    h.nombre,
                    h.responsable,
                    h.ubicacion,
                    h.valor,
                    h.accion
                ]);
            });

            const csv = filas.map(fila =>
                fila.map(celda =>
                    '"' + controlTexto(celda).replace(/"/g, '""') + '"'
                ).join(',')
            ).join('\r\n');

            const blob = new Blob(['\ufeff' + csv], {
                type: 'text/csv;charset=utf-8;'
            });
            const url = URL.createObjectURL(blob);
            const enlace = document.createElement('a');
            enlace.href = url;
            enlace.download =
                'Control_Fugas_Inventario_' +
                new Date().toISOString().slice(0, 10) +
                '.csv';

            document.body.appendChild(enlace);
            enlace.click();
            enlace.remove();
            URL.revokeObjectURL(url);
        }


        async function cargarInventario() {
            try {
                const response = await fetch('@Url.Action("GetInventario", "InventariosSistemas")');
                if (!response.ok) throw new Error("Error de red o servidor.");
                const data = await response.json();
                if (data.ok) {
                    datosInventario = data.inventario || [];
                    movimientosInventario = data.movimientos || [];

                    aplicarFiltros();
                    llenarSelects();
                    llenarSelectBaja();
                    renderMovimientos(movimientosInventario);
                    renderTablaAsignaciones();
                    generarAlertasDashboard();
                    generarControlFugas();
                    renderTablaRecuperaciones();
                    llenarSelectTaller();
                    renderTablaTaller();
                    if (qrItemActual) {
                        const actualizado = datosInventario.find(x => Number(x.id) === Number(qrItemActual.id));
                        qrItemActual = actualizado || null;
                        renderResultadoQr(qrItemActual);
                    }
                    renderMapaTiIndustrial();
                }
            } catch (error) { console.error("Error cargando inventario: ", error); }
        }
        function aplicarFiltros() {
             const texto = $('#filtroGeneral').val().toLowerCase();
             const tipo = $('#filtroTipo').val();
             const planta = $('#filtroPlanta').val();
             const estado = $('#filtroEstado').val();

             let filtrado = datosInventario.filter(i => {
                 const matchTexto = !texto || (i.idArticuloSap && i.idArticuloSap.toLowerCase().includes(texto)) || (i.nombre && i.nombre.toLowerCase().includes(texto)) || (i.numeroSerie && i.numeroSerie.toLowerCase().includes(texto));
                 const matchPlanta = !planta || i.planta === planta;

                 // Lógica centralizada para identificar qué es chatarra/baja
                 const esBaja = i.asignacion === 'BAJA DEFINITIVA' || i.asignacion === 'PARA PIEZAS' || i.tipoArticulo === 'Chatarra/Piezas';
                 const esAsignado = !esBaja && i.asignacion && i.asignacion.trim() !== '';
                 const estaDisponible = !esBaja && (!i.asignacion || i.asignacion.trim() === '');

                 let matchTipo = true;
                 if (tipo === 'Chatarra/Piezas') {
                     // Si el filtro de tipo es Chatarra, mostramos todo lo que se considere baja
                     matchTipo = esBaja;
                 } else if (tipo !== '') {
                     // Si el filtro de tipo es otro, tiene que coincidir exactamente y NO debe ser baja
                     matchTipo = i.tipoArticulo === tipo && !esBaja;
                 }

                 let matchEstado = true;
                 // Si el artículo es chatarra/baja, ignoramos el filtro de estado (porque ni están asignados ni disponibles)
                 if (esBaja && estado !== '') {
                    matchEstado = false;
                 } else {
                     if (estado === 'asignado') matchEstado = esAsignado;
                     else if (estado === 'disponible') matchEstado = estaDisponible;
                 }

                 return matchTexto && matchTipo && matchPlanta && matchEstado;
             });
             renderTabla(filtrado);
         }

        function limpiarFiltros() { $('#filtroGeneral, #filtroTipo, #filtroPlanta, #filtroEstado').val(''); aplicarFiltros(); }

        function renderTabla(datos) {
            const hoy = new Date();
            let tbody = '';
            if(datos.length === 0) { $('#tbodyInventario').html('<tr><td colspan="6" class="text-center py-4">Sin datos</td></tr>'); return; }

            datos.forEach(item => {
                let fCompraStr = item.fechaCompra ? new Date(item.fechaCompra).toLocaleDateString('es-MX') : '-';
                let vidaStr = '<span class="text-muted">N/A</span>';
                let garantiaBadge = '-';

                let aniosVida = parseInt(item.tiempoVida) || 4;
                let fBaseVida = item.fechaCompra ? new Date(item.fechaCompra) : (item.fechaEntrada ? new Date(item.fechaEntrada) : null);

                if (fBaseVida) {
                    let fFinVida = new Date(fBaseVida.getTime());
                    fFinVida.setFullYear(fFinVida.getFullYear() + aniosVida);
                    vidaStr = `<span style="color:var(--brand-main); font-weight:bold;">Expira: ${fFinVida.toLocaleDateString('es-MX')}</span>`;
                }

                if (item.fechaCompra && item.diasGarantia) {
                    let finGarantia = new Date(item.fechaCompra);
                    finGarantia.setDate(finGarantia.getDate() + item.diasGarantia);
                    let dias = Math.ceil((finGarantia - hoy) / (1000 * 60 * 60 * 24));
                    garantiaBadge = dias < 0 ? `<span class="text-danger fw-bold">Vencida</span>` : `<span class="text-success">${dias} d. rest.</span>`;
                }

                let stockStr = `<div style="font-size:1.1rem; font-weight:bold;">${item.stock}</div>`;
                if(item.tipoArticulo === 'Consumible') {
                    stockStr += `<small class="text-muted">Mín: ${item.stockMinimo}</small>`;
                    if (item.stock <= item.stockMinimo) stockStr += `<br><span class="text-danger fw-bold" style="font-size:0.7rem;">¡Bajo!</span>`;
                } else {
                    stockStr += `<small class="text-muted">Fijo</small>`;
                }

                let btnBaja = (item.asignacion === 'BAJA DEFINITIVA' || item.asignacion === 'PARA PIEZAS')
                    ? `<button class="btn-sm-action text-muted" style="background:#eee; cursor:not-allowed;" disabled>Dado de Baja</button>`
                    : `<button class="btn-sm-action" onclick="darDeBajaArticulo(${item.id})">Dar Baja</button>`;

                let usuarioBadge = '';
                if (item.enRecuperacion) {
                    usuarioBadge = `<span class="badge bg-warning text-dark"><i class="bi bi-clock-history"></i> En Recuperación</span><br><small class="text-muted">${item.asignacion}</small>`;
                } else if (item.asignacion && item.asignacion.trim() !== '') {
                    usuarioBadge = `<b>${item.asignacion}</b>`;
                } else {
                    usuarioBadge = `<span class="badge bg-success px-2 py-1">Disponible</span>`;
                }

                let badgeClase = "bg-secondary";
                if (item.tipoArticulo === 'Activo Fijo') badgeClase = "bg-primary";
                else if (item.tipoArticulo === 'Consumible') badgeClase = "bg-success";
                else if (item.tipoArticulo === 'Herramienta') badgeClase = "bg-warning text-dark";

                tbody += `<tr>
                    <td>
                        <strong style="color:var(--brand-main); font-size:1rem;">${item.idArticuloSap}</strong><br>
                        <span class="fw-bold">${item.nombre}</span><br>
                        <span class="badge ${badgeClase} px-2 py-1 mt-1" style="font-size:0.65rem; font-weight:600;">${item.tipoArticulo || 'N/A'}</span>
                    </td>
                    <td><span class="text-muted">Usuario:</span> ${usuarioBadge}<br><span class="text-muted" style="font-family:monospace;">Serie: ${item.numeroSerie || '-'}</span></td>
                    <td><strong>${item.planta || 'N/A'}</strong><br><small class="text-muted">${item.ubicacion || ''}</small></td>
                    <td><small class="text-muted">Compra:</small> ${fCompraStr}<br>${vidaStr}</td>
                    <td class="text-center">${stockStr}<br><small class="text-muted">Gar:</small> <small>${garantiaBadge}</small></td>
                    <td class="text-center text-nowrap">
                        <button class="btn-sm-action" onclick="consultarArticulo(${item.id})">Detalles</button>                       
                        <button class="btn-sm-action" onclick="imprimirEtiquetaPequena(${item.id})" title="Etiqueta compacta con nombre, serie y QR de la serie"><i class="bi bi-tag"></i></button>
                        <button class="btn-sm-action" onclick="imprimirQR(${item.id})" title="Etiqueta completa de inventario"><i class="bi bi-printer"></i> </button>
                        ${btnBaja}
                    </td>
                </tr>`;
            });
            $('#tbodyInventario').html(tbody);
        }

        function llenarSelects() {
            let optionsTodos = '<option value="">Selecciona un artículo...</option>';
            let optionsRestock = '<option value="">Selecciona un artículo...</option>';
            let optionsAsignables = '<option value="">Selecciona un artículo...</option>';

            let filtroPanel = $('#filtroSelectAsignar').val() || 'todos';
            let filtroRestock = $('#resFiltroTipo').val() || 'todos';

            datosInventario.forEach(i => {
                optionsTodos += `<option value="${i.id}">${i.idArticuloSap} - ${i.nombre}</option>`;

                if (i.asignacion !== 'BAJA DEFINITIVA' && i.asignacion !== 'PARA PIEZAS' && !i.enRecuperacion) {
                    let estaDisponible = !i.asignacion || i.asignacion.trim() === '';
                    let pasaFiltro = true;

                    if (filtroPanel === 'disponibles' && !estaDisponible) pasaFiltro = false;
                    if (filtroPanel === 'asignados' && estaDisponible) pasaFiltro = false;

                    if (pasaFiltro) {
                        optionsAsignables += `<option value="${i.id}">${i.idArticuloSap} - ${i.nombre}</option>`;
                    }

                    let pasaFiltroRestock = true;
                    if (filtroRestock !== 'todos' && i.tipoArticulo !== filtroRestock) pasaFiltroRestock = false;

                    if (pasaFiltroRestock) {
                        optionsRestock += `<option value="${i.id}">${i.idArticuloSap} - ${i.nombre}</option>`;
                    }
                }
            });

            $('#salArticulo').html(optionsTodos).trigger('change');
            $('#resArticulo').html(optionsRestock).trigger('change');
            $('#asigArticulo').html(optionsAsignables).trigger('change');
        }

        function llenarSelectBaja() {
            let usuariosConEquipo = [...new Set(datosInventario
                .filter(i => i.asignacion && i.asignacion.trim() !== '' && i.asignacion !== 'BAJA DEFINITIVA' && i.asignacion !== 'PARA PIEZAS' && !i.enRecuperacion)
                .map(i => i.asignacion))];

            let options = '<option value="">Selecciona usuario...</option>';
            usuariosConEquipo.sort().forEach(u => {
                options += `<option value="${u}">${u}</option>`;
            });
            $('#selectUsuarioBaja').html(options).trigger('change');
        }

