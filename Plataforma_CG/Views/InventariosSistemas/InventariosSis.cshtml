}

.mapa-ti-modal .modal-dialog {
    width: 100vw !important;
    max-width: none !important;
    height: 100dvh !important;
    margin: 0 !important;
}

.mapa-ti-modal .modal-content {
    width: 100% !important;
    height: 100dvh !important;
    min-height: 100dvh !important;
