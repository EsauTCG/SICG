        async function ejecutarBaja(btnElement) {
            const id = $('#bajaId').val();
            const motivo = $('#bajaMotivo').val().trim();
            const tipo = $('input[name="tipoBajaStatus"]:checked').val();

            const btn = btnElement || document.getElementById('btnConfirmarBaja');

            if (!motivo) {
                alert("Por favor, ingresa el motivo de la baja para el historial.");
                $('#bajaMotivo').focus();
                return;
            }

            try {
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Procesando...';

                const res = await fetch(`@Url.Action("DarDeBajaArticulo", "InventariosSistemas")?id=${id}&motivo=${encodeURIComponent(motivo)}&tipoBaja=${tipo}`, { method: 'POST' });
                const data = await res.json();

                if (data.ok) {
                    bajaModal.hide();
                    cargarInventario();
                    alert("✅ " + data.mensaje);
                } else {
                    alert(" Error: " + data.mensaje);
                }
            } catch(error) {
                alert("Ocurrió un error al intentar comunicar con el servidor: " + error.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Confirmar Baja';
            }
        }

