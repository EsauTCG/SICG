@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Inventario Independiente";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

<style>
    :root {
        --brand-main: #4a0e0e;
        --brand-hover: #6b1515;
        --bg-page: #fdf5f4;
        --card-bg: #ffffff;
        --panel-bg: #fcf5f4;
        --border-color: #ebdcdb;
        --text-dark: #333333;
        --text-muted: #888888;
    }

    body {
        background-color: var(--bg-page);
        color: var(--text-dark);
        font-family: 'Segoe UI', Tahoma, sans-serif;
        font-size: 0.85rem;
    }

    .dashboard-panel {
        background-color: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border-color);
        margin-bottom: 1.5rem;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    }

    .panel-header {
        background-color: transparent;
        border-bottom: 1px solid var(--border-color);
        padding: 1rem 1.25rem;
    }

    .panel-title {
        font-size: 1rem;
        font-weight: 800;
        color: var(--text-dark);
        margin: 0;
    }

    .panel-subtitle {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin: 0;
    }

    .top-banner {
        background-color: var(--brand-main);
        color: white;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .kpi-container {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .kpi-box {
        background-color: rgba(255,255,255,0.08);
        border-radius: 8px;
        padding: 1rem;
        flex: 1 1 200px;
        min-width: 150px;
    }

    .kpi-title {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        opacity: 0.8;
        margin-bottom: 0.3rem;
    }

    .kpi-value {
        font-size: 1.8rem;
        font-weight: bold;
        margin: 0;
    }

    .nav-tabs {
        border-bottom: 2px solid var(--border-color);
        margin-bottom: 1.5rem;
        flex-wrap: nowrap;
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 2px;
    }

        .nav-tabs::-webkit-scrollbar {
            height: 4px;
        }

        .nav-tabs::-webkit-scrollbar-thumb {
            background: var(--border-color);
            border-radius: 4px;
        }

        .nav-tabs .nav-link {
            color: var(--text-muted);
            font-weight: 600;
            border: none;
            padding: 10px 20px;
            transition: 0.3s;
            background: transparent;
        }

            .nav-tabs .nav-link:hover {
                color: var(--brand-main);
            }

            .nav-tabs .nav-link.active {
                color: var(--brand-main);
                border-bottom: 3px solid var(--brand-main);
                background-color: transparent;
            }

    .tab-content > .tab-pane {
        display: none;
    }

    .tab-content > .active {
        display: block;
        animation: slideFade 0.4s ease-out forwards;
    }

    @@keyframes slideFade {
        0%

    {
        opacity: 0;
        transform: translateX(30px);
    }

    100% {
        opacity: 1;
        transform: translateX(0);
    }

    }

    .btn-brand {
        background-color: var(--brand-main);
        color: white;
        border: none;
        padding: 6px 16px;
        border-radius: 20px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-brand:hover:not(:disabled) {
            background-color: var(--brand-hover);
            color: white;
        }

        .btn-brand:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

    .btn-outline {
        border: 1px solid var(--border-color);
        background: white;
        color: var(--text-dark);
        border-radius: 20px;
        font-weight: 600;
    }

        .btn-outline:hover {
            background: var(--bg-page);
            border-color: var(--brand-main);
            color: var(--brand-main);
        }

    .form-control, .form-select {
        border-color: var(--border-color);
        font-size: 0.85rem;
        border-radius: 6px;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--brand-main);
            box-shadow: 0 0 0 0.2rem rgba(74, 14, 14, 0.15);
        }

    .table-custom {
        margin-bottom: 0;
    }

        .table-custom thead th {
            background-color: var(--panel-bg);
            color: var(--text-muted);
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.7rem;
            border-bottom: 2px solid var(--border-color);
            padding: 12px;
            white-space: nowrap;
        }

        .table-custom tbody tr {
            border-bottom: 1px solid var(--border-color);
        }

        .table-custom tbody td {
            vertical-align: middle;
            padding: 12px;
        }

    .btn-sm-action {
        padding: 4px 8px;
        font-size: 0.75rem;
        border-radius: 6px;
        border: 1px solid var(--border-color);
        background: white;
        cursor: pointer;
        transition: all 0.2s;
        color: var(--text-dark);
        margin-bottom: 2px;
        margin-right: 2px;
    }

        .btn-sm-action:hover:not(:disabled) {
            background: var(--bg-page);
            border-color: var(--brand-main);
            color: var(--brand-main);
        }

    .badge-entrada {
        background-color: #dcfce7;
        color: #166534;
        padding: 3px 8px;
        border-radius: 4px;
        font-weight: bold;
        font-size: 0.7rem;
        border: 1px solid #bbf7d0;
    }

    .badge-salida {
        background-color: #fef08a;
        color: #854d0e;
        padding: 3px 8px;
        border-radius: 4px;
        font-weight: bold;
        font-size: 0.7rem;
        border: 1px solid #fde047;
    }

    .scroll-panel::-webkit-scrollbar {
        width: 6px;
    }

    .scroll-panel::-webkit-scrollbar-thumb {
        background: var(--border-color);
        border-radius: 4px;
    }

    .alerta-item {
        padding: 8px;
        border-radius: 6px;
        border-left: 4px solid;
        margin-bottom: 8px;
        font-size: 0.8rem;
        background: white;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    .btn-check:checked + .btn-outline-danger {
        background-color: var(--brand-main);
        border-color: var(--brand-main);
        color: white;
    }

    .btn-outline-danger {
        border-color: var(--border-color);
        color: var(--text-muted);
        font-weight: bold;
        font-size: 0.75rem;
        white-space: normal;
    }

        .btn-outline-danger:hover {
            background-color: var(--panel-bg);
            color: var(--brand-main);
        }

    .firma-container {
        border: 2px dashed var(--border-color);
        background-color: white;
        border-radius: 8px;
        overflow: hidden;
        position: relative;
        touch-action: none;
    }

    #firmaCanvas {
        width: 100%;
        height: 150px;
        cursor: crosshair;
    }

    @@media (max-width: 768px) {
        .kpi-box

    {
        flex: 1 1 45%;
        padding: 0.8rem;
        min-width: 40%;
    }

    .kpi-value {
        font-size: 1.4rem;
    }

    .top-banner {
        padding: 1rem;
    }

    .table-custom tbody td {
        white-space: nowrap;
    }

    .btn-sm-action {
        padding: 6px 10px;
        font-size: 0.8rem;
    }

    }


    .select2-container--bootstrap-5 .select2-selection {
        font-size: 0.85rem;
        min-height: calc(1.5em + .75rem + 2px);
        border: 1px solid var(--border-color);
        border-radius: 6px;
    }

    .select2-container--bootstrap-5.select2-container--focus .select2-selection,
    .select2-container--bootstrap-5.select2-container--open .select2-selection {
        border-color: var(--brand-main);
        box-shadow: 0 0 0 0.2rem rgba(74, 14, 14, 0.15);
    }

    .select2-container--bootstrap-5 .select2-results__option--highlighted[aria-selected] {
        background-color: var(--brand-main) !important;
        color: white !important;
    }

    .select2-container--bootstrap-5 .select2-search__field:focus {
        box-shadow: 0 0 0 0.2rem rgba(74, 14, 14, 0.15);
        border-color: var(--brand-main);
    }

    /* ESTILO ROSITA / VINO + RESPONSIVO */
html,
body {
    background: #e9edf2 !important;
    overflow-x: hidden !important;
}

body,
main,
.main,
.body-content,
.container,
.container-fluid {
    background: #e9edf2 !important;
}

.container-fluid {
    width: min(100%, calc(100vw - 48px)) !important;
    max-width: 1900px !important;
    margin: 0 auto !important;
    padding: 8px !important;
}

.top-banner {
    background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
    border: 1px solid #7e4a4a !important;
    border-radius: 0 !important;
    box-shadow: 0 8px 18px rgba(70,12,12,.14) !important;
}

.kpi-box {
    background: rgba(255,255,255,.12) !important;
    border: 1px solid rgba(255,255,255,.22) !important;
    border-radius: 0 !important;
}

.dashboard-panel {
    background: #f8eeee !important;
    border: 1px solid #c79d9d !important;
    border-radius: 0 !important;
    box-shadow: none !important;
}

.panel-header {
    background: #f1dede !important;
    border-bottom: 1px solid #c79d9d !important;
}

.panel-title {
    color: #5c1a1a !important;
}

.panel-subtitle {
    color: #6a3a3a !important;
}

.nav-tabs {
    background: #f1dede !important;
    border: 1px solid #c79d9d !important;
    padding: 4px !important;
    margin-bottom: 12px !important;
}

.nav-tabs .nav-link {
    background: linear-gradient(#fffefe,#ecd7d7) !important;
    border: 1px solid #caa0a0 !important;
    color: #5c1a1a !important;
    border-radius: 0 !important;
    margin-right: 4px !important;
    font-weight: 700 !important;
}

.nav-tabs .nav-link.active {
    background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
    color: #fff !important;
    border-color: #7a2d2d !important;
}

.form-control,
.form-select,
.input-group-text,
.select2-container--bootstrap-5 .select2-selection {
    background: #fffafa !important;
    border: 1px solid #b48787 !important;
    color: #421414 !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    font-size: 12px !important;
}

.form-control:focus,
.form-select:focus,
.select2-container--bootstrap-5.select2-container--focus .select2-selection,
.select2-container--bootstrap-5.select2-container--open .select2-selection {
    border-color: #8b0000 !important;
    box-shadow: 0 0 0 .15rem rgba(139,0,0,.12) !important;
}

.btn-brand {
    background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
    border: 1px solid #7a2d2d !important;
    color: #fff !important;
    border-radius: 0 !important;
}

.btn-outline,
.btn-outline-secondary,
.btn-sm-action {
    background: linear-gradient(#fffefe,#ecd7d7) !important;
    border: 1px solid #b48787 !important;
    color: #4b1f1f !important;
    border-radius: 0 !important;
    font-weight: 700 !important;
}

.btn-outline:hover,
.btn-outline-secondary:hover,
.btn-sm-action:hover {
    background: #f4dddd !important;
    border-color: #8b0000 !important;
    color: #5c0000 !important;
}

.table-responsive {
    background: #fffafa !important;
    border-top: 1px solid #d9b8b8 !important;
}

.table-custom {
    background: #fffafa !important;
    border-collapse: separate !important;
    border-spacing: 0 !important;
    font-size: 12px !important;
}

.table-custom thead th {
    position: sticky;
    top: 0;
    z-index: 10;
    background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
    color: #fff !important;
    border-right: 1px solid #8e3b3b !important;
    border-bottom: 1px solid #5c0000 !important;
    padding: 7px 6px !important;
    font-size: 12px !important;
    text-transform: none !important;
    white-space: nowrap !important;
}

.table-custom tbody td {
    background: #fffafa !important;
    border-right: 1px solid #d8bcbc !important;
    border-bottom: 1px solid #d8bcbc !important;
    color: #401515 !important;
    padding: 6px !important;
}

.table-custom tbody tr:nth-of-type(even) > td {
    background: #f9eded !important;
}

.table-custom tbody tr:hover > td {
    background: #f4dddd !important;
}

.modal-content {
    border: 1px solid #7d4949 !important;
    border-radius: 0 !important;
}

.modal-header {
    background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
    color: #fff !important;
    border-bottom: 1px solid #5c0000 !important;
}

.modal-title {
    color: #fff !important;
    font-size: 13px !important;
    font-weight: 700 !important;
}

.modal-body {
    background: #f0dede !important;
}

.modal-footer {
    background: #f7eaea !important;
    border-top: 1px solid #d3b0b0 !important;
}

.firma-container,
.alerta-item {
    background: #fffafa !important;
    border-color: #c79d9d !important;
    border-radius: 0 !important;
}

/* RESPONSIVO */
@@media (min-width: 1400px) {
    .container-fluid {
        width: calc(100vw - 80px) !important;
    }
}

@@media (max-width: 1200px) {
    .container-fluid {
        width: calc(100vw - 24px) !important;
    }
}

@@media (max-width: 768px) {
    .container-fluid {
        width: 100% !important;
        max-width: 100% !important;
        padding: 6px !important;
    }

    .top-banner {
        padding: 12px !important;
    }

    .top-banner h2 {
        font-size: 18px !important;
    }

    .kpi-container {
        display: grid !important;
        grid-template-columns: 1fr 1fr !important;
        gap: 8px !important;
    }

    .kpi-box {
        min-width: 0 !important;
        padding: 8px !important;
    }

    .kpi-value {
        font-size: 18px !important;
    }

    .dashboard-panel {
        padding: 0 !important;
    }

    .panel-header {
        padding: 8px !important;
    }

    .nav-tabs {
        flex-wrap: nowrap !important;
        overflow-x: auto !important;
    }

    .nav-tabs .nav-link {
        min-width: max-content !important;
        font-size: 11px !important;
        padding: 7px 10px !important;
    }

    .btn,
    .btn-brand,
    .btn-outline,
    .btn-sm-action {
        width: 100% !important;
        font-size: 12px !important;
    }

    .table-responsive {
        width: 100% !important;
        overflow-x: auto !important;
        -webkit-overflow-scrolling: touch !important;
        max-height: 65vh !important;
    }

    .table-custom {
        min-width: 900px !important;
        font-size: 10px !important;
    }

    .table-custom thead th,
    .table-custom tbody td {
        font-size: 10px !important;
        padding: 4px 3px !important;
    }

    .modal-dialog {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
    }

    .modal-content {
        min-height: 100vh !important;
    }
}


/* =========================================================
   KPIS A COLOR - INVENTARIO SISTEMAS
   ========================================================= */

.kpi-container {
    align-items: stretch !important;
}

.kpi-container .kpi-box {
    position: relative !important;
    overflow: hidden !important;
    min-height: 112px !important;
    border-radius: 16px !important;
    border: 1px solid rgba(255,255,255,.30) !important;
    padding: 14px 16px !important;
    box-shadow: inset 4px 0 0 rgba(255,255,255,.18), 0 14px 28px rgba(45, 8, 8, .18) !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: space-between !important;
}

.kpi-container .kpi-box::after {
    content: "";
    position: absolute;
    right: -38px;
    bottom: -48px;
    width: 132px;
    height: 132px;
    border-radius: 999px;
    background: rgba(255,255,255,.15);
    pointer-events: none;
}

.kpi-container .kpi-box::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,.10), rgba(255,255,255,0) 58%);
    pointer-events: none;
}

.kpi-container .kpi-title,
.kpi-container .kpi-value {
    position: relative;
    z-index: 1;
}

.kpi-container .kpi-title {
    color: rgba(255,255,255,.90) !important;
    opacity: 1 !important;
    font-size: .72rem !important;
    font-weight: 900 !important;
    letter-spacing: .06em !important;
}

.kpi-container .kpi-value {
    color: #ffffff !important;
    font-size: clamp(1.65rem, 2.2vw, 2.35rem) !important;
    line-height: 1 !important;
    font-weight: 900 !important;
    text-shadow: 0 2px 8px rgba(0,0,0,.24);
    font-variant-numeric: tabular-nums;
}

/* Total de artículos */
.kpi-container .kpi-total {
    background: linear-gradient(135deg, #7b1113 0%, #a3161a 55%, #5c090b 100%) !important;
}

/* Alertas: ámbar en cero / rojo cuando hay alertas */
.kpi-container .kpi-alertas {
    background: linear-gradient(135deg, #b7791f 0%, #d99a28 55%, #8a4f05 100%) !important;
}

.kpi-container .kpi-alertas.kpi-peligro {
    background: linear-gradient(135deg, #b91c1c 0%, #dc2626 55%, #7f1d1d 100%) !important;
    box-shadow: inset 4px 0 0 rgba(255,255,255,.20), 0 16px 30px rgba(185,28,28,.28) !important;
}

/* Equipos asignados */
.kpi-container .kpi-asignados {
    background: linear-gradient(135deg, #157f49 0%, #22a65a 55%, #0f5132 100%) !important;
}

/* Equipos disponibles */
.kpi-container .kpi-disponibles {
    background: linear-gradient(135deg, #0f766e 0%, #14b8a6 55%, #134e4a 100%) !important;
}

@@media (max-width: 768px) {
    .kpi-container .kpi-box {
        min-height: 96px !important;
        padding: 11px 12px !important;
        border-radius: 14px !important;
    }

    .kpi-container .kpi-title {
        font-size: .63rem !important;
    }

    .kpi-container .kpi-value {
        font-size: clamp(1.35rem, 7vw, 1.8rem) !important;
    }
}

@@media (max-width: 460px) {
    .kpi-container {
        grid-template-columns: 1fr !important;
    }
}

</style>

<div class="container-fluid py-4">

    <div class="top-banner">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="fw-bold mb-1">Inventario Sistemas</h2>
                <p class="mb-0" style="font-size: 0.85rem; opacity: 0.85;">Búsqueda, asignaciones, historial auditable y alertas.</p>
            </div>
            <button type="button" class="btn btn-sm btn-outline-light fw-bold" data-bs-toggle="modal" data-bs-target="#modalNivelesEquipo">
                <i class="bi bi-info-circle-fill me-1"></i> Guia Equipos
            </button>
        </div>

        <div class="kpi-container">
            <div class="kpi-box kpi-total">
                <div class="kpi-title">Artículos Activos</div>
                <div class="kpi-value" id="kpiTotal">0</div>
            </div>

            <div class="kpi-box kpi-alertas">
                <div class="kpi-title">Alertas Activas</div>
                <div class="kpi-value" id="kpiAlertas">0</div>
            </div>

            <div class="kpi-box kpi-asignados">
                <div class="kpi-title">Equipos Asignados</div>
                <div class="kpi-value" id="kpiAsignados">0</div>
            </div>

            <div class="kpi-box kpi-disponibles">
                <div class="kpi-title">Equipos Disponibles</div>
                <div class="kpi-value" id="kpiDisponibles">0</div>
            </div>
        </div>
    </div>
   
    <ul class="nav nav-tabs" id="myTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="explorador-tab" data-bs-toggle="tab" data-bs-target="#explorador" type="button" role="tab">Explorador de inventario</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="movimientos-tab" data-bs-toggle="tab" data-bs-target="#movimientos" type="button" role="tab">Stock y Entradas/Salidas</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="asignaciones-tab" data-bs-toggle="tab" data-bs-target="#asignaciones" type="button" role="tab">Asignaciones e Historial</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="recuperaciones-tab" data-bs-toggle="tab" data-bs-target="#recuperaciones" type="button" role="tab">Recuperaciones</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="taller-tab" data-bs-toggle="tab" data-bs-target="#taller" type="button" role="tab">Taller/Reparaciones </button>
        </li>
    </ul>

    <div class="tab-content" id="myTabContent">

        <div class="tab-pane fade show active" id="explorador" role="tabpanel">
            <div class="dashboard-panel">
                <div class="panel-header d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                    <div class="mb-2 mb-md-0">
                        <h3 class="panel-title">Explorador de inventario</h3>
                        <p class="panel-subtitle">Consulta de equipos y generación de etiquetas QR.</p>
                    </div>
                    <div class="mt-2 mt-md-0">
                        <button class="btn btn-success fw-bold w-100 w-md-auto" onclick="exportarExcel()"><i class="bi bi-file-earmark-excel me-1"></i> Exportar Excel</button>
                    </div>
