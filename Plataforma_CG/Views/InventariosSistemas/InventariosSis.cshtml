        function imprimirQR(id) {
            const item = datosInventario.find(i => Number(i.id) === Number(id));

            if (!item) {
                alert('No se encontró el artículo seleccionado.');
                return;
            }

            const asignacionTxt = item.asignacion ? item.asignacion : 'STOCK';
            const ubicacionTxt = item.ubicacion ? item.ubicacion : 'N/A';
            const hoy = new Date();
            let fCompraStr = 'N/A';
            let fGarantiaStr = 'N/A';
            let fVidaStr = 'N/A';

            if (item.fechaCompra) {
                const fCompra = new Date(item.fechaCompra);
                fCompraStr = fCompra.toLocaleDateString('es-MX');

                if (item.diasGarantia) {
                    const fGarantia = new Date(fCompra);
                    fGarantia.setDate(fGarantia.getDate() + item.diasGarantia);
                    const diasRest = Math.ceil((fGarantia - hoy) / (1000 * 60 * 60 * 24));
                    const estadoG = diasRest < 0 ? '(VENCIDA)' : `(${diasRest} días)`;
                    fGarantiaStr = `${fGarantia.toLocaleDateString('es-MX')} ${estadoG}`;
                }

                const aniosVida = parseInt(item.tiempoVida) || 4;
                const fVida = new Date(fCompra);
                fVida.setFullYear(fVida.getFullYear() + aniosVida);
                fVidaStr = fVida.toLocaleDateString('es-MX');
            }

            const dominioActual = window.location.origin;
            const linkAlSistema = `${dominioActual}/InventariosSistemas/EscanerRapido?id=${item.id}`;

            let textoOffline =
                `INV-IT:${item.id}\n` +
                `[ CONTROL DE INVENTARIOS IT ]\n` +
                `==========================\n` +
                ` SAP:   ${item.idArticuloSap || item.id}\n` +
                ` EQUIP: ${item.nombre || 'SIN NOMBRE'}\n` +
                ` INFO:  ${item.marca || '-'} ${item.modelo || '-'}\n` +
                ` N/S:   ${item.numeroSerie || 'N/A'}\n` +
                ` IP:    ${item.ip || 'N/A'}\n` +
                `--------------------------\n` +
                ` LUGAR: ${item.planta || 'N/A'} | ${ubicacionTxt}\n` +
                ` RESP:  ${asignacionTxt}\n` +
                `--------------------------\n` +
                ` COMPRA:   ${fCompraStr}\n` +
                ` GARANTIA: ${fGarantiaStr}\n` +
                ` FIN VIDA: ${fVidaStr}\n` +
                `==========================\n` +
                ` REVISION IT (ESCANEA AQUÍ):\n` +
                ` ${linkAlSistema}`;

            textoOffline = textoOffline
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '');

            const qrUrl = `@Url.Action("GenerarQRLocal", "InventariosSistemas")?texto=${encodeURIComponent(textoOffline)}`;
            const w = crearVentanaEtiqueta(`QR ${item.idArticuloSap || item.id}`, 430, 610);

            if (!w) return;

            const doc = w.document;
