@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Inventario Independiente";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

<style>
    :root {
        --brand-main: #4a0e0e;
        --brand-hover: #6b1515;
        --bg-page: #fdf5f4;
        --card-bg: #ffffff;
        --panel-bg: #fcf5f4;
        --border-color: #ebdcdb;
        --text-dark: #333333;
        --text-muted: #888888;
    }

    body {
        background-color: var(--bg-page);
        color: var(--text-dark);
        font-family: 'Segoe UI', Tahoma, sans-serif;
        font-size: 0.85rem;
    }

    .dashboard-panel {
        background-color: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border-color);
        margin-bottom: 1.5rem;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    }

    .panel-header {
        background-color: transparent;
        border-bottom: 1px solid var(--border-color);
        padding: 1rem 1.25rem;
    }

    .panel-title {
        font-size: 1rem;
        font-weight: 800;
        color: var(--text-dark);
        margin: 0;
    }

    .panel-subtitle {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin: 0;
    }

    .top-banner {
        background-color: var(--brand-main);
        color: white;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .kpi-container {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .kpi-box {
        background-color: rgba(255,255,255,0.08);
        border-radius: 8px;
        padding: 1rem;
        flex: 1 1 200px;
        min-width: 150px;
    }

    .kpi-title {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        opacity: 0.8;
        margin-bottom: 0.3rem;
    }

    .kpi-value {
        font-size: 1.8rem;
        font-weight: bold;
        margin: 0;
    }

    .nav-tabs {
        border-bottom: 2px solid var(--border-color);
        margin-bottom: 1.5rem;
        flex-wrap: nowrap;
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 2px;
    }

        .nav-tabs::-webkit-scrollbar {
            height: 4px;
        }

        .nav-tabs::-webkit-scrollbar-thumb {
            background: var(--border-color);
            border-radius: 4px;
        }

        .nav-tabs .nav-link {
            color: var(--text-muted);
            font-weight: 600;
            border: none;
            padding: 10px 20px;
            transition: 0.3s;
            background: transparent;
        }

            .nav-tabs .nav-link:hover {
                color: var(--brand-main);
            }

            .nav-tabs .nav-link.active {
                color: var(--brand-main);
                border-bottom: 3px solid var(--brand-main);
                background-color: transparent;
            }

    .tab-content > .tab-pane {
        display: none;
    }

    .tab-content > .active {
        display: block;
        animation: slideFade 0.4s ease-out forwards;
    }

    @@keyframes slideFade {
        0%

    {
        opacity: 0;
        transform: translateX(30px);
    }

    100% {
        opacity: 1;
        transform: translateX(0);
    }

    }

    .btn-brand {
        background-color: var(--brand-main);
        color: white;
        border: none;
        padding: 6px 16px;
        border-radius: 20px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-brand:hover:not(:disabled) {
            background-color: var(--brand-hover);
            color: white;
        }

        .btn-brand:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

    .btn-outline {
        border: 1px solid var(--border-color);
        background: white;
        color: var(--text-dark);
        border-radius: 20px;
        font-weight: 600;
    }

        .btn-outline:hover {
            background: var(--bg-page);
            border-color: var(--brand-main);
            color: var(--brand-main);
        }

    .form-control, .form-select {
        border-color: var(--border-color);
        font-size: 0.85rem;
        border-radius: 6px;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--brand-main);
            box-shadow: 0 0 0 0.2rem rgba(74, 14, 14, 0.15);
        }

    .table-custom {
        margin-bottom: 0;
    }

        .table-custom thead th {
            background-color: var(--panel-bg);
            color: var(--text-muted);
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.7rem;
            border-bottom: 2px solid var(--border-color);
            padding: 12px;
            white-space: nowrap;
        }

        .table-custom tbody tr {
            border-bottom: 1px solid var(--border-color);
        }

        .table-custom tbody td {
            vertical-align: middle;
            padding: 12px;
        }

    .btn-sm-action {
        padding: 4px 8px;
        font-size: 0.75rem;
        border-radius: 6px;
        border: 1px solid var(--border-color);
        background: white;
        cursor: pointer;
        transition: all 0.2s;
        color: var(--text-dark);
        margin-bottom: 2px;
        margin-right: 2px;
    }

        .btn-sm-action:hover:not(:disabled) {
            background: var(--bg-page);
            border-color: var(--brand-main);
            color: var(--brand-main);
        }

    .badge-entrada {
        background-color: #dcfce7;
        color: #166534;
        padding: 3px 8px;
        border-radius: 4px;
        font-weight: bold;
        font-size: 0.7rem;
        border: 1px solid #bbf7d0;
    }

    .badge-salida {
        background-color: #fef08a;
        color: #854d0e;
        padding: 3px 8px;
        border-radius: 4px;
        font-weight: bold;
        font-size: 0.7rem;
        border: 1px solid #fde047;
    }

    .scroll-panel::-webkit-scrollbar {
        width: 6px;
    }

    .scroll-panel::-webkit-scrollbar-thumb {
        background: var(--border-color);
        border-radius: 4px;
    }

    .alerta-item {
        padding: 8px;
        border-radius: 6px;
        border-left: 4px solid;
        margin-bottom: 8px;
        font-size: 0.8rem;
        background: white;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    .btn-check:checked + .btn-outline-danger {
        background-color: var(--brand-main);
        border-color: var(--brand-main);
        color: white;
    }

    .btn-outline-danger {
        border-color: var(--border-color);
        color: var(--text-muted);
        font-weight: bold;
        font-size: 0.75rem;
        white-space: normal;
    }

        .btn-outline-danger:hover {
            background-color: var(--panel-bg);
            color: var(--brand-main);
        }

    .firma-container {
        border: 2px dashed var(--border-color);
        background-color: white;
        border-radius: 8px;
        overflow: hidden;
        position: relative;
        touch-action: none;
    }

    #firmaCanvas {
        width: 100%;
        height: 150px;
        cursor: crosshair;
    }

    @@media (max-width: 768px) {
        .kpi-box

    {
        flex: 1 1 45%;
        padding: 0.8rem;
        min-width: 40%;
    }

    .kpi-value {
        font-size: 1.4rem;
    }

    .top-banner {
        padding: 1rem;
    }

    .table-custom tbody td {
        white-space: nowrap;
    }

    .btn-sm-action {
        padding: 6px 10px;
        font-size: 0.8rem;
    }

    }


    .select2-container--bootstrap-5 .select2-selection {
        font-size: 0.85rem;
        min-height: calc(1.5em + .75rem + 2px);
        border: 1px solid var(--border-color);
        border-radius: 6px;
    }

    .select2-container--bootstrap-5.select2-container--focus .select2-selection,
    .select2-container--bootstrap-5.select2-container--open .select2-selection {
        border-color: var(--brand-main);
        box-shadow: 0 0 0 0.2rem rgba(74, 14, 14, 0.15);
    }

    .select2-container--bootstrap-5 .select2-results__option--highlighted[aria-selected] {
        background-color: var(--brand-main) !important;
        color: white !important;
    }

    .select2-container--bootstrap-5 .select2-search__field:focus {
        box-shadow: 0 0 0 0.2rem rgba(74, 14, 14, 0.15);
        border-color: var(--brand-main);
    }

    /* ESTILO ROSITA / VINO + RESPONSIVO */
html,
body {
    background: #e9edf2 !important;
    overflow-x: hidden !important;
}

body,
main,
.main,
.body-content,
.container,
.container-fluid {
    background: #e9edf2 !important;
}

.container-fluid {
    width: min(100%, calc(100vw - 48px)) !important;
    max-width: 1900px !important;
    margin: 0 auto !important;
    padding: 8px !important;
}

.top-banner {
    background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
    border: 1px solid #7e4a4a !important;
    border-radius: 0 !important;
    box-shadow: 0 8px 18px rgba(70,12,12,.14) !important;
}

.kpi-box {
    background: rgba(255,255,255,.12) !important;
    border: 1px solid rgba(255,255,255,.22) !important;
    border-radius: 0 !important;
}

.dashboard-panel {
    background: #f8eeee !important;
    border: 1px solid #c79d9d !important;
    border-radius: 0 !important;
    box-shadow: none !important;
}

.panel-header {
    background: #f1dede !important;
    border-bottom: 1px solid #c79d9d !important;
}

.panel-title {
    color: #5c1a1a !important;
}

.panel-subtitle {
    color: #6a3a3a !important;
}

.nav-tabs {
    background: #f1dede !important;
    border: 1px solid #c79d9d !important;
    padding: 4px !important;
    margin-bottom: 12px !important;
}

.nav-tabs .nav-link {
    background: linear-gradient(#fffefe,#ecd7d7) !important;
    border: 1px solid #caa0a0 !important;
    color: #5c1a1a !important;
    border-radius: 0 !important;
    margin-right: 4px !important;
    font-weight: 700 !important;
}

.nav-tabs .nav-link.active {
    background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
    color: #fff !important;
    border-color: #7a2d2d !important;
}

.form-control,
.form-select,
.input-group-text,
.select2-container--bootstrap-5 .select2-selection {
    background: #fffafa !important;
    border: 1px solid #b48787 !important;
    color: #421414 !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    font-size: 12px !important;
}

.form-control:focus,
.form-select:focus,
.select2-container--bootstrap-5.select2-container--focus .select2-selection,
.select2-container--bootstrap-5.select2-container--open .select2-selection {
    border-color: #8b0000 !important;
    box-shadow: 0 0 0 .15rem rgba(139,0,0,.12) !important;
}

.btn-brand {
    background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
    border: 1px solid #7a2d2d !important;
    color: #fff !important;
    border-radius: 0 !important;
}

.btn-outline,
.btn-outline-secondary,
.btn-sm-action {
    background: linear-gradient(#fffefe,#ecd7d7) !important;
    border: 1px solid #b48787 !important;
    color: #4b1f1f !important;
    border-radius: 0 !important;
    font-weight: 700 !important;
}

.btn-outline:hover,
.btn-outline-secondary:hover,
.btn-sm-action:hover {
    background: #f4dddd !important;
    border-color: #8b0000 !important;
    color: #5c0000 !important;
}

.table-responsive {
    background: #fffafa !important;
    border-top: 1px solid #d9b8b8 !important;
}

.table-custom {
    background: #fffafa !important;
    border-collapse: separate !important;
    border-spacing: 0 !important;
    font-size: 12px !important;
}

.table-custom thead th {
    position: sticky;
    top: 0;
    z-index: 10;
    background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
    color: #fff !important;
    border-right: 1px solid #8e3b3b !important;
    border-bottom: 1px solid #5c0000 !important;
    padding: 7px 6px !important;
    font-size: 12px !important;
    text-transform: none !important;
    white-space: nowrap !important;
}

.table-custom tbody td {
    background: #fffafa !important;
    border-right: 1px solid #d8bcbc !important;
    border-bottom: 1px solid #d8bcbc !important;
    color: #401515 !important;
    padding: 6px !important;
}

.table-custom tbody tr:nth-of-type(even) > td {
    background: #f9eded !important;
}

.table-custom tbody tr:hover > td {
    background: #f4dddd !important;
}

.modal-content {
    border: 1px solid #7d4949 !important;
    border-radius: 0 !important;
}

.modal-header {
    background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
    color: #fff !important;
    border-bottom: 1px solid #5c0000 !important;
}

.modal-title {
    color: #fff !important;
    font-size: 13px !important;
    font-weight: 700 !important;
}

.modal-body {
    background: #f0dede !important;
}

.modal-footer {
    background: #f7eaea !important;
    border-top: 1px solid #d3b0b0 !important;
}

.firma-container,
.alerta-item {
    background: #fffafa !important;
    border-color: #c79d9d !important;
    border-radius: 0 !important;
}

/* RESPONSIVO */
@@media (min-width: 1400px) {
    .container-fluid {
        width: calc(100vw - 80px) !important;
    }
}

@@media (max-width: 1200px) {
    .container-fluid {
        width: calc(100vw - 24px) !important;
    }
}

@@media (max-width: 768px) {
    .container-fluid {
        width: 100% !important;
        max-width: 100% !important;
        padding: 6px !important;
    }

    .top-banner {
        padding: 12px !important;
    }

    .top-banner h2 {
        font-size: 18px !important;
    }

    .kpi-container {
        display: grid !important;
        grid-template-columns: 1fr 1fr !important;
        gap: 8px !important;
    }

    .kpi-box {
        min-width: 0 !important;
        padding: 8px !important;
    }

    .kpi-value {
        font-size: 18px !important;
    }

    .dashboard-panel {
        padding: 0 !important;
    }

    .panel-header {
        padding: 8px !important;
    }

    .nav-tabs {
        flex-wrap: nowrap !important;
        overflow-x: auto !important;
    }

    .nav-tabs .nav-link {
        min-width: max-content !important;
        font-size: 11px !important;
        padding: 7px 10px !important;
    }

    .btn,
    .btn-brand,
    .btn-outline,
    .btn-sm-action {
        width: 100% !important;
        font-size: 12px !important;
    }

    .table-responsive {
        width: 100% !important;
        overflow-x: auto !important;
        -webkit-overflow-scrolling: touch !important;
        max-height: 65vh !important;
    }

    .table-custom {
        min-width: 900px !important;
        font-size: 10px !important;
    }

    .table-custom thead th,
    .table-custom tbody td {
        font-size: 10px !important;
        padding: 4px 3px !important;
    }

    .modal-dialog {
        width: 100% !important;
        max-width: 100% !important;
        margin: 0 !important;
    }

    .modal-content {
        min-height: 100vh !important;
    }
}


/* =========================================================
   KPIS A COLOR - INVENTARIO SISTEMAS
   ========================================================= */

.kpi-container {
    align-items: stretch !important;
}

.kpi-container .kpi-box {
    position: relative !important;
    overflow: hidden !important;
    min-height: 112px !important;
    border-radius: 16px !important;
    border: 1px solid rgba(255,255,255,.30) !important;
    padding: 14px 16px !important;
    box-shadow: inset 4px 0 0 rgba(255,255,255,.18), 0 14px 28px rgba(45, 8, 8, .18) !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: space-between !important;
}

.kpi-container .kpi-box::after {
    content: "";
    position: absolute;
    right: -38px;
    bottom: -48px;
    width: 132px;
    height: 132px;
    border-radius: 999px;
    background: rgba(255,255,255,.15);
    pointer-events: none;
}

.kpi-container .kpi-box::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,.10), rgba(255,255,255,0) 58%);
    pointer-events: none;
}

.kpi-container .kpi-title,
.kpi-container .kpi-value {
    position: relative;
    z-index: 1;
}

.kpi-container .kpi-title {
    color: rgba(255,255,255,.90) !important;
    opacity: 1 !important;
    font-size: .72rem !important;
    font-weight: 900 !important;
    letter-spacing: .06em !important;
}

.kpi-container .kpi-value {
    color: #ffffff !important;
    font-size: clamp(1.65rem, 2.2vw, 2.35rem) !important;
    line-height: 1 !important;
    font-weight: 900 !important;
    text-shadow: 0 2px 8px rgba(0,0,0,.24);
    font-variant-numeric: tabular-nums;
}

/* Total de artículos */
.kpi-container .kpi-total {
    background: linear-gradient(135deg, #7b1113 0%, #a3161a 55%, #5c090b 100%) !important;
}

/* Alertas: ámbar en cero / rojo cuando hay alertas */
.kpi-container .kpi-alertas {
    background: linear-gradient(135deg, #b7791f 0%, #d99a28 55%, #8a4f05 100%) !important;
}

.kpi-container .kpi-alertas.kpi-peligro {
    background: linear-gradient(135deg, #b91c1c 0%, #dc2626 55%, #7f1d1d 100%) !important;
    box-shadow: inset 4px 0 0 rgba(255,255,255,.20), 0 16px 30px rgba(185,28,28,.28) !important;
}

/* Equipos asignados */
.kpi-container .kpi-asignados {
    background: linear-gradient(135deg, #157f49 0%, #22a65a 55%, #0f5132 100%) !important;
}

/* Equipos disponibles */
.kpi-container .kpi-disponibles {
    background: linear-gradient(135deg, #0f766e 0%, #14b8a6 55%, #134e4a 100%) !important;
}

@@media (max-width: 768px) {
    .kpi-container .kpi-box {
        min-height: 96px !important;
        padding: 11px 12px !important;
        border-radius: 14px !important;
    }

    .kpi-container .kpi-title {
        font-size: .63rem !important;
    }

    .kpi-container .kpi-value {
        font-size: clamp(1.35rem, 7vw, 1.8rem) !important;
    }
}

@@media (max-width: 460px) {
    .kpi-container {
        grid-template-columns: 1fr !important;
    }
}



/* =========================================================
   MAPA TI INDUSTRIAL 2D / PSEUDO 3D
   Inventario visual por áreas y equipos.
   ========================================================= */
.mapa-ti-shell {
    --map-bg: #07131c;
    --map-panel: #0e202d;
    --map-panel-2: #132b3a;
    --map-line: rgba(105, 210, 255, .20);
    --map-cyan: #42d6ff;
    --map-green: #39d98a;
    --map-amber: #ffbf47;
    --map-red: #ff5b66;
    --map-muted: #91a9b7;
    display: grid;
    grid-template-columns: 280px minmax(520px, 1fr) 310px;
    min-height: 690px;
    background: #08151f;
    border: 1px solid #17384a;
    color: #eaf8ff;
}

.mapa-ti-sidebar,
.mapa-ti-inspector {
    min-width: 0;
    background:
        linear-gradient(180deg, rgba(255,255,255,.025), transparent 120px),
        var(--map-panel);
    overflow: hidden;
}

.mapa-ti-sidebar {
    border-right: 1px solid #23485c;
}

.mapa-ti-inspector {
    border-left: 1px solid #23485c;
}

.mapa-ti-side-head {
    padding: 14px;
    border-bottom: 1px solid #23485c;
    background: linear-gradient(135deg, #132f40, #0a1b27);
}

.mapa-ti-side-head h4 {
    margin: 0;
    color: #fff;
    font-size: 14px;
    font-weight: 900;
    letter-spacing: .03em;
}

.mapa-ti-side-head p {
    margin: 4px 0 0;
    color: var(--map-muted);
    font-size: 11px;
}

.mapa-ti-filter {
    padding: 10px;
    border-bottom: 1px solid #23485c;
    display: grid;
    gap: 8px;
}

.mapa-ti-filter input,
.mapa-ti-filter select,
.mapa-ti-inspector input,
.mapa-ti-inspector select {
    width: 100%;
    min-width: 0;
    height: 36px !important;
    padding: 6px 9px !important;
    border: 1px solid #31596e !important;
    border-radius: 7px !important;
    background: #091923 !important;
    color: #e8f8ff !important;
    font-size: 12px !important;
    box-shadow: none !important;
}

.mapa-ti-filter input::placeholder,
.mapa-ti-inspector input::placeholder {
    color: #668392;
}

.mapa-ti-equipment-list {
    height: 575px;
    overflow-y: auto;
    padding: 10px;
}

.mapa-ti-palette-item {
    display: grid;
    grid-template-columns: 40px minmax(0, 1fr) auto;
    gap: 9px;
    align-items: center;
    margin-bottom: 8px;
    padding: 9px;
    border: 1px solid #24495d;
    border-radius: 9px;
    background: linear-gradient(135deg, #142d3b, #0c1e29);
    cursor: grab;
    user-select: none;
    transition: transform .15s ease, border-color .15s ease, background .15s ease;
}

.mapa-ti-palette-item:hover {
    transform: translateY(-1px);
    border-color: #42d6ff;
    background: linear-gradient(135deg, #17384a, #0d2431);
}

.mapa-ti-palette-item:active {
    cursor: grabbing;
}

.mapa-ti-device-icon {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border: 1px solid #32647c;
    border-radius: 9px;
    background: #08151e;
    font-size: 22px;
}

.mapa-ti-palette-name {
    overflow: hidden;
}

.mapa-ti-palette-name strong,
.mapa-ti-palette-name small {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.mapa-ti-palette-name strong {
    font-size: 12px;
    color: #f5fcff;
}

.mapa-ti-palette-name small {
    margin-top: 2px;
    color: #8da6b4;
    font-size: 10px;
}

.mapa-ti-status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    box-shadow: 0 0 10px currentColor;
}

.mapa-ti-status-dot.online { color: var(--map-green); background: var(--map-green); }
.mapa-ti-status-dot.offline { color: var(--map-red); background: var(--map-red); }
.mapa-ti-status-dot.maintenance { color: var(--map-amber); background: var(--map-amber); }
.mapa-ti-status-dot.unknown,
.mapa-ti-status-dot.noip { color: #7892a0; background: #7892a0; }

.mapa-ti-center {
    min-width: 0;
    display: flex;
    flex-direction: column;
    background: #061019;
}

.mapa-ti-toolbar {
    min-height: 58px;
    padding: 9px 11px;
    display: flex;
    align-items: center;
    gap: 7px;
    flex-wrap: wrap;
    border-bottom: 1px solid #23485c;
    background: linear-gradient(180deg, #173244, #0d202c);
}

.mapa-ti-toolbar-title {
    min-width: 210px;
    margin-right: auto;
}

.mapa-ti-toolbar-title strong {
    display: block;
    color: #fff;
    font-size: 14px;
    letter-spacing: .04em;
}

.mapa-ti-toolbar-title small {
    color: #88a6b7;
    font-size: 10px;
}

.mapa-ti-btn {
    min-height: 34px;
    padding: 0 11px;
    border: 1px solid #315d73;
    border-radius: 7px;
    background: linear-gradient(180deg, #18394b, #102735);
    color: #eafaff;
    font-size: 11px;
    font-weight: 800;
    cursor: pointer;
}

.mapa-ti-btn:hover {
    border-color: var(--map-cyan);
    background: #173e52;
}

.mapa-ti-btn.primary {
    border-color: #007da4;
    background: linear-gradient(135deg, #0088b2, #07536d);
}

.mapa-ti-btn.danger {
    border-color: #8b2930;
    background: linear-gradient(135deg, #8f2630, #52171d);
}

.mapa-ti-kpis {
    display: grid;
    grid-template-columns: repeat(4, minmax(90px, 1fr));
    gap: 7px;
    padding: 8px 10px;
    border-bottom: 1px solid #1c3b4c;
    background: #0a1a25;
}

.mapa-ti-kpi {
    min-width: 0;
    padding: 7px 9px;
    border: 1px solid #21475a;
    border-radius: 7px;
    background: #0d2230;
}

.mapa-ti-kpi span,
.mapa-ti-kpi strong {
    display: block;
}

.mapa-ti-kpi span {
    color: #7f9aa9;
    font-size: 9px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .06em;
}

.mapa-ti-kpi strong {
    margin-top: 2px;
    color: #fff;
    font-size: 18px;
    line-height: 1;
}

.mapa-ti-viewport {
    position: relative;
    flex: 1 1 auto;
    min-height: 560px;
    overflow: auto;
    background: #050d13;
}

.mapa-ti-canvas {
    position: relative;
    width: 100%;
    min-width: 760px;
    height: 610px;
    overflow: hidden;
    transform-origin: center center;
    background-color: var(--map-bg);
    background-image:
        linear-gradient(var(--map-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--map-line) 1px, transparent 1px),
        radial-gradient(circle at 35% 25%, rgba(20, 132, 177, .16), transparent 38%),
        linear-gradient(145deg, #092332 0%, #07151f 55%, #061019 100%);
    background-size: 28px 28px, 28px 28px, auto, auto;
    background-position: center;
}

.mapa-ti-canvas.has-background::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: var(--map-background-image);
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    opacity: .42;
    filter: saturate(.8) contrast(1.15);
    pointer-events: none;
}

.mapa-ti-canvas::after {
    content: "SIGO  ·  MAPA TI INDUSTRIAL";
    position: absolute;
    right: 16px;
    bottom: 10px;
    z-index: 1;
    color: rgba(93, 210, 255, .20);
    font-size: 13px;
    font-weight: 900;
    letter-spacing: .16em;
    pointer-events: none;
}

.mapa-ti-area {
    position: absolute;
    z-index: 2;
    min-width: 100px;
    min-height: 80px;
    border: 2px solid var(--area-color, #3ec7f3);
    border-radius: 10px;
    background:
        linear-gradient(145deg, color-mix(in srgb, var(--area-color) 18%, transparent), rgba(5, 20, 28, .72));
    box-shadow:
        inset 0 0 30px color-mix(in srgb, var(--area-color) 10%, transparent),
        0 10px 22px rgba(0,0,0,.25);
    transition: transform .18s ease, box-shadow .18s ease;
}

.mapa-ti-canvas.modo-3d .mapa-ti-area {
    transform: translateY(-5px) skewY(-1.5deg);
    box-shadow:
        0 7px 0 color-mix(in srgb, var(--area-color) 42%, #051019),
        0 16px 28px rgba(0,0,0,.42),
        inset 0 0 30px color-mix(in srgb, var(--area-color) 12%, transparent);
}

.mapa-ti-area.selected {
    outline: 2px solid #fff;
    outline-offset: 3px;
}

.mapa-ti-area-title {
    height: 28px;
    padding: 5px 8px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    border-bottom: 1px solid color-mix(in srgb, var(--area-color) 65%, transparent);
    background: color-mix(in srgb, var(--area-color) 20%, #07141d);
    color: #fff;
    font-size: 10px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .08em;
    cursor: move;
}

.mapa-ti-area-title small {
    color: #d7f5ff;
    font-size: 9px;
    letter-spacing: 0;
}

.mapa-ti-area-body {
    position: absolute;
    inset: 28px 0 0;
    pointer-events: none;
}

.mapa-ti-resize {
    position: absolute;
    right: -5px;
    bottom: -5px;
    z-index: 5;
    width: 14px;
    height: 14px;
    border: 2px solid #fff;
    border-radius: 3px;
    background: var(--area-color, #42d6ff);
    cursor: nwse-resize;
}

.mapa-ti-map-device {
    position: absolute;
    z-index: 10;
    width: 86px;
    min-height: 72px;
    padding: 6px;
    border: 1px solid #37677d;
    border-radius: 9px;
    background: linear-gradient(145deg, rgba(24,55,71,.96), rgba(8,23,32,.96));
    color: #fff;
    text-align: center;
    cursor: grab;
    user-select: none;
    box-shadow: 0 9px 18px rgba(0,0,0,.32);
    touch-action: none;
}

.mapa-ti-canvas.modo-3d .mapa-ti-map-device {
    box-shadow: 4px 7px 0 #071018, 0 14px 20px rgba(0,0,0,.38);
}

.mapa-ti-map-device:active {
    cursor: grabbing;
}

.mapa-ti-map-device.selected {
    border-color: #fff;
    outline: 2px solid var(--map-cyan);
    outline-offset: 2px;
}

.mapa-ti-map-device .device-emoji {
    display: block;
    font-size: 26px;
    line-height: 1;
}

.mapa-ti-map-device strong,
.mapa-ti-map-device small {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.mapa-ti-map-device strong {
    margin-top: 4px;
    font-size: 9px;
}

.mapa-ti-map-device small {
    margin-top: 2px;
    color: #9fc1d0;
    font-family: Consolas, monospace;
    font-size: 8px;
}

.mapa-ti-map-device .map-status {
    position: absolute;
    right: 5px;
    top: 5px;
}

.mapa-ti-empty {
    padding: 24px 12px;
    color: #7994a4;
    text-align: center;
    font-size: 11px;
}

.mapa-ti-inspector-body {
    height: 630px;
    padding: 12px;
    overflow-y: auto;
}

.mapa-ti-inspector-card {
    margin-bottom: 10px;
    padding: 11px;
    border: 1px solid #244b5e;
    border-radius: 9px;
    background: linear-gradient(145deg, #142e3d, #0a1b26);
}

.mapa-ti-inspector-card h5 {
    margin: 0 0 9px;
    color: #fff;
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .05em;
}

.mapa-ti-field {
    margin-bottom: 9px;
}

.mapa-ti-field label {
    display: block;
    margin-bottom: 3px;
    color: #7797a8;
    font-size: 9px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .07em;
}

.mapa-ti-readonly {
    min-height: 32px;
    padding: 7px 8px;
    border: 1px solid #24485a;
    border-radius: 6px;
    background: #081821;
    color: #e7f8ff;
    font-size: 11px;
    overflow-wrap: anywhere;
}

.mapa-ti-inspector-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 7px;
}

.mapa-ti-legend {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
}

.mapa-ti-legend div {
    display: flex;
    align-items: center;
    gap: 7px;
    color: #a7bfca;
    font-size: 10px;
}

.mapa-ti-file {
    display: none;
}

.mapa-ti-help {
    padding: 10px 12px;
    border-top: 1px solid #23485c;
    background: #07151f;
    color: #7795a5;
    font-size: 10px;
    line-height: 1.45;
}

@@media (max-width: 1350px) {
    .mapa-ti-shell {
        grid-template-columns: 240px minmax(480px, 1fr) 270px;
    }
}

@@media (max-width: 1050px) {
    .mapa-ti-shell {
        grid-template-columns: 220px minmax(650px, 1fr);
        overflow-x: auto;
    }

    .mapa-ti-inspector {
        position: absolute;
        right: 12px;
        top: 115px;
        z-index: 40;
        width: 300px;
        max-height: 650px;
        border: 1px solid #31596e;
        box-shadow: 0 16px 34px rgba(0,0,0,.55);
    }
}

@@media (max-width: 768px) {
    .mapa-ti-shell {
        display: block;
        min-height: auto;
    }

    .mapa-ti-sidebar,
    .mapa-ti-inspector {
        position: static;
        width: auto;
        max-height: none;
        border: 0;
    }

    .mapa-ti-equipment-list {
        height: 230px;
    }

    .mapa-ti-inspector-body {
        height: auto;
        max-height: 500px;
    }

    .mapa-ti-center {
        min-height: 650px;
    }

    .mapa-ti-kpis {
        grid-template-columns: repeat(2, 1fr);
    }

    .mapa-ti-toolbar-title {
        width: 100%;
        margin-right: 0;
    }
}



/* =========================================================
   MAPA TI — PANTALLA COMPLETA Y AJUSTE AUTOMÁTICO
   ========================================================= */

/* Al abrir la pestaña del mapa se aprovecha todo el ancho disponible. */
body.mapa-ti-pagina-activa {
    overflow: hidden !important;
}

body.mapa-ti-pagina-activa > main,
body.mapa-ti-pagina-activa main,
body.mapa-ti-pagina-activa .main,
body.mapa-ti-pagina-activa .body-content {
    max-width: none !important;
    width: 100% !important;
}

body.mapa-ti-pagina-activa .container-fluid {
    width: 100vw !important;
    max-width: none !important;
    margin: 0 !important;
    padding: 0 6px 6px !important;
}

body.mapa-ti-pagina-activa .top-banner {
    display: none !important;
}

body.mapa-ti-pagina-activa #myTab {
    margin: 0 !important;
    padding: 4px 6px !important;
    min-height: 42px !important;
    border-left: 0 !important;
    border-right: 0 !important;
}

body.mapa-ti-pagina-activa #mapa-ti {
    width: 100% !important;
    height: auto !important;
    margin: 0 !important;
    padding: 0 !important;
}

body.mapa-ti-pagina-activa #mapa-ti > .dashboard-panel {
    width: 100% !important;
    height: auto !important;
    margin: 0 !important;
    border: 0 !important;
    box-shadow: none !important;
    overflow: visible !important;
}

body.mapa-ti-pagina-activa #mapa-ti > .dashboard-panel > .panel-header {
    display: none !important;
}

/* El mapa ocupa todo el espacio visible restante. */
#mapaTiShell {
    position: relative;
    width: 100% !important;
    max-width: none !important;
    height: var(--mapa-ti-altura, calc(100dvh - 108px)) !important;
    min-height: 520px !important;
    overflow: hidden !important;
    grid-template-columns:
        clamp(190px, 15vw, 260px)
        minmax(0, 1fr)
        clamp(225px, 18vw, 300px) !important;
}

#mapaTiShell .mapa-ti-sidebar,
#mapaTiShell .mapa-ti-center,
#mapaTiShell .mapa-ti-inspector {
    height: 100% !important;
    min-height: 0 !important;
}

#mapaTiShell .mapa-ti-sidebar,
#mapaTiShell .mapa-ti-inspector {
    display: flex !important;
    flex-direction: column !important;
}

#mapaTiShell .mapa-ti-equipment-list {
    flex: 1 1 auto !important;
    height: auto !important;
    min-height: 0 !important;
    overflow-y: auto !important;
}

#mapaTiShell .mapa-ti-inspector-body {
    flex: 1 1 auto !important;
    height: auto !important;
    min-height: 0 !important;
    overflow-y: auto !important;
}

#mapaTiShell .mapa-ti-center {
    min-width: 0 !important;
    display: flex !important;
    flex-direction: column !important;
    overflow: hidden !important;
}

#mapaTiShell .mapa-ti-toolbar {
    flex: 0 0 auto !important;
}

#mapaTiShell .mapa-ti-kpis {
    flex: 0 0 auto !important;
}

#mapaTiShell .mapa-ti-viewport {
    flex: 1 1 auto !important;
    width: 100% !important;
    min-width: 0 !important;
    min-height: 0 !important;
    height: auto !important;
    overflow: auto !important;
}

#mapaTiShell .mapa-ti-canvas {
    width: 100% !important;
    min-width: 720px !important;
    height: 100% !important;
    min-height: 470px !important;
}

/* Modo "solo plano": oculta laterales para maximizar el lienzo. */
#mapaTiShell.mapa-ti-solo-plano {
    grid-template-columns: 0 minmax(0, 1fr) 0 !important;
}

#mapaTiShell.mapa-ti-solo-plano .mapa-ti-sidebar,
#mapaTiShell.mapa-ti-solo-plano .mapa-ti-inspector {
    display: none !important;
}

#mapaTiShell.mapa-ti-solo-plano .mapa-ti-canvas {
    min-width: 0 !important;
}

/* Fullscreen nativo del navegador. */
#mapaTiShell:fullscreen,
#mapaTiShell:-webkit-full-screen {
    width: 100vw !important;
    height: 100vh !important;
    min-height: 100vh !important;
    max-width: none !important;
    margin: 0 !important;
    border: 0 !important;
    background: #061019 !important;
}

#mapaTiShell:fullscreen .mapa-ti-canvas,
#mapaTiShell:-webkit-full-screen .mapa-ti-canvas {
    min-height: 0 !important;
    height: 100% !important;
}

/* Laptop y pantallas medianas. */
@@media (max-width: 1280px) {
    #mapaTiShell {
        grid-template-columns:
            clamp(180px, 15vw, 225px)
            minmax(0, 1fr)
            clamp(210px, 18vw, 265px) !important;
    }

    #mapaTiShell .mapa-ti-toolbar {
        gap: 5px !important;
        padding: 7px 8px !important;
    }

    #mapaTiShell .mapa-ti-btn {
        min-height: 31px !important;
        padding: 0 8px !important;
        font-size: 10px !important;
    }

    #mapaTiShell .mapa-ti-toolbar-title {
        min-width: 170px !important;
    }
}

/* Tablet horizontal: inspector flotante para dar más espacio al plano. */
@@media (max-width: 1000px) and (min-width: 769px) {
    #mapaTiShell {
        grid-template-columns: 205px minmax(0, 1fr) !important;
    }

    #mapaTiShell .mapa-ti-inspector {
        position: absolute !important;
        top: 58px !important;
        right: 8px !important;
        bottom: 8px !important;
        z-index: 80 !important;
        width: min(300px, 38vw) !important;
        height: auto !important;
        border: 1px solid #31596e !important;
        box-shadow: 0 18px 38px rgba(0,0,0,.60) !important;
    }

    #mapaTiShell.mapa-ti-solo-plano {
        grid-template-columns: minmax(0, 1fr) !important;
    }
}

/* Móvil: bloques apilados y el mapa ocupa el ancho total. */
@@media (max-width: 768px) {
    body.mapa-ti-pagina-activa {
        overflow-y: auto !important;
    }

    body.mapa-ti-pagina-activa .container-fluid {
        padding: 0 !important;
    }

    #mapaTiShell {
        display: flex !important;
        flex-direction: column !important;
        height: auto !important;
        min-height: calc(100dvh - 52px) !important;
        overflow: visible !important;
    }

    #mapaTiShell .mapa-ti-center {
        order: 1;
        width: 100% !important;
        min-height: 72dvh !important;
    }

    #mapaTiShell .mapa-ti-sidebar {
        order: 2;
        width: 100% !important;
        height: 300px !important;
    }

    #mapaTiShell .mapa-ti-inspector {
        order: 3;
        position: static !important;
        width: 100% !important;
        height: auto !important;
        max-height: 520px !important;
    }

    #mapaTiShell .mapa-ti-viewport {
        min-height: 58dvh !important;
    }

    #mapaTiShell .mapa-ti-canvas {
        min-width: 680px !important;
        min-height: 58dvh !important;
    }

    #mapaTiShell .mapa-ti-toolbar-title {
        width: 100% !important;
        min-width: 0 !important;
        margin-right: 0 !important;
    }

    #mapaTiShell .mapa-ti-toolbar {
        align-items: stretch !important;
    }

    #mapaTiShell .mapa-ti-btn {
        flex: 1 1 115px !important;
    }

    #mapaTiShell.mapa-ti-solo-plano .mapa-ti-sidebar,
    #mapaTiShell.mapa-ti-solo-plano .mapa-ti-inspector {
        display: none !important;
    }
}



/* =========================================================
   MAPA TI COMO MODAL FULLSCREEN
   ========================================================= */
