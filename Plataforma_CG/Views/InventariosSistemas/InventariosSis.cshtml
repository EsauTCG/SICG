    width: 100% !important;
    height: calc(100dvh - 58px) !important;
    min-height: 0 !important;
    overflow: hidden !important;
    background: #061019 !important;
}

.mapa-ti-modal #mapaTiShell {
    width: 100% !important;
    max-width: none !important;
    height: 100% !important;
    min-height: 0 !important;
    margin: 0 !important;
    border: 0 !important;
    overflow: hidden !important;
    grid-template-columns:
        clamp(190px, 15vw, 270px)
        minmax(0, 1fr)
        clamp(225px, 18vw, 310px) !important;
}

.mapa-ti-modal #mapaTiShell .mapa-ti-sidebar,
.mapa-ti-modal #mapaTiShell .mapa-ti-center,
.mapa-ti-modal #mapaTiShell .mapa-ti-inspector {
    height: 100% !important;
    min-height: 0 !important;
}

.mapa-ti-modal #mapaTiShell .mapa-ti-sidebar,
.mapa-ti-modal #mapaTiShell .mapa-ti-inspector {
    display: flex !important;
    flex-direction: column !important;
}

.mapa-ti-modal #mapaTiShell .mapa-ti-equipment-list,
.mapa-ti-modal #mapaTiShell .mapa-ti-inspector-body {
    flex: 1 1 auto !important;
    height: auto !important;
    min-height: 0 !important;
    overflow-y: auto !important;
}

.mapa-ti-modal #mapaTiShell .mapa-ti-center {
    min-width: 0 !important;
    display: flex !important;
    flex-direction: column !important;
    overflow: hidden !important;
}

.mapa-ti-modal #mapaTiShell .mapa-ti-toolbar,
.mapa-ti-modal #mapaTiShell .mapa-ti-kpis {
    flex: 0 0 auto !important;
}

