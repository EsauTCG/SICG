             }

             if (tipoArt === 'Chatarra/Piezas') {
                 proveedor = "N/A";
                 costo = "0";
                 serie = "N/A";
                 fEntrada = new Date().toISOString().split('T')[0];
                 fCompra = null; // <-- BLINDAJE C#
                 dGarantia = "0";
                 tVida = "0";
                 stockMinimo = "0";
             } else {
                 // Si NO es chatarra, exigimos los campos avanzados
                 if (!proveedor || !costo || !serie || !fEntrada || !fCompra || !dGarantia || !tVida) {
                     alert('Llena TODOS los campos avanzados para registrar el equipo.');
                     return;
                 }
                 if (tipoArt === 'Consumible' && !stockMinimo) {
                     alert('Ingresa el Stock Mínimo para el artículo consumible.');
                     return;
                 }
             }

             let asignacionActual = idArticuloEditando > 0 ? $('#entAsignacion').val().trim() : '';

             if (tipoArt === 'Chatarra/Piezas' && idArticuloEditando === 0) {
                 asignacionActual = $('input[name="optChatarraDestino"]:checked').val();
             }

             const item = {
                 Id: idArticuloEditando,
                 TipoArticulo: tipoArt,
                 IdArticuloSap: sap, Nombre: nombre, Marca: marca, Modelo: modelo,
                 Proveedor: proveedor, Costo: parseFloat(costo) || 0,
                 NumeroSerie: serie, IP: ip, Planta: planta, Ubicacion: ubicacion,
                 Asignacion: asignacionActual,
                 DiasGarantia: parseInt(dGarantia) || 0,
                 FechaCompra: fCompra ? fCompra : null, // <-- BLINDAJE C#
                 FechaEntrada: fEntrada ? fEntrada : null, // <-- BLINDAJE C#
                 TiempoVida: tVida, Stock: parseInt(stock) || 1,
                 StockMinimo: tipoArt === 'Consumible' ? parseInt(stockMinimo) || 1 : 0
             };

             const originalText = btnElement.innerHTML;
             const eraAltaNueva = idArticuloEditando === 0;
             const sapGuardado = sap;

             try {
                 btnElement.disabled = true;
                 btnElement.innerHTML = "Guardando...";

                 let urlGuardar = '@Url.Action("GuardarArticulo", "InventariosSistemas")';
                 if (idArticuloEditando > 0) urlGuardar += '?esCorreccion=true';

                 const res = await fetch(urlGuardar, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(item) });
                 if (!res.ok) throw new Error("Fallo la comunicación con el servidor de base de datos.");

                 const data = await res.json();
                 if(data.ok) {
                     $('#entTipoArticulo, #entSap, #entNombre, #entMarca, #entModelo, #entProveedor, #entCosto, #entSerie, #entPlanta, #entUbicacion, #entFechaEntrada, #entFechaCompra, #entDiasGarantia, #entTiempoVida, #entStock, #entStockMinimo, #entReferencia, #entIP, #entAsignacion').val('');
                     $('#panelGarantiaTxt').text('');
                     $('#optRestock').prop('checked', true);
                     toggleTipoEntrada();
                     toggleCamposPorTipo();
                     $('#divEditAsignacion').hide();
                     await cargarInventario();

                     if (eraAltaNueva) {
                         const nuevoItem = datosInventario.find(x =>
                             String(x.idArticuloSap || '').toUpperCase().trim() === String(sapGuardado).toUpperCase().trim()
                         );
                         if (nuevoItem && confirm('Artículo registrado. ¿Deseas imprimir ahora la etiqueta chica con nombre y número de serie?')) {
                             imprimirEtiquetaPequena(nuevoItem.id);
                         }
