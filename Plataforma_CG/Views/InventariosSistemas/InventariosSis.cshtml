                     idArticuloEditando = 0;
                     $('#entStock').prop('disabled', false);
                     $('#btnGuardarAlta').text('Registrar artículo').removeClass('btn-warning text-dark').addClass('btn-brand');

                 } else { alert(data.mensaje); }
             }
             catch(error) { alert("Ocurrió un error al guardar: " + error.message); }
             finally {
                 btnElement.disabled = false;
                 if(idArticuloEditando === 0) {
                     btnElement.innerHTML = 'Registrar artículo';
                 } else {
                     btnElement.innerHTML = originalText;
                 }
             }
         }

