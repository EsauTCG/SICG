        flex: 1 1 160px;
        max-width: none;
    }
}



/* =========================================================
   CENTRO DE OPERACIONES DE INVENTARIO — VERSIÓN COMPACTA
   Navegación visual con tarjetas e iconos pequeños.
   Conserva Bootstrap Tabs y todos los paneles existentes.
   ========================================================= */
.inventory-module-nav {
    margin: 0 0 10px;
    padding: 10px;
    border: 1px solid #d7c2c2;
    border-radius: 14px;
    background:
        radial-gradient(circle at 92% 5%, rgba(139, 0, 0, .06), transparent 24%),
        linear-gradient(145deg, #fffefe 0%, #f8eeee 100%);
    box-shadow:
        0 8px 20px rgba(71, 17, 17, .07),
        inset 0 1px 0 rgba(255, 255, 255, .9);
}

.inventory-module-nav__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 8px;
    padding: 0 2px;
}

.inventory-module-nav__intro {
    min-width: 0;
}

.inventory-module-nav__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-bottom: 2px;
    color: #8b0000;
    font-size: 9px;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
}

.inventory-module-nav__intro h3 {
    margin: 0;
    color: #3f1616;
    font-size: clamp(14px, 1.1vw, 17px);
    font-weight: 900;
    line-height: 1.12;
}

.inventory-module-nav__intro p {
    margin: 3px 0 0;
    color: #7a6262;
    font-size: 10px;
    line-height: 1.2;
}

.inventory-module-current {
    min-width: 185px;
    padding: 6px 9px;
    border: 1px solid #decaca;
    border-radius: 9px;
    background: rgba(255, 255, 255, .72);
    text-align: right;
}

.inventory-module-current span,
.inventory-module-current strong {
    display: block;
}

.inventory-module-current span {
    color: #947a7a;
    font-size: 7px;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
}

.inventory-module-current strong {
    margin-top: 1px;
    color: #6f1010;
    font-size: 10px;
    line-height: 1.15;
}

.inventory-module-grid {
    display: grid !important;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 8px;
    width: 100%;
    margin: 0 !important;
    padding: 0 !important;
    overflow: visible !important;
    border: 0 !important;
    background: transparent !important;
    white-space: normal !important;
}

.inventory-module-grid .nav-item {
    min-width: 0;
    margin: 0 !important;
}

.inventory-module-card {
    --module-accent: #8b0000;
    --module-soft: #f8e2e2;

    position: relative;
    isolation: isolate;
    width: 100%;
    min-height: 92px;
    margin: 0 !important;
    padding: 9px 10px !important;
    overflow: hidden;

    display: grid !important;
    grid-template-columns: 30px minmax(0, 1fr);
    grid-template-rows: auto 1fr auto;
    column-gap: 8px;
    row-gap: 4px;
    align-items: start !important;

    border: 1px solid #d8c7c7 !important;
    border-radius: 11px !important;
    background: linear-gradient(155deg, #ffffff 0%, #fffafa 100%) !important;
    color: #452222 !important;
    text-align: left !important;
    white-space: normal !important;

    box-shadow:
        0 4px 10px rgba(52, 15, 15, .05),
        inset 0 1px 0 rgba(255,255,255,.95);
    transition:
        transform .16s ease,
        border-color .16s ease,
        box-shadow .16s ease,
        background .16s ease;
}

.inventory-module-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    z-index: -1;
    width: 4px;
    background: var(--module-accent);
    opacity: .9;
}

.inventory-module-card::after {
    content: "";
    position: absolute;
    z-index: -1;
    right: -22px;
    top: -27px;
    width: 72px;
    height: 72px;
    border-radius: 999px;
    background: var(--module-soft);
    opacity: .42;
}

.inventory-module-card:hover {
    transform: translateY(-2px);
    border-color: var(--module-accent) !important;
    box-shadow:
        0 9px 17px rgba(74, 14, 14, .10),
        inset 0 1px 0 rgba(255,255,255,.95);
}

.inventory-module-card:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--module-accent) 30%, transparent);
    outline-offset: 2px;
}

.inventory-module-card.active {
    border-color: var(--module-accent) !important;
    background:
        radial-gradient(circle at 92% 6%, rgba(255,255,255,.15), transparent 27%),
        linear-gradient(145deg, var(--module-accent) 0%, #4d0909 100%) !important;
    color: #ffffff !important;
    box-shadow:
        0 10px 20px color-mix(in srgb, var(--module-accent) 23%, transparent),
        inset 0 1px 0 rgba(255,255,255,.16);
}

.inventory-module-card.active::before {
    width: 5px;
    background: #ffffff;
}

.inventory-module-card.active::after {
    background: rgba(255, 255, 255, .12);
}

.inventory-module-icon {
    grid-column: 1;
    grid-row: 1 / span 2;
    width: 30px;
    height: 30px;
    flex: 0 0 30px;
    display: grid;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--module-accent) 26%, #ffffff);
    border-radius: 8px;
    background: var(--module-soft);
    color: var(--module-accent);
    font-size: 14px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.85);
}

.inventory-module-card.active .inventory-module-icon {
    border-color: rgba(255,255,255,.24);
    background: rgba(255,255,255,.13);
    color: #ffffff;
    box-shadow: none;
}

.inventory-module-copy {
    grid-column: 2;
    grid-row: 1 / span 2;
    min-width: 0;
    display: block;
}

.inventory-module-copy strong,
.inventory-module-copy small {
    display: block;
}

.inventory-module-copy strong {
    color: inherit;
    font-size: 10.5px;
    font-weight: 900;
    line-height: 1.08;
}

.inventory-module-copy small {
    margin-top: 2px;
    color: #806c6c;
    font-size: 7.8px;
    line-height: 1.22;
}

.inventory-module-card.active .inventory-module-copy small {
    color: rgba(255,255,255,.78);
}

.inventory-module-action {
    grid-column: 1 / -1;
    grid-row: 3;
    margin-top: 2px;
    padding-top: 5px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
    border-top: 1px solid rgba(118, 74, 74, .11);
    color: var(--module-accent);
    font-size: 6.8px;
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: .025em;
    text-transform: uppercase;
}

.inventory-module-card.active .inventory-module-action {
    border-top-color: rgba(255,255,255,.16);
    color: #ffffff;
}

.inventory-module-action i {
    font-size: 10px;
}

/* Identidad visual de cada proceso */
.module-explorer {
    --module-accent: #8b0000;
    --module-soft: #f7dddd;
}

.module-stock {
    --module-accent: #b56d05;
    --module-soft: #fff0d5;
}

.module-assign {
    --module-accent: #176b46;
    --module-soft: #ddf4e8;
}

.module-recovery {
    --module-accent: #6c4aa0;
    --module-soft: #eee5fb;
}

.module-workshop {
    --module-accent: #176b82;
    --module-soft: #dff2f7;
}

/* Laptop y escritorio mediano */
@@media (max-width: 1180px) {
    .inventory-module-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .inventory-module-card {
        min-height: 88px;
    }
}

/* Tablet */
@@media (max-width: 820px) {
    .inventory-module-nav {
        padding: 9px;
        border-radius: 11px;
    }

    .inventory-module-nav__header {
        align-items: flex-start;
    }

    .inventory-module-current {
        min-width: 155px;
    }

    .inventory-module-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 7px;
    }

    .inventory-module-card {
        min-height: 86px;
        padding: 8px 9px !important;
    }
}

/* Móvil: carrusel horizontal compacto */
@@media (max-width: 560px) {
    .inventory-module-nav__header {
        display: block;
    }

    .inventory-module-current {
        display: none;
    }

    .inventory-module-nav__intro p {
        display: none;
    }

    .inventory-module-grid {
        display: flex !important;
        gap: 7px;
        overflow-x: auto !important;
        overflow-y: hidden !important;
        padding: 2px 1px 6px !important;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
    }

    .inventory-module-grid .nav-item {
        flex: 0 0 210px;
        scroll-snap-align: start;
    }

    .inventory-module-card {
        min-height: 84px;
    }

    .inventory-module-icon {
        width: 27px;
        height: 27px;
        flex-basis: 27px;
        font-size: 12px;
    }
}

/* =========================================================
   CENTRO QR / ESCANEO OPERATIVO
   Compatible con lector USB/Bluetooth y cámara.
   ========================================================= */
.module-qr {
    --module-accent: #6f1d8f;
    --module-soft: #f1e3f7;
}

.qr-launch-btn {
    border-color: rgba(255,255,255,.72) !important;
    background: rgba(255,255,255,.10) !important;
    color: #fff !important;
}

.qr-launch-btn:hover {
    background: #fff !important;
    color: #6f1d8f !important;
}

.qr-operation-shell {
    display: grid;
    grid-template-columns: minmax(310px, .92fr) minmax(420px, 1.35fr);
    gap: 12px;
    align-items: start;
}

.qr-panel {
    min-width: 0;
    border: 1px solid #c79d9d;
    background: #fffafa;
