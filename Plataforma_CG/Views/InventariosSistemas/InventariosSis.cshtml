        function imprimirQR(id) {
            const item = datosInventario.find(i => i.id === id);
            const asignacionTxt = item.asignacion ? item.asignacion : 'STOCK';
            const ubicacionTxt = item.ubicacion ? item.ubicacion : 'N/A';
            const hoy = new Date();
            let fCompraStr = 'N/A'; let fGarantiaStr = 'N/A'; let fVidaStr = 'N/A';

            if (item.fechaCompra) {
                const fCompra = new Date(item.fechaCompra);
                fCompraStr = fCompra.toLocaleDateString('es-MX');

                if (item.diasGarantia) {
                    let fGarantia = new Date(fCompra); fGarantia.setDate(fGarantia.getDate() + item.diasGarantia);
                    let diasRest = Math.ceil((fGarantia - hoy) / (1000 * 60 * 60 * 24));
                    let estadoG = diasRest < 0 ? "(VENCIDA)" : `(${diasRest} dias)`;
                    fGarantiaStr = `${fGarantia.toLocaleDateString('es-MX')} ${estadoG}`;
                }

                let aniosVida = parseInt(item.tiempoVida) || 4;
                let fVida = new Date(fCompra); fVida.setFullYear(fVida.getFullYear() + aniosVida);
                fVidaStr = fVida.toLocaleDateString('es-MX');
            }

            let dominioActual = window.location.origin;
            let linkAlSistema = `${dominioActual}/InventariosSistemas/EscanerRapido?id=${item.id}`;

            let textoOffline =
                `[ CONTROL DE INVENTARIOS IT ]\n` +
                `==========================\n` +
                ` SAP:   ${item.idArticuloSap}\n` +
                ` EQUIP: ${item.nombre}\n` +
                ` INFO:  ${item.marca || '-'} ${item.modelo || '-'}\n` +
                ` N/S:   ${item.numeroSerie || 'N/A'}\n` +
                ` IP:    ${item.ip || 'N/A'}\n` +
                `--------------------------\n` +
                ` LUGAR: ${item.planta || 'N/A'} | ${ubicacionTxt}\n` +
                ` RESP:  ${asignacionTxt}\n` +
                `--------------------------\n` +
                ` COMPRA:   ${fCompraStr}\n` +
                ` GARANTIA: ${fGarantiaStr}\n` +
                ` FIN VIDA: ${fVidaStr}\n` +
                `==========================\n` +
                ` REVISION IT (ESCANEA AQUI):\n` +
                ` ${linkAlSistema}`;

            textoOffline = textoOffline.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            const qrUrl = `@Url.Action("GenerarQRLocal", "InventariosSistemas")?texto=${encodeURIComponent(textoOffline)}`;

            const w = window.open('', '_blank', 'width=400,height=550');
            w.document.write(`
                <style>
                    body { font-family: sans-serif; text-align: center; padding: 20px; }
                    .ticket { border: 2px solid #555555; padding: 20px 15px; display: inline-block; width: 220px; border-radius: 6px; background-color: #fff; }
                    .info-name { color: #333333; font-size: 1.1rem; font-weight: bold; margin-bottom: 15px; word-wrap: break-word; }
                    img { margin: 0 auto; display: block; }
                    .btn-print { padding: 10px 20px; background: #555555; color: white; border: none; border-bottom: 3px solid #cc0000; border-radius: 4px; cursor: pointer; font-weight: bold; margin-top: 20px; }
                    @@media print { button { display: none; } .ticket { border: 1px solid #000; } }
                </style>
                <div class="ticket">
                    <div class="info-name">${item.nombre}</div>
                    <img src="${qrUrl}" alt="QR Code" width="160" height="160"/>
                </div>
                <br><button class="btn-print" onclick="window.print()">Imprimir Etiqueta</button>
            `);
            w.document.close();
        }

        function exportarExcel() {
            let csv = 'SAP,Tipo,Nombre,Marca,Modelo,Proveedor,Costo,Planta,Ubicacion,Asignacion,Serie,IP,Stock\n';
            datosInventario.forEach(i => {
                let nomSeguro = (i.nombre || "").replace(/"/g, '""');
                let marSeguro = (i.marca || "").replace(/"/g, '""');
                let modSeguro = (i.modelo || "").replace(/"/g, '""');
                let proSeguro = (i.proveedor || "").replace(/"/g, '""');
                csv += `"${i.idArticuloSap}","${i.tipoArticulo}","${nomSeguro}","${marSeguro}","${modSeguro}","${proSeguro}","${i.costo||0}","${i.planta}","${i.ubicacion}","${i.asignacion}","${i.numeroSerie}","${i.ip || ''}","${i.stock}"\n`;
            });
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = "InventarioIT.csv";
            link.click();
        }

