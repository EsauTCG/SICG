        function abrirModalFinReparacion(id) {
            $('#finReparacionId').val(id);
            $('#finReparacionNota').val('');

            let item = datosInventario.find(i => i.id === id);

            if(item.asignacion && item.asignacion.trim() !== '') {
                $('#lblDestUsuario').text(`Devolver a: ${item.asignacion}`);
                $('#opcionesDevolucion').show();
                $('#destUsuario').prop('checked', true);
            } else {
                $('#opcionesDevolucion').hide();
                $('#destDisponible').prop('checked', true);
            }
            new bootstrap.Modal(document.getElementById('modalFinReparacion')).show();
        }

        async function ejecutarAltaReparacion(btnElement) {
            const id = $('#finReparacionId').val();
            const nota = $('#finReparacionNota').val().trim();
            const regresarAlUsuario = $('#destUsuario').is(':checked');

            if (!nota) { alert("Ingresa el reporte final para la bitácora."); return; }

            try {
                btnElement.disabled = true;
                const res = await fetch(`@Url.Action("FinalizarReparacion", "InventariosSistemas")?id=${id}&comentarioFinal=${encodeURIComponent(nota)}&regresarAlUsuario=${regresarAlUsuario}`, { method: 'POST' });
                const data = await res.json();
                if(data.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('modalFinReparacion')).hide();
                    cargarInventario();
                    alert("Reparación concluida exitosamente.");
                }
            } catch(e) { alert("Error: " + e.message); }
            finally { btnElement.disabled = false; }
        }

        async function verFotoFalla(id) {
            $('#imgVerFotoTaller').attr('src', '').hide();
            let modalCuerpo = document.querySelector('#modalVerFotoTaller .modal-body');
            let loadingMsg = document.createElement('div');
            loadingMsg.id = 'loadingFotoTaller';
            loadingMsg.className = 'p-5 text-muted';
            loadingMsg.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Descargando evidencia...';

            if(document.getElementById('loadingFotoTaller')) document.getElementById('loadingFotoTaller').remove();
            modalCuerpo.prepend(loadingMsg);

            new bootstrap.Modal(document.getElementById('modalVerFotoTaller')).show();

            try {
                const res = await fetch(`@Url.Action("GetFotoTaller", "InventariosSistemas")?id=${id}`);
                const data = await res.json();

                if (data.ok && data.fotoBase64) {
                    $('#imgVerFotoTaller').attr('src', data.fotoBase64).show();
                } else {
                    $('#imgVerFotoTaller').attr('alt', 'No se pudo cargar la imagen').show();
                }
            } catch (e) {
                console.error("Error al traer la foto", e);
            } finally {
                if(document.getElementById('loadingFotoTaller')) document.getElementById('loadingFotoTaller').remove();
            }
        }

        function abrirModalCanibalizar(id) {
            $('#canibalTargetId').val(id);
            $('#canibalPiezas').val('');

            let options = '<option value="">Selecciona un donador...</option>';
            let equiposChatarra = datosInventario.filter(i => i.asignacion === 'PARA PIEZAS' && i.id !== id);
            equiposChatarra.forEach(i => {
                options += `<option value="${i.id}">${i.idArticuloSap} - ${i.nombre}</option>`;
            });

            $('#canibalDonador').html(options).trigger('change');
            new bootstrap.Modal(document.getElementById('modalCanibalizar')).show();
        }

        async function ejecutarCanibalizacion(btnElement) {
            const idDestino = $('#canibalTargetId').val();
            const idDonante = $('#canibalDonador').val();
            const piezas = $('#canibalPiezas').val().trim();

            if (!idDonante || !piezas) {
                alert("Selecciona el equipo donador y escribe qué piezas vas a extraer.");
                return;
            }

            const originalText = btnElement.innerHTML;
            try {
                btnElement.disabled = true;
                btnElement.innerHTML = "Guardando...";

                const url = `@Url.Action("ExtraerPiezas", "InventariosSistemas")?idDestino=${idDestino}&idDonante=${idDonante}&piezas=${encodeURIComponent(piezas)}`;
                const res = await fetch(url, { method: 'POST' });
                const data = await res.json();

                if(data.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('modalCanibalizar')).hide();
                    cargarInventario();
                    alert("Las piezas han sido registradas en la bitácora de ambos equipos.");
                } else {
                    alert("Error: " + data.mensaje);
                }
            } catch(e) { alert("Error: " + e.message); }
            finally {
                btnElement.disabled = false;
                btnElement.innerHTML = originalText;
            }
        }

        async function abrirModalHistorialBajas() {
            const tbody = $('#tbodyHistorialBajas');
            tbody.html('<tr><td colspan="3" class="text-center py-4"><span class="spinner-border spinner-border-sm"></span> Cargando...</td></tr>');
            new bootstrap.Modal(document.getElementById('modalHistorialBajas')).show();

            try {
                const res = await fetch('@Url.Action("GetHistorialBajas", "InventariosSistemas")');
                const result = await res.json();

                if (result.ok && result.data.length > 0) {
                    let html = '';
                    result.data.forEach(b => {
                        let fecha = new Date(b.fecha).toLocaleString('es-MX', {day:'2-digit', month:'2-digit', year:'2-digit', hour:'2-digit', minute:'2-digit'});
                        let refColor = b.referencia.includes('BAJA DEFINITIVA') ? 'text-danger' : 'text-primary';

                        html += `<tr>
                            <td class="ps-3 text-muted">${fecha}</td>
                            <td><strong class="${refColor}">${b.articuloSap}</strong><br><span>${b.nombreArticulo}</span></td>
                            <td class="small text-muted">${b.referencia}</td>
                        </tr>`;
                    });
                    tbody.html(html);
                } else {
                    tbody.html('<tr><td colspan="3" class="text-center py-4 text-muted">No hay registro de bajas en el sistema.</td></tr>');
                }
            } catch(e) {
                tbody.html('<tr><td colspan="3" class="text-center text-danger">Error de conexión al cargar historial.</td></tr>');
            }
        }

        async function abrirModalInventarioChatarra() {
            const tbody = $('#tbodyInventarioChatarra');
            tbody.html('<tr><td colspan="2" class="text-center py-4"><span class="spinner-border spinner-border-sm"></span> Cargando banco de piezas...</td></tr>');
            new bootstrap.Modal(document.getElementById('modalInventarioChatarra')).show();

            try {
                const res = await fetch('@Url.Action("GetInventarioChatarra", "InventariosSistemas")');
                const result = await res.json();

                if (result.ok) {
                    let html = '';
                    if (result.data.length === 0) {
                        html = '<tr><td colspan="2" class="text-center py-4 text-muted">No hay equipos para piezas.</td></tr>';
                    } else {
                        result.data.forEach(i => {
                            let listaExtracciones = '';
                            if (i.extracciones.length > 0) {
                                i.extracciones.forEach(e => {
                                    listaExtracciones += `<div class="mb-1 text-danger">
                                        <i class="bi bi-dash-circle-fill me-1"></i><b>${e.fechaHora}:</b> ${e.nota.replace('DONACIÓN DE PIEZAS: ', '')}
                                    </div>`;
                                });
                            } else {
                                listaExtracciones = '<span class="text-success small"><i class="bi bi-check-circle me-1"></i> Equipo completo (Sin extracciones)</span>';
                            }

                            html += `<tr>
                                <td class="ps-3 py-3" style="width: 35%;">
                                    <strong style="color: var(--brand-main);">${i.idArticuloSap}</strong><br>
                                    <span class="fw-bold">${i.nombre}</span><br>
                                    <small class="text-muted">${i.marca} ${i.modelo}</small>
                                </td>
                                <td class="py-3">${listaExtracciones}</td>
                            </tr>`;
                        });
                    }
                    tbody.html(html);
                }
            } catch (e) {
                tbody.html('<tr><td colspan="2" class="text-center py-4 text-danger">Error al cargar datos.</td></tr>');
            }
        }
    </script>
}