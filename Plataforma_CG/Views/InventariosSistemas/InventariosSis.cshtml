        function exportarExcel() {
            let csv = 'SAP,Tipo,Nombre,Marca,Modelo,Proveedor,Costo,Planta,Ubicacion,Asignacion,Serie,IP,Stock\n';
            datosInventario.forEach(i => {
                let nomSeguro = (i.nombre || "").replace(/"/g, '""');
                let marSeguro = (i.marca || "").replace(/"/g, '""');
                let modSeguro = (i.modelo || "").replace(/"/g, '""');
                let proSeguro = (i.proveedor || "").replace(/"/g, '""');
                csv += `"${i.idArticuloSap}","${i.tipoArticulo}","${nomSeguro}","${marSeguro}","${modSeguro}","${proSeguro}","${i.costo||0}","${i.planta}","${i.ubicacion}","${i.asignacion}","${i.numeroSerie}","${i.ip || ''}","${i.stock}"\n`;
            });
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = "InventarioIT.csv";
            link.click();
        }

        function darDeBajaArticulo(id) {
            $('#bajaId').val(id);
            $('#bajaMotivo').val('');
            $('#bajaPiezas').prop('checked', true);
            bajaModal.show();
