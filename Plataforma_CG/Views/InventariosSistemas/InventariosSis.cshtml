        async function ejecutarRestock(btnElement) {
            const id = parseInt($('#resArticulo').val());
            const cant = parseInt($('#resCantidad').val()) || 0;
            const ref = $('#resReferencia').val().trim();
            const nCosto = $('#resCosto').val();
            const nProveedor = $('#resProveedor').val();
            const nFechaCompra = $('#resFechaCompra').val();

            if(!id || cant <= 0 || !ref) { alert("Completa Artículo, Cantidad y Comentario (Obligatorios)."); return; }

            const originalText = btnElement.innerHTML;

            try {
                btnElement.disabled = true;
                btnElement.innerHTML = "Guardando...";

                const itemOriginal = datosInventario.find(i => i.id === id);
                if (nCosto) itemOriginal.costo = parseFloat(nCosto);
                if (nProveedor) itemOriginal.proveedor = nProveedor;
                if (nFechaCompra) itemOriginal.fechaCompra = nFechaCompra;

                const envio = {
                    Id: itemOriginal.id,
                    Costo: itemOriginal.costo,
                    Proveedor: itemOriginal.proveedor,
                    FechaCompra: itemOriginal.fechaCompra
                };

                let res1 = await fetch('@Url.Action("GuardarArticulo", "InventariosSistemas")', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(envio) });
                if(!res1.ok) throw new Error("Error al guardar información del artículo.");

                let res2 = await fetch(`@Url.Action("RegistrarMovimiento", "InventariosSistemas")?idArticulo=${id}&tipo=ENTRADA&cantidad=${cant}&referencia=${ref}`, { method: 'POST' });
                if(!res2.ok) throw new Error("Error al guardar el historial de movimiento.");

                $('#resCantidad').val(''); $('#resReferencia, #resCosto, #resProveedor, #resFechaCompra').val('');
                $('#stockInfoRestock').hide();
                cargarInventario();
            }
            catch(error) { alert("Ocurrió un error de conexión: " + error.message); }
            finally {
                btnElement.disabled = false;
                btnElement.innerHTML = originalText;
            }
        }

        async function ejecutarAlta(btnElement) {
             const tipoArt = $('#entTipoArticulo').val();
             const sap = $('#entSap').val().trim();
             const nombre = $('#entNombre').val().trim();
             const marca = $('#entMarca').val().trim();
             const modelo = $('#entModelo').val().trim();
             const planta = $('#entPlanta').val();
             const ubicacion = $('#entUbicacion').val().trim();
             const stock = $('#entStock').val().trim();
             const ref = $('#entReferencia').val().trim();
             const ip = $('#entIP').val().trim();

             let serie = $('#entSerie').val().trim();
             let proveedor = $('#entProveedor').val().trim();
             let costo = $('#entCosto').val().trim();
             let fEntrada = $('#entFechaEntrada').val();
             let fCompra = $('#entFechaCompra').val();
             let dGarantia = $('#entDiasGarantia').val().trim();
             let tVida = $('#entTiempoVida').val().trim();
             let stockMinimo = $('#entStockMinimo').val().trim();

             if (!tipoArt || !sap || !nombre || !marca || !modelo || !planta || !ubicacion || !stock || !ref) {
                 alert('Llena TODOS los campos básicos marcados (*).');
                 return;
             }

             if (tipoArt === 'Chatarra/Piezas') {
                 proveedor = "N/A";
                 costo = "0";
                 serie = "N/A";
                 fEntrada = new Date().toISOString().split('T')[0];
                 fCompra = null; // <-- BLINDAJE C#
                 dGarantia = "0";
                 tVida = "0";
                 stockMinimo = "0";
             } else {
                 // Si NO es chatarra, exigimos los campos avanzados
                 if (!proveedor || !costo || !serie || !fEntrada || !fCompra || !dGarantia || !tVida) {
                     alert('Llena TODOS los campos avanzados para registrar el equipo.');
                     return;
                 }
                 if (tipoArt === 'Consumible' && !stockMinimo) {
                     alert('Ingresa el Stock Mínimo para el artículo consumible.');
                     return;
                 }
             }

             let asignacionActual = idArticuloEditando > 0 ? $('#entAsignacion').val().trim() : '';

             if (tipoArt === 'Chatarra/Piezas' && idArticuloEditando === 0) {
                 asignacionActual = $('input[name="optChatarraDestino"]:checked').val();
             }

             const item = {
                 Id: idArticuloEditando,
                 TipoArticulo: tipoArt,
                 IdArticuloSap: sap, Nombre: nombre, Marca: marca, Modelo: modelo,
                 Proveedor: proveedor, Costo: parseFloat(costo) || 0,
                 NumeroSerie: serie, IP: ip, Planta: planta, Ubicacion: ubicacion,
                 Asignacion: asignacionActual,
                 DiasGarantia: parseInt(dGarantia) || 0,
                 FechaCompra: fCompra ? fCompra : null, // <-- BLINDAJE C#
                 FechaEntrada: fEntrada ? fEntrada : null, // <-- BLINDAJE C#
                 TiempoVida: tVida, Stock: parseInt(stock) || 1,
                 StockMinimo: tipoArt === 'Consumible' ? parseInt(stockMinimo) || 1 : 0
             };

             const originalText = btnElement.innerHTML;

             try {
                 btnElement.disabled = true;
                 btnElement.innerHTML = "Guardando...";

                 let urlGuardar = '@Url.Action("GuardarArticulo", "InventariosSistemas")';
                 if (idArticuloEditando > 0) urlGuardar += '?esCorreccion=true';

                 const res = await fetch(urlGuardar, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(item) });
                 if (!res.ok) throw new Error("Fallo la comunicación con el servidor de base de datos.");

                 const data = await res.json();
                 if(data.ok) {
                     $('#entTipoArticulo, #entSap, #entNombre, #entMarca, #entModelo, #entProveedor, #entCosto, #entSerie, #entPlanta, #entUbicacion, #entFechaEntrada, #entFechaCompra, #entDiasGarantia, #entTiempoVida, #entStock, #entStockMinimo, #entReferencia, #entIP, #entAsignacion').val('');
                     $('#panelGarantiaTxt').text('');
                     $('#optRestock').prop('checked', true);
                     toggleTipoEntrada();
                     toggleCamposPorTipo();
                     $('#divEditAsignacion').hide();
                     cargarInventario();

                     idArticuloEditando = 0;
                     $('#entStock').prop('disabled', false);
                     $('#btnGuardarAlta').text('Registrar artículo').removeClass('btn-warning text-dark').addClass('btn-brand');

                 } else { alert(data.mensaje); }
             }
             catch(error) { alert("Ocurrió un error al guardar: " + error.message); }
             finally {
                 btnElement.disabled = false;
                 if(idArticuloEditando === 0) {
                     btnElement.innerHTML = 'Registrar artículo';
                 } else {
                     btnElement.innerHTML = originalText;
                 }
             }
         }

