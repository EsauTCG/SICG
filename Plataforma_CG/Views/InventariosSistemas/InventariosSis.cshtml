                        <button class="qr-action-btn" onclick="imprimirEtiquetaPequena(${Number(item.id)})">
                            <i class="bi bi-tag"></i> Etiqueta chica
                        </button>
                        <button class="qr-action-btn" onclick="imprimirQR(${Number(item.id)})">
                            <i class="bi bi-printer"></i> QR completo
                        </button>
                        <button class="qr-action-btn" onclick="copiarDatosQr(${Number(item.id)})">
                            <i class="bi bi-clipboard"></i> Copiar ficha
                        </button>
                        <button class="qr-action-btn" onclick="abrirCentroQr('CONSULTAR')">
                            <i class="bi bi-upc-scan"></i> Otro escaneo
                        </button>
