        async function ejecutarMandarTaller(btnElement) {
            const id = parseInt($('#tallerArticulo').val());
            const motivo = $('#tallerMotivo').val().trim();
            const fileFoto = document.getElementById('tallerFotoFile').files[0];

            if(!id || !motivo) { alert("Debes seleccionar el equipo y escribir el motivo de la falla."); return; }

            const originalText = btnElement.innerHTML;
            try {
                btnElement.disabled = true;
                btnElement.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Enviando...';

                let fotoBase64 = "";
                if (fileFoto) { fotoBase64 = await getBase64(fileFoto); }

                const envio = { Id: id, MotivoFalla: motivo, FotoFalla: fotoBase64 };

                const res = await fetch('@Url.Action("MandarATaller", "InventariosSistemas")', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(envio)
                });

                const data = await res.json();
                if (data.ok) {
                    $('#tallerArticulo').val('').trigger('change');
                    $('#tallerMotivo').val('');
                    $('#tallerFotoFile').val('');
                    cargarInventario();
                    alert("Equipo ingresado al taller correctamente.");
                } else { alert("Error: " + data.mensaje); }
            } catch(e) { alert("Fallo la conexión: " + e.message); }
            finally { btnElement.disabled = false; btnElement.innerHTML = originalText; }
        }

        function abrirModalActualizarTaller(id) {
            $('#tallerEditId').val(id);
            $('#tallerNuevaNota').val('');
            new bootstrap.Modal(document.getElementById('modalActualizarTaller')).show();
        }

        async function guardarNotaTaller(btnElement) {
            const id = $('#tallerEditId').val();
            const nota = $('#tallerNuevaNota').val().trim();
            if (!nota) { alert("Escribe una actualización."); return; }

            try {
                btnElement.disabled = true;
                const res = await fetch(`@Url.Action("AgregarBitacoraReparacion", "InventariosSistemas")?id=${id}&nota=${encodeURIComponent(nota)}`, { method: 'POST' });
                const data = await res.json();
                if(data.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('modalActualizarTaller')).hide();
                    cargarInventario();
                }
            } catch(e) { alert("Error: " + e.message); }
            finally { btnElement.disabled = false; }
        }

        function abrirModalFinReparacion(id) {
            $('#finReparacionId').val(id);
            $('#finReparacionNota').val('');

            let item = datosInventario.find(i => i.id === id);

            if(item.asignacion && item.asignacion.trim() !== '') {
                $('#lblDestUsuario').text(`Devolver a: ${item.asignacion}`);
                $('#opcionesDevolucion').show();
                $('#destUsuario').prop('checked', true);
            } else {
                $('#opcionesDevolucion').hide();
                $('#destDisponible').prop('checked', true);
            }
            new bootstrap.Modal(document.getElementById('modalFinReparacion')).show();
        }

        async function ejecutarAltaReparacion(btnElement) {
            const id = $('#finReparacionId').val();
            const nota = $('#finReparacionNota').val().trim();
            const regresarAlUsuario = $('#destUsuario').is(':checked');

            if (!nota) { alert("Ingresa el reporte final para la bitácora."); return; }

            try {
                btnElement.disabled = true;
                const res = await fetch(`@Url.Action("FinalizarReparacion", "InventariosSistemas")?id=${id}&comentarioFinal=${encodeURIComponent(nota)}&regresarAlUsuario=${regresarAlUsuario}`, { method: 'POST' });
                const data = await res.json();
                if(data.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('modalFinReparacion')).hide();
                    cargarInventario();
                    alert("Reparación concluida exitosamente.");
                }
            } catch(e) { alert("Error: " + e.message); }
            finally { btnElement.disabled = false; }
        }

        async function verFotoFalla(id) {
            $('#imgVerFotoTaller').attr('src', '').hide();
            let modalCuerpo = document.querySelector('#modalVerFotoTaller .modal-body');
            let loadingMsg = document.createElement('div');
            loadingMsg.id = 'loadingFotoTaller';
            loadingMsg.className = 'p-5 text-muted';
            loadingMsg.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Descargando evidencia...';

            if(document.getElementById('loadingFotoTaller')) document.getElementById('loadingFotoTaller').remove();
            modalCuerpo.prepend(loadingMsg);

            new bootstrap.Modal(document.getElementById('modalVerFotoTaller')).show();

            try {
                const res = await fetch(`@Url.Action("GetFotoTaller", "InventariosSistemas")?id=${id}`);
                const data = await res.json();

                if (data.ok && data.fotoBase64) {
                    $('#imgVerFotoTaller').attr('src', data.fotoBase64).show();
                } else {
                    $('#imgVerFotoTaller').attr('alt', 'No se pudo cargar la imagen').show();
                }
            } catch (e) {
                console.error("Error al traer la foto", e);
            } finally {
                if(document.getElementById('loadingFotoTaller')) document.getElementById('loadingFotoTaller').remove();
            }
        }

        function abrirModalCanibalizar(id) {
            $('#canibalTargetId').val(id);
            $('#canibalPiezas').val('');

            let options = '<option value="">Selecciona un donador...</option>';
            let equiposChatarra = datosInventario.filter(i => i.asignacion === 'PARA PIEZAS' && i.id !== id);
            equiposChatarra.forEach(i => {
                options += `<option value="${i.id}">${i.idArticuloSap} - ${i.nombre}</option>`;
            });

            $('#canibalDonador').html(options).trigger('change');
            new bootstrap.Modal(document.getElementById('modalCanibalizar')).show();
