            cont.innerHTML = `
                <div class="qr-equipment-card">
                    <div class="qr-equipment-hero">
                        <div class="qr-equipment-icon">
                            <i class="bi ${iconoArticuloQr(item.tipoArticulo)}"></i>
                        </div>
                        <div class="qr-equipment-title">
                            <h4>${escapeQrHtml(item.idArticuloSap || item.id)} · ${escapeQrHtml(item.nombre || 'Sin nombre')}</h4>
                            <p>${escapeQrHtml(item.marca || '-')} ${escapeQrHtml(item.modelo || '')} · ${escapeQrHtml(item.tipoArticulo || 'Sin clasificación')}</p>
                            <span class="badge ${estado === 'DISPONIBLE' ? 'bg-success' : estado === 'EN TALLER' ? 'bg-danger' : estado === 'EN RECUPERACIÓN' ? 'bg-warning text-dark' : 'bg-info text-dark'} mt-1">${estado}</span>
                        </div>
                        <div class="qr-stock-badge">
                            <span>Stock</span>
                            <strong>${Number(item.stock || 0)}</strong>
                        </div>
                    </div>

                    <div class="qr-equipment-data">
                        <div class="qr-data-cell"><span>ID interno</span><strong>${escapeQrHtml(item.id)}</strong></div>
                        <div class="qr-data-cell"><span>Número de serie</span><strong>${escapeQrHtml(item.numeroSerie || 'N/A')}</strong></div>
                        <div class="qr-data-cell"><span>Dirección IP</span><strong>${escapeQrHtml(item.ip || 'N/A')}</strong></div>
                        <div class="qr-data-cell"><span>Responsable</span><strong>${escapeQrHtml(item.asignacion || 'DISPONIBLE')}</strong></div>
                        <div class="qr-data-cell"><span>Planta</span><strong>${escapeQrHtml(item.planta || 'N/A')}</strong></div>
                        <div class="qr-data-cell"><span>Ubicación física</span><strong>${escapeQrHtml(item.ubicacion || 'SIN UBICACIÓN')}</strong></div>
                    </div>

                    <div class="qr-operational-actions">
                        <button class="qr-action-btn primary" onclick="ejecutarAccionQr('CONSULTAR', ${Number(item.id)})">
                            <i class="bi bi-search"></i> Consultar
                        </button>
                        <button class="qr-action-btn" ${disabled} onclick="ejecutarAccionQr('ENTRADA', ${Number(item.id)})">
                            <i class="bi bi-box-arrow-in-down"></i> Entrada
                        </button>
                        <button class="qr-action-btn" ${disabled} onclick="ejecutarAccionQr('SALIDA', ${Number(item.id)})">
                            <i class="bi bi-box-arrow-up"></i> Salida
                        </button>
                        <button class="qr-action-btn" ${disabled} onclick="ejecutarAccionQr('ASIGNAR', ${Number(item.id)})">
                            <i class="bi bi-person-plus"></i> Asignar / mover
                        </button>
                        <button class="qr-action-btn" ${recuperarDisabled} onclick="ejecutarAccionQr('RECUPERAR', ${Number(item.id)})">
                            <i class="bi bi-arrow-counterclockwise"></i> Recibir
                        </button>
                        <button class="qr-action-btn" ${tallerDisabled} onclick="ejecutarAccionQr('TALLER', ${Number(item.id)})">
                            <i class="bi bi-tools"></i> Taller
