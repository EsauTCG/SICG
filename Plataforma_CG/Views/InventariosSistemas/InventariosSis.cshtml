@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.0.0/dist/signature_pad.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>

    <script>
        let datosInventario = [];
        let movimientosInventario = [];
        let consultarModal, historialModal, infoResponsableModal, camaraModal, visorHistorialModal, reportesModal, bajaModal, exploradorModal, alertasStockModal;
        let alertasStockActuales = [];
        let signaturePad;
        let streamActual = null;
        let fotoCapturadaBase64 = null;
        let idArticuloEditando = 0;
        let usuariosCoincidentesBaja = [];
        let qrHtml5Scanner = null;
        let qrScannerActivo = false;
        let qrItemActual = null;
        let qrProcesando = false;
        let qrUltimoCodigo = '';
        let qrUltimoMomento = 0;
        const QR_LOG_KEY = 'inventario_sistemas_qr_lecturas_v1';
                let permisosInventario = { puedeLeer: false, puedeEscribir: false, puedeEliminar: false };

        $(document).ready(async function () {
            await cargarPermisosInventario();
            // ... el resto del código existente ...
        });

        async function cargarPermisosInventario() {
            try {
                const res = await fetch('@Url.Action("ObtenerPermisosVistaInventarioSistemas", "InventariosSistemas")');
                if (res.ok) {
                    permisosInventario = await res.json();
                    aplicarPermisosInventario();
                }
            } catch (e) {
                console.error("Error permisos:", e);
            }
        }

                function aplicarPermisosInventario() {
            if (!permisosInventario.puedeEscribir) {
                document.querySelectorAll(
                    '#movimientos > .row > .col-lg-5:first-child, ' +
                    '#asignaciones > .row > .col-lg-4:first-child, ' +
                    '#recuperaciones > .row > .col-lg-4:first-child, ' +
                    '#taller > .row > .col-lg-4:first-child'
                ).forEach(el => el.style.display = 'none');
            }
        }



        $(document).ready(function () {
            consultarModal = new bootstrap.Modal(document.getElementById('modalConsultar'));
            historialModal = new bootstrap.Modal(document.getElementById('modalHistorial'));
            infoResponsableModal = new bootstrap.Modal(document.getElementById('modalInfoResponsable'));
            camaraModal = new bootstrap.Modal(document.getElementById('modalCamara'));
            visorHistorialModal = new bootstrap.Modal(document.getElementById('modalVisorHistorial'));
            reportesModal = new bootstrap.Modal(document.getElementById('modalReportesQR'));
            bajaModal = new bootstrap.Modal(document.getElementById('modalBaja'));
            exploradorModal = new bootstrap.Modal(document.getElementById('modalExploradorInventario'));
            alertasStockModal = new bootstrap.Modal(document.getElementById('modalAlertasStock'));
            inicializarCentroQr();
            // Evento para autocompletar destino de chatarra
        $('input[name="optChatarraDestino"]').on('change', actualizarDestinoChatarra);

            // Buscadores normales
            $('#salArticulo, #resArticulo, #asigArticulo, #selectUsuarioBaja, #tallerArticulo').select2({
                theme: 'bootstrap-5',
                width: '100%',
                language: { noResults: function() { return "No se encontró coincidencia"; } }
            });

            // Buscador que vive ADENTRO del modal de canibalizar
            $('#canibalDonador').select2({
                theme: 'bootstrap-5',
                width: '100%',
                dropdownParent: $('#modalCanibalizar'),
                language: { noResults: function() { return "No se encontró coincidencia"; } }
            });

            cargarInventario();

            $('#salArticulo').on('change', function() {
                const id = parseInt($(this).val());
                if(id) {
                    const item = datosInventario.find(i => i.id === id);
                    $('#lblStockSalida').text(item.stock);
                    $('#stockInfoSalida').slideDown(200);
                } else { $('#stockInfoSalida').slideUp(200); }
            });

            $('#resArticulo').on('change', function() {
                const id = parseInt($(this).val());
                if(id) {
                    const item = datosInventario.find(i => i.id === id);
                    $('#lblStockRestock').text(item.stock);
                    $('#stockInfoRestock').slideDown(200);
                } else { $('#stockInfoRestock').slideUp(200); }
            });

            $('#asigArticulo').on('change', function() {
                const id = parseInt($(this).val());
                limpiarFirma();
                fotoCapturadaBase64 = null;
                $('#previewFoto').hide().attr('src', '');

                if(!id) {
                    $('#asigUsuario, #asigPlanta, #asigUbicacion, #asigFotoFile, #asigDocFile').val('');
                    return;
                }
                const item = datosInventario.find(i => i.id === id);
                $('#asigUsuario').val(item.asignacion || '');
                $('#asigPlanta').val(item.planta || '');
