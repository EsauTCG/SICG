        /* =====================================================
           CENTRO QR: identificación y operación rápida
           ===================================================== */
        function inicializarCentroQr() {
            const estacion = localStorage.getItem('inventario_qr_estacion') || 'ALMACÉN TI';
            $('#qrEstacion').val(estacion);
            renderQrRecentes();

            $('#qrEstacion').off('change.qr').on('change.qr', function () {
                localStorage.setItem('inventario_qr_estacion', ($(this).val() || '').trim());
            });

            $('#qrManualInput').off('keydown.qr').on('keydown.qr', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    procesarLecturaQr($(this).val(), 'LECTOR');
                }
            });

            $('#qrProcesarManual').off('click.qr').on('click.qr', function () {
                procesarLecturaQr($('#qrManualInput').val(), 'MANUAL');
            });

            $('#qrStartCamera').off('click.qr').on('click.qr', iniciarCamaraQr);
            $('#qrStopCamera').off('click.qr').on('click.qr', detenerCamaraQr);
            $('#qrClearResult').off('click.qr').on('click.qr', limpiarResultadoQr);

            document.getElementById('qr-tab')?.addEventListener('shown.bs.tab', function () {
                setTimeout(() => $('#qrManualInput').trigger('focus'), 120);
            });

            document.getElementById('qr-tab')?.addEventListener('hide.bs.tab', function () {
                if (qrScannerActivo) detenerCamaraQr();
            });

            window.addEventListener('beforeunload', () => {
                if (qrScannerActivo) detenerCamaraQr();
            });
        }

        function abrirCentroQr(modo = 'CONSULTAR') {
            const selector = document.getElementById('qrModoOperacion');
            if (selector) selector.value = modo || 'CONSULTAR';

            const tabBtn = document.getElementById('qr-tab');
            if (tabBtn) new bootstrap.Tab(tabBtn).show();

            setQrStatus(
                modo === 'CONSULTAR'
                    ? 'Escanea una etiqueta para identificar el equipo.'
                    : `Modo ${modo}: el equipo se enviará al formulario correspondiente.`,
                ''
            );

            setTimeout(() => {
                const input = document.getElementById('qrManualInput');
                if (input) {
                    input.value = '';
                    input.focus();
                }
            }, 180);
        }

        function setQrStatus(mensaje, tipo = '') {
            const el = document.getElementById('qrStatusLine');
            if (!el) return;
            el.textContent = mensaje;
            el.classList.remove('ok', 'error');
            if (tipo) el.classList.add(tipo);
        }

        function setQrReaderState(texto, clase = 'bg-light text-dark') {
            const el = document.getElementById('qrReaderState');
            if (!el) return;
            el.className = `badge ${clase}`;
            el.textContent = texto;
        }

        function normalizarTextoQr(valor) {
            return String(valor || '').replace(/\u0000/g, '').trim();
        }

        function extraerIdentificadorQr(valor) {
            const texto = normalizarTextoQr(valor);
            if (!texto) return null;

            const urlId = texto.match(/[?&]id=(\d+)/i);
            if (urlId) return { tipo: 'ID', valor: urlId[1] };

            const tokenId = texto.match(/(?:INV(?:ENTARIO)?[-_ ]?IT|ITEM|ID)\s*[:#=-]\s*(\d+)/i);
            if (tokenId) return { tipo: 'ID', valor: tokenId[1] };

            const sap = texto.match(/(?:SAP)\s*[:#=-]\s*([^\n\r|]+)/i);
            if (sap) return { tipo: 'SAP', valor: sap[1].trim() };

            const serie = texto.match(/(?:N\/?S|SERIE)\s*[:#=-]\s*([^\n\r|]+)/i);
            if (serie) return { tipo: 'SERIE', valor: serie[1].trim() };

            if (/^\d+$/.test(texto)) return { tipo: 'ID_O_SAP', valor: texto };
            return { tipo: 'LIBRE', valor: texto };
        }

        function buscarArticuloPorQr(valor) {
            const token = extraerIdentificadorQr(valor);
            if (!token) return null;

            const inventario = Array.isArray(datosInventario) ? datosInventario : [];
            const target = String(token.valor || '').toUpperCase().trim();

            if (token.tipo === 'ID') {
                return inventario.find(x => String(x.id) === String(token.valor)) || null;
            }

            if (token.tipo === 'SAP') {
                return inventario.find(x => String(x.idArticuloSap || '').toUpperCase().trim() === target) || null;
            }

            if (token.tipo === 'SERIE') {
                return inventario.find(x => String(x.numeroSerie || '').toUpperCase().trim() === target) || null;
            }

            if (token.tipo === 'ID_O_SAP') {
                return inventario.find(x => String(x.id) === String(token.valor)) ||
                       inventario.find(x => String(x.idArticuloSap || '').toUpperCase().trim() === target) ||
                       null;
            }

            const coincidenciasExactas = inventario.filter(x =>
                String(x.idArticuloSap || '').toUpperCase().trim() === target ||
                String(x.numeroSerie || '').toUpperCase().trim() === target ||
                String(x.ip || '').toUpperCase().trim() === target
            );
            if (coincidenciasExactas.length === 1) return coincidenciasExactas[0];

            const coincidenciasParciales = inventario.filter(x => {
                const campos = [x.idArticuloSap, x.numeroSerie, x.nombre, x.modelo, x.ip]
                    .map(v => String(v || '').toUpperCase());
                return campos.some(c => c && c.includes(target));
            });
            return coincidenciasParciales.length === 1 ? coincidenciasParciales[0] : null;
        }

        async function procesarLecturaQr(valor, origen = 'LECTOR') {
            if (qrProcesando) return;
            const texto = normalizarTextoQr(valor);
            if (!texto) {
                setQrStatus('No se recibió ningún código.', 'error');
                $('#qrManualInput').trigger('focus');
                return;
            }

            const ahora = Date.now();
            if (texto === qrUltimoCodigo && (ahora - qrUltimoMomento) < 2500) return;
            qrUltimoCodigo = texto;
            qrUltimoMomento = ahora;

            qrProcesando = true;
            setQrReaderState('LEYENDO', 'bg-warning text-dark');

            try {
                const item = buscarArticuloPorQr(texto);
                if (!item) {
                    qrItemActual = null;
                    renderResultadoQr(null);
                    setQrStatus('Código no reconocido. Verifica que la etiqueta pertenezca al inventario actual.', 'error');
                    setQrReaderState('NO ENCONTRADO', 'bg-danger text-white');
                    return;
                }

                qrItemActual = item;
                renderResultadoQr(item);
                registrarLecturaQr(item, $('#qrModoOperacion').val() || 'CONSULTAR', origen);
                setQrStatus(`Equipo identificado: ${item.idArticuloSap || item.id} - ${item.nombre || ''}`, 'ok');
                setQrReaderState('IDENTIFICADO', 'bg-success text-white');

                const modo = $('#qrModoOperacion').val() || 'CONSULTAR';
                if (modo !== 'CONSULTAR') {
                    setTimeout(() => ejecutarAccionQr(modo, item.id, true), 250);
                }
            } finally {
                qrProcesando = false;
                $('#qrManualInput').val('').trigger('focus');
            }
        }

        function seleccionarEquipoQr(id, abrirCentro = false) {
            const item = datosInventario.find(x => Number(x.id) === Number(id));
            if (!item) return;
            qrItemActual = item;
            renderResultadoQr(item);
            registrarLecturaQr(item, 'CONSULTAR', 'TABLA');
            if (abrirCentro) abrirCentroQr('CONSULTAR');
            setQrStatus(`Equipo seleccionado: ${item.idArticuloSap || item.id} - ${item.nombre || ''}`, 'ok');
        }

        function limpiarResultadoQr() {
            qrItemActual = null;
            $('#qrManualInput').val('');
            renderResultadoQr(null);
            setQrReaderState('LISTO', 'bg-light text-dark');
            setQrStatus('Coloca el cursor en el campo superior y escanea la etiqueta.');
            $('#qrManualInput').trigger('focus');
        }

        function estadoTextoQr(item) {
            if (item.enRecuperacion) return 'EN RECUPERACIÓN';
            if (item.enReparacion || item.EnReparacion) return 'EN TALLER';
            if (item.asignacion === 'BAJA DEFINITIVA') return 'BAJA DEFINITIVA';
            if (item.asignacion === 'PARA PIEZAS') return 'PARA PIEZAS';
            if (item.asignacion && String(item.asignacion).trim()) return 'ASIGNADO';
            return 'DISPONIBLE';
        }

        function iconoArticuloQr(tipo) {
            const t = String(tipo || '').toUpperCase();
            if (t.includes('CONSUMIBLE')) return 'bi-box-seam';
            if (t.includes('HERRAMIENTA')) return 'bi-tools';
            if (t.includes('CHATARRA')) return 'bi-recycle';
            return 'bi-pc-display-horizontal';
        }

        function escapeQrHtml(valor) {
            return String(valor ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        function renderResultadoQr(item) {
            const cont = document.getElementById('qrResultContainer');
