        function procesarExcelBajas(event) {
            const file = event.target.files[0];
            if (!file) return;

            $('#resultadoExcelBajas').html('<span class="spinner-border spinner-border-sm text-danger"></span> Leyendo archivo...').show();
            $('#btnProcesarMasivo').hide();

            const reader = new FileReader();
            reader.onload = function (e) {
                try {
                    const data = new Uint8Array(e.target.result);
                    const workbook = XLSX.read(data, { type: 'array' });
                    const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
                    const json = XLSX.utils.sheet_to_json(firstSheet, { header: 1 });

                    let nombresExcel = json.map(row => Object.values(row)[0])
                                           .filter(n => n && typeof n === 'string')
                                           .map(n => n.trim().toLowerCase());

                    let usuariosConEquipo = [...new Set(datosInventario
                        .filter(i => i.asignacion && i.asignacion !== 'BAJA DEFINITIVA' && i.asignacion !== 'PARA PIEZAS' && !i.enRecuperacion)
                        .map(i => i.asignacion))];

                    usuariosCoincidentesBaja = usuariosConEquipo.filter(u =>
                        nombresExcel.includes(u.trim().toLowerCase())
                    );

                    if (usuariosCoincidentesBaja.length > 0) {
                        let html = `<strong class="text-danger">¡Atención!</strong> Se encontraron <b>${usuariosCoincidentesBaja.length}</b> ex-empleados con equipo pendiente:<br><ul class="mb-0 mt-1 ps-3">`;
                        usuariosCoincidentesBaja.forEach(u => html += `<li>${u}</li>`);
                        html += `</ul>`;
                        $('#resultadoExcelBajas').html(html);
                        $('#btnProcesarMasivo').show();
                    } else {
                        $('#resultadoExcelBajas').html('<strong class="text-success">Todo limpio.</strong> Ninguno de los empleados en el Excel tiene equipo asignado actualmente.');
                    }
                } catch (error) {
                    $('#resultadoExcelBajas').html('<strong class="text-danger">Error:</strong> No se pudo leer el Excel. Verifica el formato.');
                }
            };
            reader.readAsArrayBuffer(file);
        }

        async function ejecutarBajaMasiva() {
            if(!confirm(`¿Estás seguro de poner en estatus 'En Recuperación' los equipos de estos ${usuariosCoincidentesBaja.length} usuarios?`)) return;

            const btn = document.getElementById('btnProcesarMasivo');
            btn.disabled = true;
            btn.innerHTML = "Procesando...";

            try {
                const res = await fetch('@Url.Action("BajaMasivaUsuarios", "InventariosSistemas")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(usuariosCoincidentesBaja)
                });

                const data = await res.json();
                if (data.ok) {
                    alert(`✅ Se pasaron ${data.equiposAfectados} equipos a estatus de recuperación.`);
                    $('#excelBajas').val('');
                    $('#resultadoExcelBajas').hide();
                    $('#btnProcesarMasivo').hide();
                    usuariosCoincidentesBaja = [];
                    cargarInventario();
                } else {
                    alert("Error: " + data.mensaje);
                }
            } catch(e) {
                alert("Fallo la conexión: " + e.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check2-all"></i> Procesar Coincidencias';
            }
        }

