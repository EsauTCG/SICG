        function cambiarTabQr(tabId) {
            const btn = document.getElementById(tabId);
            if (btn) new bootstrap.Tab(btn).show();
        }

        function marcaReferenciaQr(item, accion) {
            const estacion = ($('#qrEstacion').val() || 'SIN ESTACIÓN').trim();
            return `[QR ${accion}] ${item.idArticuloSap || item.id} | ESTACIÓN: ${estacion}`;
        }

        function ejecutarAccionQr(accion, id, automatico = false) {
            const item = datosInventario.find(x => Number(x.id) === Number(id));
            if (!item) {
                setQrStatus('El equipo ya no está disponible en el inventario cargado.', 'error');
                return;
            }

            registrarLecturaQr(item, accion, automatico ? 'AUTOMÁTICO' : 'ACCIÓN');

            if (accion === 'CONSULTAR') {
                consultarArticulo(item.id);
                return;
            }

            if (!permisosInventario.puedeEscribir) {
                alert('Tu usuario no tiene permiso para registrar movimientos.');
                return;
            }

            if (accion === 'ENTRADA') {
                cambiarTabQr('movimientos-tab');
                $('#panelTipoOp').val('ENTRADA');
                togglePanelOperacion();
                $('#optRestock').prop('checked', true);
                toggleTipoEntrada();
                $('#resFiltroTipo').val('todos');
                llenarSelects();
                $('#resArticulo').val(String(item.id)).trigger('change');
                $('#resReferencia').val(marcaReferenciaQr(item, 'ENTRADA'));
                setTimeout(() => $('#resCantidad').trigger('focus'), 180);
                return;
            }

            if (accion === 'SALIDA') {
                cambiarTabQr('movimientos-tab');
                $('#panelTipoOp').val('SALIDA');
                togglePanelOperacion();
                $('#salArticulo').val(String(item.id)).trigger('change');
                $('#salReferencia').val(marcaReferenciaQr(item, 'SALIDA'));
                setTimeout(() => $('#salCantidad').trigger('focus'), 180);
                return;
            }

            if (accion === 'ASIGNAR') {
                if (item.asignacion === 'BAJA DEFINITIVA' || item.asignacion === 'PARA PIEZAS') {
                    alert('Este equipo está dado de baja y no puede asignarse.');
                    return;
                }
                cambiarTabQr('asignaciones-tab');
                $('#filtroSelectAsignar').val('todos');
                llenarSelects();
                $('#asigArticulo').val(String(item.id)).trigger('change');
                setTimeout(() => $('#asigUsuario').trigger('focus'), 180);
                return;
            }

            if (accion === 'RECUPERAR') {
                if (!item.enRecuperacion) {
                    alert('El equipo no está marcado como pendiente de recuperación.');
                    return;
                }
                cambiarTabQr('recuperaciones-tab');
                marcarComoRecibido(item.id);
                return;
            }

            if (accion === 'TALLER') {
                if (item.enReparacion || item.EnReparacion) {
                    alert('El equipo ya se encuentra en taller.');
                    cambiarTabQr('taller-tab');
                    return;
                }
                cambiarTabQr('taller-tab');
                llenarSelectTaller();
                $('#tallerArticulo').val(String(item.id)).trigger('change');
                $('#tallerMotivo').val(marcaReferenciaQr(item, 'TALLER') + ' | ');
                setTimeout(() => $('#tallerMotivo').trigger('focus'), 180);
            }
        }

        async function copiarDatosQr(id) {
            const item = datosInventario.find(x => Number(x.id) === Number(id));
            if (!item) return;
            const texto = [
                `SAP: ${item.idArticuloSap || item.id}`,
                `Equipo: ${item.nombre || ''}`,
                `Serie: ${item.numeroSerie || 'N/A'}`,
                `IP: ${item.ip || 'N/A'}`,
                `Responsable: ${item.asignacion || 'DISPONIBLE'}`,
                `Ubicación: ${item.planta || 'N/A'} / ${item.ubicacion || 'SIN UBICACIÓN'}`,
                `Estado: ${estadoTextoQr(item)}`
            ].join('\n');

            try {
                await navigator.clipboard.writeText(texto);
                setQrStatus('Ficha copiada al portapapeles.', 'ok');
            } catch {
                window.prompt('Copia la ficha:', texto);
            }
        }

        function registrarLecturaQr(item, accion, origen) {
            const estacion = ($('#qrEstacion').val() || 'SIN ESTACIÓN').trim();
            const registro = {
                fecha: new Date().toISOString(),
                id: item.id,
                sap: item.idArticuloSap || '',
                nombre: item.nombre || '',
                accion: accion || 'CONSULTAR',
                origen: origen || 'LECTOR',
                estacion
            };

            let historial = [];
            try {
                historial = JSON.parse(localStorage.getItem(QR_LOG_KEY) || '[]');
                if (!Array.isArray(historial)) historial = [];
            } catch { historial = []; }

            historial.unshift(registro);
            historial = historial.slice(0, 30);
            localStorage.setItem(QR_LOG_KEY, JSON.stringify(historial));
            renderQrRecentes();
        }

        function renderQrRecentes() {
            const tbody = document.getElementById('qrRecentBody');
            if (!tbody) return;
            let historial = [];
            try {
                historial = JSON.parse(localStorage.getItem(QR_LOG_KEY) || '[]');
                if (!Array.isArray(historial)) historial = [];
            } catch { historial = []; }

            if (!historial.length) {
                tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">Sin lecturas recientes.</td></tr>';
                return;
            }

            tbody.innerHTML = historial.slice(0, 15).map(x => {
                const fecha = new Date(x.fecha);
                const hora = isNaN(fecha) ? '-' : fecha.toLocaleTimeString('es-MX', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                return `<tr>
                    <td>${hora}</td>
                    <td><strong>${escapeQrHtml(x.sap || x.id)}</strong><br><small>${escapeQrHtml(x.nombre)}</small></td>
                    <td>${escapeQrHtml(x.accion)}</td>
                    <td>${escapeQrHtml(x.estacion)}</td>
                </tr>`;
            }).join('');
        }

        async function iniciarCamaraQr() {
            if (qrScannerActivo) return;
            if (typeof Html5Qrcode === 'undefined') {
                setQrStatus('No se cargó el componente de cámara QR. Usa el lector físico.', 'error');
                return;
            }

            try {
                $('#qrCameraPlaceholder').hide();
                qrHtml5Scanner = qrHtml5Scanner || new Html5Qrcode('qrCameraReader');
                const config = {
                    fps: 12,
                    qrbox: function (viewWidth, viewHeight) {
                        const edge = Math.floor(Math.min(viewWidth, viewHeight) * 0.68);
                        return { width: edge, height: edge };
                    },
                    aspectRatio: 1.333334
                };

                await qrHtml5Scanner.start(
                    { facingMode: 'environment' },
                    config,
                    decodedText => procesarLecturaQr(decodedText, 'CÁMARA'),
                    () => { }
                );

                qrScannerActivo = true;
                $('#qrStartCamera').prop('disabled', true);
                $('#qrStopCamera').prop('disabled', false);
                setQrReaderState('CÁMARA ACTIVA', 'bg-success text-white');
                setQrStatus('Apunta la cámara a la etiqueta QR.', 'ok');
            } catch (error) {
                qrScannerActivo = false;
                $('#qrCameraPlaceholder').show();
                setQrReaderState('SIN CÁMARA', 'bg-danger text-white');
                setQrStatus('No se pudo abrir la cámara. Revisa permisos HTTPS o usa el lector USB.', 'error');
                console.error('QR cámara:', error);
            }
        }

        async function detenerCamaraQr() {
            try {
                if (qrHtml5Scanner && qrScannerActivo) {
                    await qrHtml5Scanner.stop();
                    await qrHtml5Scanner.clear();
                }
            } catch (error) {
                console.warn('No se pudo detener completamente el lector QR:', error);
            } finally {
                qrScannerActivo = false;
                qrHtml5Scanner = null;
                $('#qrStartCamera').prop('disabled', false);
                $('#qrStopCamera').prop('disabled', true);
                $('#qrCameraReader').html(`
                    <div class="qr-camera-placeholder" id="qrCameraPlaceholder">
                        <i class="bi bi-camera"></i>
                        Usa un lector físico o inicia la cámara del equipo.
                    </div>`);
                setQrReaderState('LISTO', 'bg-light text-dark');
            }
        }

        function crearVentanaEtiqueta(titulo, ancho = 520, alto = 360) {
            const w = window.open('', '_blank', `width=${ancho},height=${alto}`);

            if (!w) {
                alert('El navegador bloqueó la ventana de impresión. Permite ventanas emergentes para este sitio.');
                return null;
            }

            const doc = w.document;
            doc.documentElement.lang = 'es';
            doc.title = titulo || 'Etiqueta de inventario';

            /*
             * Se construye el contenido con DOM y no con document.write().
             * Esto evita que Razor o el navegador interpreten etiquetas de
             * impresión como si fueran parte de la vista principal.
             */
            doc.head.innerHTML = '';
            doc.body.innerHTML = '';

            const meta = doc.createElement('meta');
            meta.setAttribute('charset', 'utf-8');
            doc.head.appendChild(meta);

            return w;
        }

        function agregarBotonImprimir(doc, texto = 'Imprimir etiqueta') {
            const acciones = doc.createElement('div');
            acciones.className = 'print-actions';

            const boton = doc.createElement('button');
            boton.type = 'button';
            boton.textContent = texto;
            boton.addEventListener('click', () => doc.defaultView.print());

            acciones.appendChild(boton);
            doc.body.appendChild(acciones);
        }

