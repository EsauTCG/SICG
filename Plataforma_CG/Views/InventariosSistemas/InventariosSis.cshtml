/* =========================================================
   CAMPANA DE PENDIENTES + GESTIÓN DEL MAPA POR SUCURSAL/ÁREA
   ========================================================= */
.stock-bell-btn {
    position: relative;
    min-height: 32px;
    display: inline-flex !important;
    align-items: center;
    gap: 7px;
    padding-right: 10px !important;
    border-color: rgba(255,255,255,.62) !important;
}

.stock-bell-btn .stock-bell-icon {
    position: relative;
    width: 22px;
    height: 22px;
    display: inline-grid;
    place-items: center;
    border-radius: 50%;
    background: rgba(255,255,255,.13);
}

.stock-bell-btn .stock-bell-count {
    min-width: 21px;
    height: 21px;
    padding: 0 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #ffffff;
    color: #8b0000;
    font-size: 10px;
    font-weight: 900;
    line-height: 1;
}

.stock-bell-btn.has-pending {
    border-color: #ffd166 !important;
    background: rgba(255, 193, 7, .16) !important;
    box-shadow: 0 0 0 2px rgba(255, 193, 7, .10);
}

.stock-bell-btn.has-pending .stock-bell-icon::after {
    content: "";
    position: absolute;
    right: -1px;
    top: -1px;
    width: 7px;
    height: 7px;
    border: 1px solid #7a0000;
    border-radius: 50%;
    background: #ffd166;
    animation: stockBellPulse 1.8s infinite;
}

.stock-bell-btn.is-clear .stock-bell-count {
    background: #d1fae5;
    color: #065f46;
}

@@keyframes stockBellPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.45); opacity: .62; }
}

.mapa-ti-context-selectors {
