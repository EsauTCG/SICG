            <strong id="controlRiesgoValor">0</strong>
            <small id="controlRiesgoNivel">Bajo</small>
        </div>
    </div>

    <div class="control-fugas-grid">
        <article class="control-fugas-kpi ok" id="controlExactitudCard">
            <span>Exactitud documental</span>
            <strong id="controlExactitud">100%</strong>
            <small>Activos con expediente mínimo completo</small>
        </article>

        <article class="control-fugas-kpi info" id="controlValorCard">
            <span>Valor expuesto</span>
            <strong id="controlValorRiesgo">$0</strong>
            <small>Costo asociado a hallazgos prioritarios</small>
        </article>

        <article class="control-fugas-kpi warning" id="controlResguardoCard">
            <span>Sin resguardo completo</span>
            <strong id="controlSinResguardo">0</strong>
            <small>Asignados sin foto y firma/documento</small>
        </article>

        <article class="control-fugas-kpi warning" id="controlSalidaCard">
            <span>Salidas sin evidencia</span>
            <strong id="controlSalidasSinEvidencia">0</strong>
            <small>Movimientos sin referencia suficiente</small>
        </article>

        <article class="control-fugas-kpi warning" id="controlRecuperacionCard">
            <span>Recuperaciones pendientes</span>
            <strong id="controlRecuperaciones">0</strong>
            <small>Equipos aún no recibidos físicamente</small>
        </article>

        <article class="control-fugas-kpi warning" id="controlConsumoCard">
            <span>Consumos anormales</span>
            <strong id="controlConsumosAnormales">0</strong>
            <small>Más de 25% sobre promedio de 3 meses</small>
        </article>
    </div>

    <div class="control-fugas-detail">
        <div class="control-fugas-detail-head">
            <div>
                <h4>Hallazgos prioritarios</h4>
                <p id="controlFugasResumen">Sin incidencias detectadas con la información disponible.</p>
            </div>
            <div class="control-fugas-actions">
                <button type="button" class="control-fugas-btn" onclick="generarControlFugas()">
                    <i class="bi bi-arrow-clockwise me-1"></i> Recalcular
                </button>
                <button type="button" class="control-fugas-btn" onclick="exportarControlFugasCsv()">
                    <i class="bi bi-file-earmark-spreadsheet me-1"></i> Exportar auditoría
                </button>
            </div>
        </div>

        <div class="control-fugas-table-wrap">
            <table class="control-fugas-table">
                <thead>
                    <tr>
                        <th>Riesgo</th>
                        <th>Hallazgo</th>
                        <th>Artículo / equipo</th>
                        <th>Responsable / ubicación</th>
                        <th>Valor expuesto</th>
                        <th>Acción recomendada</th>
                    </tr>
                </thead>
                <tbody id="controlFugasTbody">
                    <tr>
                        <td colspan="6" class="text-center py-3 text-muted">Calculando indicadores...</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="control-fugas-note">
            <i class="bi bi-info-circle-fill me-1"></i>
            Estos indicadores son preventivos. La fuga real y la exactitud física requieren registrar
            un conteo físico y compararlo contra la existencia teórica del sistema.
        </div>
    </div>
</section>
            </div>
        </div>
    </div>
</div>

