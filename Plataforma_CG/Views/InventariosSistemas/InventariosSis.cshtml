                            <button class="btn btn-sm btn-outline-secondary fw-bold" onclick="abrirModalCanibalizar(${i.id})"><i class="bi bi-puzzle me-1"></i>Importar Piezas</button>
                            <button class="btn btn-sm btn-outline-danger fw-bold" onclick="darDeBajaArticulo(${i.id})"><i class="bi bi-trash3 me-1"></i>Para Piezas / Baja</button>
                        </div>
