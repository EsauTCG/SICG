        /* =====================================================
           MAPA TI INDUSTRIAL
           Prototipo funcional integrado con datosInventario.
           La distribución se persiste localmente en el navegador.
           ===================================================== */
        const MAPA_TI_STORAGE_PREFIX = 'SIGO_MAPA_TI_INDUSTRIAL_V2_';
        const MAPA_TI_STORAGE_LEGACY = 'SIGO_MAPA_TI_INDUSTRIAL_V1';
        const MAPA_TI_SERVER_PREFIX = 'MAPA_TI_INDUSTRIAL_SUCURSAL_';
        const MAPA_TI_SERVER_LEGACY = 'MAPA_TI_INDUSTRIAL_GLOBAL';
        const MAPA_TI_SUCURSAL_KEY = 'SIGO_MAPA_TI_SUCURSAL_ACTIVA';

        let mapaTiSucursalActual = '';
        let mapaTiCargaToken = 0;
        let mapaTiInicializado = false;
        let mapaTiSeleccion = null;
        let mapaTiDrag = null;
        let mapaTiState = null;

        let mapaTiServidorListo = false;
        let mapaTiGuardadoPendiente = false;
        let mapaTiGuardando = false;
        let mapaTiGuardarTimer = null;
        let mapaTiUltimaFechaServidor = null;

        function mapaTiClaveSegmento(value) {
            return String(value || 'GENERAL')
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .toUpperCase()
                .replace(/[^A-Z0-9_-]+/g, '_')
                .replace(/^_+|_+$/g, '') || 'GENERAL';
        }

        function mapaTiStorageKey(sucursal = mapaTiSucursalActual) {
            return MAPA_TI_STORAGE_PREFIX + mapaTiClaveSegmento(sucursal);
        }

        function mapaTiClaveServidor(sucursal = mapaTiSucursalActual) {
            return MAPA_TI_SERVER_PREFIX + mapaTiClaveSegmento(sucursal);
        }

        function mapaTiSucursalesDisponibles() {
            const values = (Array.isArray(datosInventario) ? datosInventario : [])
                .map(item => String(item.planta || '').trim())
                .filter(Boolean);

            return Array.from(new Set(values)).sort((a, b) =>
                a.localeCompare(b, 'es', { sensitivity: 'base' })
            );
        }

        function mapaTiSucursalPrincipal() {
            const sucursales = mapaTiSucursalesDisponibles();
            return sucursales.includes('TIF') ? 'TIF' : (sucursales[0] || 'GENERAL');
        }

        function mapaTiPrepararSelectorSucursales() {
            const select = document.getElementById('mapaTiSucursalActiva');
            const sucursales = mapaTiSucursalesDisponibles();
            const guardada = localStorage.getItem(MAPA_TI_SUCURSAL_KEY) || '';
            const preferida = mapaTiSucursalActual || guardada || mapaTiSucursalPrincipal();

            if (!sucursales.length) sucursales.push('GENERAL');
            if (preferida && !sucursales.includes(preferida)) sucursales.unshift(preferida);

            mapaTiSucursalActual = sucursales.includes(preferida)
                ? preferida
                : sucursales[0];

            if (select) {
                select.innerHTML = sucursales
                    .map(s => `<option value="${mapaTiEsc(s)}">${mapaTiEsc(s)}</option>`)
                    .join('');
                select.value = mapaTiSucursalActual;
            }

            localStorage.setItem(MAPA_TI_SUCURSAL_KEY, mapaTiSucursalActual);
            mapaTiActualizarContexto();
        }

        function mapaTiFiltroAreaActual() {
            return String(document.getElementById('mapaTiFiltroArea')?.value || '');
        }

        function mapaTiPlacementCoincideArea(placement, areaFiltro = mapaTiFiltroAreaActual()) {
            if (!areaFiltro) return true;
            if (areaFiltro === '__SIN_AREA__') return !String(placement?.areaId || '').trim();
            return String(placement?.areaId || '') === areaFiltro;
        }

        function mapaTiActualizarFiltroAreas() {
            const select = document.getElementById('mapaTiFiltroArea');
            if (!select || !mapaTiState) return;

            const current = select.value;
            const options = [
                '<option value="">Todas las áreas</option>',
                ...mapaTiState.areas.map(area =>
                    `<option value="${mapaTiEsc(area.id)}">${mapaTiEsc(area.nombre)}</option>`
                ),
                '<option value="__SIN_AREA__">Equipos sin área</option>'
            ];

            select.innerHTML = options.join('');
            select.value = options.some(x => x.includes(`value="${current}"`)) ? current : '';
        }

        function mapaTiActualizarContexto() {
            const titulo = document.getElementById('mapaTiTituloContexto');
            const subtitulo = document.getElementById('mapaTiSubtituloContexto');
            const areaFiltro = mapaTiFiltroAreaActual();
            const area = mapaTiState?.areas?.find(a => a.id === areaFiltro);
            const areaTexto = area
                ? area.nombre
                : (areaFiltro === '__SIN_AREA__' ? 'Equipos sin área' : 'Todas las áreas');

            if (titulo) titulo.textContent = `${mapaTiSucursalActual || 'GENERAL'} · MAPA TI`;
            if (subtitulo) {
                subtitulo.innerHTML = `Sucursal activa: <span class="mapa-ti-branch-caption">${mapaTiEsc(mapaTiSucursalActual || 'GENERAL')}</span> · Vista: ${mapaTiEsc(areaTexto)}`;
            }
        }

        async function mapaTiCambiarSucursal(nuevaSucursal) {
            nuevaSucursal = String(nuevaSucursal || '').trim();
            if (!nuevaSucursal || nuevaSucursal === mapaTiSucursalActual) return;

            clearTimeout(mapaTiGuardarTimer);
            if (mapaTiState) mapaTiGuardarRespaldoLocal();

            mapaTiSucursalActual = nuevaSucursal;
            localStorage.setItem(MAPA_TI_SUCURSAL_KEY, mapaTiSucursalActual);
            mapaTiSeleccion = null;
            mapaTiServidorListo = false;
            mapaTiGuardadoPendiente = false;

            const areaSelect = document.getElementById('mapaTiFiltroArea');
            if (areaSelect) areaSelect.value = '';

            mapaTiState = mapaTiLeerRespaldoLocal();
            mapaTiRenderTodo();
            await mapaTiCargarState();
        }

        function mapaTiDefaultState() {
            return {
                sucursal: mapaTiSucursalActual || 'GENERAL',
                modo: '2d',
                background: '',
                areas: [
                    { id: 'area-produccion', nombre: 'Producción', x: 4, y: 7, w: 30, h: 36, color: '#38bdf8' },
                    { id: 'area-empaque', nombre: 'Empaque', x: 37, y: 7, w: 27, h: 36, color: '#22c55e' },
                    { id: 'area-calidad', nombre: 'Calidad', x: 67, y: 7, w: 28, h: 36, color: '#f59e0b' },
                    { id: 'area-almacen', nombre: 'Almacén', x: 4, y: 49, w: 28, h: 40, color: '#a78bfa' },
                    { id: 'area-oficinas', nombre: 'Oficinas', x: 35, y: 49, w: 29, h: 40, color: '#f472b6' },
                    { id: 'area-caseta', nombre: 'Caseta / Báscula', x: 67, y: 49, w: 28, h: 40, color: '#fb7185' }
                ],
                placements: {}
            };
        }

        function mapaTiEstadoValido(state) {
            return !!(
                state &&
                typeof state === 'object' &&
                Array.isArray(state.areas) &&
                state.placements &&
                typeof state.placements === 'object'
            );
        }

        function mapaTiTokenAntiforgery() {
            return document.querySelector(
                'input[name="__RequestVerificationToken"]'
            )?.value || '';
        }

        function mapaTiActualizarSync(texto, tipo = '') {
            const el = document.getElementById('mapaTiSyncEstado');
            if (!el) return;

            el.textContent = texto;
            el.classList.remove('loading', 'saving', 'ok', 'error');

            if (tipo) {
                el.classList.add(tipo);
            }
        }

        function mapaTiGuardarRespaldoLocal() {
            try {
                localStorage.setItem(
                    mapaTiStorageKey(),
                    JSON.stringify(mapaTiState)
                );
            } catch (error) {
                console.warn(
                    'No se pudo crear el respaldo local del Mapa TI:',
                    error
                );
            }
        }

        function mapaTiLeerRespaldoLocal() {
            try {
                let raw = localStorage.getItem(mapaTiStorageKey());

                /* Migración: el mapa global anterior se hereda únicamente
                   por la sucursal principal y después se guarda por separado. */
                if (!raw && mapaTiSucursalActual === mapaTiSucursalPrincipal()) {
                    raw = localStorage.getItem(MAPA_TI_STORAGE_LEGACY);
                }

                const parsed = raw ? JSON.parse(raw) : null;
                const state = mapaTiEstadoValido(parsed)
                    ? parsed
                    : mapaTiDefaultState();

                state.sucursal = mapaTiSucursalActual || state.sucursal || 'GENERAL';
                return state;
            } catch (error) {
                console.warn(
                    'No se pudo leer el respaldo local del Mapa TI:',
                    error
                );

                return mapaTiDefaultState();
            }
        }

        async function mapaTiCargarState() {
            const token = ++mapaTiCargaToken;
            const sucursalSolicitada = mapaTiSucursalActual;

            mapaTiState = mapaTiLeerRespaldoLocal();
            mapaTiActualizarSync(
                `Consultando mapa de ${sucursalSolicitada}...`,
                'loading'
            );

            async function consultarClave(claveMapa) {
                const url =
                    '@Url.Action("ObtenerMapaTiIndustrial", "InventariosSistemas")'
                    + '?claveMapa='
                    + encodeURIComponent(claveMapa);

                const response = await fetch(url, {
                    method: 'GET',
                    headers: { 'Accept': 'application/json' },
                    cache: 'no-store'
                });

                const data = await response.json();
                if (!response.ok || !data.ok) {
                    throw new Error(data.mensaje || 'No se pudo consultar el mapa compartido.');
                }
                return data;
            }

            try {
                let data = await consultarClave(mapaTiClaveServidor(sucursalSolicitada));
                let heredadoGlobal = false;

                /* Compatibilidad con el mapa global anterior. */
                if (!data.existe && sucursalSolicitada === mapaTiSucursalPrincipal()) {
                    const legacy = await consultarClave(MAPA_TI_SERVER_LEGACY);
                    if (legacy.existe && legacy.mapaJson) {
                        data = legacy;
                        heredadoGlobal = true;
                    }
                }

                if (token !== mapaTiCargaToken || sucursalSolicitada !== mapaTiSucursalActual) return;

                if (data.existe && data.mapaJson) {
                    const servidorState = JSON.parse(data.mapaJson);
                    if (!mapaTiEstadoValido(servidorState)) {
                        throw new Error('El mapa almacenado en SQL tiene un formato inválido.');
                    }

                    servidorState.sucursal = sucursalSolicitada;
                    mapaTiState = servidorState;
                    mapaTiUltimaFechaServidor = data.fechaModificacion || null;
                    mapaTiGuardarRespaldoLocal();

                    const fecha = data.fechaModificacion
                        ? new Date(data.fechaModificacion).toLocaleString('es-MX')
                        : '';

                    mapaTiActualizarSync(
                        heredadoGlobal
                            ? 'Mapa global heredado: guarda para separarlo por sucursal'
                            : (fecha ? `Sincronizado ${sucursalSolicitada}: ${fecha}` : `Mapa ${sucursalSolicitada} cargado desde SQL`),
                        heredadoGlobal ? 'loading' : 'ok'
                    );
                } else {
                    mapaTiActualizarSync(
                        `Mapa nuevo para ${sucursalSolicitada}: presiona Guardar mapa`,
                        'loading'
                    );
                }
            } catch (error) {
                if (token !== mapaTiCargaToken || sucursalSolicitada !== mapaTiSucursalActual) return;
                console.warn('No fue posible cargar el Mapa TI desde SQL:', error);
                mapaTiActualizarSync(
                    `Sin SQL (${sucursalSolicitada}): usando respaldo local`,
                    'error'
                );
            } finally {
                if (token !== mapaTiCargaToken || sucursalSolicitada !== mapaTiSucursalActual) return;

                mapaTiServidorListo = true;
                if (mapaTiInicializado) {
                    mapaTiRenderTodo();
                    mapaTiActualizarBotonesVista();
                    requestAnimationFrame(mapaTiAjustarPantalla);
                }

                if (mapaTiGuardadoPendiente) {
                    mapaTiGuardadoPendiente = false;
                    mapaTiProgramarGuardado(false, 150);
                }
            }
        }

        function mapaTiGuardarState(
            mostrarMensaje = false,
            inmediato = false
        ) {
            mapaTiGuardarRespaldoLocal();

            if (!mapaTiServidorListo) {
                mapaTiGuardadoPendiente = true;
                mapaTiActualizarSync(
                    'Cambio pendiente de sincronizar...',
                    'loading'
                );
                return;
            }

            mapaTiProgramarGuardado(
                mostrarMensaje,
                inmediato ? 0 : 550
            );
        }

        function mapaTiProgramarGuardado(
            mostrarMensaje,
            esperaMs
        ) {
            clearTimeout(mapaTiGuardarTimer);

            mapaTiGuardarTimer = setTimeout(
                () => mapaTiGuardarServidor(mostrarMensaje),
                esperaMs
            );
        }

        async function mapaTiGuardarServidor(
            mostrarMensaje = false
        ) {
            const sucursalGuardada = mapaTiSucursalActual;
            const claveServidor = mapaTiClaveServidor(sucursalGuardada);
            const mapaSnapshot = JSON.stringify({
                ...mapaTiState,
                sucursal: sucursalGuardada
            });
            if (mapaTiGuardando) {
                mapaTiGuardadoPendiente = true;
                return;
            }

            mapaTiGuardando = true;
            mapaTiActualizarSync(
                'Guardando en SQL Server...',
                'saving'
            );

            try {
                const response = await fetch(
                    '@Url.Action("GuardarMapaTiIndustrial", "InventariosSistemas")',
                    {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json',
                            'RequestVerificationToken':
                                mapaTiTokenAntiforgery()
                        },
                        body: JSON.stringify({
                            claveMapa: claveServidor,
                            mapaJson: mapaSnapshot
                        })
                    }
                );

                const data = await response.json();

                if (!response.ok || !data.ok) {
                    throw new Error(
                        data.mensaje ||
                        'No se pudo guardar el mapa compartido.'
                    );
                }

                mapaTiUltimaFechaServidor =
                    data.fechaModificacion || new Date().toISOString();

                const fecha = new Date(
                    mapaTiUltimaFechaServidor
                ).toLocaleString('es-MX');

                mapaTiActualizarSync(
                    `Guardado central: ${fecha}`,
                    'ok'
                );

                mapaTiGuardarRespaldoLocal();

                if (mostrarMensaje) {
                    alert(
                        `Mapa TI de ${sucursalGuardada} guardado en SQL Server.\n\n` +
                        'Las áreas, equipos y posiciones ya estarán ' +
                        'disponibles desde cualquier computadora.'
                    );
                }
            } catch (error) {
                console.error(
                    'Error guardando el Mapa TI en SQL:',
                    error
                );

                mapaTiActualizarSync(
                    'Error SQL: cambio guardado solo localmente',
                    'error'
                );

                if (mostrarMensaje) {
                    alert(
                        'No se pudo guardar el mapa en SQL Server.\n\n' +
                        'El cambio quedó como respaldo local en esta ' +
                        'computadora.\n\n' +
                        error.message
                    );
                }
            } finally {
                mapaTiGuardando = false;

                if (mapaTiGuardadoPendiente) {
                    mapaTiGuardadoPendiente = false;
                    mapaTiProgramarGuardado(false, 150);
                }
            }
        }

        function mapaTiEsc(value) {
            return String(value == null ? '' : value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        function mapaTiIcono(item) {
            const txt = `${item?.nombre || ''} ${item?.marca || ''} ${item?.modelo || ''}`.toLowerCase();

            if (txt.includes('impresora') || txt.includes('printer') || txt.includes('epson') || txt.includes('zebra')) return '🖨️';
            if (txt.includes('router') || txt.includes('switch') || txt.includes('access point') || txt.includes('antena') || txt.includes('wifi')) return '📡';
            if (txt.includes('cámara') || txt.includes('camara') || txt.includes('cctv') || txt.includes('nvr') || txt.includes('dvr')) return '📷';
            if (txt.includes('laptop') || txt.includes('notebook')) return '💻';
            if (txt.includes('monitor') || txt.includes('desktop') || txt.includes('computadora') || txt.includes('pc')) return '🖥️';
            if (txt.includes('servidor') || txt.includes('server') || txt.includes('nas')) return '🗄️';
            if (txt.includes('báscula') || txt.includes('bascula')) return '⚖️';
            if (txt.includes('scanner') || txt.includes('escaner') || txt.includes('lector')) return '📠';
            if (txt.includes('teléfono') || txt.includes('telefono') || txt.includes('celular')) return '📱';
            if (txt.includes('ups') || txt.includes('no break') || txt.includes('nobreak')) return '🔋';
            if (txt.includes('tablet')) return '▣';
            return '⚙️';
        }

        function mapaTiEstado(item, placement) {
            const manual = String(placement?.status || '').toLowerCase();
            if (['online', 'offline', 'maintenance', 'unknown', 'noip'].includes(manual)) return manual;

            const taller = item?.enTaller || item?.estaEnTaller || item?.estadoTaller;
            if (taller) return 'maintenance';

            const estado = String(item?.estadoConexion || item?.estadoRed || '').toLowerCase();
            if (['online', 'en linea', 'en línea', 'activo'].includes(estado)) return 'online';
            if (['offline', 'sin respuesta', 'caido', 'caído'].includes(estado)) return 'offline';

            if (!String(item?.ip || '').trim()) return 'noip';
            return 'unknown';
        }

        function mapaTiEstadoTexto(status) {
            return ({
                online: 'En línea',
                offline: 'Sin respuesta',
                maintenance: 'Taller / mantenimiento',
                noip: 'Sin dirección IP',
                unknown: 'Sin monitoreo'
            })[status] || 'Sin monitoreo';
        }

        function mapaTiEquiposValidos() {
            const sucursal = String(mapaTiSucursalActual || '').trim().toUpperCase();

            return (Array.isArray(datosInventario) ? datosInventario : []).filter(item => {
                const baja = ['BAJA DEFINITIVA', 'PARA PIEZAS'].includes(String(item.asignacion || '').toUpperCase());
                const plantaItem = String(item.planta || '').trim().toUpperCase();
                return !baja
                    && item.tipoArticulo !== 'Chatarra/Piezas'
                    && (!sucursal || sucursal === 'GENERAL' || plantaItem === sucursal);
            });
        }

        function mapaTiItem(id) {
            const numeric = Number(id);
            return mapaTiEquiposValidos().find(item => Number(item.id) === numeric) || null;
        }


        function mapaTiMarcarBackdropPropio() {
            const backdrops = Array.from(
                document.querySelectorAll('.modal-backdrop.show')
            );

            const ultimoBackdrop = backdrops[backdrops.length - 1];

            if (ultimoBackdrop) {
                ultimoBackdrop.classList.add('mapa-ti-backdrop');
            }
        }

        function mapaTiLimpiarBackdropPropio() {
            document
                .querySelectorAll('.modal-backdrop.mapa-ti-backdrop')
                .forEach(backdrop => {
                    backdrop.classList.remove('mapa-ti-backdrop');

                    /*
                     * Bootstrap normalmente elimina el backdrop.
                     * Esta limpieza evita que quede una capa negra huérfana
                     * si el modal se cerró durante una transición.
                     */
                    setTimeout(() => {
                        const modalMapa = document.getElementById('modalMapaTI');
                        const hayOtroModalVisible = document.querySelector(
                            '.modal.show:not(#modalMapaTI)'
                        );

                        if (
                            !modalMapa?.classList.contains('show') &&
                            !hayOtroModalVisible &&
                            backdrop.isConnected
                        ) {
                            backdrop.remove();
                        }
                    }, 180);
                });
        }

        function inicializarMapaTiIndustrial() {
            if (mapaTiInicializado) return;

            const canvas = document.getElementById('mapaTiCanvas');
            if (!canvas) return;

            mapaTiInicializado = true;
            mapaTiPrepararSelectorSucursales();
            mapaTiState = mapaTiLeerRespaldoLocal();
            mapaTiCargarState();

            const buscar = document.getElementById('mapaTiBuscar');
            const sucursal = document.getElementById('mapaTiSucursalActiva');
            const area = document.getElementById('mapaTiFiltroArea');
            const estado = document.getElementById('mapaTiFiltroEstado');

            buscar?.addEventListener('input', mapaTiRenderPalette);
            sucursal?.addEventListener('change', ev => mapaTiCambiarSucursal(ev.target.value));
            area?.addEventListener('change', () => {
                mapaTiSeleccion = null;
                mapaTiRenderTodo();
            });
            estado?.addEventListener('change', mapaTiRenderPalette);

            document.getElementById('mapaTiNuevaArea')?.addEventListener('click', mapaTiNuevaArea);
            document.getElementById('mapaTiPantallaCompleta')?.addEventListener('click', mapaTiTogglePantallaCompleta);
            document.getElementById('mapaTiPaneles')?.addEventListener('click', mapaTiTogglePaneles);
            document.getElementById('mapaTiModo')?.addEventListener('click', mapaTiToggleModo);
            document.getElementById('mapaTiCargarPlano')?.addEventListener('click', () => document.getElementById('mapaTiPlanoFile')?.click());
            document.getElementById('mapaTiGuardarServidor')?.addEventListener(
                'click',
                () => mapaTiGuardarState(true, true)
            );
            document.getElementById('mapaTiPlanoFile')?.addEventListener('change', mapaTiLeerPlano);
            document.getElementById('mapaTiExportar')?.addEventListener('click', mapaTiExportar);
            document.getElementById('mapaTiImportar')?.addEventListener('click', () => document.getElementById('mapaTiImportFile')?.click());
            document.getElementById('mapaTiImportFile')?.addEventListener('change', mapaTiImportar);
            document.getElementById('mapaTiRestablecer')?.addEventListener('click', mapaTiRestablecer);

            canvas.addEventListener('dragover', ev => {
                ev.preventDefault();
                ev.dataTransfer.dropEffect = 'copy';
            });

            canvas.addEventListener('drop', mapaTiDropPalette);
            canvas.addEventListener('pointerdown', mapaTiPointerDown);
            document.addEventListener('pointermove', mapaTiPointerMove);
            document.addEventListener('pointerup', mapaTiPointerUp);

            const modalMapaTi = document.getElementById('modalMapaTI');

            modalMapaTi?.addEventListener('show.bs.modal', () => {
                /*
                 * La clase especial se coloca únicamente en el backdrop
                 * generado para el Mapa TI.
                 */
                requestAnimationFrame(mapaTiMarcarBackdropPropio);
                setTimeout(mapaTiMarcarBackdropPropio, 20);
            });

            modalMapaTi?.addEventListener('shown.bs.modal', () => {
                mapaTiMarcarBackdropPropio();
                mapaTiRenderTodo();
                mapaTiActualizarBotonesVista();
                requestAnimationFrame(mapaTiAjustarPantalla);
                setTimeout(mapaTiAjustarPantalla, 120);
            });

            modalMapaTi?.addEventListener('hidden.bs.modal', async () => {
                const shell = document.getElementById('mapaTiShell');
                const actual = document.fullscreenElement || document.webkitFullscreenElement;

                if (actual === shell) {
                    try {
                        if (document.exitFullscreen) {
                            await document.exitFullscreen();
                        } else if (document.webkitExitFullscreen) {
                            document.webkitExitFullscreen();
                        }
                    } catch (e) {
                        console.warn('No se pudo cerrar fullscreen al cerrar el modal:', e);
                    }
                }

                mapaTiLimpiarBackdropPropio();
            });

            window.addEventListener('resize', mapaTiAjustarPantalla);
            document.addEventListener('fullscreenchange', mapaTiFullscreenCambio);
            document.addEventListener('webkitfullscreenchange', mapaTiFullscreenCambio);

            mapaTiRenderTodo();
            mapaTiAjustarPantalla();
        }

        function renderMapaTiIndustrial() {
            inicializarMapaTiIndustrial();
            if (!mapaTiInicializado) return;

            mapaTiPrepararSelectorSucursales();
            mapaTiRenderTodo();

            const modal = document.getElementById('modalMapaTI');
            if (modal?.classList.contains('show')) {
                requestAnimationFrame(mapaTiAjustarPantalla);
            }
        }

        function mapaTiRenderTodo() {
            mapaTiActualizarFiltroAreas();
            mapaTiActualizarContexto();
            mapaTiRenderPalette();
            mapaTiRenderCanvas();
            mapaTiRenderAreaTabs();
            mapaTiRenderInspector();
            mapaTiActualizarKpis();
        }

        function mapaTiRenderPalette() {
            const host = document.getElementById('mapaTiListaEquipos');
            if (!host || !mapaTiState) return;

            const q = String(document.getElementById('mapaTiBuscar')?.value || '').trim().toLowerCase();
            const areaFiltro = mapaTiFiltroAreaActual();
            const estado = String(document.getElementById('mapaTiFiltroEstado')?.value || '');

            const rows = mapaTiEquiposValidos().filter(item => {
                const placement = mapaTiState.placements[String(item.id)] || {};
                const status = mapaTiEstado(item, placement);
                const texto = [
                    item.idArticuloSap, item.nombre, item.numeroSerie, item.ip,
                    item.marca, item.modelo, item.asignacion, item.ubicacion
                ].join(' ').toLowerCase();

                return (!q || texto.includes(q))
                    && mapaTiPlacementCoincideArea(placement, areaFiltro)
                    && (!estado || status === estado);
            });

            host.innerHTML = rows.length ? rows.map(item => {
                const placement = mapaTiState.placements[String(item.id)] || {};
                const status = mapaTiEstado(item, placement);
                const ubicado = placement.x != null && placement.y != null;

                return `
                    <div class="mapa-ti-palette-item"
                         draggable="true"
                         data-equipo-id="${item.id}"
                         title="${ubicado ? 'Ya está colocado; puedes volver a arrastrarlo' : 'Arrastra hacia el plano'}">
                        <div class="mapa-ti-device-icon">${mapaTiIcono(item)}</div>
                        <div class="mapa-ti-palette-name">
                            <strong>${mapaTiEsc(item.nombre || item.idArticuloSap || 'Equipo')}</strong>
                            <small>${mapaTiEsc(item.idArticuloSap || '')} · ${mapaTiEsc(item.ip || 'Sin IP')}</small>
                        </div>
                        <span class="mapa-ti-status-dot ${status}"></span>
                    </div>`;
            }).join('') : '<div class="mapa-ti-empty">No hay equipos con esos filtros.</div>';

            host.querySelectorAll('.mapa-ti-palette-item').forEach(el => {
                el.addEventListener('dragstart', ev => {
                    ev.dataTransfer.setData('text/equipo-id', el.dataset.equipoId);
                    ev.dataTransfer.effectAllowed = 'copyMove';
                });
            });
        }

        function mapaTiRenderCanvas() {
            const canvas = document.getElementById('mapaTiCanvas');
            if (!canvas || !mapaTiState) return;

            canvas.classList.toggle('modo-3d', mapaTiState.modo === '3d');
            canvas.classList.toggle('has-background', !!mapaTiState.background);
            canvas.style.setProperty('--map-background-image', mapaTiState.background ? `url("${mapaTiState.background}")` : 'none');

            const areaFiltro = mapaTiFiltroAreaActual();
            const areasVisibles = mapaTiState.areas.filter(area =>
                !areaFiltro || area.id === areaFiltro
            );

            const areasHtml = areasVisibles.map(area => {
                const count = Object.entries(mapaTiState.placements).filter(([id, p]) => mapaTiItem(id) && p.areaId === area.id).length;
                const selected = mapaTiSeleccion?.tipo === 'area' && mapaTiSeleccion.id === area.id ? 'selected' : '';

                return `
                    <section class="mapa-ti-area ${selected}"
                             data-area-id="${mapaTiEsc(area.id)}"
                             style="left:${area.x}%;top:${area.y}%;width:${area.w}%;height:${area.h}%;--area-color:${area.color}">
                        <div class="mapa-ti-area-title" data-area-move="${mapaTiEsc(area.id)}">
                            <span>${mapaTiEsc(area.nombre)}</span>
                            <small>${count} eq.</small>
                        </div>
                        <div class="mapa-ti-area-body"></div>
                        <span class="mapa-ti-resize" data-area-resize="${mapaTiEsc(area.id)}"></span>
                    </section>`;
            }).join('');

            const devicesHtml = Object.entries(mapaTiState.placements).map(([id, placement]) => {
                const item = mapaTiItem(id);
                if (!item || placement.x == null || placement.y == null) return '';
                if (!mapaTiPlacementCoincideArea(placement, areaFiltro)) return '';

                const status = mapaTiEstado(item, placement);
                const selected = mapaTiSeleccion?.tipo === 'equipo' && String(mapaTiSeleccion.id) === String(id) ? 'selected' : '';

                return `
                    <div class="mapa-ti-map-device ${selected}"
                         data-map-device="${id}"
                         style="left:${placement.x}%;top:${placement.y}%"
                         title="${mapaTiEsc(item.nombre)}">
                        <span class="mapa-ti-status-dot map-status ${status}"></span>
                        <span class="device-emoji">${mapaTiIcono(item)}</span>
                        <strong>${mapaTiEsc(item.nombre || item.idArticuloSap)}</strong>
                        <small>${mapaTiEsc(item.ip || 'SIN IP')}</small>
                    </div>`;
            }).join('');

            canvas.innerHTML = areasHtml + devicesHtml;
        }

        function mapaTiRenderAreaTabs() {
            const host = document.getElementById('mapaTiAreaTabs');
            if (!host || !mapaTiState) return;

            const current = mapaTiFiltroAreaActual();
            const placementsValidos = Object.entries(mapaTiState.placements)
                .filter(([id]) => !!mapaTiItem(id));

            const tabs = [
                {
                    id: '',
                    nombre: 'Todas',
                    count: placementsValidos.filter(([, p]) => p.x != null && p.y != null).length
                },
                ...mapaTiState.areas.map(area => ({
                    id: area.id,
                    nombre: area.nombre,
                    count: placementsValidos.filter(([, p]) => p.areaId === area.id).length
                })),
                {
                    id: '__SIN_AREA__',
                    nombre: 'Sin área',
                    count: placementsValidos.filter(([, p]) => !String(p.areaId || '').trim()).length
                }
            ];

            host.innerHTML = tabs.map(tab => `
                <button type="button"
                        class="mapa-ti-area-tab ${current === tab.id ? 'active' : ''}"
                        data-map-area-filter="${mapaTiEsc(tab.id)}">
                    ${mapaTiEsc(tab.nombre)} <strong>${tab.count}</strong>
                </button>`).join('');

            host.querySelectorAll('[data-map-area-filter]').forEach(btn => {
                btn.addEventListener('click', () => {
                    const select = document.getElementById('mapaTiFiltroArea');
                    if (select) select.value = btn.dataset.mapAreaFilter || '';
                    mapaTiSeleccion = null;
                    mapaTiRenderTodo();
                });
            });
        }

        function mapaTiActualizarKpis() {
            if (!mapaTiState) return;

            let ubicados = 0;
            let online = 0;
            let offline = 0;

            const areaFiltro = mapaTiFiltroAreaActual();

            Object.entries(mapaTiState.placements).forEach(([id, placement]) => {
                const item = mapaTiItem(id);
                if (!item || placement.x == null || placement.y == null) return;
                if (!mapaTiPlacementCoincideArea(placement, areaFiltro)) return;

                ubicados++;
                const status = mapaTiEstado(item, placement);
                if (status === 'online') online++;
                if (status === 'offline') offline++;
            });

            const set = (id, value) => {
                const el = document.getElementById(id);
                if (el) el.textContent = value;
            };

            set('mapaTiKpiUbicados', ubicados);
            set('mapaTiKpiOnline', online);
            set('mapaTiKpiOffline', offline);
            set('mapaTiKpiAreas', areaFiltro && areaFiltro !== '__SIN_AREA__' ? 1 : mapaTiState.areas.length);
        }

        function mapaTiDropPalette(ev) {
            ev.preventDefault();

            const id = ev.dataTransfer.getData('text/equipo-id');
            const item = mapaTiItem(id);
            if (!item) return;

            const pos = mapaTiPosicionDesdeEvento(ev);
            const area = mapaTiAreaEnPunto(pos.x, pos.y);
            const prev = mapaTiState.placements[String(id)] || {};

            mapaTiState.placements[String(id)] = {
                ...prev,
                x: Math.max(0, Math.min(91, pos.x)),
                y: Math.max(0, Math.min(88, pos.y)),
                areaId: area?.id || ''
            };

            mapaTiSeleccion = { tipo: 'equipo', id: String(id) };
            mapaTiGuardarState(false, true);
            mapaTiRenderTodo();
        }

        function mapaTiPosicionDesdeEvento(ev) {
            const canvas = document.getElementById('mapaTiCanvas');
            const rect = canvas.getBoundingClientRect();

            return {
                x: ((ev.clientX - rect.left) / rect.width) * 100,
                y: ((ev.clientY - rect.top) / rect.height) * 100
            };
        }

        function mapaTiAreaEnPunto(x, y) {
            return mapaTiState.areas.find(area =>
                x >= area.x && x <= area.x + area.w &&
                y >= area.y && y <= area.y + area.h
            ) || null;
        }

        function mapaTiPointerDown(ev) {
            const device = ev.target.closest('[data-map-device]');
            const moveArea = ev.target.closest('[data-area-move]');
            const resizeArea = ev.target.closest('[data-area-resize]');
            const areaBox = ev.target.closest('[data-area-id]');

            if (device) {
                ev.preventDefault();
                const id = device.dataset.mapDevice;
                const placement = mapaTiState.placements[id];
                if (!placement) return;

                mapaTiSeleccion = { tipo: 'equipo', id };
                mapaTiDrag = {
                    tipo: 'equipo',
                    id,
                    startClientX: ev.clientX,
                    startClientY: ev.clientY,
                    startX: Number(placement.x),
                    startY: Number(placement.y),
                    moved: false
                };
                device.setPointerCapture?.(ev.pointerId);
                mapaTiRenderInspector();
                return;
            }

            if (resizeArea) {
                ev.preventDefault();
                const id = resizeArea.dataset.areaResize;
                const area = mapaTiState.areas.find(a => a.id === id);
                if (!area) return;

                mapaTiSeleccion = { tipo: 'area', id };
                mapaTiDrag = {
                    tipo: 'resize-area',
                    id,
                    startClientX: ev.clientX,
                    startClientY: ev.clientY,
                    startW: Number(area.w),
                    startH: Number(area.h)
                };
                mapaTiRenderInspector();
                return;
            }

            if (moveArea) {
                ev.preventDefault();
                const id = moveArea.dataset.areaMove;
                const area = mapaTiState.areas.find(a => a.id === id);
                if (!area) return;

                mapaTiSeleccion = { tipo: 'area', id };
                mapaTiDrag = {
                    tipo: 'move-area',
                    id,
                    startClientX: ev.clientX,
                    startClientY: ev.clientY,
                    startX: Number(area.x),
                    startY: Number(area.y)
                };
                mapaTiRenderInspector();
                return;
            }

            if (areaBox) {
                mapaTiSeleccion = { tipo: 'area', id: areaBox.dataset.areaId };
                mapaTiRenderTodo();
                return;
            }

            mapaTiSeleccion = null;
            mapaTiRenderTodo();
        }

        function mapaTiPointerMove(ev) {
            if (!mapaTiDrag) return;

            const canvas = document.getElementById('mapaTiCanvas');
            const rect = canvas.getBoundingClientRect();
            const dx = ((ev.clientX - mapaTiDrag.startClientX) / rect.width) * 100;
            const dy = ((ev.clientY - mapaTiDrag.startClientY) / rect.height) * 100;

            if (mapaTiDrag.tipo === 'equipo') {
                const placement = mapaTiState.placements[mapaTiDrag.id];
                placement.x = Math.max(0, Math.min(91, mapaTiDrag.startX + dx));
                placement.y = Math.max(0, Math.min(88, mapaTiDrag.startY + dy));
                mapaTiDrag.moved = Math.abs(dx) > .2 || Math.abs(dy) > .2;
            }

            if (mapaTiDrag.tipo === 'move-area') {
                const area = mapaTiState.areas.find(a => a.id === mapaTiDrag.id);
                area.x = Math.max(0, Math.min(100 - area.w, mapaTiDrag.startX + dx));
                area.y = Math.max(0, Math.min(100 - area.h, mapaTiDrag.startY + dy));
            }

            if (mapaTiDrag.tipo === 'resize-area') {
                const area = mapaTiState.areas.find(a => a.id === mapaTiDrag.id);
                area.w = Math.max(10, Math.min(100 - area.x, mapaTiDrag.startW + dx));
                area.h = Math.max(10, Math.min(100 - area.y, mapaTiDrag.startH + dy));
            }

            mapaTiRenderCanvas();
            mapaTiActualizarKpis();
        }

        function mapaTiPointerUp() {
            if (!mapaTiDrag) return;

            if (mapaTiDrag.tipo === 'equipo') {
                const placement = mapaTiState.placements[mapaTiDrag.id];
                const area = mapaTiAreaEnPunto(Number(placement.x) + 4, Number(placement.y) + 5);
                placement.areaId = area?.id || '';
            }

            mapaTiDrag = null;
            mapaTiGuardarState(false, true);
            mapaTiRenderTodo();
        }

        function mapaTiRenderInspector() {
            const host = document.getElementById('mapaTiInspector');
            if (!host || !mapaTiState) return;

            if (!mapaTiSeleccion) {
                host.innerHTML = `
                    <div class="mapa-ti-inspector-card">
                        <h5>Sin selección</h5>
                        <div class="mapa-ti-empty">
                            Selecciona un área o equipo para consultar y modificar su información visual.
                        </div>
                    </div>
                    ${mapaTiLegendHtml()}`;
                return;
            }

            if (mapaTiSeleccion.tipo === 'area') {
                const area = mapaTiState.areas.find(a => a.id === mapaTiSeleccion.id);
                if (!area) {
                    mapaTiSeleccion = null;
                    mapaTiRenderInspector();
                    return;
                }

                host.innerHTML = `
                    <div class="mapa-ti-inspector-card">
                        <h5>Área de planta</h5>
                        <div class="mapa-ti-field">
                            <label>Nombre del área</label>
                            <input id="mapaTiAreaNombre" value="${mapaTiEsc(area.nombre)}">
                        </div>
                        <div class="mapa-ti-field">
                            <label>Color operativo</label>
                            <input id="mapaTiAreaColor" type="color" value="${mapaTiEsc(area.color)}">
                        </div>
                        <div class="mapa-ti-inspector-actions">
                            <div class="mapa-ti-field">
                                <label>Posición X %</label>
                                <input id="mapaTiAreaX" type="number" min="0" max="100" step=".5" value="${Number(area.x).toFixed(1)}">
                            </div>
                            <div class="mapa-ti-field">
                                <label>Posición Y %</label>
                                <input id="mapaTiAreaY" type="number" min="0" max="100" step=".5" value="${Number(area.y).toFixed(1)}">
                            </div>
                            <div class="mapa-ti-field">
                                <label>Ancho %</label>
                                <input id="mapaTiAreaW" type="number" min="10" max="100" step=".5" value="${Number(area.w).toFixed(1)}">
                            </div>
                            <div class="mapa-ti-field">
                                <label>Alto %</label>
                                <input id="mapaTiAreaH" type="number" min="10" max="100" step=".5" value="${Number(area.h).toFixed(1)}">
                            </div>
                        </div>
                        <div class="mapa-ti-inspector-actions">
                            <button type="button" class="mapa-ti-btn primary" onclick="mapaTiGuardarAreaInspector()">Aplicar</button>
                            <button type="button" class="mapa-ti-btn danger" onclick="mapaTiEliminarArea('${mapaTiEsc(area.id)}')">Eliminar</button>
                        </div>
                    </div>
                    ${mapaTiLegendHtml()}`;
                return;
            }

            const id = String(mapaTiSeleccion.id);
            const item = mapaTiItem(id);
            const placement = mapaTiState.placements[id] || {};

            if (!item) {
                mapaTiSeleccion = null;
                mapaTiRenderInspector();
                return;
            }

            const status = mapaTiEstado(item, placement);
            const area = mapaTiState.areas.find(a => a.id === placement.areaId);
            const areaOptions = [
                '<option value="">Fuera de área</option>',
                ...mapaTiState.areas.map(a => `<option value="${mapaTiEsc(a.id)}" ${a.id === placement.areaId ? 'selected' : ''}>${mapaTiEsc(a.nombre)}</option>`)
            ].join('');

            host.innerHTML = `
                <div class="mapa-ti-inspector-card">
                    <h5>${mapaTiIcono(item)} Equipo seleccionado</h5>
                    <div class="mapa-ti-field">
                        <label>Equipo / SAP</label>
                        <div class="mapa-ti-readonly"><strong>${mapaTiEsc(item.nombre || '-')}</strong><br>${mapaTiEsc(item.idArticuloSap || '-')}</div>
                    </div>
                    <div class="mapa-ti-field">
                        <label>Marca / modelo</label>
                        <div class="mapa-ti-readonly">${mapaTiEsc(item.marca || '-')} · ${mapaTiEsc(item.modelo || '-')}</div>
                    </div>
                    <div class="mapa-ti-field">
                        <label>Número de serie</label>
                        <div class="mapa-ti-readonly" style="font-family:Consolas,monospace">${mapaTiEsc(item.numeroSerie || '-')}</div>
                    </div>
                    <div class="mapa-ti-field">
                        <label>Dirección IP</label>
                        <div class="mapa-ti-readonly" style="font-family:Consolas,monospace">${mapaTiEsc(item.ip || 'Sin IP')}</div>
                    </div>
                    <div class="mapa-ti-field">
                        <label>Responsable actual</label>
                        <div class="mapa-ti-readonly">${mapaTiEsc(item.asignacion || 'Disponible')}</div>
                    </div>
                    <div class="mapa-ti-field">
                        <label>Planta / ubicación registrada</label>
                        <div class="mapa-ti-readonly">${mapaTiEsc(item.planta || '-')} · ${mapaTiEsc(item.ubicacion || '-')}</div>
                    </div>
                </div>

                <div class="mapa-ti-inspector-card">
                    <h5>Operación visual</h5>
                    <div class="mapa-ti-field">
                        <label>Área del mapa</label>
                        <select id="mapaTiEquipoArea">${areaOptions}</select>
                    </div>
                    <div class="mapa-ti-field">
                        <label>Estado operativo</label>
                        <select id="mapaTiEquipoEstado">
                            <option value="unknown" ${status === 'unknown' ? 'selected' : ''}>Sin monitoreo</option>
                            <option value="online" ${status === 'online' ? 'selected' : ''}>En línea</option>
                            <option value="offline" ${status === 'offline' ? 'selected' : ''}>Sin respuesta</option>
                            <option value="maintenance" ${status === 'maintenance' ? 'selected' : ''}>Taller / mantenimiento</option>
                            <option value="noip" ${status === 'noip' ? 'selected' : ''}>Sin IP</option>
                        </select>
                    </div>
                    <div class="mapa-ti-field">
                        <label>Diagnóstico / observación visual</label>
                        <input id="mapaTiEquipoNota" value="${mapaTiEsc(placement.note || '')}" placeholder="Ej. Puerto 9100, UPS, rack, falla...">
                    </div>
                    <div class="mapa-ti-field">
                        <label>Estado actual</label>
                        <div class="mapa-ti-readonly">
                            <span class="mapa-ti-status-dot ${status}" style="display:inline-block;margin-right:7px"></span>
                            ${mapaTiEstadoTexto(status)}
                            ${area ? ` · ${mapaTiEsc(area.nombre)}` : ''}
                        </div>
                    </div>
                    <div class="mapa-ti-inspector-actions">
                        <button type="button" class="mapa-ti-btn primary" onclick="mapaTiGuardarEquipoInspector('${id}')">Guardar</button>
                        <button type="button" class="mapa-ti-btn" onclick="consultarArticulo(${Number(id)})">Ficha completa</button>
                        <button type="button" class="mapa-ti-btn danger" style="grid-column:1/-1" onclick="mapaTiQuitarEquipo('${id}')">Quitar del plano</button>
                    </div>
                </div>

                ${mapaTiLegendHtml()}`;
        }

        function mapaTiLegendHtml() {
            return `
                <div class="mapa-ti-inspector-card">
                    <h5>Leyenda operativa</h5>
                    <div class="mapa-ti-legend">
                        <div><span class="mapa-ti-status-dot online"></span> En línea</div>
                        <div><span class="mapa-ti-status-dot offline"></span> Sin respuesta</div>
                        <div><span class="mapa-ti-status-dot maintenance"></span> Taller</div>
                        <div><span class="mapa-ti-status-dot unknown"></span> Sin monitoreo</div>
                    </div>
                </div>`;
        }

        function mapaTiGuardarEquipoInspector(id) {
            const placement = mapaTiState.placements[String(id)] || {};
            placement.areaId = document.getElementById('mapaTiEquipoArea')?.value || '';
            placement.status = document.getElementById('mapaTiEquipoEstado')?.value || 'unknown';
            placement.note = document.getElementById('mapaTiEquipoNota')?.value?.trim() || '';

            if (placement.x == null || placement.y == null) {
                const area = mapaTiState.areas.find(a => a.id === placement.areaId);
                placement.x = area ? area.x + Math.min(4, area.w / 3) : 45;
                placement.y = area ? area.y + Math.min(6, area.h / 3) : 45;
            }

            mapaTiState.placements[String(id)] = placement;
            mapaTiGuardarState(false, true);
            mapaTiRenderTodo();
        }

        function mapaTiGuardarAreaInspector() {
            if (mapaTiSeleccion?.tipo !== 'area') return;
            const area = mapaTiState.areas.find(a => a.id === mapaTiSeleccion.id);
            if (!area) return;

            const value = id => document.getElementById(id)?.value;
            const number = (id, fallback) => {
                const n = Number(value(id));
                return Number.isFinite(n) ? n : fallback;
            };

            area.nombre = String(value('mapaTiAreaNombre') || area.nombre).trim() || area.nombre;
            area.color = value('mapaTiAreaColor') || area.color;
            area.x = Math.max(0, Math.min(90, number('mapaTiAreaX', area.x)));
            area.y = Math.max(0, Math.min(90, number('mapaTiAreaY', area.y)));
            area.w = Math.max(10, Math.min(100 - area.x, number('mapaTiAreaW', area.w)));
            area.h = Math.max(10, Math.min(100 - area.y, number('mapaTiAreaH', area.h)));

            mapaTiGuardarState(false, true);
            mapaTiRenderTodo();
        }

        function mapaTiNuevaArea() {
            const nombre = prompt('Nombre de la nueva área:', 'Nueva área');
            if (!nombre || !nombre.trim()) return;

            const colors = ['#38bdf8', '#22c55e', '#f59e0b', '#a78bfa', '#f472b6', '#fb7185', '#2dd4bf'];
            const id = `area-${Date.now()}`;

            mapaTiState.areas.push({
                id,
                nombre: nombre.trim(),
                x: 10 + (mapaTiState.areas.length * 4) % 55,
                y: 12 + (mapaTiState.areas.length * 5) % 45,
                w: 24,
                h: 28,
                color: colors[mapaTiState.areas.length % colors.length]
            });

            mapaTiSeleccion = { tipo: 'area', id };
            mapaTiGuardarState(false, true);
            mapaTiActualizarFiltroAreas();
            const areaSelect = document.getElementById('mapaTiFiltroArea');
            if (areaSelect) areaSelect.value = id;
            mapaTiRenderTodo();
        }

        function mapaTiEliminarArea(id) {
            const area = mapaTiState.areas.find(a => a.id === id);
            if (!area) return;
            if (!confirm(`¿Eliminar el área "${area.nombre}"?\nLos equipos permanecerán en el plano, pero quedarán sin área.`)) return;

            mapaTiState.areas = mapaTiState.areas.filter(a => a.id !== id);
            Object.values(mapaTiState.placements).forEach(p => {
                if (p.areaId === id) p.areaId = '';
            });

            mapaTiSeleccion = null;
            mapaTiGuardarState(false, true);
            mapaTiRenderTodo();
        }

        function mapaTiQuitarEquipo(id) {
            if (!confirm('¿Quitar este equipo del plano visual? El artículo no se elimina del inventario.')) return;
            delete mapaTiState.placements[String(id)];
            mapaTiSeleccion = null;
            mapaTiGuardarState(false, true);
            mapaTiRenderTodo();
        }


        function mapaTiAjustarPantalla() {
            const shell = document.getElementById('mapaTiShell');
            const modal = document.getElementById('modalMapaTI');

            if (!shell || !modal || !modal.classList.contains('show')) return;

            if (document.fullscreenElement === shell || document.webkitFullscreenElement === shell) {
                shell.style.height = '100vh';
                return;
            }

            shell.style.height = '100%';

            requestAnimationFrame(() => {
                mapaTiRenderCanvas();
            });
        }

        async function mapaTiTogglePantallaCompleta() {
            const shell = document.getElementById('mapaTiShell');
            if (!shell) return;

            try {
                const actual = document.fullscreenElement || document.webkitFullscreenElement;

                if (!actual) {
                    if (shell.requestFullscreen) {
                        await shell.requestFullscreen();
                    } else if (shell.webkitRequestFullscreen) {
                        shell.webkitRequestFullscreen();
                    } else {
                        shell.classList.toggle('mapa-ti-solo-plano');
                    }
                } else {
                    if (document.exitFullscreen) {
                        await document.exitFullscreen();
                    } else if (document.webkitExitFullscreen) {
                        document.webkitExitFullscreen();
                    }
                }
            } catch (error) {
                console.warn('No se pudo abrir pantalla completa:', error);
                shell.classList.toggle('mapa-ti-solo-plano');
                mapaTiActualizarBotonesVista();
            }
        }

        function mapaTiTogglePaneles() {
            const shell = document.getElementById('mapaTiShell');
            if (!shell) return;

            shell.classList.toggle('mapa-ti-solo-plano');
            mapaTiActualizarBotonesVista();
            setTimeout(mapaTiAjustarPantalla, 40);
        }

        function mapaTiFullscreenCambio() {
            mapaTiActualizarBotonesVista();
            setTimeout(mapaTiAjustarPantalla, 50);
        }

        function mapaTiActualizarBotonesVista() {
            const shell = document.getElementById('mapaTiShell');
            const btnFull = document.getElementById('mapaTiPantallaCompleta');
            const btnPaneles = document.getElementById('mapaTiPaneles');
            const full = document.fullscreenElement === shell || document.webkitFullscreenElement === shell;

            if (btnFull) {
                btnFull.textContent = full ? '✕ Salir de pantalla completa' : '⛶ Pantalla completa';
            }

            if (btnPaneles && shell) {
                btnPaneles.textContent = shell.classList.contains('mapa-ti-solo-plano')
                    ? 'Mostrar paneles'
                    : 'Ocultar paneles';
            }
        }

        function mapaTiToggleModo() {
            mapaTiState.modo = mapaTiState.modo === '3d' ? '2d' : '3d';
            const btn = document.getElementById('mapaTiModo');
            if (btn) btn.textContent = mapaTiState.modo === '3d' ? 'Vista 2D' : 'Vista 3D';
            mapaTiGuardarState(false, true);
            mapaTiRenderCanvas();
        }

        function mapaTiLeerPlano(ev) {
            const file = ev.target.files?.[0];
            if (!file) return;

            if (file.size > 3 * 1024 * 1024) {
                alert('El plano debe pesar menos de 3 MB para guardarlo localmente.');
                ev.target.value = '';
                return;
            }

            const reader = new FileReader();
            reader.onload = () => {
                mapaTiState.background = String(reader.result || '');
                mapaTiGuardarState(false, true);
                mapaTiRenderCanvas();
            };
            reader.readAsDataURL(file);
            ev.target.value = '';
        }

        function mapaTiExportar() {
            const payload = {
                version: 1,
                fecha: new Date().toISOString(),
                mapa: mapaTiState
            };

            const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `Mapa_TI_Industrial_${new Date().toISOString().slice(0, 10)}.json`;
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(url);
        }

        function mapaTiImportar(ev) {
            const file = ev.target.files?.[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = () => {
                try {
                    const parsed = JSON.parse(String(reader.result || '{}'));
                    const imported = parsed.mapa || parsed;

                    if (!Array.isArray(imported.areas) || !imported.placements) {
                        throw new Error('Formato de mapa inválido.');
                    }

                    mapaTiState = { ...imported, sucursal: mapaTiSucursalActual };
                    mapaTiSeleccion = null;
                    mapaTiGuardarState(false, true);
                    mapaTiRenderTodo();
                } catch (e) {
                    alert('No se pudo importar el mapa: ' + e.message);
                }
            };
            reader.readAsText(file);
            ev.target.value = '';
        }

        function mapaTiRestablecer() {
            if (!confirm('¿Restablecer el plano, áreas y posiciones de equipos?')) return;
            mapaTiState = mapaTiDefaultState();
            mapaTiSeleccion = null;
            mapaTiGuardarState(false, true);
            mapaTiRenderTodo();
        }



        /* Altura real de pantalla para Edge/Chrome, zoom y barras del navegador. */
        function ajustarAlturaRealMapaTi() {
            const modal = document.getElementById('modalMapaTI');
            if (!modal) return;

            const altura = Math.max(
                480,
                window.visualViewport?.height || window.innerHeight || document.documentElement.clientHeight
            );

            modal.style.setProperty('--mapa-ti-modal-height', `${Math.round(altura)}px`);
        }

        window.addEventListener('resize', ajustarAlturaRealMapaTi);
        window.visualViewport?.addEventListener('resize', ajustarAlturaRealMapaTi);

        document.addEventListener('DOMContentLoaded', ajustarAlturaRealMapaTi);

        document.getElementById('modalMapaTI')?.addEventListener('show.bs.modal', () => {
            ajustarAlturaRealMapaTi();
            document.documentElement.style.overflow = 'hidden';
            document.body.style.overflow = 'hidden';
        });

        document.getElementById('modalMapaTI')?.addEventListener('shown.bs.modal', () => {
            ajustarAlturaRealMapaTi();
            setTimeout(() => {
                ajustarAlturaRealMapaTi();
                mapaTiAjustarPantalla();
            }, 80);
        });

        document.getElementById('modalMapaTI')?.addEventListener('hidden.bs.modal', () => {
            document.documentElement.style.overflow = '';
            document.body.style.overflow = '';
            mapaTiLimpiarBackdropPropio();
        });



        document.addEventListener('hidden.bs.modal', event => {
            if (event.target?.id === 'modalMapaTI') return;

            /*
             * No se elimina el backdrop si todavía existe otro modal abierto.
             * Solamente corrige una capa huérfana.
             */
            setTimeout(() => {
                const hayModalVisible = document.querySelector('.modal.show');

                if (!hayModalVisible) {
                    document
                        .querySelectorAll('.modal-backdrop:not(.mapa-ti-backdrop)')
                        .forEach(backdrop => backdrop.remove());

                    document.body.classList.remove('modal-open');
                    document.body.style.removeProperty('padding-right');
                }
            }, 180);
        });

</script>
}


<script>
    document.addEventListener('DOMContentLoaded', function () {
        const moduleLabel = document.getElementById('inventoryActiveModule');
        const moduleButtons = document.querySelectorAll(
            '#myTab [data-bs-toggle="tab"]'
        );
        const explorerButton = document.getElementById('explorador-tab');
        const explorerModalElement = document.getElementById('modalExploradorInventario');

        moduleButtons.forEach(function (button) {
            button.addEventListener('shown.bs.tab', function (event) {
                const title =
                    event.target.getAttribute('data-module-title') ||
                    event.target.textContent.trim();

                if (moduleLabel) {
                    moduleLabel.textContent = title;
                }

                /*
                 * En móvil mantiene visible la tarjeta seleccionada
                 * sin modificar el comportamiento del tab.
                 */
                if (window.innerWidth <= 560) {
                    event.target.closest('.nav-item')?.scrollIntoView({
                        behavior: 'smooth',
                        block: 'nearest',
                        inline: 'center'
                    });
                }
            });
        });

        explorerButton?.addEventListener('click', function () {
            if (moduleLabel) moduleLabel.textContent = 'Explorador y reportería (modal)';
        });

        explorerModalElement?.addEventListener('shown.bs.modal', function () {
            aplicarFiltros();
            setTimeout(() => document.getElementById('filtroGeneral')?.focus(), 120);
        });

        explorerModalElement?.addEventListener('hidden.bs.modal', function () {
            const activeTab = document.querySelector('#myTab [data-bs-toggle="tab"].active');
            if (moduleLabel && activeTab) {
                moduleLabel.textContent = activeTab.getAttribute('data-module-title') || activeTab.textContent.trim();
            }
        });


        const controlFugasModalElement = document.getElementById('modalControlFugas');
        controlFugasModalElement?.addEventListener('shown.bs.modal', function () {
            generarControlFugas();
        });
    });
</script>
