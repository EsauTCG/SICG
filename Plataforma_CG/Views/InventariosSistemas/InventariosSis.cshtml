                    bitacoraHtml += `<li class="text-muted fst-italic">Sin historial aún...</li>`;
                }
                bitacoraHtml += '</ul>';

                let btnFoto = '';
                if (i.tieneFotoFalla) {
                    btnFoto = `<button class="btn btn-sm btn-outline-secondary py-0 mt-1" style="font-size:0.7rem;" onclick="verFotoFalla(${i.id})"><i class="fas fa-camera"></i> Ver Falla</button>`;
                }

                tbody += `<tr>
                    <td>
                        <strong style="color: var(--brand-main);">${i.idArticuloSap}</strong><br>
                        <span class="fw-bold">${i.nombre}</span><br>
                        <div class="mt-2 p-2 bg-light rounded text-danger small"><b>Falla:</b> ${i.motivoFalla || 'No detallado'}</div>
                        ${btnFoto}
                    </td>
                    <td style="background-color: #f8f9fa;">
                        <div style="max-height: 120px; overflow-y:auto;" class="scroll-panel pe-2">${bitacoraHtml}</div>
                        <button class="btn btn-sm p-0 mt-1 fw-bold" style="color: var(--brand-main); font-size:0.75rem;" onclick="abrirModalActualizarTaller(${i.id})"><i class="bi bi-plus-circle me-1"></i>Añadir Nota</button>
                    </td>
                    <td class="text-center">
                        <div class="d-flex flex-column gap-2 px-2">
