    font-size: 10px;
    font-weight: 900;
    cursor: pointer;
}

.control-fugas-btn:hover {
    border-color: #8b0000;
    background: #f4dddd;
}

.control-fugas-table-wrap {
    width: 100%;
    max-height: 270px;
    overflow: auto;
    border-top: 1px solid #eadada;
}

.control-fugas-table {
    width: 100%;
    min-width: 880px;
    margin: 0;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 10px;
}

.control-fugas-table th {
    position: sticky;
    top: 0;
    z-index: 2;
    padding: 7px 8px;
    background: #6f1111;
    color: #fff;
    font-size: 9px;
    text-align: left;
    white-space: nowrap;
}

.control-fugas-table td {
    padding: 7px 8px;
    border-right: 1px solid #eadada;
    border-bottom: 1px solid #eadada;
    color: #442020;
    vertical-align: middle;
}

.control-fugas-table tbody tr:nth-child(even) td {
    background: #fff8f8;
}

.control-risk-badge {
    display: inline-flex;
    align-items: center;
    min-width: 58px;
    justify-content: center;
    padding: 3px 6px;
    border-radius: 999px;
    font-size: 8px;
    font-weight: 900;
    text-transform: uppercase;
}

.control-risk-badge.critico {
    background: #fee2e2;
    color: #991b1b;
    border: 1px solid #fecaca;
}

.control-risk-badge.alto {
    background: #ffedd5;
    color: #9a3412;
    border: 1px solid #fed7aa;
}

.control-risk-badge.medio {
    background: #fef3c7;
    color: #92400e;
    border: 1px solid #fde68a;
}

.control-risk-badge.bajo {
    background: #dcfce7;
    color: #166534;
    border: 1px solid #bbf7d0;
}

.control-fugas-note {
    padding: 7px 12px;
    border-top: 1px solid #eadada;
    background: #fff7ed;
    color: #7c4a13;
    font-size: 9px;
    line-height: 1.4;
}

@@media (max-width: 1400px) {
    .control-fugas-grid {
        grid-template-columns: repeat(3, minmax(140px, 1fr));
    }
}

@@media (max-width: 768px) {
    .control-fugas-head,
    .control-fugas-detail-head {
        align-items: flex-start;
        flex-direction: column;
    }

    .control-fugas-score {
        width: 100%;
        text-align: left;
    }

    .control-fugas-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .control-fugas-actions {
        width: 100%;
    }

    .control-fugas-btn {
        flex: 1 1 130px;
    }
}

@@media (max-width: 460px) {
    .control-fugas-grid {
        grid-template-columns: 1fr;
    }
}


/* =========================================================
   BOTÓN SUPERIOR Y MODAL DE CONTROL DE FUGAS
   ========================================================= */
.control-fugas-trigger {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 6px !important;
    white-space: nowrap;
}

.control-fugas-trigger-icon {
    width: 21px;
    height: 21px;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    background: rgba(255,255,255,.14);
    color: #fff;
    font-size: 12px;
}

.control-fugas-trigger-count {
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255,255,255,.62);
    border-radius: 999px;
    background: #fff;
    color: #7b1113;
    font-size: 10px;
    font-weight: 900;
    font-variant-numeric: tabular-nums;
}

.control-fugas-trigger.is-clear .control-fugas-trigger-count {
    border-color: #bbf7d0;
    background: #dcfce7;
    color: #166534;
}

.control-fugas-trigger.is-warning {
    border-color: #ffd47d !important;
    box-shadow: 0 0 0 2px rgba(255, 191, 71, .12);
}

.control-fugas-trigger.is-warning .control-fugas-trigger-count {
    border-color: #fde68a;
    background: #fef3c7;
    color: #92400e;
}

.control-fugas-trigger.is-danger {
    border-color: #ffb4b4 !important;
    box-shadow: 0 0 0 2px rgba(255, 91, 102, .15);
}

.control-fugas-trigger.is-danger .control-fugas-trigger-count {
    border-color: #fecaca;
    background: #fee2e2;
    color: #991b1b;
}

#modalControlFugas {
    z-index: 1085 !important;
    padding: 0 !important;
}

#modalControlFugas .control-fugas-modal-dialog {
    width: calc(100vw - 28px) !important;
    max-width: 1780px !important;
    height: calc(100dvh - 28px) !important;
    max-height: calc(100dvh - 28px) !important;
    margin: 14px auto !important;
}

#modalControlFugas .control-fugas-modal-content {
    height: 100% !important;
    min-height: 0 !important;
    overflow: hidden !important;
    border: 1px solid #8a5252 !important;
    border-radius: 15px !important;
    background: #f7eeee !important;
    box-shadow: 0 24px 70px rgba(39, 5, 5, .38) !important;
}

#modalControlFugas .control-fugas-modal-header {
    flex: 0 0 auto;
    min-height: 58px;
    padding: 9px 14px !important;
    border-bottom: 1px solid #5c0000 !important;
    background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
    color: #fff !important;
}

#modalControlFugas .control-fugas-modal-icon {
    width: 38px;
    height: 38px;
    flex: 0 0 38px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(255,255,255,.34);
    border-radius: 10px;
    background: rgba(255,255,255,.12);
    color: #fff;
    font-size: 19px;
}

#modalControlFugas .modal-title {
    margin: 0;
    color: #fff !important;
    font-size: 15px !important;
    font-weight: 900 !important;
}

.control-fugas-modal-subtitle {
    max-width: min(720px, 72vw);
    margin-top: 2px;
    overflow: hidden;
    color: rgba(255,255,255,.82);
    font-size: 10px;
    text-overflow: ellipsis;
    white-space: nowrap;
}

#modalControlFugas .control-fugas-modal-body {
    flex: 1 1 auto !important;
    min-height: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
    background: #f5eeee !important;
}

#modalControlFugas .control-fugas-panel {
    width: 100%;
    height: 100%;
    min-height: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 0;
    border-radius: 0;
    box-shadow: none;
}

#modalControlFugas .control-fugas-head,
#modalControlFugas .control-fugas-grid {
    flex: 0 0 auto;
}

#modalControlFugas .control-fugas-detail {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

#modalControlFugas .control-fugas-detail-head,
#modalControlFugas .control-fugas-note {
    flex: 0 0 auto;
}

#modalControlFugas .control-fugas-table-wrap {
    flex: 1 1 auto;
    min-height: 180px;
    max-height: none;
    overflow: auto;
}

#modalControlFugas .control-fugas-table th {
    top: 0;
    z-index: 4;
}

@@media (max-width: 768px) {
    #modalControlFugas .control-fugas-modal-dialog {
        width: 100vw !important;
        max-width: 100vw !important;
        height: 100dvh !important;
        max-height: 100dvh !important;
        margin: 0 !important;
    }

    #modalControlFugas .control-fugas-modal-content {
        border: 0 !important;
        border-radius: 0 !important;
    }

    #modalControlFugas .control-fugas-modal-header {
        min-height: 54px;
        padding: 7px 10px !important;
    }

    #modalControlFugas .control-fugas-modal-subtitle {
        display: none;
    }

    #modalControlFugas .control-fugas-modal-body {
        overflow-y: auto !important;
    }

    #modalControlFugas .control-fugas-panel {
        height: auto;
        min-height: 100%;
        overflow: visible;
    }

    #modalControlFugas .control-fugas-detail {
        overflow: visible;
    }

    #modalControlFugas .control-fugas-table-wrap {
        min-height: 330px;
        max-height: 52dvh;
    }
}

