        async function ejecutarCanibalizacion(btnElement) {
            const idDestino = $('#canibalTargetId').val();
            const idDonante = $('#canibalDonador').val();
            const piezas = $('#canibalPiezas').val().trim();

            if (!idDonante || !piezas) {
                alert("Selecciona el equipo donador y escribe qué piezas vas a extraer.");
                return;
            }

            const originalText = btnElement.innerHTML;
            try {
                btnElement.disabled = true;
                btnElement.innerHTML = "Guardando...";

                const url = `@Url.Action("ExtraerPiezas", "InventariosSistemas")?idDestino=${idDestino}&idDonante=${idDonante}&piezas=${encodeURIComponent(piezas)}`;
                const res = await fetch(url, { method: 'POST' });
                const data = await res.json();

                if(data.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('modalCanibalizar')).hide();
                    cargarInventario();
                    alert("Las piezas han sido registradas en la bitácora de ambos equipos.");
                } else {
                    alert("Error: " + data.mensaje);
                }
            } catch(e) { alert("Error: " + e.message); }
            finally {
                btnElement.disabled = false;
                btnElement.innerHTML = originalText;
            }
        }

