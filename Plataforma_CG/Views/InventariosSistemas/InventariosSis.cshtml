    }
}

/* Móvil. */
@@media (max-width: 640px) {
    #inventarioSistemasApp .kpi-container {
        grid-template-columns: 1fr !important;
    }

    #inventarioSistemasApp .top-banner > .d-flex {
        flex-direction: column !important;
        gap: 10px !important;
    }

    #inventarioSistemasApp .top-banner > .d-flex > .d-flex {
        width: 100% !important;
        justify-content: stretch !important;
    }

    #inventarioSistemasApp .top-banner .btn {
        flex: 1 1 0 !important;
        width: auto !important;
    }

    #inventarioSistemasApp .nav-tabs {
        flex-wrap: nowrap !important;
