                            <tr>
                                <td class="ps-4 fw-bold">
                                    <span style="color: #0d6efd; font-size: 1.2rem; vertical-align: middle;" class="me-2">●</span>C (Medio)
                                </td>
                                <td>Ventas, Contabilidad</td>
                                <td class="py-3 text-muted">
                                    <div class="mb-1">i5 / Ryzen 5</div><div class="mb-1">8-16 GB RAM</div><div class="mb-1">512 GB SSD</div><div>Gráficos integrados</div>
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4 fw-bold">
                                    <span style="color: #fd7e14; font-size: 1.2rem; vertical-align: middle;" class="me-2">●</span>B (Alto)
                                </td>
                                <td>TI, Programadores</td>
                                <td class="py-3 text-muted">
                                    <div class="mb-1">i7 / Ryzen 7</div><div class="mb-1">16-32 GB RAM</div><div class="mb-1">512 GB-1TB SSD</div><div>Gráficos integrados o ligeros</div>
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4 fw-bold">
                                    <span style="color: #e83e8c; font-size: 1.2rem; vertical-align: middle;" class="me-2">●</span>A (Premium)
                                </td>
                                <td>Diseño, Gerencia, Directivos</td>
                                <td class="py-3 text-muted">
                                    <div class="mb-1">i7 / Ryzen 7-9</div><div class="mb-1">16-32 GB RAM</div><div class="mb-1">1 TB SSD</div><div>GPU dedicada (en diseño)</div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer border-0 bg-light">
                <button type="button" class="btn btn-sm btn-secondary fw-bold px-4" data-bs-dismiss="modal">Entendido</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.0.0/dist/signature_pad.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        let datosInventario = [];
        let movimientosInventario = [];
        let consultarModal, historialModal, infoResponsableModal, camaraModal, visorHistorialModal, reportesModal, bajaModal;
        let signaturePad;
        let streamActual = null;
        let fotoCapturadaBase64 = null;
        let idArticuloEditando = 0;
        let usuariosCoincidentesBaja = [];
                let permisosInventario = { puedeLeer: false, puedeEscribir: false, puedeEliminar: false };

        $(document).ready(async function () {
            await cargarPermisosInventario();
            // ... el resto del código existente ...
        });

        async function cargarPermisosInventario() {
            try {
                const res = await fetch('@Url.Action("ObtenerPermisosVistaInventarioSistemas", "InventariosSistemas")');
                if (res.ok) {
                    permisosInventario = await res.json();
                    aplicarPermisosInventario();
                }
            } catch (e) {
                console.error("Error permisos:", e);
            }
        }

                function aplicarPermisosInventario() {
            if (!permisosInventario.puedeEscribir) {
                document.querySelectorAll(
                    '#movimientos > .row > .col-lg-5:first-child, ' +
                    '#asignaciones > .row > .col-lg-4:first-child, ' +
                    '#recuperaciones > .row > .col-lg-4:first-child, ' +
                    '#taller > .row > .col-lg-4:first-child'
                ).forEach(el => el.style.display = 'none');
            }
        }



        $(document).ready(function () {
            consultarModal = new bootstrap.Modal(document.getElementById('modalConsultar'));
            historialModal = new bootstrap.Modal(document.getElementById('modalHistorial'));
            infoResponsableModal = new bootstrap.Modal(document.getElementById('modalInfoResponsable'));
            camaraModal = new bootstrap.Modal(document.getElementById('modalCamara'));
            visorHistorialModal = new bootstrap.Modal(document.getElementById('modalVisorHistorial'));
            reportesModal = new bootstrap.Modal(document.getElementById('modalReportesQR'));
            bajaModal = new bootstrap.Modal(document.getElementById('modalBaja'));
            // Evento para autocompletar destino de chatarra
        $('input[name="optChatarraDestino"]').on('change', actualizarDestinoChatarra);

            // Buscadores normales
            $('#salArticulo, #resArticulo, #asigArticulo, #selectUsuarioBaja, #tallerArticulo').select2({
                theme: 'bootstrap-5',
                width: '100%',
                language: { noResults: function() { return "No se encontró coincidencia"; } }
            });

            // Buscador que vive ADENTRO del modal de canibalizar
            $('#canibalDonador').select2({
                theme: 'bootstrap-5',
                width: '100%',
                dropdownParent: $('#modalCanibalizar'),
                language: { noResults: function() { return "No se encontró coincidencia"; } }
            });

            cargarInventario();

            $('#salArticulo').on('change', function() {
                const id = parseInt($(this).val());
                if(id) {
                    const item = datosInventario.find(i => i.id === id);
                    $('#lblStockSalida').text(item.stock);
                    $('#stockInfoSalida').slideDown(200);
                } else { $('#stockInfoSalida').slideUp(200); }
            });

            $('#resArticulo').on('change', function() {
                const id = parseInt($(this).val());
                if(id) {
                    const item = datosInventario.find(i => i.id === id);
                    $('#lblStockRestock').text(item.stock);
                    $('#stockInfoRestock').slideDown(200);
                } else { $('#stockInfoRestock').slideUp(200); }
            });

            $('#asigArticulo').on('change', function() {
                const id = parseInt($(this).val());
                limpiarFirma();
                fotoCapturadaBase64 = null;
                $('#previewFoto').hide().attr('src', '');

                if(!id) {
                    $('#asigUsuario, #asigPlanta, #asigUbicacion, #asigFotoFile, #asigDocFile').val('');
                    return;
                }
                const item = datosInventario.find(i => i.id === id);
                $('#asigUsuario').val(item.asignacion || '');
                $('#asigPlanta').val(item.planta || '');
                $('#asigUbicacion').val(item.ubicacion || '');
                $('#asigFotoFile, #asigDocFile').val('');
            });

            $('#asigFotoFile').on('change', function() {
                fotoCapturadaBase64 = null;
                $('#previewFoto').hide().attr('src', '');
            });

            $('#selectUsuarioBaja').on('change', function() {
                const usuario = $(this).val();
                if(!usuario) {
                    $('#listaEquiposBaja').hide();
                    $('#btnMarcarBaja').prop('disabled', true);
                    return;
                }

                let equipos = datosInventario.filter(i => i.asignacion === usuario && !i.enRecuperacion);
                let html = '';
                equipos.forEach(e => {
                    html += `<li class="list-group-item py-1"><i class="bi bi-pc-display me-2"></i>${e.idArticuloSap} - ${e.nombre}</li>`;
                });

                $('#ulEquiposBaja').html(html);
                $('#listaEquiposBaja').show();
                $('#btnMarcarBaja').prop('disabled', false);
            });

            $('#modalCamara').on('hidden.bs.modal', function () {
                cerrarCamaraTracks();
            });

            const canvas = document.getElementById('firmaCanvas');
            function resizeCanvas() {
                const ratio =  Math.max(window.devicePixelRatio || 1, 1);
                if (canvas.offsetWidth > 0) {
                    canvas.width = canvas.offsetWidth * ratio;
                    canvas.height = canvas.offsetHeight * ratio;
                    canvas.getContext("2d").scale(ratio, ratio);
                    if(signaturePad) signaturePad.clear();
                }
            }

            signaturePad = new SignaturePad(canvas, { penColor: "rgb(74, 14, 14)" });

            $('button[data-bs-target="#asignaciones"]').on('shown.bs.tab', function (e) {
                resizeCanvas();
            });
            window.addEventListener("resize", resizeCanvas);
        });

        async function abrirCamara() {
            try {
                streamActual = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' } });
                const video = document.getElementById('videoCamara');
                video.srcObject = streamActual;
                camaraModal.show();
            } catch (err) {
                alert("No se pudo acceder a la cámara. Asegúrate de dar permisos en tu navegador.");
                console.error(err);
            }
        }

        function cerrarCamaraTracks() {
            if (streamActual) {
                streamActual.getTracks().forEach(track => track.stop());
                streamActual = null;
            }
        }

        function capturarFoto() {
            const video = document.getElementById('videoCamara');
            const canvas = document.getElementById('canvasCamara');
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);
            fotoCapturadaBase64 = canvas.toDataURL('image/jpeg');
            $('#previewFoto').attr('src', fotoCapturadaBase64).show();
            $('#asigFotoFile').val('');
            cerrarCamaraTracks();
            camaraModal.hide();
        }

        function limpiarFirma() {
            if(signaturePad) signaturePad.clear();
        }

        const getBase64 = (file) => new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => resolve(reader.result);
            reader.onerror = error => reject(error);
        });

        async function cargarInventario() {
            try {
                const response = await fetch('@Url.Action("GetInventario", "InventariosSistemas")');
                if (!response.ok) throw new Error("Error de red o servidor.");
                const data = await response.json();
                if (data.ok) {
                    datosInventario = data.inventario || [];
                    movimientosInventario = data.movimientos || [];

                    aplicarFiltros();
                    llenarSelects();
                    llenarSelectBaja();
                    renderMovimientos(movimientosInventario);
                    renderTablaAsignaciones();
                    generarAlertasDashboard();
                    renderTablaRecuperaciones();
                    llenarSelectTaller();
                    renderTablaTaller();
                }
            } catch (error) { console.error("Error cargando inventario: ", error); }
        }
        function aplicarFiltros() {
             const texto = $('#filtroGeneral').val().toLowerCase();
             const tipo = $('#filtroTipo').val();
             const planta = $('#filtroPlanta').val();
             const estado = $('#filtroEstado').val();

             let filtrado = datosInventario.filter(i => {
                 const matchTexto = !texto || (i.idArticuloSap && i.idArticuloSap.toLowerCase().includes(texto)) || (i.nombre && i.nombre.toLowerCase().includes(texto)) || (i.numeroSerie && i.numeroSerie.toLowerCase().includes(texto));
                 const matchPlanta = !planta || i.planta === planta;

                 // Lógica centralizada para identificar qué es chatarra/baja
                 const esBaja = i.asignacion === 'BAJA DEFINITIVA' || i.asignacion === 'PARA PIEZAS' || i.tipoArticulo === 'Chatarra/Piezas';
                 const esAsignado = !esBaja && i.asignacion && i.asignacion.trim() !== '';
                 const estaDisponible = !esBaja && (!i.asignacion || i.asignacion.trim() === '');

                 let matchTipo = true;
                 if (tipo === 'Chatarra/Piezas') {
                     // Si el filtro de tipo es Chatarra, mostramos todo lo que se considere baja
                     matchTipo = esBaja;
                 } else if (tipo !== '') {
                     // Si el filtro de tipo es otro, tiene que coincidir exactamente y NO debe ser baja
                     matchTipo = i.tipoArticulo === tipo && !esBaja;
                 }

                 let matchEstado = true;
                 // Si el artículo es chatarra/baja, ignoramos el filtro de estado (porque ni están asignados ni disponibles)
                 if (esBaja && estado !== '') {
                    matchEstado = false;
                 } else {
                     if (estado === 'asignado') matchEstado = esAsignado;
                     else if (estado === 'disponible') matchEstado = estaDisponible;
                 }

                 return matchTexto && matchTipo && matchPlanta && matchEstado;
             });
             renderTabla(filtrado);
         }

        function limpiarFiltros() { $('#filtroGeneral, #filtroTipo, #filtroPlanta, #filtroEstado').val(''); aplicarFiltros(); }

        function renderTabla(datos) {
            const hoy = new Date();
            let tbody = '';
            if(datos.length === 0) { $('#tbodyInventario').html('<tr><td colspan="6" class="text-center py-4">Sin datos</td></tr>'); return; }

            datos.forEach(item => {
                let fCompraStr = item.fechaCompra ? new Date(item.fechaCompra).toLocaleDateString('es-MX') : '-';
                let vidaStr = '<span class="text-muted">N/A</span>';
                let garantiaBadge = '-';

                let aniosVida = parseInt(item.tiempoVida) || 4;
                let fBaseVida = item.fechaCompra ? new Date(item.fechaCompra) : (item.fechaEntrada ? new Date(item.fechaEntrada) : null);

                if (fBaseVida) {
                    let fFinVida = new Date(fBaseVida.getTime());
                    fFinVida.setFullYear(fFinVida.getFullYear() + aniosVida);
                    vidaStr = `<span style="color:var(--brand-main); font-weight:bold;">Expira: ${fFinVida.toLocaleDateString('es-MX')}</span>`;
                }

                if (item.fechaCompra && item.diasGarantia) {
                    let finGarantia = new Date(item.fechaCompra);
                    finGarantia.setDate(finGarantia.getDate() + item.diasGarantia);
                    let dias = Math.ceil((finGarantia - hoy) / (1000 * 60 * 60 * 24));
                    garantiaBadge = dias < 0 ? `<span class="text-danger fw-bold">Vencida</span>` : `<span class="text-success">${dias} d. rest.</span>`;
                }

                let stockStr = `<div style="font-size:1.1rem; font-weight:bold;">${item.stock}</div>`;
                if(item.tipoArticulo === 'Consumible') {
                    stockStr += `<small class="text-muted">Mín: ${item.stockMinimo}</small>`;
                    if (item.stock <= item.stockMinimo) stockStr += `<br><span class="text-danger fw-bold" style="font-size:0.7rem;">¡Bajo!</span>`;
                } else {
                    stockStr += `<small class="text-muted">Fijo</small>`;
                }

                let btnBaja = (item.asignacion === 'BAJA DEFINITIVA' || item.asignacion === 'PARA PIEZAS')
                    ? `<button class="btn-sm-action text-muted" style="background:#eee; cursor:not-allowed;" disabled>Dado de Baja</button>`
                    : `<button class="btn-sm-action" onclick="darDeBajaArticulo(${item.id})">Dar Baja</button>`;

                let usuarioBadge = '';
                if (item.enRecuperacion) {
                    usuarioBadge = `<span class="badge bg-warning text-dark"><i class="bi bi-clock-history"></i> En Recuperación</span><br><small class="text-muted">${item.asignacion}</small>`;
                } else if (item.asignacion && item.asignacion.trim() !== '') {
                    usuarioBadge = `<b>${item.asignacion}</b>`;
                } else {
                    usuarioBadge = `<span class="badge bg-success px-2 py-1">Disponible</span>`;
                }

                let badgeClase = "bg-secondary";
                if (item.tipoArticulo === 'Activo Fijo') badgeClase = "bg-primary";
                else if (item.tipoArticulo === 'Consumible') badgeClase = "bg-success";
                else if (item.tipoArticulo === 'Herramienta') badgeClase = "bg-warning text-dark";

                tbody += `<tr>
                    <td>
                        <strong style="color:var(--brand-main); font-size:1rem;">${item.idArticuloSap}</strong><br>
                        <span class="fw-bold">${item.nombre}</span><br>
                        <span class="badge ${badgeClase} px-2 py-1 mt-1" style="font-size:0.65rem; font-weight:600;">${item.tipoArticulo || 'N/A'}</span>
                    </td>
                    <td><span class="text-muted">Usuario:</span> ${usuarioBadge}<br><span class="text-muted" style="font-family:monospace;">Serie: ${item.numeroSerie || '-'}</span></td>
                    <td><strong>${item.planta || 'N/A'}</strong><br><small class="text-muted">${item.ubicacion || ''}</small></td>
                    <td><small class="text-muted">Compra:</small> ${fCompraStr}<br>${vidaStr}</td>
                    <td class="text-center">${stockStr}<br><small class="text-muted">Gar:</small> <small>${garantiaBadge}</small></td>
                    <td class="text-center text-nowrap">
                        <button class="btn-sm-action" onclick="consultarArticulo(${item.id})">Detalles</button>
                        <button class="btn-sm-action" onclick="imprimirQR(${item.id})">Imprimir</button>
                        ${btnBaja}
                    </td>
                </tr>`;
            });
            $('#tbodyInventario').html(tbody);
        }

        function llenarSelects() {
            let optionsTodos = '<option value="">Selecciona un artículo...</option>';
            let optionsRestock = '<option value="">Selecciona un artículo...</option>';
            let optionsAsignables = '<option value="">Selecciona un artículo...</option>';

            let filtroPanel = $('#filtroSelectAsignar').val() || 'todos';
            let filtroRestock = $('#resFiltroTipo').val() || 'todos';

            datosInventario.forEach(i => {
                optionsTodos += `<option value="${i.id}">${i.idArticuloSap} - ${i.nombre}</option>`;

                if (i.asignacion !== 'BAJA DEFINITIVA' && i.asignacion !== 'PARA PIEZAS' && !i.enRecuperacion) {
                    let estaDisponible = !i.asignacion || i.asignacion.trim() === '';
                    let pasaFiltro = true;

                    if (filtroPanel === 'disponibles' && !estaDisponible) pasaFiltro = false;
                    if (filtroPanel === 'asignados' && estaDisponible) pasaFiltro = false;

                    if (pasaFiltro) {
                        optionsAsignables += `<option value="${i.id}">${i.idArticuloSap} - ${i.nombre}</option>`;
                    }

                    let pasaFiltroRestock = true;
                    if (filtroRestock !== 'todos' && i.tipoArticulo !== filtroRestock) pasaFiltroRestock = false;

                    if (pasaFiltroRestock) {
                        optionsRestock += `<option value="${i.id}">${i.idArticuloSap} - ${i.nombre}</option>`;
                    }
                }
            });

            $('#salArticulo').html(optionsTodos).trigger('change');
            $('#resArticulo').html(optionsRestock).trigger('change');
            $('#asigArticulo').html(optionsAsignables).trigger('change');
        }

        function llenarSelectBaja() {
            let usuariosConEquipo = [...new Set(datosInventario
                .filter(i => i.asignacion && i.asignacion.trim() !== '' && i.asignacion !== 'BAJA DEFINITIVA' && i.asignacion !== 'PARA PIEZAS' && !i.enRecuperacion)
                .map(i => i.asignacion))];

            let options = '<option value="">Selecciona usuario...</option>';
            usuariosConEquipo.sort().forEach(u => {
                options += `<option value="${u}">${u}</option>`;
            });
            $('#selectUsuarioBaja').html(options).trigger('change');
        }

        function renderTablaRecuperaciones() {
            let pendientes = datosInventario.filter(i => i.enRecuperacion);
            let tbody = '';

            if(pendientes.length === 0) {
                $('#tbodyRecuperaciones').html('<tr><td colspan="4" class="text-center py-4 text-muted">No hay equipos pendientes</td></tr>');
                return;
            }

            pendientes.forEach(i => {
                tbody += `
                <tr>
                    <td><strong class="text-danger">${i.idArticuloSap}</strong><br><small>${i.nombre}</small></td>
                    <td><span class="badge bg-light text-dark border">${i.asignacion}</span></td>
                    <td><span class="badge bg-warning text-dark"><i class="bi bi-clock-history me-1"></i> En Recuperación</span></td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-success fw-bold" onclick="marcarComoRecibido(${i.id})">
                            <i class="bi bi-check-lg"></i> Recibido
                        </button>
                    </td>
                </tr>`;
            });
            $('#tbodyRecuperaciones').html(tbody);
        }

        async function confirmarBajaUsuario() {
            const usuario = $('#selectUsuarioBaja').val();
            if(confirm(`¿Confirmas la baja de ${usuario}? Todos sus equipos pasarán a estatus 'En Recuperación'.`)) {
                try {
                    const res = await fetch(`@Url.Action("MarcarBajaUsuario", "InventariosSistemas")?usuario=${encodeURIComponent(usuario)}`, { method: 'POST' });
                    const data = await res.json();
                    if(data.ok) {
                        cargarInventario();
                        $('#listaEquiposBaja').hide();
                    } else {
                        alert("Error: " + data.mensaje);
                    }
                } catch(e) { alert("Error de red: " + e.message); }
            }
        }

        async function marcarComoRecibido(id) {
            if(confirm("¿Confirmas que has recibido el equipo físicamente? Se marcará como Disponible.")) {
                try {
                    const res = await fetch(`@Url.Action("FinalizarRecuperacion", "InventariosSistemas")?id=${id}`, { method: 'POST' });
                    const data = await res.json();
                    if(data.ok) {
                        cargarInventario();
                    } else {
                        alert("Error: " + data.mensaje);
                    }
                } catch(e) { alert("Error de red: " + e.message); }
            }
        }

        function procesarExcelBajas(event) {
            const file = event.target.files[0];
            if (!file) return;

            $('#resultadoExcelBajas').html('<span class="spinner-border spinner-border-sm text-danger"></span> Leyendo archivo...').show();
            $('#btnProcesarMasivo').hide();

            const reader = new FileReader();
            reader.onload = function (e) {
                try {
                    const data = new Uint8Array(e.target.result);
                    const workbook = XLSX.read(data, { type: 'array' });
                    const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
                    const json = XLSX.utils.sheet_to_json(firstSheet, { header: 1 });

                    let nombresExcel = json.map(row => Object.values(row)[0])
                                           .filter(n => n && typeof n === 'string')
                                           .map(n => n.trim().toLowerCase());

                    let usuariosConEquipo = [...new Set(datosInventario
                        .filter(i => i.asignacion && i.asignacion !== 'BAJA DEFINITIVA' && i.asignacion !== 'PARA PIEZAS' && !i.enRecuperacion)
                        .map(i => i.asignacion))];

                    usuariosCoincidentesBaja = usuariosConEquipo.filter(u =>
                        nombresExcel.includes(u.trim().toLowerCase())
                    );

                    if (usuariosCoincidentesBaja.length > 0) {
                        let html = `<strong class="text-danger">¡Atención!</strong> Se encontraron <b>${usuariosCoincidentesBaja.length}</b> ex-empleados con equipo pendiente:<br><ul class="mb-0 mt-1 ps-3">`;
                        usuariosCoincidentesBaja.forEach(u => html += `<li>${u}</li>`);
                        html += `</ul>`;
                        $('#resultadoExcelBajas').html(html);
                        $('#btnProcesarMasivo').show();
                    } else {
                        $('#resultadoExcelBajas').html('<strong class="text-success">Todo limpio.</strong> Ninguno de los empleados en el Excel tiene equipo asignado actualmente.');
                    }
                } catch (error) {
                    $('#resultadoExcelBajas').html('<strong class="text-danger">Error:</strong> No se pudo leer el Excel. Verifica el formato.');
                }
            };
            reader.readAsArrayBuffer(file);
        }

        async function ejecutarBajaMasiva() {
            if(!confirm(`¿Estás seguro de poner en estatus 'En Recuperación' los equipos de estos ${usuariosCoincidentesBaja.length} usuarios?`)) return;

            const btn = document.getElementById('btnProcesarMasivo');
            btn.disabled = true;
            btn.innerHTML = "Procesando...";

            try {
                const res = await fetch('@Url.Action("BajaMasivaUsuarios", "InventariosSistemas")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(usuariosCoincidentesBaja)
                });

                const data = await res.json();
                if (data.ok) {
                    alert(`✅ Se pasaron ${data.equiposAfectados} equipos a estatus de recuperación.`);
                    $('#excelBajas').val('');
                    $('#resultadoExcelBajas').hide();
                    $('#btnProcesarMasivo').hide();
                    usuariosCoincidentesBaja = [];
                    cargarInventario();
                } else {
