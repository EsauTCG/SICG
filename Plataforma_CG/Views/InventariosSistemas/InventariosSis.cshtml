/* =========================================================
   AJUSTE DEFINITIVO: VISTA GENERAL A PANTALLA COMPLETA
   + MODAL MAPA TI REALMENTE FULLSCREEN
   ========================================================= */

/* La pantalla general utiliza todo el espacio disponible del layout. */
html,
body {
    width: 100% !important;
    min-width: 0 !important;
    max-width: none !important;
}

body:has(#inventarioSistemasApp) {
    overflow-x: hidden !important;
    background: #e9edf2 !important;
}

body:has(#inventarioSistemasApp) main,
body:has(#inventarioSistemasApp) .main,
body:has(#inventarioSistemasApp) .body-content,
body:has(#inventarioSistemasApp) .content-wrapper,
body:has(#inventarioSistemasApp) .container,
body:has(#inventarioSistemasApp) .container-fluid {
    width: 100% !important;
    max-width: none !important;
    min-width: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
}

#inventarioSistemasApp {
    width: 100% !important;
    max-width: none !important;
    min-width: 0 !important;
    min-height: calc(100dvh - 72px) !important;
    margin: 0 !important;
    padding:
        clamp(6px, .75vw, 12px)
        clamp(6px, 1vw, 16px)
        14px !important;
    overflow-x: hidden !important;
}

/* Se eliminan límites artificiales de ancho en paneles y pestañas. */
#inventarioSistemasApp > *,
#inventarioSistemasApp .tab-content,
#inventarioSistemasApp .tab-pane,
#inventarioSistemasApp .dashboard-panel,
#inventarioSistemasApp .top-banner {
    width: 100% !important;
    max-width: none !important;
    min-width: 0 !important;
}

#inventarioSistemasApp .top-banner {
    margin-bottom: clamp(8px, 1vw, 14px) !important;
    padding: clamp(12px, 1.4vw, 22px) !important;
}

#inventarioSistemasApp .nav-tabs {
    width: 100% !important;
    max-width: 100% !important;
    margin-bottom: 10px !important;
}

#inventarioSistemasApp .row {
    min-width: 0 !important;
}

/* Tablas fluidas: scroll solo dentro del bloque, nunca en toda la página. */
#inventarioSistemasApp .table-responsive {
    width: 100% !important;
    max-width: 100% !important;
    overflow-x: auto !important;
    -webkit-overflow-scrolling: touch;
}

/* KPIs adaptables a cualquier resolución. */
#inventarioSistemasApp .kpi-container {
    display: grid !important;
    grid-template-columns: repeat(4, minmax(150px, 1fr)) !important;
    gap: clamp(8px, 1vw, 14px) !important;
}

#inventarioSistemasApp .kpi-box {
    width: auto !important;
    min-width: 0 !important;
}

/* ---------------------------------------------------------
   MODAL FULLSCREEN REAL
   No depende del tamaño de .container ni del layout padre.
   --------------------------------------------------------- */
#modalMapaTI {
    position: fixed !important;
    inset: 0 !important;
    z-index: 2147483000 !important;
    width: 100vw !important;
    max-width: 100vw !important;
    height: var(--mapa-ti-modal-height, 100dvh) !important;
    max-height: var(--mapa-ti-modal-height, 100dvh) !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
    background: #061019 !important;
}

#modalMapaTI.show {
    display: block !important;
}

/*
 * IMPORTANTE:
 * El z-index elevado se aplica únicamente al backdrop del Mapa TI.
 * Los demás modales conservan el orden normal de Bootstrap.
 */
.modal-backdrop.show {
    z-index: 1050 !important;
}

.modal.show:not(#modalMapaTI) {
    z-index: 1055 !important;
}

.modal-backdrop.mapa-ti-backdrop {
    z-index: 2147482990 !important;
}

#modalMapaTI .modal-dialog,
#modalMapaTI .modal-dialog.modal-fullscreen {
    position: absolute !important;
    inset: 0 !important;
    width: 100vw !important;
    max-width: 100vw !important;
    height: var(--mapa-ti-modal-height, 100dvh) !important;
    max-height: var(--mapa-ti-modal-height, 100dvh) !important;
    min-height: var(--mapa-ti-modal-height, 100dvh) !important;
    margin: 0 !important;
    padding: 0 !important;
    transform: none !important;
}

#modalMapaTI .modal-content {
    position: absolute !important;
    inset: 0 !important;
    display: flex !important;
    flex-direction: column !important;
    width: 100vw !important;
    max-width: 100vw !important;
    height: var(--mapa-ti-modal-height, 100dvh) !important;
    max-height: var(--mapa-ti-modal-height, 100dvh) !important;
    min-height: var(--mapa-ti-modal-height, 100dvh) !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
    border: 0 !important;
    border-radius: 0 !important;
    background: #061019 !important;
}

#modalMapaTI .mapa-ti-modal-header {
    flex: 0 0 58px !important;
    width: 100% !important;
    min-height: 58px !important;
    max-height: 58px !important;
    margin: 0 !important;
}

#modalMapaTI .modal-body {
    flex: 1 1 auto !important;
    width: 100% !important;
    height: auto !important;
    min-height: 0 !important;
    max-height: none !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
}

#modalMapaTI #mapaTiShell {
    width: 100% !important;
    max-width: none !important;
    height: 100% !important;
    min-height: 0 !important;
    max-height: none !important;
    margin: 0 !important;
}

/* Los paneles y el lienzo aprovechan la altura completa del modal. */
#modalMapaTI #mapaTiShell .mapa-ti-sidebar,
#modalMapaTI #mapaTiShell .mapa-ti-center,
#modalMapaTI #mapaTiShell .mapa-ti-inspector {
    height: 100% !important;
    min-height: 0 !important;
    max-height: none !important;
}

#modalMapaTI #mapaTiShell .mapa-ti-viewport {
    height: auto !important;
    min-height: 0 !important;
}

#modalMapaTI #mapaTiShell .mapa-ti-canvas {
    height: 100% !important;
    min-height: 0 !important;
}

/* Laptop y monitor mediano. */
@@media (max-width: 1200px) {
    #inventarioSistemasApp .kpi-container {
        grid-template-columns: repeat(2, minmax(140px, 1fr)) !important;
    }

    #modalMapaTI #mapaTiShell {
        grid-template-columns:
            clamp(180px, 17vw, 225px)
            minmax(0, 1fr)
            clamp(210px, 20vw, 265px) !important;
    }
}

/* Tablet. */
@@media (max-width: 900px) {
    #inventarioSistemasApp {
        padding: 6px !important;
    }

    #inventarioSistemasApp .top-banner .d-flex {
        align-items: flex-start !important;
    }

    #modalMapaTI .mapa-ti-modal-header {
        flex-basis: 54px !important;
        min-height: 54px !important;
