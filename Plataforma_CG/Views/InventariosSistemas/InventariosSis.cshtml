        function generarIdChatarra() {
            const destino = $('input[name="optChatarraDestino"]:checked').val();
            const prefijo = destino === 'PARA PIEZAS' ? 'PZ-' : 'CH-';

            // Bloqueamos el campo para que el usuario no lo edite 
            $('#entSap').prop('readonly', true).addClass('bg-light text-primary fw-bold');

            // Si estamos en modo "Editar", respetamos el ID que ya tiene 
            if (idArticuloEditando > 0) return;

            let maxNum = 0;

            // Recorremos el inventario buscando el número más alto con ese prefijo
            datosInventario.forEach(i => {
                if (i.idArticuloSap && i.idArticuloSap.startsWith(prefijo)) {
                    let numStr = i.idArticuloSap.substring(prefijo.length);
                    let num = parseInt(numStr);
                    if (!isNaN(num) && num > maxNum) {
                        maxNum = num;
                    }
                }
            });

            const idGenerado = prefijo + String(maxNum + 1).padStart(3, '0');
            $('#entSap').val(idGenerado);
        }
        function toggleCamposPorTipo() {
            const tipo = $('#entTipoArticulo').val();

            if (tipo === 'Chatarra/Piezas') {
                $('.campo-avanzado').hide();
                $('#divChatarraDestino').show();
                $('#divStockMinimo').hide();
                $('#divIP').hide();
                $('#entIP').val('');

                actualizarDestinoChatarra();
            } else {
                $('.campo-avanzado').show();
                $('#divChatarraDestino').hide();

                // Si veníamos de chatarra, liberamos el campo SAP y lo limpiamos
                if ($('#entSap').prop('readonly')) {
                    $('#entSap').prop('readonly', false).val('').removeClass('bg-light text-primary fw-bold');
                }

                if (tipo === 'Consumible') {
                    $('#divStockMinimo').show();
                    $('#divIP').hide();
                    $('#entIP').val('');
                }
                else if (tipo === 'Activo Fijo') {
                    $('#divStockMinimo').hide();
                    $('#divIP').show();
                }
                else {
                    $('#divStockMinimo').hide();
                    $('#divIP').hide();
                }
            }
        }

        function actualizarDestinoChatarra() {
            const destino = $('input[name="optChatarraDestino"]:checked').val();
            if (destino === 'PARA PIEZAS') {
                $('#entPlanta').val('BANCO DE PIEZAS');
                $('#entUbicacion').val('ALMACÉN DE PIEZAS');
