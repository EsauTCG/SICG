                <div class="col-12 col-md-4 mt-3"><small class="text-muted fw-bold d-block">COSTO</small><span>$${item.costo || 0}</span></div>
                <div class="col-12 col-md-4 mt-3"><small class="text-muted fw-bold d-block">STOCK ACTUAL</small><span>${item.stock} ${item.tipoArticulo === 'Consumible' ? '(Mín: ' + item.stockMinimo + ')' : ''}</span></div>
