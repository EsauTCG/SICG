        function generarAlertasDashboard() {
            let htmlStock = ''; let htmlGarantia = ''; let htmlVida = '';
            let conteoAlertas = 0; let asignados = 0; let disponibles = 0; let activos = 0;
            const hoy = new Date();
            const diasParaDesaparecer = 10;

            datosInventario.forEach(i => {
                const esBajaOChatarra = i.asignacion === 'BAJA DEFINITIVA' || i.asignacion === 'PARA PIEZAS' || i.tipoArticulo === 'Chatarra/Piezas';
                if (esBajaOChatarra) {
                    return; 
                }
                if (i.asignacion === 'BAJA DEFINITIVA' || i.asignacion === 'PARA PIEZAS') {
                    // No sumamos a nadie
                } else if (i.asignacion && i.asignacion !== '') {
                    asignados++; activos++;
                } else {
                    disponibles++; activos++;
                }

                if(i.tipoArticulo === 'Consumible' && i.stock <= i.stockMinimo) {
                    conteoAlertas++;
                    htmlStock += `<div class="alerta-item alerta-critica"><strong class="text-danger">${i.idArticuloSap} - ${i.nombre}</strong><br><span class="text-muted">${i.ubicacion} | Stock: <b>${i.stock}</b> (Mín: ${i.stockMinimo})</span></div>`;
                }

                if(i.fechaCompra && i.diasGarantia) {
                    let finG = new Date(i.fechaCompra);
                    finG.setDate(finG.getDate() + i.diasGarantia);
                    let diasRestG = Math.ceil((finG - hoy) / (1000 * 60 * 60 * 24));

                    if (diasRestG < 0 && diasRestG >= -diasParaDesaparecer) {
                        conteoAlertas++;
                        let diasPasados = Math.abs(diasRestG);
                        htmlGarantia += `<div class="alerta-item alerta-critica"><strong style="color:#dc3545;">${i.idArticuloSap} - ${i.nombre}</strong><br><span class="text-muted">Vencida hace ${diasPasados} días</span></div>`;
                    }
                    else if (diasRestG >= 0 && diasRestG <= 30) {
                        conteoAlertas++;
                        htmlGarantia += `<div class="alerta-item" style="border-color: #ffc107;"><strong class="text-warning">${i.idArticuloSap} - ${i.nombre}</strong><br><span class="text-muted">Vence en ${diasRestG} días</span></div>`;
                    }
                }

                let aniosVida = parseInt(i.tiempoVida) || 4;
                let fBaseVida = i.fechaCompra ? new Date(i.fechaCompra) : (i.fechaEntrada ? new Date(i.fechaEntrada) : null);
                if(fBaseVida) {
                    let fFinVida = new Date(fBaseVida.getTime()); fFinVida.setFullYear(fFinVida.getFullYear() + aniosVida);
                    let diasRestV = Math.ceil((fFinVida - hoy) / (1000 * 60 * 60 * 24));
                    if (diasRestV < 0) {
                        conteoAlertas++;
                        htmlVida += `<div class="alerta-item alerta-critica"><strong class="text-danger">${i.idArticuloSap} - ${i.nombre}</strong><br><span class="text-muted">Vida útil Terminada</span></div>`;
                    } else if (diasRestV <= 60) {
                        conteoAlertas++;
                        htmlVida += `<div class="alerta-item" style="border-color: #adb5bd;"><strong class="text-secondary">${i.idArticuloSap} - ${i.nombre}</strong><br><span class="text-muted">Expira en ${diasRestV} días</span></div>`;
                    }
                }
            });

            $('#kpiTotal').text(activos);
            $('#kpiDisponibles').text(disponibles);
            $('#kpiAsignados').text(asignados);
            $('#kpiAlertas').text(conteoAlertas);

            if(conteoAlertas > 0) {
                $('#kpiAlertas').parent().addClass('kpi-peligro');
            } else {
                $('#kpiAlertas').parent().removeClass('kpi-peligro');
            }

            let htmlFinal = '';
            if(htmlStock) htmlFinal += `<div class="mb-3"><h6 class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Stock Crítico</h6>${htmlStock}</div>`;
            if(htmlGarantia) htmlFinal += `<div class="mb-3"><h6 class="fw-bold" style="color:#fd7e14;">Garantías / Fallos</h6>${htmlGarantia}</div>`;
            if(htmlVida) htmlFinal += `<div class="mb-3"><h6 class="text-secondary fw-bold">Vida Útil</h6>${htmlVida}</div>`;

            if(!htmlFinal) htmlFinal = '<div class="text-success text-center py-3"><br>Todo en orden</div>';
            $('#contenedorAlertasGlobales').html(htmlFinal);
        }

        function renderTablaAsignaciones() {
            let tbody = '';
            let textoFiltro = ($('#filtroAsignaciones').val() || '').toLowerCase();
            let estadoFiltro = $('#filtroEstadoAsignaciones').val();

            let datosFiltrados = datosInventario.filter(item => {
                if (item.asignacion === 'BAJA DEFINITIVA' || item.asignacion === 'PARA PIEZAS') return false;

                let tieneAsignacion = item.asignacion && item.asignacion.trim() !== '';
                let estaDisponible = !item.asignacion || item.asignacion.trim() === '';

                if (estadoFiltro === 'asignado' && !tieneAsignacion) return false;
                if (estadoFiltro === 'disponible' && !estaDisponible) return false;
                if (!textoFiltro) return true;

                let asignacion = (item.asignacion || 'Disponible').toLowerCase();
                let sap = (item.idArticuloSap || '').toLowerCase();
                let nombre = (item.nombre || '').toLowerCase();
                let serie = (item.numeroSerie || '').toLowerCase();

                return asignacion.includes(textoFiltro) || sap.includes(textoFiltro) || nombre.includes(textoFiltro) || serie.includes(textoFiltro);
            });

            datosFiltrados.forEach(item => {
                let badgeAsignacion = '';
                if (item.enRecuperacion) {
                    badgeAsignacion = `<span class="badge bg-warning text-dark px-2 py-1"><i class="bi bi-clock-history"></i> En Recuperación</span><br><small class="text-muted">${item.asignacion}</small>`;
                } else if (item.asignacion && item.asignacion.trim() !== '') {
                    badgeAsignacion = `<span class="badge bg-info text-dark px-2 py-1">${item.asignacion}</span>`;
                } else {
                    badgeAsignacion = `<span class="badge bg-success px-2 py-1">Disponible</span>`;
                }

                tbody += `<tr>
                    <td><strong style="color:var(--brand-main);">${item.idArticuloSap}</strong><br>${item.nombre}</td>
                    <td style="font-family:monospace;" class="text-muted">${item.numeroSerie || '-'}</td>
                    <td>${badgeAsignacion}<br><small class="text-muted">${item.planta} - ${item.ubicacion}</small></td>
                    <td class="text-center">
                        <div class="d-flex flex-wrap justify-content-center gap-1">
                            <button class="btn-sm-action m-0" onclick="verInfoResponsable(${item.id})">Expediente</button>
                            <button class="btn-sm-action m-0" onclick="verHistorialAsignacion(${item.id})">Historial</button>
                            <button class="btn-sm-action m-0" onclick="verReportesTecnicos(${item.id})">Reportes</button>
                        </div>
                    </td>
                </tr>`;
            });
            $('#tbodyAsignaciones').html(tbody || '<tr><td colspan="4" class="text-center py-4">No se encontraron resultados</td></tr>');
        }

        async function guardarAsignacionTab(btnElement) {
            const id = parseInt($('#asigArticulo').val());
            const nuevoUsuario = $('#asigUsuario').val().trim();
            const nuevaPlanta = $('#asigPlanta').val();
            const nuevaUbicacion = $('#asigUbicacion').val().trim();

            const fileFoto = document.getElementById('asigFotoFile').files[0];
            const fileDoc = document.getElementById('asigDocFile').files[0];

            if(!id) { alert("Por favor selecciona un equipo primero."); return; }
            if(!nuevaPlanta || !nuevaUbicacion) { alert("Es obligatorio especificar la Planta y la Ubicación del equipo."); return; }

            const originalText = btnElement.innerHTML;

            try {
                btnElement.disabled = true;
                btnElement.innerHTML = "Guardando...";

                const itemOriginal = datosInventario.find(i => i.id === id);
                const item = { ...itemOriginal };

                item.asignacion = nuevoUsuario;
                item.planta = nuevaPlanta;
                item.ubicacion = nuevaUbicacion;

                item.fotoUsuario = "";
                item.documentoComodato = "";
                item.firmaDigital = "";

                if (nuevoUsuario !== "") {
                    if (fotoCapturadaBase64) {
                        item.fotoUsuario = fotoCapturadaBase64;
                    } else if (fileFoto) {
                        item.fotoUsuario = await getBase64(fileFoto);
                    }

                    if (fileDoc) { item.documentoComodato = await getBase64(fileDoc); }

                    if (signaturePad && !signaturePad.isEmpty()) {
                        item.firmaDigital = signaturePad.toDataURL();
                    }
                }

                const res = await fetch('@Url.Action("GuardarArticulo", "InventariosSistemas")', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(item)
                });
                if (!res.ok) throw new Error("Fallo en el servidor al intentar guardar.");

                $('#asigArticulo').val('').trigger('change');
                $('#asigUsuario, #asigPlanta, #asigUbicacion').val('');
                $('#asigFotoFile, #asigDocFile').val('');
                fotoCapturadaBase64 = null;
                $('#previewFoto').hide().attr('src', '');
                limpiarFirma();

                cargarInventario();
                alert("Asignación o actualización guardada correctamente.");
            }
            catch(error) { alert("Error de guardado: " + error.message); }
            finally {
                btnElement.disabled = false;
                btnElement.innerHTML = originalText;
            }
        }

        async function verInfoResponsable(id) {
            try {
                $('#infoNombre').text('Cargando...');
                $('#infoNombre').removeClass('text-primary text-muted').addClass('text-primary');
                $('#infoLugar').text('');
                $('#infoFoto').attr('src', '');
                $('#infoDocumento').hide().attr('href', '#');
                $('#infoSinDocumento').hide();
                $('#infoFirmaContainer').hide();
                $('#infoFirma').attr('src', '');

                infoResponsableModal.show();

                const url = `@Url.Action("GetDetalleArticulo", "InventariosSistemas")?id=${id}`;
                const response = await fetch(url);
                if (!response.ok) throw new Error('No se pudo consultar el expediente.');

                const data = await response.json();
                if (!data.ok || !data.articulo) {
                    $('#infoNombre').text('Sin información');
                    $('#infoNombre').removeClass('text-primary').addClass('text-muted');
                    $('#infoSinDocumento').text(data.mensaje || 'No se encontró el expediente.').show();
                    return;
                }

                const item = data.articulo;
                if (!item.asignacion) {
                    $('#infoNombre').text('Equipo no asignado (Stock)');
                    $('#infoNombre').removeClass('text-primary').addClass('text-muted');
                } else {
                    $('#infoNombre').text(item.asignacion);
                    $('#infoNombre').removeClass('text-muted').addClass('text-primary');
                }

                $('#infoLugar').text(`${item.planta || ''} - ${item.ubicacion || ''}`);
                if (item.fotoUsuario) { $('#infoFoto').attr('src', item.fotoUsuario); }
                else { $('#infoFoto').attr('src', ''); }

                if (item.documentoComodato) {
                    $('#infoDocumento').attr('href', item.documentoComodato).show();
                    $('#infoSinDocumento').hide();
                } else {
                    $('#infoDocumento').hide();
                    $('#infoSinDocumento').text('Sin documento cargado.').show();
                }

                if (item.firmaDigital) {
                    $('#infoFirma').attr('src', item.firmaDigital);
                    $('#infoFirmaContainer').show();
                } else { $('#infoFirmaContainer').hide(); }

            } catch (error) {
                $('#infoNombre').text('Error al cargar');
                $('#infoNombre').removeClass('text-primary').addClass('text-muted');
                $('#infoDocumento, #infoFirmaContainer').hide();
                $('#infoSinDocumento').text(error.message || 'No se pudo cargar el expediente.').show();
            }
        }

        async function verHistorialAsignacion(id) {
            try {
                const item = datosInventario.find(i => i.id === id);
                $('#historialNombreEquipo').text(`${item.idArticuloSap} - ${item.nombre}`);
                $('#historialAsignacionesDiv').html('<div class="text-muted fst-italic py-3">Cargando historial...</div>');
                historialModal.show();

                const response = await fetch(`@Url.Action("GetHistorialArticulo", "InventariosSistemas")?id=${id}`);
                if (!response.ok) throw new Error('No se pudo consultar el historial.');

                const data = await response.json();
                if (!data.ok) {
                    $('#historialAsignacionesDiv').html(`<div class="text-danger fst-italic py-3">${data.mensaje || 'No se pudo cargar el historial.'}</div>`);
                    return;
                }

                const historial = (data.historial || []).filter(h => !h.nota || !h.nota.includes('REPORTE QR'));

                if (!historial.length) {
                    $('#historialAsignacionesDiv').html('<div class="text-muted fst-italic py-3">Este equipo no tiene historial de asignaciones previas.</div>');
                    return;
                }

                let html = '<ul class="list-unstyled mb-0" style="font-size: 0.85rem;">';
                historial.forEach(h => {
                    html += `<li class="border-bottom py-2">
                    <strong>${h.fechaHora || ''}</strong><br>
                    <span class="text-muted">${h.nota || ''}</span><br>
                    <div class="mt-2 d-flex flex-wrap gap-2">
                    ${h.tieneFoto ? `<button class="btn btn-sm btn-outline-secondary py-0" style="font-size:0.7rem;" onclick="mostrarArchivoHistorico(${h.id}, 'Foto')">Foto</button>` : ''}
                    ${h.tieneDocumento ? `<button class="btn btn-sm btn-outline-secondary py-0" style="font-size:0.7rem;" onclick="mostrarArchivoHistorico(${h.id}, 'Documento')">Doc</button>` : ''}
                    ${h.tieneFirma ? `<button class="btn btn-sm btn-outline-secondary py-0" style="font-size:0.7rem;" onclick="mostrarArchivoHistorico(${h.id}, 'Firma')">Firma</button>` : ''}
                    </div></li>`;
                });
                html += '</ul>';
                $('#historialAsignacionesDiv').html(html);
            } catch (error) {
                $('#historialAsignacionesDiv').html(`<div class="text-danger fst-italic py-3">${error.message || 'No se pudo cargar el historial.'}</div>`);
            }
        }

        async function mostrarArchivoHistorico(idHistorial, tipo) {
            try {
                $('#visorTitulo').text(tipo);
                $('#visorCuerpo').html('<div class="text-muted py-3">Cargando archivo...</div>');
                visorHistorialModal.show();

                const response = await fetch(`@Url.Action("GetDetalleHistorial", "InventariosSistemas")?id=${idHistorial}`);
                if (!response.ok) throw new Error('No se pudo consultar el archivo histórico.');

                const data = await response.json();
                if (!data.ok || !data.historial) {
                    $('#visorCuerpo').html(`<div class="text-danger py-3">${data.mensaje || 'No se encontró el archivo.'}</div>`);
                    return;
                }

                const h = data.historial;
                let contenido = '';

                if (tipo === 'Foto' && h.fotoBase64) {
                    contenido = `<img src="${h.fotoBase64}" class="img-fluid rounded border" />`;
                } else if (tipo === 'Firma' && h.firmaBase64) {
                    contenido = `<img src="${h.firmaBase64}" class="img-fluid rounded border" />`;
                } else if (tipo === 'Documento' && h.documentoBase64) {
                    if (h.documentoBase64.toLowerCase().includes('.pdf') || h.documentoBase64.toLowerCase().includes('application/pdf')) {
                        contenido = `<iframe src="${h.documentoBase64}" style="width:100%; height:70vh; border:none;"></iframe>
                                     <div class="mt-3"><a href="${h.documentoBase64}" target="_blank" class="btn btn-outline">Abrir documento</a></div>`;
                    } else {
                        contenido = `<img src="${h.documentoBase64}" class="img-fluid rounded border" />`;
                    }
                } else {
                    contenido = `<div class="text-muted py-3">No hay ${tipo.toLowerCase()} disponible.</div>`;
                }
                $('#visorCuerpo').html(contenido);
            } catch (error) {
                $('#visorCuerpo').html(`<div class="text-danger py-3">${error.message || 'No se pudo abrir el archivo.'}</div>`);
            }
        }

        function verReportesTecnicos(id) {
            const item = datosInventario.find(i => i.id === id);
            $('#reportesNombreEquipo').text(`${item.idArticuloSap} - ${item.nombre}`);
            let histHtml = '<ul class="list-unstyled mb-0" style="font-size: 0.85rem;">';
            let reportes = (item.registrosHistorial || []).filter(h => h.nota && h.nota.includes('REPORTE QR'));

            if(reportes.length > 0) {
                let invertido = [...reportes].reverse();
                invertido.forEach(h => {
                    let notaLimpia = h.nota.replace('REPORTE QR:', '').trim();
                    histHtml += `<li class="border-bottom py-2">
                        <strong>${h.fechaHora}</strong><br>
                        <span class="text-dark">${notaLimpia}</span><br>
                        <div class="mt-2">`;
                        if(h.fotoBase64) {
                            histHtml += `<button class="btn btn-sm btn-outline-danger py-0" style="font-size:0.7rem;" onclick="mostrarArchivoHistorico('Evidencia Fotográfica', '${h.fotoBase64}')"><i class="fas fa-camera"></i> Ver Foto</button>`;
                        }
                    histHtml += `</div></li>`;
                });
            } else {
                histHtml += '<li class="text-muted fst-italic py-3">No hay reportes de inspección para este equipo.</li>';
            }
            $('#listaReportesDiv').html(histHtml + '</ul>');
            reportesModal.show();
        }

