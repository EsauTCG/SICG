      window.openPaste  = openPaste;
      window.closePaste = closePaste;

        window.applyPaste = async function () {
        const text = document.getElementById('pasteArea').value || '';
        const lines = text.split(/\r?\n/).map(x => x.trim()).filter(Boolean);
        if(!lines.length){ showLog('warning', 'No hay líneas válidas.'); return; }
            const nuevasFilas = [];

            for (const line of lines) {
                const parts = line.split(/[\t,;]+/).map(x => x.trim()).filter(Boolean);
                const code = parts[0] || '';
                const qty = parts[1] ? parseInt(parts[1], 10) : 1;

                const tr = window.addRow(code, (isNaN(qty) || qty <= 0) ? 1 : qty);

                if (tr) nuevasFilas.push(tr);
            }

            closePaste();
            showLog('info', `Cargadas ${lines.length} líneas.`);
            setUiState('Lista cargada', 'text-bg-info');
            document.getElementById('pasteArea').value = '';

            await precargarEtiquetacionActual(nuevasFilas);

