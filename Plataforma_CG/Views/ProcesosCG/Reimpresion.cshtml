        async function loadPrinters() {
            const plant = getPlant();
            const sel = document.getElementById('PrinterName');

            sel.innerHTML = '<option value="">Cargando...</option>';

            enhanceSearchDropdown(sel, {
                placeholder: '(Seleccione)',
                searchPlaceholder: 'Buscar impresora...'
            });

            try {
                const res = await fetch(`${URL_PRINTERS}?source=${encodeURIComponent(plant)}`, {
                    method: 'GET',
                    credentials: 'include',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const r = await safeRead(res);

                if (r.isHtml) {
                    throw new Error('InstalledPrinters devolvió HTML');
                }

                if (!res.ok || !r.okParse || !r.data?.ok) {
                    throw new Error('No se pudo cargar impresoras. HTTP ' + res.status);
                }

                let printers = Array.isArray(r.data.printers) ? r.data.printers : [];

                printers = printers
                    .map(x => (x || '').toString())
                    .filter(Boolean);

                printers = getPrintersForPlant(printers, plant);

                if (!printers.length) {
                    sel.innerHTML = '<option value="">(sin impresoras)</option>';

                    enhanceSearchDropdown(sel, {
                        placeholder: '(sin impresoras)',
                        searchPlaceholder: 'Buscar impresora...'
                    });

                    showLog('warning', `No hay impresoras para ${plant}.`);
                    setUiState('Sin impresoras', 'text-bg-warning');
                    return;
                }

                sel.innerHTML = printers
                    .map(p => `<option value="${escapeHtml(p)}">${escapeHtml(p)}</option>`)
                    .join('');

                const saved = getSavedPrinter(plant);

                if (saved && printers.includes(saved)) {
                    sel.value = saved;
                } else if (DEFAULT_PRINTER && printers.includes(DEFAULT_PRINTER)) {
                    sel.value = DEFAULT_PRINTER;
                } else {
                    sel.value = printers[0];
                }

                enhanceSearchDropdown(sel, {
                    placeholder: '(Seleccione)',
                    searchPlaceholder: 'Buscar impresora...'
                });

                sel.onchange = () => {
                    savePrinter(plant, sel.value);
                };

            } catch (e) {
                sel.innerHTML = '<option value="">(error)</option>';

                enhanceSearchDropdown(sel, {
                    placeholder: '(error)',
                    searchPlaceholder: 'Buscar impresora...'
                });

                showLog('danger', 'Error impresoras: ' + (e?.message || e));
                setUiState('Error impresoras', 'text-bg-danger');
            }
        }

        function enhanceRowEtiSelect(sel) {
            if (!sel) return;

            enhanceSearchDropdown(sel, {
                placeholder: '(Seleccione)',
                searchPlaceholder: 'Buscar etiquetación...'
            });
        }

        async function loadEtiquetaciones() {
            const plant = getPlant();
            const sel = document.getElementById('ClaveReporte');

            sel.innerHTML = '<option value="">Cargando...</option>';

            enhanceSearchDropdown(sel, {
                placeholder: '(Cargando...)',
                searchPlaceholder: 'Buscar etiquetación...'
            });

            try {
                const res = await fetch(`${URL_ETI}?source=${encodeURIComponent(plant)}`, {
                    method: 'GET',
                    credentials: 'include',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const r = await safeRead(res);

                if (r.isHtml) {
                    throw new Error('Etiquetaciones devolvió HTML');
                }

                if (!res.ok || !r.okParse || !r.data?.ok) {
                    throw new Error('No se pudo cargar etiquetaciones. HTTP ' + res.status);
                }

                const rows = Array.isArray(r.data.rows) ? r.data.rows : [];

                if (!rows.length) {
                    sel.innerHTML = '<option value="">(sin datos)</option>';

                    enhanceSearchDropdown(sel, {
                        placeholder: '(sin datos)',
                        searchPlaceholder: 'Buscar etiquetación...'
                    });

                    showLog('warning', `No hay etiquetaciones para ${plant}.`);
                    setUiState('Sin etiquetaciones', 'text-bg-warning');
                    return;
                }

                ETI_LIST = rows.map(x => {
                    const idRaw = (x.ColectorId ?? x.colectorId ?? '').toString().trim();
                    const idNum = Number.parseInt(idRaw, 10);
                    const name = (x.Etiquetacion ?? x.etiquetacion ?? x.Nombre ?? x.nombre ?? '').toString();

                    return {
                        idRaw,
                        idNum: Number.isFinite(idNum) ? idNum : 999999,
                        name
                    };
                }).sort((a, b) => a.idNum - b.idNum);

                sel.innerHTML = ETI_LIST.map(x =>
                    `<option value="${escapeHtml(x.idRaw)}">${escapeHtml(x.name)}</option>`
                ).join('');

                if (DEFAULT_ETI && Array.from(sel.options).some(o => o.value === DEFAULT_ETI)) {
                    sel.value = DEFAULT_ETI;
                } else if (!sel.value && sel.options.length) {
                    sel.value = sel.options[0].value;
                }

                enhanceSearchDropdown(sel, {
                    placeholder: '(Seleccione)',
                    searchPlaceholder: 'Buscar etiquetación...'
                });

                document.querySelectorAll('#rows tr').forEach(tr => {
                    const s = tr.querySelector('.js-eti');
                    const current = s?.value || sel.value || DEFAULT_ETI;

                    setSelectOptionsPreserve(s, current, '');
                    enhanceRowEtiSelect(s);
                });

                sel.onchange = () => {
                    const v = sel.value || '';

                    if (!v) return;

                    if (!confirm('¿Aplicar esta Etiquetación a TODAS las filas?')) return;
                    document.querySelectorAll('#rows tr').forEach(tr => {
                        const s = tr.querySelector('.js-eti');

                        setSelectOptionsPreserve(s, v, '');
                        enhanceRowEtiSelect(s);
                    });
                };

            } catch (e) {
                sel.innerHTML = '<option value="">(error)</option>';

                enhanceSearchDropdown(sel, {
                    placeholder: '(error)',
                    searchPlaceholder: 'Buscar etiquetación...'
                });

                showLog('danger', 'Error etiquetaciones: ' + (e?.message || e));
                setUiState('Error etiquetaciones', 'text-bg-danger');
            }
        }

            document.addEventListener('blur', function (e) {
                if (!e.target.matches('.js-code')) return;

                const tr = e.target.closest('tr');

                if (!tr) return;

                const code = (e.target.value || '').trim();

                if (!code) return;

                precargarEtiquetacionActual([tr]);
            }, true);

      window.printAll = async function(){
        const btn  = document.getElementById('btnPrint');
        const btn2 = document.getElementById('btnPrint2');
        if(btn)  btn.disabled  = true;
        if(btn2) btn2.disabled = true;
        try{
          const cfg = getConfig();
          if(!cfg.printerName){ showLog('warning', 'Selecciona impresora.'); setUiState('Falta impresora', 'text-bg-warning'); return; }
          const items = collectItems();
          if(!items.length){ showLog('warning', 'Agrega al menos una etiqueta.'); setUiState('Sin filas', 'text-bg-warning'); return; }
          const valid = items.filter(it => (it.code||'').trim() && (it.qty||0) > 0 && (it.eti||'').trim());
          if(!valid.length){ showLog('warning', 'No hay filas válidas para imprimir.'); setUiState('Sin filas válidas', 'text-bg-warning'); return; }
          savePrinter(cfg.plant, cfg.printerName);
          const baseReq = { source: cfg.plant, empresaEysId: cfg.empresaEysId || 'CARNG', tipoImpresion: 3, printerName: cfg.printerName };
          const first = valid[0];
          setUiState(`Imprimiendo prueba (${cfg.plant})...`, 'text-bg-info');
          showLog('info', `Imprimiendo 1 etiqueta de prueba:\n${first.code}`);
          for(const it of items) setRowStatus(it.tr, null, 'Pendiente');
          const testReq = { ...baseReq, items: [{ CodigoEtiqueta: first.code, Cantidad: 1, ClaveReporte: first.eti }] };
          setProgress(true, 0, 1);
          const testRes = await fetchJson(URL_PRINT, testReq);
          const testR = await safeRead(testRes);
          if (testR.isHtml) { showLog('danger', 'Imprimir devolvió HTML:\n' + (testR.raw||'').slice(0,250)); setUiState('Error impresión', 'text-bg-danger'); return; }
          if(!testRes.ok || !testR.okParse || !testR.data?.ok){ showLog('danger', (testR.data?.msg||'No se pudo imprimir prueba.')+'\nHTTP '+testRes.status+'\n'+(testR.raw||'')); setUiState('Error impresión', 'text-bg-danger'); return; }
          const testRow = (testR.data.rows||[])[0];
          if(testRow) setRowStatus(first.tr, testRow.ok, `${testRow.msg} (x${testRow.cantidad})`);
          setProgress(true, 1, 1);
          if(testRow && testRow.ok === false){ showLog('danger', `Falló la etiqueta de prueba:\n${testRow.msg}`); setUiState('Prueba fallida', 'text-bg-danger'); return; }
          const okContinue = confirm(`✅ Se imprimió 1 etiqueta de prueba (${first.code}).\n\n¿La etiqueta salió correcta?\n\nAceptar = continuar con el resto\nCancelar = detener`);
          if(!okContinue){ showLog('warning', 'Cancelado por el usuario después de la prueba.'); setUiState('Cancelado', 'text-bg-warning'); return; }
          const restPayload = [];
          if(first.qty > 1) restPayload.push({ CodigoEtiqueta: first.code, Cantidad: first.qty - 1, ClaveReporte: first.eti });
          for(let i=1; i<valid.length; i++) restPayload.push({ CodigoEtiqueta: valid[i].code, Cantidad: valid[i].qty, ClaveReporte: valid[i].eti });
          if(!restPayload.length){ showLog('success', 'Solo se imprimió la prueba (no había más cantidades).'); setUiState('Completado', 'text-bg-success'); return; }
          setUiState(`Imprimiendo (${cfg.plant})...`, 'text-bg-info');
          showLog('info', `Continuando con el resto...\nTotal filas restantes: ${restPayload.length}`);
          setProgress(true, 0, restPayload.length);
          const res = await fetchJson(URL_PRINT, { ...baseReq, items: restPayload });
          const r = await safeRead(res);
          if (r.isHtml) { showLog('danger', 'Imprimir devolvió HTML:\n' + (r.raw||'').slice(0,250)); setUiState('Error impresión', 'text-bg-danger'); return; }
          if(!res.ok || !r.okParse || !r.data?.ok){ showLog('danger', (r.data?.msg||'No se pudo imprimir.')+'\nHTTP '+res.status+'\n'+(r.raw||'')); setUiState('Error impresión', 'text-bg-danger'); return; }
          const map = new Map();
          for(const row of (r.data.rows||[])) map.set((row.codigoEtiqueta||'').toUpperCase(), row);
          let done = 0, total = (r.data.rows||[]).length;
          for(const it of items){ const key=(it.code||'').trim().toUpperCase(); const row=map.get(key); if(row){ setRowStatus(it.tr, row.ok, `${row.msg} (x${row.cantidad})`); done++; setProgress(true, done, total); } }
          showLog(r.data.failCount===0?'success':'warning', `Terminado.\nOK: ${r.data.okCount}\nFallidas: ${r.data.failCount}`);
          setUiState(r.data.failCount===0?'Completado':'Completado con alertas', r.data.failCount===0?'text-bg-success':'text-bg-warning');
        }catch(e){ showLog('danger', 'Error: '+(e?.message||e)); setUiState('Error', 'text-bg-danger'); }
        finally{ setProgress(false); if(btn) btn.disabled=false; if(btn2) btn2.disabled=false; }
      };

      (async () => {
        try{
          setUiState('Cargando...', 'text-bg-info');
          const plantSel = document.getElementById('PlantaId');
          if (plantSel) plantSel.value = (DEFAULT_SOURCE || 'P1').toUpperCase();
          await Promise.allSettled([loadPrinters(), loadEtiquetaciones()]);
          if (plantSel){
            plantSel.addEventListener('change', async () => {
              setUiState('Cambiando planta...', 'text-bg-info');
              await Promise.allSettled([loadPrinters(), loadEtiquetaciones()]);
              setUiState('Listo', 'text-bg-light');
            });
          }
          setUiState('Listo', 'text-bg-light');
        }catch(e){ showLog('danger', 'Error inicializando: '+(e?.message||e)); setUiState('Error', 'text-bg-danger'); }
      })();

    })();

    window.manualConfig = {
        title: "Manual de Reimpresion",
        sections: [
            { id: "Primeros pasos de uso", title: "Primeros pasos de uso", icon: "fa-home",
              steps: [
                { title: "1.1 Configuracion Inicial", text: "Paso a paso para configurar las Reimpresiones", image: "/images/ReImpresiones/etiquetas1-gif.gif" },
                { title: "1.2 Detalle de uso", text: "Paso a paso para configurar las Etiquetas", image: "/images/ReImpresiones/etiquetas2-gif.gif" }
              ]
            },
            { id: "Tutorial", title: "Tutorial", icon: "fa-file-lines",
              steps: [{ title: "2.1 Video Tutorial", text: "Tutorial como usar el modulo de ReImpresiones", video: "/images/ReImpresiones/etiquetas.mp4" }]
            }
        ]
    };
</script>
