@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        let modoAlta = false;
        let tablaDt;

        let JS_PuedeEscribir = @(puedeEscribir.ToString().ToLower());
        let JS_PuedeEliminar = @(puedeEliminar.ToString().ToLower());

        function mostrarLoader() { document.getElementById('loader-overlay').style.display = 'flex'; }
        function ocultarLoader() { $('#loader-overlay').fadeOut('fast'); }

  let editorSelect2Listo = false;
let timerBusqueda = null;

$(document).ready(function() {
    aplicarPermisosVisuales();
    $('#filtroEmpInt, #filtroEmpExt, #selEmpaqueInt, #selEmpaqueExt').select2({ width: '100%' });

    if ($.fn.DataTable.isDataTable('#tablaArticulos')) {
        $('#tablaArticulos').DataTable().clear().destroy();
    }

    tablaDt = $('#tablaArticulos').DataTable({
        pageLength: 50,
        lengthChange: false,
        searching: true,
        info: false,
        ordering: false,
        autoWidth: false,
        deferRender: true,
        processing: true,
        dom: 't<"bottom"ip>'
    });

    $('#tablaArticulos').show();

    $('#filtroTexto').on('input', function() {
        clearTimeout(timerBusqueda);
        const valor = this.value;
        timerBusqueda = setTimeout(function() {
            tablaDt.search(valor).draw();
        }, 250);
    });

    $('#filtroEmpInt, #filtroEmpExt').on('change', function() {
        tablaDt.draw();
    });

    ocultarLoader();
});

function inicializarSelect2Editor() {
    if (editorSelect2Listo) return;

    $('#selEmpaqueInt, #selEmpaqueExt').select2({
        width: '100%'
    });

    editorSelect2Listo = true;
}

function setSelectEditor(selector, valor) {
    const $select = $(selector);
    $select.val(valor || '');

    if (editorSelect2Listo) {
        $select.trigger('change.select2');
    }
}

        function aplicarPermisosVisuales() {
            if (!JS_PuedeEscribir && !JS_PuedeEliminar) {
                document.querySelectorAll(".col-seguridad").forEach(el => el.style.display = "none");
            }
        }

        $.fn.dataTable.ext.search.push(function(settings, data, dataIndex, rowData, counter) {
            const valFiltroInt = $('#filtroEmpInt').val();
            const valFiltroExt = $('#filtroEmpExt').val();
            if (valFiltroInt === "" && valFiltroExt === "") return true;

            const nodoFila = tablaDt.row(dataIndex).node();
            if (!nodoFila) return true;

            const evaluarConfig = (eInt, eExt) => {
                const valInt = (eInt === null || eInt === "") ? "SIN" : eInt;
                const valExt = (eExt === null || eExt === "") ? "SIN" : eExt;
                const cumpleInt = (valFiltroInt === "") || (valFiltroInt === "SIN" && valInt === "SIN") || (valInt === valFiltroInt);
                const cumpleExt = (valFiltroExt === "") || (valFiltroExt === "SIN" && valExt === "SIN") || (valExt === valFiltroExt);
                return cumpleInt && cumpleExt;
            };

            const empIntMain = nodoFila.getAttribute('data-emp-int');
            const empExtMain = nodoFila.getAttribute('data-emp-ext');

            if (evaluarConfig(empIntMain, empExtMain)) return true;

            const btnExpandir = $(nodoFila).find('.btn-expandir');
            if (btnExpandir.length > 0) {
                try {
                    const extras = JSON.parse(btnExpandir.attr('data-extras'));
                    for (let i = 0; i < extras.length; i++) {
                        if (evaluarConfig(extras[i].EmpaqueInt, extras[i].EmpaqueExt)) {
                            return true;
                        }
                    }
                } catch (e) { console.error("Error al leer extras", e); }
            }
            return false;
        });

        function limpiarFiltros() {
            $('#filtroTexto').val('');
            $('#filtroEmpInt').val('').trigger('change');
            $('#filtroEmpExt').val('').trigger('change');
            tablaDt.search('').draw();
        }

        const txtArticulosSel = document.getElementById('txtArticulosSel');
        const divAltaNueva = document.getElementById('divAltaNueva');
        const contadorSel = document.getElementById('contador-seleccion');

        $('#chkTodos').on('change', function() {
            const isChecked = this.checked;
            tablaDt.$('.chk-fila').each(function() {
                if($(this).closest('tr').css('display') !== "none") { this.checked = isChecked; }
            });
            actualizarEstadoUI();
        });

        $('#tablaArticulos tbody').on('change', '.chk-fila', function() { actualizarEstadoUI(); });

        function seleccionarFilaRapida(sku) {
            tablaDt.$('.chk-fila').prop('checked', false);
            const checkbox = $('#chk_' + sku);
            if(checkbox.length) { checkbox.prop('checked', true); }
            actualizarEstadoUI();
        }

       function prepararAltaIndividual() {
    modoAlta = true;
    $('#chkTodos').prop('checked', false);
    tablaDt.$('.chk-fila').prop('checked', false);

    document.getElementById('titulo-editor').textContent = "Alta de Nuevo Artículo";
    txtArticulosSel.style.display = "none";
    divAltaNueva.style.display = "grid";

    document.getElementById('inpNuevoSku').value = "";
    document.getElementById('inpNuevaDesc').value = "";

    inicializarSelect2Editor();
    limpiarCamposFormulario();

    document.getElementById('inpNuevoSku').focus();
}

        function actualizarEstadoUI() {
            modoAlta = false;
            txtArticulosSel.style.display = "block";
            divAltaNueva.style.display = "none";

            const seleccionados = tablaDt.$('.chk-fila:checked').toArray();
            const total = seleccionados.length;
            contadorSel.textContent = `${total} seleccionados`;

            if (total === 0) {
                document.getElementById('titulo-editor').textContent = "Alta, Baja y Actualizaciones";
                txtArticulosSel.value = "Seleccione un registro";
                txtArticulosSel.rows = 2;
                limpiarCamposFormulario();
            }
            else if (total === 1) {
                document.getElementById('titulo-editor').textContent = "Edición Individual";
                const fila = seleccionados[0].closest('tr');
                const desc = fila.querySelector(".col-desc").textContent;
                txtArticulosSel.value = `${seleccionados[0].value} - ${desc}`;
                txtArticulosSel.rows = 2;

                document.getElementById('selEmpaqueInt').value = fila.querySelector('.col-emp-int').getAttribute('data-val') || "";
                $('#selEmpaqueInt').trigger('change');
                document.getElementById('inpPzMin').value = fila.querySelector('.col-pz-min').textContent.trim();
                document.getElementById('inpPzDef').value = fila.querySelector('.col-pz-def').textContent.trim();
                document.getElementById('inpPzMax').value = fila.querySelector('.col-pz-max').textContent.trim();
                document.getElementById('inpPesoMin').value = fila.querySelector('.col-peso-min').textContent.trim();
                document.getElementById('inpPesoMax').value = fila.querySelector('.col-peso-max').textContent.trim();

                document.getElementById('selEmpaqueExt').value = fila.querySelector('.col-emp-ext').getAttribute('data-val') || "";
                $('#selEmpaqueExt').trigger('change');
                document.getElementById('inpBolsaMin').value = fila.querySelector('.col-bs-min').textContent.trim();
                document.getElementById('inpBolsaDef').value = fila.querySelector('.col-bs-def').textContent.trim();
                document.getElementById('inpBolsaMax').value = fila.querySelector('.col-bs-max').textContent.trim();
                document.getElementById('inpPesoExtMin').value = fila.querySelector('.col-peso-ext-min').textContent.trim();
                document.getElementById('inpPesoExtMax').value = fila.querySelector('.col-peso-ext-max').textContent.trim();
            }
            else {
                document.getElementById('titulo-editor').textContent = `Edición Masiva (${total} SKUs)`;
                let listaNombres = seleccionados.map(chk => {
                    const desc = chk.closest('tr').querySelector(".col-desc").textContent;
                    return `• ${chk.value} - ${desc}`;
                }).join('\n');

                txtArticulosSel.value = listaNombres;
                txtArticulosSel.rows = total > 4 ? 4 : (total < 2 ? 2 : total);
                limpiarCamposFormulario();
            }
        }

 

     function limpiarCamposFormulario() {
    document.querySelectorAll('.panel-derecho input[type="number"]').forEach(el => el.value = '');

    setSelectEditor('#selEmpaqueInt', '');
    setSelectEditor('#selEmpaqueExt', '');
}

        function limpiarEditor() {
            modoAlta = false;
            $('#chkTodos').prop('checked', false);
            tablaDt.$('.chk-fila').prop('checked', false);
            actualizarEstadoUI();
        }

        async function subirExcelMasivo(input) {
             if(input.files.length === 0) return;
             const file = input.files[0];

             // Validar que el usuario haya guardado su tabla como CSV
             if (!file.name.toLowerCase().endsWith('.csv')) {
                 alert("⚠️ Por favor, en Excel vaya a 'Guardar como' y seleccione el formato 'CSV (delimitado por comas)' y suba ese archivo.");
                 input.value = "";
                 return;
             }

             mostrarLoader();

             // Empaquetar el archivo para mandarlo a C#
             const formData = new FormData();
             formData.append("archivo", file);

             try {
                 const plantaActiva = document.getElementById('selPlanta').value;
                 const urlCarga = '@Url.Action("CargarMasivoEmpaques", "ProcesosCG")' + '?planta=' + plantaActiva;

                 const response = await fetch(urlCarga, {
                     method: 'POST',
                     body: formData
                 });

                 const data = await response.json();
                 if (data.ok) {
                     alert(data.mensaje);
                     window.location.reload();
                 } else {
                     alert("Error: " + data.mensaje);
                     ocultarLoader();
                 }
             } catch (error) {
                 alert("Error de conexión al procesar el archivo masivo.");
                 ocultarLoader();
             } finally {
                 input.value = "";
             }
         }
        async function guardarEmpaque() {
            if(!JS_PuedeEscribir) return alert("No tiene permisos para guardar.");

            let seleccionados = [];
            let nuevoSku = "";
            let nuevaDesc = "";

            if (modoAlta) {
                nuevoSku = document.getElementById('inpNuevoSku').value.trim();
                nuevaDesc = document.getElementById('inpNuevaDesc').value.trim();
                if (nuevoSku === "") { alert("Capture el SKU."); return; }
                seleccionados.push(nuevoSku);
            } else {
                seleccionados = tablaDt.$('.chk-fila:checked').map(function() { return this.value; }).get();
                if (seleccionados.length === 0) { alert("Seleccione un registro o haga clic en Nuevo SKU."); return; }
            }

            const getNum = (id) => { const val = document.getElementById(id).value; return val === "" ? null : parseFloat(val); };

            const payload = {
                ModoAlta: modoAlta, NuevoSkuDesc: nuevaDesc, Skus: seleccionados,
                EmpaqueInterno: document.getElementById('selEmpaqueInt').value,
                PzaMin: getNum('inpPzMin'), PzaDef: getNum('inpPzDef'), PzaMax: getNum('inpPzMax'), PesoMin: getNum('inpPesoMin'), PesoMax: getNum('inpPesoMax'),
                EmpaqueExterno: document.getElementById('selEmpaqueExt').value,
                BolsaMin: getNum('inpBolsaMin'), BolsaDef: getNum('inpBolsaDef'), BolsaMax: getNum('inpBolsaMax'), PesoExtMin: getNum('inpPesoExtMin'), PesoExtMax: getNum('inpPesoExtMax')
            };

            mostrarLoader();
            try {
                const plantaActiva = document.getElementById('selPlanta').value;
                const urlGuardar = '@Url.Action("GuardarConfiguracionEmpaque", "ProcesosCG")' + '?planta=' + plantaActiva;
                const response = await fetch(urlGuardar, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                const data = await response.json();
                if (data.ok) { alert(data.mensaje); window.location.reload(); }
                else { alert("Error: " + data.mensaje); ocultarLoader(); }
            } catch (error) { alert("Error de conexion."); ocultarLoader(); }
        }

        // Eliminacion desde el panel derecho (masivo o individual)
        async function eliminarPanelDerecho() {
            if(!JS_PuedeEliminar) return alert("No tiene permisos para eliminar configuraciones.");
            let seleccionados = tablaDt.$('.chk-fila:checked').map(function() { return this.value; }).get();
            if (seleccionados.length === 0) { alert("Seleccione al menos un SKU para eliminar su configuración."); return; }

            let empaqueIntId = document.getElementById('selEmpaqueInt').value;
            let empaqueExtId = document.getElementById('selEmpaqueExt').value;

            if(empaqueIntId === "" && empaqueExtId === "") {
                alert("Seleccione el empaque (Bolsa o Caja) en los selectores derechos que desea desvincular de los SKUs seleccionados."); return;
            }

            if(!confirm(`¿Desea desvincular los empaques seleccionados de los ${seleccionados.length} SKUs marcados?`)) return;

            mostrarLoader();
            try {
                const payload = { Skus: seleccionados, EmpaqueInterno: empaqueIntId, EmpaqueExterno: empaqueExtId };
                const plantaActiva = document.getElementById('selPlanta').value;
                const urlEliminar = '@Url.Action("EliminarConfiguracionEmpaque", "ProcesosCG")' + '?planta=' + plantaActiva;
                const response = await fetch(urlEliminar, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
                const data = await response.json();
                if (data.ok) { alert(data.mensaje); window.location.reload(); }
                else { alert("Error: " + data.mensaje); ocultarLoader(); }
            } catch (error) { alert("Error de conexion."); ocultarLoader(); }
        }

        // --- SISTEMA DE MODAL PARA ELIMINAR (Principal y Extras) ---
        function abrirModalEliminar(sku, empInt, empExt, descInt, descExt) {
            if(!JS_PuedeEliminar) return alert("No tiene permisos para eliminar configuraciones.");

            if(!empInt && !empExt) {
                alert("Este artículo no tiene empaques asignados para eliminar.");
                return;
            }

            $('#lblEliminarSku').text(sku);
            $('#hidEliminarSku').val(sku);
            $('#hidEliminarBolsaId').val(empInt || "");
            $('#hidEliminarCajaId').val(empExt || "");

            if(empInt) {
                $('#optEliminarBolsa').show();
                $('#lblEliminarBolsaTxt').text(descInt || "Bolsa Asignada");
                $('#chkEliminarBolsa').prop('checked', false);
            } else {
                $('#optEliminarBolsa').hide();
                $('#chkEliminarBolsa').prop('checked', false);
            }

            if(empExt) {
                $('#optEliminarCaja').show();
                $('#lblEliminarCajaTxt').text(descExt || "Caja Asignada");
                $('#chkEliminarCaja').prop('checked', false);
            } else {
                $('#optEliminarCaja').hide();
                $('#chkEliminarCaja').prop('checked', false);
            }

            var miModal = new bootstrap.Modal(document.getElementById('modalEliminarEmpaque'));
            miModal.show();
        }

        async function ejecutarEliminacionSeleccionada() {
            const sku = $('#hidEliminarSku').val();
            const borrarInt = $('#chkEliminarBolsa').is(':checked');
            const borrarExt = $('#chkEliminarCaja').is(':checked');
            const empInt = $('#hidEliminarBolsaId').val();
            const empExt = $('#hidEliminarCajaId').val();

            if(!borrarInt && !borrarExt) {
                alert("Debe seleccionar al menos un empaque para eliminar.");
                return;
            }

            mostrarLoader();
            try {
                const payload = {
                    Skus: [sku],
                    EmpaqueInterno: borrarInt ? empInt : "",
                    EmpaqueExterno: borrarExt ? empExt : ""
                };

                const plantaActiva = document.getElementById('selPlanta').value;
                const urlEliminar = '@Url.Action("EliminarConfiguracionEmpaque", "ProcesosCG")' + '?planta=' + plantaActiva;

                const response = await fetch(urlEliminar, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();
                if (data.ok) {
                    alert("Se ha actualizado la configuración.");
                    window.location.reload();
                } else {
                    alert("Error: " + data.mensaje);
                    ocultarLoader();
                }
            } catch (error) {
                alert("Error de conexion.");
                ocultarLoader();
            }
        }

        function cambiarPlanta() {
            mostrarLoader();
            const planta = document.getElementById('selPlanta').value;
            window.location.href = '@Url.Action("EmpaqueArticulos", "ProcesosCG")' + '?planta=' + planta;
        }

        // Sub-tabla y Botón +
        $('#tablaArticulos tbody').on('click', '.btn-expandir', function () {
            var tr = $(this).closest('tr');
            var row = tablaDt.row(tr);

            if (row.child.isShown()) {
                row.child.hide();
                $(this).text('+');
            } else {
                var extras = JSON.parse($(this).attr('data-extras'));

                var subHtml = '<div style="padding: 10px; background: #fdf6f6; border-bottom: 2px solid #8b0000; display:flex; justify-content:center;">';
                subHtml += '<table class="sub-tabla">';
                subHtml += '<thead>';
                subHtml += '<tr style="background: linear-gradient(180deg, #980000 0%, #7a0000 55%, #5c0000 100%);">';
                subHtml += '<th colspan="6" style="border-right: 1px solid #d88989;">EMPAQUES ADICIONALES (BOLSA)</th>';
                subHtml += '<th colspan="6" style="border-right: 1px solid #d88989;">EMPAQUES ADICIONALES (CAJA)</th>';

                if(JS_PuedeEscribir || JS_PuedeEliminar) {
                    subHtml += '<th rowspan="2" style="vertical-align: middle;">Acción</th>';
                }

                subHtml += '</tr>';
                subHtml += '<tr style="background: linear-gradient(180deg, #7a0000 0%, #5c0000 55%, #3d0000 100%);">';
                subHtml += '<th>Tipo Bolsa</th><th>Pz.Min</th><th>Pz.Def</th><th>Pz.Max</th><th>Kg.Min</th><th style="border-right: 1px solid #d88989;">Kg.Max</th>';
                subHtml += '<th>Tipo Contenedor</th><th>Bs.Min</th><th>Bs.Def</th><th>Bs.Max</th><th>Kg.Min</th><th style="border-right: 1px solid #d88989;">Kg.Max</th>';
                subHtml += '</tr>';
                subHtml += '</thead>';

                subHtml += '<tbody>';
                extras.forEach(function(ext, index) {
                    let bolsa = ext.EmpaqueIntDesc && ext.EmpaqueIntDesc !== '-' ? `<span class="badge-dark">${ext.EmpaqueIntDesc}</span>` : '-';
                    let caja = ext.EmpaqueExtDesc && ext.EmpaqueExtDesc !== '-' ? `<span class="badge-dark">${ext.EmpaqueExtDesc}</span>` : '-';

                    // Evitar problemas de comillas simples en el texto al pasar parametros
                    let descIntSafe = ext.EmpaqueIntDesc && ext.EmpaqueIntDesc !== '-' ? ext.EmpaqueIntDesc.replace(/'/g, "\\'") : '';
                    let descExtSafe = ext.EmpaqueExtDesc && ext.EmpaqueExtDesc !== '-' ? ext.EmpaqueExtDesc.replace(/'/g, "\\'") : '';

                    subHtml += '<tr>';
                    subHtml += `<td>${bolsa}</td><td>${ext.PzMin}</td><td>${ext.PzDef}</td><td>${ext.PzMax}</td><td>${parseFloat(ext.PesoMin).toFixed(2)}</td><td style="border-right: 1px solid #e0baba;">${parseFloat(ext.PesoMax).toFixed(2)}</td>`;
                    subHtml += `<td style="background: #fcf4f4;">${caja}</td><td style="background: #fcf4f4;">${ext.BolsaMin}</td><td style="background: #fcf4f4;">${ext.BolsaDef}</td><td style="background: #fcf4f4;">${ext.BolsaMax}</td><td style="background: #fcf4f4;">${parseFloat(ext.PesoExtMin).toFixed(2)}</td><td style="background: #fcf4f4; border-right: 1px solid #e0baba;">${parseFloat(ext.PesoExtMax).toFixed(2)}</td>`;

                    if(JS_PuedeEscribir || JS_PuedeEliminar) {
                        let btnHtml = '';
                        if(JS_PuedeEscribir) { btnHtml += `<button class="pm-btn pm-btn-secondary" style="height:20px; font-size:9px; padding:0 6px; margin-right:4px;" onclick="editarExtra('${ext.Sku}', ${index})">Editar</button>`; }
                        if(JS_PuedeEliminar) { btnHtml += `<button class="pm-btn pm-btn-danger" style="height:20px; font-size:9px; padding:0 6px;" onclick="abrirModalEliminar('${ext.Sku}', '${ext.EmpaqueInt}', '${ext.EmpaqueExt}', '${descIntSafe}', '${descExtSafe}')">Eliminar</button>`; }
                        subHtml += `<td style="background: #fcf4f4; white-space:nowrap;">${btnHtml}</td>`;
                    }
                    subHtml += '</tr>';
                });

                subHtml += '</tbody></table></div>';
                row.child(subHtml).show();
                $(this).text('-');
            }
        });

        function editarExtra(sku, index) {
            if(!JS_PuedeEscribir) return alert("No tiene permisos para editar.");
            seleccionarFilaRapida(sku);

            var trPrincipal = $('#chk_' + sku).closest('tr');
            var btnExpandir = trPrincipal.find('.btn-expandir');
            var extras = JSON.parse(btnExpandir.attr('data-extras'));
            var ext = extras[index];

            $('#selEmpaqueInt').val(ext.EmpaqueInt || "").trigger('change');
            $('#inpPzMin').val(ext.PzMin); $('#inpPzDef').val(ext.PzDef); $('#inpPzMax').val(ext.PzMax); $('#inpPesoMin').val(ext.PesoMin); $('#inpPesoMax').val(ext.PesoMax);
            $('#selEmpaqueExt').val(ext.EmpaqueExt || "").trigger('change');
            $('#inpBolsaMin').val(ext.BolsaMin); $('#inpBolsaDef').val(ext.BolsaDef); $('#inpBolsaMax').val(ext.BolsaMax); $('#inpPesoExtMin').val(ext.PesoExtMin); $('#inpPesoExtMax').val(ext.PesoExtMax);

            $('#titulo-editor').text("Edición de Empaque Adicional");
        }
                // Funcion unificada para historial general e individual
        function verHistorial(sku = null) {
            mostrarLoader();
            const planta = document.getElementById('selPlanta').value;

            // Construir URL con o sin parametro de SKU
            let urlPeticion = '@Url.Action("ObtenerHistorialEmpaque", "ProcesosCG")' + '?planta=' + planta;
            if (sku) {
                urlPeticion += '&sku=' + encodeURIComponent(sku);
                $('.modal-title', '#modalHistorialEmpaque').text('Historial Individual - SKU: ' + sku);
            } else {
                $('.modal-title', '#modalHistorialEmpaque').text('Historial General de Movimientos');
            }

            fetch(urlPeticion)
                .then(r => r.json())
                .then(result => {
                    const tbody = document.getElementById('tbodyHistorial');
                    tbody.innerHTML = '';
                    document.getElementById('sinHistorial').style.display = 'none';

                    if (!result.ok || !result.data || result.data.length === 0) {
                        document.getElementById('sinHistorial').style.display = 'block';
                    } else {
                        result.data.forEach(log => {
                            const fecha = new Date(log.fechaHora).toLocaleString('es-MX');
                            const badges = { 'INSERT': 'success', 'UPDATE': 'primary', 'DELETE': 'danger' };
                            const badgeColor = badges[log.operacion] || 'secondary';
                            const detalle = log.valoresNuevos || '-';
                            const tr = document.createElement('tr');
                            tr.innerHTML = `
                                <td style="padding: 6px; white-space: nowrap;">${fecha}</td>
                                <td style="padding: 6px; font-weight: bold;">${log.sku || '-'}</td>
                                <td style="padding: 6px;"><span class="badge bg-${badgeColor}">${log.operacion}</span></td>
                                <td style="padding: 6px;">${log.nombreEmpaque || '-'}</td>
                                <td style="padding: 6px; font-size: 10px;">${detalle}</td>
                                <td style="padding: 6px;">${log.usuario || '-'}</td>
                            `;
                            tbody.appendChild(tr);
                        });
                    }

                    var miModal = new bootstrap.Modal(document.getElementById('modalHistorialEmpaque'));
                    miModal.show();
                    ocultarLoader();
                })
                .catch(() => {
                    alert('Error al cargar historial.');
                    ocultarLoader();
                });
        }

    </script>
}