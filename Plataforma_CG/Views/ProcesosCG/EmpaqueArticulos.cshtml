@model List<Plataforma_CG.Models.EmpaqueRowVM>
@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Control de Empaque por SKU";

    bool puedeEscribir = Context.Items["Permiso_EMPAQUES_ARTICULOS_ESCRIBIR"] as bool? ?? true;
    bool puedeEliminar = Context.Items["Permiso_EMPAQUES_ARTICULOS_ELIMINAR"] as bool? ?? true;
}

<style>
    /* Variables de disenio general */
    :root {
        --bg: #f0dede;
        --panel: #f8eeee;
        --panel-2: #f1dede;
        --line: #c79d9d;
        --text: #3b1717;
        --white: #ffffff;
        --vino-border: #9a5a5a;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0 !important;
        padding: 0 !important;
        font-family: Tahoma, sans-serif;
        background: transparent !important;
        color: var(--text);
    }

    /* Layout principal */
    .window-empaque {
        display: flex;
        gap: 10px;
        padding: 10px;
        background: var(--bg);
        height: calc(100vh - 50px);
        overflow: hidden;
    }

    .workspace {
        border: 1px solid var(--line);
        background: var(--panel);
        padding: 8px;
        display: flex;
        flex-direction: column;
    }

    .panel-izquierdo {
        flex: 3;
        overflow: hidden;
    }

    .panel-derecho {
        flex: 1.2;
        min-width: 360px;
        overflow: hidden;
    }

    .section {
        border: 1px solid var(--line);
        background: var(--white);
        margin-bottom: 10px;
        display: flex;
        flex-direction: column;
    }

        .section.flex-fill {
            flex: 1;
            margin-bottom: 0;
            overflow: hidden;
        }

    .section-title {
        padding: 6px 8px;
        font-size: 12px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    /* Filtros y UI */
    .filters {
        display: flex;
        gap: 8px;
        padding: 10px;
        background: var(--panel-2);
        align-items: end;
    }

    .filter-group {
        flex: 1;
    }

        .filter-group label {
            display: block;
            color: #5c1a1a;
            font-size: 11px;
            margin-bottom: 4px;
            font-weight: bold;
        }

    .form-control, .form-select {
        height: 26px !important;
        padding: 2px 6px !important;
        border: 1px solid #b48787 !important;
        background: #fffdfd !important;
        font-size: 11px !important;
        width: 100%;
        color: #421414 !important;
        border-radius: 0;
    }

    textarea.form-control {
        height: auto !important;
        resize: none;
        font-size: 10px !important;
        line-height: 1.3;
    }

    .pm-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        height: 26px;
        padding: 0 12px;
        border: 1px solid transparent;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        color: #fff;
        text-decoration: none;
        white-space: nowrap;
    }

    .pm-btn-primary {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-color: #7a2d2d;
    }

    .pm-btn-success {
        background: linear-gradient(180deg, #27ae60 0%, #1f9a54 55%, #198754 100%);
        border-color: #157347;
    }

    .pm-btn-danger {
        background: linear-gradient(180deg, #dc3545 0%, #c82333 55%, #bd2130 100%);
        border-color: #b02a37;
    }

    .pm-btn-secondary {
        background: linear-gradient(#fffefe, #ecd7d7);
        border-color: var(--vino-border);
        color: #4a1111;
    }

    /* Tabla datos */
    .table-wrap {
        overflow: auto;
        height: 100%;
        background: #fffafa;
    }

    table {
        width: 100%;
        border-collapse: separate !important;
        border-spacing: 0 !important;
        font-size: 10px;
    }

    thead th {
        position: sticky;
        color: #fff;
        padding: 5px;
        border-right: 1px solid #8e3b3b;
        z-index: 10;
        white-space: nowrap;
        text-align: center;
    }

    thead tr:nth-child(1) th {
        top: 0;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #ffb3b3;
        z-index: 11;
    }

    .th-ext-top {
        background: linear-gradient(180deg, #8b0000 0%, #6a0000 55%, #3d0000 100%) !important;
    }

    .th-ext-sub {
        background: linear-gradient(180deg, #7a0000 0%, #5c0000 55%, #3d0000 100%) !important;
    }

    thead th:first-child {
        border-left: 1px solid #8e3b3b;
    }

    tbody td {
        padding: 4px 5px;
        border-bottom: 1px solid #d8bcbc;
        border-right: 1px solid #d8bcbc;
        color: #111;
        text-align: center;
        vertical-align: middle;
        overflow: hidden;
        text-overflow: ellipsis;
    }

        tbody td:first-child {
            border-left: 1px solid #d8bcbc;
        }

        tbody td.text-left {
            text-align: left;
        }

        tbody td.col-ext {
            background-color: #fbf0f0;
        }

    tbody tr:nth-child(even) td {
        background: #f9eded;
    }

        tbody tr:nth-child(even) td.col-ext {
            background: #f4e6e6;
        }

    tbody tr:hover td {
        background: #f4dddd !important;
    }

    .check-col {
        width: 30px;
        text-align: center;
    }

    input[type="checkbox"] {
        cursor: pointer;
        margin: 0;
    }

    .badge-dark {
        background: #333;
        color: #fff;
        padding: 2px 6px;
        border-radius: 2px;
        font-size: 9px;
        font-weight: bold;
    }

    /* Correccion scroll horizontal */
    #tablaArticulos {
        table-layout: auto !important;
        width: 100% !important;
    }

        #tablaArticulos th, #tablaArticulos td {
            padding: 3px 4px !important;
            vertical-align: middle;
        }

    .col-desc {
        white-space: normal !important;
        word-wrap: break-word;
        min-width: 120px;
        max-width: 160px;
    }

    .col-emp-int, .col-emp-ext {
        white-space: normal !important;
        word-wrap: break-word;
        max-width: 90px;
    }

    .col-sku, .col-pz-min, .col-pz-def, .col-pz-max, .col-peso-min, .col-peso-max, .col-bs-min, .col-bs-def, .col-bs-max, .col-peso-ext-min, .col-peso-ext-max {
        white-space: nowrap !important;
        text-align: center;
    }

    #tablaArticulos > thead > tr > th {
        position: sticky;
        color: #fff;
        border-right: 1px solid #5c0000;
        z-index: 10;
        white-space: nowrap;
    }

    #tablaArticulos > thead > tr:nth-child(1) > th {
        top: 0;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #5c0000;
        z-index: 11;
    }

    #tablaArticulos > thead > tr:nth-child(2) > th {
        top: 22px;
        background: linear-gradient(180deg, #980000 0%, #7a0000 55%, #5c0000 100%);
        border-bottom: 1px solid #5c0000;
    }

    /* Estilos sub-tabla */
    .sub-tabla {
        width: 98%;
        margin: 0 auto;
        border-collapse: separate !important;
        border-spacing: 0 !important;
        background: #fff;
        border: 1px solid #8b0000;
        border-radius: 4px;
        overflow: hidden;
        box-shadow: 0 3px 8px rgba(0,0,0,0.15);
    }

        .sub-tabla thead th {
            position: static !important;
            color: #fff;
            padding: 5px;
            text-align: center;
            font-size: 10px;
            border-right: 1px solid #b85c5c;
        }

        .sub-tabla tbody td {
            padding: 4px;
            text-align: center;
            border-bottom: 1px solid #e0e0e0;
            border-right: 1px solid #e0e0e0;
            font-size: 10px;
            color: #333;
        }

    /* Paneles de edicion */
    .editor-body {
        padding: 12px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        overflow-y: auto;
        flex: 1;
    }

    .editor-footer {
        padding: 10px 12px;
        background: #f7eaea;
        border-top: 1px solid #d3b0b0;
        display: flex;
        gap: 8px;
    }

    .form-section-title {
        font-size: 11px;
        font-weight: bold;
        color: #8b0000;
        text-transform: uppercase;
        border-bottom: 1px solid var(--line);
        padding-bottom: 4px;
        margin-top: 5px;
    }

    .row-inputs {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 8px;
    }

    .row-inputs-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    /* Select2 y DataTables */
    .select2-container .select2-selection--single {
        height: 26px !important;
        padding: 2px 6px !important;
        border: 1px solid #b48787 !important;
        background: #fffdfd !important;
        border-radius: 0 !important;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 20px !important;
        font-size: 11px !important;
        color: #421414 !important;
        padding-left: 0 !important;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 24px !important;
    }

    .select2-dropdown {
        font-size: 11px !important;
        border: 1px solid #b48787 !important;
        border-radius: 0 !important;
    }

    .select2-search__field {
        font-size: 11px !important;
    }

    .dataTables_wrapper .bottom {
        display: flex;
        justify-content: center;
        padding: 8px 10px;
        background: var(--panel-2);
        border-top: 1px solid var(--line);
        font-size: 11px;
    }

    .dataTables_paginate .paginate_button {
        padding: 3px 10px !important;
        margin: 0 2px;
        border: 1px solid #c79d9d !important;
        background: #fff !important;
        color: #4a1111 !important;
        border-radius: 2px;
        cursor: pointer;
    }

        .dataTables_paginate .paginate_button:hover {
            background: #f4dddd !important;
        }

        .dataTables_paginate .paginate_button.current {
            background: linear-gradient(180deg, #b30000 0%, #8b0000 100%) !important;
            color: white !important;
            border: 1px solid #7a2d2d !important;
            font-weight: bold;
        }

    /* Pantalla de carga */
    #loader-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.85);
        z-index: 9999;
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    .spinner {
        border: 4px solid #d8bcbc;
        border-top: 4px solid #8b0000;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .loader-text {
        margin-top: 10px;
        font-weight: bold;
        color: #8b0000;
        font-size: 12px;
    }

    .col-seguridad {
        display: revert;
    }
</style>

<div class="window-empaque">
    <div id="loader-overlay">
        <div class="spinner"></div>
        <div class="loader-text">Cargando información...</div>
    </div>

    <div class="workspace panel-izquierdo">
        <div class="section">
            <div class="section-title">Filtros y Acciones</div>
            <div class="filters">
                <div class="filter-group" style="max-width: 90px;">
                    <label>Planta</label>
                    <select id="selPlanta" class="form-select" onchange="cambiarPlanta()">
                        @if (ViewBag.PlantaActual == "P1")
                        {
                            <option value="TIF">TIF</option>
                            <option value="P1" selected>P1</option>
                        }
                        else
                        {
                            <option value="TIF" selected>TIF</option>
                            <option value="P1">P1</option>
                        }
                    </select>
                </div>
                <div class="filter-group" style="flex: 2;">
                    <label>Artículo o Descripción</label>
                    <input type="text" id="filtroTexto" class="form-control" placeholder="Escriba para buscar...">
                </div>
                <div class="filter-group">
                    <label>Bolsa.</label>
                    <select id="filtroEmpInt" class="form-select">
                        <option value="">TODOS</option>
                        <option value="SIN">SIN ASIGNAR</option>
                        @if (ViewBag.EmpaquesInternos != null)
                        {
                            foreach (var emp in ViewBag.EmpaquesInternos)
                            {
                                <option value="@emp.Id">@emp.Descripcion</option>
                            }
                        }
                    </select>
                </div>
                <div class="filter-group">
                    <label>Caja.</label>
                    <select id="filtroEmpExt" class="form-select">
                        <option value="">TODOS</option>
                        <option value="SIN">SIN ASIGNAR</option>
                        @if (ViewBag.EmpaquesExternos != null)
                        {
                            foreach (var emp in ViewBag.EmpaquesExternos)
                            {
                                <option value="@emp.Id">@emp.Descripcion</option>
                            }
                        }
                    </select>
                </div>
                <div class="filter-group" style="flex: 0 0 auto; display: flex; gap: 5px;">
                    <label>&nbsp;</label>
                    <button class="pm-btn pm-btn-secondary" onclick="limpiarFiltros()">Limpiar</button>

                    <button class="pm-btn pm-btn-secondary col-seguridad" onclick="verHistorial()">Historial</button>
                    <button id="btnNuevoSku" class="pm-btn pm-btn-success col-seguridad" onclick="prepararAltaIndividual()">+ Nuevo SKU</button>
                    <button id="btnAltaMasiva" class="pm-btn pm-btn-primary col-seguridad" onclick="document.getElementById('fileExcel').click()">+ Alta Masiva</button>
                    <input type="file" id="fileExcel" accept=".csv, application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" style="display: none;" onchange="subirExcelMasivo(this)">
                </div>
            </div>
        </div>

        <div class="section flex-fill">
            <div class="section-title">
                <span>Catálogo de Artículos y Empaques</span>
                <span id="contador-seleccion">0 seleccionados</span>
            </div>
            <div class="table-wrap">
                <table id="tablaArticulos" class="table table-sm" style="display: none;">
                    <thead>
                        <tr>
                            <th rowspan="2" class="check-col col-seguridad"><input type="checkbox" id="chkTodos"></th>
                            <th rowspan="2" style="width: 50px;">SKU</th>
                            <th rowspan="2" class="text-left" style="width: 140px;">Descripción</th>

                            <th colspan="6">EMPAQUE INTERNO (BOLSA)</th>
                            <th colspan="6" class="th-ext-top">EMPAQUE EXTERNO (CAJA/CARRO)</th>
                            <th rowspan="2" style="width: 50px;" class="col-seguridad">Acción</th>
                        </tr>
                        <tr>
                            <th style="width: 100px;">Tipo Bolsa</th>
                            <th style="width: 35px;">Pz.Min</th>
                            <th style="width: 35px;">Pz.Def</th>
                            <th style="width: 35px;">Pz.Max</th>
                            <th style="width: 50px;">Kg.Min</th>
                            <th style="width: 50px;">Kg.Max</th>

                            <th style="width: 100px;" class="th-ext-sub">Tipo Contenedor</th>
                            <th style="width: 35px;" class="th-ext-sub">Bs.Min</th>
                            <th style="width: 35px;" class="th-ext-sub">Bs.Def</th>
                            <th style="width: 35px;" class="th-ext-sub">Bs.Max</th>
                            <th style="width: 50px;" class="th-ext-sub">Kg.Min</th>
                            <th style="width: 50px;" class="th-ext-sub">Kg.Max</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            var agrupado = Model.GroupBy(x => x.Sku).ToList();
                            foreach (var grupo in agrupado)
                            {
                                var item = grupo.First();
                                var extras = grupo.Skip(1).ToList();
                                var hasExtras = extras.Count > 0;
                                var extrasJson = System.Text.Json.JsonSerializer.Serialize(extras);

                                // Sanitizacion rapida para evitar conflicto de comillas simples en el JS
                                var descIntSafe = string.IsNullOrEmpty(item.EmpaqueIntDesc) || item.EmpaqueIntDesc == "-" ? "" : item.EmpaqueIntDesc.Replace("'", "\\'");
                                var descExtSafe = string.IsNullOrEmpty(item.EmpaqueExtDesc) || item.EmpaqueExtDesc == "-" ? "" : item.EmpaqueExtDesc.Replace("'", "\\'");

                                <tr class="fila-dato" data-emp-int="@item.EmpaqueInt" data-emp-ext="@item.EmpaqueExt">
                                    <td class="check-col col-seguridad">
                                        <input type="checkbox" class="chk-fila" value="@item.Sku" id="chk_@item.Sku">
                                        @if (hasExtras)
                                        {
                                            <br>
                                            <button class="pm-btn pm-btn-secondary btn-expandir" data-extras="@extrasJson" style="height:16px; padding:0 4px; margin-top:3px; font-size:10px;">+</button>
                                        }
                                    </td>
                                    <td class="col-sku">@item.Sku</td>
                                    <td class="text-left col-desc" title="@item.Descripcion">@item.Descripcion</td>

                                    <td class="col-emp-int" data-val="@item.EmpaqueInt">
                                        @if (string.IsNullOrEmpty(item.EmpaqueIntDesc) || item.EmpaqueIntDesc == "-")
                                        {
                                            <text>-</text>
                                        }
                                        else
                                        {

                                            <span class="badge-dark">@item.EmpaqueIntDesc</span>
                                        }
                                    </td>
                                    <td class="col-pz-min">@item.PzMin</td>
                                    <td class="col-pz-def">@item.PzDef</td>
                                    <td class="col-pz-max">@item.PzMax</td>
                                    <td class="col-peso-min">@item.PesoMin.ToString("0.00")</td>
                                    <td class="col-peso-max">@item.PesoMax.ToString("0.00")</td>

                                    <td class="col-emp-ext col-ext" data-val="@item.EmpaqueExt">
                                        @if (string.IsNullOrEmpty(item.EmpaqueExtDesc) || item.EmpaqueExtDesc == "-")
                                        {
                                            <text>-</text>
                                        }
                                        else
                                        {

                                            <span class="badge-dark">@item.EmpaqueExtDesc</span>
                                        }
                                    </td>
                                    <td class="col-bs-min col-ext">@(item.BolsaMin)</td>
                                    <td class="col-bs-def col-ext">@(item.BolsaDef)</td>
                                    <td class="col-bs-max col-ext">@(item.BolsaMax)</td>
                                    <td class="col-peso-ext-min col-ext">@(item.PesoExtMin.ToString("0.00"))</td>
                                    <td class="col-peso-ext-max col-ext">@(item.PesoExtMax.ToString("0.00"))</td>

                                    <td class="col-seguridad" style="white-space: nowrap;">
                                        <button class="pm-btn pm-btn-secondary" onclick="verHistorial('@item.Sku')" style="margin-left: 4px;">Historial</button>
                                        @if (puedeEscribir)
                                        {
                                            <button class="pm-btn pm-btn-secondary" onclick="seleccionarFilaRapida('@item.Sku')">Editar</button>
                                        }
                                        @if (puedeEliminar)
                                        {
                                            <button class="pm-btn pm-btn-danger" style="margin-left: 4px;" onclick="abrirModalEliminar('@item.Sku', '@item.EmpaqueInt', '@item.EmpaqueExt', '@descIntSafe', '@descExtSafe')">Eliminar</button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="workspace panel-derecho">
        <div class="section flex-fill">
            <div class="section-title" id="titulo-editor"> Alta, Baja y Actualizaciones </div>
            <div class="editor-body">

                <div id="info-objetivo">
                    <label style="font-size: 11px; color: #5c1a1a; font-weight: bold;">Identificador de Artículo:</label>
                    <textarea id="txtArticulosSel" class="form-control" disabled style="background: #e9ecef !important; margin-bottom: 5px;" rows="2">Seleccione un registro</textarea>
                    <div id="divAltaNueva" style="display: none; grid-template-columns: 1fr 2fr; gap: 8px; margin-bottom: 5px;">
                        <input type="text" id="inpNuevoSku" class="form-control" placeholder="Escriba SKU...">
                        <input type="text" id="inpNuevaDesc" class="form-control" placeholder="Descripción del artículo...">
                    </div>
                </div>

                <div class="form-section-title">1. Empaque Interno (Bolsa)</div>
                <div class="filter-group">
                    <label>Tipo de Bolsa</label>
                    <select id="selEmpaqueInt" class="form-select">
                        <option value="">SELECCIONE EMPAQUE</option>
                        @if (ViewBag.EmpaquesInternos != null)
                        {
                            foreach (var emp in ViewBag.EmpaquesInternos)
                            {
                                <option value="@emp.Id">@emp.Descripcion</option>
                            }
                        }
                    </select>
                </div>

                <div class="row-inputs">
                    <div class="filter-group"><label>Pzas Mínimas</label><input type="number" id="inpPzMin" class="form-control" placeholder="0"></div>
                    <div class="filter-group"><label>Pzas Default</label><input type="number" id="inpPzDef" class="form-control" placeholder="0"></div>
                    <div class="filter-group"><label>Pzas Máximas</label><input type="number" id="inpPzMax" class="form-control" placeholder="0"></div>
                </div>

                <div class="row-inputs-2">
                    <div class="filter-group"><label>Peso Mínimo</label><input type="number" id="inpPesoMin" class="form-control" step="0.01" placeholder="0.00"></div>
                    <div class="filter-group"><label>Peso Máximo</label><input type="number" id="inpPesoMax" class="form-control" step="0.01" placeholder="0.00"></div>
                </div>

                <div class="form-section-title">2. Empaque Externo (Caja/Carro)</div>
                <div class="filter-group">
                    <label>Tipo de Contenedor</label>
                    <select id="selEmpaqueExt" class="form-select">
                        <option value="">SELECCIONE EMPAQUE</option>
                        @if (ViewBag.EmpaquesExternos != null)
                        {
                            foreach (var emp in ViewBag.EmpaquesExternos)
                            {
                                <option value="@emp.Id">@emp.Descripcion</option>
                            }
                        }
                    </select>
                </div>

                <div class="row-inputs">
                    <div class="filter-group"><label>Bolsas Mínimas</label><input type="number" id="inpBolsaMin" class="form-control" placeholder="0"></div>
                    <div class="filter-group"><label>Bolsas Default</label><input type="number" id="inpBolsaDef" class="form-control" placeholder="0"></div>
                    <div class="filter-group"><label>Bolsas Máximas</label><input type="number" id="inpBolsaMax" class="form-control" placeholder="0"></div>
                </div>

                <div class="row-inputs-2">
                    <div class="filter-group"><label>Peso Mínimo</label><input type="number" id="inpPesoExtMin" class="form-control" step="0.01" placeholder="0.00"></div>
                    <div class="filter-group"><label>Peso Máximo</label><input type="number" id="inpPesoExtMax" class="form-control" step="0.01" placeholder="0.00"></div>
                </div>
            </div>

            <div class="editor-footer">
                @if (puedeEscribir)
                {
                    <button class="pm-btn pm-btn-success" id="btnGuardar" style="flex: 1;" onclick="guardarEmpaque()">Guardar / Actualizar</button>
                }
                @if (puedeEliminar)
                {
                    <button class="pm-btn pm-btn-danger" id="btnEliminarLateral" style="flex: 1;" onclick="eliminarPanelDerecho()">Eliminar</button>
                }
                <button class="pm-btn pm-btn-secondary" style="flex: 1;" onclick="limpiarEditor()">Cancelar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEliminarEmpaque" tabindex="-1" aria-hidden="true">
