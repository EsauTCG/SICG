@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Planeación Ejecutiva de Inventario";
}

<style>
    :root {
      --bg: #f0dede;
      --panel: #f8eeee;
      --panel-2: #f1dede;
      --line: #c79d9d;
      --line-dark: #8f4c4c;
      --text: #3b1717;
      --muted: #6a3a3a;
      --white: #ffffff;
      --brand: #8B0000;

      --vino-1: #5c0000;
      --vino-2: #7a0000;
      --vino-3: #980000;
      --vino-4: #b30000;

      --bajo-bg: #fde2e2;
      --bajo-text: #b00000;

      --min-bg: #fff4cc;
      --min-text: #7a5a00;

      --ok-bg: #dff3e2;
      --ok-text: #2f6b1f;

      --sobre-bg: #eadcff;
      --sobre-text: #5b3fa3;

      --sin-bg: #eeeeee;
      --sin-text: #555555;

      --shadow: 0 1px 0 rgba(255,255,255,.55) inset;
    }

    .minmax-layout2-root,
    .minmax-layout2-root * {
      box-sizing: border-box;
    }

    .minmax-layout2-root {
      width: 100%;
      height: calc(100vh - var(--layout2-offset, 72px));
      min-height: 620px;
      margin: 0;
      overflow: hidden;
      font-family: Tahoma, Verdana, Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    @@supports (height: 100dvh) {
      .minmax-layout2-root {
        height: calc(100dvh - var(--layout2-offset, 72px));
      }
    }

    .app {
      width: 100%;
      height: 100%;
      min-height: 0;
      padding: 0;
      background: var(--bg);
      overflow: hidden;
    }

    .window {
      width: 100%;
      height: 100%;
      border: 0;
      background: var(--panel);
      box-shadow: none;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }

    .titlebar {
      padding: 8px 12px;
      background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
      color: #fff;
      font-weight: 800;
      font-size: 14px;
      border-bottom: 1px solid #5c0000;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .titlebar small {
      font-size: 11px;
      opacity: .92;
      font-weight: 600;
    }

    .content {
      flex: 1;
      min-height: 0;
      padding: 8px;
      background: var(--bg);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      gap: 8px;
    }

    .section {
      border: 1px solid var(--line);
      background: #fffafa;
      margin-bottom: 0;
      box-shadow: var(--shadow);
    }

    .detalle-section {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
    }

    .section-title {
      padding: 6px 8px;
      font-size: 12px;
      font-weight: bold;
      color: #fff;
      background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
      border-bottom: 1px solid #6b1f1f;
    }

    .filters {
      display: grid;
      grid-template-columns: minmax(250px, 1.2fr) 180px 210px auto auto auto;
      gap: 8px;
      padding: 10px;
      background: var(--panel-2);
      align-items: end;
    }

    .filter-group label {
      display: block;
      color: #5c1a1a;
      font-size: 12px;
      margin-bottom: 4px;
      font-weight: bold;
    }

    input,
    select {
      height: 28px !important;
      padding: 3px 6px !important;
      border: 1px solid #b48787 !important;
      background: #fffdfd !important;
      font-family: inherit !important;
      font-size: 12px !important;
      width: 100%;
      border-radius: 0 !important;
      box-shadow: none !important;
      color: #421414 !important;
    }

    input:focus,
    select:focus {
      outline: 2px solid rgba(139, 0, 0, .22);
      border-color: #8b0000 !important;
    }

    button {
      height: 28px;
      padding: 0 10px;
      border: 1px solid #9a5a5a;
      background: linear-gradient(#fffefe, #ecd7d7);
      font-size: 12px;
      font-weight: 700;
      box-shadow: var(--shadow);
      cursor: pointer;
      color: #4d1818;
      white-space: nowrap;
      font-family: inherit;
    }

    button.primary {
      color: #fff;
      border-color: #7f0a0a;
      background: linear-gradient(180deg, #b40000 0%, #8f0000 55%, #6e0000 100%);
    }

    button:hover {
      filter: brightness(0.98);
    }

    .kpis {
      display: grid;
      grid-template-columns: repeat(5, minmax(150px, 1fr));
      gap: 8px;
      padding: 10px;
      background: #fffafa;
    }

    .kpi {
      border: 1px solid #d8bcbc;
      background: #fffafa;
      padding: 8px 10px;
      box-shadow: var(--shadow);
    }

    .kpi span {
      display: block;
      font-size: 11px;
      color: #7a0000;
      font-weight: 800;
      margin-bottom: 5px;
      text-transform: uppercase;
    }

    .kpi strong {
      font-size: 22px;
      color: #4a1111;
    }

    .kpi.bajo strong {
      color: var(--bajo-text);
    }

    .kpi.ok strong {
      color: var(--ok-text);
    }

    .table-wrap {
      flex: 1;
      min-height: 220px;
      overflow: auto;
      max-height: none;
      background: #fffafa;
      width: 100%;
      position: relative;
      border-top: 1px solid #d9b8b8;
    }

    table {
      width: max-content;
      min-width: 100%;
      border-collapse: separate !important;
      border-spacing: 0 !important;
      font-size: 12px;
      background: #fffafa;
    }

    thead th {
      position: sticky;
      top: 0;
      z-index: 20;
      background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
      color: #fff !important;
      border-top: 1px solid #c46a6a;
      border-right: 1px solid #8e3b3b;
      border-bottom: 1px solid #5c0000;
      padding: 6px 5px;
      text-align: left;
      white-space: nowrap;
      font-size: 12px;
      line-height: 1.2;
      box-shadow: 0 2px 0 #6f1d1d;
    }

    tbody td {
      background: #fffafa;
      border-right: 1px solid #d8bcbc;
      border-bottom: 1px solid #d8bcbc;
      padding: 5px;
      white-space: nowrap;
      vertical-align: middle;
      font-size: 12px;
      overflow: hidden;
      text-overflow: ellipsis;
      line-height: 1.2;
      color: #111111;
    }

    tbody tr:nth-child(even) td {
      background: #f9eded;
    }

    tbody tr:hover td {
      background: #f4dddd;
    }

    th:first-child,
    td:first-child {
      border-left: 1px solid #d8bcbc;
    }

    .sticky-master {
      position: sticky;
      left: 0;
      z-index: 12;
      min-width: 120px;
      width: 120px;
    }

    .sticky-sku {
      position: sticky;
      left: 120px;
      z-index: 12;
      min-width: 80px;
      width: 80px;
      font-weight: 800;
    }

    thead .sticky-master,
    thead .sticky-sku {
      z-index: 25;
    }

    tbody .sticky-master,
    tbody .sticky-sku {
      background: inherit;
    }

    .producto {
      min-width: 300px;
      max-width: 360px;
    }

    .num {
      text-align: right !important;
      font-variant-numeric: tabular-nums;
    }

    .actual-input {
      width: 95px;
      text-align: right;
      font-weight: 700;
      background: #f7f1f1 !important;
      color: #2f1515 !important;
    }

    .actual-input[readonly] {
      cursor: default;
    }

    .badge {
      display: inline-block;
      min-width: 130px;
      text-align: center;
      padding: 4px 8px;
      border: 1px solid transparent;
      font-size: 11px;
      font-weight: 800;
      border-radius: 2px;
      line-height: 1.2;
      white-space: nowrap;
    }

    .status-bajo {
      background: var(--bajo-bg);
      border-color: #d9534f;
      color: var(--bajo-text);
    }

    .status-min {
      background: var(--min-bg);
      border-color: #d6b656;
      color: var(--min-text);
    }

    .status-ok {
      background: var(--ok-bg);
      border-color: #6aa84f;
      color: var(--ok-text);
    }

    .status-sobre {
      background: var(--sobre-bg);
      border-color: #8e7cc3;
      color: var(--sobre-text);
    }

    .status-sin {
      background: var(--sin-bg);
      border-color: #bbbbbb;
      color: var(--sin-text);
    }

    .bar-wrap {
      width: 120px;
      height: 14px;
      background: #f4eeee;
      border: 1px solid #d8bcbc;
      overflow: hidden;
      position: relative;
    }

    .bar-fill {
      height: 100%;
      width: 0%;
      transition: width .2s;
    }

    .fill-bajo {
      background: #dc2626;
    }

    .fill-min {
      background: #f59e0b;
    }

    .fill-ok {
      background: #16a34a;
    }

    .fill-sobre {
      background: #7c3aed;
    }

    .fill-sin {
      background: #999999;
    }

    .charts {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 8px;
      padding: 8px;
      background: #fffafa;
    }

    .chart-card {
      border: 1px solid #d8bcbc;
      background: #fffafa;
      padding: 8px;
      min-height: 180px;
    }

    .chart-card h3 {
      margin: 0 0 10px 0;
      font-size: 12px;
      color: #4a1111;
      text-transform: uppercase;
    }

    .sem-row {
      display: grid;
      grid-template-columns: 150px 1fr 45px;
      gap: 8px;
      align-items: center;
      margin-bottom: 8px;
      font-size: 12px;
    }

    .sem-bar {
      height: 20px;
      background: #f4eeee;
      border: 1px solid #d8bcbc;
      overflow: hidden;
    }

    .sem-fill {
      height: 100%;
      min-width: 3px;
    }

    .top-list {
      display: grid;
      gap: 7px;
    }

    .top-item {
      display: grid;
      grid-template-columns: 105px 1fr 90px;
      gap: 8px;
      align-items: center;
      font-size: 11px;
    }

    .top-name {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .footer-note {
      flex: 0 0 auto;
      padding: 7px 10px;
      font-size: 11px;
      color: #4a1a1a;
      border-top: 1px solid #b88c8c;
      background: linear-gradient(#f6e9e9, #ead5d5);
      display: flex;
      justify-content: space-between;
      gap: 8px;
      flex-wrap: wrap;
    }

    @@media (max-width: 1100px) {
      .filters {
        grid-template-columns: 1fr 1fr;
      }

      .kpis {
        grid-template-columns: repeat(2, 1fr);
      }

      .charts {
        grid-template-columns: 1fr;
      }
    }

    @@media (max-width: 650px) {
      .minmax-layout2-root {
        height: auto;
        min-height: calc(100vh - var(--layout2-offset, 72px));
        overflow: visible;
      }

      .app {
        height: auto;
        min-height: calc(100vh - var(--layout2-offset, 72px));
        overflow: visible;
      }

      .filters,
      .kpis {
        grid-template-columns: 1fr;
      }

      .sticky-master,
      .sticky-sku {
        position: static;
      }

      table {
        min-width: 1100px;
      }
    }
  </style>

<div class="minmax-layout2-root">
<div class="app">
    <div class="window">
      <div class="titlebar">
        <div>Indicador de Inventario Mínimos y Máximos</div>
        <small>Inventario real desde SIGO · Semáforo por SKU</small>
      </div>

      <div class="content">

        <div class="section">
          <div class="section-title">Filtros</div>
          <div class="filters">
            <div class="filter-group">
              <label>Buscar SKU / Producto / Master</label>
              <input type="text" id="buscarInput" placeholder="Ej. N108, costilla, pulpa..." oninput="renderizar()" />
            </div>

            <div class="filter-group">
              <label>Master</label>
              <select id="masterSelect" onchange="renderizar()">
                <option value="">Todos</option>
              </select>
            </div>

            <div class="filter-group">
              <label>Estatus</label>
              <select id="estatusSelect" onchange="renderizar()">
                <option value="">Todos</option>
                <option value="BAJO">Bajo mínimo</option>
                <option value="MIN">Entre mínimo e ideal</option>
                <option value="OK">Dentro de rango</option>
                <option value="SOBRE">Sobre máximo</option>
                <option value="SIN">Sin parámetro</option>
              </select>
            </div>

            <button class="primary" type="button" onclick="cargarInventarioReal()">Actualizar inventario real</button>
            <button type="button" onclick="exportarCSV()">Exportar CSV</button>
            <button type="button" onclick="toggleFullscreen()">Pantalla completa</button>
          </div>
        </div>

        <div class="section">
          <div class="section-title">Resumen ejecutivo</div>
          <div class="kpis">
            <div class="kpi">
              <span>SKUs filtrados</span>
              <strong id="kpiSkus">0</strong>
            </div>
            <div class="kpi bajo">
              <span>Bajo mínimo</span>
              <strong id="kpiBajo">0</strong>
            </div>
            <div class="kpi ok">
              <span>Dentro de rango</span>
              <strong id="kpiOk">0</strong>
            </div>
            <div class="kpi">
              <span>Sobre máximo</span>
              <strong id="kpiSobre">0</strong>
            </div>
            <div class="kpi">
              <span>Inventario actual</span>
              <strong id="kpiActual">0</strong>
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-title">Semáforo de inventario</div>
          <div class="charts">
            <div class="chart-card">
              <h3>Distribución por estatus</h3>
              <div id="semaforoChart"></div>
            </div>

            <div class="chart-card">
              <h3>Top 20 por máximo permitido</h3>
              <div id="topChart" class="top-list"></div>
            </div>
          </div>
        </div>

        <div class="section detalle-section">
          <div class="section-title">Detalle por SKU</div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th class="sticky-master">Master</th>
                  <th class="sticky-sku">SKU</th>
                  <th class="producto">Producto</th>
                  <th class="num">Total base</th>
                  <th class="num">Inventario actual</th>
                  <th class="num">Mínimo</th>
                  <th class="num">Ideal</th>
                  <th class="num">Máximo</th>
                  <th class="num">% Máx</th>
                  <th class="num">Días actual</th>
                  <th class="num">Días inv. máx</th>
                  <th>Indicador</th>
                </tr>
              </thead>
              <tbody id="tablaBody"></tbody>
            </table>
          </div>
        </div>

      </div>

      <div class="footer-note">
        <div>Regla: Inventario actual &lt; mínimo = bajo mínimo; entre mínimo e ideal = alerta; ideal a máximo = dentro de rango; arriba de máximo = sobre inventario.</div>
        <div id="fuenteDatos">Fuente base: INDICADOR DE INVENTARIO MIN-MAX (2).xlsx · Inventario actual: SIGO</div>
      </div>
    </div>
  </div>

