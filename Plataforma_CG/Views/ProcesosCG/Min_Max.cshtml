<script>
    (() => {
        "use strict";

        const URLS = {
            datos: '@Url.Action("InventarioMinMaxDatos", "ProcesosCg")',
            catalogo: '@Url.Action("InventarioMinMaxCatalogo", "ProcesosCg")',
            guardarClasificacion: '@Url.Action("GuardarInventarioMinMaxClasificacion", "ProcesosCg")',
            guardarSku: '@Url.Action("GuardarInventarioMinMaxSkuClasificacion", "ProcesosCg")'
        };

        const LABELS = {
            BAJO: "Bajo mínimo",
            MIN: "Entre mínimo e ideal",
            OK: "Dentro de rango",
            SOBRE: "Sobre máximo",
            NOPROD: "No producir",
            SIN: "Sin configuración/base"
        };

        const STATUS_ORDER = ["BAJO", "MIN", "OK", "SOBRE", "NOPROD", "SIN"];

        let datos = [];
        let clasificaciones = [];
        let catalogoSkus = [];
        let cargando = false;

        let ordenTabla = {
            campo: "clasificacion",
            direccion: "asc"
        };

        const el = id => document.getElementById(id);

        const tablaBody = el("tablaBody");
        const buscarInput = el("buscarInput");
        const mesInput = el("mesInput");
        const clasificacionSelect = el("clasificacionSelect");
        const masterSelect = el("masterSelect");
        const estatusSelect = el("estatusSelect");
        const btnActualizar = el("btnActualizar");
        const btnCatalogo = el("btnCatalogo");
        const catalogoModal = el("catalogoModal");

        function normalizarNumero(value) {
            const n = Number(value);
            return Number.isFinite(n) ? n : 0;
        }

        function normalizarTexto(value) {
            return String(value ?? "").trim();
        }

        function getVal(obj, ...keys) {
            for (const key of keys) {
                if (obj && obj[key] !== undefined && obj[key] !== null) {
                    return obj[key];
                }
            }
            return null;
        }

        function esc(value) {
            return normalizarTexto(value)
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function formatoNumero(value, decimals = 0) {
            return normalizarNumero(value).toLocaleString("es-MX", {
                minimumFractionDigits: decimals,
                maximumFractionDigits: decimals
            });
        }

        function formatoFecha(value) {
            if (!value) return "N/D";

            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return normalizarTexto(value);

            return date.toLocaleString("es-MX", {
                dateStyle: "medium",
                timeStyle: "short"
            });
        }

        function mesActual() {
            const now = new Date();
            const month = String(now.getMonth() + 1).padStart(2, "0");
            return `${now.getFullYear()}-${month}`;
        }

        function normalizarFila(row) {
            return {
                clasificacion: normalizarTexto(
                    getVal(row, "clasificacion", "Clasificacion")
                ).toUpperCase(),

                clasificacionOrden: normalizarNumero(
                    getVal(row, "clasificacionOrden", "ClasificacionOrden")
                ),

                master: normalizarTexto(
                    getVal(row, "master", "Master", "masterProducto", "MasterProducto")
                ) || "SIN MASTER",

                sku: normalizarTexto(
                    getVal(row, "sku", "Sku", "SKU")
                ).toUpperCase(),

                producto: normalizarTexto(
                    getVal(row, "producto", "Producto")
                ),

                kgProduccionMes: normalizarNumero(
                    getVal(row, "kgProduccionMes", "KgProduccionMes")
                ),

                kgInventarioInicial: normalizarNumero(
                    getVal(row, "kgInventarioInicial", "KgInventarioInicial")
                ),

                kgBaseCalculo: normalizarNumero(
                    getVal(row, "kgBaseCalculo", "KgBaseCalculo")
                ),

                kgActual: normalizarNumero(
                    getVal(row, "kgActual", "KgActual")
                ),

                cajasActuales: normalizarNumero(
                    getVal(row, "cajasActuales", "CajasActuales")
                ),

                lotes: normalizarNumero(
                    getVal(row, "lotes", "Lotes")
                ),

                diasMinimo: normalizarNumero(
                    getVal(row, "diasMinimo", "DiasMinimo")
                ),

                diasIdeal: normalizarNumero(
                    getVal(row, "diasIdeal", "DiasIdeal")
                ),

                diasMaximo: normalizarNumero(
                    getVal(row, "diasMaximo", "DiasMaximo")
                ),

                minimo: normalizarNumero(
                    getVal(row, "minimo", "Minimo")
                ),

                ideal: normalizarNumero(
                    getVal(row, "ideal", "Ideal")
                ),

                maximo: normalizarNumero(
                    getVal(row, "maximo", "Maximo")
                ),

                gapIdeal: normalizarNumero(
                    getVal(row, "gapIdeal", "GapIdeal")
                ),

                consumoDiario: normalizarNumero(
                    getVal(row, "consumoDiario", "ConsumoDiario")
                ),

                diasActual: normalizarNumero(
                    getVal(row, "diasActual", "DiasActual")
                ),

                porcentajeMaximo: normalizarNumero(
                    getVal(row, "porcentajeMaximo", "PorcentajeMaximo")
                ),

                estatus: normalizarTexto(
                    getVal(row, "estatus", "Estatus")
                ).toUpperCase() || "SIN",

                fechaActualizacion: getVal(
                    row,
                    "fechaActualizacion",
                    "FechaActualizacion"
                ),

                fechaInventarioInicial: getVal(
                    row,
                    "fechaInventarioInicial",
                    "FechaInventarioInicial"
                )
            };
        }

        async function leerJson(response) {
            const raw = await response.text();
            let data = null;

            try {
                data = raw ? JSON.parse(raw) : null;
            } catch {
                data = null;
            }

            if (!response.ok) {
                const mensajeBase =
                    data?.msg ||
                    data?.message ||
                    `HTTP ${response.status}`;

                const detalle = [
                    data?.error,
                    data?.inner
                ]
                    .filter(Boolean)
                    .join(" | ");

                throw new Error(
                    detalle
                        ? `${mensajeBase} Detalle: ${detalle}`
                        : (mensajeBase || raw || `HTTP ${response.status}`)
                );
            }

            return data;
        }

        async function postJson(url, payload) {
            const response = await fetch(url, {
                method: "POST",
                cache: "no-store",
                headers: {
                    "Content-Type": "application/json",
                    "Accept": "application/json"
                },
                body: JSON.stringify(payload)
            });

            const data = await leerJson(response);

            if (data?.ok === false) {
                throw new Error(data.msg || data.error || "La operación no se completó.");
            }

            return data;
        }

        function setCargando(value) {
            cargando = value;
            btnActualizar.disabled = value;
            btnActualizar.innerHTML = value
                ? `<span class="spinner-border spinner-border-sm"></span> Consultando`
                : `<i class="fa-solid fa-rotate"></i> Actualizar`;
        }

        function renderLoading(message) {
            tablaBody.innerHTML = `
                <tr>
                    <td colspan="15" class="mm-loading">
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        ${esc(message)}
                    </td>
                </tr>`;
        }

        async function cargarDatos() {
            if (cargando) return;

            const mes = mesInput.value || mesActual();
            const mesFecha = `${mes}-01`;

            setCargando(true);
            renderLoading("Consultando planeación, inventario inicial y existencias actuales…");
            el("fuenteDatos").textContent = "Consultando fuentes de información…";

            try {
                const url =
                    `${URLS.datos}?mes=${encodeURIComponent(mesFecha)}&_=${Date.now()}`;

                const response = await fetch(url, {
                    method: "GET",
                    cache: "no-store",
                    headers: { "Accept": "application/json" }
                });

                const data = await leerJson(response);

                if (data?.ok === false) {
                    throw new Error(data.msg || data.error || "No se pudo consultar.");
                }

                const rows = Array.isArray(data?.data) ? data.data : [];
                datos = rows
                    .map(normalizarFila)
                    .filter(x => x.sku);

                llenarFiltros();
                renderizar();

                el("mmUpdatedText").textContent =
                    `SIGO: ${formatoFecha(data?.fechaActualizacion)} · ` +
                    `Inventario inicial: ${formatoFecha(data?.fechaInventarioInicial)}`;

                el("fuenteDatos").textContent =
                    `${data?.criterio || "Base mensual dinámica."} ` +
                    `Registros: ${formatoNumero(datos.length)}.`;
            } catch (error) {
                console.error(error);
                datos = [];
                renderizar();

                tablaBody.innerHTML = `
                    <tr>
                        <td colspan="15" class="mm-loading" style="color:#b42318 !important">
                            <i class="fa-solid fa-triangle-exclamation me-1"></i>
                            ${esc(error?.message || "No se pudo cargar la información.")}
                        </td>
                    </tr>`;

                el("mmUpdatedText").textContent = "Error de consulta";
                el("fuenteDatos").textContent =
                    "No se muestran valores simulados. Revisa la migración SQL y el endpoint InventarioMinMaxDatos.";
            } finally {
                setCargando(false);
            }
        }

        function llenarFiltros() {
            const clasActual = clasificacionSelect.value;
            const masterActual = masterSelect.value;

            const clasificacionesDisponibles = [
                ...new Set(datos.map(x => x.clasificacion).filter(Boolean))
            ].sort();

            const masters = [
                ...new Set(datos.map(x => x.master).filter(Boolean))
            ].sort();

            clasificacionSelect.innerHTML =
                `<option value="">Todas</option>` +
                clasificacionesDisponibles
                    .map(x => `<option value="${esc(x)}">${esc(x)}</option>`)
                    .join("");

            masterSelect.innerHTML =
                `<option value="">Todos</option>` +
                masters
                    .map(x => `<option value="${esc(x)}">${esc(x)}</option>`)
                    .join("");

            if (clasificacionesDisponibles.includes(clasActual)) {
                clasificacionSelect.value = clasActual;
            }

            if (masters.includes(masterActual)) {
                masterSelect.value = masterActual;
            }
        }

        function obtenerFiltrados() {
            const buscar = buscarInput.value.trim().toLowerCase();
            const clasificacion = clasificacionSelect.value;
            const master = masterSelect.value;
            const estatus = estatusSelect.value;

            return datos.filter(item => {
                const texto =
                    `${item.clasificacion} ${item.master} ${item.sku} ${item.producto}`
                    .toLowerCase();

                if (buscar && !texto.includes(buscar)) return false;
                if (clasificacion && item.clasificacion !== clasificacion) return false;
                if (master && item.master !== master) return false;
                if (estatus && item.estatus !== estatus) return false;

                return true;
            });
        }

        function esNumeroOrden(campo) {
            return [
                "kgProduccionMes",
                "kgInventarioInicial",
                "kgBaseCalculo",
                "kgActual",
                "minimo",
                "ideal",
                "maximo",
                "gapIdeal",
                "diasActual",
                "porcentajeMaximo"
            ].includes(campo);
        }

        function ordenarLista(lista) {
            const campo = ordenTabla.campo;
            const factor = ordenTabla.direccion === "desc" ? -1 : 1;

            return [...lista].sort((a, b) => {
                let resultado = 0;

                if (esNumeroOrden(campo)) {
                    const valorA = normalizarNumero(a[campo]);
                    const valorB = normalizarNumero(b[campo]);
                    resultado = valorA - valorB;
                } else {
                    const valorA = normalizarTexto(a[campo]).toLocaleUpperCase("es-MX");
                    const valorB = normalizarTexto(b[campo]).toLocaleUpperCase("es-MX");
                    resultado = valorA.localeCompare(valorB, "es-MX", {
                        numeric: true,
                        sensitivity: "base"
                    });
                }

                if (resultado === 0 && campo !== "sku") {
                    resultado = normalizarTexto(a.sku).localeCompare(
                        normalizarTexto(b.sku),
                        "es-MX",
                        { numeric: true, sensitivity: "base" }
                    );
                }

                return resultado * factor;
            });
        }

        function actualizarIndicadoresOrden() {
            document.querySelectorAll("#mmTableHeader [data-sort]").forEach(th => {
                const indicador = th.querySelector(".mm-sort-indicator");
                const activo = th.dataset.sort === ordenTabla.campo;

                th.classList.toggle("mm-sort-active", activo);
                th.setAttribute("aria-sort", activo
                    ? (ordenTabla.direccion === "asc" ? "ascending" : "descending")
                    : "none");

                if (indicador) {
                    indicador.textContent = activo
                        ? (ordenTabla.direccion === "asc" ? "▲" : "▼")
                        : "◇";
                }
            });
        }

        function cambiarOrden(campo) {
            if (!campo) return;

            if (ordenTabla.campo === campo) {
                ordenTabla.direccion = ordenTabla.direccion === "asc" ? "desc" : "asc";
            } else {
                ordenTabla.campo = campo;
                ordenTabla.direccion = "asc";
            }

            renderizar();
        }

        function renderizar() {
            const lista = ordenarLista(obtenerFiltrados());

            actualizarIndicadoresOrden();
            renderTabla(lista);
            renderKpis(lista);
            renderSemaforo(lista);
            renderTop(lista);

            el("mmResultCount").textContent =
                `${formatoNumero(lista.length)} registro${lista.length === 1 ? "" : "s"}`;
        }

        function renderTabla(lista) {
            if (!lista.length) {
                tablaBody.innerHTML = `
                    <tr>
                        <td colspan="15" class="mm-loading">
                            No hay registros para los filtros seleccionados.
                        </td>
                    </tr>`;
                return;
            }

            tablaBody.innerHTML = lista.map(item => {
                const pct = Math.min(Math.max(item.porcentajeMaximo, 0), 120);
                const gapClass = item.gapIdeal < 0
                    ? "mm-gap-negative"
                    : item.gapIdeal > 0
                        ? "mm-gap-positive"
                        : "";

                const clasificacion = item.clasificacion || "SIN ASIGNAR";
                const tooltip =
                    `Días: ${formatoNumero(item.diasMinimo, 2)} / ` +
                    `${formatoNumero(item.diasIdeal, 2)} / ` +
                    `${formatoNumero(item.diasMaximo, 2)} · ` +
                    `Cajas: ${formatoNumero(item.cajasActuales)} · ` +
                    `Lotes: ${formatoNumero(item.lotes)}`;

                return `
                    <tr>
                        <td class="sticky-clas" title="${esc(tooltip)}">
                            <strong>${esc(clasificacion)}</strong>
                        </td>

                        <td class="sticky-master">
                            ${esc(item.master)}
                        </td>

                        <td class="sticky-sku">
                            ${esc(item.sku)}
                        </td>

                        <td class="product" title="${esc(item.producto)}">
                            ${esc(item.producto || "Sin descripción")}
                        </td>

                        <td class="num">${formatoNumero(item.kgProduccionMes, 0)}</td>
                        <td class="num">${formatoNumero(item.kgInventarioInicial, 0)}</td>
                        <td class="num"><strong>${formatoNumero(item.kgBaseCalculo, 0)}</strong></td>
                        <td class="num"><strong>${formatoNumero(item.kgActual, 0)}</strong></td>
                        <td class="num">${formatoNumero(item.minimo, 0)}</td>
                        <td class="num">${formatoNumero(item.ideal, 0)}</td>
                        <td class="num">${formatoNumero(item.maximo, 0)}</td>

                        <td class="num ${gapClass}">
                            ${formatoNumero(item.gapIdeal, 0)}
                        </td>

                        <td class="num">
                            ${formatoNumero(item.diasActual, 1)}
                        </td>

                        <td class="num">
                            <div class="mm-bar"
                                 title="${formatoNumero(item.porcentajeMaximo, 1)}% del máximo">
                                <div class="mm-bar-fill fill-${esc(item.estatus)}"
                                     style="width:${pct}%"></div>
                            </div>
                            <div style="margin-top:2px">
                                ${formatoNumero(item.porcentajeMaximo, 1)}%
                            </div>
                        </td>

                        <td>
                            <span class="mm-badge status-${esc(item.estatus)}">
                                ${esc(LABELS[item.estatus] || item.estatus)}
                            </span>
                        </td>
                    </tr>`;
            }).join("");
        }

        function renderKpis(lista) {
            const counts = {
                BAJO: 0,
                MIN: 0,
                OK: 0,
                SOBRE: 0,
                NOPROD: 0,
                SIN: 0
            };

            let actual = 0;

            lista.forEach(item => {
                actual += item.kgActual;
                counts[item.estatus] = (counts[item.estatus] || 0) + 1;
            });

            el("kpiSkus").textContent = formatoNumero(lista.length);
            el("kpiBajo").textContent = formatoNumero(counts.BAJO);
            el("kpiMin").textContent = formatoNumero(counts.MIN);
            el("kpiOk").textContent = formatoNumero(counts.OK);
            el("kpiSobre").textContent = formatoNumero(counts.SOBRE);
            el("kpiSin").textContent =
                formatoNumero(counts.SIN + counts.NOPROD);
            el("kpiActual").textContent = `${formatoNumero(actual, 0)} kg`;
        }

        function renderSemaforo(lista) {
            const counts = Object.fromEntries(
                STATUS_ORDER.map(key => [key, 0])
            );

            lista.forEach(item => {
                counts[item.estatus] = (counts[item.estatus] || 0) + 1;
            });

            const max = Math.max(...Object.values(counts), 1);

            el("semaforoChart").innerHTML = STATUS_ORDER.map(key => {
                const width = (counts[key] / max) * 100;

                return `
                    <div class="mm-status-row">
                        <span class="mm-badge status-${key}">
                            ${esc(LABELS[key])}
                        </span>

                        <div class="mm-bar">
                            <div class="mm-bar-fill fill-${key}"
                                 style="width:${width}%"></div>
                        </div>

                        <strong style="text-align:right">
                            ${formatoNumero(counts[key])}
                        </strong>
                    </div>`;
            }).join("");
        }

        function renderTop(lista) {
            const top = [...lista]
                .filter(x => x.ideal > 0)
                .sort((a, b) => Math.abs(b.gapIdeal) - Math.abs(a.gapIdeal))
                .slice(0, 15);

            if (!top.length) {
                el("topChart").innerHTML =
                    `<div style="color:var(--mm-muted);font-size:.72rem">Sin información.</div>`;
                return;
            }

            const max = Math.max(...top.map(x => Math.abs(x.gapIdeal)), 1);

            el("topChart").innerHTML = top.map(item => {
                const width = (Math.abs(item.gapIdeal) / max) * 100;

                return `
                    <div class="mm-top-row">
                        <strong>${esc(item.sku)}</strong>

                        <div>
                            <div class="mm-top-name" title="${esc(item.producto)}">
                                ${esc(item.producto)}
                            </div>

                            <div class="mm-bar" style="margin-top:3px">
                                <div class="mm-bar-fill fill-${esc(item.estatus)}"
                                     style="width:${width}%"></div>
                            </div>
                        </div>

                        <strong class="${item.gapIdeal < 0 ? "mm-gap-negative" : "mm-gap-positive"}"
                                style="text-align:right">
                            ${item.gapIdeal > 0 ? "+" : ""}${formatoNumero(item.gapIdeal, 0)}
                        </strong>
                    </div>`;
            }).join("");
        }

        async function cargarCatalogo() {
            const bodyClas = el("catalogoClasificacionesBody");
            const bodySku = el("catalogoSkuBody");

            bodyClas.innerHTML = `
                <tr><td colspan="6" class="mm-loading">Cargando reglas…</td></tr>`;
            bodySku.innerHTML = `
                <tr><td colspan="4" class="mm-loading">Cargando asignaciones…</td></tr>`;

            const response = await fetch(
                `${URLS.catalogo}?_=${Date.now()}`,
                {
                    method: "GET",
                    cache: "no-store",
                    headers: { "Accept": "application/json" }
                }
            );

            const data = await leerJson(response);

            if (data?.ok === false) {
                throw new Error(data.msg || data.error || "No se pudo consultar el catálogo.");
            }

            clasificaciones = Array.isArray(data?.clasificaciones)
                ? data.clasificaciones.map(x => ({
                    clasificacion: normalizarTexto(
                        getVal(x, "clasificacion", "Clasificacion")
                    ).toUpperCase(),
                    diasMinimo: normalizarNumero(
                        getVal(x, "diasMinimo", "DiasMinimo")
                    ),
                    diasIdeal: normalizarNumero(
                        getVal(x, "diasIdeal", "DiasIdeal")
                    ),
                    diasMaximo: normalizarNumero(
                        getVal(x, "diasMaximo", "DiasMaximo")
                    ),
                    orden: normalizarNumero(
                        getVal(x, "orden", "Orden")
                    ),
                    activo: Boolean(
                        getVal(x, "activo", "Activo")
                    )
                }))
                : [];

            catalogoSkus = Array.isArray(data?.skus)
                ? data.skus.map(x => ({
                    sku: normalizarTexto(
                        getVal(x, "sku", "Sku")
                    ).toUpperCase(),
                    producto: normalizarTexto(
                        getVal(x, "producto", "Producto")
                    ),
                    master: normalizarTexto(
                        getVal(x, "master", "Master")
                    ) || "SIN MASTER",
                    clasificacion: normalizarTexto(
                        getVal(x, "clasificacion", "Clasificacion")
                    ).toUpperCase()
                }))
                : [];

            renderCatalogoClasificaciones();
            renderCatalogoSkus();
        }

        function renderCatalogoClasificaciones() {
            const body = el("catalogoClasificacionesBody");

            if (!clasificaciones.length) {
                body.innerHTML = `
                    <tr><td colspan="6" class="mm-loading">No hay clasificaciones.</td></tr>`;
                return;
            }

            body.innerHTML = clasificaciones.map((item, index) => `
                <tr data-clas-index="${index}">
                    <td>
                        <strong>${esc(item.clasificacion)}</strong>
                    </td>
                    <td>
                        <input data-field="diasMinimo"
                               type="number"
                               min="0"
                               step="0.1"
                               value="${item.diasMinimo}" />
                    </td>
                    <td>
                        <input data-field="diasIdeal"
                               type="number"
                               min="0"
                               step="0.1"
                               value="${item.diasIdeal}" />
                    </td>
                    <td>
                        <input data-field="diasMaximo"
                               type="number"
                               min="0"
                               step="0.1"
                               value="${item.diasMaximo}" />
                    </td>
                    <td>
                        <input data-field="orden"
                               type="number"
                               min="1"
                               step="1"
                               value="${item.orden}" />
                    </td>
                    <td>
                        <button type="button"
                                class="mm-btn primary"
                                data-save-clas="${index}">
                            Guardar
                        </button>
                    </td>
                </tr>`).join("");
        }

        function clasificacionOptions(selected) {
            const options = [
                `<option value="">Sin asignar</option>`,
                ...clasificaciones
                    .filter(x => x.activo)
                    .map(x => `
                        <option value="${esc(x.clasificacion)}"
                                ${x.clasificacion === selected ? "selected" : ""}>
                            ${esc(x.clasificacion)}
                        </option>`)
            ];

            return options.join("");
        }

        function renderCatalogoSkus() {
            const buscar = el("catalogoSkuBuscar").value
                .trim()
                .toLowerCase();

            const rows = catalogoSkus
                .filter(item => {
                    if (!buscar) return true;

                    return `${item.sku} ${item.producto} ${item.master}`
                        .toLowerCase()
                        .includes(buscar);
                })
                .slice(0, 500);

            const body = el("catalogoSkuBody");

            if (!rows.length) {
                body.innerHTML = `
                    <tr><td colspan="4" class="mm-loading">Sin resultados.</td></tr>`;
                return;
            }

            body.innerHTML = rows.map(item => `
                <tr data-sku="${esc(item.sku)}">
                    <td>
                        <strong>${esc(item.sku)}</strong>
                    </td>
                    <td>
                        <div style="font-weight:800">${esc(item.producto || "Sin descripción")}</div>
                        <div style="color:var(--mm-muted);font-size:.64rem">${esc(item.master)}</div>
                    </td>
                    <td>
                        <select data-sku-select="${esc(item.sku)}">
                            ${clasificacionOptions(item.clasificacion)}
                        </select>
                    </td>
                    <td>
                        <button type="button"
                                class="mm-btn"
                                data-save-sku="${esc(item.sku)}">
                            Guardar
                        </button>
                    </td>
                </tr>`).join("");
        }

        async function guardarClasificacion(index, button) {
            const item = clasificaciones[index];
            const row = button.closest("tr");

            if (!item || !row) return;

            const payload = {
                clasificacion: item.clasificacion,
                diasMinimo: normalizarNumero(
                    row.querySelector('[data-field="diasMinimo"]').value
                ),
                diasIdeal: normalizarNumero(
                    row.querySelector('[data-field="diasIdeal"]').value
                ),
                diasMaximo: normalizarNumero(
                    row.querySelector('[data-field="diasMaximo"]').value
                ),
                orden: normalizarNumero(
                    row.querySelector('[data-field="orden"]').value
                ),
                activo: true
            };

            if (
                payload.diasMinimo < 0 ||
                payload.diasIdeal < payload.diasMinimo ||
                payload.diasMaximo < payload.diasIdeal
            ) {
                alert("La regla debe cumplir mínimo ≤ ideal ≤ máximo.");
                return;
            }

            button.disabled = true;
            button.textContent = "Guardando…";

            try {
                await postJson(URLS.guardarClasificacion, payload);
                await cargarCatalogo();
                await cargarDatos();
            } catch (error) {
                alert(error?.message || "No se pudo guardar la clasificación.");
            } finally {
                button.disabled = false;
                button.textContent = "Guardar";
            }
        }

        async function guardarSku(sku, button) {
            const row = button.closest("tr");
            const select = row?.querySelector("[data-sku-select]");

            if (!select) return;

            button.disabled = true;
            button.textContent = "Guardando…";

            try {
                await postJson(
                    URLS.guardarSku,
                    {
                        sku,
                        clasificacion: select.value
                    }
                );

                const item = catalogoSkus.find(x => x.sku === sku);
                if (item) item.clasificacion = select.value;

                await cargarDatos();
            } catch (error) {
                alert(error?.message || "No se pudo guardar el SKU.");
            } finally {
                button.disabled = false;
                button.textContent = "Guardar";
            }
        }

        function abrirCatalogo() {
            catalogoModal.classList.add("show");
            catalogoModal.setAttribute("aria-hidden", "false");
            document.body.style.overflow = "hidden";

            cargarCatalogo().catch(error => {
                console.error(error);
                alert(error?.message || "No se pudo abrir el catálogo.");
            });
        }

        function cerrarCatalogo() {
            catalogoModal.classList.remove("show");
            catalogoModal.setAttribute("aria-hidden", "true");
            document.body.style.overflow = "";
        }

        function exportarCsv() {
            const lista = obtenerFiltrados();

            const headers = [
                "CLASIFICACION",
                "MASTER",
                "SKU",
                "PRODUCTO",
                "PRODUCCION_MES",
                "INVENTARIO_INICIAL",
                "BASE_CALCULO",
                "INVENTARIO_ACTUAL",
                "DIAS_MINIMO",
                "DIAS_IDEAL",
                "DIAS_MAXIMO",
                "MINIMO",
                "IDEAL",
                "MAXIMO",
                "GAP_IDEAL",
                "DIAS_ACTUAL",
                "PORCENTAJE_MAXIMO",
                "INDICADOR"
            ];

            const rows = lista.map(item => [
                item.clasificacion,
                item.master,
                item.sku,
                item.producto,
                item.kgProduccionMes,
                item.kgInventarioInicial,
                item.kgBaseCalculo,
                item.kgActual,
                item.diasMinimo,
                item.diasIdeal,
                item.diasMaximo,
                item.minimo,
                item.ideal,
                item.maximo,
                item.gapIdeal,
                item.diasActual,
                item.porcentajeMaximo,
                LABELS[item.estatus] || item.estatus
            ]);

            const csv = [headers, ...rows]
                .map(row =>
                    row
                        .map(value =>
                            `"${String(value ?? "").replaceAll('"', '""')}"`
                        )
                        .join(",")
                )
                .join("\r\n");

            const blob = new Blob(
                ["\uFEFF" + csv],
                { type: "text/csv;charset=utf-8" }
            );

            const url = URL.createObjectURL(blob);
            const link = document.createElement("a");

            link.href = url;
            link.download =
                `inventario_min_max_${mesInput.value || mesActual()}.csv`;

            document.body.appendChild(link);
            link.click();
            link.remove();
            URL.revokeObjectURL(url);
        }

        const minmaxRoot = document.querySelector(".minmax-root");

        function prepararContenedorLayout() {
            if (!minmaxRoot) return;

            let actual = minmaxRoot.parentElement;
            let profundidad = 0;

            while (actual && actual !== document.body && profundidad < 5) {
                const clases = actual.classList;
                const esContenedorAncho =
                    clases.contains("container") ||
                    clases.contains("container-sm") ||
                    clases.contains("container-md") ||
                    clases.contains("container-lg") ||
                    clases.contains("container-xl") ||
                    clases.contains("container-xxl") ||
                    clases.contains("container-fluid");

                const estilo = window.getComputedStyle(actual);
                const maxWidthLimitado =
                    estilo.maxWidth !== "none" &&
                    Number.parseFloat(estilo.maxWidth) > 0;

                if (esContenedorAncho || maxWidthLimitado) {
                    actual.classList.add("mm-minmax-host");
                }

                /*
                   Solo se limpia la envoltura inmediata o una envoltura que
                   contiene exclusivamente esta vista. Así no se toca el
                   content-wrapper que controla la apertura del sidebar.
                */
                const soloContieneLaVista =
                    actual.children.length === 1 &&
                    actual.contains(minmaxRoot);

                if (profundidad === 0 || soloContieneLaVista) {
                    actual.classList.add("mm-minmax-host-clean");
                }

                if (
                    clases.contains("content-wrapper") ||
                    clases.contains("main-content") ||
                    clases.contains("page-wrapper") ||
                    clases.contains("app-content")
                ) {
                    break;
                }

                actual = actual.parentElement;
                profundidad += 1;
            }
        }

        function actualizarBotonFullscreen() {
            const button = el("btnFullscreen");
            if (!button) return;

            button.innerHTML = document.fullscreenElement
                ? `<i class="fa-solid fa-compress"></i> Salir`
                : `<i class="fa-solid fa-expand"></i> Pantalla`;
        }

        function toggleFullscreen() {
            const target = minmaxRoot || document.documentElement;

            if (!document.fullscreenElement) {
                target.requestFullscreen?.().catch(console.warn);
            } else {
                document.exitFullscreen?.();
            }
        }

        let searchTimer = null;

        buscarInput.addEventListener("input", () => {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(renderizar, 130);
        });

        clasificacionSelect.addEventListener("change", renderizar);
        masterSelect.addEventListener("change", renderizar);
        estatusSelect.addEventListener("change", renderizar);

        const mmTableHeader = el("mmTableHeader");

        mmTableHeader?.addEventListener("click", event => {
            const th = event.target.closest("[data-sort]");
            if (!th) return;
            cambiarOrden(th.dataset.sort);
        });

        mmTableHeader?.addEventListener("keydown", event => {
            if (event.key !== "Enter" && event.key !== " ") return;

            const th = event.target.closest("[data-sort]");
            if (!th) return;

            event.preventDefault();
            cambiarOrden(th.dataset.sort);
        });

        btnActualizar.addEventListener("click", cargarDatos);
        btnCatalogo.addEventListener("click", abrirCatalogo);
        el("btnCerrarCatalogo").addEventListener("click", cerrarCatalogo);
        el("btnCsv").addEventListener("click", exportarCsv);
        el("btnFullscreen").addEventListener("click", toggleFullscreen);

        document.addEventListener("fullscreenchange", actualizarBotonFullscreen);

        el("catalogoSkuBuscar").addEventListener("input", () => {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(renderCatalogoSkus, 130);
        });

        el("catalogoClasificacionesBody").addEventListener("click", event => {
            const button = event.target.closest("[data-save-clas]");
            if (!button) return;

            guardarClasificacion(
                Number(button.getAttribute("data-save-clas")),
                button
            );
        });

        el("catalogoSkuBody").addEventListener("click", event => {
            const button = event.target.closest("[data-save-sku]");
            if (!button) return;

            guardarSku(
                button.getAttribute("data-save-sku"),
                button
            );
        });

        catalogoModal.addEventListener("click", event => {
            if (event.target === catalogoModal) {
                cerrarCatalogo();
            }
        });

        document.addEventListener("keydown", event => {
            if (event.key === "Escape" && catalogoModal.classList.contains("show")) {
                cerrarCatalogo();
            }
        });

        prepararContenedorLayout();
        mesInput.value = mesActual();
        actualizarBotonFullscreen();
        actualizarIndicadoresOrden();
        cargarDatos();
    })();
</script>
