    const CLAVES = {
      BAJO: "Bajo mínimo",
      MIN: "Entre mínimo e ideal",
      OK: "Dentro de rango",
      SOBRE: "Sobre máximo",
      SIN: "Sin parámetro"
    };

    function formatoNumero(valor, decimales = 0) {
      const n = Number(valor || 0);
      return n.toLocaleString("es-MX", {
        minimumFractionDigits: decimales,
        maximumFractionDigits: decimales
      });
    }

    function normalizar(valor) {
      const n = Number(valor);
      return Number.isFinite(n) ? n : 0;
    }

    function getVal(obj, ...keys) {
      for (const k of keys) {
        if (obj && obj[k] !== undefined && obj[k] !== null) return obj[k];
      }
      return null;
    }

    function normalizarSku(valor) {
      return String(valor || "").trim().toUpperCase();
    }

    function setTextoFuente(texto) {
      const el = document.getElementById("fuenteDatos");
      if (el) el.textContent = texto;
    }

    async function cargarInventarioReal() {
      try {
        setTextoFuente("Cargando inventario real desde SIGO...");

        const url = '@Url.Action("InventarioActualMinMax", "ProcesosCg")';

        const resp = await fetch(url, {
          method: "GET",
          cache: "no-store",
          headers: {
            "Accept": "application/json"
          }
        });

        if (!resp.ok) {
          throw new Error("HTTP " + resp.status);
        }

        const json = await resp.json();

        if (!json.ok) {
          throw new Error(json.msg || json.error || "No se pudo consultar inventario real.");
        }

        const rows = Array.isArray(json.data) ? json.data : [];
        const invPorSku = new Map();

        rows.forEach(r => {
          const sku = normalizarSku(getVal(r, "sku", "Sku", "SKU"));
          if (!sku) return;

          const kgActual = normalizar(getVal(r, "kgActual", "KgActual"));
          const cajasActuales = normalizar(getVal(r, "cajasActuales", "CajasActuales"));
          const lotes = normalizar(getVal(r, "lotes", "Lotes"));
          const articulo = getVal(r, "producto", "Producto", "productoNombre", "ProductoNombre") || "";
          const fechaActualizacion = getVal(r, "fechaActualizacion", "FechaActualizacion") || "";

          const actual = invPorSku.get(sku) || {
            sku: sku,
            kgActual: 0,
            cajasActuales: 0,
            lotes: 0,
            articulo: "",
            fechaActualizacion: ""
          };

          actual.kgActual += kgActual;
          actual.cajasActuales += cajasActuales;
          actual.lotes += lotes;

          if (!actual.articulo && articulo) {
            actual.articulo = articulo;
          }

          if (fechaActualizacion) {
            actual.fechaActualizacion = fechaActualizacion;
          }

          invPorSku.set(sku, actual);
        });

        let skusConInventarioReal = 0;

        datos.forEach(item => {
          const sku = normalizarSku(item.sku);
          const real = invPorSku.get(sku);

          if (real) {
            item.actual = real.kgActual;
            item.cajasActuales = real.cajasActuales;
            item.lotes = real.lotes;
            item.fechaActualizacion = real.fechaActualizacion;
            skusConInventarioReal++;

            if (real.articulo) {
              item.producto = real.articulo;
            }
          } else {
            item.actual = 0;
            item.cajasActuales = 0;
            item.lotes = 0;
            item.fechaActualizacion = "";
          }
        });

        llenarMasters();
        renderizar();

        const criterio = json.criterio || "SUM(Kg) agrupado por ProductoCodigo";

        setTextoFuente(
          `Fuente real: InventarioActualMinMax · Registros recibidos: ${formatoNumero(rows.length)} · SKUs cruzados: ${formatoNumero(skusConInventarioReal)} · Inventario actual: ${criterio}`
        );
      } catch (err) {
        console.error(err);
        alert("No se pudo cargar inventario real: " + (err.message || err));
        setTextoFuente("Error al cargar inventario real. Revisa el endpoint InventarioActualMinMax y la consola del navegador.");
      }
    }

    function toggleFullscreen() {
      const el = document.querySelector(".minmax-layout2-root") || document.documentElement;

      if (!document.fullscreenElement) {
        if (el.requestFullscreen) {
          el.requestFullscreen().catch(err => console.warn("No se pudo activar pantalla completa", err));
        }
      } else if (document.exitFullscreen) {
        document.exitFullscreen();
      }
    }

    function storageKey(sku) {
      return "cg_minmax_actual_" + sku;
    }

    function cargarInventariosGuardados() {
      datos.forEach(item => {
        const guardado = localStorage.getItem(storageKey(item.sku));
        if (guardado !== null) {
          item.actual = normalizar(guardado);
        }
      });
    }

    function guardarInventario(sku, valor) {
      const item = datos.find(x => x.sku === sku);
      if (!item) return;

      item.actual = normalizar(valor);
      localStorage.setItem(storageKey(sku), item.actual);
      renderizar();
    }

    function calcular(item) {
      const actual = normalizar(item.actual);
      const minimo = normalizar(item.minimo);
      const ideal = normalizar(item.ideal);
      const maximo = normalizar(item.maximo);
      const diasMax = normalizar(item.diasMax);

      let status = "SIN";

      if (maximo <= 0 && ideal <= 0 && minimo <= 0) {
        status = "SIN";
      } else if (actual < minimo) {
        status = "BAJO";
      } else if (actual >= minimo && actual < ideal) {
        status = "MIN";
      } else if (actual >= ideal && actual <= maximo) {
        status = "OK";
      } else if (actual > maximo) {
        status = "SOBRE";
      }

      const consumoDiario = maximo > 0 && diasMax > 0 ? maximo / diasMax : 0;
      const diasActual = consumoDiario > 0 ? actual / consumoDiario : 0;
      const pctMax = maximo > 0 ? (actual / maximo) * 100 : 0;

      return { status, diasActual, pctMax };
    }

    function claseStatus(status) {
      if (status === "BAJO") return "status-bajo";
      if (status === "MIN") return "status-min";
      if (status === "OK") return "status-ok";
      if (status === "SOBRE") return "status-sobre";
      return "status-sin";
    }

    function claseFill(status) {
      if (status === "BAJO") return "fill-bajo";
      if (status === "MIN") return "fill-min";
      if (status === "OK") return "fill-ok";
      if (status === "SOBRE") return "fill-sobre";
      return "fill-sin";
    }

    function llenarMasters() {
      const select = document.getElementById("masterSelect");
      const valorActual = select.value;
      const masters = [...new Set(datos.map(x => x.master).filter(Boolean))].sort();

      select.innerHTML = `<option value="">Todos</option>`;

      masters.forEach(master => {
        const opt = document.createElement("option");
        opt.value = master;
        opt.textContent = master;
        select.appendChild(opt);
      });

      if (masters.includes(valorActual)) {
        select.value = valorActual;
      }
    }

    function obtenerFiltrados() {
      const buscar = document.getElementById("buscarInput").value.trim().toLowerCase();
      const master = document.getElementById("masterSelect").value;
      const estatus = document.getElementById("estatusSelect").value;

      return datos.filter(item => {
        const calc = calcular(item);
        const texto = `${item.master} ${item.sku} ${item.producto}`.toLowerCase();

        if (buscar && !texto.includes(buscar)) return false;
        if (master && item.master !== master) return false;
        if (estatus && calc.status !== estatus) return false;

        return true;
      });
    }

    function renderizar() {
      const filtrados = obtenerFiltrados();
      renderizarTabla(filtrados);
      renderizarKPIs(filtrados);
      renderizarSemaforo(filtrados);
      renderizarTop(filtrados);
    }

    function renderizarTabla(lista) {
      const tbody = document.getElementById("tablaBody");
      tbody.innerHTML = "";

      if (!lista.length) {
        tbody.innerHTML = `<tr><td colspan="12" style="text-align:center; padding:15px;">Sin resultados.</td></tr>`;
        return;
      }

      lista.forEach(item => {
        const calc = calcular(item);
        const pctBar = Math.min(Math.max(calc.pctMax, 0), 120);
        const tr = document.createElement("tr");

        tr.innerHTML = `
          <td class="sticky-master">${item.master}</td>
          <td class="sticky-sku">${item.sku}</td>
          <td class="producto" title="${item.producto}">${item.producto}</td>
          <td class="num">${formatoNumero(item.total, 0)}</td>
          <td class="num">
            <input 
              class="actual-input" 
              type="number" 
              value="${Math.round(item.actual)}"
              readonly
              title="Inventario actual real desde SIGO / InventarioSigo"
            />
          </td>
          <td class="num">${formatoNumero(item.minimo, 0)}</td>
          <td class="num">${formatoNumero(item.ideal, 0)}</td>
          <td class="num">${formatoNumero(item.maximo, 0)}</td>
          <td class="num">
            <div class="bar-wrap" title="${formatoNumero(calc.pctMax, 1)}% del máximo">
              <div class="bar-fill ${claseFill(calc.status)}" style="width:${pctBar}%;"></div>
            </div>
            ${formatoNumero(calc.pctMax, 1)}%
          </td>
          <td class="num">${formatoNumero(calc.diasActual, 1)}</td>
          <td class="num">${formatoNumero(item.diasMax, 0)}</td>
          <td><span class="badge ${claseStatus(calc.status)}">${CLAVES[calc.status]}</span></td>
        `;

        tbody.appendChild(tr);
      });
    }

    function renderizarKPIs(lista) {
      let bajo = 0;
      let ok = 0;
      let sobre = 0;
      let actual = 0;

      lista.forEach(item => {
        const calc = calcular(item);
        actual += normalizar(item.actual);

        if (calc.status === "BAJO") bajo++;
        if (calc.status === "OK") ok++;
        if (calc.status === "SOBRE") sobre++;
      });

      document.getElementById("kpiSkus").textContent = formatoNumero(lista.length);
      document.getElementById("kpiBajo").textContent = formatoNumero(bajo);
      document.getElementById("kpiOk").textContent = formatoNumero(ok);
      document.getElementById("kpiSobre").textContent = formatoNumero(sobre);
      document.getElementById("kpiActual").textContent = formatoNumero(actual, 0);
    }

    function renderizarSemaforo(lista) {
      const cont = document.getElementById("semaforoChart");
      const conteos = { BAJO: 0, MIN: 0, OK: 0, SOBRE: 0, SIN: 0 };

      lista.forEach(item => {
        const calc = calcular(item);
        conteos[calc.status]++;
      });

      const max = Math.max(...Object.values(conteos), 1);

      cont.innerHTML = Object.keys(conteos).map(key => {
        const pct = (conteos[key] / max) * 100;
        return `
          <div class="sem-row">
            <div><span class="badge ${claseStatus(key)}">${CLAVES[key]}</span></div>
            <div class="sem-bar">
              <div class="sem-fill ${claseFill(key)}" style="width:${pct}%;"></div>
            </div>
            <div class="num">${conteos[key]}</div>
          </div>
        `;
      }).join("");
    }

    function renderizarTop(lista) {
      const cont = document.getElementById("topChart");
      const top = [...lista]
        .filter(x => normalizar(x.maximo) > 0)
        .sort((a, b) => normalizar(b.maximo) - normalizar(a.maximo))
        .slice(0, 20);

      const max = Math.max(...top.map(x => normalizar(x.maximo)), 1);

      cont.innerHTML = top.map(item => {
        const calc = calcular(item);
        const pct = (normalizar(item.maximo) / max) * 100;

        return `
          <div class="top-item">
            <div><strong>${item.sku}</strong></div>
            <div>
              <div class="top-name" title="${item.producto}">${item.producto}</div>
              <div class="bar-wrap" style="width:100%;">
                <div class="bar-fill ${claseFill(calc.status)}" style="width:${pct}%;"></div>
              </div>
            </div>
            <div class="num">${formatoNumero(item.maximo, 0)}</div>
          </div>
        `;
      }).join("");
    }

    function restablecerIdeal() {
      if (!confirm("¿Deseas restablecer el inventario actual al nivel ideal para todos los SKUs?")) return;

      datos.forEach(item => {
        item.actual = normalizar(item.ideal);
        localStorage.setItem(storageKey(item.sku), item.actual);
      });

      renderizar();
    }

    function exportarCSV() {
      const lista = obtenerFiltrados();
      const encabezados = [
        "MASTER", "SKU", "PRODUCTO", "TOTAL_BASE", "INVENTARIO_ACTUAL",
        "MINIMO", "IDEAL", "MAXIMO", "PORCENTAJE_MAXIMO",
        "DIAS_ACTUAL", "DIAS_INV_MAX", "INDICADOR"
      ];

      const filas = lista.map(item => {
        const calc = calcular(item);
        return [
          item.master,
          item.sku,
          item.producto,
          item.total,
          item.actual,
          item.minimo,
          item.ideal,
          item.maximo,
          calc.pctMax,
          calc.diasActual,
          item.diasMax,
          CLAVES[calc.status]
        ];
      });

      const csv = [encabezados, ...filas]
        .map(row => row.map(v => `"${String(v ?? "").replaceAll('"', '""')}"`).join(","))
        .join("\n");

      const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "indicador_inventario_min_max.csv";
      a.click();
      URL.revokeObjectURL(url);
    }

    llenarMasters();
    renderizar();
    cargarInventarioReal();
  </script>
</div>
