    function parseUbicacionRack(ubic) {
    const txt = String(ubic || "").trim().toUpperCase();
    const m = txt.match(/^R(\d+)-(\d+)([A-Z])$/);

    if (!m) return null;

    return {
    rack: Number(m[1]),
    posicion: Number(m[2]),
    altura: m[3],
    raw: txt
    };
    }

    function alturaToIndex(altura) {
    const alturas = "ABCDEFG";
    const idx = alturas.indexOf(String(altura || "").toUpperCase());
    return idx >= 0 ? idx : 0;
    }

    async function abrirRack3D() {
    const camara = camaraActual || [...camarasSeleccionadas][0] || "";
    rackCamaraActualVista = camara;

    if (!camara) {
    alert("Selecciona una cámara/almacén primero.");
