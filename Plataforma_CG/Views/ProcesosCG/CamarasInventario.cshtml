@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewBag.Title = "Inventario Por Planta";
}

<style>
    :root {
        --bg: #f0dede;
        --panel: #f8eeee;
        --line: #c79d9d;
        --text: #3b1717;
        --brand: #8B0000;
        --brand-dark: #5c0000;
        --brand-light: #b30000;
    }

    * {
        box-sizing: border-box;
    }

    html,
    body {
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
    }

    body {
        font-family: Tahoma, Verdana, Arial, sans-serif;
        background: transparent !important;
    }

    body,
    main,
    .main,
    .body-content,
    .container,
    .container-fluid,
    .container-sm,
    .container-md,
    .container-lg,
    .container-xl,
    .container-xxl,
    .pb-3 {
        background: transparent !important;
        box-shadow: none !important;
        border: none !important;
    }

    .camaras-page {
        width: calc(100vw - 48px);
        max-width: none;
        margin-left: 50%;
        transform: translateX(-50%);
        margin-top: 0 !important;
    }

    .window {
        width: 100% !important;
        max-width: none !important;
        margin: 0 auto 18px auto !important;
        border: 1px solid #7e4a4a;
        background: var(--panel);
        box-shadow: 0 0 0 1px rgba(255,255,255,.45) inset, 0 8px 18px rgba(70,12,12,.14);
        overflow: hidden;
        border-radius: 0 !important;
    }

    .titlebar {
        min-height: 36px;
        /* display: flex; */
         display: none !important;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 8px 12px;
        background: linear-gradient(180deg, #c00000 0%, #8b0000 60%, #5c0000 100%) !important;
        border-bottom: 1px solid #5c0000 !important;
        color: #fff;
        font-size: 14px;
        font-weight: bold;
    }

    .actions {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
    }

    .win-btn {
        width: 16px;
        height: 16px;
        border: 1px solid #7c4848;
        background: linear-gradient(#fff6f6,#ead0d0);
    }

    .content {
        padding: 12px 14px;
        background: var(--bg);
    }

    .section {
        border: 1px solid var(--line);
        background: #fff;
        margin-bottom: 14px;
        min-width: 0;
    }

    .section-title {
        padding: 8px 10px;
        font-size: 13px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        border-bottom: 1px solid #6b1f1f !important;
    }

    .section-body {
        padding: 12px;
        background: #fffafa;
        min-width: 0;
    }

    .btn-planta,
    .btn-main,
    .btn-excel,
    .btn-light {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .45rem;
        height: 34px;
        padding: 0 14px;
        font-weight: 700;
        border-radius: 0;
        font-size: 13px;
        cursor: pointer;
        white-space: nowrap;
    }

    .btn-planta {
        border: 1px solid #b48787;
        color: #4b1f1f;
        background: linear-gradient(#fffefe,#ecd7d7);
    }

        .btn-planta.active {
            background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
            color: #fff;
            border-color: #7a2d2d;
        }

    .btn-main {
        border: 1px solid #7a2d2d;
        color: #fff;
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
    }

    .btn-excel {
        border: 1px solid #146c43;
        color: #fff;
        background: linear-gradient(180deg,#198754 0%, #146c43 100%);
    }

    .filters-one-line {
        display: grid;
        grid-template-columns: 180px minmax(160px, 1fr) minmax(260px, 1.5fr) auto;
        align-items: end;
        gap: 12px;
    }

    .planta-bar-inline {
        display: flex;
        gap: 6px;
    }

    .filter-actions {
        display: flex;
        gap: 8px;
        align-items: end;
        justify-content: flex-end;
    }

    .form-label {
        display: block;
        color: #5c1a1a;
        font-size: 13px;
        margin-bottom: 5px;
        font-weight: bold;
    }

    .form-control,
    .form-select {
        width: 100%;
        max-width: 100%;
        border: 1px solid #b48787 !important;
        background: #fffdfd !important;
        color: #421414 !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        font-size: 13px !important;
        height: 34px !important;
    }

    .inv-layout {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        min-width: 0;
    }

    .sidebar {
        width: 160px;
        flex: 0 0 160px;
        border: 1px solid var(--line);
        background: #fff;
        overflow: hidden;
    }

    .sidebar-title {
        padding: 7px 8px;
        font-size: 12px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
    }

    .sidebar-list {
        max-height: 520px;
        overflow-y: auto;
    }

    .cam-item {
        padding: 7px 8px;
        font-size: 12px;
        cursor: pointer;
        color: #3b1717;
        border-bottom: 1px solid #ecd7d7;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        user-select: none;
    }

        .cam-item:hover {
            background: #f4dddd;
        }

        .cam-item.active {
            background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%);
            color: #fff;
            font-weight: bold;
        }

    .sidebar-actions {
        border-top: 1px solid #d8bcbc;
        background: #f6e9e9;
        padding: 6px 8px;
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .sidebar-actions button {
            width: 100%;
            height: 30px;
            font-size: 12px;
            font-weight: 700;
            border-radius: 0;
            cursor: pointer;
        }

            .sidebar-actions button:first-child {
                border: 1px solid #146c43;
                color: #fff;
                background: linear-gradient(180deg,#198754 0%, #146c43 100%);
            }

            .sidebar-actions button:last-child {
                border: 1px solid #c99700;
                color: #3b2b00;
                background: linear-gradient(180deg,#ffd54d 0%, #e0a800 100%);
            }

    .inv-right,
    .traz-left,
    .traz-right {
        flex: 1 1 0;
        min-width: 0;
    }

    .inv-right {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .totales-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
    }

    .totales-text {
        font-size: 14px;
        font-weight: bold;
        color: #401515;
    }

        .totales-text span {
            color: #8b0000;
        }

    .table-card {
        background: var(--panel);
        border: 1px solid var(--line);
        overflow: hidden;
        min-width: 0;
        width: 100%;
    }

    .table-responsive-sticky {
        max-height: 72vh;
        overflow: auto;
        border-top: 1px solid #d9b8b8;
        background: #fffafa;
        width: 100%;
        -webkit-overflow-scrolling: touch;
    }

    #tbl-inv,
    #tbl-traz {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin-bottom: 0;
        background: #fffafa;
    }

    #tbl-inv {
        font-size: 13px;
        min-width: 850px;
    }

    #tbl-traz {
        font-size: 12px;
        min-width: 1250px;
    }

        #tbl-inv thead th,
        #tbl-traz thead th {
            position: sticky;
            top: -1px;
            z-index: 20;
            background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
            color: #fff !important;
            border-top: 1px solid #c46a6a !important;
            border-right: 1px solid #8e3b3b !important;
            border-bottom: 1px solid #5c0000 !important;
            font-weight: 700 !important;
            white-space: nowrap;
        }

    #tbl-inv thead th {
        padding: 8px 6px !important;
        font-size: 13px !important;
        cursor: pointer;
        user-select: none;
    }

    #tbl-traz thead th {
        padding: 7px 5px !important;
        font-size: 12px !important;
    }

    #tbl-inv tbody td,
    #tbl-traz tbody td {
        background: #fffafa !important;
        border-right: 1px solid #d8bcbc !important;
        border-bottom: 1px solid #d8bcbc !important;
        color: #111 !important;
        white-space: nowrap;
        vertical-align: middle;
    }

    #tbl-inv tbody td {
        padding: 7px 6px !important;
        font-size: 13px;
    }

    #tbl-traz tbody td {
        padding: 6px 5px !important;
        font-size: 12px;
    }

    #tbl-inv tbody tr:nth-of-type(even) > *,
    #tbl-traz tbody tr:nth-of-type(even) > * {
        background-color: #f9eded !important;
    }

    #tbl-inv tbody tr:hover > *,
    #tbl-traz tbody tr:hover > * {
        background: #f4dddd !important;
    }

    #tbl-inv tbody tr.row-sel > * {
        background: #fff3a3 !important;
        border-top: 2px solid #c9a100 !important;
        border-bottom: 2px solid #c9a100 !important;
    }

  
  #tbl-traz tbody td:nth-child(2),
#tbl-traz tbody td:nth-child(7) {
    background: #fff3a3 !important;
    color: #000 !important;
}

    .traz-panel {
        display: flex;
        gap: 12px;
        min-width: 0;
    }

    .text-end {
        text-align: right !important;
        font-variant-numeric: tabular-nums;
    }

    .text-center {
        text-align: center !important;
    }

    .badge-activo,
    .badge-inactivo {
        display: inline-block;
        padding: 2px 7px;
        font-size: 11px;
        font-weight: 700;
        color: #fff;
    }

    .badge-activo {
        background: #198754;
    }

    .badge-inactivo {
        background: #dc3545;
    }

    .statusbar {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 8px 10px;
        font-size: 12px;
        color: #4a1a1a;
        border-top: 1px solid #b88c8c;
        background: linear-gradient(#f6e9e9,#ead5d5);
        flex-wrap: wrap;
    }

    .rack-title {
        padding: 7px 10px !important;
        font-size: 12px !important;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .btn-rack3d {
        height: 24px;
        padding: 0 10px;
        border: 1px solid #ffd36a;
        background: linear-gradient(180deg,#ffdd6b,#d99a00);
        color: #2d1800;
        font-size: 11px;
        font-weight: 800;
        cursor: pointer;
    }

    /* ===================== MODAL THREE.JS ===================== */

    .rack-modal {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 99999;
        background: rgba(0,0,0,.72);
        align-items: center;
        justify-content: center;
        padding: 18px;
    }

        .rack-modal.show {
            display: flex;
        }

    .rack-modal-box {
        width: min(1500px, 96vw);
        height: min(850px, 92vh);
        background: #170909;
        border: 1px solid #b30000;
        box-shadow: 0 20px 70px rgba(0,0,0,.65);
        display: flex;
        flex-direction: column;
    }

    .rack-modal-head {
        height: 46px;
        background: linear-gradient(180deg,#b30000,#5c0000);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 14px;
        border-bottom: 1px solid #2d0000;
    }

        .rack-modal-head span {
            display: block;
            font-size: 11px;
            color: #ffd8d8;
            margin-top: 2px;
        }

    .rack-close {
        width: 30px;
        height: 30px;
        border: 1px solid #ffd0d0;
        background: #fff;
        color: #8b0000;
        font-size: 22px;
        font-weight: bold;
        cursor: pointer;
    }

    .rack3d-body {
        flex: 1;
        display: grid;
        grid-template-columns: 1fr 330px;
        min-height: 0;
    }

    #rack3d-canvas {
        width: 100%;
        height: 100%;
        background: #d8d8d8;
        overflow: hidden;
        position: relative;
    }

    .rack-info {
        background: #fff8f8;
        border-left: 1px solid #8b0000;
        padding: 14px;
        overflow: auto;
        color: #270d0d;
    }

        .rack-info h4 {
            margin: 0 0 12px 0;
            color: #8b0000;
            font-size: 22px;
        }

    .rack-info-row {
        border-bottom: 1px solid #e2bcbc;
        padding: 8px 0;
        font-size: 12px;
    }

        .rack-info-row b {
            display: block;
            color: #5c0000;
            margin-bottom: 3px;
        }

    @@media (min-width: 1400px) {
        .camaras-page {
            width: calc(100vw - 80px);
        }

        .table-responsive-sticky {
            max-height: 68vh;
        }
    }

    @@media (max-width: 1200px) {
        .traz-panel {
            flex-direction: column;
        }

        #tbl-traz {
            min-width: 1150px;
        }
    }

    @@media (max-width: 992px) {
        .content {
            padding: 10px;
        }

        .filters-one-line {
            grid-template-columns: 1fr 1fr;
        }

        .filter-actions {
            justify-content: flex-start;
        }

        .inv-layout {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
            flex: 0 0 auto;
        }

        .sidebar-list {
            max-height: 220px;
        }

        .sidebar-actions {
            flex-direction: row;
            flex-wrap: wrap;
        }

            .sidebar-actions button {
                flex: 1 1 140px;
            }
    }

    @@media (max-width: 768px) {
        .camaras-page {
            width: calc(100vw - 12px);
        }

            .camaras-page .window {
                margin: 6px auto !important;
            }

        .rack3d-body {
            grid-template-columns: 1fr;
        }

        .rack-info {
            max-height: 220px;
            border-left: none;
            border-top: 1px solid #8b0000;
        }
    }

    @@media (max-width: 576px) {
        .titlebar {
            font-size: 13px;
            align-items: flex-start;
        }

        .content {
            padding: 6px;
        }

        .section {
            margin-bottom: 10px;
        }

        .section-body {
            padding: 8px;
        }

        .filters-one-line {
            grid-template-columns: 1fr;
            gap: 8px;
        }

        .filter-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

            .filter-actions button,
            .btn-main,
            .btn-excel {
                width: 100%;
                padding: 0 8px;
                font-size: 12px;
            }

        .totales-bar {
            flex-direction: column;
            align-items: flex-start;
        }

        .totales-text {
            font-size: 13px;
        }

        .table-responsive-sticky {
            max-height: 62vh;
        }

        #tbl-inv {
            min-width: 760px;
        }

        #tbl-traz {
            min-width: 1050px;
        }

            #tbl-inv thead th,
            #tbl-inv tbody td,
            #tbl-traz thead th,
            #tbl-traz tbody td {
                font-size: 11px !important;
                padding: 5px 4px !important;
            }

        .statusbar {
            font-size: 11px;
            padding: 6px 8px;
        }
    }

    .rack-kpi-bar {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 8px;
        padding: 8px;
        background: #fff8f8;
        border-bottom: 1px solid #8b0000;
    }

    .rack-kpi-card {
        border: 1px solid #d8bcbc;
        background: linear-gradient(#fffefe, #f3e2e2);
        padding: 8px 10px;
        min-height: 58px;
    }

        .rack-kpi-card.danger {
            background: linear-gradient(#ffecec, #ffd1d1);
            border-color: #b30000;
        }

    .rack-kpi-title {
        font-size: 11px;
        font-weight: 800;
        color: #5c0000;
        text-transform: uppercase;
        margin-bottom: 4px;
    }

    .rack-kpi-value {
        font-size: 20px;
        font-weight: 900;
        color: #111;
        font-variant-numeric: tabular-nums;
    }

    @@media (max-width: 992px) {
        .rack-kpi-bar {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .rack-search-bar {
        display: grid;
        grid-template-columns: 260px 1fr 260px;
        gap: 10px;
        align-items: center;
        padding: 8px;
        background: #fffafa;
        border-bottom: 1px solid #b30000;
        color: #4a0000;
        font-size: 13px;
        font-weight: 700;
    }

    .rack-search-box {
        display: flex;
        gap: 6px;
    }

    #txt-buscar-rack {
        width: 100%;
        height: 30px;
        border: 1px solid #b48787;
        padding: 0 10px;
        font-size: 13px;
    }

    #btn-buscar-rack {
        height: 30px;
        border: 1px solid #7a2d2d;
        background: linear-gradient(180deg,#b30000,#5c0000);
        color: #fff;
        font-weight: 800;
        padding: 0 14px;
        cursor: pointer;
    }

    #rack-search-result {
        color: #8b0000;
        font-weight: 800;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    @@media (max-width: 992px) {
        .rack-search-bar {
            grid-template-columns: 1fr;
        }
    }

    #tbl-traz tbody td.dias-verde {
        background: #d1e7dd !important;
        color: #0f5132 !important;
        font-weight: 900 !important;
    }

    #tbl-traz tbody td.dias-amarillo {
        background: #fff3cd !important;
        color: #664d03 !important;
        font-weight: 900 !important;
    }

    #tbl-traz tbody td.dias-rojo {
        background: #f8d7da !important;
        color: #842029 !important;
        font-weight: 900 !important;
    }

    th[data-col] {
        cursor: pointer;
        user-select: none;
        position: relative;
    }

    .sort-arrow {
        display: inline-flex;
        flex-direction: column;
        margin-left: 5px;
        vertical-align: middle;
    }

    .arr-up, .arr-dn {
        width: 0;
        height: 0;
        border-left: 4px solid transparent;
        border-right: 4px solid transparent;
    }

    .arr-up {
        border-bottom: 6px solid rgba(255,255,255,.6);
        margin-bottom: 1px;
    }

    .arr-dn {
        border-top: 6px solid rgba(255,255,255,.6);
    }

    th.asc .arr-up {
        border-bottom-color: #fff;
    }

    th.desc .arr-dn {
        border-top-color: #fff;
    }

    .btn-total-camara {
        height: 24px;
        padding: 0 10px;
        border: 1px solid #146c43;
        background: linear-gradient(180deg,#198754,#146c43);
        color: #fff;
        font-size: 11px;
        font-weight: 800;
        cursor: pointer;
    }

        .btn-total-camara:hover {
            background: linear-gradient(180deg,#20a164,#0f5a37);
        }

    /* Quitar fondo blanco de atrás */
    html,
    body,
    main,
    .main,
    .body-content,
    .container,
    .container-fluid,
    .pb-3 {
        background: transparent !important;
    }

  


    /* RESPONSIVO REAL CELULAR */
    @@media (max-width: 768px) {
        html,
        body {
            width: 100% !important;
            max-width: 100% !important;
            overflow-x: hidden !important;
        }

        .camaras-page {
            width: 100% !important;
            max-width: 100% !important;
            margin: 0 !important;
            transform: none !important;
            padding: 0 4px !important;
        }

        .window,
        .content,
        .section,
        .section-body,
        .inv-right,
        .traz-left,
        .traz-right,
        .table-card {
            width: 100% !important;
            max-width: 100% !important;
            min-width: 0 !important;
        }

        .content {
            padding: 4px !important;
        }

        .filters-one-line {
            display: grid !important;
            grid-template-columns: 1fr !important;
            gap: 8px !important;
        }

        .planta-bar-inline,
        .filter-actions {
            display: grid !important;
            grid-template-columns: 1fr 1fr !important;
            gap: 6px !important;
        }

        .btn-planta,
        .btn-main,
        .btn-excel {
            width: 100% !important;
            font-size: 11px !important;
            padding: 0 6px !important;
        }

        .inv-layout,
        .traz-panel {
            display: flex !important;
            flex-direction: column !important;
            width: 100% !important;
            gap: 8px !important;
        }

        .sidebar {
            width: 100% !important;
            flex: none !important;
        }

        .sidebar-list {
            max-height: 150px !important;
        }

        .totales-bar {
            display: block !important;
        }

        .totales-text {
            font-size: 12px !important;
            margin-bottom: 6px;
        }

        .table-responsive-sticky {
            width: 100% !important;
            max-width: 100% !important;
            overflow-x: auto !important;
            overflow-y: auto !important;
            -webkit-overflow-scrolling: touch !important;
        }

        #tbl-inv {
            min-width: 620px !important;
            font-size: 10px !important;
        }

        #tbl-traz {
            min-width: 900px !important;
            font-size: 10px !important;
        }

            #tbl-inv th,
            #tbl-inv td,
            #tbl-traz th,
            #tbl-traz td {
                font-size: 10px !important;
                padding: 4px 3px !important;
                line-height: 1.1 !important;
            }

        .rack-title {
            flex-direction: column !important;
            align-items: stretch !important;
        }

            .rack-title > div {
                display: grid !important;
                grid-template-columns: 1fr 1fr !important;
                width: 100% !important;
            }

        .btn-total-camara,
        .btn-rack3d {
