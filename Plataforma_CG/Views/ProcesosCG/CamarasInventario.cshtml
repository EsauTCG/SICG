    }

    document.getElementById("modal-rack3d").classList.add("show");
    document.getElementById("rack-title-camara").textContent = "Vista Cámara - " + camara;
    document.getElementById("rack-almacen-actual").textContent = camara;
    document.getElementById("txt-buscar-rack").value = "";
    document.getElementById("rack-search-result").textContent = "Sin búsqueda";

    setTimeout(() => {
    try {
    if (typeof THREE === "undefined") {
    alert("No cargó THREE.js");
    return;
    }

    if (typeof THREE.OrbitControls === "undefined") {
    alert("No cargó OrbitControls");
    return;
    }

    iniciarRackThree();
    renderRackThree();
    } catch (err) {
