    async function cargarTrazabilidad(row) {
    if (!row || !row.sku) return;

    const camaraDetalle = row.almacen || camaraActual || [...camarasSeleccionadas][0] || "";

    if (!camaraDetalle) {
    alert("Selecciona una cámara para consultar el detalle.");
    return;
    }

