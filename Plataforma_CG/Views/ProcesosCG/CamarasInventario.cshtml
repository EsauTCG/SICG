    /* =========================================================
       KPIS EJECUTIVOS CON COLOR - INVENTARIO POR PLANTA
       ========================================================= */

    .main-kpi-panel {
        margin-bottom: 12px !important;
        border: 1px solid #c79d9d !important;
        background: #fffafa !important;
        box-shadow: 0 8px 18px rgba(70,12,12,.10) !important;
        overflow: hidden;
    }

    .main-kpi-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(130px, 1fr));
        gap: 10px;
        padding: 10px;
        background: linear-gradient(180deg, #fffafa 0%, #f2dddd 100%);
    }

    .main-kpi-card {
        position: relative;
        min-height: 96px;
        overflow: hidden;
        border-radius: 14px;
        border: 1px solid rgba(255,255,255,.30);
        padding: 12px 13px;
        color: #fff;
        box-shadow: 0 12px 24px rgba(56, 9, 9, .18);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .main-kpi-card::after {
        content: "";
        position: absolute;
        right: -34px;
        bottom: -42px;
        width: 125px;
        height: 125px;
        border-radius: 999px;
        background: rgba(255,255,255,.15);
        pointer-events: none;
    }

    .main-kpi-title,
    .main-kpi-value,
    .main-kpi-sub {
        position: relative;
        z-index: 1;
    }

    .main-kpi-title {
        font-size: 10px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: rgba(255,255,255,.90);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .main-kpi-value {
        margin-top: 8px;
        font-size: clamp(20px, 1.8vw, 30px);
        line-height: 1.05;
        font-weight: 900;
        color: #fff;
        text-shadow: 0 2px 8px rgba(0,0,0,.22);
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .main-kpi-sub {
        margin-top: 6px;
        font-size: 10.5px;
        font-weight: 800;
        color: rgba(255,255,255,.86);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .kpi-main-camaras {
        background: linear-gradient(135deg, #7b1113 0%, #a3161a 58%, #4b0608 100%);
    }

    .kpi-main-skus {
        background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 58%, #172554 100%);
    }

    .kpi-main-cajas {
