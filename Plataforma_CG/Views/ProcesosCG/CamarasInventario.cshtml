    }

    try {
    const url = `/ProcesosCG/DetalleCamaraCompleta?planta=${encodeURIComponent(plantaActual)}&camara=${encodeURIComponent(camara)}`;

    const resp = await fetch(url);
    const data = await resp.json();

    if (!data.ok) {
    alert(data.mensaje || "Error cargando cámara completa");
    return;
    }

    datosTrazOriginal = data.rows || [];
    datosTraz = datosTrazOriginal;
    calcularKpisCamara(datosTraz);

    if (!datosTraz.length) {
    alert("La cámara seleccionada no tiene productos con ubicación.");
    return;
    }

    } catch (err) {
    console.error(err);
    alert("Error conectando con DetalleCamaraCompleta");
