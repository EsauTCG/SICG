    function cerrarRack3D() {
    document.getElementById("modal-rack3d").classList.remove("show");

    if (rackAnimationId) {
    cancelAnimationFrame(rackAnimationId);
    rackAnimationId = null;
    }

    if (rackRenderer) {
    rackRenderer.dispose();
    rackRenderer = null;
    }

    const cont = document.getElementById("rack3d-canvas");
    if (cont) cont.innerHTML = "";
    }

    function iniciarRackThree() {
    const cont = document.getElementById("rack3d-canvas");

    cont.innerHTML = "";

    rackScene = new THREE.Scene();
    rackScene.background = new THREE.Color(0xd9d9d9);

    rackCamera = new THREE.PerspectiveCamera(
    45,
    cont.clientWidth / cont.clientHeight,
    0.1,
    2000
    );

    rackCamera.position.set(28, 24, 34);

    rackRenderer = new THREE.WebGLRenderer({ antialias: true });
    rackRenderer.setSize(cont.clientWidth, cont.clientHeight);
    rackRenderer.setPixelRatio(window.devicePixelRatio || 1);
    rackRenderer.shadowMap.enabled = true;

    cont.appendChild(rackRenderer.domElement);

    rackControls = new THREE.OrbitControls(rackCamera, rackRenderer.domElement);
    rackControls.enableDamping = true;
    rackControls.dampingFactor = 0.08;
    rackControls.target.set(10, 3, 8);

    rackRaycaster = new THREE.Raycaster();
    rackMouse = new THREE.Vector2();

    const ambient = new THREE.AmbientLight(0xffffff, 0.7);
    rackScene.add(ambient);

    const dir = new THREE.DirectionalLight(0xffffff, 1.1);
    dir.position.set(20, 40, 30);
    dir.castShadow = true;
    rackScene.add(dir);

    const grid = new THREE.GridHelper(90, 90, 0x888888, 0xb5b5b5);
    rackScene.add(grid);

    const floorGeo = new THREE.BoxGeometry(80, 0.2, 55);
    const floorMat = new THREE.MeshStandardMaterial({ color: 0xbfbfbf });
    const floor = new THREE.Mesh(floorGeo, floorMat);
    floor.position.set(18, -0.12, 12);
    floor.receiveShadow = true;
    rackScene.add(floor);

    rackRenderer.domElement.addEventListener("click", onRackClick);

    window.removeEventListener("resize", resizeRackThree);
    window.addEventListener("resize", resizeRackThree);

    animateRackThree();
    }

    function limpiarEscenaRack() {
    if (!rackScene) return;

    const conservar = [];

    rackScene.children.forEach(obj => {
    if (obj.type === "AmbientLight" || obj.type === "DirectionalLight") {
    conservar.push(obj);
    }
    });

    rackScene.children.slice().forEach(obj => {
    rackScene.remove(obj);

    if (obj.geometry) obj.geometry.dispose();

    if (obj.material) {
    if (Array.isArray(obj.material)) {
    obj.material.forEach(m => m.dispose && m.dispose());
    } else {
    obj.material.dispose && obj.material.dispose();
    }
    }
    });

    conservar.forEach(obj => rackScene.add(obj));

    rackObjects = [];
    rackItemsIndex = [];

    const grid = new THREE.GridHelper(90, 90, 0x888888, 0xb5b5b5);
    rackScene.add(grid);

    const floorGeo = new THREE.BoxGeometry(80, 0.2, 55);
    const floorMat = new THREE.MeshStandardMaterial({ color: 0xbfbfbf });
    const floor = new THREE.Mesh(floorGeo, floorMat);
    floor.position.set(18, -0.12, 12);
    floor.receiveShadow = true;
    rackScene.add(floor);
    }

    function renderRackThree() {
    rackObjects = [];

    const subtitle = document.getElementById("rack-subtitle");

    const items = (datosTraz || [])
    .map(x => {
    const ubic = getVal(x, "Ubic", "ubic");
    const parsed = parseUbicacionRack(ubic);

    return {
    raw: x,
    parsed,
    ubic,
    sku: getVal(x, "Sku", "sku"),
    producto: getVal(x, "Producto", "producto"),
    kg: Number(getVal(x, "Kg", "kg") || 0),
    fecha: getVal(x, "Fecha", "fecha"),
    diasInv: diasInventario(getVal(x, "Fecha", "fecha")),
    cajas: Number(getVal(x, "Cantidad", "cantidad") || 1),
    lote: getVal(x, "Lote", "lote"),
    tarima: getVal(x, "Tar", "tar"),
    codigo: getVal(x, "CodigoEtiqueta", "codigoEtiqueta")
    };
    })
    .filter(x => x.parsed);

    if (!items.length) {
    subtitle.textContent = "No hay ubicaciones válidas tipo R2-02A.";
    document.getElementById("rack-info-content").innerHTML =
    "Formato esperado: <b>R2-02A</b>.";
    return;
    }

    const agrupado = {};

    items.forEach(item => {
    const key = `${item.parsed.rack}-${item.parsed.posicion}-${item.parsed.altura}`;

    if (!agrupado[key]) {
    agrupado[key] = {
    ...item,
    cajasTotal: 0,
    kgTotal: 0,
    productos: [],
    diasMax: 0
    };
    }

    agrupado[key].cajasTotal += item.cajas || 1;
    agrupado[key].kgTotal += item.kg || 0;
    agrupado[key].productos.push(item);
    agrupado[key].diasMax = Math.max(agrupado[key].diasMax, item.diasInv || 0);
    });

    const ubicaciones = Object.values(agrupado);
    rackItemsIndex = ubicaciones;

    subtitle.textContent = `${ubicaciones.length} posiciones | ${items.length} etiquetas`;

    const racks = [...new Set(ubicaciones.map(x => x.parsed.rack))].sort((a, b) => a - b);

    rackIndexMap = {};

    racks.forEach((rack, index) => {
    rackIndexMap[rack] = index;
    });
    const maxPos = Math.max(8, ...ubicaciones.map(x => x.parsed.posicion));
    const maxAltura = Math.max(4, ...ubicaciones.map(x => alturaToIndex(x.parsed.altura) + 1));

    racks.forEach((rack, rackIndex) => {
    crearRackFisico(rack, rackIndex, maxPos, maxAltura);
    });

    ubicaciones.forEach(item => {
    crearTarima(item);
    });

    const first = rackObjects[0];

    if (first) {
    seleccionarRackObject(first);
    }
    }

    function crearRackFisico(rack, rackIndex, maxPos, maxAltura) {
    const rackGap = 7;
    const posGap = 2.1;
    const levelGap = 1.7;

    const zBase = rackIndex * rackGap;

    const blueMat = new THREE.MeshStandardMaterial({ color: 0x003399, metalness: 0.2, roughness: 0.45 });
    const beamMat = new THREE.MeshStandardMaterial({ color: 0xd71920, metalness: 0.25, roughness: 0.4 });

    for (let p = 1; p <= maxPos + 1; p++) {
    const x = p * posGap;

    const postGeo = new THREE.BoxGeometry(0.12, maxAltura * levelGap + 0.8, 0.12);

    const post1 = new THREE.Mesh(postGeo, blueMat);
    post1.position.set(x, (maxAltura * levelGap) / 2, zBase);
    post1.castShadow = true;
    rackScene.add(post1);

    const post2 = new THREE.Mesh(postGeo, blueMat);
    post2.position.set(x, (maxAltura * levelGap) / 2, zBase + 1.7);
    post2.castShadow = true;
    rackScene.add(post2);
    }

    for (let h = 0; h <= maxAltura; h++) {
    const y = h * levelGap;

    for (let p = 1; p <= maxPos; p++) {
    const x = p * posGap + posGap / 2;

    const beamGeo = new THREE.BoxGeometry(posGap, 0.12, 0.12);

    const beam1 = new THREE.Mesh(beamGeo, beamMat);
    beam1.position.set(x, y, zBase);
    beam1.castShadow = true;
    rackScene.add(beam1);

    const beam2 = new THREE.Mesh(beamGeo, beamMat);
    beam2.position.set(x, y, zBase + 1.7);
    beam2.castShadow = true;
    rackScene.add(beam2);
    }
    }

    // Posiciones abajo: 01, 02, 03...
    for (let p = 1; p <= maxPos; p++) {
    const x = p * posGap + posGap / 2;
    crearTextoPosicion(
    String(p).padStart(2, "0"),
    x,
    -0.45,
    zBase + 0.85
    );
    }

    // Alturas a un lado: A, B, C...
    const letrasAltura = "ABCDEFG";

    for (let h = 0; h < maxAltura; h++) {
    crearTextoAltura(
    letrasAltura[h] || String(h + 1),
    0.45,
    h * levelGap + 0.55,
    zBase - 0.35
    );
    }

    crearLetreroRack(`RACK ${rack}`, 0.5, maxAltura * levelGap + 1.3, zBase + 0.85);
    }

    function claseDiasInventario(dias) {
    dias = Number(dias || 0);

    if (dias >= 50) return "dias-rojo";
    if (dias >= 15) return "dias-amarillo";
    return "dias-verde";
    }

    function crearTarima(item) {
    const rackGap = 7;
    const posGap = 2.1;
    const levelGap = 1.7;

    const rackIndex = rackIndexMap[item.parsed.rack] ?? 0;
    const alturaIndex = alturaToIndex(item.parsed.altura);

    const x = item.parsed.posicion * posGap + posGap / 2;
    const y = alturaIndex * levelGap + 0.45;
    const z = rackIndex * rackGap + 0.85;

    const palletMat = new THREE.MeshStandardMaterial({ color: 0x8b5a1f, roughness: 0.6 });
    const boxMat = new THREE.MeshStandardMaterial({
    color: colorSemaforoPorDias(item.diasMax || 0),
    roughness: 0.55
    });

    const palletGeo = new THREE.BoxGeometry(1.45, 0.18, 1.2);
    const pallet = new THREE.Mesh(palletGeo, palletMat);
    pallet.position.set(x, y - 0.25, z);
    pallet.castShadow = true;
    pallet.receiveShadow = true;
    rackScene.add(pallet);

    const cajasVisuales = Math.max(1, Math.min(8, item.cajasTotal || 1));
    const cols = cajasVisuales >= 4 ? 2 : 1;
    const rows = Math.ceil(cajasVisuales / cols);

    let count = 0;

    for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) {
    if (count >= cajasVisuales) break;

    const boxGeo = new THREE.BoxGeometry(0.58, 0.45, 0.48);
    const box = new THREE.Mesh(boxGeo, boxMat);

    box.position.set(
    x + (c - (cols - 1) / 2) * 0.62,
    y + r * 0.47,
    z
    );

    box.castShadow = true;
    box.receiveShadow = true;
    box.userData.item = item;

    rackScene.add(box);
    rackObjects.push(box);

    count++;
    }
    }

    crearTextoSprite(item.sku, x, y + rows * 0.55, z, 1.5, 0.38, item);
    }

    function crearTextoSprite(texto, x, y, z, sx, sy, item = null) {
    const canvas = document.createElement("canvas");
    canvas.width = 256;
    canvas.height = 64;

    const ctx = canvas.getContext("2d");
    ctx.fillStyle = "rgba(255,255,255,0.92)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.fillStyle = "#000";
    ctx.font = "bold 28px Arial";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText(String(texto || "-"), 128, 32);

    const texture = new THREE.CanvasTexture(canvas);
    const mat = new THREE.SpriteMaterial({ map: texture });
    const sprite = new THREE.Sprite(mat);

    sprite.position.set(x, y + 0.5, z);
    sprite.scale.set(sx, sy, 1);

    if (item) {
    sprite.userData.item = item;
    }

    rackScene.add(sprite);
    }

    function crearLetreroRack(texto, x, y, z) {
    const canvas = document.createElement("canvas");
    canvas.width = 512;
    canvas.height = 160;

    const ctx = canvas.getContext("2d");

    ctx.fillStyle = "rgba(255,255,255,0.95)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.strokeStyle = "#003399";
    ctx.lineWidth = 10;
    ctx.strokeRect(5, 5, canvas.width - 10, canvas.height - 10);

    ctx.fillStyle = "#003399";
    ctx.font = "bold 72px Arial";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText(String(texto || "-"), 256, 80);

    const texture = new THREE.CanvasTexture(canvas);
    const mat = new THREE.SpriteMaterial({
    map: texture,
    transparent: true,
    depthTest: false
    });

    const sprite = new THREE.Sprite(mat);
    sprite.position.set(x, y, z);
    sprite.scale.set(4.5, 1.4, 1);
    sprite.renderOrder = 999;

    rackScene.add(sprite);
    }

    function crearTextoPosicion(texto, x, y, z) {
    const canvas = document.createElement("canvas");
    canvas.width = 160;
    canvas.height = 80;

    const ctx = canvas.getContext("2d");
    ctx.fillStyle = "rgba(255,255,255,0.95)";
    ctx.fillRect(0, 0, 160, 80);

    ctx.strokeStyle = "#333";
    ctx.lineWidth = 5;
    ctx.strokeRect(4, 4, 152, 72);

    ctx.fillStyle = "#111";
    ctx.font = "bold 44px Arial";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText(String(texto), 80, 40);

    const texture = new THREE.CanvasTexture(canvas);
    const mat = new THREE.SpriteMaterial({ map: texture, transparent: true, depthTest: false });

    const sprite = new THREE.Sprite(mat);
    sprite.position.set(x, y, z);
    sprite.scale.set(0.85, 0.42, 1);
    sprite.renderOrder = 1000;

    rackScene.add(sprite);
    }

    function crearTextoAltura(texto, x, y, z) {
    const canvas = document.createElement("canvas");
    canvas.width = 120;
    canvas.height = 120;

    const ctx = canvas.getContext("2d");
    ctx.fillStyle = "rgba(255,255,255,0.95)";
    ctx.fillRect(0, 0, 120, 120);

    ctx.strokeStyle = "#003399";
    ctx.lineWidth = 6;
    ctx.strokeRect(4, 4, 112, 112);

    ctx.fillStyle = "#003399";
    ctx.font = "bold 64px Arial";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText(String(texto), 60, 60);

    const texture = new THREE.CanvasTexture(canvas);
    const mat = new THREE.SpriteMaterial({ map: texture, transparent: true, depthTest: false });

    const sprite = new THREE.Sprite(mat);
    sprite.position.set(x, y, z);
    sprite.scale.set(0.65, 0.65, 1);
    sprite.renderOrder = 1000;

    rackScene.add(sprite);
    }


    function onRackClick(event) {
    const rect = rackRenderer.domElement.getBoundingClientRect();

    rackMouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
    rackMouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;

    rackRaycaster.setFromCamera(rackMouse, rackCamera);

    const hits = rackRaycaster.intersectObjects(rackObjects, false);

    if (!hits.length) return;

    seleccionarRackObject(hits[0].object);
    }

    function seleccionarRackObject(obj) {
    rackObjects.forEach(o => {
    const item = o.userData.item;
    o.material.color.set(colorSemaforoPorDias(item?.diasMax || 0));
    });

    obj.material.color.set(0xffeb3b);

    const item = obj.userData.item;

    if (item) {
    mostrarInfoRackAgrupado(item);
    }
    }

    function buscarEnRack3D() {
    const q = document.getElementById("txt-buscar-rack").value.trim().toUpperCase();

    if (!q) {
    alert("Escribe un SKU o CódigoEtiqueta.");
    return;
    }

    const filtrados = datosTrazOriginal.filter(x => {
    const sku = String(getVal(x, "Sku", "sku") || "").toUpperCase();
    const codigo = String(getVal(x, "CodigoEtiqueta", "codigoEtiqueta") || "").toUpperCase();
    const tarima = String(getVal(x, "Tar", "tar") || "").toUpperCase();
    const ubic = String(getVal(x, "Ubic", "ubic") || "").toUpperCase();

    return sku === q
    || codigo === q
    || tarima === q
    || ubic === q;
    });

    if (!filtrados.length) {
    document.getElementById("rack-search-result").textContent = "No encontrado";
    alert("No encontré ese SKU o CódigoEtiqueta en esta cámara.");
    return;
    }

    datosTraz = filtrados;

    limpiarEscenaRack();
    renderRackThree();
    calcularKpisCamara(datosTraz);

    const primerObjeto = rackObjects[0];

    if (primerObjeto) {
    primerObjeto.material.color.set(0xff00ff);
    enfocarCajaBuscada(primerObjeto);
    }

    const primero = filtrados[0];

    const skuBuscado = String(getVal(primero, "Sku", "sku") || "").toUpperCase();
    const codigoBuscado = String(getVal(primero, "CodigoEtiqueta", "codigoEtiqueta") || "").toUpperCase();

    if (q === skuBuscado && q !== codigoBuscado) {
    mostrarResumenFiltroSku(filtrados, q);
    } else {
    const item = rackItemsIndex[0];
    if (item) {
    const detalle = item.productos[0];
    mostrarInfoRackDetalle(item, detalle, q);
    }
    }

    document.getElementById("rack-search-result").textContent =
    `${getVal(primero, "Sku", "sku")} | ${getVal(primero, "CodigoEtiqueta", "codigoEtiqueta")} | ${getVal(primero, "Ubic", "ubic")}`;
    }


    function mostrarResumenFiltroSku(rows, filtro) {
    const totalCajas = rows.length;
    const totalKg = rows.reduce((s, r) => s + Number(getVal(r, "Kg", "kg") || 0), 0);

    const dias = rows
    .map(r => diasInventario(getVal(r, "Fecha", "fecha")))
    .filter(d => !isNaN(d));

    const promDias = dias.length
    ? Math.round(dias.reduce((s, d) => s + d, 0) / dias.length)
    : 0;

    const ubicaciones = [...new Set(rows.map(r => getVal(r, "Ubic", "ubic")).filter(Boolean))];
    const tarimas = [...new Set(rows.map(r => getVal(r, "Tar", "tar")).filter(Boolean))];
    const lotes = [...new Set(rows.map(r => getVal(r, "Lote", "lote")).filter(Boolean))];

    const primero = rows[0];

    document.getElementById("rack-info-content").innerHTML = `
    <div class="rack-info-row"><b>Filtro SKU</b>${esc(filtro)}</div>
    <div class="rack-info-row"><b>Producto</b>${esc(getVal(primero, "Producto", "producto") || "-")}</div>
    <div class="rack-info-row"><b>Total cajas / etiquetas</b>${nf.format(totalCajas)}</div>
    <div class="rack-info-row"><b>Kg totales</b>${nfK.format(totalKg)} Kg</div>
    <div class="rack-info-row"><b>Promedio días inventario</b>${nf.format(promDias)} días</div>
    <div class="rack-info-row"><b>Ubicaciones</b>${nf.format(ubicaciones.length)}</div>
    <div class="rack-info-row"><b>Tarimas</b>${nf.format(tarimas.length)}</div>
    <div class="rack-info-row"><b>Lotes</b>${esc(lotes.join(" / ") || "-")}</div>
    `;
    }

 
    function mostrarInfoRackDetalle(item, detalle, filtro) {
    const p = item.parsed;

    document.getElementById("rack-info-content").innerHTML = `
    <div class="rack-info-row"><b>Filtro buscado</b>${esc(filtro)}</div>
    <div class="rack-info-row"><b>Ubicación</b>${esc(item.ubic)}</div>
    <div class="rack-info-row"><b>Rack</b>Rack ${p.rack}</div>
    <div class="rack-info-row"><b>Posición</b>${p.posicion}</div>
    <div class="rack-info-row"><b>Altura</b>${p.altura}</div>
    <div class="rack-info-row"><b>Código etiqueta</b>${esc(detalle.codigo || "-")}</div>
    <div class="rack-info-row"><b>SKU</b>${esc(detalle.sku || "-")}</div>
    <div class="rack-info-row"><b>Producto</b>${esc(detalle.producto || "-")}</div>
    <div class="rack-info-row"><b>Kg etiqueta</b>${nfK.format(Number(detalle.kg || 0))} Kg</div>
    <div class="rack-info-row"><b>Días inventario etiqueta</b>${nf.format(detalle.diasInv || 0)} días</div>
    <div class="rack-info-row"><b>Tarima</b>${esc(detalle.tarima || "-")}</div>
    <div class="rack-info-row"><b>Lote</b>${esc(detalle.lote || "-")}</div>
    `;
    }


    function enfocarCajaBuscada(obj) {
    if (!obj || !rackCamera || !rackControls) return;

    const pos = obj.position.clone();

    const distancia = 10;
    const altura = 4;

    rackControls.target.set(pos.x, pos.y + 0.6, pos.z);

    rackCamera.position.set(
    pos.x + distancia,
    pos.y + altura,
    pos.z + distancia
    );

    rackCamera.near = 0.1;
    rackCamera.far = 3000;
    rackCamera.updateProjectionMatrix();

    rackControls.update();
    }

    function mostrarInfoRackAgrupado(item) {
    const p = item.parsed;

    const tarimas = [...new Set(item.productos.map(x => x.tarima).filter(Boolean))];
    const skus = [...new Set(item.productos.map(x => x.sku).filter(Boolean))];
    const productos = [...new Set(item.productos.map(x => x.producto).filter(Boolean))];

    document.getElementById("rack-info-content").innerHTML = `
    <div class="rack-info-row"><b>Ubicación</b>${esc(item.ubic)}</div>
    <div class="rack-info-row"><b>Rack</b>Rack ${p.rack}</div>
    <div class="rack-info-row"><b>Posición</b>${p.posicion}</div>
    <div class="rack-info-row"><b>Altura</b>${p.altura}</div>
    <div class="rack-info-row"><b>SKU</b>${esc(skus.join(" / ") || "-")}</div>
    <div class="rack-info-row"><b>Producto</b>${esc(productos.join(" / ") || "-")}</div>
    <div class="rack-info-row"><b>Cajas en ubicación</b>${nf.format(item.cajasTotal)}</div>
    <div class="rack-info-row"><b>Kg en ubicación</b>${nfK.format(item.kgTotal)} Kg</div>
    <div class="rack-info-row"><b>Días inventario</b>${nf.format(item.diasMax || 0)} días</div>
    <div class="rack-info-row"><b>Tarima</b>${esc(tarimas.join(" / ") || "-")}</div>
    <div class="rack-info-row"><b>Lote</b>${esc(item.lote || "-")}</div>
    <div class="rack-info-row"><b>Etiquetas</b>${nf.format(item.productos.length)}</div>
    `;
    }

    function calcularKpisCamara(rows) {
    rows = rows || [];

    const totalEtiquetas = rows.length;
    const totalKg = rows.reduce((s, r) => s + Number(getVal(r, "Kg", "kg") || 0), 0);

    const ubicaciones = new Set(
    rows
    .map(r => String(getVal(r, "Ubic", "ubic") || "").trim())
    .filter(x => x && x !== "-")
    );

    const posicionesOcupadas = ubicaciones.size;

    // Ajusta esta capacidad según tu cámara real.
    // Ejemplo: 5 racks * 8 posiciones * 4 alturas = 160 posiciones.
    const capacidadTotalPosiciones = 160;

    const capacidad = capacidadTotalPosiciones > 0
    ? Math.round((posicionesOcupadas / capacidadTotalPosiciones) * 100)
    : 0;

    // Temporal: valor aproximado por kg.
    // Lo ideal es traer costo/precio desde SQL.
    const costoPromedioKg = 80;
    const valorInventario = totalKg * costoPromedioKg;

    const fechas = rows
    .map(r => getVal(r, "Fecha", "fecha"))
    .filter(Boolean)
    .map(f => diasInventario(f));

    const diasPromedio = fechas.length
    ? Math.round(fechas.reduce((s, d) => s + d, 0) / fechas.length)
    : 0;

    const diasMax = fechas.length ? Math.max(...fechas) : 0;

    // Fórmulas base, después las podemos conectar con ventas reales.
    const rotacion = diasPromedio > 0
    ? (365 / diasPromedio)
    : 0;

    const daysOfSupply = diasPromedio;

    const criticos = rows.filter(r => diasInventario(getVal(r, "Fecha", "fecha")) >= 30).length;

    // Reorden provisional: productos con menos de 10 cajas/etiquetas por SKU.
    const porSku = {};

    rows.forEach(r => {
    const sku = getVal(r, "Sku", "sku") || "-";
    if (!porSku[sku]) porSku[sku] = 0;
    porSku[sku]++;
    });

    const reorden = Object.keys(porSku).filter(sku => porSku[sku] <= 10).length;

    document.getElementById("kpi-capacidad").textContent = nf.format(capacidad) + "%";
    document.getElementById("kpi-valor").textContent = "$" + nf.format(valorInventario);
    document.getElementById("kpi-rotacion").textContent = nfP.format(rotacion);
    document.getElementById("kpi-dos").textContent = nf.format(daysOfSupply);
    document.getElementById("kpi-reorden").textContent = nf.format(reorden);
    document.getElementById("kpi-criticos").textContent = nf.format(criticos);
    }

    function resizeRackThree() {
    const cont = document.getElementById("rack3d-canvas");

    if (!rackRenderer || !rackCamera || !cont) return;

    rackCamera.aspect = cont.clientWidth / cont.clientHeight;
    rackCamera.updateProjectionMatrix();

    rackRenderer.setSize(cont.clientWidth, cont.clientHeight);
    }

    function animateRackThree() {
    rackAnimationId = requestAnimationFrame(animateRackThree);

    if (rackControls) {
    rackControls.update();
    }

    if (rackRenderer && rackScene && rackCamera) {
    rackRenderer.render(rackScene, rackCamera);
    }
    }


    function diasInventario(fecha) {
    if (!fecha) return 0;

    const f = new Date(String(fecha).substring(0, 10) + "T00:00:00");
    const hoy = new Date();
    hoy.setHours(0, 0, 0, 0);

    if (isNaN(f.getTime())) return 0;

    return Math.floor((hoy - f) / 86400000);
    }

    function colorSemaforoPorDias(dias) {
    if (dias <= 15) return 0x22c55e;   // verde
    if (dias <= 30) return 0xfacc15;   // amarillo
    return 0xef4444;                   // rojo
    }


    function ordenarInventario(col){

    if(sortCol === col){
    sortDir = sortDir === "asc" ? "desc" : "asc";
    }else{
    sortCol = col;
    sortDir = "asc";
    }

    datosInv.sort((a,b)=>{

    let v1 = a[col];
    let v2 = b[col];

    if(!isNaN(v1) && !isNaN(v2)){
    v1 = Number(v1);
    v2 = Number(v2);
    }else{
    v1 = String(v1).toLowerCase();
    v2 = String(v2).toLowerCase();
    }

    if(v1 > v2) return sortDir === "asc" ? 1 : -1;
    if(v1 < v2) return sortDir === "asc" ? -1 : 1;
    return 0;
    });

    document.querySelectorAll("#tbl-inv th").forEach(x=>{
    x.classList.remove("asc");
    x.classList.remove("desc");
    });

    let th = document.querySelector(`#tbl-inv th[data-col='${col}']`);
    if(th) th.classList.add(sortDir);

    renderInventario(datosInv);
    }

    function ordenarTrazabilidad(col) {
    if (!datosTraz || !datosTraz.length) return;

    if (sortTrazCol === col) {
    sortTrazDir = sortTrazDir === "asc" ? "desc" : "asc";
    } else {
    sortTrazCol = col;
    sortTrazDir = "asc";
    }

    datosTraz.sort((a, b) => {
    let v1;
    let v2;

    if (col === "diasInv") {
    v1 = diasInventario(getVal(a, "Fecha", "fecha"));
    v2 = diasInventario(getVal(b, "Fecha", "fecha"));
    } else {
    v1 = getVal(a, col, col.charAt(0).toLowerCase() + col.slice(1));
    v2 = getVal(b, col, col.charAt(0).toLowerCase() + col.slice(1));
    }

    if (!isNaN(v1) && !isNaN(v2) && v1 !== "" && v2 !== "") {
    v1 = Number(v1);
    v2 = Number(v2);
    } else {
    v1 = String(v1 || "").toLowerCase();
    v2 = String(v2 || "").toLowerCase();
    }

    if (v1 > v2) return sortTrazDir === "asc" ? 1 : -1;
    if (v1 < v2) return sortTrazDir === "asc" ? -1 : 1;
    return 0;
    });

    document.querySelectorAll("#tbl-traz th").forEach(x => {
    x.classList.remove("asc", "desc");
    });

    const th = document.querySelector(`#tbl-traz th[data-col-traz='${col}']`);
    if (th) th.classList.add(sortTrazDir);

    renderTrazabilidad(datosTraz);
    }


    async function cargarTotalCamara() {
    const camara = camaraActual || [...camarasSeleccionadas][0] || "";

    if (!camara) {
    alert("Selecciona una cámara primero.");
    return;
    }

    try {
    const url = `/ProcesosCG/DetalleCamaraCompleta?planta=${encodeURIComponent(plantaActual)}&camara=${encodeURIComponent(camara)}`;

    const resp = await fetch(url);
    const data = await resp.json();

    if (!data.ok) {
    alert(data.mensaje || "Error cargando total cámara");
    datosTraz = [];
    renderTrazabilidad([]);
    return;
    }

    datosTrazOriginal = data.rows || [];
    datosTraz = datosTrazOriginal;

    renderTrazabilidad(datosTraz);

    } catch (err) {
    console.error(err);
    alert("Error conectando con DetalleCamaraCompleta");
    }
    }

    function exportarExcelBasico() {
    const table = document.getElementById("tbl-inv").outerHTML;
    const blob = new Blob([table], { type: "application/vnd.ms-excel" });
    const a = document.createElement("a");

    a.href = URL.createObjectURL(blob);
    a.download = "Inventario_Camaras.xls";
    a.click();

    URL.revokeObjectURL(a.href);
    }

    document.getElementById("sidebar-list").addEventListener("click", e => {
    const item = e.target.closest(".cam-item");
    if (!item || !item.dataset.cam) return;

    const cam = item.dataset.cam;

    if (e.ctrlKey || e.metaKey) {
    if (camarasSeleccionadas.has(cam)) {
    camarasSeleccionadas.delete(cam);
    } else {
    camarasSeleccionadas.add(cam);
    }
    } else {
    camarasSeleccionadas.clear();
    camarasSeleccionadas.add(cam);
    }

    camaraActual = camarasSeleccionadas.size === 1 ? [...camarasSeleccionadas][0] : null;

    renderSidebar();
    cargarInventario();
    });

    document.getElementById("tbody-inv").addEventListener("click", e => {
    const tr = e.target.closest("tr");
    if (!tr || !tr.dataset.idx) return;

    document.querySelectorAll("#tbody-inv tr").forEach(x => x.classList.remove("row-sel"));
    tr.classList.add("row-sel");

    const row = datosInv[Number(tr.dataset.idx)];
    cargarTrazabilidad(row);
    });

    document.querySelectorAll(".btn-planta").forEach(btn => {
    btn.addEventListener("click", async () => {
    document.querySelectorAll(".btn-planta").forEach(x => x.classList.remove("active"));
    btn.classList.add("active");

    plantaActual = btn.dataset.planta;
    camaraActual = null;
    camarasSeleccionadas.clear();
    datosInv = [];
    datosTraz = [];

    await cargarCamarasPorPlanta();
    renderInventario([]);
    renderTrazabilidad([]);
    cargarInventario();
    });
    });

    document.getElementById("btn-buscar").addEventListener("click", cargarInventario);
    document.getElementById("btn-excel").addEventListener("click", function () {

    if (!datosInv || !datosInv.length) {
        alert("No hay inventario para exportar.");
        return;
    }

    let wb = XLSX.utils.book_new();

    let ws1 = XLSX.utils.json_to_sheet(datosInv);
    XLSX.utils.book_append_sheet(wb, ws1, "Inventario");

    let ws2 = XLSX.utils.json_to_sheet(datosTraz || []);
    XLSX.utils.book_append_sheet(wb, ws2, "Detalle");

    XLSX.writeFile(wb, "Inventario_Camaras.xlsx");
});

   
    document.getElementById("btn-rack3d").addEventListener("click", abrirRack3D);
    document.getElementById("btn-close-rack").addEventListener("click", cerrarRack3D);
    document.getElementById("btn-buscar-rack").addEventListener("click", buscarEnRack3D);
    document.getElementById("btn-limpiar-rack").addEventListener("click", () => {
    datosTraz = datosTrazOriginal;
    document.getElementById("txt-buscar-rack").value = "";
    document.getElementById("rack-search-result").textContent = "Sin búsqueda";

    limpiarEscenaRack();
    renderRackThree();
    calcularKpisCamara(datosTraz);
    });


    document.querySelectorAll("#tbl-traz th[data-col-traz]").forEach(th => {
    th.addEventListener("click", function () {
        ordenarTrazabilidad(this.dataset.colTraz);
    });
});

    document.getElementById("btn-total-camara").addEventListener("click", cargarTotalCamara);

    document.getElementById("txt-buscar-rack").addEventListener("keydown", e => {
    if (e.key === "Enter") {
    buscarEnRack3D();
    }
    });

    document.getElementById("modal-rack3d").addEventListener("click", e => {
    if (e.target.id === "modal-rack3d") cerrarRack3D();
    });

    document.querySelectorAll("#tbl-inv th[data-col]").forEach(th=>{

    th.addEventListener("click",function(){

    let col = this.dataset.col;
    ordenarInventario(col);

    });

    });

    window.seleccionarTodas = function () {
    camarasSeleccionadas = new Set(PLANTAS[plantaActual].camaras);
    camaraActual = null;
    renderSidebar();
    cargarInventario();
    };

    window.limpiarSeleccion = function () {
    camarasSeleccionadas.clear();
    camaraActual = null;
    datosInv = [];
    datosTraz = [];
    renderSidebar();
    renderInventario([]);
    renderTrazabilidad([]);
    };

    cargarCamarasPorPlanta().then(() => cargarInventario());
</script>

<script>
    (() => {
        "use strict";

        const pagina = document.querySelector(".camaras-page");
        const boton = document.getElementById("btn-pantalla-vista");

        if (!pagina) return;

        function prepararContenedorLayout() {
            const contenedorDirecto = pagina.parentElement;
            if (contenedorDirecto) {
                contenedorDirecto.classList.add("inventario-planta-direct-host");
            }

            let actual = pagina.parentElement;

            while (actual && actual !== document.body) {
                actual.classList.add("inventario-planta-host");

                if (
                    actual.matches(
                        ".container, .container-fluid, .container-sm, .container-md, " +
                        ".container-lg, .container-xl, .container-xxl, .body-content, .pb-3"
                    )
                ) {
                    actual.classList.add("inventario-planta-host-clean");
                }

                actual = actual.parentElement;
            }
        }

        function ajustarAreaTrabajo() {
            const area = pagina.querySelector(".inv-layout");
            if (!area) return;

            if (pagina.classList.contains("ip-focus-mode")) {
                pagina.style.removeProperty("--ip-work-height");
                return;
            }

            const rect = area.getBoundingClientRect();
            const espacioInferior = 8;
            const altoDisponible = Math.max(
                340,
                Math.floor(window.innerHeight - Math.max(0, rect.top) - espacioInferior)
            );

            pagina.style.setProperty("--ip-work-height", `${altoDisponible}px`);
        }

        function ajustarAlturaDisponible() {
            if (pagina.classList.contains("ip-focus-mode")) {
                pagina.style.setProperty("--ip-available-height", "100dvh");
                pagina.style.removeProperty("--ip-work-height");
                return;
            }

            const rect = pagina.getBoundingClientRect();
            const top = Math.max(0, rect.top);
            const alto = Math.max(480, window.innerHeight - top);
            pagina.style.setProperty("--ip-available-height", `${alto}px`);

            requestAnimationFrame(ajustarAreaTrabajo);
        }

        function actualizarBotonPantalla() {
            if (!boton) return;

            const activo = pagina.classList.contains("ip-focus-mode");
            boton.setAttribute("aria-pressed", activo ? "true" : "false");
            boton.innerHTML = activo
                ? '<i class="fa-solid fa-compress"></i><span>Salir</span>'
                : '<i class="fa-solid fa-expand"></i><span>Pantalla</span>';
        }

        function cambiarModoPantalla(forzar) {
            const activoActual = pagina.classList.contains("ip-focus-mode");
            const activar = typeof forzar === "boolean" ? forzar : !activoActual;

            pagina.classList.toggle("ip-focus-mode", activar);
            document.body.classList.toggle("inventario-planta-focus", activar);

            actualizarBotonPantalla();
            ajustarAlturaDisponible();

            requestAnimationFrame(() => {
                window.dispatchEvent(new Event("resize"));
            });
        }

        prepararContenedorLayout();
        ajustarAlturaDisponible();
        actualizarBotonPantalla();

        requestAnimationFrame(() => {
            ajustarAlturaDisponible();
            ajustarAreaTrabajo();
        });

        window.addEventListener("load", () => {
            ajustarAlturaDisponible();
            ajustarAreaTrabajo();
        }, { once: true });

        setTimeout(() => {
            ajustarAlturaDisponible();
            ajustarAreaTrabajo();
        }, 250);

        boton?.addEventListener("click", () => cambiarModoPantalla());

        document.addEventListener("keydown", event => {
            if (event.key === "Escape" && pagina.classList.contains("ip-focus-mode")) {
                cambiarModoPantalla(false);
            }
        });

        window.addEventListener("resize", () => {
            ajustarAlturaDisponible();
            ajustarAreaTrabajo();
        }, { passive: true });

        window.addEventListener("orientationchange", () => {
            ajustarAlturaDisponible();
            ajustarAreaTrabajo();
        }, { passive: true });
    })();
</script>

