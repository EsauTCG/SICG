    const url = `/ProcesosCG/TrazabilidadCamara?planta=${encodeURIComponent(plantaActual)}&sku=${encodeURIComponent(row.sku)}&camara=${encodeURIComponent(camaraDetalle)}`;
    const resp = await fetch(url);
    const data = await resp.json();

    if (!data.ok) {
    alert(data.mensaje || "Error cargando trazabilidad");
    datosTraz = [];
    renderTrazabilidad([]);
    return;
    }

    datosTraz = data.rows || [];
    renderTrazabilidad(datosTraz);

    } catch (err) {
