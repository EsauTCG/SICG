<script>
    const nf = new Intl.NumberFormat('es-MX', { maximumFractionDigits: 0 });
    const nfK = new Intl.NumberFormat('es-MX', { minimumFractionDigits: 3, maximumFractionDigits: 3 });
    const nfP = new Intl.NumberFormat('es-MX', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    let plantaActual = "P1";
    let camaraActual = null;
    let camarasSeleccionadas = new Set();
    let datosInv = [];
    let datosTraz = [];

    let rackScene = null;
    let rackCamera = null;
    let rackRenderer = null;
    let rackIndexMap = {};
    let rackControls = null;
    let rackRaycaster = null;
    let rackMouse = null;
    let rackObjects = [];
    let rackAnimationId = null;
    let rackItemsIndex = [];
    let rackCamaraActualVista = "";
    let datosTrazOriginal = [];

    let sortCol = "";
    let sortDir = "asc";

    let sortTrazCol = "";
    let sortTrazDir = "asc";

    const PLANTAS = {
    P1: { label: 'PLANTA 1', camaras: [] },
    TIF: { label: 'TIF', camaras: [] }
    };

    function esc(v) {
    return String(v ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");
    }

    function getVal(obj, ...keys) {
    for (const k of keys) {
    if (obj && obj[k] !== undefined && obj[k] !== null) return obj[k];
    }
    return "";
    }

    function formatDate(v) {
    if (!v) return "-";

    const s = String(v);

    if (s.includes("T")) {
    return s.substring(0, 10);
    }

    return s.length >= 10 ? s.substring(0, 10) : s;
    }

    function formatDateTime(v) {
    if (!v) return "-";

    const s = String(v);

    if (s.includes("T")) {
        return s.substring(0, 16).replace("T", " ");
    }

    return s.length >= 16 ? s.substring(0, 16) : s;
}

    async function cargarCamarasPorPlanta() {
    const list = document.getElementById('sidebar-list');
    list.innerHTML = '<div class="cam-item">Cargando...</div>';

    try {
    const resp = await fetch(`/ProcesosCG/ObtenerCamaras?planta=${encodeURIComponent(plantaActual)}`);
    const data = await resp.json();

    if (!data.ok) {
    alert(data.mensaje || 'Error cargando cámaras');
    PLANTAS[plantaActual].camaras = [];
    renderSidebar();
    return;
    }

    PLANTAS[plantaActual].camaras = data.camaras || [];
    renderSidebar();

    } catch (err) {
    console.error(err);
    alert('Error conectando con ObtenerCamaras');
    PLANTAS[plantaActual].camaras = [];
    renderSidebar();
    }
    }

    function renderSidebar() {
    const planta = PLANTAS[plantaActual];
    document.getElementById("sidebar-title").textContent = "Cámaras" 

    const list = document.getElementById("sidebar-list");

    if (!planta.camaras.length) {
    list.innerHTML = '<div class="cam-item">Sin cámaras</div>';
    return;
    }

    list.innerHTML = planta.camaras.map(c =>
    `<div class="cam-item${camarasSeleccionadas.has(c) ? " active" : ""}" data-cam="${esc(c)}">${esc(c)}</div>`
    ).join("");
    }

    async function cargarInventario() {
    const skuFiltro = document.getElementById("txt-sku").value.trim().toLowerCase();
    const productoFiltro = document.getElementById("txt-producto").value.trim().toLowerCase();

    try {
    const camaras = [...camarasSeleccionadas];
    const camarasParaConsultar = camaras.length ? camaras : [""];

    let todasLasFilas = [];

    for (const cam of camarasParaConsultar) {
    const url = `/ProcesosCG/InventarioCamaras?planta=${encodeURIComponent(plantaActual)}&camara=${encodeURIComponent(cam)}`;

    const resp = await fetch(url);
    const data = await resp.json();

    if (!data.ok) {
    console.warn(data.mensaje || "Error cargando inventario");
    continue;
    }

    const rows = (data.rows || []).map(r => ({
    fecha: getVal(r, "Fecha", "fecha") || "-",
    almacen: getVal(r, "Almacen", "almacen") || cam || "",
    sku: getVal(r, "Sku", "sku") || "",
    nombre: getVal(r, "Nombre", "nombre", "Producto", "producto") || "",
    cajas: Number(getVal(r, "Cajas", "cajas") || 0),
    kg: Number(getVal(r, "Kg", "kg") || 0),
    prom: Number(getVal(r, "Prom", "prom") || 0),
    lineaId: getVal(r, "LineaId", "lineaId") || "",
    estatus: getVal(r, "Estatus", "estatus") || "",
    ubic: getVal(r, "Ubic", "ubic") || "-"
    }));

    todasLasFilas = todasLasFilas.concat(rows);
    }

    if (skuFiltro) {
    todasLasFilas = todasLasFilas.filter(r =>
    String(r.sku).toLowerCase().includes(skuFiltro)
    );
    }

    if (productoFiltro) {
    todasLasFilas = todasLasFilas.filter(r =>
    String(r.nombre).toLowerCase().includes(productoFiltro)
    );
    }

    datosInv = todasLasFilas;
    datosTraz = [];

    renderInventario(todasLasFilas);
    renderTrazabilidad([]);

    } catch (err) {
    console.error(err);
    alert("Error conectando con InventarioCamaras");
    datosInv = [];
    datosTraz = [];
    renderInventario([]);
    renderTrazabilidad([]);
    }
    }


    function actualizarKpisInventario(rows) {
    rows = Array.isArray(rows) ? rows : [];

    const totalCajas = rows.reduce((s, r) => s + Number(r.cajas || 0), 0);
    const totalKg = rows.reduce((s, r) => s + Number(r.kg || 0), 0);
    const skus = new Set(rows.map(r => String(r.sku || "").trim()).filter(Boolean));
    const almacenes = new Set(rows.map(r => String(r.almacen || "").trim()).filter(Boolean));
    const inactivos = rows.filter(r => String(r.estatus || "").trim().toUpperCase() !== "ACTIVO").length;
    const promedio = totalCajas > 0 ? totalKg / totalCajas : 0;

    const totalCamaras = Number(PLANTAS[plantaActual]?.camaras?.length || 0);
    const seleccionadas = camarasSeleccionadas.size;
    const camarasMostradas = seleccionadas || almacenes.size || totalCamaras;

    const setText = (id, value) => {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
    };

    setText("kpi-main-camaras", nf.format(camarasMostradas));
    setText("kpi-main-camaras-sub", seleccionadas ? "Seleccionadas" : "Todas / visibles");
    setText("kpi-main-skus", nf.format(skus.size));
    setText("kpi-main-cajas", nf.format(totalCajas));
    setText("kpi-main-kg", nfK.format(totalKg));
    setText("kpi-main-prom", nfP.format(promedio));
    setText("kpi-main-alertas", nf.format(inactivos));
