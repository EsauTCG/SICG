@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "AutoArtículos - Control de Acceso";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

<style>
    :root {
        --brand-main: #4a0e0e;
        --brand-hover: #6b1515;
        --bg-page: #fdf5f4;
        --card-bg: #ffffff;
        --panel-bg: #fcf5f4;
        --border-color: #ebdcdb;
        --text-dark: #333333;
        --text-muted: #888888;
    }

    body {
        background-color: var(--bg-page);
        color: var(--text-dark);
        font-family: 'Segoe UI', Tahoma, sans-serif;
        font-size: 0.85rem;
    }

    .dashboard-panel {
        background-color: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border-color);
        margin-bottom: 1.5rem;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
    }

    .top-banner {
        background-color: var(--brand-main);
        color: white;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        transition: background-color 0.3s;
    }

    /* Mejora responsiva en los tabs */
    .nav-tabs {
        border-bottom: 2px solid var(--border-color);
        margin-bottom: 1.5rem;
        flex-wrap: nowrap;
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
        padding-bottom: 2px;
        -webkit-overflow-scrolling: touch; /* Suavidad en iOS */
    }

        .nav-tabs::-webkit-scrollbar {
            height: 4px;
        }

        .nav-tabs::-webkit-scrollbar-thumb {
            background-color: var(--border-color);
            border-radius: 4px;
        }

        .nav-tabs .nav-link {
            color: var(--text-muted);
            font-weight: 600;
            border: none;
            padding: 10px 20px;
            transition: 0.3s;
            background: transparent;
        }

            .nav-tabs .nav-link:hover {
                color: var(--brand-main);
            }

            .nav-tabs .nav-link.active {
                color: var(--brand-main);
                border-bottom: 3px solid var(--brand-main);
                background-color: transparent;
            }

    .btn-brand {
        background-color: var(--brand-main);
        color: white;
        border: none;
        padding: 6px 16px;
        border-radius: 20px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-brand:hover {
            background-color: var(--brand-hover);
            color: white;
        }

    .table-custom thead th {
        background-color: var(--panel-bg);
        color: var(--text-muted);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.7rem;
        border-bottom: 2px solid var(--border-color);
        padding: 12px;
    }

    .table-custom tbody tr {
        border-bottom: 1px solid var(--border-color);
    }

        .table-custom tbody tr:hover {
            background-color: #fafafa;
        }

    .table-custom tbody td {
        vertical-align: middle;
        padding: 12px;
    }

    .btn-sm-action {
        padding: 4px 8px;
        font-size: 0.75rem;
        border-radius: 6px;
        border: 1px solid var(--border-color);
        background: white;
        cursor: pointer;
        transition: all 0.2s;
        color: var(--text-dark);
    }

        .btn-sm-action:hover {
            background: var(--bg-page);
            border-color: var(--brand-main);
            color: var(--brand-main);
        }

    .crit-critico {
        background-color: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecaca;
    }

    .crit-semi {
        background-color: #fefce8;
        color: #ca8a04;
        border: 1px solid #fef08a;
    }

    .crit-no {
        background-color: #f3f4f6;
        color: #4b5563;
        border: 1px solid #e5e7eb;
    }

    .badge-crit {
        padding: 4px 10px;
        border-radius: 12px;
        font-weight: 800;
        font-size: 0.7rem;
        display: inline-block;
        margin-bottom: 4px; /* Espaciado extra en móvil */
    }

    .acceso-concedido {
        background-color: #dcfce7 !important;
        border-color: #22c55e !important;
    }

    .acceso-denegado {
        background-color: #fee2e2 !important;
        border-color: #ef4444 !important;
    }

    .lista-equipos-container {
        max-height: 400px;
        overflow-y: auto;
        border-radius: 8px;
    }

    .eq-checkbox-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 15px;
        border-bottom: 1px solid var(--border-color);
        background-color: white;
        transition: background-color 0.2s;
    }

    .form-switch .form-check-input {
        width: 2.5em;
        height: 1.25em;
        cursor: pointer;
    }

        .form-switch .form-check-input:checked {
            background-color: var(--brand-main);
            border-color: var(--brand-main);
        }

    .accordion-button {
        font-size: 0.85rem;
        padding: 12px 15px;
    }

        .accordion-button:not(.collapsed) {
            background-color: var(--panel-bg);
            color: var(--brand-main);
            font-weight: bold;
            box-shadow: inset 0 -1px 0 rgba(0,0,0,.125);
        }

        .accordion-button:focus {
            box-shadow: none;
            border-color: rgba(0,0,0,.125);
        }

    .grupo-acciones {
        font-size: 0.75rem;
        background: #f8f9fa;
        padding: 6px 15px;
        border-bottom: 1px solid var(--border-color);
    }

    .letter-spacing-2 {
        letter-spacing: 0.5rem;
    }

    /* --- AJUSTES RESPONSIVOS --- */
    @@media (max-width: 768px) {
        .top-banner {
            flex-direction: column;
            align-items: flex-start !important;
            text-align: center;
            padding: 1rem;
        }

            .top-banner div {
                width: 100%;
            }

            .top-banner h2 {
                font-size: 1.5rem;
            }

            .top-banner button {
                width: 100%;
                margin-top: 10px;
            }
        /* Ajuste de botones en la pestaña permisos */
        .tab-pane#permisos .d-flex.gap-2 {
            flex-direction: column;
            width: 100%;
        }

        .tab-pane#permisos .btn {
            width: 100%;
        }
        /* Ajuste de contenedor de cámara */
        #qr-reader-container {
            min-height: 300px !important;
        }
        /* Ajuste de la foto de perfil en el resultado */
        #imgUsuario {
            width: 80px !important;
            height: 80px !important;
        }

        .row.text-start.align-items-center {
            flex-direction: column;
            text-align: center !important;
        }

            .row.text-start.align-items-center .col-4,
            .row.text-start.align-items-center .col-8 {
                width: 100%;
                text-align: center;
            }

        #lblCategorias {
            justify-content: center;
        }
        /* Ajuste del modal Asignar Permisos en móvil */
        #panelEquiposCheckbox .d-flex.justify-content-between {
            flex-direction: column;
            align-items: stretch !important;
            gap: 10px;
        }

        #buscarCheckbox {
            width: 100% !important;
        }
    }


    /* ESTILO GENERAL ROSITA / VINO */
    html,
    body {
        background: #e9edf2 !important;
        overflow-x: hidden !important;
    }

    body,
    main,
    .main,
    .body-content,
    .container,
    .container-fluid {
        background: #e9edf2 !important;
    }

    .container-fluid {
        width: min(100%, calc(100vw - 48px)) !important;
        max-width: 1900px !important;
        margin: 0 auto !important;
        padding: 8px !important;
    }

    /* Encabezado */
    .top-banner {
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
        border-radius: 0 !important;
        border: 1px solid #7e4a4a !important;
        box-shadow: 0 8px 18px rgba(70,12,12,.14) !important;
    }

    /* Paneles */
    .dashboard-panel {
        background: #f8eeee !important;
        border: 1px solid #c79d9d !important;
        border-radius: 0 !important;
        box-shadow: none !important;
    }

    .panel-header {
        background: #f1dede !important;
        border-bottom: 1px solid #c79d9d !important;
    }

    .panel-title {
        color: #5c1a1a !important;
    }

    /* Inputs */
    .form-control,
    .form-select,
    .input-group-text {
        background: #fffafa !important;
        border: 1px solid #b48787 !important;
        color: #421414 !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        font-size: 12px !important;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #8b0000 !important;
            box-shadow: 0 0 0 .15rem rgba(139,0,0,.12) !important;
        }

    /* Botones */
    .btn-brand {
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
        border: 1px solid #7a2d2d !important;
        color: #fff !important;
        border-radius: 0 !important;
    }

    .btn-outline,
    .btn-outline-secondary {
        background: linear-gradient(#fffefe,#ecd7d7) !important;
        border: 1px solid #b48787 !important;
        color: #4b1f1f !important;
        border-radius: 0 !important;
        font-weight: 700 !important;
    }

        .btn-outline:hover,
        .btn-outline-secondary:hover {
            background: #f4dddd !important;
            border-color: #8b0000 !important;
            color: #5c0000 !important;
        }

    /* Tabs VLAN */
    .nav-tabs {
        border-bottom: 1px solid #c79d9d !important;
        background: #f1dede !important;
        padding: 4px !important;
        margin-top: 12px !important;
    }

        .nav-tabs .nav-link {
            background: linear-gradient(#fffefe,#ecd7d7) !important;
            border: 1px solid #caa0a0 !important;
            color: #5c1a1a !important;
            border-radius: 0 !important;
            margin-right: 4px !important;
            font-weight: 700 !important;
        }

            .nav-tabs .nav-link.active {
                background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
                color: #fff !important;
                border-color: #7a2d2d !important;
            }

    /* Tabla */
    .table-responsive {
        background: #fffafa !important;
        border-top: 1px solid #d9b8b8 !important;
    }

    .table-custom {
        background: #fffafa !important;
        border-collapse: separate !important;
        border-spacing: 0 !important;
        font-size: 12px !important;
    }

        .table-custom thead th {
            position: sticky;
            top: 0;
            z-index: 10;
            background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
            color: #fff !important;
            border-right: 1px solid #8e3b3b !important;
            border-bottom: 1px solid #5c0000 !important;
            padding: 7px 6px !important;
            font-size: 12px !important;
            text-transform: none !important;
            white-space: nowrap !important;
        }

        .table-custom tbody td {
            background: #fffafa !important;
            border-right: 1px solid #d8bcbc !important;
            border-bottom: 1px solid #d8bcbc !important;
            color: #401515 !important;
            padding: 6px !important;
            white-space: nowrap;
        }

        .table-custom tbody tr:nth-of-type(even) > td {
            background: #f9eded !important;
        }

        .table-custom tbody tr:hover > td {
            background: #f4dddd !important;
        }

    /* Badges */
    .ip-badge {
        background: #fff3cd !important;
        color: #664d03 !important;
        border: 1px solid #d6b656 !important;
        border-radius: 0 !important;
    }

    .badge-disponible {
        background: #d1e7dd !important;
        color: #0f5132 !important;
        border: 1px solid #badbcc !important;
        border-radius: 0 !important;
    }

    .tipo-cable,
    .tipo-wifi {
        border-radius: 0 !important;
    }

    /* Modal mismo estilo */
    .modal-content {
        border: 1px solid #7d4949 !important;
        border-radius: 0 !important;
    }

    .modal-header {
        background: linear-gradient(180deg,#b30000 0%,#8b0000 55%,#5c0000 100%) !important;
        color: #fff !important;
        border-bottom: 1px solid #5c0000 !important;
    }

    .modal-title {
        color: #fff !important;
        font-size: 13px !important;
        font-weight: 700 !important;
    }

    .modal-body {
        background: #f0dede !important;
    }

    .modal-footer {
        background: #f7eaea !important;
        border-top: 1px solid #d3b0b0 !important;
    }

    /* RESPONSIVO */
    @@media (min-width: 1400px) {
        .container-fluid {
            width: calc(100vw - 80px) !important;
        }
    }

    @@media (max-width: 1200px) {
        .container-fluid {
            width: calc(100vw - 24px) !important;
        }
    }

    @@media (max-width: 768px) {
        .container-fluid {
            width: 100% !important;
            max-width: 100% !important;
            padding: 6px !important;
        }

        .top-banner {
            padding: 12px !important;
        }

            .top-banner h2 {
                font-size: 18px !important;
            }

        .dashboard-panel {
            padding: 8px !important;
        }

        .row.align-items-center > div {
            width: 100% !important;
        }

        .col-12.col-md-8.col-lg-9 {
            justify-content: flex-start !important;
        }

        .input-group {
            max-width: 100% !important;
            width: 100% !important;
        }

        .btn,
        .btn-brand,
        .btn-outline,
        .btn-outline-secondary {
            width: 100% !important;
            font-size: 12px !important;
        }

        .nav-tabs {
            flex-wrap: nowrap !important;
            overflow-x: auto !important;
        }

            .nav-tabs .nav-link {
                min-width: max-content !important;
                font-size: 11px !important;
                padding: 7px 10px !important;
            }

        .table-responsive {
            width: 100% !important;
            overflow-x: auto !important;
            -webkit-overflow-scrolling: touch !important;
            max-height: 65vh !important;
        }

        .table-custom {
            min-width: 920px !important;
            font-size: 10px !important;
        }

            .table-custom thead th,
            .table-custom tbody td {
                font-size: 10px !important;
                padding: 4px 3px !important;
            }

        .modal-dialog {
            width: 100% !important;
            max-width: 100% !important;
            margin: 0 !important;
        }

        .modal-content {
            min-height: 100vh !important;
        }
    }




    /* AUTOARTICULOS - ajustes específicos con el estilo del primer código */
