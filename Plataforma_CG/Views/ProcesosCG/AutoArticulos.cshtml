@section Scripts {
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        let modalAsignar;
        let catalogoCategorias = [];
        let usuariosTablaGlobal = [];
        let html5QrCode;
        let lastScanTime = 0;
        let timerPantalla;

        let accionSeguraPendiente = null;
        let usuarioEscaneadoId = null;

        $(document).ready(async function () {
        modalAsignar = new bootstrap.Modal(document.getElementById('modalAsignarPermiso'));

        $('#selectUsuario').select2({
        theme: 'bootstrap-5',
        dropdownParent: $('#modalAsignarPermiso'),
        width: '100%'
        });

        await cargarDatosBase();
        await renderTablaPermisos();

        $("#buscadorPermisos").on("keyup", function () {
        let value = $(this).val().toLowerCase();
        $("#tbodyPermisos tr").filter(function () {
        $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
        });
        });

        $('#inSupervisorPin').keypress(function (e) {
        if (e.which == 13) $('#btnConfirmarPin').click();
        });
        $('#exPin').keypress(function (e) {
        if (e.which == 13) procesarAutorizacion();
        });
        });

        // Contraseñas y permisos
        function pedirAutorizacion(accion) {
        accionSeguraPendiente = accion;
        $('#inSupervisorPin').val('');
        new bootstrap.Modal(document.getElementById('modalPassword')).show();
        setTimeout(() => { $('#inSupervisorPin').focus(); }, 500);
        }

        $('#btnConfirmarPin').click(async function () {
        let pin = $('#inSupervisorPin').val();
        if (!pin) return;

        let formData = new FormData();
        formData.append("pin", pin);

        try {
        const res = await fetch('@Url.Action("ValidarPinSupervisor", "ProcesosCG")', {
        method: 'POST', body: formData
        });
        const data = await res.json();

        if (data.ok) {
        $('#modalPassword').modal('hide');
        ejecutarAccionAutorizada();
        } else {
        alert("Aviso: " + data.mensaje);
        $('#inSupervisorPin').val('').focus();
        }
        } catch (e) { alert("Error de comunicación."); }
        });

        function ejecutarAccionAutorizada() {
        if (accionSeguraPendiente === 'ASIGNAR') {
        abrirModalAsignar();
        } else if (accionSeguraPendiente === 'NUEVO_USUARIO') {
        abrirModalNuevoUsuario();
        }
        accionSeguraPendiente = null;
        }

        // Cambio de PIN
        function abrirModalCambiarPin() {
        $('#cpActual').val('');
        $('#cpNuevo').val('');
        $('#cpConfirmar').val('');
        new bootstrap.Modal(document.getElementById('modalCambiarPin')).show();
        }

        async function procesarCambioPin() {
        let actual = $('#cpActual').val();
        let nuevo = $('#cpNuevo').val();
        let confirmar = $('#cpConfirmar').val();

        if (!actual || !nuevo || !confirmar) {
        alert("Aviso: Llene todos los campos.");
        return;
        }

        if (nuevo !== confirmar) {
        alert("Aviso: El nuevo PIN y la confirmación no coinciden.");
        return;
        }

        let formData = new FormData();
        formData.append("pinActual", actual);
        formData.append("pinNuevo", nuevo);

        try {
        const res = await fetch('@Url.Action("CambiarPinSupervisor", "ProcesosCG")', {
        method: 'POST', body: formData
        });
        const data = await res.json();

        if (data.ok) {
        alert("Éxito: " + data.mensaje);
        bootstrap.Modal.getInstance(document.getElementById('modalCambiarPin')).hide();
        } else {
        alert("Aviso: " + data.mensaje);
        }
        } catch (e) {
        alert("Error de red al intentar cambiar el PIN.");
        }
        }

        // Excepciones y Bitácora
        function abrirModalAutorizacion(uId) {
        if (!uId || uId === 0) {
        alert("Atención: El QR escaneado no pertenece a ningún colaborador. Registre al colaborador antes de autorizar.");
        return;
        }

        usuarioEscaneadoId = uId;
        $('#exMotivo').val('');
        $('#exPin').val('');

        let options = '<option value="" style="color:#888;">-- Seleccione Categoría --</option>';

        const niveles = [
        { id: 'CRITICO', color: '#dc2626', bg: '#fef2f2' },
        { id: 'SEMICRITICO', color: '#ca8a04', bg: '#fefce8' },
        { id: 'NO_CRITICO', color: '#4b5563', bg: '#f3f4f6' }
        ];

        niveles.forEach(nivel => {
        let filtrados = catalogoCategorias.filter(c => c.criticidad === nivel.id);
        filtrados.sort((a, b) => a.nombre.localeCompare(b.nombre));

        if (filtrados.length > 0) {

        options += `<optgroup label="=== NIVEL: ${nivel.id.replace('_', ' ')} ===" style="background-color: ${nivel.bg}; color: ${nivel.color}; font-weight: bold;">`;

        filtrados.forEach(c => {
        options += `<option value="${c.id}" style="background-color: #ffffff; color: ${nivel.color}; font-weight: 600;">${c.nombre}</option>`;
        });

        options += `</optgroup>`;
        }
        });

        $('#exCategoria').html(options);

        new bootstrap.Modal(document.getElementById('modalAutorizacion')).show();
        setTimeout(() => { $('#exMotivo').focus(); }, 500);
        }

        async function procesarAutorizacion() {
        const motivo = $('#exMotivo').val().trim();
        const categoriaId = $('#exCategoria').val();
        const pin = $('#exPin').val();

        if (!motivo || !categoriaId || !pin) {
        alert("Todos los campos son obligatorios para el registro de seguridad.");
        return;
        }

        let formData = new FormData();
        formData.append("pin", pin);
        formData.append("usuarioId", usuarioEscaneadoId);
        formData.append("motivo", motivo);
        formData.append("categoriaId", categoriaId);

        try {
        const res = await fetch('@Url.Action("AutorizarExcepcion", "ProcesosCG")', {
        method: 'POST', body: formData
        });
        const data = await res.json();

        if (data.ok) {
        bootstrap.Modal.getInstance(document.getElementById('modalAutorizacion')).hide();

        let panel = $('#panelResultado');
        panel.removeClass('acceso-denegado').addClass('acceso-concedido');
        $('#lblMensajeAcceso').text('ACCESO AUTORIZADO (BITÁCORA)').attr('class', 'text-warning fw-bold mb-4');
        $('#lblDetalleCheck').html(`<strong>MOTIVO AUTORIZADO:</strong> <br> ${motivo}`);
        $('#btnAutorizarExcepcion').addClass('d-none');

        alert("Registro guardado exitosamente en la bitácora.");

        if ($('#bitacora').hasClass('active')) {
        renderTablaBitacora();
        }
        } else {
        alert("Aviso: " + data.mensaje);
        $('#exPin').val('').focus();
        }
        } catch (e) {
        alert("Error de red al intentar registrar la autorización.");
        }
        }

        // Lógica de cámara
        function encenderCamara() {
        $('#pantallaEsperaCamara').addClass('d-none');
        $('#reader').removeClass('d-none');
        $('#btnApagarCamara').removeClass('d-none');

        Html5Qrcode.getCameras().then(devices => {
        if (devices && devices.length) {
        // Seleccionar la cámara trasera si está en un móvil
        let cameraId = devices[0].id;
        let backendCamera = devices.find(d => d.label.toLowerCase().includes('back') || d.label.toLowerCase().includes('trasera'));
        if (backendCamera) {
        cameraId = backendCamera.id;
        }

        html5QrCode = new Html5Qrcode("reader");

        // Configuración responsiva para el escáner
        let config = { fps: 10, qrbox: { width: 220, height: 220 } };
        if (window.innerWidth < 768) {
        config.qrbox = { width: 180, height: 180 };
        }

        html5QrCode.start(
        cameraId,
        config,
        onScanSuccess, onScanFailure
        ).catch((err) => {
        alert("Error al intentar abrir el lente de la cámara."); apagarCamara();
        });
        } else {
        alert("No se detectó cámara en el dispositivo."); apagarCamara();
        }
        }).catch(err => { alert("El navegador ha bloqueado el acceso a la cámara."); apagarCamara(); });
        }

        function apagarCamara() {
        if (html5QrCode) {
        html5QrCode.stop().then(() => {
        $('#reader').addClass('d-none');
        $('#btnApagarCamara').addClass('d-none');
        $('#pantallaEsperaCamara').removeClass('d-none');
        html5QrCode.clear();
        }).catch(err => { });
        }
        }

        function onScanSuccess(decodedText, decodedResult) {
        const now = new Date().getTime();
        if (now - lastScanTime < 3000) return;
        lastScanTime = now;
        $('#inputTokenManual').val(decodedText);
        simularEscaneo();
        }
        function onScanFailure(error) { }

        // Renderizado y obtención de datos
        async function cargarDatosBase() {
        try {
        const res = await fetch('@Url.Action("ObtenerDatosBase", "ProcesosCG")');
        const data = await res.json();
        if (data.ok) {
        catalogoCategorias = data.categorias;
        let options = '<option value="">Seleccione un usuario...</option>';
        data.usuarios.forEach(u => options += `<option value="${u.id}">${u.nombre} - ${u.departamento} (${u.tokenGafete})</option>`);
        $('#selectUsuario').html(options);
        }
        } catch (error) { }
        }

        async function renderTablaPermisos() {
        try {
        const res = await fetch('@Url.Action("ObtenerTablaPermisos", "ProcesosCG")');
        const data = await res.json();
        if (data.ok) {
        usuariosTablaGlobal = data.datos;
        let html = '';
        data.datos.forEach(row => {
        html += `<tr>
        <td><div class="fw-bold text-dark">${row.nombre}</div><div class="text-muted small">${row.departamento}</div></td>
        <td><button class="btn btn-sm btn-outline-dark fw-bold border-0 bg-transparent text-primary" onclick="imprimirGafete('${row.tokenGafete}', '${row.nombre}')"><i class="bi bi-qr-code me-1"></i> ${row.tokenGafete}</button></td>
        <td><span class="badge ${row.categorias.length ? 'bg-success' : 'bg-secondary'}">${row.categorias.length ? 'Activo' : 'Inactivo'}</span></td>
        <td class="text-center"><button class="btn-sm-action fw-bold ${row.categorias.length ? 'text-brand border-brand' : 'text-muted'}" onclick="verPermisosUsuario(${row.usuarioId})"><i class="bi bi-eye me-1"></i> Ver Permisos (${row.categorias.length})</button></td>
        </tr>`;
        });
        $('#tbodyPermisos').html(html || '<tr><td colspan="4" class="text-center">No hay datos registrados.</td></tr>');
        }
        } catch (e) { }
        }

        async function renderTablaBitacora() {
        try {
        $('#tbodyBitacora').html('<tr><td colspan="5" class="text-center text-muted"><div class="spinner-border spinner-border-sm me-2"></div>Cargando registros...</td></tr>');

        const res = await fetch('@Url.Action("ObtenerBitacoraExcepciones", "ProcesosCG")');
        const data = await res.json();

        if (data.ok) {
        let html = '';
        if (data.logs.length === 0) {
        html = '<tr><td colspan="5" class="text-center text-muted">No hay registros de excepciones en la bitácora.</td></tr>';
        } else {
        data.logs.forEach(row => {
        let claseBdg = row.criticidad == 'CRITICO' ? 'crit-critico' : (row.criticidad == 'SEMICRITICO' ? 'crit-semi' : 'crit-no');
        html += `<tr>
        <td class="text-nowrap"><span class="badge bg-light text-dark border"><i class="bi bi-calendar-event me-1"></i>${row.fecha}</span></td>
        <td><div class="fw-bold text-dark">${row.colaborador}</div><div class="text-muted small">${row.departamento}</div></td>
        <td><span class="fw-bold text-dark">${row.articulo}</span></td>
        <td><span class="badge-crit ${claseBdg}">${row.categoria}</span></td>
        <td><span class="text-muted small fw-bold"><i class="bi bi-person-badge me-1"></i>${row.supervisor}</span></td>
        </tr>`;
        });
        }
        $('#tbodyBitacora').html(html);
        } else {
        $('#tbodyBitacora').html(`<tr><td colspan="5" class="text-center text-danger">Error: ${data.mensaje}</td></tr>`);
        }
        } catch (e) {
        $('#tbodyBitacora').html('<tr><td colspan="5" class="text-center text-danger">Error de red al cargar la bitácora.</td></tr>');
        }
        }

        function verPermisosUsuario(id) {
        let user = usuariosTablaGlobal.find(u => u.usuarioId === id);
        if (!user) return;
        $('#vp-nombre').text(user.nombre);
        $('#vp-depto').text(user.departamento + " | " + user.tokenGafete);

        if (!user.categorias || user.categorias.length === 0) {
        $('#vp-badges').html('<div class="alert alert-warning text-center mt-3"><i class="bi bi-exclamation-triangle me-2"></i>Este colaborador no tiene permisos asignados.</div>');
        } else {
        let htmlBadges = '';
        ['CRITICO', 'SEMICRITICO', 'NO_CRITICO'].forEach(crit => {
        let catsCrit = user.categorias.filter(c => c.criticidad === crit);
        if (catsCrit.length > 0) {
        let claseHdr = crit == 'CRITICO' ? 'text-danger' : (crit == 'SEMICRITICO' ? 'text-warning' : 'text-secondary');
        let claseBdg = crit == 'CRITICO' ? 'crit-critico' : (crit == 'SEMICRITICO' ? 'crit-semi' : 'crit-no');
        htmlBadges += `<div class="text-start mb-3 border border-1 rounded p-3 bg-light"><h6 class="fw-bold border-bottom pb-2 mb-3 ${claseHdr}"><i class="bi bi-tag-fill me-2"></i>NIVEL: ${crit.replace('_', ' ')}</h6><div class="d-flex flex-wrap gap-2">${catsCrit.map(c => `<span class="badge-crit ${claseBdg} px-3 py-2 shadow-sm border-0 bg-white" style="font-size:0.80rem;">${c.nombre}</span>`).join('')}</div></div>`;
        }
        });
        $('#vp-badges').html(htmlBadges);
        }
        new bootstrap.Modal(document.getElementById('modalVerPermisos')).show();
        }

        // Usuarios y Asignaciones
        function abrirModalNuevoUsuario() {
        $('#inNuevoNombre').val('');
        $('#inNuevoToken').val('');
        new bootstrap.Modal(document.getElementById('modalNuevoUsuario')).show();
        }

        async function guardarNuevoUsuario() {
        const nombre = $('#inNuevoNombre').val().trim();
        const token = $('#inNuevoToken').val().trim();
        const depto = $('#inNuevoDepto').val();

        if (!nombre || !token) { alert("Campos obligatorios incompletos."); return; }

        try {
        const res = await fetch('@Url.Action("GuardarUsuario", "ProcesosCG")', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ Nombre: nombre, Departamento: depto, TokenGafete: token })
        });
        const data = await res.json();
        if (data.ok) {
        bootstrap.Modal.getInstance(document.getElementById('modalNuevoUsuario'))?.hide();
        await cargarDatosBase();
        await renderTablaPermisos();
        } else { alert(data.mensaje); }
        } catch (e) { }
        }

        function imprimirGafete(token, nombre) {
        const qrUrl = `/ProcesosCG/GenerarQrGafete?token=${encodeURIComponent(token)}`;
        // Ajustar tamaño ventana popup para móviles
        const width = window.innerWidth > 400 ? 400 : window.innerWidth - 20;
        const w = window.open('', '_blank', `width=${width},height=550`);
        let template = document.getElementById('plantillaGafete').innerHTML;
        template = template.replace(/{{NOMBRE}}/g, nombre).replace('{{QR_URL}}', qrUrl).replace('{{TOKEN}}', token);
        w.document.write(template); w.document.close();
        }

        function abrirModalAsignar() {
        $('#selectUsuario').val('').trigger('change');
        $('#panelEquiposCheckbox').addClass('d-none');
        modalAsignar.show();
        }

        async function cargarCategoriasDeUsuario() {
        let userId = $('#selectUsuario').val();
        if (!userId) { $('#panelEquiposCheckbox').addClass('d-none'); return; }
        $('#panelEquiposCheckbox').removeClass('d-none');
        $('#btnGuardarPermisos').prop('disabled', false);

        try {
        const resP = await fetch(`@Url.Action("ObtenerPermisosUsuario", "ProcesosCG")?usuarioId=${userId}`);
        const dataP = await resP.json();
        const actuales = dataP.ok ? dataP.permisos : [];

        let html = '<div class="accordion accordion-flush" id="accordionCategorias">';
        ['CRITICO', 'SEMICRITICO', 'NO_CRITICO'].forEach((crit) => {
        let items = catalogoCategorias.filter(c => c.criticidad == crit);
        if (items.length) {
        let idCollapse = `collapse_${crit}`;
        let colorHdr = crit == 'CRITICO' ? 'text-danger' : (crit == 'SEMICRITICO' ? 'text-warning' : 'text-secondary');
        html += `<div class="accordion-item border-bottom"><h2 class="accordion-header"><button class="accordion-button collapsed fw-bold py-3 ${colorHdr}" type="button" data-bs-toggle="collapse" data-bs-target="#${idCollapse}">NIVEL: ${crit.replace('_', ' ')} &nbsp;<span class="badge bg-secondary ms-2 rounded-pill">${items.length}</span></button></h2><div id="${idCollapse}" class="accordion-collapse collapse" data-bs-parent="#accordionCategorias"><div class="accordion-body p-0"><div class="grupo-acciones d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2"><span class="text-muted fw-bold">Selección Rápida:</span><div><a href="javascript:void(0)" class="text-decoration-none fw-bold me-3 btn btn-sm btn-outline-secondary py-0" onclick="marcarGrupo('${crit}', true)">Todas</a><a href="javascript:void(0)" class="text-decoration-none fw-bold text-danger btn btn-sm btn-outline-danger py-0" onclick="marcarGrupo('${crit}', false)">Ninguna</a></div></div>`;
        items.forEach(c => {
        let isChecked = actuales.includes(c.id) ? 'checked' : '';
        html += `<div class="eq-checkbox-row chk-item-fila crit-group-${crit}"><span class="ps-3 fw-bold eq-nombre text-dark">${c.nombre}</span><div class="form-check form-switch pe-3"><input class="form-check-input chk-categoria" type="checkbox" value="${c.id}" ${isChecked} onchange="actualizarContador()"></div></div>`;
        });
        html += `</div></div></div>`;
        }
        });
        html += '</div>';
        $('#contenedorCheckboxes').html(html);
        actualizarContador();
        } catch (e) { }
        }

        function marcarGrupo(crit, check) { $(`.crit-group-${crit} .chk-categoria`).prop('checked', check); actualizarContador(); }
        function actualizarContador() { $('#contadorSeleccionados').text($('.chk-categoria:checked').length); }
        function desmarcarTodos() { $('.chk-categoria').prop('checked', false); actualizarContador(); }
        function filtrarCheckboxes() {
        let txt = $('#buscarCheckbox').val().toLowerCase();
        if (txt.length > 0) { $('.accordion-collapse').addClass('show'); }
        $('.chk-item-fila').each(function () { $(this).toggle($(this).find('.eq-nombre').text().toLowerCase().includes(txt)); });
        }

        async function guardarPermisos() {
        let userId = $('#selectUsuario').val();
        let ids = [];
        $('.chk-categoria:checked').each(function () { ids.push(parseInt($(this).val())); });
        try {
        const res = await fetch('@Url.Action("GuardarPermisos", "ProcesosCG")', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ UsuarioId: parseInt(userId), CategoriasIds: ids })
        });
        const data = await res.json();
        if (data.ok) { modalAsignar.hide(); renderTablaPermisos(); }
        else { alert(data.mensaje); }
        } catch (e) { }
        }

        async function simularEscaneo() {
        let token = $('#inputTokenManual').val().trim();
        if (!token) return;
        try {
        const res = await fetch(`@Url.Action("ValidarEscaneo", "ProcesosCG")?token=${token}`);
        const data = await res.json();
        mostrarResultadoPantalla(data);
        $('#inputTokenManual').val('');
        } catch (e) { alert("Error al conectar con la base de datos."); }
        }

        function mostrarResultadoPantalla(data) {
        let panel = $('#panelResultado');
        $('#resultadoDefault').addClass('d-none');
        $('#resultadoDatos').removeClass('d-none');
        panel.removeClass('acceso-concedido acceso-denegado');

        $('#btnAutorizarExcepcion').removeClass('d-none');
        let uId = data.usuario ? data.usuario.id : 0;
        $('#btnAutorizarExcepcion').attr('onclick', `abrirModalAutorizacion(${uId})`);

        if (data.concedido) {
        panel.addClass('acceso-concedido');
        $('#lblMensajeAcceso').text('IDENTIDAD VERIFICADA').attr('class', 'text-success fw-bold mb-4');
        $('#lblUsuario').text(data.usuario.nombre);
        $('#lblDepartamento').text(data.usuario.departamento);
        $('#lblDetalleCheck').text('Verifique físicamente los equipos. Use el botón inferior para autorizar ingreso no listado.');

        $('#lblCategorias').html(data.categorias.map(c => {
        let clase = c.criticidad == 'CRITICO' ? 'crit-critico' : (c.criticidad == 'SEMICRITICO' ? 'crit-semi' : 'crit-no');
        return `<span class="badge-crit ${clase}">${c.nombre}</span>`;
        }).join(''));
        } else {
        panel.addClass('acceso-denegado');
        $('#lblMensajeAcceso').text('ACCESO NO AUTORIZADO').attr('class', 'text-danger fw-bold mb-4');
        $('#lblUsuario').text(data.usuario ? data.usuario.nombre : 'Gafete Inválido');
        $('#lblDepartamento').text(data.mensaje);
        $('#lblCategorias').html('');
        $('#lblDetalleCheck').text('Si el usuario requiere ingresar, se necesita autorización de supervisor.');
        }

        clearTimeout(timerPantalla);
        timerPantalla = setTimeout(() => {
        $('#resultadoDatos').addClass('d-none');
        $('#resultadoDefault').removeClass('d-none');
        panel.removeClass('acceso-concedido acceso-denegado');
        $('#btnAutorizarExcepcion').addClass('d-none');
        }, 30000);
        }
        let permisosModulo = { puedeLeer: false, puedeEscribir: false, puedeEliminar: false };

        document.addEventListener("DOMContentLoaded", async () => {
            await cargarPermisosDeSeguridad();

            
        });

        async function cargarPermisosDeSeguridad() {
              try {
                  // Usamos Url.Action para asegurar que la ruta siempre sea correcta en el servidor
                  let response = await fetch('@Url.Action("ObtenerPermisosVistaAutoArticulos", "ProcesosCG")');

                  if (response.ok) {
                      permisosModulo = await response.json();
                      aplicarPermisosVisuales();
                  }
              } catch (error) {
                  console.error("Error al verificar seguridad:", error);
              }
          }

          function aplicarPermisosVisuales() {
              // Si NO PUEDE ESCRIBIR, ocultamos todos los botones que modifiquen datos
              if (!permisosModulo.puedeEscribir) {

                  // Oculta botones principales
                  let btnCambiarPin = document.getElementById("btnCambiarPin");
                  if(btnCambiarPin) btnCambiarPin.style.display = "none";

                  let btnNuevoColaborador = document.getElementById("btnNuevoColaborador");
                  if(btnNuevoColaborador) btnNuevoColaborador.style.display = "none";

                  let btnAsignarPermisos = document.getElementById("btnAsignarPermisos");
                  if(btnAsignarPermisos) btnAsignarPermisos.style.display = "none";

                  // Oculta botones dentro de los modales y el escáner
                  let btnGuardarUsuario = document.getElementById("btnGuardarUsuario");
                  if(btnGuardarUsuario) btnGuardarUsuario.style.display = "none";

                  let btnGuardarPermisos = document.getElementById("btnGuardarPermisos");
                  if(btnGuardarPermisos) btnGuardarPermisos.style.display = "none";

                 
              }

              if (!permisosModulo.puedeEliminar) {
                  let botonesEliminar = document.querySelectorAll(".btn-eliminar-registro");
                  botonesEliminar.forEach(btn => btn.style.display = "none");
              }
          }
    </script>
}