<div class="container-fluid py-4 px-3 px-md-4">

    <div class="top-banner d-flex justify-content-between align-items-center flex-wrap gap-3 shadow-sm">
        <div>
            <h2 class="fw-bold mb-1">Autorización Entrada de Artículos</h2>
            <p class="mb-0" style="font-size: 0.85rem; opacity: 0.85;">Control de acceso a producción por código QR y categorías permitidas.</p>
        </div>
        <div>
            <button id="btnCambiarPin" class="btn btn-sm btn-outline-light fw-bold px-3 border-2" onclick="abrirModalCambiarPin()">
                <i class="bi bi-gear-fill me-1"></i> Cambiar PIN
            </button>
        </div>
    </div>

    <ul class="nav nav-tabs" id="moduloTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="escaner-tab" data-bs-toggle="tab" data-bs-target="#escaner" type="button" role="tab">Punto de Acceso</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="permisos-tab" data-bs-toggle="tab" data-bs-target="#permisos" type="button" role="tab" onclick="renderTablaPermisos()">Gestión de Permisos</button>
