            function badgeInventario(estatus) {
                const e = String(estatus || '').toUpperCase();

                if (e === 'OK') {
                    return `<span class="trz-badge-warning" style="background:#dff3e2;border-color:#6aa84f;color:#2f6b1f;">✅ OK</span>`;
                }

                if (e === 'FALTA SAP') {
                    return `<span class="trz-badge-danger">⛔ FALTA SAP</span>`;
                }

                if (e === 'FALTA LOCAL') {
                    return `<span class="trz-badge-danger">⛔ FALTA MEAT</span>`;
                }

                return `<span class="trz-badge-warning">⚠️ ${escapeHtml(estatus)}</span>`;
            }

            async function cargarInventarioModal() {
                const body = document.getElementById('inventarioBody');

                const sucursal = document.getElementById('invSucursal')?.value || '';
                const articulo = document.getElementById('invArticulo')?.value || '';
                const lote = document.getElementById('invLote')?.value || '';
                const estatus = document.getElementById('invEstatus')?.value || '';

                body.innerHTML = htmlSpinnerTabla(11, 'Cargando conciliación de inventario...');

                try {
                    const url = '@Url.Action("ConciliacionInventarioJson", "ProcesosCg")'
                        + '?sucursal=' + encodeURIComponent(sucursal)
                        + '&articulo=' + encodeURIComponent(articulo)
                        + '&lote=' + encodeURIComponent(lote)
                        + '&estatus=' + encodeURIComponent(estatus);

                    const res = await fetch(url, {
                        credentials: 'same-origin'
                    });

                    const data = await readResponse(res);

                if (!res.ok || !data?.ok) {
            const msg = data?.msg || data?.message || data?.detalle || data?.error || data?.inner || 'Error al consultar inventario.';

            console.error('Error inventario:', {
                status: res.status,
                statusText: res.statusText,
                url: url,
                response: data
            });

            body.innerHTML = `
                <tr>
                    <td colspan="11" class="text-center">
                        <b>Error al consultar inventario.</b><br>
                        HTTP: ${res.status} ${escapeHtml(res.statusText)}<br>
                        ${escapeHtml(msg)}<br>
                        ${data?.error ? 'Error: ' + escapeHtml(data.error) + '<br>' : ''}
                        ${data?.inner ? 'Detalle: ' + escapeHtml(data.inner) : ''}
                    </td>
                </tr>`;

            showLog('danger',
                'Error al consultar inventario.\n' +
                'HTTP: ' + res.status + ' ' + res.statusText + '\n' +
                'URL: ' + url + '\n' +
                'Mensaje: ' + msg
            );

            return;
        }

                    const rows = Array.isArray(data.rows) ? data.rows : [];

                    const total = rows.length;
                    const ok = rows.filter(x => String(x.estatus || '').toUpperCase() === 'OK').length;
                    const dif = rows.filter(x => String(x.estatus || '').toUpperCase() !== 'OK').length;
                    const kgDif = rows.reduce((sum, x) => sum + Math.abs(toNumber(getPropValue(x, 'diferenciaKg', 'DiferenciaKg', 0))), 0);

                    document.getElementById('invTotalRegistros').textContent = total;
                    document.getElementById('invTotalOk').textContent = ok;
                    document.getElementById('invTotalDif').textContent = dif;
                    document.getElementById('invKgDif').textContent = formatKg(kgDif);

                    if (!rows.length) {
                        body.innerHTML = `
                            <tr>
                                <td colspan="11" class="text-center">Sin información.</td>
                            </tr>`;
                        return;
                    }

                    body.innerHTML = rows.map(x => `
                        <tr class="${esProduccionHoy(x) ? 'trz-row-produccion-hoy' : ''}">
                            <td>${escapeHtml(x.sucursal)}</td>
                            <td>${escapeHtml(x.productoCodigo)}</td>
                            <td title="${escapeHtml(x.descripcionSap)}">${escapeHtml(x.descripcionSap || '-')}</td>
                            <td>${escapeHtml(x.lote)}</td>
                            <td>${htmlFechaProduccion(x)}</td>
                            <td class="text-end">${formatKg(x.kgLocal)}</td>
                            <td class="text-end">${formatKg(x.cantidadSap)}</td>
                            <td class="text-end">${formatKg(x.comprometidoSap)}</td>
                            <td class="text-end">${formatKg(x.disponibleSap)}</td>
                            <td class="text-end">${formatKg(x.diferenciaKg)}</td>
                            <td>${badgeInventario(x.estatus)}</td>
                        </tr>
                    `).join('');

                    showLog(dif === 0 ? 'success' : 'warning',
                        dif === 0
                            ? 'Inventario conciliado correctamente.'
                            : `Inventario con diferencias: ${dif} registros.`
                    );

                } catch (e) {
                    body.innerHTML = `
                        <tr>
                            <td colspan="11" class="text-center">Error de red al consultar inventario.</td>
                        </tr>`;

                    showLog('danger', 'Error al consultar inventario: ' + (e?.message || e));
