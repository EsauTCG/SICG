                const okGeneral =
                    Boolean(estadoTraza?.ok) &&
                    !hayErrorDevolucion;

                const alertIcon = document.getElementById('trzAlertIcon');
                const alertTitle = document.getElementById('trzAlertTitle');
                const alertText = document.getElementById('trzAlertText');

                if (devolucionError) {
                    alertIcon.textContent = '⚠️';
                    alertTitle.textContent =
                        estadoTraza?.ok
                            ? 'Trazabilidad correcta; devoluciones no disponibles.'
                            : 'Trazabilidad con diferencias y devoluciones no disponibles.';
                    alertText.textContent =
                        'Se conservaron los lotes cargados. Revisa la conexión o consulta de devoluciones.';
                } else if (okGeneral) {
                    alertIcon.textContent = '✅';
                    alertTitle.textContent = 'Validación correcta.';
                    alertText.textContent =
                        'La trazabilidad está correcta y las devoluciones, si existen, están aplicadas en SAP.';
                } else if (hayErrorDevolucion) {
                    alertIcon.textContent = '⚠️';
                    alertTitle.textContent =
                        'La entrega tiene devoluciones pendientes o diferencias.';
                    alertText.textContent =
                        estadoTraza?.ok
                            ? 'La trazabilidad está correcta. Revisa únicamente las devoluciones Meat vs SAP.'
                            : 'También existen diferencias de trazabilidad. Revisa ambos apartados.';
                } else {
                    alertIcon.textContent = '⚠️';
                    alertTitle.textContent =
                        'La entrega tiene diferencias de trazabilidad.';
                    alertText.textContent =
                        'Las devoluciones están correctas; revisa lotes, kilos y disponibilidad SAP.';
                }

                return {
                    ok: okGeneral,
                    hayError: hayErrorDevolucion,
                    devoluciones,
                    devolucionError
                };
            }

            async function obtenerTrazabilidadRapida(ref) {
                const res = await fetch(
                    '@Url.Action("ValidarTrazabilidadRapida", "ProcesosCg")'
                    + '?referencia=' + encodeURIComponent(ref)
                    + '&source=' + encodeURIComponent(SOURCE),
                    {
                        credentials: 'same-origin'
                    }
                );

                const data = await readResponse(res);

                if (!res.ok) {
                    throw new Error(
                        data?.msg ||
                        data?.error ||
                        'No se pudo consultar la trazabilidad.'
                    );
                }

                return {
                    httpOk: res.ok,
                    data
                };
            }

            async function obtenerDevolucionesEntrega(ref) {
                const res = await fetch(
                    '@Url.Action("ValidarDevolucionesEntrega", "ProcesosCg")'
                    + '?referencia=' + encodeURIComponent(ref)
                    + '&source=' + encodeURIComponent(SOURCE),
                    {
                        credentials: 'same-origin'
                    }
                );

                const data = await readResponse(res);

                if (!res.ok) {
                    throw new Error(
                        data?.msg ||
                        data?.error ||
                        'No se pudieron consultar las devoluciones.'
                    );
                }

                return {
                    httpOk: res.ok,
                    data
                };
            }

            async function validarTrazabilidad(ref, mostrarModal = true) {
                const requestId = ++trazabilidadRequestSeq;

                if (mostrarModal) {
                    prepararModalTrazabilidad(ref);
                }

                showLog(
                    'info',
                    'Cargando trazabilidad: ' + ref +
                    '. Las devoluciones se consultarán en segundo plano…'
                );

                // Ambas consultas comienzan de inmediato, pero la interfaz presenta
                // el resultado de trazabilidad en cuanto está disponible.
                const devolucionesPromise = obtenerDevolucionesEntrega(ref)
                    .catch(error => ({
                        httpOk: false,
                        data: {
                            ok: false,
                            devoluciones: [],
                            devolucionError: error?.message || String(error)
                        }
                    }));

                let estadoTraza;

                try {
                    const trazaResponse = await obtenerTrazabilidadRapida(ref);

                    estadoTraza = {
                        ok: Boolean(trazaResponse.httpOk && trazaResponse.data?.ok),
                        hayError: !Boolean(trazaResponse.httpOk && trazaResponse.data?.ok),
                        detalle: getArrayProp(
                            trazaResponse.data,
                            'detalle',
                            'Detalle'
                        )
                    };

                    if (mostrarModal && requestId === trazabilidadRequestSeq) {
                        estadoTraza = renderizarTrazabilidadRapida(
                            ref,
                            trazaResponse.data
                        );
                    }
                } catch (error) {
                    estadoTraza = {
                        ok: false,
                        hayError: true,
                        detalle: []
                    };

                    if (mostrarModal && requestId === trazabilidadRequestSeq) {
                        estadoTraza = renderizarErrorTrazabilidad(error);
                    }
                }

                const devResponse = await devolucionesPromise;
                const devData = devResponse.data || {
                    ok: false,
                    devoluciones: [],
                    devolucionError: 'No se recibió respuesta de devoluciones.'
                };

                actualizarEstatusDevolucionFila(ref, devData);

                let estadoDev = {
                    ok: Boolean(devResponse.httpOk && devData?.ok),
                    hayError: !Boolean(devResponse.httpOk && devData?.ok),
                    devoluciones: getArrayProp(
                        devData,
                        'devoluciones',
                        'Devoluciones'
                    ),
                    devolucionError: getPropValue(
                        devData,
                        'devolucionError',
                        'DevolucionError',
                        ''
                    )
                };

                if (mostrarModal && requestId === trazabilidadRequestSeq) {
                    estadoDev = renderizarDevolucionesTrazabilidad(
                        devData,
                        estadoTraza
                    );
                }

                const esOk = Boolean(estadoTraza?.ok && estadoDev?.ok);

                if (esOk) {
                    showLog(
                        'success',
                        'Trazabilidad y devoluciones correctas: ' + ref
                    );
                    return true;
                }

                showLog(
                    'warning',
                    'La entrega requiere revisión de trazabilidad o devoluciones: ' + ref
                );

                return false;
            }

            async function sendOne(ref) {
                if (isSending) {
                    showLog('warning', 'Hay un envío en proceso. Espera a que termine.');
                    return;
                }

                isSending = true;
                setSendButtonsDisabled(true);

                try {
                    const validacionOk = await validarPrevioEnvioSap(ref);

                    if (!validacionOk) {
                        setRowStatus(ref, false, 'Pendiente de trazabilidad/devolución SAP');
                        return;
                    }

                    showLog('info', 'Enviando entrega a SAP: ' + ref + ' ...');

                    const { res, data } = await postEnviarEntregaSap(ref);

                    if (res.ok && data?.ok) {
                        const m = buildMsg(data, 'Enviado con éxito.');
                        setRowStatus(ref, true, m);
                        showLog('success', m);
                    } else {
                        const err = buildMsg(data, 'No se pudo enviar.');
                        setRowStatus(ref, false, err);
                        showLog('danger', err + (data?.detalle ? String.fromCharCode(10) + data.detalle : ''));
                    }
                } catch (e) {
                    setRowStatus(ref, false, 'Error de red');
                    showLog('danger', 'Error de red al enviar a SAP: ' + (e?.message || e));
                } finally {
                    isSending = false;
                    setSendButtonsDisabled(false);
                }
            }

                async function sendMany() {
                    if (isSending) {
                        showLog('warning', 'Hay un envío en proceso.');
                        return;
                    }

                    const refs = Array.from(document.querySelectorAll('.ck:checked'))
                        .map(x => x.value)
                        .filter(Boolean);

                    if (!refs.length) {
                        showLog('warning', 'Selecciona al menos una entrega.');
                        return;
                    }

                    isSending = true;
                    setSendButtonsDisabled(true);

                    let okCount = 0;
                    let failCount = 0;
                    let omitidosValidacion = 0;

                    try {
                        showLog('info', `Enviando ${refs.length} entregas a SAP...`);

                        for (let i = 0; i < refs.length; i++) {
                            const ref = refs[i];
                            showLog('info', `(${i + 1}/${refs.length}) Validando / enviando: ${ref}...`);

                            const validacionOk = await validarPrevioEnvioSap(ref);

                            if (!validacionOk) {
                                failCount++;
                                omitidosValidacion++;
                                setRowStatus(ref, false, 'Pendiente de trazabilidad/devolución SAP');
                                continue;
                            }

                            const { res, data } = await postEnviarEntregaSap(ref);

                            if (res.ok && data?.ok) {
                                okCount++;
                                setRowStatus(ref, true, buildMsg(data, 'Enviado.'));
                            } else {
                                failCount++;
                                setRowStatus(ref, false, buildMsg(data, `Falló: ${ref}`));
                            }
                        }

                        let resumen = `Terminado. OK: ${okCount} | Fallidos: ${failCount}`;
                        if (omitidosValidacion > 0) {
                            resumen += ` | Bloqueados por validación: ${omitidosValidacion}`;
                        }

                        showLog(failCount === 0 ? 'success' : 'warning', resumen);
                    } catch (e) {
                        showLog('danger', 'Error de red al enviar masivo a SAP: ' + (e?.message || e));
                    } finally {
                        isSending = false;
                        setSendButtonsDisabled(false);
                    }
                }

                let autoEnabled = false, autoTimer = null, autoRefreshTimer = null;

                function isAutoCandidateStatus(sym) { return sym === '—' || sym === '❌' || sym === ''; }

                function getAutoRefsToSend() {
                    return Array.from(document.querySelectorAll('tr[data-ref]'))
                        .filter(row => isAutoCandidateStatus(getStatusSymbolFromRow(row)))
                        .map(row => row.getAttribute('data-ref'))
                        .filter(Boolean);
                }

                async function sendManyRefs(refs) {
                    if (isSending || !refs?.length) return;

                    isSending = true;
                    setSendButtonsDisabled(true);

                    try {
                        showLog('info', `Auto: enviando ${refs.length} entrega(s) a SAP...`);

                        for (let i = 0; i < refs.length; i++) {
                            const ref = refs[i];
                            const row = document.querySelector(`tr[data-ref="${CSS.escape(ref)}"]`);

                            if (!isAutoCandidateStatus(getStatusSymbolFromRow(row))) continue;

                            const validacionOk = await validarPrevioEnvioSap(ref);

                            if (!validacionOk) {
                                setRowStatus(ref, false, 'Pendiente de trazabilidad/devolución SAP');
                                continue;
                            }

                            const { res, data } = await postEnviarEntregaSap(ref);

                            if (res.ok && data?.ok) {
                                setRowStatus(ref, true, buildMsg(data, 'Enviado.'));
                            } else {
                                setRowStatus(ref, false, buildMsg(data, `Falló: ${ref}`));
                            }
                        }
                    } catch (e) {
                        showLog('danger', 'Error de red en envío automático SAP: ' + (e?.message || e));
                    } finally {
                        isSending = false;
                        setSendButtonsDisabled(false);
                    }
                }

                function updateAutoButton() {
                    const b   = document.getElementById('btnAuto');
                    const ico = document.getElementById('autoIco');
                    if (!b || !ico) return;
                    if (autoEnabled) {
                        b.classList.add('auto-on');
                        ico.textContent = '▶';
                        b.title = 'Auto: ON — clic para desactivar';
                    } else {
                        b.classList.remove('auto-on');
                        ico.textContent = '⏸';
                        b.title = 'Auto: OFF — clic para activar';
                    }
                }

                async function serverAutoSet(enabled) {
                    const intervalMs = parseInt(document.getElementById('autoInterval')?.value || '5000', 10);
                    const res = await fetch('/ProcesosCG/AutoSapSet', {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: 'enabled='+encodeURIComponent(enabled)+'&source=ALL&intervalMs='+encodeURIComponent(intervalMs)
                    });
                    const data = await readResponse(res);
                    if (!res.ok || !data?.ok) throw new Error(data?.msg || 'Error auto servidor');
                    return data;
                }

                async function serverAutoStatus() {
                    const res = await fetch('/ProcesosCG/AutoSapStatus?source=ALL', { credentials: 'same-origin' });
                    const data = await readResponse(res);
                    if (!res.ok || !data?.ok) throw new Error(data?.msg || 'Error estado auto');
                    return data;
                }

                async function refreshSapTableSilentSafe() {
                    const container = document.querySelector('.table-wrap');
                    const tbody = document.querySelector('tbody');
                    if (!container || !tbody) return;
                    const checked = new Set(Array.from(document.querySelectorAll('.ck:checked')).map(x => x.value));
                    const scrollTop = container.scrollTop;
                    const res = await fetch(window.location.href, { credentials: 'same-origin' });
                    const html = await res.text();
                    const tmp = document.createElement('div');
                    tmp.innerHTML = html;
                    const newTbody = tmp.querySelector('tbody');
                    if (!newTbody) return;
                    tbody.replaceWith(newTbody);
                    document.querySelectorAll('.ck').forEach(x => { if (checked.has(x.value)) x.checked = true; });
                    container.scrollTop = scrollTop;
                    updateReserveButtons();
                }

                function startAutoRefresh() {
                    if (autoRefreshTimer) clearInterval(autoRefreshTimer);
                    autoRefreshTimer = setInterval(async () => {
                        if (!autoEnabled) return;
                        await refreshSapTableSilentSafe();
                    }, 30000);
                }

                function stopAutoRefresh() {
                    if (autoRefreshTimer) clearInterval(autoRefreshTimer);
                    autoRefreshTimer = null;
                }

                function stopAuto() {
                    autoEnabled = false;
                    if (autoTimer) clearInterval(autoTimer);
                    autoTimer = null;
                    stopAutoRefresh();
                    updateAutoButton();
                    showLog('secondary', 'Envío automático desactivado.');
                    serverAutoSet(false).catch(e => console.warn(e));
                }

                async function startAuto() {
                    autoEnabled = true;
                    updateAutoButton();
                    showLog('info', 'Activando envío automático...');
                    try {
                        const r = await serverAutoSet(true);
                        if (r?.msg) showLog('info', r.msg);
                    } catch(e) {
                        showLog('danger', 'No pude activar auto en servidor: '+(e?.message||e));
                        autoEnabled = false; updateAutoButton(); return;
                    }
                    const intervalMs = parseInt(document.getElementById('autoInterval')?.value || '5000', 10);
                    const first = getAutoRefsToSend();
                    if (first.length) await sendManyRefs(first);
                    if (autoTimer) clearInterval(autoTimer);
                    autoTimer = setInterval(async () => {
                        if (!autoEnabled || isSending) return;
                        const refs = getAutoRefsToSend();
                        if (refs.length) await sendManyRefs(refs);
                    }, intervalMs);
                    startAutoRefresh();
                }

                document.getElementById('btnAuto')?.addEventListener('click', () => {
                    if (autoEnabled) stopAuto(); else startAuto();
                });

                document.getElementById('autoInterval')?.addEventListener('change', () => {
                    if (autoEnabled) startAuto();
                });

                (async function initAutoState() {
                    try {
                        const s = await serverAutoStatus();
                        const anyOn = (s?.all || []).some(x => x.enabled === true || x.Enabled === true);
                        if (anyOn) {
                            autoEnabled = true; updateAutoButton();
                            showLog('info', 'Auto server ya estaba ACTIVADO');
