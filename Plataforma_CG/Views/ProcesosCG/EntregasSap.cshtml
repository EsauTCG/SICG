    /* =========================================================
           KPIS EJECUTIVOS ENTREGAS SAP
           ========================================================= */

    .sap-kpi-section {
        background: linear-gradient(180deg, #fffafa, #f2dddd);
    }

    .sap-kpi-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

        .sap-kpi-title span {
            font-size: 11px;
            font-weight: 700;
            color: #ffe4e4;
            opacity: .95;
        }

    .sap-kpi-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(120px, 1fr));
        gap: 10px;
        padding: 10px;
        background: linear-gradient(180deg, #fffafa 0%, #f4e4e4 100%);
    }

    .sap-kpi {
        position: relative;
        min-height: 96px;
        overflow: hidden;
        border-radius: 12px;
        padding: 12px 13px;
        border: 1px solid rgba(255,255,255,.25);
        color: #fff;
        box-shadow: 0 12px 22px rgba(72, 12, 12, .16);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        isolation: isolate;
    }

        .sap-kpi::before {
            content: "";
            position: absolute;
            right: -34px;
            bottom: -46px;
            width: 118px;
            height: 118px;
            border-radius: 999px;
            background: rgba(255,255,255,.16);
            z-index: -1;
        }

        .sap-kpi::after {
            content: "";
            position: absolute;
            right: -10px;
            bottom: -30px;
            width: 78px;
            height: 78px;
            border-radius: 999px;
            background: rgba(0,0,0,.08);
            z-index: -1;
        }

        .sap-kpi label {
            margin: 0;
            color: rgba(255,255,255,.92);
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .04em;
            line-height: 1.2;
        }

        .sap-kpi strong {
            display: block;
            margin-top: 10px;
            color: #fff;
            font-size: clamp(24px, 2.4vw, 36px);
            font-weight: 900;
            line-height: 1;
            text-shadow: 0 2px 10px rgba(0,0,0,.25);
            word-break: break-word;
        }

        .sap-kpi small {
            display: block;
            margin-top: 8px;
            color: rgba(255,255,255,.90);
            font-size: 11px;
            font-weight: 700;
            line-height: 1.2;
        }

    .sap-kpi-total {
        background: linear-gradient(135deg, #8b0000 0%, #b30000 56%, #5c0000 100%);
    }

    .sap-kpi-ok {
        background: linear-gradient(135deg, #157347 0%, #22a461 55%, #0d5d37 100%);
    }

    .sap-kpi-pending {
        background: linear-gradient(135deg, #b7791f 0%, #f0b429 55%, #805400 100%);
    }

    .sap-kpi-error {
        background: linear-gradient(135deg, #b91c1c 0%, #e03333 55%, #7f1111 100%);
    }

    .sap-kpi-selected {
        background: linear-gradient(135deg, #0d5aa7 0%, #2787d9 55%, #083d75 100%);
    }

    .sap-kpi-dev {
        background: linear-gradient(135deg, #4c1d95 0%, #7c3aed 55%, #2e1065 100%);
    }

        .sap-kpi-dev.ok {
            background: linear-gradient(135deg, #157347 0%, #22a461 55%, #0d5d37 100%);
        }

        .sap-kpi-dev.warn {
            background: linear-gradient(135deg, #b7791f 0%, #f0b429 55%, #805400 100%);
        }

        .sap-kpi-dev.bad {
            background: linear-gradient(135deg, #b91c1c 0%, #e03333 55%, #7f1111 100%);
        }

    @@media(max-width: 1300px) {
        .sap-kpi-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media(max-width: 768px) {
        .sap-kpi-title {
            align-items: flex-start;
            flex-direction: column;
        }

        .sap-kpi-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .sap-kpi {
            min-height: 88px;
        }

            .sap-kpi strong {
                font-size: 26px;
            }
    }

    @@media(max-width: 480px) {
        .sap-kpi-grid {
            grid-template-columns: 1fr;
        }
    }

