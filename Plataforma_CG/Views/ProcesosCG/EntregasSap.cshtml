            function renderizarTrazabilidadRapida(ref, data) {
                const detalle = getArrayProp(data, 'detalle', 'Detalle');

                const totalKgSolicitados = detalle.reduce(
                    (sum, x) => sum + toNumber(
                        getPropValue(x, 'kgSolicitadosJson', 'KgSolicitadosJson', 0)
                    ),
                    0
                );

                const totalKgFaltantes = detalle.reduce(
                    (sum, x) => sum + toNumber(
                        getPropValue(x, 'kgFaltantes', 'KgFaltantes', 0)
                    ),
                    0
                );

                const hayErrorTrazabilidad = detalle.some(x => {
                    const e = String(
                        getPropValue(x, 'estatus', 'Estatus', '')
                    ).toUpperCase();

                    return e.includes('NO EXISTE') ||
                           e.includes('SIN DISPONIBLE') ||
                           e.includes('FALTAN KG') ||
                           e.includes('JSON SIN LOTES') ||
                           e.includes('JSON VACÍO');
                });

                document.getElementById('trzRef').textContent = ref || '-';
                document.getElementById('trzTotalPartidas').textContent = detalle.length;
                document.getElementById('trzKgSolicitados').textContent =
                    formatKg(totalKgSolicitados);
                document.getElementById('trzKgFaltantes').textContent =
                    formatKg(totalKgFaltantes);

                const body = document.getElementById('trzDetalleBody');

                if (!detalle.length) {
                    body.innerHTML = `
                        <tr>
                            <td colspan="8" class="text-center">
                                No se recibió detalle de trazabilidad.
                            </td>
                        </tr>`;
                } else {
                    body.innerHTML = detalle.map(x => {
                        const estatus = getPropValue(
                            x,
                            'estatus',
                            'Estatus',
                            ''
                        );

                        const b = badgeInfo(estatus);
                        const hoy = esProduccionHoy(x);

                        return `
                            <tr class="${hoy ? 'trz-row-produccion-hoy' : ''}">
                                <td>${escapeHtml(getPropValue(x, 'articulo', 'Articulo', ''))}</td>
                                <td>${escapeHtml(getPropValue(x, 'almacen', 'Almacen', ''))}</td>
                                <td>${escapeHtml(getPropValue(x, 'lote', 'Lote', ''))}</td>
                                <td>${htmlFechaProduccion(x)}</td>
                                <td class="text-end">${formatKg(getPropValue(x, 'kgSolicitadosJson', 'KgSolicitadosJson', 0))}</td>
                                <td class="text-end">${formatKg(getPropValue(x, 'disponibleSap', 'DisponibleSap', 0))}</td>
                                <td class="text-end">${formatKg(getPropValue(x, 'kgFaltantes', 'KgFaltantes', 0))}</td>
                                <td>
                                    <span class="${b.cls}">
                                        ${b.icon}
                                        ${escapeHtml(estatus)}
                                    </span>
                                </td>
                            </tr>`;
                    }).join('');
                }

                const alertIcon = document.getElementById('trzAlertIcon');
                const alertTitle = document.getElementById('trzAlertTitle');
                const alertText = document.getElementById('trzAlertText');

                if (hayErrorTrazabilidad) {
                    alertIcon.textContent = '⚠️';
                    alertTitle.textContent =
                        'Se encontraron diferencias de trazabilidad.';
                    alertText.textContent =
                        'Los lotes ya están visibles. Las devoluciones continúan cargándose en segundo plano.';
                } else {
                    alertIcon.textContent = '✅';
                    alertTitle.textContent =
                        'Trazabilidad cargada correctamente.';
                    alertText.textContent =
                        'Los lotes están disponibles. Consultando devoluciones Meat vs SAP…';
                }

                return {
                    ok: !hayErrorTrazabilidad,
                    hayError: hayErrorTrazabilidad,
                    detalle
