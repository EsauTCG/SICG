            function renderizarDevolucionesTrazabilidad(data, estadoTraza) {
                const devoluciones = getArrayProp(
                    data,
                    'devoluciones',
                    'Devoluciones'
                );

                const devolucionError = getPropValue(
                    data,
                    'devolucionError',
                    'DevolucionError',
                    ''
                );

                const totalKgMeat = devoluciones.reduce(
                    (sum, x) => sum + toNumber(
                        getPropValue(x, 'kgDevueltosMeat', 'KgDevueltosMeat', 0)
