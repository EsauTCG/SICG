<div class="modal fade" id="reserveKgModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Factura de Reserva Manual</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p style="font-size:12px; color:#6a3a3a; margin-bottom:8px;">Captura los KG por ItemCode.</p>
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>ItemCode</th>
                                <th class="text-end">KG</th>
                            </tr>
                        </thead>
                        <tbody id="reserveLinesBody"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button class="pm-btn pm-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button class="pm-btn pm-btn-warning" onclick="sendReserveKg()">Enviar Reserva</button>
            </div>
        </div>
    </div>
</div>

<script>
                const SOURCE = '@source';
                const TODAY_ISO = '@DateTime.Today.ToString("yyyy-MM-dd")';
                const RESERVE_AFTER_MINUTES = 20;
                let trazabilidadRequestSeq = 0;

                // =========================================================
                // AJUSTE TEMPORAL DE ENVÍO SAP
                // =========================================================
                // false = permite enviar la entrega a SAP sin validar primero trazabilidad/devoluciones.
                // true  = obliga a validar trazabilidad/devoluciones antes de enviar.
                // Cuando ya tengas estable la comunicación con SAP/trazabilidad, cámbialo a true.
                const VALIDAR_TRAZABILIDAD_ANTES_DE_ENVIAR = false;

                // Evita doble clic / envíos simultáneos en botones individuales, masivos y auto.
                let isSending = false;

                async function validarPrevioEnvioSap(ref) {
                    if (!ref) {
                        showLog('warning', 'Referencia vacía. No se puede enviar a SAP.');
                        return false;
                    }

                    if (!VALIDAR_TRAZABILIDAD_ANTES_DE_ENVIAR) {
                        showLog('warning', 'Modo prueba: se omitió validación previa de trazabilidad/devoluciones para ' + ref + '.');
                        return true;
                    }

                    try {
                        return await validarTrazabilidad(ref, false);
                    } catch (e) {
                        showLog('danger', 'No se pudo validar trazabilidad/devoluciones para ' + ref + ': ' + (e?.message || e));
                        return false;
                    }
                }

                function setSendButtonsDisabled(disabled) {
                    document.querySelectorAll('.btn-enviar, .js-send-one, #btnAuto')
                        .forEach(btn => {
                            if (!btn) return;
                            btn.disabled = !!disabled;
                            btn.style.opacity = disabled ? '.65' : '';
                            btn.style.pointerEvents = disabled ? 'none' : '';
                        });
                }

                async function postEnviarEntregaSap(ref) {
                    const res = await fetch('@Url.Action("EnviarEntrega", "ProcesosCg")', {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: 'referencia=' + encodeURIComponent(ref) + '&source=' + encodeURIComponent(SOURCE)
                    });

                    const data = await readResponse(res);
                    return { res, data };
                }

                function showLog(type, text) {
                    const box = document.getElementById('logBox');
                    const log = document.getElementById('log');
                    box.style.display = 'block';
                    log.className = 'log-inner log-' + (type || 'secondary');
                    log.textContent = text || '';
                }

                function selectAll(on) {
                    document.querySelectorAll('.ck').forEach(x => x.checked = !!on);
                }

                function buildMsg(data, fallback) {
                    if (!data) return fallback || '';
                    let msg = data.msg || fallback || '';
                    const extras = [];
                    if (data.referencia) extras.push('Ref: ' + data.referencia);
                    if (data.docNum)     extras.push('DocNum: ' + data.docNum);
                    if (data.docEntry)   extras.push('DocEntry: ' + data.docEntry);
                    if (extras.length)   msg += ' (' + extras.join(' | ') + ')';
                    return msg;
                }

              async function readResponse(res) {
            const ct = (res.headers.get('content-type') || '').toLowerCase();
            const t = await res.text();

            if (ct.includes('application/json')) {
                try {
                    return JSON.parse(t);
                } catch (e) {
                    return {
                        ok: false,
                        msg: 'La respuesta dice ser JSON, pero no se pudo leer.',
                        detalle: t
                    };
                }
            }

            try {
                return JSON.parse(t);
            } catch {
                return {
                    ok: false,
                    msg: ct.includes('text/html')
                        ? 'El servidor regresó HTML en lugar de JSON. Posible sesión vencida, error MVC o redirección a login.'
                        : 'El servidor no regresó JSON.',
                    detalle: t.substring(0, 500)
                };
            }
        }

                function getStatusSymbolFromRow(row) {
                    const est = row?.querySelector('.js-est');
                    return (est?.textContent || '').trim();
                }

                function parseRowDateIso(row) {
                    const iso = row?.getAttribute('data-fecha');
                    if (!iso) return null;
                    const d = new Date(iso);
                    return isNaN(d.getTime()) ? null : d;
                }

                function isReserveCandidateStatus(sym) {
                    return sym === '—' || sym === '❌' || sym === '';
                }

                function canEnableReserve(row) {
                    const sym = getStatusSymbolFromRow(row);
                    if (!isReserveCandidateStatus(sym)) return false;
                    const d = parseRowDateIso(row);
                    if (!d) return false;
                    return (Date.now() - d.getTime()) / 60000 >= RESERVE_AFTER_MINUTES;
                }

                function updateReserveButtons() {
                    document.querySelectorAll('tr[data-ref]').forEach(row => {
                        const btn = row.querySelector('.js-reserve');
                        if (!btn) return;
                        const enabled = canEnableReserve(row);
                        if (enabled) {
                btn.style.opacity = '';
                btn.style.pointerEvents = '';
                btn.removeAttribute('aria-disabled');
            } else {
                btn.style.opacity = '.5';
                btn.style.pointerEvents = 'none';
                btn.setAttribute('aria-disabled', 'true');
            }
                        if (enabled) {
                            btn.title = 'Generar y enviar Factura de Reserva';
                        } else {
                            const d = parseRowDateIso(row);
                            if (!d) { btn.title = 'Sin fecha'; return; }
                            const minutes = (Date.now() - d.getTime()) / 60000;
                            const faltan = Math.ceil(RESERVE_AFTER_MINUTES - minutes);
                            const sym = getStatusSymbolFromRow(row);
                            btn.title = !isReserveCandidateStatus(sym)
                                ? 'No disponible: entrega ya enviada'
                                : (faltan > 0 ? `Disponible en ~${faltan} min` : 'No disponible');
                        }
                    });
                }

                function setRowStatus(ref, ok, msg) {
                    const row = document.querySelector(`tr[data-ref="${CSS.escape(ref)}"]`);
                    if (!row) return;

                        row.classList.toggle('sap-error', ok === false);
                    row.querySelectorAll('.js-est').forEach(est => {
                        if (ok === true)       { est.textContent = '✅'; est.title = msg || 'Enviado'; }
                        else if (ok === false) { est.textContent = '❌'; est.title = msg || 'Falló'; }
                        else                   { est.textContent = '—';  est.title = msg || 'Sin intento'; }
                    });
                    updateReserveButtons();
                }

            function escapeHtml(value) {
                return String(value ?? '')
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#039;');
            }

            function toNumber(value) {
                const n = Number(value);
                return isNaN(n) ? 0 : n;
            }

            function formatKg(value) {
                const n = toNumber(value);
                return n.toLocaleString('es-MX', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
            }

            function getFechaProduccion(obj) {
                return getPropValue(obj, 'fechaProduccion', 'FechaProduccion', null)
                    ?? getPropValue(obj, 'fechaProduccionLote', 'FechaProduccionLote', null)
                    ?? getPropValue(obj, 'productionDate', 'ProductionDate', null);
            }

            function formatFecha(value) {
                if (value === undefined || value === null || String(value).trim() === '') {
                    return '-';
                }

                const raw = String(value).trim();

                // ISO: 2026-07-07 o 2026-07-07T10:30:00
                const iso = raw.match(/^(\d{4})-(\d{2})-(\d{2})/);
                if (iso) {
                    return `${iso[3]}/${iso[2]}/${iso[1]}`;
                }

                // Formato antiguo de ASP.NET: /Date(1783396800000)/
                const aspNet = raw.match(/\/Date\(([-+]?\d+)/);
                if (aspNet) {
                    const fechaAsp = new Date(Number(aspNet[1]));
                    if (!Number.isNaN(fechaAsp.getTime())) {
                        return fechaAsp.toLocaleDateString('es-MX');
                    }
                }

                const fecha = new Date(raw);
                return Number.isNaN(fecha.getTime())
                    ? raw
                    : fecha.toLocaleDateString('es-MX');
            }


            function getFechaIsoKey(value) {
                if (value === undefined || value === null || String(value).trim() === '') {
                    return '';
                }

                const raw = String(value).trim();
                const iso = raw.match(/^(\d{4})-(\d{2})-(\d{2})/);

                if (iso) {
                    return `${iso[1]}-${iso[2]}-${iso[3]}`;
                }

                const aspNet = raw.match(/\/Date\(([-+]?\d+)/);

                if (aspNet) {
                    const d = new Date(Number(aspNet[1]));

                    if (!Number.isNaN(d.getTime())) {
                        return [
                            d.getFullYear(),
                            String(d.getMonth() + 1).padStart(2, '0'),
                            String(d.getDate()).padStart(2, '0')
                        ].join('-');
                    }
                }

                const d = new Date(raw);

                if (Number.isNaN(d.getTime())) {
                    return '';
                }

                return [
                    d.getFullYear(),
                    String(d.getMonth() + 1).padStart(2, '0'),
                    String(d.getDate()).padStart(2, '0')
                ].join('-');
            }

            function esProduccionHoy(obj) {
                const flag = getPropValue(
                    obj,
                    'esProduccionHoy',
                    'EsProduccionHoy',
                    null
                );

                if (flag === true || String(flag).toLowerCase() === 'true') {
                    return true;
                }

                return getFechaIsoKey(getFechaProduccion(obj)) === TODAY_ISO;
            }

            function htmlFechaProduccion(obj) {
                const texto = formatFecha(getFechaProduccion(obj));

                if (texto === '-') {
                    return '<span class="trz-fecha-normal">-</span>';
                }

                if (esProduccionHoy(obj)) {
                    return `
                        <span class="trz-fecha-hoy"
                              title="Este lote corresponde a producción de hoy">
                            🔴 ${escapeHtml(texto)}
                            <small>Producción de hoy</small>
                        </span>`;
                }

                return `<span class="trz-fecha-normal">${escapeHtml(texto)}</span>`;
            }


            function getArrayProp(obj, camelName, pascalName) {
                const v = obj?.[camelName];
                if (Array.isArray(v)) return v;

                const p = obj?.[pascalName];
                if (Array.isArray(p)) return p;

                return [];
            }

            function getPropValue(obj, camelName, pascalName, fallback = '') {
                if (obj && obj[camelName] !== undefined && obj[camelName] !== null) return obj[camelName];
                if (obj && obj[pascalName] !== undefined && obj[pascalName] !== null) return obj[pascalName];
                return fallback;
            }

            function getDevResumenFromData(data) {
                const devoluciones = getArrayProp(data, 'devoluciones', 'Devoluciones');
                const devolucionError = getPropValue(data, 'devolucionError', 'DevolucionError', '');

                if (devoluciones.length === 0) {
                    if (devolucionError) {
                        return {
                            cls: 'dev-diff',
                            icon: '⚠️',
                            title: 'Error al consultar devoluciones: ' + devolucionError,
                            texto: 'Error'
                        };
                    }

                    return {
                        cls: 'dev-none',
                        icon: '—',
                        title: 'Sin devolución Meat para comparar',
                        texto: 'Sin devolución'
                    };
                }

                const estatus = devoluciones.map(x =>
                    String(getPropValue(x, 'estatus', 'Estatus', '')).toUpperCase()
                ).join('|');

                const totalKgMeat = devoluciones.reduce((s, x) =>
                    s + toNumber(getPropValue(x, 'kgDevueltosMeat', 'KgDevueltosMeat', 0)), 0);

                const totalKgSap = devoluciones.reduce((s, x) =>
                    s + toNumber(getPropValue(x, 'kgDevueltosSap', 'KgDevueltosSap', 0)), 0);

                const totalDif = devoluciones.reduce((s, x) =>
                    s + toNumber(getPropValue(x, 'diferenciaKg', 'DiferenciaKg', 0)), 0);

                const titleBase = `Meat: ${formatKg(totalKgMeat)} kg | SAP: ${formatKg(totalKgSap)} kg | Dif: ${formatKg(totalDif)} kg`;

                if (estatus.includes('PENDIENTE')) {
                    return {
                        cls: 'dev-pending',
                        icon: '❌',
                        title: 'Devolución pendiente en SAP. ' + titleBase,
                        texto: 'Pendiente'
                    };
                }

                if (estatus.includes('DIFERENCIA') || estatus.includes('FALTA') || estatus.includes('SOBRANTE')) {
                    return {
                        cls: 'dev-diff',
                        icon: '⚠️',
                        title: 'Devolución con diferencia. ' + titleBase,
                        texto: 'Diferencia'
                    };
                }

                if (estatus.includes('APLICADA')) {
                    return {
                        cls: 'dev-ok',
                        icon: '✅',
                        title: 'Devolución aplicada en SAP. ' + titleBase,
                        texto: 'Aplicada'
                    };
                }

                return {
                    cls: 'dev-diff',
                    icon: '⚠️',
                    title: 'Devolución requiere revisión. ' + titleBase,
                    texto: 'Revisar'
                };
            }

            function actualizarEstatusDevolucionFila(ref, data) {
                const row = document.querySelector(`tr[data-ref="${CSS.escape(ref)}"]`);
                if (!row) return;

                const info = getDevResumenFromData(data);

                row.querySelectorAll('.js-dev-est').forEach(el => {
                    el.className = 'dev-est js-dev-est ' + info.cls;
                    el.textContent = info.icon;
                    el.title = info.title;
                    el.setAttribute('data-dev-status', info.texto);
                });
            }

            async function validarDevolucionFila(ref) {
                try {
                    const res = await fetch('@Url.Action("ValidarDevolucionesEntrega", "ProcesosCg")'
                        + '?referencia=' + encodeURIComponent(ref)
                        + '&source=' + encodeURIComponent(SOURCE), {
                        credentials: 'same-origin'
                    });

                    const data = await readResponse(res);
                    actualizarEstatusDevolucionFila(ref, data);
                    return data;
                } catch (e) {
                    const row = document.querySelector(`tr[data-ref="${CSS.escape(ref)}"]`);
                    if (row) {
                        row.querySelectorAll('.js-dev-est').forEach(el => {
                            el.className = 'dev-est js-dev-est dev-diff';
                            el.textContent = '⚠️';
                            el.title = 'Error al validar devolución: ' + (e?.message || e);
                            el.setAttribute('data-dev-status', 'Error');
                        });
                    }
                    return null;
                }
            }

            async function validarDevolucionesVisibles() {
                const refs = Array.from(document.querySelectorAll('tr[data-ref]'))
                    .map(row => row.getAttribute('data-ref'))
                    .filter(Boolean);

                if (!refs.length) {
                    showLog('warning', 'No hay entregas visibles para validar.');
                    return;
                }

                showLog('info', `Validando devoluciones de ${refs.length} entregas visibles...`);

                for (const ref of refs) {
                    const row = document.querySelector(`tr[data-ref="${CSS.escape(ref)}"]`);
                    if (row) {
                        row.querySelectorAll('.js-dev-est').forEach(el => {
                            el.className = 'dev-est js-dev-est dev-unknown';
                            el.textContent = '⏳';
                            el.title = 'Validando devolución...';
                        });
                    }

                    await validarDevolucionFila(ref);
                    await new Promise(resolve => setTimeout(resolve, 80));
                }

                showLog('success', 'Validación de devoluciones visibles terminada.');
            }


            function badgeInfo(estatus) {
                const e = String(estatus || '').toUpperCase();

                if (e.includes('APLICADA') ||
                    e.includes('OK EXACTO') ||
                    e.includes('OK CON SOBRANTE')) {
                    return { cls: 'trz-badge-success', icon: '✅' };
                }

                if (e.includes('PENDIENTE') ||
                    e.includes('DIFERENCIA') ||
                    e.includes('FALTA') ||
                    e.includes('NO EXISTE') ||
                    e.includes('SIN DISPONIBLE') ||
                    e.includes('SOBRANTE SAP')) {
                    return { cls: 'trz-badge-danger', icon: '⛔' };
                }

                return { cls: 'trz-badge-warning', icon: '⚠️' };
            }

            function prepararModalTrazabilidad(ref) {
                document.getElementById('trzRef').textContent = ref || '-';

                document.getElementById('trzTotalPartidas').textContent = '…';
                document.getElementById('trzKgSolicitados').textContent = '…';
                document.getElementById('trzKgFaltantes').textContent = '…';

                document.getElementById('devTotalPartidas').textContent = '…';
                document.getElementById('devKgMeat').textContent = '…';
                document.getElementById('devKgSap').textContent = '…';
                document.getElementById('devKgDif').textContent = '…';
                document.getElementById('devTotalAplicadas').textContent = '…';
                document.getElementById('devTotalPendientes').textContent = '…';

                document.getElementById('trzAlertIcon').textContent = '⏳';
                document.getElementById('trzAlertTitle').textContent =
                    'Abriendo detalle de trazabilidad…';
                document.getElementById('trzAlertText').textContent =
