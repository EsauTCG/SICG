    /* Filas con error SAP - alerta parpadeo tenue */
    @@keyframes sapErrorBlink {
        0%, 100% {
            box-shadow: inset 0 0 0 9999px rgba(255, 235, 235, .65);
        }

        50% {
            box-shadow: inset 0 0 0 9999px rgba(220, 53, 69, .28);
