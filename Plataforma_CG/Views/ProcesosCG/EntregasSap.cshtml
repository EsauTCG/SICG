            // ======================================================
    // AUTO VALIDACIÓN DE DEVOLUCIONES
    // ======================================================
    const DEV_AUTO_KEY = `entregas_dev_auto_${SOURCE}`;
    const DEV_AUTO_INTERVAL_MS = 3 * 60 * 1000; // cada 3 minutos
    const DEV_AUTO_VALIDATE_ALL_VISIBLE = true; // true = valida todas las visibles

    let devAutoTimer = null;
    let devAutoBusy = false;

    function sleepDev(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    function getRowsVisiblesDevoluciones() {
        return Array.from(document.querySelectorAll('tr[data-ref]'))
            .filter(row => row.offsetParent !== null);
    }

    function getRefsParaValidarDevoluciones() {
        const rows = getRowsVisiblesDevoluciones();

        return rows
            .filter(row => {
                if (DEV_AUTO_VALIDATE_ALL_VISIBLE) return true;

                const dev = row.querySelector('.js-dev-est');
                if (!dev) return false;

                const status = dev.getAttribute('data-dev-status') || '';
                const cls = dev.className || '';

                return (
                    !status ||
                    status === 'Error' ||
                    status === 'Pendiente' ||
                    status === 'Diferencia' ||
                    cls.includes('dev-unknown') ||
                    cls.includes('dev-pending') ||
                    cls.includes('dev-diff')
                );
            })
            .map(row => row.getAttribute('data-ref'))
            .filter(Boolean);
    }

    async function validarDevolucionesAutomatico() {
        if (devAutoBusy) return;

        const refs = getRefsParaValidarDevoluciones();

        if (!refs.length) {
            showLog('secondary', 'Auto Dev: no hay entregas visibles para validar.');
            return;
        }

        devAutoBusy = true;

        try {
            showLog('info', `Auto Dev: validando devoluciones de ${refs.length} entrega(s)...`);

            for (let i = 0; i < refs.length; i++) {
                const ref = refs[i];

                const row = document.querySelector(`tr[data-ref="${CSS.escape(ref)}"]`);

                if (row) {
                    row.querySelectorAll('.js-dev-est').forEach(el => {
                        el.className = 'dev-est js-dev-est dev-unknown';
                        el.textContent = '⏳';
                        el.title = 'Validando devolución automáticamente...';
                    });
                }

                await validarDevolucionFila(ref);

                // Pausa pequeña para no saturar el servidor
                await sleepDev(120);
            }

            showLog('success', `Auto Dev: validación terminada. ${refs.length} entrega(s) revisadas.`);
        } catch (e) {
            showLog('danger', 'Auto Dev: error al validar devoluciones: ' + (e?.message || e));
        } finally {
            devAutoBusy = false;
        }
    }

    function setAutoDevUi(activo) {
        const btn = document.getElementById('btnAutoDev');
        const ico = document.getElementById('autoDevIco');

        if (!btn || !ico) return;

        if (activo) {
            btn.classList.add('pm-btn-auto-on');
            ico.textContent = '▶';
            btn.title = 'Auto Dev: ON';
        } else {
            btn.classList.remove('pm-btn-auto-on');
            ico.textContent = '⏸';
            btn.title = 'Auto Dev: OFF';
        }
    }

    function iniciarAutoDev() {
        detenerAutoDev();

        localStorage.setItem(DEV_AUTO_KEY, '1');
        setAutoDevUi(true);

        // Ejecuta una vez inmediatamente
        validarDevolucionesAutomatico();

        // Luego ejecuta cada intervalo
        devAutoTimer = setInterval(() => {
            validarDevolucionesAutomatico();
        }, DEV_AUTO_INTERVAL_MS);
    }

    function detenerAutoDev() {
        if (devAutoTimer) {
            clearInterval(devAutoTimer);
            devAutoTimer = null;
        }

        localStorage.setItem(DEV_AUTO_KEY, '0');
        setAutoDevUi(false);
    }

    function toggleAutoDev() {
        const activo = localStorage.getItem(DEV_AUTO_KEY) === '1';

        if (activo) {
            detenerAutoDev();
            showLog('warning', 'Auto Dev desactivado.');
        } else {
            iniciarAutoDev();
            showLog('success', 'Auto Dev activado.');
        }
    }

    document.getElementById('btnAutoDev')?.addEventListener('click', function () {
        toggleAutoDev();
    });

    document.addEventListener('DOMContentLoaded', function () {
        const activo = localStorage.getItem(DEV_AUTO_KEY) === '1';

        setAutoDevUi(activo);

        if (activo) {
            iniciarAutoDev();
        } else {
            // Validación inicial una sola vez al cargar la página
            setTimeout(() => {
                validarDevolucionesAutomatico();
            }, 800);
        }
    });

    // Si la pestaña vuelve a estar visible, refresca devoluciones
    document.addEventListener('visibilitychange', function () {
        if (!document.hidden && localStorage.getItem(DEV_AUTO_KEY) === '1') {
            validarDevolucionesAutomatico();
        }
    });



    /* =========================
       KPIS ENTREGAS SAP
       ========================= */
    function actualizarKpisEntregasSap() {
        const rows = Array.from(document.querySelectorAll('.tbl-sap tbody tr[data-ref]'));

        const seleccionadas = rows.filter(row => row.querySelector('.ck')?.checked).length;

        const devBad = rows.filter(row => {
            const el = row.querySelector('.js-dev-est');
            const cls = String(el?.className || '');
            const txt = String(el?.getAttribute('data-dev-status') || el?.title || '').toUpperCase();

            return cls.includes('dev-pending') ||
                   cls.includes('dev-diff') ||
                   txt.includes('PENDIENTE') ||
                   txt.includes('DIFERENCIA') ||
                   txt.includes('FALTA') ||
                   txt.includes('SOBRANTE') ||
                   txt.includes('ERROR');
        }).length;

        const devOk = rows.filter(row => {
            const el = row.querySelector('.js-dev-est');
            const cls = String(el?.className || '');
            const txt = String(el?.getAttribute('data-dev-status') || el?.title || '').toUpperCase();

            return cls.includes('dev-ok') ||
                   txt.includes('APLICADA') ||
                   txt.includes('OK');
        }).length;

        const devPendientes = Math.max(rows.length - devOk - devBad, 0);

        const setText = (id, value) => {
            const el = document.getElementById(id);
            if (el) el.textContent = Number(value || 0).toLocaleString('es-MX');
        };

        setText('kpiSapSeleccionadas', seleccionadas);
        setText('kpiSapDevRevisar', devBad);

        const cardDev = document.getElementById('kpiSapDevCard');
        const txtDev = document.getElementById('kpiSapDevTexto');

        if (cardDev) {
            cardDev.classList.remove('ok', 'warn', 'bad');

            if (devBad > 0) {
                cardDev.classList.add('bad');
                if (txtDev) txtDev.textContent = 'Con diferencias / pendientes';
            } else if (devPendientes > 0) {
                cardDev.classList.add('warn');
                if (txtDev) txtDev.textContent = `${devPendientes.toLocaleString('es-MX')} sin validar`;
            } else {
                cardDev.classList.add('ok');
                if (txtDev) txtDev.textContent = 'Devoluciones correctas';
            }
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        actualizarKpisEntregasSap();

        document.querySelectorAll('.ck').forEach(chk => {
            chk.addEventListener('change', actualizarKpisEntregasSap);
        });

        const devTargets = document.querySelectorAll('.js-dev-est');
        if (devTargets.length) {
            const observer = new MutationObserver(actualizarKpisEntregasSap);
            devTargets.forEach(el => {
                observer.observe(el, {
                    attributes: true,
                    childList: true,
                    characterData: true,
                    subtree: true
                });
            });
        }
    });

