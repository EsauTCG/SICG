<div class="window">

    <div class="titlebar">
        <div></div>
        <div class="actions">
            <div class="win-btn"></div>
            <div class="win-btn"></div>
            <div class="win-btn"></div>
        </div>
    </div>



    <div class="content">



        <div class="workspace">

            <div class="section">
                <div class="section-title">Filtros de búsqueda</div>

                <form id="frmFiltros" method="get">
                    <div class="filters">

                        <div class="filter-group">
                            <label>Origen</label>
                            <select name="source" class="form-select">
                                @if (source == "P1")
                                {
                                    <option value="P1" selected>Planta 1</option>
                                }
                                else
                                {
                                    <option value="P1">Planta 1</option>
                                }

                                @if (source == "TIF")
                                {
                                    <option value="TIF" selected>Planta TIF</option>
                                }
                                else
                                {
                                    <option value="TIF">Planta TIF</option>
                                }
                            </select>
                        </div>

                        <div class="filter-group">
                            <label>Cliente</label>
                            <input type="text"
                                   class="form-control"
                                   name="cliente"
                                   value="@cliente"
                                   placeholder="Buscar cliente..." />
                        </div>

                        
                        <div class="filter-group">
                            <label>Estatus SAP</label>
                            <select name="estatusSap" class="form-select">
                                <option value="todos">Todos</option>
                                <option value="enviados">Enviados ✅</option>
                                <option value="noenviados">No enviados ❌</option>
                            </select>
                        </div>


                        <div class="filter-group">
                            <label>Desde</label>
                            <input type="date"
                                   class="form-control"
                                   name="desde"
                                   value="@desde.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="filter-group">
                            <label>Hasta</label>
                            <input type="date"
                                   class="form-control"
                                   name="hasta"
                                   value="@hasta.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="filter-group filter-actions-group">
                            <label>&nbsp;</label>
                            <div class="pm-actions" style="justify-content:flex-end;">
                                <button class="pm-btn pm-btn-primary" type="submit">
                                    <i class="bi bi-search"></i> Buscar
                                </button>

                             @*    <button class="pm-btn btn-enviar" type="button" onclick="sendMany()">
                                    <i class="bi bi-send-fill"></i> Enviar seleccionados
                                </button> *@

                                <button class="pm-btn btn-auto" type="button" id="btnAuto">
                                    <span id="autoIco">⏸</span> Auto
                                </button>

                             @*    <button class="pm-btn pm-btn-warning" type="button" onclick="validarDevolucionesVisibles()" title="Valida devoluciones visibles en la tabla">
                                    <span class="pm-icon">✅</span> Dev.
                                </button> *@

                                <button class="pm-btn btn-auto" type="button" id="btnAutoDev" title="Activar validación automática de devoluciones">
                                    <span id="autoDevIco">⏸</span> Auto Dev
                                </button>

                                <button class="pm-btn btn-actualizar" type="button" onclick="abrirInventarioModal()">
                                    <span class="pm-icon">📦</span> Inventario
                                </button>
                            </div>
                        </div>

                    </div>
                </form>
            </div>


            <div class="section sap-kpi-section">
                <div class="section-title sap-kpi-title">
                    <div>Resumen ejecutivo de entregas SAP</div>
                    <span>Origen: @source | Periodo: @periodoSap | Clientes: @totalClientesSap</span>
                </div>

                <div class="sap-kpi-grid">
                    <div class="sap-kpi sap-kpi-total">
                        <label>Total entregas</label>
                        <strong id="kpiSapTotal">@totalEntregasSap.ToString("N0")</strong>
                        <small>Registros visibles en consulta</small>
                    </div>

                    <div class="sap-kpi sap-kpi-ok">
                        <label>Enviadas SAP</label>
                        <strong id="kpiSapEnviadas">@totalEnviadasSap.ToString("N0")</strong>
                        <small>Confirmadas correctamente</small>
                    </div>

                    <div class="sap-kpi sap-kpi-pending">
                        <label>Pendientes</label>
                        <strong id="kpiSapPendientes">@totalPendientesSap.ToString("N0")</strong>
                        <small>Sin intento / por enviar</small>
                    </div>

                    <div class="sap-kpi sap-kpi-error">
                        <label>Fallidas</label>
                        <strong id="kpiSapFallidas">@totalFallidasSap.ToString("N0")</strong>
                        <small>Requieren revisión</small>
                    </div>

                    <div class="sap-kpi sap-kpi-selected">
                        <label>Seleccionadas</label>
                        <strong id="kpiSapSeleccionadas">0</strong>
                        <small>Marcadas para envío masivo</small>
                    </div>

                    <div class="sap-kpi sap-kpi-dev" id="kpiSapDevCard">
                        <label>Dev. revisar</label>
                        <strong id="kpiSapDevRevisar">0</strong>
                        <small id="kpiSapDevTexto">Pendiente de validar</small>
                    </div>
                </div>
            </div>

            <div class="section">
                @*  <div class="section-title">Listado de entregas</div> *@

                <div class="table-wrap">
                    <table class="tbl-sap">
                        <thead>
                            <tr>
                                <th class="text-center">#</th>
                                <th>Fecha</th>
                                <th>Solicitud</th>
                                <th>Cliente</th>
                                <th>Pedido</th>
                                <th>Remisión</th>
                                <th class="text-center">Est.</th>
                                <th class="text-center">Dev.</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var x in Model)
                                {
                                    var icon = x.EnviadoSap == true ? "✅" : (x.EnviadoSap == false ? "❌" : "—");
                                    var title = x.EnviadoSap == true
                                    ? $"Enviado{(x.FechaEnvioSap != null ? " (" + x.FechaEnvioSap.Value.ToString("dd/MM/yyyy HH:mm") + ")" : "")}"
                                    : (x.EnviadoSap == false
                                    ? $"Falló{(x.FechaEnvioSap != null ? " (" + x.FechaEnvioSap.Value.ToString("dd/MM/yyyy HH:mm") + ")" : "")}{(!string.IsNullOrWhiteSpace(x.MsgSap) ? " - " + x.MsgSap : "")}"
                                    : "Sin intento");

                                    <tr class="@(x.EnviadoSap == false ? "sap-error" : "")"
                                        data-ref="@x.ReferenciaDocMeat"
                                        data-fecha="@((x.FechaDocumento?.ToString("o")) ?? "")">

                                        <td class="text-center">
                                            <span style="font-size:11px;color:#9a6a6a;font-weight:700;display:block;margin-bottom:2px;">@(Model.IndexOf(x) + 1)</span>
                                            <input type="checkbox" class="ck" value="@x.ReferenciaDocMeat"
                                                   style="width:14px!important;height:14px!important;min-width:14px!important;" />
                                        </td>
                                        <td title="@((x.FechaDocumento?.ToString("dd/MM/yyyy HH:mm")) ?? "-")">@((x.FechaDocumento?.ToString("dd/MM/yyyy HH:mm")) ?? "-")</td>
                                        <td title="@x.SolicitudSurtidoId">@x.SolicitudSurtidoId</td>
                                        <td title="@((string.IsNullOrWhiteSpace(x.Cliente) ? "-" : x.Cliente))">@((string.IsNullOrWhiteSpace(x.Cliente) ? "-" : x.Cliente))</td>
                                        <td title="@x.Remision">@x.Remision</td>
                                        <td title="@x.ReferenciaDocMeat"><code style="font-size:11px;">@x.ReferenciaDocMeat</code></td>
                                        <td class="text-center">
                                            <span class="sap-est js-est" title="@title">@icon</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="dev-est js-dev-est dev-unknown"
                                                  title="Devolución sin validar">⏳</span>
                                        </td>
                                        <td class="text-end">
                                            <div class="pm-actions" style="justify-content:flex-end;">
                                                <a class="pm-btn pm-btn-outline"
                                                   target="_blank"
                                                   href="@Url.Action("EntregaJson", "ProcesosCg", new { referencia = x.ReferenciaDocMeat, source = source })"
                                                   style="font-size:11px;">
                                                    <span class="pm-icon">📄</span> JSON
                                                </a>

                                                <button class="pm-btn pm-btn-warning js-traza"
                                                        type="button"
                                                        onclick="validarTrazabilidad('@x.ReferenciaDocMeat')"
                                                        style="font-size:11px;">
                                                    <span class="pm-icon">🔎</span> Trazabilidad
                                                </button>

                                                <button class="pm-btn pm-btn-success"
                                                        type="button"
                                                        onclick="abrirPdfConComentarios('@x.SolicitudSurtidoId', '@x.ReferenciaDocMeat')"
                                                        style="font-size:11px;">
                                                    <span class="pm-icon">📕</span> PDF
                                                </button>

                                                <button class="pm-btn pm-btn-primary js-send-one"
                                                        type="button"
                                                        onclick="sendOne('@x.ReferenciaDocMeat')"
                                                        style="font-size:11px;">
                                                    <span class="pm-icon">📤</span> Enviar
                                                </button>
                                                <div class="dropdown">
                                                    @*  <button class="pm-btn pm-btn-warning dropdown-toggle js-reserve"
            type="button"
            data-bs-toggle="dropdown"
            style="font-size:11px; opacity:.5; pointer-events:none;"
            aria-disabled="true">
        Reserva
    </button> *@
                                                    <ul class="dropdown-menu dropdown-menu-end">
                                                        <li>
                                                            <button class="dropdown-item" type="button"
                                                                    onclick="sendReserveByDelivery('@x.ReferenciaDocMeat')">
                                                                📦 Por entrega
                                                            </button>
                                                        </li>
                                                        <li>
                                                            <button class="dropdown-item" type="button"
                                                                    onclick="openReserveManual('@x.ReferenciaDocMeat')">
                                                                ✍️ Manual (KG)
                                                            </button>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="text-center text-muted">Sin resultados.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Log -->
            <div id="logBox">
                <div id="log" class="log-inner log-secondary"></div>
            </div>

        </div>
    </div>

    <div class="statusbar">
        <div>Registro listo</div>
        <div>Usuario: @(User?.Identity?.Name ?? "")</div>
        <div>Empresa: Carnes G SA de CV</div>
        <div>Módulo: Entregas SAP</div>
    </div>

</div>

<div class="modal fade" id="pdfComentariosModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered pdf-modal-width">
        <div class="modal-content pdf-modal">

            <div class="pdf-modal-header">
                <div class="pdf-modal-title">
                    <span class="pdf-title-icon">📄</span>
                    Generar PDF con comentarios
                </div>

                <button type="button"
                        class="pdf-close"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                    ×
                </button>
            </div>

            <div class="pdf-modal-body">

                <div class="pdf-icon-circle">
                    <span>PDF</span>
                </div>

                <h4 class="pdf-heading">Agrega comentarios para el PDF</h4>

                <div class="pdf-line"></div>

                <p class="pdf-subtitle">
                    Los comentarios que escribas se incluirán en el PDF
                    en la sección de Comentarios.
                </p>

                <div class="pdf-source-box">
                    <div class="pdf-source-title">Selecciona de dónde tomar los datos del PDF</div>

                    <div class="pdf-source-options">
                        <label class="pdf-source-option" for="pdfOrigenRemision">
                            <input type="radio"
                                   id="pdfOrigenRemision"
                                   name="pdfOrigenDatos"
                                   value="remision"
                                   checked />
                            <span>
                                <span class="pdf-source-name">Remisión / Surtido real</span>
                                <span class="pdf-source-desc">
                                    Usa lo que realmente se cargó y viene en el Meat de la entrega.
                                </span>
                            </span>
                        </label>

                        <label class="pdf-source-option" for="pdfOrigenOrden">
                            <input type="radio"
                                   id="pdfOrigenOrden"
                                   name="pdfOrigenDatos"
                                   value="orden" />
                            <span>
                                <span class="pdf-source-name">Orden de venta / Pedido</span>
                                <span class="pdf-source-desc">
                                    Usa los datos originales de la solicitud que genera el pedido.
                                </span>
                            </span>
                        </label>
                    </div>

                    <div class="pdf-source-context">
                        <div>Solicitud: <strong id="pdfSolicitudLabel">-</strong></div>
                        <div>Remisión / JSON: <strong id="pdfReferenciaLabel">-</strong></div>
                    </div>

                    <div class="pdf-source-note" id="pdfOrigenNota">
                        Se generará el PDF con los datos realmente surtidos de la remisión/JSON.
                    </div>
                </div>

                <div class="pdf-field">
                    <label for="pdfComentarios">Comentarios opcional</label>

                    <textarea id="pdfComentarios"
                              maxlength="1000"
                              rows="5"
                              placeholder="Escribe aquí tus comentarios..."></textarea>

                    <div class="pdf-counter" id="pdfComentariosCount">0/1000</div>
                </div>

                <div class="pdf-alert">
                    <span>ℹ️</span>
                    <div>
                        Si no agregas comentarios, se mostrará el comentario
                        registrado en el sistema, si existe.
                    </div>
                </div>

            </div>

            <div class="pdf-modal-footer">
                <button type="button"
                        class="pdf-btn pdf-btn-cancel"
                        data-bs-dismiss="modal">
                    ✕ Cancelar
                </button>

                <button type="button"
                        class="pdf-btn pdf-btn-generate"
                        onclick="generarPdfConComentarios()">
                    📄 Generar PDF
                </button>
            </div>

        </div>
    </div>
</div>


<div class="modal fade" id="trazabilidadModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content trz-modal">

            <div class="trz-header">
                <div class="trz-title">
                    <span>🔎</span>
                    Diferencias de trazabilidad
                </div>

                <button type="button"
                        class="trz-close"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                    ×
                </button>
            </div>

            <div class="trz-body">

                <div class="trz-alert-main" id="trzAlertBox">
                    <div class="trz-icon" id="trzAlertIcon">⚠️</div>
                    <div>
                        <strong id="trzAlertTitle">Validación de trazabilidad y devoluciones.</strong><br />
                        <span id="trzAlertText">
                            Revisa los lotes, kilos solicitados, disponibilidad en SAP y devoluciones aplicadas.
                        </span>
                    </div>
                </div>

                <div class="trz-ref-box">
                    Entrega / Referencia: <strong id="trzRef">-</strong>
                </div>

                <div class="trz-summary">
                    <div class="trz-summary-card">
                        <div class="label">Partidas</div>
                        <div class="value" id="trzTotalPartidas">0</div>
                    </div>

                    <div class="trz-summary-card">
                        <div class="label">Kg solicitados</div>
                        <div class="value" id="trzKgSolicitados">0</div>
                    </div>

                    <div class="trz-summary-card">
                        <div class="label">Kg faltantes</div>
                        <div class="value" id="trzKgFaltantes">0</div>
                    </div>
                </div>

                <div class="trz-table-wrap">
                    <table class="trz-table" style="min-width:900px;">
                        <thead>
                            <tr>
                                <th>Artículo</th>
                                <th>Almacén</th>
                                <th>Lote</th>
                                <th>Fecha producción</th>
                                <th class="text-end">SIGO</th>
                                <th class="text-end">SAP Disp.</th>
                                <th class="text-end">Falta</th>
                                <th>Estatus</th>
                            </tr>
                        </thead>
                        <tbody id="trzDetalleBody">
                            <tr>
                                <td colspan="8" class="text-center">Sin detalle.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="trz-ref-box" style="margin-top:14px;">
                    Devoluciones Meat vs SAP:
                    <strong>comparativo por artículo, lote y kilos</strong>
                </div>

                <div class="trz-summary">
                    <div class="trz-summary-card">
                        <div class="label">Partidas devolución</div>
                        <div class="value" id="devTotalPartidas">0</div>
                    </div>

                    <div class="trz-summary-card">
                        <div class="label">Kg Meat</div>
                        <div class="value" id="devKgMeat">0</div>
                    </div>

                    <div class="trz-summary-card">
                        <div class="label">Kg SAP</div>
                        <div class="value" id="devKgSap">0</div>
                    </div>
                </div>

                <div class="trz-summary">
                    <div class="trz-summary-card">
                        <div class="label">Diferencia KG</div>
                        <div class="value" id="devKgDif">0</div>
                    </div>

                    <div class="trz-summary-card">
                        <div class="label">Aplicadas</div>
                        <div class="value" id="devTotalAplicadas">0</div>
                    </div>

                    <div class="trz-summary-card">
                        <div class="label">Pendientes / Diferencias</div>
                        <div class="value" id="devTotalPendientes">0</div>
