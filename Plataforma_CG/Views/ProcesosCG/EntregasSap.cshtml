@model List<Plataforma_CG.ViewModels.EntregaSapRowVM>
@removeTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "";

    var source = (string)(ViewBag.Source ?? "P1");
    DateTime desde = ViewBag.Desde != null ? (DateTime)ViewBag.Desde : DateTime.Today;
    DateTime hasta = ViewBag.Hasta != null ? (DateTime)ViewBag.Hasta : DateTime.Today;
    var cliente = (string)(ViewBag.Cliente ?? "");

    var totalEntregasSap = Model?.Count ?? 0;
    var totalEnviadasSap = Model?.Count(x => x.EnviadoSap == true) ?? 0;
    var totalFallidasSap = Model?.Count(x => x.EnviadoSap == false) ?? 0;
    var totalPendientesSap = totalEntregasSap - totalEnviadasSap - totalFallidasSap;
    var totalClientesSap = Model?
        .Where(x => !string.IsNullOrWhiteSpace(x.Cliente))
        .Select(x => x.Cliente.Trim())
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count() ?? 0;
    var periodoSap = desde.Date == hasta.Date
        ? desde.ToString("dd/MM/yyyy")
        : $"{desde:dd/MM/yyyy} - {hasta:dd/MM/yyyy}";
}

