                            </td>
                        </tr>`;
                } else {
                    devBody.innerHTML = devoluciones.map(x => {
                        const estatus = getPropValue(
                            x,
                            'estatus',
                            'Estatus',
                            ''
                        );

                        const b = badgeInfo(estatus);
                        const docNum = getPropValue(
                            x,
                            'docNumDevolucion',
                            'DocNumDevolucion',
                            ''
                        );

                        return `
                            <tr>
                                <td>${escapeHtml(getPropValue(x, 'pedidoSap', 'PedidoSap', ''))}</td>
                                <td>${escapeHtml(getPropValue(x, 'articulo', 'Articulo', ''))}</td>
                                <td>${escapeHtml(getPropValue(x, 'lote', 'Lote', ''))}</td>
                                <td class="text-end">${formatKg(getPropValue(x, 'kgDevueltosMeat', 'KgDevueltosMeat', 0))}</td>
                                <td class="text-end">${formatKg(getPropValue(x, 'kgDevueltosSap', 'KgDevueltosSap', 0))}</td>
                                <td class="text-end">${formatKg(getPropValue(x, 'diferenciaKg', 'DiferenciaKg', 0))}</td>
                                <td>${escapeHtml(docNum ? String(docNum) : '-')}</td>
                                <td>${escapeHtml(getPropValue(x, 'tipoAplicacion', 'TipoAplicacion', '-'))}</td>
                                <td>
                                    <span class="${b.cls}">
                                        ${b.icon}
                                        ${escapeHtml(estatus)}
                                    </span>
