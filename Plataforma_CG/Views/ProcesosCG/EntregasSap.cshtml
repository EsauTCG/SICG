                    return e.includes('PENDIENTE') ||
                           e.includes('DIFERENCIA') ||
                           e.includes('FALTA') ||
                           e.includes('SOBRANTE');
                }).length;

                const hayErrorDevolucion =
                    Boolean(devolucionError) ||
                    devoluciones.some(x => {
                        const e = String(
                            getPropValue(x, 'estatus', 'Estatus', '')
                        ).toUpperCase();

                        return e.includes('PENDIENTE') ||
                               e.includes('DIFERENCIA') ||
                               e.includes('FALTA') ||
                               e.includes('SOBRANTE');
                    });

                document.getElementById('devTotalPartidas').textContent =
                    devoluciones.length;
                document.getElementById('devKgMeat').textContent =
                    formatKg(totalKgMeat);
                document.getElementById('devKgSap').textContent =
                    formatKg(totalKgSap);
                document.getElementById('devKgDif').textContent =
                    formatKg(totalKgDif);
                document.getElementById('devTotalAplicadas').textContent =
                    devAplicadas;
                document.getElementById('devTotalPendientes').textContent =
                    devPendientes;

                const devBody = document.getElementById('devDetalleBody');

                if (devolucionError) {
                    devBody.innerHTML = `
