            function mostrarCargando(texto) {
                const el = document.getElementById('loadingModalText');
                if (el) {
                    el.textContent = texto || 'Cargando información...';
                }

                bootstrap.Modal.getOrCreateInstance(
                    document.getElementById('loadingModal')
                ).show();
            }

            function ocultarCargando() {
                const modalEl = document.getElementById('loadingModal');
                if (!modalEl) return;

                try {
                    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                    modal.hide();
                } catch (e) {
                    // No bloquear la pantalla si Bootstrap no alcanza a cerrar el modal.
                }

                // Refuerzo: cuando se abren/cierra modales muy rápido, Bootstrap puede dejar
                // el loading visible. Forzamos el cierre sin afectar el modal de trazabilidad.
                setTimeout(() => {
                    modalEl.classList.remove('show');
                    modalEl.style.display = 'none';
                    modalEl.setAttribute('aria-hidden', 'true');
                    modalEl.removeAttribute('aria-modal');
                    modalEl.removeAttribute('role');

                    const modalesAbiertos = Array.from(document.querySelectorAll('.modal.show'))
                        .filter(x => x.id !== 'loadingModal');

                    if (modalesAbiertos.length === 0) {
                        document.body.classList.remove('modal-open');
                        document.body.style.removeProperty('overflow');
                        document.body.style.removeProperty('padding-right');
                        document.querySelectorAll('.modal-backdrop').forEach(x => x.remove());
                    } else {
                        // Deja máximo un backdrop para el modal que sí queda abierto.
                        const backs = Array.from(document.querySelectorAll('.modal-backdrop'));
                        backs.slice(1).forEach(x => x.remove());
                        document.body.classList.add('modal-open');
                    }
                }, 120);
            }

            function htmlSpinnerTabla(colspan, texto) {
                return `
                    <tr>
                        <td colspan="${colspan}" class="loading-row">
                            <div class="pm-spinner"></div>
