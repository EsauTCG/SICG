                async function sendReserveKg() {
                    const lines = [];
                    document.querySelectorAll('.reserve-qty').forEach(inp => {
                        const qty = parseFloat(inp.value);
                        if (qty > 0) lines.push({ baseLine: parseInt(inp.dataset.baseline), quantity: qty });
                    });
                    if (!lines.length) { alert('Captura al menos un KG.'); return; }
                    if (!confirm('¿Generar reserva MANUAL con los KG capturados?')) return;
                    showLog('info', 'Generando Reserva Manual...');
                    try {
                        const res = await fetch('@Url.Action("EnviarFacturaReservaManual", "ProcesosCg")', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ referencia: currentReserveRef, source: SOURCE, lines })
                        });
                        const data = await readResponse(res);
                        if (res.ok && data?.ok) {
                            showLog('success', buildMsg(data, 'Reserva manual enviada.'));
                            bootstrap.Modal.getInstance(document.getElementById('reserveKgModal'))?.hide();
