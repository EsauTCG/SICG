                );

                const totalKgSap = devoluciones.reduce(
                    (sum, x) => sum + toNumber(
                        getPropValue(x, 'kgDevueltosSap', 'KgDevueltosSap', 0)
                    ),
                    0
                );

                const totalKgDif = devoluciones.reduce(
