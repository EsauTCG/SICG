                                        @if (Model?.Resultados != null && Model.Resultados.Any())
                                        {
                                            foreach (var r in Model.Resultados)
                                            {
                                                var esManual = (r.Tipo ?? "").ToUpper().Contains("MANUAL");
                                                var dur = (r.Hasta > r.Desde) ? (r.Hasta - r.Desde) : TimeSpan.Zero;
                                                var durTxt = esManual ? $"{(int)dur.TotalHours:00}:{dur.Minutes:00}:{dur.Seconds:00}" : "-";
                                                var durSort = esManual ? (int)dur.TotalSeconds : -1;

                                                <tr>
                                                    <td title="@(r.NombreLote ?? "")">
                                                        <a href="#"
                                                           class="ver-det"
                                                           data-lote="@r.LoteId"
                                                           data-nombrelote="@((r.NombreLote ?? "").Replace("\"",""))"
                                                           data-tipo="@r.Tipo"
                                                           data-desde="@r.Desde.ToString("o")"
                                                           data-hasta="@r.Hasta.ToString("o")"
                                                           title="Ver detalle">
                                                            @(r.NombreLote ?? "")
                                                        </a>
                                                    </td>
                                                    <td>
                                                        <span class="badge-tipo @(esManual ? "badge-manual" : "badge-auto")">@r.Tipo</span>
                                                    </td>
                                                    <td title="@r.Desde.ToString("yyyy-MM-dd HH:mm:ss")">@r.Desde.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                                    <td data-sort-value="@durSort" title="@durTxt">@durTxt</td>
                                                    <td title="@r.Hasta.ToString("yyyy-MM-dd HH:mm:ss")">@r.Hasta.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                                    <td title="@(r.Proceso ?? "-")">@(r.Proceso ?? "-")</td>
                                                    <td title="@(r.Solicitante ?? "-")">@(r.Solicitante ?? "-")</td>
                                                    <td title="@(r.Autoriza ?? "-")">@(r.Autoriza ?? "-")</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="8" class="text-center text-muted">Sin resultados.</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div><!-- /VISTA 1 -->

                    <!-- ══════════════ VISTA 2 ══════════════ -->
                    <div class="view-page">

                        <div class="section">
                            <div class="section-title">Filtros de búsqueda</div>

                            <form id="frmBuscarVista2" method="get" action="@Url.Action("PesoLote","ProcesosCg")">
                                <div class="filters-v2">

                                    <div class="filter-group">
                                        <label>Desde</label>
                                        <input type="date" class="form-control" name="Desde" value="@desdeDef.ToString("yyyy-MM-dd")" />
                                    </div>

                                    <div class="filter-group">
                                        <label>Hasta</label>
                                        <input type="date" class="form-control" name="Hasta" value="@hastaDef.ToString("yyyy-MM-dd")" />
                                    </div>

                                    <div class="filter-group">
                                        <label>
                                            Lote
                                            <span class="sub-label">— mismos filtros</span>
                                        </label>

                                        <div class="dropdown w-100" id="dd-lote-v2">
                                            <button class="btn-select-like" type="button"
                                                    data-bs-toggle="dropdown" aria-expanded="false">
                                                <span class="multi-label">(Todos)</span>
                                            </button>

                                            <ul class="dropdown-menu w-100" style="max-height:260px; overflow-y:auto;">
                                                @if (Model?.Lotes != null && Model.Lotes.Any())
                                                {
                                                    var j = 0;
                                                    foreach (var txt in Model.Lotes)
                                                    {
                                                        var idStr = "";
                                                        var p1 = txt.LastIndexOf('(');
                                                        var p2 = txt.LastIndexOf(')');
                                                        if (p1 >= 0 && p2 > p1) idStr = txt.Substring(p1 + 1, p2 - p1 - 1);
                                                        int.TryParse(idStr, out var idInt);
                                                        var id = $"lotev2_{j++}";
                                                        var isSelected = (Model?.LotesSeleccionados ?? new List<int>()).Contains(idInt);
                                                        <li class="px-2">
                                                            <div class="form-check">
                                                                <input class="form-check-input multi-check-lote-v2" type="checkbox"
                                                                       value="@idInt" id="@id" data-text="@txt"
                                                                @(isSelected ? "checked" : null) />
                                                                <label class="form-check-label" for="@id">@txt</label>
                                                            </div>
                                                        </li>
                                                    }
                                                }
                                                else
                                                {
                                                    <li class="px-3 py-2 text-muted" style="font-size:12px;">Sin lotes para ese rango.</li>
                                                }
                                            </ul>

                                            <div id="dd-lote-hidden-v2">
                                                @foreach (var v in (Model?.LotesSeleccionados ?? new List<int>()))
                                                {
                                                    <input type="hidden" name="LotesSeleccionados" value="@v" />
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <div class="filter-group">
                                        <label>&nbsp;</label>
                                        <div class="pm-actions">
                                            <button id="btnBuscarV2" class="pm-btn pm-btn-primary" type="submit">
                                                <i class="bi bi-search"></i> Buscar
                                            </button>
                                            <a class="pm-btn pm-btn-excel"
                                               href="@Url.Action("PesoLoteExcel","ProcesosCg", new {
                                                   desde = desdeDef.ToString("yyyy-MM-dd"),
                                                   hasta = hastaDef.ToString("yyyy-MM-dd")
                                               })">
                                                <i class="bi bi-file-earmark-excel"></i> Excel
                                            </a>
                                        </div>
                                    </div>

                                </div>
                            </form>
                        </div>

                        <div class="section">
                            <div class="section-title">Kardex Movimientos</div>

                            <div class="table-wrap">
                                <table class="tbl-second">
                                    <thead>
                                        <tr>
                                            <th>Lote</th>
                                            <th>Fecha Producción</th>
                                            <th>Artículo</th>
                                            <th>Producto</th>
                                            <th>Solicitante</th>
                                            <th>Autoriza</th>
                                            <th class="text-end">Valor Actual</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model?.Resultados != null && Model.Resultados.Any())
                                        {
                                            foreach (var r in Model.Resultados)
                                            {
                                                <tr>
                                                    <td title="@(r.NombreLote ?? "")">@(r.NombreLote ?? "-")</td>
                                                    <td title="@r.Desde.ToString("yyyy-MM-dd HH:mm:ss")">@r.Desde.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                                    <td>-</td>
                                                    <td>-</td>
                                                    <td title="@(r.Solicitante ?? "-")">@(r.Solicitante ?? "-")</td>
                                                    <td title="@(r.Autoriza ?? "-")">@(r.Autoriza ?? "-")</td>
                                                    <td class="text-end">-</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="7" class="text-center text-muted">Sin resultados.</td>
                                            </tr>
                                        }
                                    </tbody>
