</div><!-- /window -->

@Html.AntiForgeryToken()

<!-- ══════════ MODAL ══════════ -->
<div class="modal fade" id="pesoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    Detalle de Peso — Lote: <span id="pm-lote"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            <div class="modal-body">
                <div class="header-row">
                    <div><strong>Lote:</strong> <span id="pm-nombre"></span></div>
                    <div><strong>Tipo:</strong>  <span id="pm-tipo"></span></div>
                    <div><strong>Desde:</strong> <span id="pm-desde"></span></div>
                    <div><strong>Hasta:</strong> <span id="pm-hasta"></span></div>
                </div>

                <div class="table-responsive" style="max-height:60vh;">
                    <table class="sap-grid">
                        <thead>
                            <tr>
                                <th>Artículo</th>
                                <th>Producto</th>
                                <th>Fecha Producción</th>
                                <th>Fecha Solicitud</th>
                                <th>Solicitante</th>
                                <th>Autoriza</th>
                                <th>Estación</th>
                                <th class="text-end">Valor Actual</th>
                            </tr>
                        </thead>
                        <tbody id="pm-tbody">
                            <tr>
                                <td colspan="8" class="text-center text-muted">Selecciona un rango...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="modal-footer">
                <small class="text-muted me-auto" id="pm-count"></small>
                <a id="btnExcelDetalle"
                   class="pm-btn pm-btn-excel"
                   href="#"
                   target="_blank">
                    <i class="bi bi-file-earmark-excel"></i> Excel
                </a>
                <button type="button" class="pm-btn pm-btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<script>
    var DETALLE_URL       = '@Url.Action("PesoLoteDetalleApi",   "ProcesosCg")';
    var DETALLE_EXCEL_URL = '@Url.Action("PesoLoteDetalleExcel", "ProcesosCg")';

    function fmtDateTime(s) {
        if (!s) return "";
        var dt = new Date(s);
        return isNaN(dt) ? String(s) : dt.toLocaleString();
    }

    function safeText(v) { return (v === null || v === undefined) ? "" : String(v); }

    function getv(r, pascal, camel) {
        if (!r) return undefined;
        if (r[pascal] !== undefined) return r[pascal];
        if (r[camel]  !== undefined) return r[camel];
        return undefined;
    }

    function buildUrl(base, params) {
        var qs = [];
        for (var k in params) {
            if (!params.hasOwnProperty(k)) continue;
            qs.push(encodeURIComponent(k) + "=" + encodeURIComponent(params[k]));
        }
        return base + "?" + qs.join("&");
    }

    function showOverlay(msg, sub) {
        var ov = document.getElementById('globalOverlay');
        var t  = document.getElementById('globalOverlayText');
        var s  = document.getElementById('globalOverlaySub');
        if (t) t.textContent = msg || "Cargando...";
        if (s) s.textContent = sub || "Por favor espera";
        if (ov) { ov.classList.add('show'); ov.setAttribute('aria-hidden','false'); }
    }

    function hideOverlay() {
        var ov = document.getElementById('globalOverlay');
        if (ov) { ov.classList.remove('show'); ov.setAttribute('aria-hidden','true'); }
    }

    function setDetalleLoading(isLoading) {
        var btn = document.getElementById('btnExcelDetalle');
        if (!btn) return;
        if (isLoading) {
            btn.classList.add('disabled');
            btn.setAttribute('aria-disabled','true');
            btn.style.pointerEvents = 'none';
        } else {
            btn.classList.remove('disabled');
            btn.removeAttribute('aria-disabled');
            btn.style.pointerEvents = '';
        }
    }

    /* ── Ordenamiento tabla principal ── */
    function parseDateFromCell(text) {
        var t = (text || "").trim();
        if (!t) return NaN;
        var d = new Date(t.replace(" ", "T"));
        return isNaN(d) ? NaN : d.getTime();
    }

    function getCellText(tr, idx) {
        var td = tr.children[idx];
        if (!td) return "";
        var dv = td.getAttribute("data-sort-value");
        if (dv !== null) return dv;
        return (td.innerText || td.textContent || "").trim();
    }

    function sortTableByColumn(table, colIndex, type, asc) {
        var tbody = table.tBodies[0];
        if (!tbody) return;
        var rows = Array.from(tbody.querySelectorAll("tr"));
        if (rows.length === 1 && rows[0].children.length === 1) return;

        rows.sort(function(a, b) {
            var av = getCellText(a, colIndex);
            var bv = getCellText(b, colIndex);

            if (type === "date") {
                var at = parseDateFromCell(av), bt = parseDateFromCell(bv);
                if (isNaN(at) || isNaN(bt)) return asc ? av.localeCompare(bv,"es",{sensitivity:"base"}) : bv.localeCompare(av,"es",{sensitivity:"base"});
                return asc ? at - bt : bt - at;
            }
            if (type === "num") {
                var an = Number(av), bn = Number(bv);
                if (isNaN(an)) an = -999999999;
                if (isNaN(bn)) bn = -999999999;
                return asc ? an - bn : bn - an;
            }
            return asc ? av.localeCompare(bv,"es",{sensitivity:"base"}) : bv.localeCompare(av,"es",{sensitivity:"base"});
        });

        rows.forEach(function(r) { tbody.appendChild(r); });
    }

    document.addEventListener("DOMContentLoaded", function() {
        var table = document.querySelector(".tbl-main");
        if (!table) return;
        var headers = table.querySelectorAll("thead th[data-sort]");
        var current = { index: -1, asc: true };

        headers.forEach(function(th, idx) {
            th.addEventListener("click", function() {
                headers.forEach(function(h) { h.classList.remove("sort-asc","sort-desc"); });
                var type = th.getAttribute("data-sort") || "text";
                var asc  = (current.index === idx) ? !current.asc : true;
                current.index = idx;
                current.asc   = asc;
                sortTableByColumn(table, idx, type, asc);
                th.classList.add(asc ? "sort-asc" : "sort-desc");
            });
        });
    });

    /* ── Cargar detalle modal ── */
    async function cargarDetalle(loteId, desdeIso, hastaIso, nombreLote, tipo) {
        var tbody    = document.getElementById('pm-tbody');
        var lblCount = document.getElementById('pm-count');

        document.getElementById('pm-lote').textContent   = safeText(loteId);
        document.getElementById('pm-nombre').textContent = safeText(nombreLote);
        document.getElementById('pm-tipo').textContent   = safeText(tipo);
        document.getElementById('pm-desde').textContent  = fmtDateTime(desdeIso);
        document.getElementById('pm-hasta').textContent  = fmtDateTime(hastaIso);

        var btnExcel = document.getElementById('btnExcelDetalle');
        if (btnExcel) btnExcel.href = buildUrl(DETALLE_EXCEL_URL, { loteId: loteId, desde: desdeIso, hasta: hastaIso });

        lblCount.textContent = "";
        setDetalleLoading(true);
        showOverlay("Cargando lote " + safeText(loteId) + "...", "Obteniendo registros");
        if (tbody) tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted">Cargando...</td></tr>';

        var url = buildUrl(DETALLE_URL, { loteId: loteId, desde: desdeIso, hasta: hastaIso });

        try {
            var resp = await fetch(url, { cache: 'no-store', credentials: 'same-origin' });
            var raw  = await resp.text();

            if (!resp.ok) {
                if (tbody) tbody.innerHTML = '<tr><td colspan="8" class="text-center text-danger">Error HTTP ' + resp.status + '</td></tr>';
                return;
            }

            var json;
            try { json = JSON.parse(raw); } catch(e) {
                if (tbody) tbody.innerHTML = '<tr><td colspan="8" class="text-center text-danger">Respuesta no es JSON.</td></tr>';
                return;
            }

            if (!json || json.ok === false) {
                if (tbody) tbody.innerHTML = '<tr><td colspan="8" class="text-center text-danger">Error del backend.</td></tr>';
                return;
            }

            var rows = Array.isArray(json.rows) ? json.rows : [];
            lblCount.textContent = rows.length ? (rows.length + " registro(s)") : "0 registros";

            if (!rows.length) {
                if (tbody) tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted">Sin registros.</td></tr>';
                return;
            }

            var html = "";
            for (var i = 0; i < rows.length; i++) {
                var r = rows[i];
                html += '<tr>'
                    + '<td>'  + safeText(getv(r,"Articulo","articulo")) + '</td>'
                    + '<td class="col-desc">' + safeText(getv(r,"NombreArticulo","nombreArticulo")) + '</td>'
                    + '<td>'  + fmtDateTime(getv(r,"FechaProduccion","fechaProduccion")) + '</td>'
                    + '<td>'  + fmtDateTime(getv(r,"FechaSolicitud","fechaSolicitud")) + '</td>'
                    + '<td>'  + safeText(getv(r,"Solicitante","solicitante")) + '</td>'
                    + '<td>'  + safeText(getv(r,"Autoriza","autoriza")) + '</td>'
                    + '<td>'  + safeText(getv(r,"Estacion","estacion")) + '</td>'
                    + '<td class="text-end">' + safeText(getv(r,"ValorActual","valorActual")) + '</td>'
                    + '</tr>';
            }
            if (tbody) tbody.innerHTML = html;

        } catch(e) {
            if (tbody) tbody.innerHTML = '<tr><td colspan="8" class="text-center text-danger">Error de red.</td></tr>';
            lblCount.textContent = "";
        } finally {
            setDetalleLoading(false);
            hideOverlay();
        }
    }

    /* ── Click en link lote ── */
    document.addEventListener('click', async function(ev) {
        var a = ev.target.closest('a.ver-det');
        if (!a) return;
        ev.preventDefault();
        new bootstrap.Modal(document.getElementById('pesoModal')).show();
        await cargarDetalle(a.dataset.lote, a.dataset.desde, a.dataset.hasta, a.dataset.nombrelote || "", a.dataset.tipo || "");
    });

    /* ── Multi-dropdown ── */
    function initMultiDropdown(rootId, checkClass, hiddenId, hiddenName) {
        var root   = document.getElementById(rootId);
        if (!root) return;
        var label  = root.querySelector('.multi-label');
        var checks = root.querySelectorAll('.' + checkClass);
        var hidden = document.getElementById(hiddenId);

        function refresh() {
            hidden.innerHTML = "";
            var texts = [];
            checks.forEach(function(ch) {
                if (ch.checked) {
                    texts.push(ch.getAttribute('data-text') || ch.value);
                    var inp = document.createElement('input');
                    inp.type = 'hidden'; inp.name = hiddenName; inp.value = ch.value;
                    hidden.appendChild(inp);
                }
            });
            if (!texts.length)          label.textContent = '(Todos)';
            else if (texts.length <= 2) label.textContent = texts.join(', ');
            else                        label.textContent = texts.length + ' seleccionados';
        }

        checks.forEach(function(ch) { ch.addEventListener('change', refresh); });
        refresh();
    }

    /* ── Cambio entre vistas ── */
    function setActiveView(viewName) {
        var track   = document.getElementById('viewsTrack');
        var btnGo   = document.getElementById('btnGoSecondary');
        var btnBack = document.getElementById('btnBackPrimary');
        if (!track) return;

        if (viewName === 'secondary') {
            track.classList.add('show-secondary');
            if (btnGo)   btnGo.style.display   = 'none';
            if (btnBack) btnBack.style.display  = '';
            sessionStorage.setItem('pesoLoteView','secondary');
        } else {
            track.classList.remove('show-secondary');
            if (btnGo)   btnGo.style.display   = '';
            if (btnBack) btnBack.style.display  = 'none';
            sessionStorage.setItem('pesoLoteView','primary');
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        initMultiDropdown('dd-lote',    'multi-check-lote',    'dd-lote-hidden',    'LotesSeleccionados');
        initMultiDropdown('dd-lote-v2', 'multi-check-lote-v2', 'dd-lote-hidden-v2', 'LotesSeleccionados');

        var btnGo   = document.getElementById('btnGoSecondary');
        var btnBack = document.getElementById('btnBackPrimary');
        if (btnGo)   btnGo.addEventListener('click',   function() { setActiveView('secondary'); });
        if (btnBack) btnBack.addEventListener('click',  function() { setActiveView('primary'); });

        var savedView = sessionStorage.getItem('pesoLoteView') || 'primary';
        setActiveView(savedView);

        /* overlay en submit */
        var form1 = document.getElementById('frmBuscar');
        var btn1  = document.getElementById('btnBuscar');
        if (form1) form1.addEventListener('submit', function() {
            showOverlay("Cargando resultados...", "Aplicando filtros y consultando datos");
            if (btn1) { btn1.disabled = true; btn1.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Buscando...'; }
        });

        var form2 = document.getElementById('frmBuscarVista2');
        var btn2  = document.getElementById('btnBuscarV2');
        if (form2) form2.addEventListener('submit', function() {
            showOverlay("Cargando segunda vista...", "Aplicando filtros y consultando datos");
            if (btn2) { btn2.disabled = true; btn2.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Buscando...'; }
            sessionStorage.setItem('pesoLoteView','secondary');
        });
    });
</script>
