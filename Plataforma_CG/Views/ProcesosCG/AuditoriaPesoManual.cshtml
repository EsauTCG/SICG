                        </div>

                    </div><!-- /VISTA 2 -->

                </div><!-- /views-track -->
            </div><!-- /views-viewport -->

        </div><!-- /workspace -->
    </div><!-- /content -->

    <div class="statusbar">
        <div>Registro listo</div>
        <div>Usuario: @User.Identity.Name</div>
        <div>Empresa: Carnes G SA de CV</div>
        <div>Módulo: Peso Lote</div>
