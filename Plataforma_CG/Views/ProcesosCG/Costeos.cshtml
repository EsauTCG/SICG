                <div id="resultadoComparativa">

                    <div id="resumenComparativa">
                            
                    </div>

                    
                    <div id="tablaComparativa" class="table-wrap mb-3">
                       
                        <table id="tblComparativa"
                                class="tbl-comparativa">

                            <thead id="theadComparativa">

                                 
                            </thead>


