<script>
    function showLog(type, text) {
        const box = document.getElementById('logBox');
        const log = document.getElementById('log');
        if (!box || !log) return;

        box.style.display = 'block';
        log.className = 'log-inner log-' + (type || 'secondary');
        log.textContent = text || '';
    }

    function getPayload() {
        const modo = (document.getElementById('Modo')?.value || 'DIA').toUpperCase();

        return {
            Source: document.getElementById('Source')?.value || 'P1',
            TipoProceso: document.getElementById('TipoProceso')?.value || 'CAJAS',
            Modo: modo,
            FechaInicial: document.getElementById('FechaInicial')?.value || null,
            FechaFinal: (modo === 'DIA'
                ? (document.getElementById('FechaInicial')?.value || null)
                : (document.getElementById('FechaFinal')?.value || null)),
            TipoCosteoId: parseInt(document.getElementById('TipoCosteoId')?.value || '1'),
            LoteId: (modo === 'LOTE' && document.getElementById('LoteId')?.value)
                ? parseInt(document.getElementById('LoteId').value)
                : null,
            BrincarSinCosto: document.getElementById('BrincarSinCosto')?.checked === true,
            ContinuarConError: document.getElementById('ContinuarConError')?.checked === true,
            Automatico: document.getElementById('Automatico')?.checked === true,
            HoraProgramada: document.getElementById('HoraProgramada')?.value || '18:00'
        };
    }

    function getHistoricoPayload() {
        return {
            source: document.getElementById('HistSource')?.value || 'ALL',
            tipoProceso: document.getElementById('HistTipoProceso')?.value || 'AMBOS',
            fechaDesde: document.getElementById('HistFechaDesde')?.value || null,
            fechaHasta: document.getElementById('HistFechaHasta')?.value || null,
            soloErrores: document.getElementById('HistSoloErrores')?.checked === true,
            soloAutomatico: document.getElementById('HistSoloAutomatico')?.checked === true
        };
    }

    function syncModeUI() {
        const panel = document.getElementById('filterPanel');
        if (!panel) return;

        const modo = (document.getElementById('Modo')?.value || 'DIA').toUpperCase();

        panel.classList.remove('mode-dia', 'mode-rango', 'mode-lote');

        if (modo === 'RANGO') panel.classList.add('mode-rango');
        else if (modo === 'LOTE') panel.classList.add('mode-lote');
        else panel.classList.add('mode-dia');
    }

    async function loadAutoStatus() {
    try {
        const res = await fetch('@Url.Action("CosteoAutoStatus", "ProcesosCG")', {
            credentials: 'same-origin'
        });

        const data = await res.json();
        if (!res.ok || !data?.ok || !Array.isArray(data.rows)) return;

        const source = (document.getElementById('Source')?.value || 'P1').toUpperCase();
        const tipoProceso = (document.getElementById('TipoProceso')?.value || 'CAJAS').toUpperCase();

        const rows = data.rows.filter(x =>
            (x.source || '').toUpperCase() === source &&
            (x.tipoProceso || '').toUpperCase() === (tipoProceso === 'AMBOS' ? 'CAJAS' : tipoProceso)
        );

        if (!rows.length) return;

        const row = rows[0];

        document.getElementById('HoraProgramada').value = row.horaProgramada || '18:00';
        document.getElementById('Automatico').checked = row.activo === true;
        document.getElementById('BrincarSinCosto').checked = row.brincarSinCosto === true;
        document.getElementById('ContinuarConError').checked = row.continuarConError === true;
    } catch (e) {
        console.warn('CosteoAutoStatus error:', e);
    }
}

  async function guardarAuto(silent = false) {
    const payload = getPayload();

    try {
        if (!silent) showLog('info', 'Guardando configuración automática...');

        const procesos = payload.TipoProceso === 'AMBOS'
            ? ['CAJAS', 'RETRABAJO']
            : [payload.TipoProceso];

        for (const proc of procesos) {
            const form = new URLSearchParams();
            form.append('source', payload.Source);
            form.append('tipoProceso', proc);
            form.append('tipoCosteoId', payload.TipoCosteoId);
            form.append('horaProgramada', payload.HoraProgramada || '18:00');
            form.append('brincarSinCosto', payload.BrincarSinCosto);
            form.append('continuarConError', payload.ContinuarConError);
            form.append('activo', document.getElementById('Automatico')?.checked === true);

            const res = await fetch('@Url.Action("CosteoAutoSet", "ProcesosCG")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                credentials: 'same-origin',
                body: form.toString()
            });

            const data = await res.json();

            if (!res.ok || !data?.ok) {
                showLog('danger', data?.msg || `No se pudo guardar la configuración para ${proc}.`);
                return;
            }
        }

        if (!silent) showLog('success', 'Configuración guardada.');
        await loadAutoStatus();
    } catch (e) {
        showLog('danger', 'Error de red: ' + (e?.message || e));
    }
}

    async function recargarBitacora() {
    try {
        const h = getHistoricoPayload();
        const qs = new URLSearchParams();
        qs.append('top', '300');

        if (h.source && h.source !== 'ALL') qs.append('source', h.source);
        if (h.tipoProceso && h.tipoProceso !== 'AMBOS') qs.append('tipoProceso', h.tipoProceso);
        if (h.fechaDesde) qs.append('fechaDesde', h.fechaDesde);
        if (h.fechaHasta) qs.append('fechaHasta', h.fechaHasta);
        if (h.soloErrores) qs.append('soloErrores', 'true');
        if (h.soloAutomatico) qs.append('soloAutomatico', 'true');

        const res = await fetch('@Url.Action("CosteoBitacora", "ProcesosCG")?' + qs.toString(), {
            credentials: 'same-origin'
        });

        const data = await res.json();
        if (!res.ok || !data?.ok) {
            showLog('danger', data?.msg || 'No se pudo consultar la bitácora.');
            return;
        }

        const tbody = document.getElementById('tbodyBitacora');
        if (!tbody) return;

        const rows = data.rows || [];

        if (!rows.length) {
            tbody.innerHTML = '<tr><td colspan="15" class="text-center text-muted">Sin resultados.</td></tr>';
            return;
        }

        tbody.innerHTML = rows.map(x => {
            const icon = x.Ok ? '✅' : '❌';
            const sinCosto = x.BrincarSinCosto ? 'Sí' : 'No';
            const continuar = x.ContinuarConError ? 'Sí' : 'No';
            const auto = x.EsAutomatico ? 'Sí' : 'No';

            const mensajeCombo = [
                x.Mensaje || '',
                x.Parametros || ''
            ].filter(Boolean).join(' | ');

            return `
                <tr>
                    <td class="text-center">${x.Id ?? ''}</td>
                    <td title="${x.FechaEjecucion ?? ''}">${formatDateTime(x.FechaEjecucion)}</td>
                    <td>${safe(x.Source)}</td>
                    <td>${safe(x.TipoProceso)}</td>
                    <td title="${safeAttr(x.SpEjecutado)}">${safe(x.SpEjecutado)}</td>
                    <td>${formatDate(x.FechaInicial)}</td>
                    <td>${formatDate(x.FechaFinal)}</td>
                    <td class="text-center">${x.LoteId ?? '-'}</td>
                    <td class="text-center">${sinCosto}</td>
                    <td class="text-center">${continuar}</td>
                    <td class="text-center"><span class="sap-est">${icon}</span></td>
                    <td class="text-center">${auto}</td>
                    <td>${safe(x.Usuario)}</td>
                    <td>${safe(x.HoraProgramada)}</td>
                    <td title="${safeAttr(mensajeCombo)}">${safe(mensajeCombo)}</td>
                </tr>
            `;
        }).join('');
    } catch (e) {
        showLog('danger', 'Error al actualizar bitácora: ' + (e?.message || e));
    }
}

    async function ejecutarCosteo() {
        const payload = getPayload();

        if (!payload.FechaInicial) {
            showLog('warning', 'Captura fecha inicial.');
            return;
        }

        if (payload.Modo === 'RANGO' && !payload.FechaFinal) {
            showLog('warning', 'Captura fecha final.');
            return;
        }

        if (payload.Modo === 'LOTE' && !payload.LoteId) {
            showLog('warning', 'Captura el lote.');
            return;
        }

        try {
            showLog('info', 'Ejecutando costeo...');

            const res = await fetch('@Url.Action("EjecutarCosteo", "ProcesosCG")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify(payload)
            });

            const data = await res.json();

            if (res.ok && data?.ok) {
                showLog('success', 'Proceso terminado correctamente.');
                await recargarBitacora();

                const modalEl = document.getElementById('modalHistorico');
                if (modalEl && window.bootstrap) {
                    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                    modal.show();
                }
            } else {
                showLog('danger', data?.msg || 'No se pudo ejecutar el costeo.');
            }
        } catch (e) {
            showLog('danger', 'Error de red: ' + (e?.message || e));
        }
    }

    function safe(v) {
        if (v === null || v === undefined || v === '') return '-';
        return String(v)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function safeAttr(v) {
        return safe(v ?? '');
    }

    function formatDate(v) {
        if (!v) return '-';
        const d = new Date(v);
        if (isNaN(d.getTime())) return v;
        return d.toISOString().slice(0, 10);
    }

    function formatDateTime(v) {
        if (!v) return '-';
        const d = new Date(v);
        if (isNaN(d.getTime())) return v;

        const dd = String(d.getDate()).padStart(2, '0');
        const mm = String(d.getMonth() + 1).padStart(2, '0');
        const yyyy = d.getFullYear();
        const hh = String(d.getHours()).padStart(2, '0');
        const mi = String(d.getMinutes()).padStart(2, '0');
        const ss = String(d.getSeconds()).padStart(2, '0');

        return `${dd}/${mm}/${yyyy} ${hh}:${mi}:${ss}`;
    }

    document.getElementById('Modo')?.addEventListener('change', syncModeUI);
    document.getElementById('Source')?.addEventListener('change', loadAutoStatus);
    document.getElementById('TipoProceso')?.addEventListener('change', loadAutoStatus);
    document.getElementById('HoraProgramada')?.addEventListener('change', () => guardarAuto(true));
    document.getElementById('BrincarSinCosto')?.addEventListener('change', () => guardarAuto(true));
    document.getElementById('ContinuarConError')?.addEventListener('change', () => guardarAuto(true));
    document.getElementById('Automatico')?.addEventListener('change', () => guardarAuto());

    syncModeUI();
    loadAutoStatus();

    //SCRIPT para Comparativa-costeo

    //Control del render Activo
    let TokenActivo = 0;

    function cancelarRenderActivo(){
        TokenActivo++;

            document.getElementById("tbodyComparativaCosteo").innerHTML = "";

    }

    function limpiarComparativa(){
        cancelarRenderActivo();

        ocultarLoading();

        document.getElementById("theadComparativa").innerHTML = "";
        document.getElementById("tbodyComparativaCosteo").innerHTML = "";
        document.getElementById("resumenComparativa").innerHTML = "";

        desbloquearConsulta();
    }

    function mostrarLoading(titulo, mensaje){
        document.getElementById("resultadoComparativa").classList.add("d-none");
        document.getElementById("loadingComparativa").classList.remove("d-none");

        document.getElementById("loadingTitulo").textContent = titulo;
        document.getElementById("loadingMensaje").textContent = mensaje;

        const barra = document.getElementById("loadingBarra");
        barra.style.width = "0%";
        barra.textContent = "0%";
    }

    function actualizarLoading(titulo, mensaje, porcentaje){
        document.getElementById("loadingTitulo").textContent = titulo;
        document.getElementById("loadingMensaje").textContent = mensaje;

        const barra = document.getElementById("loadingBarra");
        barra.style.width = `${porcentaje}%`;
        barra.textContent = `${porcentaje}%`;

    }

    function ocultarLoading() {
        document.getElementById("loadingComparativa").classList.add("d-none");
        document.getElementById("resultadoComparativa").classList.remove("d-none");
    }

    function bloquearConsulta(){
        const btn = document.getElementById("btnConsultarComparativa");

        btn.disabled = true;
        btn.style.backgroundColor = "red";
        btn.style.opacity = "0.5";
    }

    function desbloquearConsulta() {
        const btn = document.getElementById("btnConsultarComparativa");

        btn.disabled = false;
        btn.style.backgroundColor = "";
        btn.style.opacity = "";
    }

    async function consultarComparativa() {

        cancelarRenderActivo();

        document.getElementById("theadComparativa").innerHTML = "";
        document.getElementById("tbodyComparativaCosteo").innerHTML = "";

        const consultaActual = TokenActivo;

        mostrarLoading(
            "Consultando información...",
            "Obteniendo registros...");

        bloquearConsulta();
      

       

        try {

            const filtro = {
                tipoPeriodo: document.getElementById("cmpPeriodo").value,
                fechaBase: document.getElementById("cmpFecha").value,
                tolerancia: parseFloat(document.getElementById("cmpTolerancia").value),
                estadoCosto: document.getElementById("cmpEstado").value
             };

            

        

            const response = await fetch("/ProcesosCG/ConsultarComparativaCosteo", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(filtro)
            });

            

        
          
            const resultado = await response.json();

         

    

            if (!resultado.ok){
                alert(resultado.mensaje);
                return;
            }
            const datos = resultado.datos;

            actualizarLoading(
                "Renderizando resultados...",
                "Procesando Registros...",
                0
            );

          

            renderResumen(datos);

            

            renderEncabezado(datos);

            

            await renderFilas(datos);

            if (consultaActual === TokenActivo){

                ocultarLoading();

                

            }

            

        }
        finally {

            if (consultaActual !== TokenActivo) {
                return;
              }

            desbloquearConsulta();
            
            
        }

    }

    
    function renderEncabezado(datos) {

       
        
        const thead = document.getElementById("theadComparativa");

        thead.innerHTML = "";

        if (!datos || datos.length === 0)
            return;
        
        const columnas = Object.keys(datos[0]);

        let html = "<tr>";

        for (const columna of columnas) {
            html += `<th class="${obtenerClaseColumna(columna)}">${columna}</th>`;
        }

        html += "</tr>";

        thead.innerHTML = html;

        
    }


    function renderFilas(datos) {

        return new Promise(resolve => {
                const tbody = document.getElementById("tbodyComparativaCosteo");

            const tokenActual = TokenActivo;

        
            if (!datos || datos.length === 0){

                resolve();

                return;
            }

            

            
            const columnas = Object.keys(datos[0]);

            const TAMANO_LOTE = 500;

            let indice = 0;


            function renderLote(){

                if(tokenActual !== TokenActivo){
                   

                    resolve();

                    return;
                }



                const fin = Math.min(indice + TAMANO_LOTE, datos.length);

                let html = "";

                for (; indice < fin; indice++){
                    const fila = datos[indice];

                    html += "<tr>";

                    columnas.forEach(columna => {
                        html += `
                            <td class="${obtenerClaseColumna(columna)}">
                                ${formatearCelda(columna, fila[columna])}
                            </td>
                        `;
                    });

                    html += "</tr>";
                }


                if (tokenActual !== TokenActivo){
                    

                    resolve();

                    return;
                }

                //Agrega el bloque al final sin reconstruir toda la tabla

                tbody.insertAdjacentHTML("beforeend", html);

                const porcentaje = Math.round((indice / datos.length) * 100);

                actualizarLoading(
                    "Renderizando resultados...",
                    `Procesando ${indice.toLocaleString("es-MX")} de ${datos.length.toLocaleString("es-MX")} registros...`,
                    porcentaje
                );

                if (indice < datos.length){
                    requestAnimationFrame(renderLote);


                } else {
                   

                    resolve();
                }
            }

            requestAnimationFrame(renderLote);

       
        
        });
    }




    function formatearCelda(columna, valor){

        if (columna === "estadoCosto" || columna === "EstadoCosto"){
            switch (valor) {
                 case "100% MISMO COSTO":
            return `<span class="badge bg-success">${valor}</span>`;

        case "COSTO DIFERENTE":
            return `<span class="badge bg-danger">${valor}</span>`;

        case "SIN COSTO EN TIF":
            return `<span class="badge bg-warning text-dark">${valor}</span>`;

        case "SIN COSTO EN P1":
            return `<span class="badge text-white"
                        style="background:#fd7e14;">
                        ${valor}
                    </span>`;

        case "SIN COSTO EN TIF Y P1":
            return `<span class="badge bg-secondary">${valor}</span>`;
            }
        }

        if (typeof valor === "string" && valor.includes("T")){
            const fecha = new Date(valor);

            if (!isNaN(fecha)) {
                return fecha.toLocaleDateString("es-MX");
            }
        }

        return valor;
    }

    function obtenerClaseColumna(nombre){

        if(nombre.includes("Producto"))
            return "col-producto";

        if(nombre.includes("Costo"))
            return "col-costo";

        if(nombre.includes("Peso"))
            return "col-peso";

        if(nombre.includes("Estado"))
            return "col-estado";

        if(nombre.includes("Id"))
            return "col-id";

        return "";
    }

    function renderResumen(datos) {
        
        const contenedor = document.getElementById("resumenComparativa")

        contenedor.innerHTML = "";

        if (!datos || datos.length === 0)
            return;

        const primerRegistro = datos[0];

        contenedor.innerHTML = `
            <div class="comparativa-resumen">

            <span>
                <strong>Registros:</strong>
                ${datos.length.toLocaleString("es-MX")}
            </span>

        </div>
            `
    }

        const modalComparativa = document.getElementById("modalComparativa");

        modalComparativa.addEventListener("hidden.bs.modal", () => {
            limpiarComparativa();
        })
   
</script>