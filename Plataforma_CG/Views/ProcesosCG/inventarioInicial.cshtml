@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Planeación Ejecutiva de Inventario";
}

<style>
    :root {
        --vino-900: #4b0000;
        --vino-800: #650000;
        --vino-700: #7f0000;
        --vino-600: #9b0000;
        --vino-500: #b40000;
        --bg: #f4e1e1;
        --panel: #fffafa;
        --line: #d7b7b7;
        --text: #351313;
        --muted: #765050;
        --green: #047857;
        --orange: #b45309;
        --red: #dc2626;
        --blue-bg: #e8f3ff;
        --green-bg: #e9f8ec;
        --orange-bg: #fff1e6;
        --gray-bg: #f3f4f6;
        --red-bg: #fee2e2;
        --shadow: 0 18px 36px rgba(70, 12, 12, .16);
        --inner: inset 0 1px 0 rgba(255,255,255,.55);
    }

    * {
        box-sizing: border-box;
    }

    html,
    body {
        width: 100%;
        min-width: 0;
        overflow-x: hidden;
    }

    body,
    main,
    .main,
    .body-content,
    .container,
    .container-fluid,
    .container-sm,
    .container-md,
    .container-lg,
    .container-xl,
    .container-xxl,
    .pb-3 {
        background: transparent !important;
        box-shadow: none !important;
        border: none !important;
    }

    body {
        font-family: Tahoma, Verdana, Arial, sans-serif;
        color: var(--text);
    }

    .app {
        width: calc(100vw - 48px);
        max-width: none;
        min-height: calc(100dvh - 20px);
        margin-left: 50% !important;
        margin-right: 0 !important;
        margin-top: 0 !important;
        margin-bottom: 18px !important;
        transform: translateX(-50%);
        padding: clamp(8px, 1vw, 14px);
        display: flex;
        flex-direction: column;
        gap: 12px;
        overflow-x: hidden;
        background:
            radial-gradient(circle at top left, rgba(139, 0, 0, .16), transparent 34%),
            linear-gradient(135deg, #f8eeee 0%, #f3dddd 45%, #ead0d0 100%);
    }

    .hero {
        width: 100%;
        border-radius: 18px;
        padding: clamp(14px, 1.5vw, 20px);
        color: #fff;
        background:
            linear-gradient(135deg, rgba(75,0,0,.99), rgba(139,0,0,.96)),
            linear-gradient(#fff, #fff);
        border: 1px solid rgba(92,0,0,.55);
        box-shadow: var(--shadow);
        display: grid;
        grid-template-columns: minmax(300px, 1fr) auto;
        gap: 16px;
        align-items: start;
    }

    .title-block h1 {
        margin: 0;
        font-size: clamp(19px, 1.55vw, 28px);
        line-height: 1.12;
        letter-spacing: -.03em;
        font-weight: 900;
    }

    .title-block p {
        margin: 7px 0 0;
        max-width: 850px;
        color: rgba(255,255,255,.78);
        font-size: clamp(11px, .85vw, 13px);
        line-height: 1.4;
    }

    .status-chip {
        align-self: start;
        min-width: 190px;
        padding: 10px 12px;
        border-radius: 14px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.22);
        text-align: right;
    }

    .status-chip span {
        display: block;
        color: rgba(255,255,255,.72);
        font-size: 10px;
        text-transform: uppercase;
        font-weight: 800;
        letter-spacing: .06em;
    }

    .status-chip strong {
        display: block;
        margin-top: 3px;
        font-size: 14px;
        font-weight: 900;
        color: #fff;
    }

    .filtros-ejecutivos {
        grid-column: 1 / -1;
        width: 100%;
        display: grid;
        grid-template-columns: minmax(220px, 1.25fr) minmax(300px, 1.8fr) 150px 150px auto;
        gap: 10px;
        margin-top: 4px;
        align-items: end;
    }

    .filtro-card {
        min-width: 0;
    }

    .filtro-card > label {
        display: block;
        margin-bottom: 5px;
        font-size: 10.5px;
        font-weight: 900;
        text-transform: uppercase;
        color: rgba(255,255,255,.82);
        letter-spacing: .05em;
    }

    .filtro-card.fechas input {
        width: 100% !important;
        height: 39px !important;
        border-radius: 12px !important;
        border: 1px solid rgba(255,255,255,.28) !important;
        background: rgba(255,255,255,.96) !important;
        color: #4a1111 !important;
        font-weight: 900;
        font-size: 12px !important;
        padding: 0 10px !important;
        box-shadow: 0 8px 16px rgba(0,0,0,.14) !important;
    }

    .multi-select {
        position: relative;
        width: 100%;
    }

    .multi-trigger {
        width: 100%;
        height: 39px !important;
        border-radius: 12px !important;
        border: 1px solid rgba(255,255,255,.28) !important;
        background: rgba(255,255,255,.96) !important;
        color: #4a1111 !important;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        padding: 0 12px !important;
        font-size: 12px !important;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 8px 16px rgba(0,0,0,.14) !important;
    }

    .multi-trigger span {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .multi-panel {
        display: none;
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        width: min(430px, 92vw);
        max-height: 390px;
        overflow: hidden;
        background: #fff;
        border: 1px solid #c99;
        border-radius: 16px;
        box-shadow: 0 26px 56px rgba(65, 0, 0, .30);
        z-index: 9999;
    }

    .multi-select.open .multi-panel {
        display: block;
    }

    .multi-search {
        padding: 10px;
        border-bottom: 1px solid #ead0d0;
        background: #fff7f7;
    }

    .multi-search input {
        width: 100% !important;
        height: 34px !important;
        border-radius: 9px !important;
        border: 1px solid #d7b7b7 !important;
        text-align: left !important;
        padding: 0 10px !important;
        font-weight: 800;
        color: var(--text) !important;
        background: #fff !important;
    }

    .multi-options {
        max-height: 278px;
        overflow: auto;
        padding: 6px;
        scrollbar-width: thin;
    }

    .multi-option {
        display: flex !important;
        align-items: center;
        gap: 8px;
        min-height: 34px;
        padding: 7px 9px;
        border-radius: 9px;
        color: var(--text) !important;
        font-size: 12px;
        font-weight: 800;
        cursor: pointer;
        user-select: none;
    }

    .multi-option:hover {
        background: #f8e7e7;
    }

    .multi-option input {
        appearance: auto !important;
        width: 15px !important;
        height: 15px !important;
        min-width: 15px !important;
        accent-color: var(--vino-700);
        margin: 0 !important;
    }

    .multi-option small {
        color: var(--muted);
        font-size: 11px;
        font-weight: 800;
    }

    .multi-all {
        border-bottom: 1px solid #ead0d0;
        border-radius: 0;
        padding: 10px 14px;
        background: #fff;
        color: var(--vino-800) !important;
    }

    .actions {
        display: flex;
        gap: 7px;
        justify-content: flex-end;
        flex-wrap: nowrap;
    }

    .btn {
        height: 39px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.28);
        padding: 0 14px;
        font-size: 12px;
        font-weight: 900;
        cursor: pointer;
        white-space: nowrap;
        box-shadow: 0 8px 16px rgba(0,0,0,.14);
    }

    .btn-primary {
        background: linear-gradient(180deg, #fff 0%, #ead0d0 100%);
        color: #4a1111;
    }

    .btn-dark {
        background: rgba(255,255,255,.13);
        color: #fff;
    }

    .view-options {
        width: 100%;
        display: flex;
        gap: 7px;
        flex-wrap: wrap;
        align-items: center;
    }

    .radio-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        min-height: 29px;
        padding: 5px 10px;
        border: 1px solid #d8bcbc;
        border-radius: 999px;
        background: #fffafa;
        color: #4d1818;
        font-size: 12px;
        font-weight: 900;
        cursor: pointer;
        user-select: none;
        box-shadow: var(--inner);
    }

    .radio-pill input[type="radio"] {
        appearance: auto;
        width: 14px !important;
        height: 14px !important;
        margin: 0 !important;
        accent-color: var(--vino-700);
    }

    .radio-pill:has(input[type="radio"]:checked) {
        background: linear-gradient(180deg, #b40000 0%, #8f0000 55%, #6e0000 100%);
        color: #fff;
        border-color: #7f0a0a;
    }

    .cards {
        width: 100%;
        display: grid;
        grid-template-columns: repeat(5, minmax(150px, 1fr));
        gap: 10px;
    }

    .card {
        min-width: 0;
        background: rgba(255,250,250,.96);
        border: 1px solid #d8bcbc;
        border-radius: 16px;
        padding: clamp(11px, 1vw, 15px);
        box-shadow: 0 10px 24px rgba(70,12,12,.10), var(--inner);
    }

    .card span {
        display: block;
        font-size: 10.5px;
        color: var(--vino-700);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 7px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .card strong {
        display: block;
        font-size: clamp(19px, 1.8vw, 27px);
        color: #3b1111;
        line-height: 1.02;
        font-weight: 900;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .card em {
        display: block;
        margin-top: 5px;
        font-size: 11px;
        color: var(--muted);
        font-style: normal;
        font-weight: 800;
    }

    .panel {
        width: 100%;
        background: #fffafa;
        border: 1px solid #d8bcbc;
        border-radius: 16px;
        box-shadow: 0 10px 24px rgba(70,12,12,.10), var(--inner);
        overflow: hidden;
    }

    .panel-title {
        min-height: 39px;
        padding: 10px 13px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
    }

    .panel-title strong {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .panel-title span {
        font-size: 11px;
        color: rgba(255,255,255,.78);
        font-weight: 800;
    }

    .table-wrapper {
        width: 100%;
        flex: 1 1 auto;
        min-height: 260px;
        max-height: min(48dvh, 560px);
        overflow: auto;
        scrollbar-width: thin;
        padding: 8px;
    }

    table {
        border-collapse: separate !important;
        border-spacing: 0 !important;
        width: max-content;
        min-width: 100%;
        font-size: 12px;
        background: #fffafa;
    }

    th,
    td {
        border-right: 1px solid #d8bcbc;
        border-bottom: 1px solid #d8bcbc;
        padding: 7px 6px;
        text-align: center;
        min-width: clamp(92px, 7vw, 122px);
        white-space: nowrap;
        font-size: clamp(11px, .84vw, 12px);
        line-height: 1.2;
    }

    th {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        color: #fff !important;
        position: sticky;
        top: 0;
        z-index: 3;
        border-top: 1px solid #c46a6a;
        border-right: 1px solid #8e3b3b;
        border-bottom: 1px solid #5c0000;
        box-shadow: 0 2px 0 #6f1d1d;
        font-weight: 900;
    }

    th:first-child,
    td:first-child {
        border-left: 1px solid #d8bcbc;
    }

    .sticky-alcance {
        position: sticky;
        left: 0;
        z-index: 2;
        background: #fffafa;
        font-weight: 900;
        min-width: 142px;
        width: 142px;
        max-width: 142px;
        text-align: left;
        color: #4a1111;
    }

    .sticky-concepto {
        position: sticky;
        left: 142px;
        z-index: 2;
        background: #fffafa;
        font-weight: 900;
        min-width: 150px;
        width: 150px;
        max-width: 150px;
        text-align: left;
        color: #4a1111;
    }

    th.sticky-alcance,
    th.sticky-concepto {
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        color: #fff !important;
        z-index: 4;
    }

    .row-inventario .sticky-alcance,
    .row-inventario .sticky-concepto,
    .row-inventario td {
        background: var(--blue-bg);
    }

    .row-produccion .sticky-alcance,
    .row-produccion .sticky-concepto,
    .row-produccion td {
        background: var(--green-bg);
    }

    .row-pedidos .sticky-alcance,
    .row-pedidos .sticky-concepto,
    .row-pedidos td {
        background: var(--orange-bg);
    }

    .row-disponible .sticky-alcance,
    .row-disponible .sticky-concepto,
    .row-disponible td {
        background: var(--gray-bg);
        font-weight: 900;
    }

    tbody tr:hover td,
    tbody tr:hover .sticky-alcance,
    tbody tr:hover .sticky-concepto {
        filter: brightness(.985);
    }

    .disponible-ok {
        color: var(--green);
        font-weight: 900;
    }

    .disponible-alerta {
        color: var(--orange);
        font-weight: 900;
    }

    .disponible-negativo,
    .valor-negativo {
        color: var(--red) !important;
        font-weight: 900 !important;
        background: var(--red-bg) !important;
    }

    .legend {
        padding: 9px 12px 12px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        font-size: 12px;
        color: #4a1a1a;
    }

    .legend-item {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        min-height: 28px;
        padding: 3px 8px;
        border: 1px solid transparent;
        border-radius: 999px;
        cursor: pointer;
        user-select: none;
        font-weight: 800;
    }

    .legend-item:hover {
        border-color: #d8bcbc;
        background: #fffafa;
    }

    .legend-item.inactivo {
        opacity: .45;
        filter: grayscale(.35);
    }

    .legend-item input[type="checkbox"] {
        appearance: auto;
        width: 14px !important;
        height: 14px !important;
        margin: 0 !important;
        accent-color: var(--vino-700);
    }

    .dot {
        width: 13px;
        height: 13px;
        border-radius: 50%;
        display: inline-block;
        border: 1px solid #d8bcbc;
    }

    .dot-blue { background: var(--blue-bg); }
    .dot-green { background: var(--green-bg); }
    .dot-orange { background: var(--orange-bg); }
    .dot-gray { background: var(--gray-bg); }

    .chart-box {
        min-height: 230px;
    }

    .bars {
        display: flex;
        align-items: flex-end;
        gap: 8px;
        height: clamp(150px, 23dvh, 230px);
        overflow-x: auto;
        overflow-y: hidden;
        padding: 16px 12px 24px;
        border-bottom: 1px solid #d8bcbc;
        background: #fffafa;
        scrollbar-width: thin;
    }

    .bar-item {
        min-width: clamp(52px, 4.8vw, 70px);
        text-align: center;
        font-size: 11px;
        color: #4a1111;
    }

    .bar-stack {
        display: flex;
        justify-content: center;
        align-items: flex-end;
        gap: 3px;
        min-height: 4px;
        margin-bottom: 6px;
    }

    .bar {
        width: clamp(8px, 1vw, 14px);
        min-height: 4px;
        border-radius: 8px 8px 0 0;
        transition: .2s;
    }

    .bar.negative { background: #dc2626; }
    .bar.inventario { background: #2563eb; }
    .bar.produccion { background: #059669; }
    .bar.pedidos { background: #ea580c; }
    .bar.disponible { background: #6b7280; }

    .bar-label {
        transform: rotate(-42deg);
        white-space: nowrap;
        margin-top: 13px;
        color: #6a3a3a;
        transform-origin: center;
        font-size: 10px;
        font-weight: 800;
    }

    .sin-datos {
        width: 100%;
        align-self: center;
        text-align: center;
        color: #6a3a3a;
        font-size: 13px;
        font-weight: 900;
        padding: 24px;
    }

    .loading {
        opacity: .55;
        pointer-events: none;
    }

    .app[data-modo-vista="tabla"] .chart-box {
        display: none;
    }

    .app[data-modo-vista="grafica"] .table-panel {
        display: none;
    }

    .app[data-modo-vista="grafica"] .chart-box {
        min-height: 55dvh;
    }

    .app[data-modo-vista="grafica"] .bars {
        height: 46dvh;
    }

    @@media (max-width: 1240px) {
        .hero {
            grid-template-columns: 1fr;
        }

        .status-chip {
            text-align: left;
        }

        .filtros-ejecutivos {
            grid-template-columns: repeat(2, minmax(220px, 1fr));
        }

        .actions {
            justify-content: flex-start;
        }

        .cards {
            grid-template-columns: repeat(3, minmax(150px, 1fr));
        }
    }

    @@media (max-width: 760px) {
        .app {
            width: 100% !important;
            margin: 0 !important;
            transform: none !important;
            padding: 8px;
        }

        .filtros-ejecutivos {
            grid-template-columns: 1fr;
        }

        .cards {
            grid-template-columns: 1fr;
        }

        .multi-panel {
            position: fixed;
            left: 12px;
            right: 12px;
            top: 110px;
            width: auto;
        }

        .sticky-alcance {
            min-width: 112px;
            width: 112px;
            max-width: 112px;
        }

        .sticky-concepto {
            left: 112px;
            min-width: 126px;
            width: 126px;
            max-width: 126px;
        }

        th,
        td {
            min-width: 82px;
            padding: 6px 5px;
        }
    }

    .multi-options .multi-option.opcion-oculta {
    display: none !important;
}

    /* =========================================================
       KPIS EJECUTIVOS CON COLOR OPERATIVO
       ========================================================= */

    .kpi-dashboard {
        align-items: stretch;
    }

    .card.kpi-card-color {
        position: relative;
        overflow: hidden;
        min-height: 122px;
        border: 1px solid rgba(255,255,255,.28) !important;
        box-shadow: 0 16px 30px rgba(54, 9, 9, .16), inset 0 1px 0 rgba(255,255,255,.18) !important;
    }

    .card.kpi-card-color::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,.16) 0%, rgba(255,255,255,0) 55%);
        pointer-events: none;
    }

    .card.kpi-card-color::after {
        content: "";
        position: absolute;
        right: -42px;
        bottom: -52px;
        width: 142px;
        height: 142px;
        border-radius: 999px;
        background: rgba(255,255,255,.13);
        border: 22px solid rgba(255,255,255,.08);
        pointer-events: none;
    }

    .card.kpi-card-color span,
    .card.kpi-card-color strong,
    .card.kpi-card-color em {
        position: relative;
        z-index: 1;
    }

    .card.kpi-card-color span {
        color: rgba(255,255,255,.88) !important;
        letter-spacing: .07em;
    }

    .card.kpi-card-color strong {
        color: #ffffff !important;
        text-shadow: 0 2px 10px rgba(0,0,0,.24);
    }

    .card.kpi-card-color em {
        color: rgba(255,255,255,.86) !important;
        font-weight: 800;
    }

    .card.kpi-alcance {
        background: linear-gradient(135deg, #4b0000 0%, #7f0000 54%, #340303 100%) !important;
    }

    .card.kpi-disponible {
        background: linear-gradient(135deg, #047857 0%, #10a36a 54%, #064e3b 100%) !important;
    }

    .card.kpi-produccion {
        background: linear-gradient(135deg, #0f4f74 0%, #1879a8 54%, #083449 100%) !important;
    }

    .card.kpi-pedidos {
        background: linear-gradient(135deg, #b45309 0%, #e07b18 54%, #7c2d12 100%) !important;
    }

    .card.kpi-faltante {
        background: linear-gradient(135deg, #374151 0%, #4b5563 54%, #111827 100%) !important;
    }

    .card.kpi-faltante.kpi-alerta-activa,
    .card.kpi-disponible.kpi-negativo {
        background: linear-gradient(135deg, #991b1b 0%, #dc2626 55%, #5f0f0f 100%) !important;
    }

    .card.kpi-disponible.kpi-alerta {
        background: linear-gradient(135deg, #a16207 0%, #d97706 55%, #713f12 100%) !important;
    }

    @@media (min-width: 1500px) {
        .card.kpi-card-color {
            min-height: 138px;
        }

        .card.kpi-card-color strong {
            font-size: clamp(24px, 2vw, 32px);
        }
    }

    @@media (max-width: 760px) {
        .card.kpi-card-color {
            min-height: 112px;
        }

        .card.kpi-card-color strong {
            white-space: normal;
        }
    }

</style>

<div class="app" id="app" data-modo-vista="completa">

    <section class="hero">
        <div class="title-block">
            <h1>Planeación Ejecutiva de Inventario, Producción y Pedidos</h1>
            <p>
                Vista consolidada para Dirección General: inventario inicial del día actual, producción planeada,
                pedidos comprometidos y disponibilidad proyectada por día. El disponible de un día
                se convierte automáticamente en el inventario del siguiente.
            </p>
        </div>

        <div class="status-chip">
            <span>Última consulta</span>
            <strong id="ultimaConsulta">Sin cargar</strong>
        </div>

