</div>

<script>
    let datos = [];
    let modoVista = "completa";
    const DIAS_ADELANTE = 23;
    const SOLO_SKU_CON_INVENTARIO_O_PRODUCCION = true;
    let catalogoDepuradoPorMovimiento = false;


    let filtrosCatalogo = {
        masters: [],
        skus: []
    };

    let seleccion = {
        masters: [],
        skus: []
    };

    let filtrosMetricas = {
        inventario: true,
        produccion: true,
        pedidos: true,
        disponible: true
    };

    const metricasGrafica = [
        { key: "inventario", nombre: "Inventario", clase: "inventario" },
        { key: "produccion", nombre: "Producción", clase: "produccion" },
        { key: "pedidos", nombre: "Pedidos", clase: "pedidos" },
        { key: "disponible", nombre: "Disponible", clase: "disponible" }
    ];

    function escapeHtml(value) {
        return String(value ?? "")
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#039;");
    }

    function normalizarTexto(value) {
        return String(value ?? "").trim().toUpperCase();
    }

    function formatoNumero(valor) {
        return Number(valor || 0).toLocaleString("es-MX", {
            minimumFractionDigits: 0,
            maximumFractionDigits: 3
        });
    }

    function normalizarNumero(valor) {
        const numero = Number(valor);
        return isNaN(numero) ? 0 : numero;
    }

    function claseNegativo(valor) {
        return normalizarNumero(valor) < 0 ? "valor-negativo" : "";
    }

    function obtenerCampo(row, camelCase, pascalCase, defaultValue = 0) {
        if (!row) return defaultValue;
        return row[camelCase] ?? row[pascalCase] ?? defaultValue;
    }

    function obtenerTextoCampo(row, nombres, defaultValue = "") {
        if (!row) return defaultValue;

        for (const nombre of nombres) {
            if (row[nombre] !== undefined && row[nombre] !== null) {
                return String(row[nombre]);
            }
        }

        return defaultValue;
    }

    function obtenerSkuRow(row) {
        return normalizarTexto(obtenerTextoCampo(row, [
            "sku", "Sku", "SKU",
            "articulo", "Articulo",
            "itemCode", "ItemCode",
            "productoCodigo", "ProductoCodigo",
            "codigoProducto", "CodigoProducto"
        ], ""));
    }

    function filaTieneInventarioOProduccion(row) {
        const inventario = normalizarNumero(obtenerCampo(row, "kgInventario", "KgInventario", 0));
        const produccion = normalizarNumero(obtenerCampo(row, "kgProduccion", "KgProduccion", 0));

        return inventario > 0 || produccion > 0;
    }

    function obtenerSkusConInventarioOProduccion(rows) {
        const skus = new Set();

        (rows || []).forEach(row => {
            const sku = obtenerSkuRow(row);

            if (sku && filaTieneInventarioOProduccion(row)) {
                skus.add(sku);
            }
        });

        return skus;
    }

    function aplicarCatalogoSkusConMovimiento(rows, consultaSinFiltros) {
        /*
           No depurar el catálogo desde el resultado de InventarioInicialDatos.
           Ese endpoint puede regresar filas consolidadas como "TODOS" o "123 SKU".
           Si se usa eso para filtrar el catálogo, se borran MASTER/SKU y el combo queda vacío.
           Los filtros deben venir de /ProcesosCG/InventarioInicialFiltros.
        */
        return;
    }

    function fechaDesdeValor(valor) {
        if (!valor) return null;

        if (valor instanceof Date && !isNaN(valor.getTime())) {
            const f = new Date(valor);
            f.setHours(0, 0, 0, 0);
            return f;
        }

        const texto = String(valor).trim();
        const iso = texto.substring(0, 10);
        const mIso = iso.match(/^(\d{4})-(\d{2})-(\d{2})$/);

        if (mIso) {
            const f = new Date(Number(mIso[1]), Number(mIso[2]) - 1, Number(mIso[3]));
            f.setHours(0, 0, 0, 0);
            return f;
        }

        const mMx = texto.match(/^(\d{2})\/(\d{2})\/(\d{2}|\d{4})$/);
        if (mMx) {
            const year = mMx[3].length === 2 ? 2000 + Number(mMx[3]) : Number(mMx[3]);
            const f = new Date(year, Number(mMx[2]) - 1, Number(mMx[1]));
            f.setHours(0, 0, 0, 0);
            return f;
        }

        const fecha = new Date(texto);
        if (isNaN(fecha.getTime())) return null;

        fecha.setHours(0, 0, 0, 0);
        return fecha;
    }

    function fechaKey(fecha) {
        const f = fechaDesdeValor(fecha);
        if (!f) return "";

        const year = f.getFullYear();
        const month = String(f.getMonth() + 1).padStart(2, "0");
        const day = String(f.getDate()).padStart(2, "0");

        return `${year}-${month}-${day}`;
    }

    function fechaCorta(valor) {
        const fecha = fechaDesdeValor(valor);
        if (!fecha) return "Actual";

        return fecha.toLocaleDateString("es-MX", {
            day: "2-digit",
            month: "2-digit",
            year: "2-digit"
        });
    }

    function formatoInputFecha(fecha) {
        const f = fechaDesdeValor(fecha);
        if (!f) return "";
        return fechaKey(f);
    }

    function sumarDiasInput(fechaIso, dias) {
        const f = fechaDesdeValor(fechaIso);
        if (!f) return "";
        f.setDate(f.getDate() + Number(dias || 0));
        return formatoInputFecha(f);
    }

    function inicializarRangoFechas() {
        const inicio = document.getElementById("fechaInicioInput");
        const fin = document.getElementById("fechaFinInput");

        const hoy = new Date();
        hoy.setHours(0, 0, 0, 0);

        const fechaFin = new Date(hoy);
        fechaFin.setDate(hoy.getDate() + DIAS_ADELANTE);

        if (inicio && !inicio.value) {
            inicio.value = formatoInputFecha(hoy);
        }

        if (fin && !fin.value) {
            fin.value = formatoInputFecha(fechaFin);
        }
    }

    function obtenerRangoFechas() {
        const inicioInput = document.getElementById("fechaInicioInput")?.value || "";
        const finInput = document.getElementById("fechaFinInput")?.value || "";

        let inicio = fechaDesdeValor(inicioInput);
        let fin = fechaDesdeValor(finInput);

        if (!inicio) {
            inicio = new Date();
            inicio.setHours(0, 0, 0, 0);
        }

        if (!fin) {
            fin = new Date(inicio);
            fin.setDate(inicio.getDate() + DIAS_ADELANTE);
        }

        if (fin < inicio) {
            const temp = inicio;
            inicio = fin;
            fin = temp;
        }

        return { inicio, fin };
    }

    function crearCalendarioRango(fechaInicio, fechaFin) {
        const inicio = fechaDesdeValor(fechaInicio);
        const fin = fechaDesdeValor(fechaFin);
        const calendario = [];

        if (!inicio || !fin) return calendario;

        const actual = new Date(inicio);
        actual.setHours(0, 0, 0, 0);

        const limite = new Date(fin);
        limite.setHours(0, 0, 0, 0);

        while (actual <= limite) {
            calendario.push({
                fecha: fechaCorta(actual),
                fechaKey: fechaKey(actual),
                inventario: 0,
                produccion: 0,
                pedidos: 0,
                disponible: 0
            });

            actual.setDate(actual.getDate() + 1);
        }

        return calendario;
    }

    function setCargando(activo) {
        const app = document.getElementById("app");
        if (app) app.classList.toggle("loading", Boolean(activo));
    }

    async function cargarFiltrosIniciales() {
        try {
            setCargando(true);

            const rango = obtenerRangoFechas();
            const fechaInicio = formatoInputFecha(rango.inicio);
            const fechaFin = formatoInputFecha(rango.fin);
            const fechaInventarioInicial = sumarDiasInput(fechaInicio, -1);

            const params = new URLSearchParams({
                fechaInicio: fechaInicio,
                fechaFin: fechaFin,
                fechaInventarioInicial: fechaInventarioInicial,
                // Los combos MASTER/SKU siempre deben venir del catálogo activo.
                // La depuración por inventario/producción se aplica al consultar datos, no al cargar filtros.
                soloSkuMovimiento: "false"
            });

            const response = await fetch(`/ProcesosCG/InventarioInicialFiltros?${params.toString()}`, {
                method: "GET",
                headers: { "Accept": "application/json" }
            });

            const json = await response.json();

            if (!response.ok || !json.ok) {
                throw new Error(json.msg || "No se pudieron cargar los filtros.");
            }

            filtrosCatalogo.masters = (json.masters || json.Masters || []).map(x => ({
                value: normalizarTexto(x.value ?? x.Value),
                text: String(x.text ?? x.Text ?? x.value ?? x.Value ?? ""),
                totalSkus: Number(x.totalSkus ?? x.TotalSkus ?? 0)
            })).filter(x => x.value);

            filtrosCatalogo.skus = (json.skus || json.Skus || []).map(x => ({
                value: normalizarTexto(x.value ?? x.Value),
                text: String(x.text ?? x.Text ?? x.value ?? x.Value ?? ""),
                articulo: String(x.articulo ?? x.Articulo ?? ""),
                master: normalizarTexto(x.master ?? x.Master ?? x.masterProducto ?? x.MasterProducto)
            })).filter(x => x.value);

            seleccion.masters = filtrosCatalogo.masters.map(x => x.value);
            seleccion.skus = filtrosCatalogo.skus.map(x => x.value);

            renderizarOpcionesMaster();
            renderizarOpcionesSku();
            actualizarTextosFiltros();
        } catch (error) {
            console.error(error);
            alert("Error al cargar filtros: " + error.message);
        } finally {
            setCargando(false);
        }
    }

    function toggleMultiSelect(id) {
        document.querySelectorAll(".multi-select").forEach(x => {
            if (x.id !== id) x.classList.remove("open");
        });

        const el = document.getElementById(id);
        if (el) el.classList.toggle("open");
    }

function renderizarOpcionesMaster() {
    const cont = document.getElementById("masterOptions");
    if (!cont) return;

    cont.innerHTML = filtrosCatalogo.masters.map(item => {
        const checked = seleccion.masters.includes(item.value);

        const textoBusqueda = [
            item.value,
            item.text
        ].join(" ").toUpperCase();

        return `
            <label class="multi-option" data-text="${escapeHtml(textoBusqueda)}">
                <input
                    type="checkbox"
                    value="${escapeHtml(item.value)}"
                    ${checked ? "checked" : ""}
                    onchange="toggleOpcion('masters', '${escapeHtml(item.value)}', this.checked)"
                />
                <span>${escapeHtml(item.text)} <small>(${formatoNumero(item.totalSkus)})</small></span>
            </label>
        `;
    }).join("");
}

    function obtenerSkusVisiblesPorMaster() {
        const mastersActivos = new Set(seleccion.masters);

        return filtrosCatalogo.skus.filter(item => {
            return !mastersActivos.size || mastersActivos.has(item.master);
        });
    }

function renderizarOpcionesSku() {
    const cont = document.getElementById("skuOptions");
    if (!cont) return;

    const skusFiltrados = obtenerSkusVisiblesPorMaster();

    cont.innerHTML = skusFiltrados.map(item => {
        const checked = seleccion.skus.includes(item.value);

        const textoBusqueda = [
            item.value,
            item.text,
            item.articulo,
            item.master
        ].join(" ").toUpperCase();

        return `
            <label class="multi-option" data-text="${escapeHtml(textoBusqueda)}">
                <input
                    type="checkbox"
                    value="${escapeHtml(item.value)}"
                    ${checked ? "checked" : ""}
                    onchange="toggleOpcion('skus', '${escapeHtml(item.value)}', this.checked)"
                />
                <span>${escapeHtml(item.text)}</span>
            </label>
        `;
    }).join("");
}

    function toggleOpcion(tipo, value, checked) {
        value = normalizarTexto(value);

        if (checked) {
            if (!seleccion[tipo].includes(value)) {
                seleccion[tipo].push(value);
            }
        } else {
            seleccion[tipo] = seleccion[tipo].filter(x => x !== value);
        }

        if (tipo === "masters") {
            const skusPermitidos = obtenerSkusVisiblesPorMaster().map(x => x.value);

            seleccion.skus = seleccion.skus.filter(sku => skusPermitidos.includes(sku));

            if (seleccion.masters.length === filtrosCatalogo.masters.length) {
                seleccion.skus = filtrosCatalogo.skus.map(x => x.value);
            }

            renderizarOpcionesSku();
        }

        actualizarChecksTodo();
        actualizarTextosFiltros();
        cargarDatosSql();
    }

    function seleccionarTodos(selectId, checked) {
        if (selectId === "masterSelect") {
            seleccion.masters = checked
                ? filtrosCatalogo.masters.map(x => x.value)
                : [];

            seleccion.skus = checked
                ? filtrosCatalogo.skus.map(x => x.value)
                : [];

            renderizarOpcionesMaster();
            renderizarOpcionesSku();
        }

        if (selectId === "skuSelect") {
            const skusVisibles = obtenerSkusVisiblesPorMaster().map(x => x.value);

            if (checked) {
                seleccion.skus = Array.from(new Set([...seleccion.skus, ...skusVisibles]));
            } else {
                seleccion.skus = seleccion.skus.filter(x => !skusVisibles.includes(x));
            }

            renderizarOpcionesSku();
        }

        actualizarChecksTodo();
        actualizarTextosFiltros();
        cargarDatosSql();
    }

    function limpiarFiltros() {
        seleccion.masters = filtrosCatalogo.masters.map(x => x.value);
        seleccion.skus = filtrosCatalogo.skus.map(x => x.value);

        renderizarOpcionesMaster();
        renderizarOpcionesSku();
        actualizarChecksTodo();
        actualizarTextosFiltros();
        cargarDatosSql();
    }

function filtrarOpciones(selectId, texto) {
    const root = document.getElementById(selectId);
    if (!root) return;

    const filtro = normalizarTexto(texto);

    root.querySelectorAll(".multi-options .multi-option").forEach(op => {
        const txt = normalizarTexto(
            (op.dataset.text || "") + " " + (op.textContent || "")
        );

        const mostrar = !filtro || txt.includes(filtro);

        op.classList.toggle("opcion-oculta", !mostrar);
    });
}

    function actualizarChecksTodo() {
        const masterAll = document.getElementById("masterAllCheck");
        const skuAll = document.getElementById("skuAllCheck");

        if (masterAll) {
            masterAll.checked =
                filtrosCatalogo.masters.length > 0 &&
                seleccion.masters.length === filtrosCatalogo.masters.length;
        }

        if (skuAll) {
            const skusVisibles = obtenerSkusVisiblesPorMaster().map(x => x.value);
            skuAll.checked =
                skusVisibles.length > 0 &&
                skusVisibles.every(sku => seleccion.skus.includes(sku));
        }
    }

    function actualizarTextosFiltros() {
        const masterText = document.getElementById("masterSelectText");
        const skuText = document.getElementById("skuSelectText");

        if (masterText) {
            if (seleccion.masters.length === 0) {
                masterText.textContent = "Sin MASTER seleccionado";
            } else if (seleccion.masters.length === filtrosCatalogo.masters.length) {
                masterText.textContent = "Todos los MASTER";
            } else if (seleccion.masters.length === 1) {
                masterText.textContent = seleccion.masters[0];
            } else {
                masterText.textContent = `${seleccion.masters.length} MASTER seleccionados`;
            }
        }

        if (skuText) {
            if (seleccion.skus.length === 0) {
                skuText.textContent = "Sin SKU seleccionado";
            } else if (seleccion.skus.length === filtrosCatalogo.skus.length) {
                skuText.textContent = "Todos los SKU";
            } else if (seleccion.skus.length === 1) {
                skuText.textContent = seleccion.skus[0];
            } else {
                skuText.textContent = `${seleccion.skus.length} SKU seleccionados`;
            }
        }
    }

    function metricaVisible(key) {
        return filtrosMetricas[key] !== false;
    }

    function cambiarFiltroMetrica(key, activo) {
        filtrosMetricas[key] = Boolean(activo);

        const item = document.querySelector(`.legend-item[data-filtro="${key}"]`);
        if (item) {
            item.classList.toggle("inactivo", !activo);
        }

        renderizar();
    }

    function aplicarFiltrosTabla() {
        const filas = {
            inventario: document.getElementById("filaInventario"),
            produccion: document.getElementById("filaProduccion"),
            pedidos: document.getElementById("filaPedidos"),
            disponible: document.getElementById("filaDisponible")
        };

        Object.keys(filas).forEach(key => {
            if (filas[key]) {
                filas[key].style.display = metricaVisible(key) ? "" : "none";
            }
        });
    }

    function cambiarModoVista(modo) {
        modoVista = modo || "completa";

        const app = document.getElementById("app");
        if (app) {
            app.dataset.modoVista = modoVista;
        }

        const radio = document.querySelector(`input[name="modoVista"][value="${modoVista}"]`);
        if (radio) {
            radio.checked = true;
        }

        renderizarGrafica();
    }

    async function cargarDatosSql() {
        const rango = obtenerRangoFechas();
        const fechaInicio = formatoInputFecha(rango.inicio);
        const fechaFin = formatoInputFecha(rango.fin);
        const calendario = crearCalendarioRango(rango.inicio, rango.fin);

        const todosMasters =
            filtrosCatalogo.masters.length > 0 &&
            seleccion.masters.length === filtrosCatalogo.masters.length;

        const todosSkus =
            filtrosCatalogo.skus.length > 0 &&
            seleccion.skus.length === filtrosCatalogo.skus.length;

        const mastersCsv = todosMasters ? "" : seleccion.masters.join(",");
        const skusCsv = todosSkus ? "" : seleccion.skus.join(",");

        try {
            setCargando(true);

            let url = "/ProcesosCG/InventarioInicialDatos?";
            url += `skusCsv=${encodeURIComponent(skusCsv)}`;
            url += `&mastersCsv=${encodeURIComponent(mastersCsv)}`;
            url += `&fechaInicio=${encodeURIComponent(fechaInicio)}`;
            url += `&fechaFin=${encodeURIComponent(fechaFin)}`;
            const fechaInventarioInicial = sumarDiasInput(fechaInicio, -1);
            url += `&fechaInventarioInicial=${encodeURIComponent(fechaInventarioInicial)}`;
            url += `&dias=${DIAS_ADELANTE}`;
            url += `&soloSkuMovimiento=${SOLO_SKU_CON_INVENTARIO_O_PRODUCCION ? "true" : "false"}`;

            const response = await fetch(url, {
                method: "GET",
                headers: { "Accept": "application/json" }
            });

            const json = await response.json();

            if (!response.ok || !json.ok) {
                throw new Error(json.msg || json.error || "No se pudo consultar la información.");
            }

            const rows = json.data || json.Data || [];

            aplicarCatalogoSkusConMovimiento(rows, todosMasters && todosSkus);

            const skusConMovimiento = obtenerSkusConInventarioOProduccion(rows);
            const rowsProcesar = SOLO_SKU_CON_INVENTARIO_O_PRODUCCION && skusConMovimiento.size
                ? rows.filter(row => {
                    const sku = obtenerSkuRow(row);
                    return !sku || skusConMovimiento.has(sku);
                })
                : rows;

            const inventarioPorFecha = {};
            const pedidosPorFecha = {};
            const produccionPorFecha = {};

            rowsProcesar.forEach(row => {
                const fechaValor = obtenerCampo(row, "fecha", "Fecha", null);
                const key = fechaKey(fechaValor);
                if (!key) return;

                const inventario = normalizarNumero(obtenerCampo(row, "kgInventario", "KgInventario", 0));
                const pedidos = normalizarNumero(
                    obtenerCampo(row, "kgPedido", "KgPedido",
                        obtenerCampo(row, "kgPedidoEstimado", "KgPedidoEstimado", 0)
                    )
                );
                const produccion = normalizarNumero(obtenerCampo(row, "kgProduccion", "KgProduccion", 0));
                inventarioPorFecha[key] = normalizarNumero(inventarioPorFecha[key]) + inventario;
                pedidosPorFecha[key] = normalizarNumero(pedidosPorFecha[key]) + pedidos;
                produccionPorFecha[key] = normalizarNumero(produccionPorFecha[key]) + produccion;
            });

            let inventarioArrastre = 0;

            datos = calendario.map((dia, index) => {
                const produccion = normalizarNumero(produccionPorFecha[dia.fechaKey]);
                const pedidos = normalizarNumero(pedidosPorFecha[dia.fechaKey]);

                // El inventario inicial se toma en la fecha de inicio seleccionada,
                // que por defecto es hoy. Ya no se toma el día anterior.
                const inventario = index === 0
                    ? normalizarNumero(inventarioPorFecha[dia.fechaKey])
                    : inventarioArrastre;

                const disponible = inventario + produccion - pedidos;
                inventarioArrastre = disponible;

                return {
                    fecha: dia.fecha,
                    fechaKey: dia.fechaKey,
                    inventario,
                    produccion,
                    pedidos,
                    disponible
                };
            });

            const ultima = document.getElementById("ultimaConsulta");
            if (ultima) {
                ultima.textContent = new Date().toLocaleString("es-MX", {
                    day: "2-digit",
                    month: "2-digit",
                    year: "numeric",
                    hour: "2-digit",
                    minute: "2-digit"
                });
            }

            renderizar();
        } catch (error) {
            console.error(error);
            alert("Error al cargar Inventario Inicial: " + error.message);
        } finally {
            setCargando(false);
        }
    }

    function textoAlcance() {
        if (seleccion.skus.length === 0) return "Sin SKU";

        if (seleccion.skus.length === 1) return seleccion.skus[0];

        if (seleccion.skus.length === filtrosCatalogo.skus.length) {
            return "Todos";
        }

        return `${seleccion.skus.length} SKU`;
    }

    function textoDetalleAlcance() {
        if (seleccion.masters.length === 0) return "Sin MASTER";

        const masters = seleccion.masters.length === filtrosCatalogo.masters.length
            ? "Todos los MASTER"
            : `${seleccion.masters.length} MASTER`;

        const skus = seleccion.skus.length === filtrosCatalogo.skus.length
            ? "Todos los SKU"
            : `${seleccion.skus.length} SKU`;

        return `${masters} / ${skus}`;
    }

    function renderizar() {
        const filaFechas = document.getElementById("filaFechas");
        const filaInventario = document.getElementById("filaInventario");
        const filaProduccion = document.getElementById("filaProduccion");
        const filaPedidos = document.getElementById("filaPedidos");
        const filaDisponible = document.getElementById("filaDisponible");

        const alcance = textoAlcance();
        const alcanceDetalle = textoDetalleAlcance();

        filaFechas.innerHTML = `
            <th class="sticky-alcance">Alcance</th>
            <th class="sticky-concepto">Concepto</th>
        `;

        filaInventario.innerHTML = `
            <td class="sticky-alcance">${escapeHtml(alcance)}</td>
            <td class="sticky-concepto">Inventario KG</td>
        `;

        filaProduccion.innerHTML = `
            <td class="sticky-alcance">${escapeHtml(alcance)}</td>
            <td class="sticky-concepto">Producción KG</td>
        `;

        filaPedidos.innerHTML = `
            <td class="sticky-alcance">${escapeHtml(alcance)}</td>
            <td class="sticky-concepto">Pedidos KG</td>
        `;

        filaDisponible.innerHTML = `
            <td class="sticky-alcance">${escapeHtml(alcance)}</td>
            <td class="sticky-concepto">Disponible KG</td>
        `;

        datos.forEach((dia) => {
            filaFechas.innerHTML += `<th>${escapeHtml(dia.fecha)}</th>`;

            filaInventario.innerHTML += `
                <td class="${claseNegativo(dia.inventario)}">${formatoNumero(dia.inventario)}</td>
            `;

            filaProduccion.innerHTML += `
                <td class="${claseNegativo(dia.produccion)}">${formatoNumero(dia.produccion)}</td>
            `;

            filaPedidos.innerHTML += `
                <td class="${claseNegativo(dia.pedidos)}">${formatoNumero(dia.pedidos)}</td>
            `;

            let claseDisponible = "disponible-ok";

            if (dia.disponible < 0) {
                claseDisponible = "disponible-negativo";
            } else if (dia.disponible <= 10) {
                claseDisponible = "disponible-alerta";
            }

            filaDisponible.innerHTML += `
                <td class="${claseDisponible} ${claseNegativo(dia.disponible)}">
                    ${formatoNumero(dia.disponible)}
                </td>
            `;
        });

        aplicarFiltrosTabla();
        actualizarKPIs(alcance, alcanceDetalle);
        renderizarGrafica();
    }

    function actualizarKPIs(alcance, alcanceDetalle) {
        const disponibleFinal = datos.length ? datos[datos.length - 1].disponible : 0;

        const produccionTotal = datos.reduce((total, dia) => {
            return total + normalizarNumero(dia.produccion);
        }, 0);

        const pedidosTotal = datos.reduce((total, dia) => {
            return total + normalizarNumero(dia.pedidos);
        }, 0);

        const diasFaltante = datos.filter(dia => dia.disponible < 0).length;

        document.getElementById("kpiAlcance").textContent = alcance;
        document.getElementById("kpiAlcanceDetalle").textContent = alcanceDetalle;
        document.getElementById("kpiDisponibleFinal").textContent = formatoNumero(disponibleFinal);
        document.getElementById("kpiProduccionTotal").textContent = formatoNumero(produccionTotal);
        document.getElementById("kpiPedidosTotal").textContent = formatoNumero(pedidosTotal);
        document.getElementById("kpiDiasFaltante").textContent = formatoNumero(diasFaltante);

        const cardDisponible = document.getElementById("kpiDisponibleFinal")?.closest(".card");
        const cardFaltante = document.getElementById("kpiDiasFaltante")?.closest(".card");

        if (cardDisponible) {
            cardDisponible.classList.toggle("kpi-negativo", disponibleFinal < 0);
            cardDisponible.classList.toggle("kpi-alerta", disponibleFinal >= 0 && disponibleFinal <= 10);
        }

        if (cardFaltante) {
            cardFaltante.classList.toggle("kpi-alerta-activa", diasFaltante > 0);
        }

        const tablaResumen = document.getElementById("tablaResumen");
        if (tablaResumen) {
            tablaResumen.textContent = `${alcanceDetalle} | Inventario inicial desde hoy`;
        }
    }

    function renderizarGrafica() {
        const contenedor = document.getElementById("graficaDisponible");
        if (!contenedor) return;

        contenedor.innerHTML = "";

        const metricasVisibles = metricasGrafica.filter(m => metricaVisible(m.key));

        if (!metricasVisibles.length) {
            contenedor.innerHTML = `
                <div class="sin-datos">
                    Selecciona al menos un indicador para mostrar información.
                </div>
            `;
            return;
        }

        if (!datos.length) {
            contenedor.innerHTML = `
                <div class="sin-datos">
                    No hay información para el rango seleccionado.
                </div>
            `;
            return;
        }

        const valores = [];
        datos.forEach(dia => {
            metricasVisibles.forEach(metrica => {
                valores.push(Math.abs(normalizarNumero(dia[metrica.key])));
            });
        });

        const maximo = Math.max(...valores, 1);
        const altoDisponible = Math.max(contenedor.clientHeight - 62, 90);

        datos.forEach(dia => {
            const barras = metricasVisibles.map(metrica => {
                const valor = normalizarNumero(dia[metrica.key]);
                const altura = Math.max((Math.abs(valor) / maximo) * altoDisponible, 4);

                return `
                    <div
                        class="bar ${metrica.clase} ${valor < 0 ? "negative" : ""}"
                        style="height: ${altura}px;"
                        title="${metrica.nombre}: ${formatoNumero(valor)} KG | ${dia.fecha}"
                    ></div>
                `;
            }).join("");

            const resumen = metricasVisibles.length === 1
                ? `<div>${formatoNumero(dia[metricasVisibles[0].key])}</div>`
                : `<div>${metricasVisibles.length} datos</div>`;

            contenedor.innerHTML += `
                <div class="bar-item">
                    <div class="bar-stack">
                        ${barras}
                    </div>
                    ${resumen}
                    <div class="bar-label">${escapeHtml(dia.fecha)}</div>
                </div>
            `;
        });
    }

    document.addEventListener("click", function (e) {
        if (!e.target.closest(".multi-select")) {
            document.querySelectorAll(".multi-select").forEach(x => x.classList.remove("open"));
        }
    });

    inicializarRangoFechas();
    cambiarModoVista("completa");

    cargarFiltrosIniciales().then(() => {
        cargarDatosSql();
    });
</script>
