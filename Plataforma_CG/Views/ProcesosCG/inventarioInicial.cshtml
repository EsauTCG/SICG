        <div class="legend" role="group" aria-label="Filtros de indicadores">
            <label class="legend-item" data-filtro="inventario">
                <input type="checkbox" checked onchange="cambiarFiltroMetrica('inventario', this.checked)" />
                <span class="dot dot-blue"></span> Inventario
            </label>
            <label class="legend-item" data-filtro="produccion">
                <input type="checkbox" checked onchange="cambiarFiltroMetrica('produccion', this.checked)" />
                <span class="dot dot-green"></span> Producción
            </label>
            <label class="legend-item" data-filtro="pedidos">
                <input type="checkbox" checked onchange="cambiarFiltroMetrica('pedidos', this.checked)" />
                <span class="dot dot-orange"></span> Pedidos
            </label>
            <label class="legend-item" data-filtro="disponible">
                <input type="checkbox" checked onchange="cambiarFiltroMetrica('disponible', this.checked)" />
                <span class="dot dot-gray"></span> Disponible
