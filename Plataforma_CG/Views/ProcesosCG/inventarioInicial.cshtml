                <tbody>
                    <tr class="row-inventario" id="filaInventario">
                        <td class="sticky-alcance">-</td>
                        <td class="sticky-concepto">Inventario KG</td>
                    </tr>

                    <tr class="row-produccion" id="filaProduccion">
                        <td class="sticky-alcance">-</td>
                        <td class="sticky-concepto">Producción KG</td>
                    </tr>

                    <tr class="row-pedidos" id="filaPedidos">
                        <td class="sticky-alcance">-</td>
                        <td class="sticky-concepto">Pedidos KG</td>
                    </tr>

                    <tr class="row-disponible" id="filaDisponible">
                        <td class="sticky-alcance">-</td>
                        <td class="sticky-concepto">Disponible KG</td>
