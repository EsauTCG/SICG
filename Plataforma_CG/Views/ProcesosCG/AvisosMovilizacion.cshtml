@model Plataforma_CG.ViewModels.AvisosMovilizacionPageVM
@removeTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Avisos de Movilización";

    /*
        IMPORTANTE:
        Esta vista ya NO debe recibir Rows precargados desde el controlador.
        La pantalla abre primero y los avisos se cargan después por AJAX.
    */
    var desdeTxt = (Model?.Desde ?? DateTime.Today.AddDays(-7)).ToString("yyyy-MM-dd");
    var hastaTxt = (Model?.Hasta ?? DateTime.Today).ToString("yyyy-MM-dd");
    var clienteTxt = Model?.Cliente ?? "";
    var ventaTxt = Model?.Venta ?? "";
    var loteTxt = Model?.Lote ?? "";

    var origenReq = ((ViewBag.Source as string) ?? Context?.Request?.Query["source"].ToString() ?? "TIF").Trim();
    var origenSel = origenReq.Equals("P1", StringComparison.OrdinalIgnoreCase)
        || origenReq.Equals("PLANTA 1", StringComparison.OrdinalIgnoreCase)
        || origenReq.Equals("PLANTA1", StringComparison.OrdinalIgnoreCase)
            ? "P1"
            : "TIF";
}

<style>
    :root {
        --bg: #f0dede;
        --panel: #f8eeee;
        --panel-2: #f1dede;
        --line: #c79d9d;
        --text: #3b1717;
        --muted: #6a3a3a;
        --white: #ffffff;
        --brand: #8B0000;
        --vino-border: #9a5a5a;
    }

    body {
        margin: 0 !important;
        padding: 0 !important;
        font-family: Tahoma, Verdana, Arial, sans-serif;
        background: transparent !important;
        color: var(--text);
    }

    .container, .container-fluid {
        max-width: 100% !important;
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .window {
        width: 100%;
        border: 1px solid #7e4a4a;
        background: var(--panel);
        box-shadow: 0 8px 18px rgba(70,12,12,.14);
        overflow: hidden;
    }

    .content {
        padding: 8px;
        background: var(--bg);
    }

    .workspace {
        border: 1px solid var(--line);
        background: var(--panel);
        padding: 8px;
    }

    .section {
        border: 1px solid var(--line);
        background: var(--white);
        margin-bottom: 10px;
    }

    .section-title {
        padding: 7px 10px;
        font-size: 13px;
        font-weight: bold;
        color: #fff;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        border-bottom: 1px solid #6b1f1f;
    }

    .filters {
        display: grid;
        grid-template-columns: 145px 130px 130px 190px 170px 160px auto;
        gap: 10px;
        padding: 10px;
        background: var(--panel-2);
        align-items: end;
    }

    .filter-group label {
        display: block;
        color: #5c1a1a;
        font-size: 12px;
        margin-bottom: 4px;
        font-weight: bold;
    }

    input, select, .form-control {
        height: 30px !important;
        padding: 3px 6px !important;
        border: 1px solid #b48787 !important;
        background: #fffdfd !important;
        font-family: inherit !important;
        font-size: 12px !important;
        width: 100%;
        border-radius: 0 !important;
        box-shadow: none !important;
        color: #421414 !important;
    }

        input[type="checkbox"] {
            height: 14px !important;
            width: 14px !important;
            min-width: 14px !important;
            cursor: pointer;
        }

    .pm-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 6px;
        flex-wrap: wrap;
    }

    .pm-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        height: 30px;
        padding: 0 10px;
        border: 1px solid transparent;
        border-radius: 0;
        font-family: Tahoma, Verdana, Arial, sans-serif;
        font-size: 12px;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        white-space: nowrap;
    }

    .pm-btn-primary {
        color: #fff;
        border-color: #7a2d2d;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
    }

    .pm-btn-success {
        color: #fff;
        border-color: #157347;
        background: linear-gradient(180deg, #27ae60 0%, #1f9a54 55%, #198754 100%);
    }

    .pm-btn-warning {
        color: #3d2000;
        border-color: #c87800;
        background: linear-gradient(180deg, #ffc107 0%, #e6a800 100%);
    }

    .pm-btn-secondary {
        background: linear-gradient(#fffefe, #ecd7d7);
        border-color: var(--vino-border);
        color: #4a1111;
    }

    .summary {
        display: grid;
        grid-template-columns: repeat(4, minmax(150px, 1fr));
        gap: 10px;
        padding: 10px;
        background: #fffafa;
        border-top: 1px solid #ead6d6;
    }

    .summary-card {
        position: relative;
        overflow: hidden;
        min-height: 94px;
        border: 1px solid rgba(255,255,255,.34);
        border-radius: 14px;
        padding: 12px 14px;
        box-shadow: 0 14px 28px rgba(70,12,12,.16), inset 0 1px 0 rgba(255,255,255,.22);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        isolation: isolate;
    }

        .summary-card::after {
            content: "";
            position: absolute;
            right: -34px;
            bottom: -44px;
            width: 126px;
            height: 126px;
            border-radius: 999px;
            background: rgba(255,255,255,.16);
            z-index: -1;
        }

        .summary-card .label {
            font-size: 11px;
            color: rgba(255,255,255,.88);
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .06em;
        }

        .summary-card .value {
            font-size: clamp(22px, 2vw, 32px);
            color: #fff;
            font-weight: 900;
            margin-top: 3px;
            line-height: 1.05;
            font-variant-numeric: tabular-nums;
            text-shadow: 0 2px 8px rgba(0,0,0,.18);
            word-break: break-word;
        }

        .summary-card .hint {
            margin-top: 5px;
            color: rgba(255,255,255,.86);
            font-size: 11px;
            font-weight: 700;
        }

        .summary-card.kpi-solicitudes {
            background: linear-gradient(135deg, #7b1113 0%, #a3161a 55%, #5c090b 100%);
        }

        .summary-card.kpi-cajas {
            background: linear-gradient(135deg, #b7791f 0%, #d99a28 55%, #8a4f05 100%);
        }

        .summary-card.kpi-kg {
            background: linear-gradient(135deg, #157f49 0%, #22a65a 55%, #0f5132 100%);
        }

        .summary-card.kpi-seleccionadas {
            background: linear-gradient(135deg, #1f3a5f 0%, #2563eb 55%, #0f172a 100%);
        }

            .summary-card.kpi-seleccionadas.has-selection {
                background: linear-gradient(135deg, #0f766e 0%, #14b8a6 55%, #134e4a 100%);
            }

    .table-wrap {
        overflow: auto;
        max-height: 70vh;
        background: #fffafa;
        width: 100%;
        border-top: 1px solid #d9b8b8;
    }

    table.tbl-aviso {
        width: 100%;
        min-width: 1040px;
        table-layout: fixed;
        border-collapse: separate !important;
        border-spacing: 0 !important;
        font-size: 12px;
        background: #fffafa;
    }

    .tbl-aviso thead th {
        position: sticky;
        top: -1px;
        z-index: 20;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%) !important;
        color: #fff !important;
        border-right: 1px solid #8e3b3b !important;
        border-bottom: 1px solid #5c0000 !important;
        padding: 6px 5px !important;
        font-weight: 700 !important;
        white-space: nowrap;
    }

    .tbl-aviso tbody td {
        background: #fffafa !important;
        border-right: 1px solid #d8bcbc !important;
        border-bottom: 1px solid #d8bcbc !important;
        padding: 5px !important;
        white-space: nowrap;
        vertical-align: middle;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #111 !important;
    }

    .tbl-aviso tbody tr:nth-child(even) td {
        background: #f9eded !important;
    }

    .tbl-aviso tbody tr:hover td {
        background: #f4dddd !important;
    }

    .text-end {
        text-align: right !important;
    }

    .text-center {
        text-align: center !important;
    }

    .modal-card {
        border: 1px solid #7a2d2d;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 18px 45px rgba(0,0,0,.35);
    }

    .modal-head {
        padding: 14px 18px;
        background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
        color: #fff;
        font-weight: 800;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-close {
        border: none;
        background: transparent;
        color: #fff;
        font-size: 28px;
        font-weight: 700;
        line-height: 1;
        cursor: pointer;
    }

    .modal-body-aviso {
        background: #fff8f8;
        padding: 16px;
    }

    .modal-footer-aviso {
        background: #fff;
        border-top: 1px solid #e5d5d5;
        padding: 12px 16px;
        display: flex;
        justify-content: flex-end;
        gap: 8px;
    }

    .detalle-wrap {
        border: 1px solid #d8bcbc;
        background: #fffafa;
        overflow: auto;
        max-height: 430px;
    }

    .detalle-table {
        width: 100%;
        min-width: 1080px;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 12px;
    }

        .detalle-table th {
            position: sticky;
            top: 0;
            z-index: 2;
            background: linear-gradient(180deg, #b30000 0%, #8b0000 55%, #5c0000 100%);
            color: #fff;
            padding: 6px;
            border-right: 1px solid #8e3b3b;
        }

        .detalle-table td {
            padding: 5px;
            border-right: 1px solid #d8bcbc;
            border-bottom: 1px solid #d8bcbc;
            background: #fffafa;
            white-space: nowrap;
        }


    .detalle-fecha {
        min-width: 130px;
    }

    .detalle-fecha-wrap {
        display: flex;
        align-items: center;
        gap: 6px;
        min-height: 20px;
    }

    .detalle-fecha-local {
        color: #4b1d1d;
    }

    .detalle-fecha-tif {
        color: #0f6b3d;
        font-weight: 800;
    }

    .detalle-row-status {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        margin-left: 5px;
        font-size: 10px;
        font-weight: 800;
        white-space: nowrap;
    }

        .detalle-row-status.is-pending {
            color: #8a5700;
        }

        .detalle-row-status.is-complete {
            color: #157347;
        }

        .detalle-row-status.is-error {
            color: #b00000;
        }

    .detalle-mini-spinner {
        display: inline-block;
        width: 11px;
        height: 11px;
        border: 2px solid currentColor;
        border-right-color: transparent;
        border-radius: 50%;
        animation: tif-spin .75s linear infinite;
    }

    .detalle-progress {
        margin: 0 0 10px 0;
        padding: 8px 10px;
        border: 1px solid #d8bcbc;
        background: #fffafa;
        color: #5c1a1a;
        font-size: 12px;
        font-weight: 700;
    }

        .detalle-progress.is-loading {
            background: #e8f4fd;
            border-color: #7ab8d4;
            color: #064b6b;
        }

        .detalle-progress.is-success {
            background: #dff3e2;
            border-color: #6aa84f;
            color: #2f6b1f;
        }

        .detalle-progress.is-warning {
            background: #fff3cd;
            border-color: #e0a800;
            color: #765500;
        }

    #logBox {
        margin-top: 8px;
        display: none;
    }

    .log-inner {
        padding: 8px 10px;
        font-size: 12px;
        border: 1px solid var(--line);
        white-space: pre-wrap;
        font-family: Tahoma, Verdana, Arial, sans-serif;
    }

    .log-info {
        background: #e8f4fd;
        border-color: #7ab8d4;
        color: #064b6b;
    }

    .log-success {
        background: #dff3e2;
        border-color: #6aa84f;
        color: #2f6b1f;
    }

    .log-danger {
        background: #fde2e2;
        border-color: #d9534f;
        color: #b00000;
    }


    .tif-status {
        display: flex;
        align-items: center;
        gap: 9px;
        min-height: 36px;
        padding: 8px 12px;
        border-top: 1px solid #ead6d6;
        font-size: 12px;
        font-weight: 700;
    }

        .tif-status.is-hidden {
            display: none;
        }

        .tif-status.status-loading {
            color: #064b6b;
            background: #e8f4fd;
        }

        .tif-status.status-success {
            color: #21652b;
            background: #e2f4e5;
        }

        .tif-status.status-warning {
            color: #7a4a00;
            background: #fff3cd;
        }

        .tif-status.status-danger {
            color: #9d1111;
            background: #fde2e2;
        }

    .tif-spinner {
        width: 15px;
        height: 15px;
        border: 2px solid currentColor;
        border-right-color: transparent;
        border-radius: 50%;
        animation: tif-spin .75s linear infinite;
        flex: 0 0 auto;
    }

    @@keyframes tif-spin {
        to {
            transform: rotate(360deg);
        }
    }

    @@media(max-width: 992px) {
        .filters {
            grid-template-columns: 1fr 1fr;
        }

        .summary {
            grid-template-columns: 1fr;
        }
    }

    @@media(max-width: 768px) {
        .filters {
            grid-template-columns: 1fr;
        }

        .pm-actions {
            justify-content: stretch;
        }

        .pm-btn {
            width: 100%;
        }
    }
</style>

<div class="window">
    <div class="content">
        <div class="workspace">

            <div class="section">
                <div class="section-title">Avisos de movilización - <span id="tituloPlanta">@(origenSel == "P1" ? "Planta 1" : "Planta TIF")</span></div>

                <form id="filtrosAvisosForm" autocomplete="off">
                    <input type="hidden" id="plantaHidden" name="planta" value="@origenSel" />
                    <input type="hidden" id="origenHidden" name="origen" value="@(origenSel == "P1" ? "Planta 1" : "Planta TIF")" />
                    <div class="filters">

                        <div class="filter-group">
                            <label>Origen</label>
                            <select id="origenPlanta" name="source">
                                @if (origenSel == "P1")
                                {
                                    <option value="P1" selected>Planta 1</option>
                                    <option value="TIF">Planta TIF</option>
                                }
                                else
                                {
                                    <option value="P1">Planta 1</option>
                                    <option value="TIF" selected>Planta TIF</option>
                                }
                            </select>
                        </div>

                        <div class="filter-group">
                            <label>Desde</label>
                            <input type="date"
                                   name="desde"
                                   value="@desdeTxt" />
                        </div>

                        <div class="filter-group">
                            <label>Hasta</label>
                            <input type="date"
                                   name="hasta"
                                   value="@hastaTxt" />
                        </div>

                        <div class="filter-group">
                            <label>Cliente</label>
                            <input type="text"
                                   name="cliente"
                                   value="@clienteTxt"
                                   placeholder="Buscar cliente..." />
                        </div>

                        <div class="filter-group">
                            <label>Venta</label>
                            <input type="text"
                                   name="venta"
                                   value="@ventaTxt"
                                   placeholder="Venta / pedido..." />
                        </div>

                        <div class="filter-group">
                            <label>Lote</label>
                            <input type="text"
                                   name="lote"
                                   value="@loteTxt"
                                   placeholder="Lote..." />
                        </div>

                        <div class="filter-group">
                            <label>&nbsp;</label>
                            <div class="pm-actions">
                                <button id="btnBuscarAvisos" class="pm-btn pm-btn-primary" type="submit">🔎 Buscar</button>
                                <button class="pm-btn pm-btn-warning" type="button" onclick="selectAllAvisos(true)">☑ Todos</button>
                                <button class="pm-btn pm-btn-secondary" type="button" onclick="selectAllAvisos(false)">☐ Ninguno</button>
                                <button class="pm-btn pm-btn-success" type="button" onclick="abrirEnvioMedico()">📧 Enviar médico</button>
                                <button class="pm-btn pm-btn-primary" type="button" onclick="abrirPdfSeleccionados()">📄 PDF</button>
                                @*  <button class="pm-btn pm-btn-success" type="button" onclick="descargarExcelAvisoMovilizacion()">📊 Aviso de Movilización</button> *@
                            </div>
                        </div>

                    </div>
                </form>

                <div class="summary">
                    <div class="summary-card kpi-solicitudes">
                        <div class="label">Solicitudes</div>
                        <div class="value" id="kpiSolicitudes">0</div>
                        <div class="hint">Avisos encontrados</div>
                    </div>

                    <div class="summary-card kpi-cajas">
                        <div class="label">Cajas</div>
                        <div class="value" id="kpiCajas">0</div>
                        <div class="hint">Total del rango</div>
                    </div>

                    <div class="summary-card kpi-kg">
                        <div class="label">Kg</div>
                        <div class="value" id="kpiKg">0.000</div>
                        <div class="hint">Peso acumulado</div>
                    </div>

                    <div class="summary-card kpi-seleccionadas" id="kpiSeleccionadasCard">
                        <div class="label">Seleccionadas</div>
                        <div class="value" id="kpiSeleccionadas">0</div>
                        <div class="hint">Para PDF / envío médico</div>
                    </div>
                </div>

                <div id="estadoCargaTif"
                     class="tif-status is-hidden"
                     role="status"
                     aria-live="polite">
                    <span id="estadoCargaTifIcono"></span>
                    <span id="estadoCargaTifTexto"></span>
                </div>
            </div>

            <div class="section">
                <div class="table-wrap">
                    <table class="tbl-aviso">
                        <thead>
                            <tr>
                                <th style="width:42px;" class="text-center">Sel.</th>
                                <th style="width:92px;">Origen</th>
                                <th style="width:95px;">Fecha venta</th>
                                <th style="width:110px;">Solicitud</th>
                                <th style="width:150px;">Venta</th>
                                <th style="width:260px;">Cliente</th>
                                <th style="width:80px;" class="text-end">Partidas</th>
                                <th style="width:80px;" class="text-end">Cajas</th>
                                <th style="width:95px;" class="text-end">Kg</th>
                                <th style="width:170px;" class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="avisosBody">
                            <tr>
                                <td colspan="10" class="text-center">Cargando avisos...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="logBox">
                <div id="log" class="log-inner log-info"></div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="detalleAvisoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:1180px;">
        <div class="modal-content modal-card">
            <div class="modal-head">
                <div>🔎 Detalle del aviso de movilización</div>
                <button type="button" class="modal-close" data-bs-dismiss="modal">×</button>
            </div>
            <div class="modal-body-aviso">
                <div style="margin-bottom:10px;">
                    Solicitud: <strong id="detalleSolicitud">-</strong>
                    &nbsp; | &nbsp; Cajas: <strong id="detalleCajas">0</strong>
                    &nbsp; | &nbsp; Kg: <strong id="detalleKg">0</strong>
                </div>

                <div id="detalleTifProgress"
                     class="detalle-progress"
                     style="display:none;"
                     role="status"
                     aria-live="polite"></div>

                <div class="detalle-wrap">
                    <table class="detalle-table">
                        <thead>
                            <tr>
                                <th>SKU</th>
                                <th>Producto</th>
                                <th>Lote</th>
                                <th>F. sacrificio</th>
                                <th>F. producción</th>
                                <th>F. caducidad</th>
                                <th class="text-end">Cajas</th>
                                <th class="text-end">Kg</th>
                            </tr>
                        </thead>
                        <tbody id="detalleBody">
                            <tr>
                                <td colspan="8" class="text-center">Sin detalle.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer-aviso">
                <button type="button" class="pm-btn pm-btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="envioMedicoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:620px;">
        <div class="modal-content modal-card">
            <div class="modal-head">
                <div>📧 Enviar avisos al médico SENASICA</div>
                <button type="button" class="modal-close" data-bs-dismiss="modal">×</button>
            </div>
            <div class="modal-body-aviso">
                <div class="filter-group">
                    <label>Correo del médico</label>
                    <input id="correoMedico" type="email" placeholder="medico@correo.com" />
                </div>

                <div class="filter-group" style="margin-top:10px;">
                    <label>Comentarios</label>
                    <textarea id="comentariosEnvio"
                              maxlength="1000"
                              rows="4"
                              style="width:100%; min-height:95px; border:1px solid #b48787; padding:8px;"
                              placeholder="Observaciones para el médico..."></textarea>
                </div>

                <div style="margin-top:10px; padding:10px; background:#fffafa; border:1px solid #d8bcbc;">
                    Solicitudes seleccionadas:
                    <strong id="totalSeleccionadasEnvio">0</strong>
                    <div id="listaSeleccionadasEnvio" style="margin-top:6px; font-size:12px; color:#5c1a1a;"></div>
                </div>
            </div>
            <div class="modal-footer-aviso">
                <button type="button" class="pm-btn pm-btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="pm-btn pm-btn-primary" onclick="abrirPdfDesdeModal()">📄 PDF</button>
                <button type="button" class="pm-btn pm-btn-success" onclick="enviarAvisosMedico()">📧 Enviar</button>
            </div>
        </div>
    </div>
</div>

<script>
    const URL_DATA = '@Url.Action("AvisosMovilizacionData", "ProcesosCg")';
    const URL_DETALLE = '@Url.Action("AvisosMovilizacionDetalle", "ProcesosCg")';
    const URL_PDF = '@Url.Action("AvisosMovilizacionPdf", "ProcesosCg")';
    const URL_ENVIAR = '@Url.Action("EnviarAvisosMovilizacionSenasica", "ProcesosCg")';
    const URL_EXCEL_AVISO = '@Url.Action("AvisosMovilizacionExcel", "ProcesosCg")';

    let avisosAbortController = null;
    let avisosRequestVersion = 0;

    let detalleAbortController = null;
    let detalleRequestVersion = 0;

    function normalizePlanta(value) {
        const v = String(value || '').trim().toUpperCase();
        return (v === 'P1' || v === 'PLANTA 1' || v === 'PLANTA1') ? 'P1' : 'TIF';
    }

    function getPlantaActual() {
        return normalizePlanta(document.getElementById('origenPlanta')?.value || 'TIF');
    }

    function getNombrePlanta(value) {
        return normalizePlanta(value) === 'P1' ? 'Planta 1' : 'Planta TIF';
    }

    function syncOrigenFields() {
        const planta = getPlantaActual();
        const nombre = getNombrePlanta(planta);

        const plantaHidden = document.getElementById('plantaHidden');
        const origenHidden = document.getElementById('origenHidden');
        const tituloPlanta = document.getElementById('tituloPlanta');

        if (plantaHidden) plantaHidden.value = planta;
        if (origenHidden) origenHidden.value = nombre;
        if (tituloPlanta) tituloPlanta.textContent = nombre;

        return { planta, nombre };
    }

    function appendOrigenParams(params) {
        const origen = syncOrigenFields();
        params.set('source', origen.planta);
        params.set('planta', origen.planta);
        params.set('origen', origen.nombre);
        return params;
    }

    function getFiltroAvisosParams() {
        const form = document.getElementById('filtrosAvisosForm');
        const params = form
            ? new URLSearchParams(new FormData(form))
            : new URLSearchParams();

        appendOrigenParams(params);
        return params;
    }

    function buildUrlWithParams(baseUrl, params) {
        appendOrigenParams(params);
        return baseUrl + '?' + params.toString();
    }

    function showLog(type, text) {
        const box = document.getElementById('logBox');
        const log = document.getElementById('log');
        box.style.display = 'block';
        log.className = 'log-inner log-' + (type || 'info');
        log.textContent = text || '';
    }

    function hideLog() {
        const box = document.getElementById('logBox');
        if (box) box.style.display = 'none';
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    function pick(obj, ...keys) {
        for (const key of keys) {
            if (obj && obj[key] !== undefined && obj[key] !== null) {
                return obj[key];
            }
        }
        return '';
    }

    function toNumber(value) {
        const n = Number(value);
        return isNaN(n) ? 0 : n;
    }

    function formatInt(value) {
        return toNumber(value).toLocaleString('es-MX', {
            maximumFractionDigits: 0
        });
    }

    function formatKg(value) {
        return toNumber(value).toLocaleString('es-MX', {
            minimumFractionDigits: 3,
            maximumFractionDigits: 3
        });
    }

    function setTableMessage(text) {
        const body = document.getElementById('avisosBody');
        if (!body) return;

        body.innerHTML = `
            <tr>
                <td colspan="10" class="text-center">${escapeHtml(text)}</td>
            </tr>
        `;
    }

    function setBuscando(on, text = '') {
        const btn = document.getElementById('btnBuscarAvisos');
        if (!btn) return;

        btn.disabled = !!on;
        btn.textContent = on
            ? (text || '⏳ Cargando...')
            : '🔎 Buscar';
    }

    function setEstadoTif(tipo, texto, mostrarSpinner = false) {
        const box = document.getElementById('estadoCargaTif');
        const icono = document.getElementById('estadoCargaTifIcono');
        const label = document.getElementById('estadoCargaTifTexto');

        if (!box || !icono || !label) return;

        if (!texto) {
            box.className = 'tif-status is-hidden';
            icono.innerHTML = '';
            label.textContent = '';
            return;
        }

        const tipoSeguro = ['loading', 'success', 'warning', 'danger'].includes(tipo)
            ? tipo
            : 'loading';

        box.className = 'tif-status status-' + tipoSeguro;
        icono.innerHTML = mostrarSpinner
            ? '<span class="tif-spinner" aria-hidden="true"></span>'
            : (tipoSeguro === 'success'
                ? '✓'
                : (tipoSeguro === 'warning' ? '⚠' : (tipoSeguro === 'danger' ? '✕' : 'ℹ')));

        label.textContent = texto;
    }

    function renderResumen(data, rows) {
        const totalSolicitudes = pick(data, 'totalSolicitudes', 'TotalSolicitudes') || (rows ? rows.length : 0);
        const totalCajas = pick(data, 'totalCajas', 'TotalCajas');
        const totalKg = pick(data, 'totalKg', 'TotalKg');

        const kpiSolicitudes = document.getElementById('kpiSolicitudes');
        const kpiCajas = document.getElementById('kpiCajas');
        const kpiKg = document.getElementById('kpiKg');

        if (kpiSolicitudes) kpiSolicitudes.textContent = formatInt(totalSolicitudes);
        if (kpiCajas) kpiCajas.textContent = formatInt(totalCajas);
        if (kpiKg) kpiKg.textContent = formatKg(totalKg);
    }

    function renderAvisos(rows, seleccionadasPrevias = []) {
        const body = document.getElementById('avisosBody');
        if (!body) return;

        const seleccionSet = new Set(
            (seleccionadasPrevias || []).map(x => String(x || '').trim())
        );

        if (!rows || !rows.length) {
            setTableMessage('Sin avisos para el rango seleccionado.');
            actualizarKpiSeleccionadas();
            return;
        }

        body.innerHTML = rows.map(x => {
            const id = pick(x, 'solicitudSurtidoId', 'SolicitudSurtidoId');
            const fechaVenta = pick(x, 'fechaVentaTxt', 'FechaVentaTxt');
            const venta = pick(x, 'venta', 'Venta');
            const cliente = pick(x, 'cliente', 'Cliente');
            const totalPartidas = pick(x, 'totalPartidas', 'TotalPartidas');
            const totalCajas = pick(x, 'totalCajas', 'TotalCajas');
            const totalKg = pick(x, 'totalKg', 'TotalKg');
            const planta = pick(x, 'planta', 'Planta', 'origen', 'Origen') || getPlantaActual();
            const plantaNombre = getNombrePlanta(planta);
            const checked = seleccionSet.has(String(id || '').trim()) ? ' checked' : '';

            return `
                <tr data-id="${escapeHtml(id)}" data-venta="${escapeHtml(venta)}" data-planta="${escapeHtml(normalizePlanta(planta))}">
                    <td class="text-center">
                        <input type="checkbox" class="ck-aviso" value="${escapeHtml(id)}"${checked} />
                    </td>
                    <td title="${escapeHtml(plantaNombre)}">${escapeHtml(plantaNombre)}</td>
                    <td title="${escapeHtml(fechaVenta)}">${escapeHtml(fechaVenta)}</td>
                    <td title="${escapeHtml(id)}"><strong>${escapeHtml(id)}</strong></td>
                    <td title="${escapeHtml(venta)}">${escapeHtml(venta)}</td>
                    <td title="${escapeHtml(cliente)}">${escapeHtml(cliente)}</td>
                    <td class="text-end">${formatInt(totalPartidas)}</td>
                    <td class="text-end">${formatInt(totalCajas)}</td>
                    <td class="text-end">${formatKg(totalKg)}</td>
                    <td class="text-end">
                        <div class="pm-actions">
                            <button type="button" class="pm-btn pm-btn-warning js-detalle-aviso" data-id="${escapeHtml(id)}">🔎 Detalle</button>
                            <button type="button" class="pm-btn pm-btn-primary js-pdf-aviso" data-id="${escapeHtml(id)}">📄 PDF</button>
                        </div>
                    </td>
                </tr>
            `;
        }).join('');

        document.querySelectorAll('.ck-aviso').forEach(x => {
            x.addEventListener('change', actualizarKpiSeleccionadas);
        });

        document.querySelectorAll('.js-detalle-aviso').forEach(btn => {
            btn.addEventListener('click', () => verDetalleAviso(btn.dataset.id));
        });

        document.querySelectorAll('.js-pdf-aviso').forEach(btn => {
            btn.addEventListener('click', () => abrirPdfAviso(btn.dataset.id));
        });

        actualizarKpiSeleccionadas();
    }

    async function readResponse(res) {
        const ct = (res.headers.get('content-type') || '').toLowerCase();
        const t = await res.text();

        if (ct.includes('application/json')) {
            try { return JSON.parse(t); }
            catch { return { ok: false, msg: 'Respuesta JSON inválida.', detalle: t }; }
        }

        try { return JSON.parse(t); }
        catch { return { ok: false, msg: t || 'Respuesta no JSON.' }; }
    }

    async function cargarAvisos() {
        const form = document.getElementById('filtrosAvisosForm');
        if (!form) return;

        avisosAbortController?.abort();
        avisosAbortController = new AbortController();

        const requestVersion = ++avisosRequestVersion;
        const signal = avisosAbortController.signal;
        const params = appendOrigenParams(new URLSearchParams(new FormData(form)));
        const sourceActual = getPlantaActual();

        /*
         * La tabla principal no muestra fechas de sacrificio, producción o
         * caducidad. Por eso P1 carga únicamente datos locales aquí.
         * Las fechas TIF se consultan progresivamente al abrir Detalle.
         */
        params.set('cargarTif', 'false');
        params.set('tamanoLote', '50');

        hideLog();
        setEstadoTif('', '');
        setBuscando(true, sourceActual === 'P1'
            ? '⏳ Cargando local...'
            : '⏳ Cargando...');
        setTableMessage(sourceActual === 'P1'
            ? 'Cargando información local de Planta 1...'
            : 'Cargando avisos de Planta TIF...');
        renderResumen({ totalSolicitudes: 0, totalCajas: 0, totalKg: 0 }, []);

        try {
            const res = await fetch(URL_DATA + '?' + params.toString(), {
                method: 'GET',
                headers: { 'Accept': 'application/json' },
                cache: 'no-store',
                signal
            });

            const data = await readResponse(res);

            if (requestVersion !== avisosRequestVersion) return;

            if (!res.ok || data.ok === false) {
                throw new Error(
                    data.msg ||
                    data.error ||
                    data.detalle ||
                    'No se pudieron cargar los avisos.'
                );
            }

            const rows = Array.isArray(data)
                ? data
                : (data.rows || data.Rows || []);

            renderResumen(data, rows);
            renderAvisos(rows);

            if (sourceActual === 'P1') {
                setEstadoTif(
                    'success',
                    ''
                );
            } else {
                setEstadoTif(
                    'success',
                    ''
                );
            }
        }
        catch (e) {
            if (e?.name === 'AbortError') return;
            if (requestVersion !== avisosRequestVersion) return;

            setTableMessage('No se pudieron cargar los avisos.');
            setEstadoTif('danger', 'No fue posible cargar la información.');
            showLog('danger', 'Error al cargar avisos: ' + (e?.message || e));
        }
        finally {
            if (requestVersion === avisosRequestVersion) {
                setBuscando(false);
            }
        }
    }

    function getSeleccionadas() {
        return Array.from(document.querySelectorAll('.ck-aviso:checked'))
            .map(x => x.value)
            .filter(x => x);
    }

    function actualizarKpiSeleccionadas() {
        const total = getSeleccionadas().length;
        const value = document.getElementById('kpiSeleccionadas');
        const card = document.getElementById('kpiSeleccionadasCard');

        if (value) {
            value.textContent = total.toLocaleString('es-MX');
        }

        if (card) {
            card.classList.toggle('has-selection', total > 0);
        }
    }

    function selectAllAvisos(on) {
        document.querySelectorAll('.ck-aviso').forEach(x => x.checked = !!on);
        actualizarKpiSeleccionadas();
    }

    function setDetalleProgress(tipo, texto) {
        const box = document.getElementById('detalleTifProgress');
        if (!box) return;

        if (!texto) {
            box.style.display = 'none';
            box.className = 'detalle-progress';
            box.textContent = '';
            return;
        }

        box.style.display = 'block';
        box.className = 'detalle-progress ' + (
            tipo === 'loading'
                ? 'is-loading'
                : (tipo === 'success'
                    ? 'is-success'
                    : (tipo === 'warning' ? 'is-warning' : ''))
        );
        box.textContent = texto;
    }

    function detalleBool(value) {
        return value === true ||
               value === 1 ||
               String(value || '').trim().toLowerCase() === 'true' ||
               String(value || '').trim() === '1';
    }

    function getDetalleKey(x, index = 0) {
        const serverKey = pick(x, 'detalleKey', 'DetalleKey');
        if (serverKey) return String(serverKey);

        return [
            pick(x, 'solicitudSurtidoId', 'SolicitudSurtidoId'),
            pick(x, 'sku', 'Sku'),
            pick(x, 'lote', 'Lote'),
            pick(x, 'fechaProduccionTxt', 'FechaProduccionTxt'),
            index
        ].join('|');
    }

    function getDetalleLote(x) {
        return String(pick(x, 'lote', 'Lote') || '').trim();
    }

    function getDetalleSku(x) {
        return String(pick(x, 'sku', 'Sku') || '').trim();
    }

    function renderDetalleRows(rows) {
        const body = document.getElementById('detalleBody');

        if (!rows || !rows.length) {
            body.innerHTML =
                '<tr><td colspan="8" class="text-center">Sin detalle.</td></tr>';
            return;
        }

        body.innerHTML = rows.map((x, index) => {
            const key = getDetalleKey(x, index);
            const lote = getDetalleLote(x);
            const requiereTif = detalleBool(pick(x, 'requiereTif', 'RequiereTif'));
            const estadoTif = String(pick(x, 'estadoTif', 'EstadoTif') || '');
            const statusHtml = requiereTif
                ? `<span class="detalle-row-status is-pending"
                         data-role="estado-tif">
                       <span class="detalle-mini-spinner"></span>
                       TIF pendiente
                   </span>`
                : `<span class="detalle-row-status is-complete"
                         data-role="estado-tif"></span>`;

            return `
                <tr data-detalle-key="${escapeHtml(key)}"
                    data-lote="${escapeHtml(lote)}"
                    data-sku="${escapeHtml(getDetalleSku(x))}"
                    data-requiere-tif="${requiereTif ? '1' : '0'}">
                    <td>${escapeHtml(pick(x, 'sku', 'Sku'))}</td>
                    <td>${escapeHtml(pick(x, 'producto', 'Producto'))}</td>
                    <td>${escapeHtml(lote)}</td>

                    <td class="detalle-fecha" data-role="fecha-sacrificio">
                        <div class="detalle-fecha-wrap">
                            <span class="detalle-fecha-local"
                                  data-role="valor">${escapeHtml(pick(x, 'fechaSacrificioTxt', 'FechaSacrificioTxt')) || '-'}</span>
                            ${statusHtml}
                        </div>
                    </td>

                    <td class="detalle-fecha" data-role="fecha-produccion">
                        <span class="detalle-fecha-local"
                              data-role="valor">${escapeHtml(pick(x, 'fechaProduccionTxt', 'FechaProduccionTxt')) || '-'}</span>
                    </td>

                    <td class="detalle-fecha" data-role="fecha-caducidad">
                        <span class="detalle-fecha-local"
                              data-role="valor">${escapeHtml(pick(x, 'fechaCaducidadTxt', 'FechaCaducidadTxt')) || '-'}</span>
                    </td>

                    <td class="text-end">${formatInt(pick(x, 'cuentaDeEtiqueta', 'CuentaDeEtiqueta'))}</td>
                    <td class="text-end">${formatKg(pick(x, 'sumaDeKg', 'SumaDeKg'))}</td>
                </tr>
            `;
        }).join('');
    }

    function setDetalleLoteEstado(lote, tipo, texto) {
        const rows = Array.from(document.querySelectorAll('#detalleBody tr[data-lote]'))
            .filter(tr => (tr.dataset.lote || '') === lote);

        rows.forEach(tr => {
            const badge = tr.querySelector('[data-role="estado-tif"]');
            if (!badge) return;

            badge.className = 'detalle-row-status ' + (
                tipo === 'complete'
                    ? 'is-complete'
                    : (tipo === 'error' ? 'is-error' : 'is-pending')
            );

            badge.innerHTML = tipo === 'pending'
                ? '<span class="detalle-mini-spinner"></span>' + escapeHtml(texto || 'Consultando TIF')
                : escapeHtml(texto || '');
        });
    }

    function actualizarFilaDetalleDesdeTif(x, index = 0) {
        const key = getDetalleKey(x, index);
        const selector = `#detalleBody tr[data-detalle-key="${CSS.escape(key)}"]`;
        let tr = document.querySelector(selector);

        /*
         * El registro_key es la coincidencia principal. Como respaldo,
         * intenta SKU + lote cuando una base antigua todavía no lo devuelve.
         */
        if (!tr) {
            const lote = getDetalleLote(x);
            const sku = getDetalleSku(x);

            tr = Array.from(document.querySelectorAll('#detalleBody tr[data-lote][data-sku]'))
                .find(row =>
                    (row.dataset.lote || '') === lote &&
                    (row.dataset.sku || '') === sku &&
                    row.dataset.tifActualizado !== '1'
                );
        }

        if (!tr) return false;

        const values = [
            ['fecha-sacrificio', pick(x, 'fechaSacrificioTxt', 'FechaSacrificioTxt')],
            ['fecha-produccion', pick(x, 'fechaProduccionTxt', 'FechaProduccionTxt')],
            ['fecha-caducidad', pick(x, 'fechaCaducidadTxt', 'FechaCaducidadTxt')]
        ];

        values.forEach(([role, value]) => {
            const target = tr.querySelector(`[data-role="${role}"] [data-role="valor"]`);
            if (!target) return;

            target.textContent = value || '-';
            target.className = 'detalle-fecha-tif';
        });

        const estado = String(pick(x, 'estadoTif', 'EstadoTif') || '').toUpperCase();
        const mensaje = String(pick(x, 'mensajeTif', 'MensajeTif') || '');

        const badge = tr.querySelector('[data-role="estado-tif"]');
        if (badge) {
            if (estado === 'ERROR TIF') {
                badge.className = 'detalle-row-status is-error';
                badge.textContent = 'Error TIF';
                badge.title = mensaje;
            } else if (estado === 'SIN COINCIDENCIA') {
                badge.className = 'detalle-row-status is-error';
                badge.textContent = 'Sin coincidencia';
                badge.title = mensaje;
            } else {
                badge.className = 'detalle-row-status is-complete';
                // badge.textContent = 'TIF actualizado';
                badge.textContent = '';
                badge.title = mensaje;
            }
        }

        tr.dataset.tifActualizado = '1';
        return true;
    }

    async function enriquecerDetalleTifPorLotes(
        id,
        rowsLocales,
        paramsBase,
        requestVersion,
        signal
    ) {
        const pendientes = rowsLocales.filter(x =>
            detalleBool(pick(x, 'requiereTif', 'RequiereTif'))
        );

        const lotes = Array.from(new Set(
            pendientes
                .map(getDetalleLote)
                .filter(x => x && x.toUpperCase() !== 'SIN LOTE')
        ));

        if (!lotes.length) {
            setDetalleProgress(
                'success',
                'El detalle local está completo; no hay lotes pendientes de consultar en TIF.'
            );
            return;
        }

        let completados = 0;
        let errores = 0;

        for (const loteActual of lotes) {
            if (requestVersion !== detalleRequestVersion || signal.aborted) return;

            setDetalleLoteEstado(loteActual, 'pending', 'Consultando TIF');
            // setDetalleProgress(
            //     'loading',
            //     `Mostrando datos locales. Consultando TIF lote ${completados + 1} de ${lotes.length}: ${loteActual}`
            // );

            const paramsTif = new URLSearchParams(paramsBase);
            paramsTif.set('id', id);
            paramsTif.set('lote', loteActual);
            paramsTif.set('cargarTif', 'true');
            paramsTif.set('tamanoLote', '50');

            try {
                const res = await fetch(URL_DETALLE + '?' + paramsTif.toString(), {
                    headers: { 'Accept': 'application/json' },
                    cache: 'no-store',
                    signal
                });

                const data = await readResponse(res);

                if (requestVersion !== detalleRequestVersion || signal.aborted) return;

                if (!res.ok || !data.ok) {
                    throw new Error(
                        data.msg ||
                        data.error ||
                        `No se pudo consultar TIF para el lote ${loteActual}.`
                    );
                }

                const rowsTif = data.rows || data.Rows || [];

                if (!rowsTif.length) {
                    errores++;
                    setDetalleLoteEstado(loteActual, 'error', 'Sin coincidencia TIF');
                    continue;
                }

                rowsTif.forEach((x, index) => {
                    actualizarFilaDetalleDesdeTif(x, index);
                });

                // setDetalleLoteEstado(loteActual, 'complete', 'TIF actualizado');
                 setDetalleLoteEstado(loteActual, 'complete', '');
                completados++;
            }
            catch (e) {
                if (e?.name === 'AbortError') return;

                errores++;
                setDetalleLoteEstado(loteActual, 'error', 'Error TIF');

                console.error(
                    `Error al enriquecer lote ${loteActual}:`,
                    e
                );
            }
        }

        if (requestVersion !== detalleRequestVersion || signal.aborted) return;

        if (errores > 0) {
            setDetalleProgress(
                'warning',
                `Detalle local visible. TIF completó ${completados} lote(s) y no pudo completar ${errores}.`
            );
        } else {
            // setDetalleProgress(
            //     'success',
            //     `Fechas TIF actualizadas progresivamente para ${completados} lote(s).`
            // );
        }
    }

    async function verDetalleAviso(id) {
        if (!id) return;

        detalleAbortController?.abort();
        detalleAbortController = new AbortController();

        const requestVersion = ++detalleRequestVersion;
        const signal = detalleAbortController.signal;

        document.getElementById('detalleSolicitud').textContent = id;
        document.getElementById('detalleCajas').textContent = '0';
        document.getElementById('detalleKg').textContent = '0';
        document.getElementById('detalleBody').innerHTML =
            '<tr><td colspan="8" class="text-center">Cargando información local...</td></tr>';

        // setDetalleProgress(
        //     'loading',
        //     'Cargando partidas locales. No se está esperando a TIF.'
        // );

        bootstrap.Modal
            .getOrCreateInstance(document.getElementById('detalleAvisoModal'))
            .show();

        try {
            const paramsLocal = getFiltroAvisosParams();
            paramsLocal.set('id', id);
            paramsLocal.set('cargarTif', 'false');
            paramsLocal.set('tamanoLote', '50');

            const res = await fetch(URL_DETALLE + '?' + paramsLocal.toString(), {
                headers: { 'Accept': 'application/json' },
                cache: 'no-store',
                signal
            });

            const data = await readResponse(res);

            if (requestVersion !== detalleRequestVersion) return;

            if (!res.ok || !data.ok) {
                throw new Error(
                    data.msg ||
                    data.error ||
                    'No se pudo cargar el detalle local.'
                );
            }

            document.getElementById('detalleCajas').textContent =
                formatInt(data.totalCajas ?? data.TotalCajas);

            document.getElementById('detalleKg').textContent =
                formatKg(data.totalKg ?? data.TotalKg);

            const rowsLocal = data.rows || data.Rows || [];

            renderDetalleRows(rowsLocal);

            if (!rowsLocal.length) {
                setDetalleProgress('warning', 'No se encontraron partidas locales.');
                return;
            }

            if (getPlantaActual() !== 'P1') {
                setDetalleProgress(
                    'success',
                    ''
                );
                return;
            }

            // No se bloquea el modal: las filas locales ya están visibles.
            await enriquecerDetalleTifPorLotes(
                id,
                rowsLocal,
                paramsLocal,
                requestVersion,
                signal
            );
        }
        catch (e) {
            if (e?.name === 'AbortError') return;
            if (requestVersion !== detalleRequestVersion) return;

            document.getElementById('detalleBody').innerHTML =
                '<tr><td colspan="8" class="text-center">No se pudo cargar el detalle local.</td></tr>';

            setDetalleProgress(
                'warning',
                'No fue posible cargar las partidas locales: ' + (e?.message || e)
            );
        }
    }

    function abrirPdfAviso(id) {
        if (!id) return;
        const params = getFiltroAvisosParams();
        params.set('ids', id);
        window.open(URL_PDF + '?' + params.toString(), '_blank');
    }

    function abrirPdfSeleccionados() {
        const ids = getSeleccionadas();

        if (!ids.length) {
            alert('Selecciona al menos una solicitud para generar PDF.');
            return;
        }

        const params = getFiltroAvisosParams();
        params.set('ids', ids.join(','));
        window.open(URL_PDF + '?' + params.toString(), '_blank');
    }

    function abrirEnvioMedico() {
        const ids = getSeleccionadas();

        if (!ids.length) {
            alert('Selecciona al menos una solicitud para enviar al médico.');
            return;
        }

        document.getElementById('totalSeleccionadasEnvio').textContent = ids.length;
        document.getElementById('listaSeleccionadasEnvio').textContent = getNombrePlanta(getPlantaActual()) + ': ' + ids.join(', ');

        bootstrap.Modal.getOrCreateInstance(document.getElementById('envioMedicoModal')).show();
    }

    function abrirPdfDesdeModal() {
        const ids = getSeleccionadas();

        if (!ids.length) {
            alert('Selecciona al menos una solicitud.');
            return;
        }

        const comentarios = document.getElementById('comentariosEnvio')?.value || '';

        const params = getFiltroAvisosParams();
        params.set('ids', ids.join(','));
        params.set('comentarios', comentarios);

        window.open(URL_PDF + '?' + params.toString(), '_blank');
    }

    async function enviarAvisosMedico() {
        const ids = getSeleccionadas();

        if (!ids.length) {
            alert('Selecciona al menos una solicitud.');
            return;
        }

        const correoMedico = document.getElementById('correoMedico')?.value || '';
        const comentarios = document.getElementById('comentariosEnvio')?.value || '';
        const origenActual = syncOrigenFields();

        if (!correoMedico) {
            alert('Captura el correo del médico SENASICA.');
            return;
        }

        if (!confirm(`¿Enviar ${ids.length} aviso(s) de movilización al médico SENASICA?`)) {
            return;
        }

        showLog('info', 'Enviando avisos de movilización...');

        try {
            const paramsEnvio = getFiltroAvisosParams();

            const res = await fetch(URL_ENVIAR + '?' + paramsEnvio.toString(), {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    solicitudes: ids,
                    correoMedico,
                    comentarios,
                    source: origenActual.planta,
                    planta: origenActual.planta,
                    origen: origenActual.nombre
                })
            });

            const data = await readResponse(res);

            if (res.ok && data.ok) {
                showLog('success', data.msg || 'Avisos enviados correctamente.');
                bootstrap.Modal.getInstance(document.getElementById('envioMedicoModal'))?.hide();
            } else {
                showLog(
                    'danger',
                    (data.msg || 'No se pudieron enviar los avisos.')
                    + '\n\nError: ' + (data.error || '')
                    + '\n\nInner: ' + (data.inner || '')
                    + '\n\nDetalle: ' + (data.detalle || '')                );
            }

        } catch (e) {
            showLog('danger', 'Error de red al enviar avisos: ' + e.message);
        }
    }


    function getSolicitudesSeleccionadasAviso() {
        return Array.from(document.querySelectorAll('.ck-aviso:checked'))
            .map(x => (x.value || '').trim())
            .filter(x => x)
            .filter((x, i, arr) => arr.indexOf(x) === i);
    }

    function getFileNameFromDispositionAviso(disposition) {
        if (!disposition) return null;

        const match = /filename\*?=(?:UTF-8''|")?([^\";]+)"?/i.exec(disposition);
        if (!match || !match[1]) return null;

        try { return decodeURIComponent(match[1]); }
        catch { return match[1]; }
    }

    async function descargarBlobAvisoMovilizacion(url) {
        showLog('info', 'Generando Aviso de Movilización ' + getNombrePlanta(getPlantaActual()) + '...');

        try {
            const resp = await fetch(url, {
                method: 'GET',
                credentials: 'same-origin',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                cache: 'no-store'
            });

            if (!resp.ok) {
                const txt = await resp.text().catch(() => '');
                throw new Error(txt || resp.statusText || 'No se pudo generar el archivo.');
            }

            const blob = await resp.blob();
            const disposition = resp.headers.get('content-disposition');
            const serverName = getFileNameFromDispositionAviso(disposition);
            const filename = serverName || ('AvisoMovilizacion_' + getPlantaActual() + '.xlsx');

            const blobUrl = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = blobUrl;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            a.remove();
            window.URL.revokeObjectURL(blobUrl);

            showLog('success', 'Aviso de Movilización ' + getNombrePlanta(getPlantaActual()) + ' generado correctamente.');
        } catch (err) {
            showLog('danger', 'No se pudo generar el Aviso de Movilización ' + getNombrePlanta(getPlantaActual()) + '.\n\n' + err.message);
        }
    }

    function descargarExcelAvisoMovilizacion() {
        const solicitudes = getSolicitudesSeleccionadasAviso();

        if (!solicitudes.length) {
            alert('Selecciona al menos una solicitud para generar el Aviso de Movilización.');
            return;
        }

        const params = getFiltroAvisosParams();
        params.set('ids', solicitudes.join(','));

        const url = URL_EXCEL_AVISO + '?' + params.toString();
        descargarBlobAvisoMovilizacion(url);
    }

    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('detalleAvisoModal')?.addEventListener('hidden.bs.modal', () => {
            detalleAbortController?.abort();
            detalleAbortController = null;
            detalleRequestVersion++;
            setDetalleProgress('', '');
        });

        document.getElementById('filtrosAvisosForm')?.addEventListener('submit', e => {
            e.preventDefault();
            cargarAvisos();
        });

        document.getElementById('origenPlanta')?.addEventListener('change', () => {
            selectAllAvisos(false);
            cargarAvisos();
        });

        syncOrigenFields();
        actualizarKpiSeleccionadas();
        cargarAvisos();
    });
</script>