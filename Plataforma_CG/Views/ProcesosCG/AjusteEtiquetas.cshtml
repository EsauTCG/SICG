                <div class="ae-field">
                    <label for="aeSearchInput">ProduccionId o código de etiqueta</label>
                    <input id="aeSearchInput"
                           class="ae-input"
                           type="search"
                           autocomplete="off"
                           placeholder="Ej. 3594180 o DEST00002474053301" />
