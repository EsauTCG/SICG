        </section>



        <section class="ae-card ae-search-card ae-hidden" id="aeBulkSearchCard">
            <div class="ae-bulk-grid">
                <div class="ae-field">
                    <label for="aeBulkInput">ProduccionId o códigos de etiqueta</label>
                    <textarea id="aeBulkInput"
                              class="ae-textarea ae-bulk-input"
                              autocomplete="off"
                              spellcheck="false"
                              placeholder="Pega un valor por línea. También acepta comas, punto y coma o tabulaciones.

                    Ejemplo:
                    3594180
                    DEST00002474053301
                    3594182"></textarea>
                    <small style="display:block;margin-top:5px;color:var(--ae-muted);font-size:10.5px;font-weight:750">
                        Máximo 100 valores por operación. Los duplicados se eliminan automáticamente.
                    </small>
                </div>
                <div class="ae-bulk-actions">
                    <button type="button" class="ae-btn primary" id="btnAeBulkLoad">
                        <i class="fa-solid fa-list-check"></i> Validar lista
                    </button>
                    <button type="button" class="ae-btn secondary" id="btnAeBulkClear">
                        <i class="fa-solid fa-eraser"></i> Limpiar lista
                    </button>
                </div>
            </div>
        </section>

        <section class="ae-card ae-hidden" id="aeBulkResultsCard">
            <div class="ae-card-title">
                <strong><i class="fa-solid fa-clipboard-check me-1"></i> Validación de etiquetas</strong>
                <small id="aeBulkTitleState">Sin lista</small>
            </div>
            <div class="ae-bulk-summary" id="aeBulkSummary">
                <span class="ae-chip info">Pega y valida una lista para comenzar.</span>
            </div>
            <div class="ae-table-wrap">
                <table class="ae-table ae-bulk-table">
                    <thead>
                        <tr>
                            <th style="width:42px;text-align:center">
                                <input type="checkbox" id="aeBulkSelectAll" title="Seleccionar elegibles" />
                            </th>
                            <th>Valor capturado</th>
                            <th>ProduccionId</th>
                            <th>Código etiqueta</th>
                            <th>Fecha</th>
                            <th>Almacén</th>
                            <th>Estado</th>
                            <th>Resultado</th>
                        </tr>
                    </thead>
                    <tbody id="aeBulkBody">
                        <tr><td colspan="8"><div class="ae-loading">Sin valores validados.</div></td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section class="ae-main-grid">
            <article class="ae-card">
                <div class="ae-card-title">
                    <strong><i class="fa-solid fa-box-open me-1"></i> Información actual de la etiqueta</strong>
                    <small id="aePlantLabel">Planta @sourceInicial</small>
                </div>

                <div id="aeDetailContent" class="ae-empty">
                    <div>
                        <i class="fa-solid fa-barcode"></i>
                        <strong>Consulta una etiqueta para comenzar</strong>
                        <div style="margin-top:6px;font-size:11.5px">
                            Puedes buscar por ProduccionId o por CódigoEtiqueta.
                        </div>
                    </div>
                </div>
            </article>

            <article class="ae-card">
                <div class="ae-card-title">
                    <strong><i class="fa-solid fa-screwdriver-wrench me-1"></i> Operación autorizada</strong>
                    <small id="aeOperationState">Sin etiqueta</small>
                </div>

                <div class="ae-operation-body">
                    <div class="ae-action-switch">
                        <label class="ae-action-option" id="aeDeleteOption">
                            <input type="radio" name="aeAction" value="ELIMINAR" checked />
                            <i class="fa-solid fa-trash-can"></i>
                            Eliminar etiqueta
                        </label>
                        <label class="ae-action-option" id="aeActivateOption">
                            <input type="radio" name="aeAction" value="ACTIVAR" />
                            <i class="fa-solid fa-rotate-left"></i>
                            Activar etiqueta
                        </label>
                    </div>

                    <div class="ae-form-stack">
                        <div class="ae-field">
                            <label for="aeReason">Motivo obligatorio</label>
                            <textarea id="aeReason"
                                      class="ae-textarea"
                                      maxlength="1000"
                                      placeholder="Describe claramente por qué se realiza el ajuste…"
                                      disabled></textarea>
                        </div>

                        <div class="ae-danger-box" id="aeDeleteBox">
                            <p>
                                La eliminación lógica cambia <b>Estatus a 0</b>, <b>UltimoProcesoId a 29</b> y
                                <b>PesoNeto a 0.01</b>. En ProduccionLog se conserva el peso y estatus anteriores.
                            </p>
                            <div class="ae-field">
                                <label for="aeConfirmDelete">Escribe ELIMINAR para confirmar</label>
                                <input id="aeConfirmDelete" class="ae-input" autocomplete="off" disabled />
                            </div>
                            <div class="ae-history-auth" id="aeHistoryAuthBox">
                                <div class="ae-field">
                                    <label for="aeHistoricalAuthorization">Etiqueta de otro día: escribe AUTORIZAR</label>
                                    <input id="aeHistoricalAuthorization"
                                           class="ae-input"
                                           autocomplete="off"
                                           placeholder="AUTORIZAR"
                                           disabled />
                                </div>
                            </div>
                        </div>

                        <div class="ae-activate-box" id="aeActivateBox">
                            <p>
                                La activación cambia <b>Estatus a 1</b>, <b>UltimoProcesoId a 20</b> y el <b>PesoNeto</b> capturado.
                                En ProduccionLog se registra <b>ProcesoId 20</b> y <b>DeviceId Sistema SIGO</b>.
                            </p>
                            <div class="ae-field">
                                <label for="aeNewWeight">Peso neto correcto (kg)</label>
                                <input id="aeNewWeight"
                                       class="ae-input"
                                       type="number"
                                       min="0.001"
                                       step="0.001"
                                       inputmode="decimal"
                                       placeholder="Ej. 20.688"
                                       disabled />
                            </div>
                            <div class="ae-field" style="margin-top:9px">
                                <label for="aeConfirmActivate">Escribe ACTIVAR para confirmar</label>
                                <input id="aeConfirmActivate" class="ae-input" autocomplete="off" disabled />
                            </div>
                        </div>

                        <button type="button" class="ae-btn success" id="btnAeApply" disabled>
                            <i class="fa-solid fa-shield-halved"></i> Aplicar ajuste controlado
                        </button>
