@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Ajuste controlado de etiquetas";
    var sourceInicial = ((ViewBag.Source as string) ?? "P1").Trim().ToUpperInvariant();
}

@Html.AntiForgeryToken()

<style>
    :root {
        --ae-brand-950: #3d0000;
        --ae-brand-900: #550000;
        --ae-brand-800: #700000;
        --ae-brand-700: #8b0000;
        --ae-brand-600: #aa0909;
        --ae-bg: #edf0f4;
        --ae-panel: #ffffff;
        --ae-panel-soft: #fff8f8;
        --ae-line: #d8c3c3;
        --ae-text: #321515;
        --ae-muted: #765858;
        --ae-green: #147a48;
        --ae-yellow: #b87600;
        --ae-red: #c52222;
        --ae-blue: #175cd3;
        --ae-purple: #6d3bb3;
        --ae-shadow: 0 16px 36px rgba(61, 0, 0, .13);
    }

    html,
    body {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow-x: hidden;
    }

    /*
          Estas clases se agregan por JavaScript únicamente a los contenedores
          de _Layout2 que envuelven esta vista. Así quitamos el max-width de
          Bootstrap sin afectar permanentemente las demás pantallas del sistema.
        */
    .ae-layout-host {
        min-width: 0 !important;
        max-width: none !important;
        box-sizing: border-box !important;
        background: transparent !important;
        box-shadow: none !important;
        border: 0 !important;
    }

        .ae-layout-host.container,
        .ae-layout-host.container-fluid,
        .ae-layout-host.container-sm,
        .ae-layout-host.container-md,
        .ae-layout-host.container-lg,
        .ae-layout-host.container-xl,
        .ae-layout-host.container-xxl,
        .ae-layout-host.body-content,
        .ae-layout-host.pb-3 {
            width: 100% !important;
            max-width: none !important;
            margin-left: 0 !important;
            margin-right: 0 !important;
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        .ae-layout-host.pb-3 {
            padding-bottom: 0 !important;
        }

    .ae-page,
    .ae-page * {
        box-sizing: border-box;
    }

    .ae-page {
        --ae-layout-top: 76px;
        width: 100%;
        max-width: none;
        min-width: 0;
        min-height: calc(100dvh - var(--ae-layout-top));
        margin: 0;
        padding: clamp(7px, .8vw, 13px);
        overflow-x: hidden;
        color: var(--ae-text);
        background: radial-gradient(circle at top right, rgba(139, 0, 0, .09), transparent 33%), linear-gradient(135deg, #f4f6f8 0%, #eceff3 55%, #e5e9ee 100%);
        font-family: Inter, "Segoe UI", Arial, sans-serif;
    }

    .ae-shell {
        width: 100%;
        min-width: 0;
        display: grid;
        gap: 12px;
    }

    .ae-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 16px;
        align-items: center;
        padding: 16px 18px;
        border: 1px solid #5f0000;
        border-radius: 18px;
        color: #fff;
        background: linear-gradient(115deg, rgba(255,255,255,.09), transparent 42%), linear-gradient(110deg, var(--ae-brand-950), var(--ae-brand-700) 56%, #400000);
        box-shadow: var(--ae-shadow);
    }

    .ae-title h1 {
        margin: 0;
        font-size: clamp(20px, 1.8vw, 30px);
        line-height: 1.12;
        font-weight: 950;
        letter-spacing: -.025em;
    }

    .ae-title p {
        max-width: 950px;
        margin: 7px 0 0;
        color: rgba(255,255,255,.78);
        font-size: 12px;
        line-height: 1.45;
        font-weight: 650;
    }

    .ae-header-actions {
        display: flex;
        gap: 8px;
        align-items: center;
        justify-content: flex-end;
        flex-wrap: wrap;
    }

    .ae-card {
        min-width: 0;
        border: 1px solid var(--ae-line);
        border-radius: 16px;
        background: rgba(255,255,255,.97);
        box-shadow: 0 10px 26px rgba(70, 20, 20, .08);
        overflow: hidden;
    }

    .ae-card-title {
        min-height: 44px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 10px 13px;
        color: #fff;
        background: linear-gradient(180deg, #b00000 0%, #850000 58%, #5c0000 100%);
        border-bottom: 1px solid #4f0000;
    }

        .ae-card-title strong {
            font-size: 12px;
            font-weight: 950;
            text-transform: uppercase;
            letter-spacing: .045em;
        }

        .ae-card-title small {
            color: rgba(255,255,255,.78);
            font-size: 10.5px;
            font-weight: 800;
        }

    .ae-search-card {
        padding: 13px;
    }

    .ae-search-grid {
        display: grid;
        grid-template-columns: 190px minmax(260px, 1fr) auto;
        gap: 10px;
        align-items: end;
    }

    .ae-field {
        min-width: 0;
    }

        .ae-field label {
            display: block;
            margin-bottom: 5px;
            color: #623737;
            font-size: 10.5px;
            font-weight: 950;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

    .ae-input,
    .ae-select,
    .ae-textarea {
        width: 100%;
        border: 1px solid #cfaeae;
        border-radius: 11px;
        background: #fff;
        color: var(--ae-text);
        font: inherit;
        font-size: 12.5px;
        font-weight: 750;
        outline: none;
        transition: border-color .18s, box-shadow .18s;
    }

    .ae-input,
    .ae-select {
        height: 41px;
        padding: 0 12px;
    }

    .ae-textarea {
        min-height: 92px;
        resize: vertical;
        padding: 10px 12px;
        line-height: 1.4;
    }

        .ae-input:focus,
        .ae-select:focus,
        .ae-textarea:focus {
            border-color: var(--ae-brand-700);
            box-shadow: 0 0 0 3px rgba(139,0,0,.10);
        }

    .ae-btn {
        min-height: 41px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        border: 1px solid transparent;
        border-radius: 11px;
        padding: 0 14px;
        font: inherit;
        font-size: 12px;
        font-weight: 900;
        cursor: pointer;
        white-space: nowrap;
        transition: transform .15s, filter .15s, opacity .15s;
    }

        .ae-btn:hover:not(:disabled) {
            filter: brightness(1.04);
            transform: translateY(-1px);
        }

        .ae-btn:disabled {
            cursor: not-allowed;
            opacity: .46;
        }

        .ae-btn.primary {
            color: #fff;
            border-color: #670000;
            background: linear-gradient(180deg, #b60000, #790000);
        }

        .ae-btn.secondary {
            color: #4d2525;
            border-color: #d2b7b7;
            background: linear-gradient(#fff, #f2e6e6);
        }

        .ae-btn.dark {
            color: #fff;
            border-color: #30343a;
            background: #343a40;
        }

        .ae-btn.danger {
            color: #fff;
            border-color: #8e1616;
            background: linear-gradient(180deg, #dc3030, #a01818);
        }

        .ae-btn.success {
            color: #fff;
            border-color: #116b3e;
            background: linear-gradient(180deg, #1c9158, #126a40);
        }

    .ae-plant-toggle {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5px;
    }

    .ae-plant-btn {
        height: 41px;
        border: 1px solid #cdaaaa;
        border-radius: 10px;
        color: #612b2b;
        background: #fff8f8;
        font-size: 12px;
        font-weight: 950;
        cursor: pointer;
    }

        .ae-plant-btn.active {
            color: #fff;
            border-color: #650000;
            background: linear-gradient(180deg, #b00000, #720000);
            box-shadow: 0 7px 14px rgba(86, 0, 0, .18);
        }

    .ae-permissions {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        align-items: center;
    }

    .ae-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        min-height: 27px;
        padding: 4px 9px;
        border: 1px solid transparent;
        border-radius: 999px;
        font-size: 10.5px;
        font-weight: 900;
    }

        .ae-chip.ok {
            color: #0d6338;
            border-color: #8dd0aa;
            background: #e7f7ed;
        }

        .ae-chip.no {
            color: #8f1c1c;
            border-color: #e4a2a2;
            background: #fdeaea;
        }

        .ae-chip.warn {
            color: #785100;
            border-color: #e7c36d;
            background: #fff3cd;
        }

        .ae-chip.info {
            color: #174c96;
            border-color: #9dbbe8;
            background: #e9f2ff;
        }

    .ae-main-grid {
        display: grid;
        grid-template-columns: minmax(400px, 1.08fr) minmax(360px, .92fr);
        gap: 12px;
        align-items: stretch;
    }

    .ae-empty {
        min-height: 335px;
        display: grid;
        place-items: center;
        padding: 30px;
        text-align: center;
        color: var(--ae-muted);
    }

        .ae-empty i {
            display: block;
            margin-bottom: 12px;
            color: #b08787;
            font-size: 42px;
        }

        .ae-empty strong {
            display: block;
            color: #5b3030;
            font-size: 15px;
        }

    .ae-detail-body,
    .ae-operation-body {
        padding: 13px;
    }

    .ae-status-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 10px;
        margin-bottom: 12px;
    }

    .ae-label-code {
        min-width: 0;
    }

        .ae-label-code span {
            display: block;
            color: var(--ae-muted);
            font-size: 10px;
            font-weight: 950;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .ae-label-code strong {
            display: block;
            margin-top: 4px;
            color: var(--ae-brand-800);
            font-size: clamp(17px, 1.5vw, 24px);
            font-weight: 950;
            overflow-wrap: anywhere;
        }

    .ae-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 29px;
        padding: 5px 10px;
        border-radius: 999px;
        font-size: 10.5px;
        font-weight: 950;
        white-space: nowrap;
    }

        .ae-badge.active {
            color: #0d6338;
            background: #dff5e7;
            border: 1px solid #8ac7a0;
        }

        .ae-badge.inactive {
            color: #8c1d1d;
            background: #fde1e1;
            border: 1px solid #e09a9a;
        }

    .ae-detail-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
    }

    .ae-data {
        min-width: 0;
        padding: 10px;
        border: 1px solid #e1d0d0;
        border-radius: 11px;
        background: #fffafa;
    }

        .ae-data.wide {
            grid-column: span 2;
        }

        .ae-data label {
            display: block;
            margin-bottom: 4px;
            color: var(--ae-muted);
            font-size: 9.5px;
            font-weight: 950;
            text-transform: uppercase;
            letter-spacing: .045em;
        }

        .ae-data strong {
            display: block;
            color: #3e1c1c;
            font-size: 12px;
            font-weight: 900;
            overflow-wrap: anywhere;
        }

    .ae-rule-banner {
        margin-top: 11px;
        display: flex;
        gap: 9px;
        align-items: flex-start;
        padding: 10px 11px;
        border-radius: 11px;
        font-size: 11.5px;
        line-height: 1.4;
        font-weight: 800;
    }

        .ae-rule-banner.today {
            color: #0d6338;
            border: 1px solid #8bc8a3;
            background: #e7f7ed;
        }

        .ae-rule-banner.history-ok {
            color: #785100;
            border: 1px solid #dfbd61;
            background: #fff3cd;
        }

        .ae-rule-banner.history-block {
            color: #8f1d1d;
            border: 1px solid #dda0a0;
            background: #fde9e9;
        }

    .ae-action-switch {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 7px;
        margin-bottom: 12px;
    }

    .ae-action-option {
        min-height: 50px;
        display: flex;
        gap: 8px;
        align-items: center;
        padding: 8px 10px;
        border: 1px solid #dcc6c6;
        border-radius: 12px;
        background: #fffafa;
        color: #542929;
        font-size: 11.5px;
        font-weight: 900;
        cursor: pointer;
    }

        .ae-action-option:has(input:checked) {
            color: #fff;
            border-color: #6c0000;
            background: linear-gradient(180deg, #ad0000, #750000);
        }

        .ae-action-option input {
            accent-color: var(--ae-brand-700);
        }

        .ae-action-option:has(input:disabled) {
            opacity: .48;
            cursor: not-allowed;
            filter: grayscale(.15);
        }

    .ae-form-stack {
        display: grid;
        gap: 10px;
    }

    .ae-danger-box {
        display: none;
        padding: 10px;
        border: 1px solid #e0a0a0;
        border-radius: 11px;
        background: #fff0f0;
    }

        .ae-danger-box.show {
            display: block;
        }


    .ae-activate-box {
        display: none;
        padding: 10px;
        border: 1px solid #8bc8a3;
        border-radius: 11px;
        background: #edf9f1;
    }

        .ae-activate-box.show {
            display: block;
        }

        .ae-activate-box p {
            margin: 0 0 8px;
            color: #12633a;
            font-size: 11px;
            font-weight: 850;
            line-height: 1.4;
        }

    .ae-history-auth {
        display: none;
        margin-top: 9px;
        padding-top: 9px;
        border-top: 1px dashed #d39a9a;
    }

        .ae-history-auth.show {
            display: block;
        }

    .ae-danger-box p {
        margin: 0 0 8px;
        color: #8d2020;
        font-size: 11px;
        font-weight: 850;
        line-height: 1.4;
    }

    .ae-audit-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .ae-table-wrap {
        width: 100%;
        max-height: 340px;
        overflow: auto;
        background: #fff;
        scrollbar-width: thin;
    }

    .ae-table {
        width: max-content;
        min-width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 11px;
    }

        .ae-table th,
        .ae-table td {
            padding: 7px 8px;
            border-right: 1px solid #e3d2d2;
            border-bottom: 1px solid #e3d2d2;
            text-align: left;
            white-space: nowrap;
        }

        .ae-table th {
            position: sticky;
            top: 0;
            z-index: 2;
            color: #fff;
            background: linear-gradient(180deg, #a90000, #720000);
            font-size: 9.5px;
            font-weight: 950;
            text-transform: uppercase;
            letter-spacing: .035em;
        }

        .ae-table tbody tr:nth-child(even) td {
            background: #fff8f8;
        }

        .ae-table tbody tr:hover td {
            background: #ffeded;
        }

    .ae-loading {
        min-height: 100px;
        display: grid;
        place-items: center;
        padding: 20px;
        color: var(--ae-muted);
        font-size: 12px;
        font-weight: 850;
        text-align: center;
    }

    .ae-spinner {
        width: 18px;
        height: 18px;
        display: inline-block;
        border: 2px solid rgba(255,255,255,.35);
        border-top-color: currentColor;
        border-radius: 50%;
        animation: ae-spin .75s linear infinite;
    }

    @@keyframes ae-spin {
        to {
            transform: rotate(360deg);
        }
    }

    .ae-toast {
        position: fixed;
        right: 18px;
        bottom: 18px;
        z-index: 99999;
        max-width: min(430px, calc(100vw - 36px));
        display: none;
        gap: 9px;
        align-items: flex-start;
        padding: 12px 14px;
        border-radius: 13px;
        color: #fff;
        box-shadow: 0 18px 44px rgba(0,0,0,.28);
        font-size: 12px;
        font-weight: 850;
        line-height: 1.4;
    }

        .ae-toast.show {
            display: flex;
        }

        .ae-toast.ok {
            background: #106b3d;
        }

        .ae-toast.error {
            background: #a51f1f;
        }

    @@media (max-width: 1180px) {
        .ae-main-grid {
            grid-template-columns: 1fr;
        }

        .ae-audit-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 850px) {
        .ae-header {
            grid-template-columns: 1fr;
        }

        .ae-header-actions {
            justify-content: flex-start;
        }

        .ae-search-grid {
            grid-template-columns: 1fr 1fr;
        }

            .ae-search-grid .ae-search-actions {
                grid-column: 1 / -1;
            }

        .ae-detail-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 580px) {
        .ae-page {
            padding: 6px;
        }

        .ae-header {
            border-radius: 13px;
            padding: 13px;
        }

        .ae-search-grid {
            grid-template-columns: 1fr;
        }

            .ae-search-grid .ae-search-actions {
                grid-column: auto;
            }

        .ae-search-actions {
            display: grid !important;
            grid-template-columns: 1fr 1fr;
        }

        .ae-detail-grid {
            grid-template-columns: 1fr;
        }

        .ae-data.wide {
            grid-column: auto;
        }

        .ae-action-switch {
            grid-template-columns: 1fr;
        }

        .ae-card-title {
            align-items: flex-start;
            flex-direction: column;
        }
    }


    /* ===== MODO DE ELIMINACIÓN MASIVA ===== */
    .ae-hidden {
        display: none !important;
    }

    .ae-mode-switch {
        display: inline-grid;
        grid-template-columns: 1fr 1fr;
        gap: 4px;
        padding: 4px;
        border: 1px solid rgba(255,255,255,.22);
        border-radius: 12px;
        background: rgba(255,255,255,.08);
    }

    .ae-mode-btn {
        min-height: 34px;
        border: 0;
        border-radius: 9px;
        padding: 0 11px;
        color: rgba(255,255,255,.76);
        background: transparent;
        font: inherit;
        font-size: 11px;
        font-weight: 900;
        cursor: pointer;
    }

        .ae-mode-btn.active {
            color: #5c0000;
            background: #fff;
            box-shadow: 0 5px 14px rgba(0,0,0,.16);
        }

    .ae-bulk-grid {
        display: grid;
        grid-template-columns: minmax(300px, 1fr) auto;
        gap: 10px;
        align-items: end;
    }

    .ae-bulk-input {
        min-height: 112px;
        resize: vertical;
        font-family: Consolas, "Courier New", monospace;
        font-size: 12px;
        line-height: 1.45;
    }

    .ae-bulk-actions {
        display: grid;
        gap: 7px;
        min-width: 155px;
    }

    .ae-bulk-summary {
        display: flex;
        gap: 7px;
        flex-wrap: wrap;
        align-items: center;
        padding: 10px 13px;
        border-bottom: 1px solid #ead7d7;
        background: #fffafa;
    }

    .ae-bulk-table input[type="checkbox"] {
        width: 17px;
        height: 17px;
        accent-color: var(--ae-brand-700);
        cursor: pointer;
    }

    .ae-bulk-value {
        max-width: 230px;
        font-family: Consolas, "Courier New", monospace;
        font-size: 11px;
        overflow-wrap: anywhere;
    }

    .ae-row-ok {
        background: #f5fff8;
    }

    .ae-row-warn {
        background: #fffaf0;
    }

    .ae-row-error {
        background: #fff4f4;
    }

    .ae-mini-status {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 7px;
        border-radius: 999px;
        font-size: 9.5px;
        font-weight: 950;
        white-space: nowrap;
    }

        .ae-mini-status.ok {
            color: #0d6338;
            background: #dff5e7;
            border: 1px solid #8ac7a0;
        }

        .ae-mini-status.warn {
            color: #785100;
            background: #fff3cd;
            border: 1px solid #dfbd61;
        }

        .ae-mini-status.no {
            color: #8f1d1d;
            background: #fde1e1;
            border: 1px solid #e09a9a;
        }

        .ae-mini-status.info {
            color: #174c96;
            background: #e9f2ff;
            border: 1px solid #9dbbe8;
        }

    @@media (max-width: 760px) {
        .ae-bulk-grid {
            grid-template-columns: 1fr;
        }

        .ae-bulk-actions {
            grid-template-columns: 1fr 1fr;
            min-width: 0;
        }

        .ae-mode-switch {
            width: 100%;
        }
    }
</style>

<div class="ae-page" id="aePage" data-source="@sourceInicial">
    <div class="ae-shell">
        <header class="ae-header">
            <div class="ae-title">
                <h1><i class="fa-solid fa-tags me-1"></i> Ajuste controlado de etiquetas</h1>

            </div>

            <div class="ae-header-actions">
                <div class="ae-permissions" id="aePermissions">
                    <span class="ae-chip info">Consultando permisos…</span>
                </div>
                <div class="ae-mode-switch" aria-label="Modo de operación">
                    <button type="button" class="ae-mode-btn active" id="btnAeModeSingle">
                        <i class="fa-solid fa-tag"></i> Individual
                    </button>
                    <button type="button" class="ae-mode-btn" id="btnAeModeBulk">
                        <i class="fa-solid fa-layer-group"></i> Masiva
                    </button>
                </div>
            </div>
        </header>

        <section class="ae-card ae-search-card" id="aeSingleSearchCard">
            <div class="ae-search-grid">
                <div class="ae-field">
                    <label>Planta / fuente</label>
                    <div class="ae-plant-toggle">
                        <button type="button" class="ae-plant-btn" data-source="P1">PLANTA 1</button>
                        <button type="button" class="ae-plant-btn" data-source="TIF">TIF 776</button>
                    </div>
