                </div>
            </article>
        </section>

        <section class="ae-audit-grid">
            <article class="ae-card">
                <div class="ae-card-title">
                    <strong><i class="fa-solid fa-clock-rotate-left me-1"></i> ProduccionLog</strong>
                    <small>Bitácora operativa Meat</small>
                </div>
                <div class="ae-table-wrap">
                    <table class="ae-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Log ID</th>
                                <th>Proceso</th>
                                <th>Estatus</th>
                                <th>Peso</th>
                                <th>Almacén</th>
                                <th>Artículo</th>
                                <th>DeviceId</th>
                                <th>Motivo / usuario</th>
                            </tr>
                        </thead>
                        <tbody id="aeProductionLogBody">
                            <tr><td colspan="9"><div class="ae-loading">Sin etiqueta consultada.</div></td></tr>
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="ae-card">
                <div class="ae-card-title">
                    <strong><i class="fa-solid fa-user-shield me-1"></i> Auditoría de ajustes SIGO</strong>
                    <small>Antes, después, usuario y autorización</small>
                </div>
                <div class="ae-table-wrap">
                    <table class="ae-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Acción</th>
                                <th>Usuario</th>
                                <th>Autorizó</th>
                                <th>Proceso</th>
                                <th>Estatus</th>
                                <th>Peso</th>
                                <th>Motivo</th>
                            </tr>
                        </thead>
                        <tbody id="aeAuditBody">
                            <tr><td colspan="8"><div class="ae-loading">Sin etiqueta consultada.</div></td></tr>
                        </tbody>
                    </table>
                </div>
            </article>
        </section>
    </div>
</div>

<div class="ae-toast" id="aeToast"></div>

<script>
    (() => {
        "use strict";

        const URLS = {
            permisos: '@Url.Action("AjusteEtiquetaPermisos", "ProcesosCg")',
            buscar: '@Url.Action("BuscarEtiquetaAjuste", "ProcesosCg")',
            historial: '@Url.Action("HistorialEtiquetaAjuste", "ProcesosCg")',
            aplicar: '@Url.Action("AplicarAjusteEtiqueta", "ProcesosCg")'
        };

        const state = {
            source: String(document.getElementById("aePage")?.dataset.source || "P1").toUpperCase() === "TIF" ? "TIF" : "P1",
            permisos: { puedeLeer: false, puedeEscribir: false, puedeEliminar: false },
            etiqueta: null,
            consulta: null,
            busy: false,
            mode: "single",
            bulkRows: []
        };

        const $ = id => document.getElementById(id);
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || "";

        function esc(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function val(obj, ...keys) {
            for (const key of keys) {
                if (obj && obj[key] !== undefined && obj[key] !== null) return obj[key];
            }
            return null;
        }

        function fmtNumber(value, decimals = 3) {
            const number = Number(value ?? 0);
            return Number.isFinite(number)
                ? number.toLocaleString("es-MX", { minimumFractionDigits: decimals, maximumFractionDigits: decimals })
                : "0";
        }

        function fmtDate(value, withTime = true) {
            if (!value) return "-";
            const d = new Date(value);
            if (Number.isNaN(d.getTime())) return String(value);
            return d.toLocaleString("es-MX", withTime
                ? { dateStyle: "short", timeStyle: "medium" }
                : { dateStyle: "short" });
        }

        function loteDesdeEtiqueta(codigoEtiqueta) {
            const codigo = String(codigoEtiqueta ?? "").trim();
            return codigo ? codigo.substring(0, 12) : "-";
        }

        function newOperationId() {
            if (globalThis.crypto?.randomUUID) return globalThis.crypto.randomUUID();
            return "xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx".replace(/[xy]/g, c => {
                const r = Math.random() * 16 | 0;
                const v = c === "x" ? r : (r & 0x3 | 0x8);
                return v.toString(16);
            });
        }

        async function readJson(response) {
            const raw = await response.text();
            let json = null;
            try { json = raw ? JSON.parse(raw) : null; } catch { json = null; }

            if (!response.ok || json?.ok === false) {
                const message = [json?.msg, json?.error, json?.inner]
                    .filter(Boolean)
                    .join("\n") || raw || `HTTP ${response.status}`;
                const error = new Error(message);
                error.status = response.status;
                error.payload = json;
                throw error;
            }

            return json || {};
        }

        async function getJson(url) {
            const response = await fetch(url, {
                method: "GET",
                cache: "no-store",
                headers: { "Accept": "application/json" }
            });
            return readJson(response);
        }

        async function postJson(url, body) {
            const response = await fetch(url, {
                method: "POST",
                cache: "no-store",
                headers: {
                    "Accept": "application/json",
                    "Content-Type": "application/json",
                    "RequestVerificationToken": token
                },
                body: JSON.stringify(body)
            });
            return readJson(response);
        }

        function toast(message, type = "ok") {
            const el = $("aeToast");
            el.className = `ae-toast show ${type}`;
            el.innerHTML = `<i class="fa-solid ${type === "ok" ? "fa-circle-check" : "fa-triangle-exclamation"}"></i><div>${esc(message)}</div>`;
            clearTimeout(toast.timer);
            toast.timer = setTimeout(() => el.classList.remove("show"), 5200);
        }

        function setBusy(value, text = "Procesando…") {
            state.busy = value;
            const search = $("btnAeSearch");
            const apply = $("btnAeApply");

            search.disabled = value;
            search.innerHTML = value
                ? `<span class="ae-spinner"></span> ${esc(text)}`
                : `<i class="fa-solid fa-magnifying-glass"></i> Consultar`;

            updateOperationAvailability();
            if (value) apply.disabled = true;
        }


        function parseBulkValues(raw) {
            const seen = new Set();
            return String(raw || "")
                .split(/[\r\n,;\t]+/)
                .map(x => x.trim())
                .filter(Boolean)
                .filter(x => {
                    const key = x.toUpperCase();
                    if (seen.has(key)) return false;
                    seen.add(key);
                    return true;
                });
        }

        function bulkRowStatus(row) {
            if (!row.ok) return { text: "NO ENCONTRADA", cls: "no", eligible: false };

            const e = row.etiqueta;
            const active = Number(val(e, "estatus", "Estatus") ?? 0) === 1;
            const historical = Boolean(row.consulta?.esHistorico ?? row.consulta?.EsHistorico);
            const blocked = Boolean(row.consulta?.eliminacionBloqueadaAlmacen ?? row.consulta?.EliminacionBloqueadaAlmacen);

            if (!active) return { text: "INACTIVA", cls: "no", eligible: false };
            if (blocked) return { text: "ALMACÉN PROTEGIDO", cls: "no", eligible: false };
            if (!state.permisos.puedeEscribir) return { text: "SIN PERMISO", cls: "no", eligible: false };
            if (historical && !state.permisos.puedeEliminar) return { text: "HISTÓRICA SIN PERMISO", cls: "no", eligible: false };
            if (historical) return { text: "HISTÓRICA", cls: "warn", eligible: true };
            return { text: "ELEGIBLE", cls: "ok", eligible: true };
        }

        function selectedBulkRows() {
            return state.bulkRows.filter(r => r.selected && bulkRowStatus(r).eligible && !r.processedOk);
        }

        function renderBulkRows() {
            const body = $("aeBulkBody");
            const total = state.bulkRows.length;

            if (!total) {
                body.innerHTML = `<tr><td colspan="8"><div class="ae-loading">Sin valores validados.</div></td></tr>`;
                $("aeBulkSummary").innerHTML = `<span class="ae-chip info">Pega y valida una lista para comenzar.</span>`;
                $("aeBulkTitleState").textContent = "Sin lista";
                $("aeBulkSelectAll").checked = false;
                updateOperationAvailability();
                return;
            }

            let eligible = 0, historical = 0, blocked = 0, invalid = 0, selected = 0, success = 0, failed = 0;

            body.innerHTML = state.bulkRows.map((row, index) => {
                const status = bulkRowStatus(row);
                const e = row.etiqueta;
                const isHistorical = Boolean(row.consulta?.esHistorico ?? row.consulta?.EsHistorico);
                const isBlocked = Boolean(row.consulta?.eliminacionBloqueadaAlmacen ?? row.consulta?.EliminacionBloqueadaAlmacen);

                if (status.eligible) eligible++;
                if (status.eligible && isHistorical) historical++;
                if (isBlocked) blocked++;
                if (!row.ok) invalid++;
                if (row.selected && status.eligible && !row.processedOk) selected++;
                if (row.processedOk) success++;
                if (row.processedError) failed++;

                const resultText = row.processedOk
                    ? `<span class="ae-mini-status ok"><i class="fa-solid fa-check"></i> Eliminada</span>`
                    : row.processedError
                        ? `<span class="ae-mini-status no" title="${esc(row.processedError)}"><i class="fa-solid fa-xmark"></i> Error</span>`
                        : `<span class="ae-mini-status info"><i class="fa-solid fa-hourglass-half"></i> Pendiente</span>`;

                return `<tr class="${row.processedOk ? "ae-row-ok" : row.processedError || !status.eligible ? "ae-row-error" : isHistorical ? "ae-row-warn" : "ae-row-ok"}">
                    <td style="text-align:center">
                        <input type="checkbox"
                               class="ae-bulk-check"
                               data-index="${index}"
                               ${row.selected && status.eligible && !row.processedOk ? "checked" : ""}
                               ${!status.eligible || row.processedOk || state.busy ? "disabled" : ""} />
                    </td>
                    <td class="ae-bulk-value">${esc(row.input)}</td>
                    <td>${esc(val(e, "produccionId", "ProduccionId") ?? "-")}</td>
                    <td class="ae-bulk-value">${esc(val(e, "codigoEtiqueta", "CodigoEtiqueta") ?? "-")}</td>
                    <td>${esc(e ? fmtDate(val(e, "fechaProduccion", "FechaProduccion"), false) : "-")}</td>
                    <td>${esc(val(e, "almacenNombre", "AlmacenNombre") || val(e, "almacen", "Almacen") || "-")}</td>
                    <td><span class="ae-mini-status ${status.cls}">${esc(status.text)}</span></td>
                    <td title="${esc(row.processedError || row.error || "")}">${resultText}</td>
                </tr>`;
            }).join("");

            $("aeBulkSummary").innerHTML = `
                <span class="ae-chip info"><i class="fa-solid fa-list"></i> Total ${total}</span>
                <span class="ae-chip ok"><i class="fa-solid fa-check"></i> Elegibles ${eligible}</span>
                <span class="ae-chip warn"><i class="fa-solid fa-clock"></i> Históricas ${historical}</span>
                <span class="ae-chip no"><i class="fa-solid fa-lock"></i> Bloqueadas ${blocked}</span>
                <span class="ae-chip no"><i class="fa-solid fa-circle-xmark"></i> No encontradas ${invalid}</span>
                ${success ? `<span class="ae-chip ok"><i class="fa-solid fa-trash-can"></i> Eliminadas ${success}</span>` : ""}
                ${failed ? `<span class="ae-chip no"><i class="fa-solid fa-triangle-exclamation"></i> Fallidas ${failed}</span>` : ""}`;

            $("aeBulkTitleState").textContent = `${selected} seleccionada${selected === 1 ? "" : "s"}`;
            const selectable = state.bulkRows.filter(r => bulkRowStatus(r).eligible && !r.processedOk);
            $("aeBulkSelectAll").checked = selectable.length > 0 && selectable.every(r => r.selected);

            document.querySelectorAll(".ae-bulk-check").forEach(chk => {
                chk.addEventListener("change", () => {
                    const row = state.bulkRows[Number(chk.dataset.index)];
                    if (row) row.selected = chk.checked;
                    renderBulkRows();
                });
            });

            updateOperationAvailability();
        }

        async function mapWithConcurrency(items, limit, worker) {
            const results = new Array(items.length);
            let next = 0;
            const runners = Array.from({ length: Math.min(limit, items.length) }, async () => {
                while (true) {
                    const index = next++;
                    if (index >= items.length) break;
                    results[index] = await worker(items[index], index);
                }
            });
            await Promise.all(runners);
            return results;
        }

        async function validateBulkList() {
            if (state.busy) return;
            const values = parseBulkValues($("aeBulkInput").value);

            if (!values.length) {
                toast("Captura al menos un ProduccionId o código de etiqueta.", "error");
                $("aeBulkInput").focus();
                return;
            }
            if (values.length > 100) {
                toast(`La operación permite máximo 100 valores. Capturaste ${values.length}.`, "error");
                return;
            }

            state.busy = true;
            state.bulkRows = values.map(input => ({ input, ok: false, selected: false }));
            $("aeBulkResultsCard").classList.remove("ae-hidden");
            $("aeBulkBody").innerHTML = `<tr><td colspan="8"><div class="ae-loading"><span class="ae-spinner" style="color:#8b0000"></span> Validando ${values.length} valores…</div></td></tr>`;
            const button = $("btnAeBulkLoad");
            button.disabled = true;
            button.innerHTML = `<span class="ae-spinner"></span> Validando…`;
            updateOperationAvailability();

            try {
                state.bulkRows = await mapWithConcurrency(values, 5, async input => {
                    try {
                        const json = await getJson(`${URLS.buscar}?source=${encodeURIComponent(state.source)}&valor=${encodeURIComponent(input)}&_=${Date.now()}`);
                        const row = {
                            input,
                            ok: true,
                            etiqueta: json.etiqueta || json.Etiqueta,
                            consulta: json,
                            selected: false,
                            processedOk: false,
                            processedError: ""
                        };
                        row.selected = bulkRowStatus(row).eligible;
                        return row;
                    } catch (error) {
                        return { input, ok: false, error: error.message, selected: false, processedOk: false, processedError: "" };
                    }
                });
                renderBulkRows();
                const count = selectedBulkRows().length;
                toast(count ? `${count} etiqueta(s) quedaron listas para eliminar.` : "No hay etiquetas elegibles para eliminar.", count ? "ok" : "error");
            } finally {
                state.busy = false;
                button.disabled = false;
                button.innerHTML = `<i class="fa-solid fa-list-check"></i> Validar lista`;
                renderBulkRows();
                renderActionMode();
            }
        }

        function clearBulk() {
            state.bulkRows = [];
            $("aeBulkInput").value = "";
            $("aeBulkResultsCard").classList.add("ae-hidden");
            $("aeReason").value = "";
            $("aeConfirmDelete").value = "";
            $("aeHistoricalAuthorization").value = "";
            renderBulkRows();
        }

        function setMode(mode) {
            state.mode = mode === "bulk" ? "bulk" : "single";
            const bulk = state.mode === "bulk";

            $("btnAeModeSingle").classList.toggle("active", !bulk);
            $("btnAeModeBulk").classList.toggle("active", bulk);
            $("aeSingleSearchCard").classList.toggle("ae-hidden", bulk);
            $("aeBulkSearchCard").classList.toggle("ae-hidden", !bulk);
            $("aeBulkResultsCard").classList.toggle("ae-hidden", !bulk || state.bulkRows.length === 0);
            $("aeActivateOption").classList.toggle("ae-hidden", bulk);

            if (bulk) {
                const deleteInput = document.querySelector('input[name="aeAction"][value="ELIMINAR"]');
                if (deleteInput) deleteInput.checked = true;
                $("aeDetailContent").className = "ae-empty";
                $("aeDetailContent").innerHTML = `<div><i class="fa-solid fa-layer-group"></i><strong>Eliminación masiva</strong><div style="margin-top:6px;font-size:11.5px">Valida la lista, revisa los estados y selecciona únicamente las etiquetas correctas.</div></div>`;
                $("aeProductionLogBody").innerHTML = `<tr><td colspan="9"><div class="ae-loading">El historial individual no se muestra en modo masivo.</div></td></tr>`;
                $("aeAuditBody").innerHTML = `<tr><td colspan="8"><div class="ae-loading">Cada etiqueta eliminada conservará su auditoría individual.</div></td></tr>`;
                $("aeBulkInput").focus();
            } else {
                $("aeActivateOption").classList.remove("ae-hidden");
                if (state.etiqueta) {
                    renderDetail();
                    loadHistory();
                } else {
                    clearAll(false);
                }
                $("aeSearchInput").focus();
            }

            renderActionMode();
        }

        function renderPermissions() {
            const p = state.permisos;
            $("aePermissions").innerHTML = `
                <span class="ae-chip ${p.puedeLeer ? "ok" : "no"}">
                    <i class="fa-solid ${p.puedeLeer ? "fa-eye" : "fa-eye-slash"}"></i> Leer
                </span>
                <span class="ae-chip ${p.puedeEscribir ? "ok" : "no"}">
                    <i class="fa-solid ${p.puedeEscribir ? "fa-pen" : "fa-ban"}"></i> Ajustar día
                </span>
                <span class="ae-chip ${p.puedeEliminar ? "warn" : "no"}">
                    <i class="fa-solid ${p.puedeEliminar ? "fa-user-shield" : "fa-lock"}"></i> Histórico
                </span>`;
        }

        async function loadPermissions() {
            try {
                const json = await getJson(URLS.permisos);
                state.permisos = {
                    puedeLeer: Boolean(json.puedeLeer ?? json.PuedeLeer),
                    puedeEscribir: Boolean(json.puedeEscribir ?? json.PuedeEscribir),
                    puedeEliminar: Boolean(json.puedeEliminar ?? json.PuedeEliminar)
                };
            } catch (error) {
                console.error(error);
                state.permisos = { puedeLeer: false, puedeEscribir: false, puedeEliminar: false };
                toast(error.message, "error");
            }
            renderPermissions();
            updateOperationAvailability();
        }

        function renderPlants() {
            document.querySelectorAll(".ae-plant-btn").forEach(btn => {
                btn.classList.toggle("active", btn.dataset.source === state.source);
            });
            $("aePlantLabel").textContent = state.source === "TIF" ? "TIF 776" : "Planta 1";
        }

        async function setSource(source) {
            state.source = String(source).toUpperCase() === "TIF" ? "TIF" : "P1";
            renderPlants();
            clearAll(false);
            clearBulk();
            setMode(state.mode);
        }

        function clearAll(clearSearch = true) {
            state.etiqueta = null;
            state.consulta = null;
            if (clearSearch) $("aeSearchInput").value = "";
            $("aeReason").value = "";
            $("aeConfirmDelete").value = "";
            $("aeHistoricalAuthorization").value = "";
            $("aeNewWeight").value = "";
            $("aeConfirmActivate").value = "";
            $("aeDetailContent").className = "ae-empty";
            $("aeDetailContent").innerHTML = `
                <div>
                    <i class="fa-solid fa-barcode"></i>
                    <strong>Consulta una etiqueta para comenzar</strong>
                    <div style="margin-top:6px;font-size:11.5px">Puedes buscar por ProduccionId o por CódigoEtiqueta.</div>
                </div>`;
            $("aeProductionLogBody").innerHTML = `<tr><td colspan="9"><div class="ae-loading">Sin etiqueta consultada.</div></td></tr>`;
            $("aeAuditBody").innerHTML = `<tr><td colspan="8"><div class="ae-loading">Sin etiqueta consultada.</div></td></tr>`;
            $("aeOperationState").textContent = "Sin etiqueta";
            updateOperationAvailability();
        }

        async function searchLabel() {
            const input = $("aeSearchInput").value.trim();
            if (!input) {
                toast("Captura un ProduccionId o código de etiqueta.", "error");
                $("aeSearchInput").focus();
                return;
            }

            setBusy(true, "Consultando…");
            $("aeDetailContent").className = "ae-loading";
            $("aeDetailContent").innerHTML = `<div><span class="ae-spinner" style="color:#8b0000"></span><div style="margin-top:8px">Consultando etiqueta…</div></div>`;

            try {
                const json = await getJson(`${URLS.buscar}?source=${encodeURIComponent(state.source)}&valor=${encodeURIComponent(input)}&_=${Date.now()}`);
                state.etiqueta = json.etiqueta || json.Etiqueta;
                state.consulta = json;
                renderDetail();
                await loadHistory();
            } catch (error) {
                console.error(error);
                state.etiqueta = null;
                state.consulta = null;
                $("aeDetailContent").className = "ae-empty";
                $("aeDetailContent").innerHTML = `
                    <div>
                        <i class="fa-solid fa-circle-exclamation" style="color:#b42318"></i>
                        <strong>No se encontró o no se pudo consultar</strong>
                        <div style="margin-top:7px;font-size:11.5px;white-space:pre-line">${esc(error.message)}</div>
                    </div>`;
                toast(error.message, "error");
                updateOperationAvailability();
            } finally {
                setBusy(false);
            }
        }

        function renderDetail() {
            const e = state.etiqueta;
            if (!e) return;

            const status = Number(val(e, "estatus", "Estatus") ?? 0);
            const historical = Boolean(state.consulta?.esHistorico ?? state.consulta?.EsHistorico);
            const canAuthorize = Boolean(state.consulta?.puedeAutorizarHistorico ?? state.consulta?.PuedeAutorizarHistorico);
            const blockedWarehouse = Boolean(state.consulta?.eliminacionBloqueadaAlmacen ?? state.consulta?.EliminacionBloqueadaAlmacen);
            const activationBlockedProcess = Boolean(state.consulta?.activacionBloqueadaProceso ?? state.consulta?.ActivacionBloqueadaProceso);
            const rule = state.consulta?.regla ?? state.consulta?.Regla ?? "";

            let bannerClass = "today";
            let bannerIcon = "fa-circle-check";
            if (blockedWarehouse) {
                bannerClass = "history-block";
                bannerIcon = "fa-warehouse";
            } else if (activationBlockedProcess) {
                bannerClass = "history-block";
                bannerIcon = "fa-ban";
            } else if (historical && canAuthorize) {
                bannerClass = "history-ok";
                bannerIcon = "fa-user-shield";
            } else if (historical) {
                bannerClass = "history-block";
                bannerIcon = "fa-lock";
            }

            $("aeDetailContent").className = "ae-detail-body";
            $("aeDetailContent").innerHTML = `
                <div class="ae-status-row">
                    <div class="ae-label-code">
                        <span>Código de etiqueta</span>
                        <strong>${esc(val(e, "codigoEtiqueta", "CodigoEtiqueta") || "-")}</strong>
                    </div>
                    <span class="ae-badge ${status === 1 ? "active" : "inactive"}">
                        <i class="fa-solid ${status === 1 ? "fa-circle-check" : "fa-circle-xmark"}"></i>&nbsp;
                        ${status === 1 ? "ACTIVA" : "INACTIVA"}
                    </span>
                </div>

                <div class="ae-detail-grid">
                    ${dataCell("ProduccionId", val(e, "produccionId", "ProduccionId"))}
                    ${dataCell("Fecha de producción", fmtDate(val(e, "fechaProduccion", "FechaProduccion"), false))}
                    ${dataCell("Fecha servidor Meat", fmtDate(val(e, "fechaServidor", "FechaServidor"), false))}
                    ${dataCell("Peso neto", `${fmtNumber(val(e, "pesoNeto", "PesoNeto"), 3)} kg`)}
                    ${dataCell("SKU / artículo", val(e, "articulo", "Articulo") || "-")}
                    ${dataCell("Producto", val(e, "producto", "Producto") || "-", true)}
                    ${dataCell("Almacén", val(e, "almacenNombre", "AlmacenNombre") || val(e, "almacen", "Almacen") || "-")}
                    ${dataCell("Lote", loteDesdeEtiqueta(val(e, "codigoEtiqueta", "CodigoEtiqueta")))}
                    ${dataCell("Proceso actual", `${esc(val(e, "ultimoProcesoId", "UltimoProcesoId") ?? "-")} - ${esc(val(e, "procesoActual", "ProcesoActual") || "")}`, true, false)}
                </div>

                <div class="ae-rule-banner ${bannerClass}">
                    <i class="fa-solid ${bannerIcon}"></i>
                    <div>${esc(rule)}</div>
                </div>`;

            $("aeOperationState").textContent = blockedWarehouse
                ? "Almacén protegido"
                : activationBlockedProcess
                    ? "Activación bloqueada por proceso"
                    : status === 1
                        ? (historical ? "Activa / histórica" : "Activa / del día")
                        : "Etiqueta inactiva";

            const actionToSelect = status === 1 ? "ELIMINAR" : "ACTIVAR";
            const actionInput = document.querySelector(`input[name="aeAction"][value="${actionToSelect}"]`);
            if (actionInput) actionInput.checked = true;
            renderActionMode();
        }

        function dataCell(label, value, wide = false, escapeValue = true) {
            return `<div class="ae-data ${wide ? "wide" : ""}">
                <label>${esc(label)}</label>
                <strong>${escapeValue ? esc(value ?? "-") : (value ?? "-")}</strong>
            </div>`;
        }

        async function loadHistory() {
            const id = Number(val(state.etiqueta, "produccionId", "ProduccionId") || 0);
            if (!id) return;

            $("aeProductionLogBody").innerHTML = `<tr><td colspan="9"><div class="ae-loading">Consultando ProduccionLog…</div></td></tr>`;
            $("aeAuditBody").innerHTML = `<tr><td colspan="8"><div class="ae-loading">Consultando auditoría…</div></td></tr>`;

            try {
                const json = await getJson(`${URLS.historial}?source=${encodeURIComponent(state.source)}&produccionId=${id}&_=${Date.now()}`);
                renderProductionLog(json.produccionLog || json.ProduccionLog || []);
                renderAudit(json.auditoria || json.Auditoria || [], Boolean(json.auditoriaDisponible ?? json.AuditoriaDisponible));
            } catch (error) {
                console.error(error);
                $("aeProductionLogBody").innerHTML = `<tr><td colspan="9"><div class="ae-loading">${esc(error.message)}</div></td></tr>`;
                $("aeAuditBody").innerHTML = `<tr><td colspan="8"><div class="ae-loading">${esc(error.message)}</div></td></tr>`;
            }
        }

        function renderProductionLog(rows) {
            if (!rows.length) {
                $("aeProductionLogBody").innerHTML = `<tr><td colspan="9"><div class="ae-loading">Sin movimientos en ProduccionLog.</div></td></tr>`;
                return;
            }

            $("aeProductionLogBody").innerHTML = rows.map(r => `
                <tr>
                    <td>${esc(fmtDate(val(r, "fechaHora", "FechaHora")))}</td>
                    <td>${esc(val(r, "produccionLogId", "ProduccionLogId") ?? "-")}</td>
                    <td>${esc(val(r, "procesoId", "ProcesoId") ?? "-")}</td>
                    <td>${esc(val(r, "estatus", "Estatus") ?? "-")}</td>
                    <td>${esc(fmtNumber(val(r, "pesoNeto", "PesoNeto"), 3))}</td>
                    <td>${esc(val(r, "almacen", "Almacen") ?? "-")}</td>
                    <td>${esc(val(r, "articulo", "Articulo") ?? "-")}</td>
                    <td>${esc(val(r, "deviceId", "DeviceId") ?? "-")}</td>
                    <td title="${esc(val(r, "motivo", "Motivo") ?? "")}">${esc(val(r, "motivo", "Motivo") || val(r, "usuario", "Usuario") || "-")}</td>
                </tr>`).join("");
        }

        function renderAudit(rows, available) {
            if (!available) {
                $("aeAuditBody").innerHTML = `<tr><td colspan="8"><div class="ae-loading">Falta ejecutar el SQL de instalación de auditoría.</div></td></tr>`;
                return;
            }

            if (!rows.length) {
                $("aeAuditBody").innerHTML = `<tr><td colspan="8"><div class="ae-loading">Sin ajustes registrados por SIGO.</div></td></tr>`;
                return;
            }

            $("aeAuditBody").innerHTML = rows.map(r => `
                <tr>
                    <td>${esc(fmtDate(val(r, "fechaHora", "FechaHora")))}</td>
                    <td>${esc(val(r, "accion", "Accion") ?? "-")}</td>
                    <td>${esc(val(r, "usuarioSolicita", "UsuarioSolicita") ?? "-")}</td>
                    <td>${esc(val(r, "usuarioAutoriza", "UsuarioAutoriza") ?? "-")}</td>
                    <td>${esc(val(r, "procesoAnterior", "ProcesoAnterior") ?? "-")} → ${esc(val(r, "procesoNuevo", "ProcesoNuevo") ?? "-")}</td>
                    <td>${esc(val(r, "estatusAnterior", "EstatusAnterior") ?? "-")} → ${esc(val(r, "estatusNuevo", "EstatusNuevo") ?? "-")}</td>
                    <td>${esc(fmtNumber(val(r, "pesoAnterior", "PesoAnterior"), 3))} → ${esc(fmtNumber(val(r, "pesoNuevo", "PesoNuevo"), 3))}</td>
                    <td title="${esc(val(r, "motivo", "Motivo") ?? "")}">${esc(val(r, "motivo", "Motivo") ?? "-")}</td>
                </tr>`).join("");
        }

        function currentAction() {
            return document.querySelector('input[name="aeAction"]:checked')?.value || "ELIMINAR";
        }

        function renderActionMode() {
            const bulk = state.mode === "bulk";
            const action = bulk ? "ELIMINAR" : currentAction();
            const deleting = action === "ELIMINAR";
            const activating = action === "ACTIVAR" && !bulk;
            const historical = bulk
                ? selectedBulkRows().some(r => Boolean(r.consulta?.esHistorico ?? r.consulta?.EsHistorico))
                : Boolean(state.consulta?.esHistorico ?? state.consulta?.EsHistorico);

            $("aeDeleteBox").classList.toggle("show", deleting);
            $("aeActivateBox").classList.toggle("show", activating);
            $("aeHistoryAuthBox").classList.toggle("show", deleting && historical);
            $("aeOperationState").textContent = bulk
                ? `${selectedBulkRows().length} seleccionada(s)`
                : $("aeOperationState").textContent;
            updateOperationAvailability();
        }

        function updateOperationAvailability() {
            if (state.mode === "bulk") {
                const selected = selectedBulkRows();
                const historical = selected.some(r => Boolean(r.consulta?.esHistorico ?? r.consulta?.EsHistorico));
                const can = selected.length > 0 && state.permisos.puedeEscribir && !state.busy;

                const deleteRadio = document.querySelector('input[name="aeAction"][value="ELIMINAR"]');
                const activateRadio = document.querySelector('input[name="aeAction"][value="ACTIVAR"]');
                if (deleteRadio) deleteRadio.disabled = !can;
                if (activateRadio) activateRadio.disabled = true;

                $("aeReason").disabled = !can;
                $("aeConfirmDelete").disabled = !can;
                $("aeHistoricalAuthorization").disabled = !can || !historical;
                $("aeNewWeight").disabled = true;
                $("aeConfirmActivate").disabled = true;
                $("btnAeApply").disabled = !can;
                $("btnAeApply").innerHTML = state.busy
                    ? `<span class="ae-spinner"></span> Procesando…`
                    : `<i class="fa-solid fa-trash-can"></i> Eliminar ${selected.length} etiqueta${selected.length === 1 ? "" : "s"}`;
                return;
            }

            const e = state.etiqueta;
            const hasLabel = Boolean(e);
            const historical = Boolean(state.consulta?.esHistorico ?? state.consulta?.EsHistorico);
            const blockedWarehouse = Boolean(state.consulta?.eliminacionBloqueadaAlmacen ?? state.consulta?.EliminacionBloqueadaAlmacen);
            const serverCanActivate = Boolean(state.consulta?.puedeActivar ?? state.consulta?.PuedeActivar);
            const activationBlockedProcess = Boolean(state.consulta?.activacionBloqueadaProceso ?? state.consulta?.ActivacionBloqueadaProceso);
            const active = Number(val(e, "estatus", "Estatus") ?? 0) === 1;
            const action = currentAction();

            const deleteRadio = document.querySelector('input[name="aeAction"][value="ELIMINAR"]');
            const activateRadio = document.querySelector('input[name="aeAction"][value="ACTIVAR"]');

            if (deleteRadio) deleteRadio.disabled = !hasLabel || !active || blockedWarehouse || state.busy;
            if (activateRadio) {
                activateRadio.disabled =
                    !hasLabel
                    || active
                    || !serverCanActivate
                    || activationBlockedProcess
                    || state.busy;
            }

            const canDelete = hasLabel
                && active
                && !blockedWarehouse
                && state.permisos.puedeEscribir
                && (!historical || state.permisos.puedeEliminar)
                && !state.busy;

            const canActivate = hasLabel
                && !active
                && serverCanActivate
                && !activationBlockedProcess
                && state.permisos.puedeEscribir
                && state.permisos.puedeEliminar
                && !state.busy;

            const can = action === "ELIMINAR" ? canDelete : canActivate;

            $("aeReason").disabled = !can;
            $("aeConfirmDelete").disabled = !can || action !== "ELIMINAR";
            $("aeHistoricalAuthorization").disabled = !can || action !== "ELIMINAR" || !historical;
            $("aeNewWeight").disabled = !can || action !== "ACTIVAR";
            $("aeConfirmActivate").disabled = !can || action !== "ACTIVAR";
            $("btnAeApply").disabled = !can;
            if (!state.busy) $("btnAeApply").innerHTML = `<i class="fa-solid fa-shield-halved"></i> Aplicar ajuste controlado`;
        }

        async function applyBulkDeletion() {
            const rows = selectedBulkRows();
            if (!rows.length || state.busy) return;

            const reason = $("aeReason").value.trim();
            const confirmation = $("aeConfirmDelete").value.trim().toUpperCase();
            const historicalAuthorization = $("aeHistoricalAuthorization").value.trim().toUpperCase();
            const hasHistorical = rows.some(r => Boolean(r.consulta?.esHistorico ?? r.consulta?.EsHistorico));

            if (reason.length < 10) {
                toast("Captura un motivo de al menos 10 caracteres.", "error");
                $("aeReason").focus();
                return;
            }
            if (confirmation !== "ELIMINAR") {
                toast("Escribe ELIMINAR para confirmar.", "error");
                $("aeConfirmDelete").focus();
                return;
            }
            if (hasHistorical && historicalAuthorization !== "AUTORIZAR") {
                toast("La selección incluye etiquetas históricas. Escribe AUTORIZAR para continuar.", "error");
                $("aeHistoricalAuthorization").focus();
                return;
            }
            if (!globalThis.confirm(`¿Confirmas eliminar lógicamente ${rows.length} etiqueta(s)?\n\nEl proceso continuará con las demás aunque alguna falle.`)) return;

            state.busy = true;
            renderBulkRows();
            updateOperationAvailability();

            let ok = 0, failed = 0;
            try {
                for (const row of rows) {
                    const productionId = Number(val(row.etiqueta, "produccionId", "ProduccionId") || 0);
                    try {
                        const json = await postJson(URLS.aplicar, {
                            operacionId: newOperationId(),
                            source: state.source,
                            produccionId: productionId,
                            accion: "ELIMINAR",
                            pesoNuevo: null,
                            motivo: reason,
                            confirmacion: "ELIMINAR",
                            autorizacionHistorica: Boolean(row.consulta?.esHistorico ?? row.consulta?.EsHistorico)
                                ? historicalAuthorization
                                : ""
                        });
                        row.processedOk = true;
                        row.processedError = "";
                        row.selected = false;
                        row.result = json;
                        ok++;
                    } catch (error) {
                        row.processedError = error.message;
                        failed++;
                    }
                    renderBulkRows();
                }

                toast(`Proceso terminado. Eliminadas: ${ok}. Fallidas: ${failed}.`, failed ? "error" : "ok");
                $("aeConfirmDelete").value = "";
                $("aeHistoricalAuthorization").value = "";
            } finally {
                state.busy = false;
                renderBulkRows();
                renderActionMode();
            }
        }

        async function applyAdjustment() {
            if (state.mode === "bulk") {
                await applyBulkDeletion();
                return;
            }
            if (!state.etiqueta || state.busy) return;

            const action = currentAction();
            const reason = $("aeReason").value.trim();
            const confirmation = action === "ELIMINAR"
                ? $("aeConfirmDelete").value.trim()
                : $("aeConfirmActivate").value.trim();
            const historicalAuthorization = $("aeHistoricalAuthorization").value.trim();
            const newWeight = Number($("aeNewWeight").value || 0);
            const historical = Boolean(state.consulta?.esHistorico ?? state.consulta?.EsHistorico);
            const productionId = Number(val(state.etiqueta, "produccionId", "ProduccionId") || 0);

            const blockedWarehouse = Boolean(state.consulta?.eliminacionBloqueadaAlmacen ?? state.consulta?.EliminacionBloqueadaAlmacen);
            if (action === "ELIMINAR" && blockedWarehouse) {
                toast("No se permite eliminar esta etiqueta porque se encuentra en un almacén protegido.", "error");
                return;
            }

            if (reason.length < 10) {
                toast("Captura un motivo de al menos 10 caracteres.", "error");
                $("aeReason").focus();
                return;
            }

            if (action === "ELIMINAR") {
                if (confirmation.toUpperCase() !== "ELIMINAR") {
                    toast("Escribe ELIMINAR para confirmar.", "error");
                    $("aeConfirmDelete").focus();
                    return;
                }

                if (historical && historicalAuthorization.toUpperCase() !== "AUTORIZAR") {
                    toast("La etiqueta es de otro día. Escribe AUTORIZAR para continuar.", "error");
                    $("aeHistoricalAuthorization").focus();
                    return;
                }
            }

            if (action === "ACTIVAR") {
                if (!Number.isFinite(newWeight) || newWeight <= 0) {
                    toast("Captura un peso neto válido mayor que cero.", "error");
                    $("aeNewWeight").focus();
                    return;
                }

                if (confirmation.toUpperCase() !== "ACTIVAR") {
                    toast("Escribe ACTIVAR para confirmar.", "error");
                    $("aeConfirmActivate").focus();
                    return;
                }
            }

            const code = val(state.etiqueta, "codigoEtiqueta", "CodigoEtiqueta");
            const question = action === "ELIMINAR"
                ? `¿Confirmas eliminar lógicamente la etiqueta ${code}?`
                : `¿Confirmas activar la etiqueta ${code} con ${newWeight.toFixed(3)} kg?`;

            if (!globalThis.confirm(question)) return;

            state.busy = true;
            updateOperationAvailability();
            const button = $("btnAeApply");
            button.innerHTML = `<span class="ae-spinner"></span> Aplicando transacción…`;

            try {
                const json = await postJson(URLS.aplicar, {
                    operacionId: newOperationId(),
                    source: state.source,
                    produccionId: productionId,
                    accion: action,
                    pesoNuevo: action === "ACTIVAR" ? newWeight : null,
                    motivo: reason,
                    confirmacion: confirmation,
                    autorizacionHistorica: action === "ELIMINAR" && historical
                        ? historicalAuthorization
                        : ""
                });

                toast(json.msg || "Ajuste aplicado correctamente.", "ok");
                $("aeReason").value = "";
                $("aeConfirmDelete").value = "";
                $("aeHistoricalAuthorization").value = "";
                $("aeNewWeight").value = "";
                $("aeConfirmActivate").value = "";
                await searchLabel();
            } catch (error) {
                console.error(error);
                toast(error.message, "error");
            } finally {
                state.busy = false;
                button.innerHTML = `<i class="fa-solid fa-shield-halved"></i> Aplicar ajuste controlado`;
                updateOperationAvailability();
            }
        }

        document.querySelectorAll(".ae-plant-btn").forEach(btn => {
            btn.addEventListener("click", () => setSource(btn.dataset.source));
        });

        document.querySelectorAll('input[name="aeAction"]').forEach(input => {
            input.addEventListener("change", renderActionMode);
        });

        $("btnAeModeSingle").addEventListener("click", () => setMode("single"));
        $("btnAeModeBulk").addEventListener("click", () => setMode("bulk"));
        $("btnAeBulkLoad").addEventListener("click", validateBulkList);
        $("btnAeBulkClear").addEventListener("click", clearBulk);
        $("aeBulkSelectAll").addEventListener("change", e => {
            state.bulkRows.forEach(row => {
                if (bulkRowStatus(row).eligible && !row.processedOk) row.selected = e.target.checked;
            });
            renderBulkRows();
        });

        $("btnAeSearch").addEventListener("click", searchLabel);
        $("btnAeClear").addEventListener("click", () => clearAll(true));
        $("btnAeApply").addEventListener("click", applyAdjustment);
        $("aeSearchInput").addEventListener("keydown", e => {
            if (e.key === "Enter") searchLabel();
        });

        function fitViewInsideLayout2() {
            const page = $("aePage");
            if (!page) return;

            /*
              Marcamos solamente los ancestros estructurales de esta vista.
              No se modifica el sidebar, navbar ni el resto de _Layout2.
            */
            const layoutSelectors = [
                "main",
                ".main",
                ".body-content",
                ".container",
                ".container-fluid",
                ".container-sm",
                ".container-md",
                ".container-lg",
                ".container-xl",
                ".container-xxl",
                ".pb-3"
            ].join(",");

            let parent = page.parentElement;
            while (parent && parent !== document.body) {
                if (parent.matches(layoutSelectors)) {
                    parent.classList.add("ae-layout-host");
                }
                parent = parent.parentElement;
            }

            /*
              Calculamos el espacio que ya ocupa el encabezado real de _Layout2.
              La vista llena el resto del alto visible, pero conserva scroll cuando
              el contenido sea mayor que la pantalla.
            */
            const top = Math.max(0, Math.round(page.getBoundingClientRect().top));
            page.style.setProperty("--ae-layout-top", `${top}px`);
        }

        window.addEventListener("resize", fitViewInsideLayout2, { passive: true });
        window.addEventListener("orientationchange", fitViewInsideLayout2, { passive: true });

