@model dynamic
@using System.Text.Json.Nodes
@using System.Globalization
@using System.Reflection
@using System.Collections

@{
    Layout = null;

    var orden = Model;
    var detalles = GetItems(Model);
    var comentariosPdf = Context.Request.Query["comentarios"].ToString();

    decimal totalCantidad = 0;
    decimal subtotal = 0;

    foreach (var item in detalles)
    {
        totalCantidad += ToDecimal(Get(item, "Cantidad", "Quantity", "Qty"));
        subtotal += ToDecimal(Get(item, "Importe", "LineTotal", "TotalLinea", "Total"));
    }

    var descuento = ToDecimal(Get(orden, "Descuento", "DiscSum", "Discount"));
    var iva = ToDecimal(Get(orden, "IVA", "Impuesto", "Tax", "Vat"));
    var total = ToDecimal(Get(orden, "Total", "DocTotal", "TotalDocumento"));

    if (total <= 0)
    {
        total = subtotal - descuento + iva;
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="~/images/ico_sigo.ico" />
    <title>Factura de clientes</title>

    <style>
            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                background-image: url('/images/textura.jpeg');
                background-size: cover;
                background-position: center;
                background-attachment: fixed;
                background-repeat: no-repeat;
                font-family: Arial, Helvetica, sans-serif;
                font-size: 11px;
                color: #000;
            }

            .actions {
                width: 216mm;
                margin: 10px auto;
                text-align: right;
            }

            .btn-print {
                background: #0d6efd;
                color: white;
                border: 1px solid #084298;
                padding: 8px 14px;
                border-radius: 4px;
                font-weight: bold;
                cursor: pointer;
            }

            .page {
                width: 216mm;
                min-height: 279mm;
                margin: 0 auto 18px auto;
                padding: 10mm 11mm;
                background: white;
                box-shadow: 0 0 7px rgba(0,0,0,.25);
            }

            .sap-title {
                text-align: center;
                font-size: 13px;
                font-weight: bold;
                margin-bottom: 14px;
            }

            .top {
                display: grid;
                grid-template-columns: 1fr 215px;
                gap: 20px;
            }

            .company {
                line-height: 1.35;
            }

            .company-name {
                font-weight: bold;
                font-size: 12px;
                margin-bottom: 2px;
            }

            .invoice-title {
                text-align: center;
                font-size: 22px;
                font-weight: bold;
                letter-spacing: 1px;
                margin-bottom: 8px;
            }

            .right-box table,
            .info table,
            .items,
            .totals table {
                width: 100%;
                border-collapse: collapse;
            }

            .right-box td {
                padding: 2px 3px;
                font-size: 11px;
            }

            .label {
                font-weight: bold;
                white-space: nowrap;
            }

            .blue-line {
                border-top: 2px dotted #2c6db2;
                margin: 10px 0 8px 0;
            }

            .info {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 18px;
                margin-top: 6px;
            }

                .info td {
                    padding: 2px 3px;
                    vertical-align: top;
                }

            .section-label {
                font-weight: bold;
                margin-bottom: 2px;
            }

            .items {
                margin-top: 14px;
                font-size: 10px;
            }

                .items th {
                    border-bottom: 1px solid #000;
                    border-top: 1px solid #000;
                    padding: 4px 3px;
                    text-align: left;
                    font-weight: bold;
                }

                .items td {
                    padding: 4px 3px;
                    vertical-align: top;
                }

                .items tbody tr {
                    height: 22px;
                }

            .text-right {
                text-align: right;
            }

            .text-center {
                text-align: center;
            }

            .after-table {
                display: grid;
                grid-template-columns: 1fr 235px;
                gap: 20px;
                margin-top: 20px;
            }

            .amount-words {
                min-height: 65px;
                line-height: 1.45;
            }

            .totals td {
                padding: 3px 4px;
                font-size: 11px;
            }

            .totals .total-row td {
                border-top: 1px solid #000;
                font-weight: bold;
                font-size: 12px;
            }

            .footer-block {
                margin-top: 25px;
                line-height: 1.45;
            }

            .footer-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 25px;
                margin-top: 18px;
            }

            .small-box {
                min-height: 60px;
            }

            .signature {
                margin-top: 35px;
                display: flex;
                justify-content: center;
                text-align: center;
            }

                .signature div {
                    width: 430px;
                    border-top: 1px solid #000;
                    padding-top: 5px;
                }

            @@media print {
                body {
                    background: white;
                }

                .actions {
                    display: none;
                }

                .page {
                    width: 100%;
                    min-height: auto;
                    margin: 0;
                    padding: 8mm 9mm;
                    box-shadow: none;
                }

                @@page {
                    size: letter;
                    margin: 8mm;
                }
            }

            .company-logo {
                width: 120px;
                max-height: 70px;
                object-fit: contain;
                margin: 6px 0 10px 0;
                display: block;
            }
    </style>
</head>

<body>

    <div class="actions">
        <button class="btn-print" onclick="window.print()">Imprimir / Guardar PDF</button>
    </div>

    <div class="page">

        <div class="sap-title">Factura de clientes (artículo) - CR (MX)</div>

        <div class="top">
            <div class="company">
                <div class="company-name">@Txt(Get(orden, "Empresa", "CompanyName", "NombreEmpresa"), "Carnes G")</div>             
                <div>Camino Alcala </div>
                <div>San Juan de los Lagos,47000, JAL MX
                </div>

                <img src="~/images/logoPDF.png" class="company-logo" />            
            </div>

            <div class="right-box">
                <div class="invoice-title">FACTURA</div>

                <table>
                    <tr>
                        <td class="label">No.</td>
                        <td class="text-right">
                            @Txt(Get(orden, "Id", "DocNum", "OrderNumber", "OrdenVenta", "ReferenciaDocMeat"))
                        </td>
                    </tr>
                    <tr>
                        <td class="label">Fecha</td>
                        <td class="text-right">@DateTime.Now.ToString("dd/MM/yyyy")</td>
                    </tr>
                    <tr>
                        <td class="label">Página</td>
                        <td class="text-right">1</td>
                    </tr>
                    <tr>
                        <td class="label">Moneda</td>
                        <td class="text-right">@Txt(Get(orden, "Moneda", "Currency"), "MXN")</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="blue-line"></div>

        <div class="info">
            <div>
                <div class="section-label">Cliente</div>
                <table>
                    <tr>
                        <td class="label">Código:</td>
                        <td>@Model.Cliente</td>
                    </tr>
                    <tr>
                        <td class="label">Nombre:</td>
                        <td>@Model.ClienteNombre</td>
                    </tr>
                    <tr>
                        <td class="label">RFC:</td>
                        <td>@Txt(Get(orden, "RFC", "RfcCliente", "LicTradNum"))</td>
                    </tr>
                    <tr>
                        <td class="label">Dirección:</td>
                        <td>@Model.DireccionCliente</td>
                    </tr>
                </table>
            </div>

            <div>
                <div class="section-label">Datos de documento</div>
                <table>
                    <tr>
                        <td class="label">Referencia:</td>
                        <td>@Txt(Get(orden, "ReferenciaCliente", "NumAtCard", "CustomerRef"))</td>
                    </tr>
                    <tr>
                        <td class="label">Vendedor:</td>
                        <td>@Txt(Get(orden, "Vendedor", "SlpName", "SalesPerson"))</td>
                    </tr>
                    <tr>
                        <td class="label">Cond. pago:</td>
                        <td>@Txt(Get(orden, "CondicionPago", "PaymentTerms", "PymntGroup"))</td>
                    </tr>
                    <tr>
                        <td class="label">Entrega:</td>
                        <td>@DateTxt(Get(orden, "FechaEntrega", "DocDueDate", "DeliveryDate"))</td>
                    </tr>
                </table>
            </div>
        </div>

        <table class="items">
            <thead>
                <tr>
                    <th style="width:35px;">#</th>
                    <th style="width:85px;">Número artículo</th>
                    <th>Producto</th>
                    <th style="width:80px;" class="text-right">KG</th>
                    <th style="width:60px;" class="text-right">Cajas</th>
                    <th style="width:80px;" class="text-right">Precio</th>
                    <th style="width:75px;" class="text-right">Desc.</th>
                    <th style="width:90px;" class="text-right">Total</th>
                </tr>
            </thead>
            <tbody>
                @if (detalles.Count > 0)
                {
                    var i = 1;

                    foreach (var d in detalles)
                    {
                        <tr>
                            <td class="text-center">@i</td>
                            <td>@d.ProductoCodigo</td>
                            <td>@d.ProductoNombre</td>
                            <td class="text-right">@d.Peso.ToString("N2")</td>
                            <td class="text-right">@d.Cajas</td>
                            <td class="text-right">@d.Precio.ToString("C2")</td>
                            <td class="text-right">$0.00</td>
                            <td class="text-right">@d.Importe.ToString("C2")</td>
                        </tr>

                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center">Sin detalle de artículos.</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="blue-line"></div>

        <div class="after-table">
            <div class="amount-words">
                <div class="section-label">Comentarios</div>
                <div>
                    @(string.IsNullOrWhiteSpace(comentariosPdf)
                        ? Txt(Get(orden, "Comentarios", "Comments", "Observaciones"))
                        : comentariosPdf)
                </div>
                <br />
                <div class="section-label">Cantidad total</div>
                <div>@totalCantidad.ToString("N2")</div>
            </div>

            <div class="totals">
                <table>
                    <tr>
                        <td>Subtotal</td>
                        <td class="text-right">@subtotal.ToString("C2", CultureInfo.GetCultureInfo("es-MX"))</td>
                    </tr>
                    <tr>
                        <td>Descuento</td>
                        <td class="text-right">@descuento.ToString("C2", CultureInfo.GetCultureInfo("es-MX"))</td>
                    </tr>
                    <tr>
                        <td>Impuesto</td>
                        <td class="text-right">@iva.ToString("C2", CultureInfo.GetCultureInfo("es-MX"))</td>
                    </tr>
                    <tr class="total-row">
                        <td>Total</td>
                        <td class="text-right">@total.ToString("C2", CultureInfo.GetCultureInfo("es-MX"))</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="footer-block">
            <div class="blue-line"></div>

            <div class="footer-grid">
               @*  <div class="small-box">
                    <b>
                    </b><br />
                    @Txt(Get(orden, "DireccionEntrega", "ShipToAddress", "Address2"))
                </div> *@

               @*  <div class="small-box">
                    <b>Dirección de facturación</b><br />
                    @Txt(Get(orden, "DireccionFacturacion", "BillToAddress", "Address"))
                </div> *@
            </div>
        </div>

        <div class="signature">
            <div>Recibió</div>
        </div>

    </div>

</body>
</html>
@functions {
    object Get(object obj, params string[] names)
    {
        if (obj == null) return null;

        if (obj is System.Text.Json.Nodes.JsonObject jsonObj)
        {
            foreach (var name in names)
            {
                foreach (var kv in jsonObj)
                {
                    if (string.Equals(kv.Key, name, StringComparison.OrdinalIgnoreCase))
                        return UnwrapJson(kv.Value);
                }
            }

            return null;
        }

        if (obj is System.Text.Json.Nodes.JsonNode jsonNode)
        {
            return UnwrapJson(jsonNode);
        }

        var dict = obj as IDictionary;
        if (dict != null)
        {
            foreach (var name in names)
            {
                foreach (var key in dict.Keys)
                {
                    if (string.Equals(key?.ToString(), name, StringComparison.OrdinalIgnoreCase))
                        return dict[key];
                }
            }
        }

        var type = obj.GetType();

        foreach (var name in names)
        {
            var prop = type.GetProperty(
                name,
                BindingFlags.IgnoreCase | BindingFlags.Public | BindingFlags.Instance
            );

            if (prop != null)
                return prop.GetValue(obj);
        }

        return null;
    }

    object UnwrapJson(System.Text.Json.Nodes.JsonNode node)
    {
        if (node == null) return null;

        if (node is System.Text.Json.Nodes.JsonValue value)
        {
            if (value.TryGetValue<string>(out var s)) return s;
            if (value.TryGetValue<decimal>(out var dec)) return dec;
            if (value.TryGetValue<double>(out var dbl)) return dbl;
            if (value.TryGetValue<int>(out var i)) return i;
            if (value.TryGetValue<long>(out var l)) return l;
            if (value.TryGetValue<bool>(out var b)) return b;
            if (value.TryGetValue<DateTime>(out var dt)) return dt;
        }

        return node;
    }

    List<object> GetItems(object obj)
    {
        var result = new List<object>();

        if (obj == null) return result;

        var possibleNames = new[]
        {
            "Detalles",
            "Detalle",
            "Lineas",
            "Items",
            "Articulos",
            "DocumentLines",
            "Lines"
        };

        foreach (var name in possibleNames)
        {
            var value = Get(obj, name);

            if (value is System.Text.Json.Nodes.JsonArray jsonArray)
            {
                foreach (var item in jsonArray)
                    result.Add(item);

                if (result.Count > 0)
                    return result;
            }

            if (value is IEnumerable enumerable && !(value is string))
            {
                foreach (var item in enumerable)
                    result.Add(item);

                if (result.Count > 0)
                    return result;
            }
        }

        return result;
    }

    string Txt(object value, string fallback = "")
    {
        if (value == null) return fallback;

        var text = value.ToString();

        return string.IsNullOrWhiteSpace(text) ? fallback : text;
    }

    decimal ToDecimal(object value)
    {
        if (value == null) return 0;

        if (value is System.Text.Json.Nodes.JsonNode node)
            value = UnwrapJson(node);

        decimal result;

        if (decimal.TryParse(value.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out result))
            return result;

        if (decimal.TryParse(value.ToString(), NumberStyles.Any, CultureInfo.GetCultureInfo("es-MX"), out result))
            return result;

        return 0;
    }

    string Money(object value)
    {
        return ToDecimal(value).ToString("C2", CultureInfo.GetCultureInfo("es-MX"));
    }

    string Num(object value)
    {
        return ToDecimal(value).ToString("N2");
    }

    string DateTxt(object value)
    {
        if (value == null) return "";

        if (value is System.Text.Json.Nodes.JsonNode node)
            value = UnwrapJson(node);

        DateTime date;

        if (DateTime.TryParse(value.ToString(), out date))
            return date.ToString("dd/MM/yyyy");

        return value.ToString();
    }
}