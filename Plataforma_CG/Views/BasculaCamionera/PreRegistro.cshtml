@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Pre-registro Báscula";
}

<style>
    :root {
        --bg: #f5eeee;
        --bg-2: #eadada;
        --surface: #ffffff;
        --surface-soft: #fff7f7;
        --line: #e2c7c7;
        --line-strong: #caa1a1;
        --text: #2b1515;
        --muted: #7c5a5a;
        --vino: #7b1113;
        --vino-2: #9d1619;
        --vino-3: #b42024;
        --vino-dark: #3a0809;
        --green: #16834a;
        --amber: #b7791f;
        --red: #b91c1c;
        --shadow: 0 14px 35px rgba(61, 14, 14, .13);
        --shadow-soft: 0 8px 22px rgba(61, 14, 14, .08);
        --radius-lg: 18px;
        --radius-md: 12px;
        --radius-sm: 8px;
    }

    /*
       Todo el estilo queda contenido dentro de esta vista.
       Así no se sobrescriben body, contenedores ni botones del Layout2.
    */
    .pre-app,
    .pre-app *,
    .modal-backdrop,
    .modal-backdrop * {
        box-sizing: border-box;
    }

    .pre-app {
        width: 100% !important;
        max-width: 100% !important;
        min-height: calc(100dvh - 72px) !important;
        margin: 0 !important;
        overflow-x: hidden !important;
        font-family: "Segoe UI", Tahoma, Verdana, Arial, sans-serif;
        color: var(--text);
        background: linear-gradient(180deg, #f9f1f1 0%, #eedede 100%);
        padding: 8px 12px 12px !important;
    }

    .pre-wrap {
        width: 100% !important;
        max-width: 100% !important;
        min-width: 0 !important;
        margin: 0 auto !important;
    }

    .pre-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        margin-bottom: 8px;
        padding: 9px 14px;
        border-radius: 16px;
        background: linear-gradient(135deg, #3b0809 0%, #681012 52%, #8f1719 100%);
        color: #fff;
        box-shadow: var(--shadow-soft);
        min-width: 0;
    }

    .pre-title {
        min-width: 0;
    }

        .pre-title h1 {
            margin: 0;
            font-size: clamp(18px, 1.6vw, 24px);
            font-weight: 950;
            line-height: 1.05;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .pre-title p {
            margin: 3px 0 0;
            color: #ffe1e1;
            font-size: 11px;
            font-weight: 700;
            line-height: 1.2;
            overflow-wrap: anywhere;
        }

    .pre-actions,
    .form-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 7px;
        flex-wrap: wrap;
        min-width: 0;
    }

    .pre-btn {
        min-height: 32px;
        border: 1px solid var(--line-strong);
        border-radius: 9px;
        padding: 0 12px;
        background: linear-gradient(180deg, #fff, #f6e8e8);
        color: var(--vino-dark);
        font-family: inherit;
        font-size: 11px;
        font-weight: 900;
        cursor: pointer;
        white-space: nowrap;
        transition: transform .14s ease, box-shadow .14s ease, background .14s ease;
    }

        .pre-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 22px rgba(79, 10, 10, .16);
        }

        .pre-btn.primary {
            color: #fff;
            border-color: #650b0d;
            background: linear-gradient(135deg, #b91c1c 0%, #8f1215 55%, #58080a 100%);
        }

        .pre-btn.success {
            color: #fff;
            border-color: #10663a;
            background: linear-gradient(135deg, #24a35a 0%, #157f49 100%);
        }

        .pre-btn.warning {
            color: #4c2b00;
            border-color: #d69a2d;
            background: linear-gradient(135deg, #fff2be 0%, #f1c35b 100%);
        }

        .pre-btn.danger {
            color: #fff;
            border-color: #790a0c;
            background: linear-gradient(135deg, #ce1f24 0%, #8f1114 100%);
        }

        .pre-btn.small {
            min-height: 28px;
            padding: 0 9px;
            font-size: 10px;
            border-radius: 8px;
        }

    .grid-main {
        display: grid;
        grid-template-columns: 1fr !important;
        gap: 10px;
        align-items: stretch;
        width: 100%;
        min-width: 0;
    }

    .card {
        width: 100%;
        min-width: 0;
        border: 1px solid rgba(123, 17, 19, .14);
        border-radius: var(--radius-lg);
        background: rgba(255, 255, 255, .93);
        box-shadow: var(--shadow-soft);
        overflow: hidden;
        margin-bottom: 10px;
    }

    .card-title {
        min-height: 36px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 9px 14px;
        color: #fff;
        background: linear-gradient(135deg, #6b0d10 0%, #8d1518 60%, #611012 100%);
        border-bottom: 1px solid rgba(82, 5, 7, .40);
        font-size: 12px;
        font-weight: 950;
        min-width: 0;
    }

        .card-title span {
            font-size: 11px;
            font-weight: 700;
            color: #ffe3e3;
            overflow-wrap: anywhere;
            text-align: right;
        }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 8px 10px;
        padding: 12px 14px;
        background: linear-gradient(180deg, #fffafa, #f8eeee);
        align-items: end;
        width: 100%;
        min-width: 0;
    }

    .form-group {
        min-width: 0;
    }

    .span-2 {
        grid-column: span 2;
    }

    .span-3 {
        grid-column: span 3;
    }

    .span-4 {
        grid-column: span 4;
    }

    .span-6 {
        grid-column: 1 / -1;
    }

    .pre-app label {
        display: block;
        margin-bottom: 4px;
        color: var(--vino-dark);
        font-size: 11px;
        font-weight: 900;
        line-height: 1.15;
    }

    .pre-app input,
    .pre-app select,
    .pre-app textarea,
    .modal-backdrop input,
    .modal-backdrop select,
    .modal-backdrop textarea {
        width: 100% !important;
        max-width: 100% !important;
        min-width: 0 !important;
        height: 32px !important;
        border: 1px solid #cda7a7 !important;
        border-radius: 8px !important;
        background: #fff !important;
        color: #321111 !important;
        padding: 5px 8px !important;
        font: inherit !important;
        font-size: 12px !important;
        outline: none !important;
        box-shadow: inset 0 1px 0 rgba(0,0,0,.02) !important;
    }

    textarea {
        height: 48px !important;
        min-height: 48px !important;
        resize: vertical;
    }

        .pre-app input:focus,
        .pre-app select:focus,
        .pre-app textarea:focus,
        .modal-backdrop input:focus,
        .modal-backdrop select:focus,
        .modal-backdrop textarea:focus {
            border-color: var(--vino-2) !important;
            box-shadow: 0 0 0 3px rgba(157, 22, 25, .13) !important;
        }

    /* =========================================================
           VALIDACIÓN OBLIGATORIA DE TODOS LOS CAMPOS
           Si falta cualquier dato, no permite crear pre-registro.
           ========================================================= */

    .required-mark {
        color: var(--red);
        font-weight: 950;
        margin-left: 2px;
    }

    .pre-app input.input-error,
    .pre-app select.input-error,
    .pre-app textarea.input-error {
        border-color: var(--red) !important;
        background: #fff5f5 !important;
        box-shadow: 0 0 0 3px rgba(185, 28, 28, .14) !important;
    }

    .validation-summary {
        display: none;
        margin: 0 14px 10px;
        padding: 10px 12px;
        border-radius: 12px;
        border: 1px solid #fca5a5;
        background: #fff1f1;
        color: #7f1d1d;
        font-size: 12px;
        font-weight: 800;
        line-height: 1.35;
    }

        .validation-summary.active {
            display: block;
        }

        .validation-summary strong {
            display: block;
            margin-bottom: 4px;
            font-size: 12px;
            font-weight: 950;
        }

        .validation-summary ul {
            margin: 5px 0 0 17px;
            padding: 0;
        }

        .validation-summary li {
            margin: 2px 0;
        }


    .lookup-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 76px;
        gap: 6px;
        align-items: center;
        min-width: 0;
    }

    .hint {
        margin-top: 3px;
        color: var(--muted);
        font-size: 10px;
        line-height: 1.2;
        overflow-wrap: anywhere;
    }

    .result-box {
        padding: 9px 14px;
        background: linear-gradient(180deg, #fffafa, #f3e5e5);
        border-top: 1px solid var(--line);
    }

        .result-box .pre-btn {
            margin-right: 5px;
            margin-bottom: 5px;
        }

    .status {
        display: inline-flex;
        align-items: center;
        min-height: 26px;
        padding: 4px 9px;
        border-radius: 999px;
        background: #fff4ce;
        border: 1px solid #efc96f;
        color: #6d3d00;
        font-size: 10px;
        font-weight: 950;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

        .status.ok {
            color: #0f5132;
            background: #dcfce7;
            border-color: #86efac;
        }

        .status.err {
            color: #7f1d1d;
            background: #fee2e2;
            border-color: #fca5a5;
        }

    .folio-box {
        display: grid;
        grid-template-columns: minmax(260px, .85fr) minmax(320px, 1.15fr) minmax(320px, 1.3fr);
        gap: 8px;
        margin-top: 9px;
        align-items: stretch;
    }

    .big-folio,
    .code-panel {
        min-width: 0;
        min-height: 62px;
        padding: 9px 10px;
        border-radius: 12px;
        background: linear-gradient(180deg, #fff, #fff8f8);
        border: 1px solid rgba(123, 17, 19, .13);
    }

        .big-folio label,
        .code-panel label {
            display: block;
            color: var(--muted);
            font-size: 10px;
            font-weight: 950;
            text-transform: uppercase;
            letter-spacing: .05em;
            margin-bottom: 5px;
        }

        .big-folio strong {
            display: block;
            color: var(--vino-dark);
            font-size: clamp(16px, 1.5vw, 22px);
            font-weight: 950;
            line-height: 1.1;
            overflow-wrap: anywhere;
        }

    .code-box {
        width: 100%;
        min-height: 32px;
        padding: 6px 8px;
        border-radius: 9px;
        border: 1px dashed #cda7a7;
        background: #fffafa;
        font-family: Consolas, Monaco, monospace;
        font-size: 11px;
        line-height: 1.25;
        word-break: break-all;
        color: #321111;
    }

    .filter-row {
        display: grid;
        grid-template-columns: 170px minmax(0, 1fr) 110px;
        gap: 8px;
        padding: 10px 14px;
        background: #fffafa;
        border-top: 1px solid var(--line);
        min-width: 0;
    }

    .table-wrap {
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        overflow-y: auto;
        max-height: calc(100dvh - 470px);
        min-height: 210px;
        background: #fff;
        border-top: 1px solid var(--line);
        -webkit-overflow-scrolling: touch;
        scrollbar-gutter: stable;
    }

    .pre-app table,
    .modal-backdrop table {
        width: max-content;
        min-width: 100%;
        max-width: none;
        table-layout: fixed;
        border-collapse: separate !important;
        border-spacing: 0 !important;
        font-size: 12px;
        background: #fff;
    }

    .pre-app th,
    .modal-backdrop th {
        position: sticky;
        top: 0;
        z-index: 2;
        padding: 8px 7px;
        text-align: left;
        color: #fff;
        background: linear-gradient(135deg, #751012, #4e080a);
        border-right: 1px solid rgba(255,255,255,.12);
        white-space: nowrap;
        font-size: 11px;
        font-weight: 950;
    }

    .pre-app td,
    .modal-backdrop td {
        padding: 7px;
        border-bottom: 1px solid #efdada;
        border-right: 1px solid #efdada;
        background: #fff;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        vertical-align: middle;
        font-size: 11px;
        color: #1f1212;
    }

    .pre-app tr:nth-child(even) td,
    .modal-backdrop tr:nth-child(even) td {
        background: #fff7f7;
    }

    .pre-app tr:hover td,
    .modal-backdrop tr:hover td {
        background: #fff0f0;
    }

    .pre-app th:nth-child(1), .pre-app td:nth-child(1) {
        min-width: 160px;
    }

    .pre-app th:nth-child(2), .pre-app td:nth-child(2) {
        min-width: 130px;
    }

    .pre-app th:nth-child(3), .pre-app td:nth-child(3) {
        min-width: 145px;
    }

    .pre-app th:nth-child(4), .pre-app td:nth-child(4) {
        min-width: 210px;
    }

    .pre-app th:nth-child(5), .pre-app td:nth-child(5) {
        min-width: 210px;
    }

    .pre-app th:nth-child(6), .pre-app td:nth-child(6) {
        min-width: 90px;
    }

    .pre-app th:nth-child(7), .pre-app td:nth-child(7) {
        min-width: 130px;
    }

    .pre-app th:nth-child(8), .pre-app td:nth-child(8) {
        min-width: 150px;
    }

    .pre-app th:nth-child(9), .pre-app td:nth-child(9) {
        min-width: 150px;
    }

    .pre-app th:nth-child(10), .pre-app td:nth-child(10) {
        min-width: 90px;
    }

    .pre-app th:nth-child(11), .pre-app td:nth-child(11) {
        min-width: 240px;
    }

    .modal-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(25, 5, 5, .62);
        padding: 18px;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(3px);
    }

        .modal-backdrop.active {
            display: flex;
        }

    .modal {
        width: min(980px, 96vw);
        max-height: min(760px, 92vh);
        overflow: hidden;
        background: #fffafa;
        border-radius: 18px;
        border: 1px solid rgba(123, 17, 19, .22);
        box-shadow: 0 26px 70px rgba(25, 3, 3, .38);
        display: flex;
        flex-direction: column;
    }

    .modal-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        padding: 12px 15px;
        color: #fff;
        background: linear-gradient(135deg, #6b0d10, #9d1619);
    }

        .modal-head strong {
            font-size: 15px;
        }

    .modal-body {
        overflow: auto;
        background: #fff;
    }

        .modal-body table {
            min-width: 760px;
        }

    .modal-search {
        padding: 12px;
        background: #fffafa;
        border-bottom: 1px solid var(--line);
    }

    .close-x {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        border: 1px solid rgba(255,255,255,.35);
        background: rgba(255,255,255,.10);
        color: #fff;
        font-size: 20px;
        font-weight: 900;
        cursor: pointer;
    }

    /* Laptop / caseta: mantiene todo ancho, compacta verticalmente */
    @@media screen and (max-height: 850px) and (min-width: 901px) {
        .pre-app {
            padding-top: 6px !important;
            padding-bottom: 8px !important;
        }

        .pre-header {
            padding-top: 7px;
            padding-bottom: 7px;
            margin-bottom: 7px;
        }

        .pre-title h1 {
            font-size: 18px;
        }

        .pre-title p {
            font-size: 10px;
        }

        .card {
            margin-bottom: 8px;
            border-radius: 14px;
        }

        .card-title {
            min-height: 32px;
            padding-top: 7px;
            padding-bottom: 7px;
        }

        .form-grid {
            padding-top: 9px;
            padding-bottom: 9px;
            gap: 7px 9px;
        }

        .pre-app input,
        .pre-app select {
            height: 29px !important;
        }

        .pre-app textarea {
            height: 42px !important;
            min-height: 42px !important;
        }

        .result-box {
            padding-top: 8px;
            padding-bottom: 8px;
        }

        .folio-box {
            margin-top: 7px;
        }

        .table-wrap {
            max-height: calc(100dvh - 430px);
            min-height: 185px;
        }
    }

    @@media (min-width: 1600px) {
        .form-grid {
            grid-template-columns: repeat(6, minmax(150px, 1fr));
        }

        .pre-app {
            padding-left: 16px !important;
            padding-right: 16px !important;
        }
    }

    @@media (max-width: 1280px) and (min-width: 901px) {
        .form-grid {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }

        .span-4 {
            grid-column: 1 / -1;
        }

        .folio-box {
            grid-template-columns: 1fr;
        }

        .table-wrap {
            max-height: calc(100dvh - 520px);
        }
    }

    @@media (max-width: 900px) {
        .pre-app {
            padding: 6px 8px 12px !important;
        }

        .pre-header {
            display: block;
        }

        .pre-title h1 {
            white-space: normal;
        }

        .pre-actions {
            justify-content: flex-start;
            margin-top: 9px;
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

            .pre-actions .pre-btn {
                width: 100%;
            }

        .form-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            padding: 10px;
            gap: 9px;
        }

        .span-2,
        .span-3,
        .span-4,
        .span-6 {
            grid-column: 1 / -1;
        }

        .folio-box {
            grid-template-columns: 1fr;
        }

        .filter-row {
            grid-template-columns: 1fr;
            padding: 10px;
        }

        .table-wrap {
            max-height: 58vh;
            min-height: 240px;
        }

        .result-box .pre-btn {
            width: calc(50% - 6px);
        }
    }

    @@media (max-width: 640px) {
        .pre-app {
            padding: 6px 7px 10px !important;
        }

        .form-grid {
            grid-template-columns: 1fr;
        }

        .lookup-row {
            grid-template-columns: 1fr;
        }

        .pre-actions {
            grid-template-columns: 1fr;
        }

        .result-box .pre-btn {
            width: 100%;
        }

        .card-title {
            align-items: flex-start;
            flex-direction: column;
            gap: 3px;
        }

            .card-title span {
                text-align: left;
            }

        .pre-app input,
        .pre-app select,
        .pre-app textarea,
        .modal-backdrop input {
            height: 40px !important;
            font-size: 14px !important;
        }

        .pre-app textarea {
            min-height: 76px !important;
        }

        .table-wrap table {
            min-width: 980px;
        }

        .modal {
            width: 98vw;
            max-height: 94vh;
            border-radius: 14px;
        }
    }

    /* Fondo blanco completo e integrado con _Layout2 */
    html,
    body {
        background: #ffffff !important;
    }

    .container,
    .container-fluid,
    main,
    .body-content,
    .content-wrapper,
    .page-content,
    .main-content,
    .layout-content {
        width: 100% !important;
        max-width: 100% !important;
        min-height: 100% !important;
        margin-left: 0 !important;
        margin-right: 0 !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
        background: #ffffff !important;
        border: 0 !important;
        border-radius: 0 !important;
        box-shadow: none !important;
    }

    @@media screen {
        #preRegistroApp {
            position: relative !important;
            left: auto !important;
            right: auto !important;
            width: 100vw !important;
            max-width: 100vw !important;
            min-width: 0 !important;
            min-height: calc(100dvh - 70px) !important;
            margin-left: calc(50% - 50vw) !important;
            margin-right: calc(50% - 50vw) !important;
            padding: 6px 10px 12px !important;
            background: #ffffff !important;
            border: 0 !important;
            border-radius: 0 !important;
            box-shadow: none !important;
            overflow-x: hidden !important;
        }

        #preRegistroApp .pre-wrap {
            width: 100% !important;
            max-width: none !important;
            min-width: 0 !important;
            margin: 0 !important;
            background: #ffffff !important;
        }
    }

    @@media (max-width: 900px) {
        #preRegistroApp {
            padding: 6px 8px 10px !important;
        }
    }

    @@media (max-width: 640px) {
        #preRegistroApp {
            padding: 6px 6px 8px !important;
        }
    }

</style>

<div class="pre-app" id="preRegistroApp">
    <div class="pre-wrap">
        <div class="pre-header">
            <div class="pre-title">
                <h1>Pre-registro de Báscula</h1>
                @*  <p>Captura previa para CEDIS, Compras, Embarques o Producción. Caseta solo escanea el QR y pesa.</p> *@
            </div>
            <div class="pre-actions">
                @* <button class="pre-btn" type="button" id="btnAbrirBascula">Ir a caseta</button> *@
                <button class="pre-btn success" type="button" id="btnRecargar">Recargar pendientes</button>
            </div>
        </div>

        <div class="grid-main">
            <div class="card">
                <div class="card-title">
                    <div>Captura del pre-registro</div>
                    <span>Esta información se cargará automáticamente en caseta al escanear el QR</span>
                </div>

                <form id="frmPreRegistro" autocomplete="off">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Área origen <span class="required-mark">*</span></label>
                            <select id="areaOrigen" required data-required-label="Área origen">
                                <option value="CEDIS">CEDIS</option>
                                <option value="Compras">Compras</option>
                                <option value="Embarques">Embarques</option>
                                <option value="Producción">Producción</option>
                                <option value="Ventas">Ventas</option>
                                <option value="Logística">Logística</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Tipo movimiento <span class="required-mark">*</span></label>
                            <select id="tipoMovimiento" required data-required-label="Tipo movimiento">
                                <option value="Entrada proveedor">Entrada proveedor</option>
                                <option value="Entrada traslado">Entrada traslado</option>
                                <option value="Entrada devolución">Entrada devolución</option>
                                <option value="Salida venta">Salida venta</option>
                                <option value="Salida traslado">Salida traslado</option>
                                <option value="Salida maquila">Salida maquila</option>
                                <option value="Salida desperdicio">Salida desperdicio</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Clasificación <span class="required-mark">*</span></label>
                            <select id="clasificacion" required data-required-label="Clasificación">
                                <option value="Ganado en pie">Ganado en pie</option>
                                <option value="Cajas de carne">Cajas de carne</option>
                                <option value="Canal / medias canales">Canal / medias canales</option>
                                <option value="Insumos">Insumos</option>
                                <option value="Subproducto">Subproducto</option>
                                <option value="Material empaque">Material empaque</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label>Placas <span class="required-mark">*</span></label>
                            <input id="placas" type="text" maxlength="40" placeholder="ABC-123" required data-required-label="Placas" />
                        </div>

                        <div class="form-group span-2">
                            <label>Proveedor / cliente <span class="required-mark">*</span></label>
                            <div class="lookup-row">
                                <input id="tercero" type="text" required data-required-label="Proveedor / cliente" placeholder="Nombre proveedor o cliente" />
                                <button class="pre-btn small primary" type="button" id="btnBuscarTercero">Buscar</button>
                            </div>
                            <div class="hint">Para entradas normalmente es proveedor; para salidas normalmente es cliente.</div>
                        </div>

                        <div class="form-group">
                            <label>Código SAP <span class="required-mark">*</span></label>
                            <input id="codigoSap" type="text" maxlength="60" placeholder="Código SAP" required data-required-label="Código SAP" />
                        </div>

                        <div class="form-group">
                            <label>Documento <span class="required-mark">*</span></label>
                            <input id="documento" type="text" maxlength="120" placeholder="Orden, factura, remisión" required data-required-label="Documento" />
                        </div>

                        <div class="form-group span-2">
                            <label>Producto <span class="required-mark">*</span></label>
                            <div class="lookup-row">
                                <input id="producto" type="text" required data-required-label="Producto" placeholder="Producto / material" />
                                <button class="pre-btn small primary" type="button" id="btnBuscarProducto">Buscar</button>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>SKU <span class="required-mark">*</span></label>
                            <input id="sku" type="text" maxlength="80" placeholder="SKU / código artículo" required data-required-label="SKU" />
                        </div>

                        <div class="form-group">
                            <label>Chofer <span class="required-mark">*</span></label>
                            <input id="chofer" type="text" maxlength="160" placeholder="Nombre chofer" required data-required-label="Chofer" />
                        </div>

                        <div class="form-group span-2">
                            <label>Origen <span class="required-mark">*</span></label>
                            <input id="origen" type="text" maxlength="180" placeholder="Rancho, proveedor, planta, almacén" required data-required-label="Origen" />
                        </div>

                        <div class="form-group span-2">
                            <label>Destino <span class="required-mark">*</span></label>
                            <input id="destino" type="text" maxlength="180" placeholder="Planta, CEDIS, cliente, sucursal" required data-required-label="Destino" />
                        </div>

                        <div class="form-group span-2">
                            <label>Condición <span class="required-mark">*</span></label>
                            <input id="condicion" type="text" maxlength="120" placeholder="Normal, refrigerado, jaula, caja seca, etc." required data-required-label="Condición" />
                        </div>

                        <div class="form-group span-4">
                            <label>Observaciones <span class="required-mark">*</span></label>
                            <textarea id="observaciones" maxlength="1000" placeholder="Indicaciones para caseta" required data-required-label="Observaciones"></textarea>
                        </div>
                    </div>

                    <div class="validation-summary" id="validationSummary" aria-live="polite"></div>

                    <div class="result-box">
                        <div class="form-actions" style="justify-content:flex-start;">
                            <button class="pre-btn success" type="submit" id="btnCrearPreRegistro">Crear pre-registro</button>
                            <button class="pre-btn" type="button" id="btnLimpiar">Limpiar</button>
                            <button class="pre-btn primary" type="button" id="btnImprimirUltimo" disabled>Imprimir hoja QR</button>
                            <button class="pre-btn warning" type="button" id="btnCopiarUltimo" disabled>Copiar código QR</button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="card">
                <div class="card-title">
                    <div>Resultado para caseta</div>
                    <span>Entrega esta hoja al operador para que solo escanee y pese</span>
                </div>
                <div class="result-box">
                    <span class="status" id="resultStatus">Sin pre-registro creado</span>
                    <div class="folio-box">
                        <div class="big-folio">
                            <label>Folio pre-registro</label>
                            <strong id="folioPreview">---</strong>
                        </div>
                        <div class="code-panel">
                            <label>Código que leerá caseta</label>
                            <div class="code-box" id="scanPayloadPreview">---</div>
                        </div>
                        <div class="code-panel">
                            <label>URL hoja QR</label>
                            <div class="code-box" id="hojaUrlPreview">---</div>
                        </div>
                    </div>
                    <div class="hint" style="margin-top:8px;">
                        El operador abre la vista de báscula, escanea esta hoja y se llenan los datos automáticamente. Si el camión llega sin hoja, caseta puede capturar manualmente.
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-title">
                <div>Pre-registros pendientes / en proceso</div>
                <span>Control de folios que aún no se han cerrado en báscula</span>
            </div>
            <div class="filter-row">
                <select id="filtroEstatus">
                    <option value="PENDIENTE_CASETA">Pendiente caseta</option>
                    <option value="ESCANEADO_CASETA">Escaneado caseta</option>
                    <option value="PESADO_ENTRADA">Pesado entrada</option>
                    <option value="CERRADO">Cerrado</option>
                    <option value="CANCELADO">Cancelado</option>
                    <option value="">Todos</option>
                </select>
                <input id="filtroQ" type="text" placeholder="Buscar folio, tercero, producto, placas, documento, origen o destino" />
                <button class="pre-btn primary" type="button" id="btnBuscarPendientes">Buscar</button>
            </div>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Folio</th>
                            <th>Estatus</th>
                            <th>Tipo</th>
                            <th>Tercero</th>
                            <th>Producto</th>
                            <th>Placas</th>
                            <th>Documento</th>
                            <th>Origen</th>
                            <th>Destino</th>
                            <th>Área</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="tblPreRegistros">
                        <tr><td colspan="11">Cargando...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal-backdrop" id="catalogModal">
    <div class="modal">
        <div class="modal-head">
            <strong id="catalogTitle">Catálogo</strong>
            <button class="close-x" type="button" id="btnCerrarCatalogo">×</button>
        </div>
        <div class="modal-search">
            <input id="catalogSearch" type="text" placeholder="Buscar..." />
        </div>
        <div class="modal-body">
            <table>
                <thead id="catalogHead"></thead>
                <tbody id="catalogBody"></tbody>
            </table>
        </div>
    </div>
</div>

<script src="/lib/qrcode/qrcode.min.js"></script>
<script>
    if (typeof QRCode === "undefined") {
        document.write('<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"><\/script>');
    }
</script>
<script>
    (function () {
        "use strict";

        var ENDPOINT_CREAR = "/BasculaCamionera/PreRegistro/Crear";
        var ENDPOINT_LISTAR = "/BasculaCamionera/PreRegistro/Listar";
        var ENDPOINT_CANCELAR = "/BasculaCamionera/PreRegistro/Cancelar";
        var ENDPOINT_CLIENTES = "/BasculaCamionera/BuscarClientes";
        var ENDPOINT_ARTICULOS = "/BasculaCamionera/BuscarArticulos";
        var URL_BASCULA = "/BasculaCamionera";

        var ultimo = null;
        var catalogMode = "";
        var catalogRows = [];

        var REQUIRED_FIELDS = [
            { id: "areaOrigen", label: "Área origen" },
            { id: "tipoMovimiento", label: "Tipo movimiento" },
            { id: "clasificacion", label: "Clasificación" },
            { id: "placas", label: "Placas" },
            { id: "tercero", label: "Proveedor / cliente" },
            { id: "codigoSap", label: "Código SAP" },
            { id: "documento", label: "Documento" },
            { id: "producto", label: "Producto" },
            { id: "sku", label: "SKU" },
            { id: "chofer", label: "Chofer" },
            { id: "origen", label: "Origen" },
            { id: "destino", label: "Destino" },
            { id: "condicion", label: "Condición" },
            { id: "observaciones", label: "Observaciones" }
        ];

        function byId(id) { return document.getElementById(id); }
        function val(id) { var el = byId(id); return el ? String(el.value || "").trim() : ""; }
        function setVal(id, value) { var el = byId(id); if (el) el.value = value == null ? "" : value; }
        function setText(id, value) { var el = byId(id); if (el) el.textContent = value == null ? "" : value; }

        function setStatus(text, type) {
            var el = byId("resultStatus");
            if (!el) return;
            el.textContent = text;
            el.classList.remove("ok", "err");
            if (type) el.classList.add(type);
        }

        function safeOn(id, eventName, handler) {
            var el = byId(id);
            if (el) el.addEventListener(eventName, handler);
        }

        function limpiarErrores() {
            REQUIRED_FIELDS.forEach(function (f) {
                var el = byId(f.id);
                if (el) el.classList.remove("input-error");
            });

            var summary = byId("validationSummary");
            if (summary) {
                summary.classList.remove("active");
                summary.innerHTML = "";
            }
        }

        function mostrarErrores(camposFaltantes) {
            var summary = byId("validationSummary");
            if (!summary) return;

            summary.innerHTML =
                "<strong>No se puede crear el pre-registro.</strong>" +
                "Capture todos los campos obligatorios antes de guardar:" +
                "<ul>" + camposFaltantes.map(function (x) { return "<li>" + esc(x.label) + "</li>"; }).join("") + "</ul>";

            summary.classList.add("active");
        }

        function marcarErrores(camposFaltantes) {
            limpiarErrores();

            camposFaltantes.forEach(function (f) {
                var el = byId(f.id);
                if (el) el.classList.add("input-error");
            });

            mostrarErrores(camposFaltantes);

            if (camposFaltantes.length) {
                var first = byId(camposFaltantes[0].id);
                if (first) {
                    first.focus();
                    first.scrollIntoView({ behavior: "smooth", block: "center" });
                }
            }
        }

        function campoTieneValor(id) {
            var el = byId(id);
            if (!el) return false;
            return String(el.value || "").trim().length > 0;
        }

        function limpiar() {
            ["placas", "tercero", "codigoSap", "documento", "producto", "sku", "chofer", "origen", "destino", "condicion", "observaciones"].forEach(function (id) {
                setVal(id, "");
            });
            ultimo = null;
            setStatus("Sin pre-registro creado", "");
            setText("folioPreview", "---");
            setText("scanPayloadPreview", "---");
            setText("hojaUrlPreview", "---");
            byId("btnImprimirUltimo").disabled = true;
            byId("btnCopiarUltimo").disabled = true;
            byId("tercero").focus();
        }

        function buildDto() {
            return {
                areaOrigen: val("areaOrigen"),
                tipoMovimiento: val("tipoMovimiento"),
                clasificacion: val("clasificacion"),
                tercero: val("tercero"),
                codigoSap: val("codigoSap"),
                placas: val("placas"),
                producto: val("producto"),
                sku: val("sku"),
                documento: val("documento"),
                chofer: val("chofer"),
                origen: val("origen"),
                destino: val("destino"),
                condicion: val("condicion"),
                observaciones: val("observaciones")
            };
        }

        function validar(dto) {
            var faltantes = REQUIRED_FIELDS.filter(function (f) {
                return !campoTieneValor(f.id);
            });

            if (faltantes.length) {
                marcarErrores(faltantes);
                return "Faltan campos obligatorios.";
            }

            limpiarErrores();
            return "";
        }

        async function crearPreRegistro(ev) {
            if (ev) ev.preventDefault();

            var dto = buildDto();
            var error = validar(dto);
            if (error) {
                setStatus("Faltan campos obligatorios", "err");
                return;
            }

            setStatus("Creando pre-registro...", "");
            byId("btnCrearPreRegistro").disabled = true;

            try {
                var resp = await fetch(ENDPOINT_CREAR, {
                    method: "POST",
                    headers: {
                        "Accept": "application/json",
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(dto)
                });

                var data = await resp.json();

                if (!resp.ok || !data || data.ok !== true) {
                    throw new Error((data && data.msg) ? data.msg : "No se pudo crear el pre-registro.");
                }

                ultimo = data;
                var pre = data.preRegistro || {};
                var hojaUrl = data.hojaUrl || ("/BasculaCamionera/PreRegistro/Hoja?token=" + encodeURIComponent(data.token || pre.token || ""));
                var fullHojaUrl = new URL(hojaUrl, window.location.origin).href;

                setStatus("Pre-registro creado", "ok");
                setText("folioPreview", pre.folioPreRegistro || "---");
                setText("scanPayloadPreview", data.scanPayload || data.qrPayload || ("BASPRE|" + (data.token || pre.token || "")));
                setText("hojaUrlPreview", fullHojaUrl);
                byId("btnImprimirUltimo").disabled = false;
                byId("btnCopiarUltimo").disabled = false;

                await listarPreRegistros();

                if (confirm("Pre-registro creado correctamente. ¿Desea imprimir la hoja QR ahora?")) {
                    window.open(fullHojaUrl, "_blank");
                }
            } catch (err) {
                setStatus("Error al crear", "err");
                alert(err.message);
            } finally {
                byId("btnCrearPreRegistro").disabled = false;
            }
        }

        async function listarPreRegistros() {
            var estatus = encodeURIComponent(val("filtroEstatus"));
            var q = encodeURIComponent(val("filtroQ"));
            var tbody = byId("tblPreRegistros");
            tbody.innerHTML = "<tr><td colspan='11'>Cargando...</td></tr>";

            try {
                var resp = await fetch(ENDPOINT_LISTAR + "?estatus=" + estatus + "&q=" + q + "&take=150", { headers: { "Accept": "application/json" } });
                var data = await resp.json();
                if (!resp.ok || !data || data.ok !== true) throw new Error((data && data.msg) ? data.msg : "No se pudo consultar pre-registros.");

                var rows = data.rows || [];
                if (!rows.length) {
                    tbody.innerHTML = "<tr><td colspan='11'>No hay pre-registros con esos filtros.</td></tr>";
                    return;
                }

                tbody.innerHTML = rows.map(function (r) {
                    var hoja = "/BasculaCamionera/PreRegistro/Hoja?token=" + encodeURIComponent(r.token || "");
                    var payload = "BASPRE|" + (r.token || "");
                    return "<tr>" +
                        td(r.folioPreRegistro) +
                        td(r.estatus) +
                        td(r.tipoMovimiento) +
                        td(r.tercero) +
                        td(r.producto) +
                        td(r.placas) +
                        td(r.documento) +
                        td(r.origen) +
                        td(r.destino) +
                        td(r.areaOrigen) +
                        "<td>" +
                            "<button class='pre-btn small primary' type='button' data-print='" + esc(hoja) + "'>Imprimir</button> " +
                            "<button class='pre-btn small warning' type='button' data-copy='" + esc(payload) + "'>Copiar</button> " +
                            (r.estatus !== "CERRADO" && r.estatus !== "CANCELADO" ? "<button class='pre-btn small danger' type='button' data-cancel='" + esc(r.token || "") + "'>Cancelar</button>" : "") +
                        "</td>" +
                        "</tr>";
                }).join("");
            } catch (err) {
                tbody.innerHTML = "<tr><td colspan='11'>" + esc(err.message) + "</td></tr>";
            }
        }

        function td(value) {
            return "<td title='" + esc(value) + "'>" + esc(value || "") + "</td>";
        }

        function esc(value) {
            return String(value == null ? "" : value)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/\"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        async function copiarTexto(texto) {
            try {
                await navigator.clipboard.writeText(texto);
                alert("Copiado: " + texto);
            } catch (e) {
                prompt("Copie manualmente:", texto);
            }
        }

        async function cancelarToken(token) {
            if (!token) return;
            var motivo = prompt("Motivo de cancelación:", "Cancelado desde pre-registro");
            if (motivo === null) return;

            try {
                var resp = await fetch(ENDPOINT_CANCELAR, {
                    method: "POST",
                    headers: { "Accept": "application/json", "Content-Type": "application/json" },
                    body: JSON.stringify({ token: token, motivo: motivo || "Cancelado" })
                });
                var data = await resp.json();
                if (!resp.ok || !data || data.ok !== true) throw new Error((data && data.msg) ? data.msg : "No se pudo cancelar.");
                await listarPreRegistros();
            } catch (err) {
                alert(err.message);
            }
        }

        async function buscarCatalogo(tipo) {
            catalogMode = tipo;
            catalogRows = [];
            var title = tipo === "producto" ? "Buscar producto / artículo" : "Buscar proveedor / cliente";
            setText("catalogTitle", title);
            byId("catalogModal").classList.add("active");
            setVal("catalogSearch", tipo === "producto" ? val("producto") : val("tercero"));
            await cargarCatalogo();
            byId("catalogSearch").focus();
        }

        async function cargarCatalogo() {
            var q = encodeURIComponent(val("catalogSearch"));
            var head = byId("catalogHead");
            var body = byId("catalogBody");
            body.innerHTML = "<tr><td>Cargando...</td></tr>";

            try {
                var url = catalogMode === "producto"
                    ? ENDPOINT_ARTICULOS + "?q=" + q + "&take=60"
                    : ENDPOINT_CLIENTES + "?q=" + q + "&take=60";

                var resp = await fetch(url, { headers: { "Accept": "application/json" } });
                var data = await resp.json();
                if (!resp.ok || !data || data.ok !== true) throw new Error((data && data.msg) ? data.msg : "No se pudo cargar catálogo.");
                catalogRows = data.rows || [];

                if (catalogMode === "producto") {
                    head.innerHTML = "<tr><th>Código</th><th>Producto</th><th>Acción</th></tr>";
                    body.innerHTML = catalogRows.length ? catalogRows.map(function (r, i) {
                        return "<tr><td>" + esc(r.productoCodigo) + "</td><td>" + esc(r.productoNombre) + "</td><td><button class='pre-btn small primary' data-select-catalog='" + i + "'>Seleccionar</button></td></tr>";
                    }).join("") : "<tr><td colspan='3'>Sin resultados.</td></tr>";
                } else {
                    head.innerHTML = "<tr><th>Código SAP</th><th>Nombre</th><th>Clasificación</th><th>Acción</th></tr>";
                    body.innerHTML = catalogRows.length ? catalogRows.map(function (r, i) {
                        return "<tr><td>" + esc(r.codigoSap) + "</td><td>" + esc(r.nombre) + "</td><td>" + esc(r.clasificacion || r.canal || "") + "</td><td><button class='pre-btn small primary' data-select-catalog='" + i + "'>Seleccionar</button></td></tr>";
                    }).join("") : "<tr><td colspan='4'>Sin resultados.</td></tr>";
                }
            } catch (err) {
                head.innerHTML = "";
                body.innerHTML = "<tr><td>" + esc(err.message) + "</td></tr>";
            }
        }

        function seleccionarCatalogo(index) {
            var r = catalogRows[Number(index)] || null;
            if (!r) return;

            if (catalogMode === "producto") {
                setVal("sku", r.productoCodigo || "");
                setVal("producto", r.productoNombre || "");
            } else {
                setVal("codigoSap", r.codigoSap || "");
                setVal("tercero", r.nombre || "");
            }

            byId("catalogModal").classList.remove("active");
        }

        function abrirUltimaHoja() {
            if (!ultimo) return;
            var pre = ultimo.preRegistro || {};
            var hojaUrl = ultimo.hojaUrl || ("/BasculaCamionera/PreRegistro/Hoja?token=" + encodeURIComponent(ultimo.token || pre.token || ""));
            window.open(new URL(hojaUrl, window.location.origin).href, "_blank");
        }

        function copiarUltimo() {
            if (!ultimo) return;
            var pre = ultimo.preRegistro || {};
            copiarTexto(ultimo.scanPayload || ultimo.qrPayload || ("BASPRE|" + (ultimo.token || pre.token || "")));
        }

        safeOn("frmPreRegistro", "submit", crearPreRegistro);
        safeOn("btnLimpiar", "click", limpiar);
        safeOn("btnRecargar", "click", listarPreRegistros);
        safeOn("btnBuscarPendientes", "click", listarPreRegistros);
        safeOn("btnAbrirBascula", "click", function () { window.location.href = URL_BASCULA; });
        safeOn("btnImprimirUltimo", "click", abrirUltimaHoja);
        safeOn("btnCopiarUltimo", "click", copiarUltimo);
        safeOn("btnBuscarTercero", "click", function () { buscarCatalogo("tercero"); });
        safeOn("btnBuscarProducto", "click", function () { buscarCatalogo("producto"); });
        safeOn("btnCerrarCatalogo", "click", function () { byId("catalogModal").classList.remove("active"); });
        safeOn("catalogSearch", "keydown", function (e) { if (e.key === "Enter") { e.preventDefault(); cargarCatalogo(); } });
        safeOn("catalogSearch", "input", debounce(cargarCatalogo, 350));

        REQUIRED_FIELDS.forEach(function (f) {
            var el = byId(f.id);
            if (!el) return;

            var handler = function () {
                if (campoTieneValor(f.id)) el.classList.remove("input-error");

                var faltantes = REQUIRED_FIELDS.filter(function (x) { return !campoTieneValor(x.id); });
                if (!faltantes.length) limpiarErrores();
            };

            el.addEventListener("input", handler);
            el.addEventListener("change", handler);
        });

        byId("tblPreRegistros").addEventListener("click", function (e) {
            var t = e.target;
            if (!t) return;
            if (t.dataset.print) window.open(t.dataset.print, "_blank");
            if (t.dataset.copy) copiarTexto(t.dataset.copy);
            if (t.dataset.cancel) cancelarToken(t.dataset.cancel);
        });

        byId("catalogBody").addEventListener("click", function (e) {
            var t = e.target;
            if (t && t.dataset.selectCatalog !== undefined) seleccionarCatalogo(t.dataset.selectCatalog);
        });

        function debounce(fn, ms) {
            var timer = null;
            return function () {
                clearTimeout(timer);
                timer = setTimeout(fn, ms);
            };
        }

        listarPreRegistros();
    })();
</script>
