        box-shadow: inset 0 1px 0 rgba(255,255,255,.12), 0 0 0 1px rgba(34,197,94,.18), 0 18px 34px rgba(5, 58, 34, .24) !important;
    }

    .indicador-head,
    .indicador-meta,
    .peso-display-label {
