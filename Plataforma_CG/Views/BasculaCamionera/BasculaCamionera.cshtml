@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Báscula Camionera";
}

<style>
    #basculaApp,
    #catalogModalBackdrop,
    #ticketPrintArea {
    --bg: #f5eeee;
    --bg-2: #eadada;
    --surface: #ffffff;
    --surface-soft: #fff7f7;
    --surface-muted: #f7eaea;
    --panel: #ffffff;
    --panel-2: #fbf1f1;
    --line: #e2c7c7;
    --line-strong: #caa1a1;
    --text: #2b1515;
    --muted: #7c5a5a;
    --vino: #7b1113;
    --vino-2: #9d1619;
    --vino-3: #b42024;
    --vino-dark: #3a0809;
    --green: #16834a;
    --amber: #b7791f;
    --red: #b91c1c;
    --shadow: 0 14px 35px rgba(61, 14, 14, .13);
    --shadow-soft: 0 8px 22px rgba(61, 14, 14, .08);
    --radius-lg: 18px;
    --radius-md: 12px;
    --radius-sm: 8px;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) * {
    box-sizing: border-box;
    }

    #basculaApp {
    min-height: 100%;
    }

    #basculaApp {
    margin: 0 !important;
    padding: 0 !important;
    font-family: "Segoe UI", Tahoma, Verdana, Arial, sans-serif;
    background: radial-gradient(circle at top left, #fff 0, var(--bg) 34%, #e7d4d4 100%) !important;
    color: var(--text);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .container,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .container-fluid,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) main,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .body-content {
    max-width: 100% !important;
    width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
    }

    #basculaApp {
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    background: linear-gradient(180deg, #f9f1f1 0%, #eedede 100%);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .app-header {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
    padding: 14px 18px;
    background: linear-gradient(135deg, #3b0809 0%, #681012 50%, #8f1719 100%);
    color: #fff;
    border-bottom: 1px solid rgba(255, 255, 255, .16);
    box-shadow: 0 12px 30px rgba(70, 0, 0, .22);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .brand-block {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 280px;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .brand-mark {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, .42);
    background: linear-gradient(180deg, rgba(255,255,255,.20), rgba(255,255,255,.04));
    color: #fff;
    font-weight: 900;
    letter-spacing: .6px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.25);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .brand-block h1 {
    margin: 0;
    font-size: clamp(20px, 2vw, 30px);
    font-weight: 850;
    letter-spacing: -.4px;
    line-height: 1;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .brand-block p {
    margin: 5px 0 0;
    color: #ffe5e5;
    font-size: 12px;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .eyebrow {
    color: #ffd2d2;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .11em;
    text-transform: uppercase;
    margin-bottom: 4px;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .toolbar,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .header-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
    flex-wrap: wrap;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .operator-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(130px, 1fr));
    gap: 1px;
    background: rgba(123, 17, 19, .18);
    border-bottom: 1px solid var(--line-strong);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .strip-item {
    padding: 9px 16px;
    background: rgba(255, 250, 250, .82);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    min-width: 0;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .strip-item span {
    color: var(--muted);
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .05em;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .strip-item strong {
    color: var(--vino-dark);
    font-size: 12px;
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .content {
    padding: 16px;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .workspace {
    max-width: 1780px;
    margin: 0 auto;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
    flex-wrap: wrap;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .tab {
    min-height: 38px;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0 16px;
    background: rgba(255, 255, 255, .82);
    color: var(--vino-dark);
    cursor: pointer;
    font-size: 12px;
    font-weight: 800;
    box-shadow: var(--shadow-soft);
    white-space: nowrap;
    transition: transform .14s ease, box-shadow .14s ease, background .14s ease;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .tab:hover,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .tool-btn:hover,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .pm-btn:hover,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .lookup-btn:hover,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .small-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 22px rgba(79, 10, 10, .16);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .tab.active {
    background: linear-gradient(135deg, var(--vino-2), #5c090b);
    color: #fff;
    border-color: #641112;
    box-shadow: 0 12px 26px rgba(123, 17, 19, .24);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .section {
    border: 1px solid rgba(123, 17, 19, .14);
    background: rgba(255, 255, 255, .90);
    margin-bottom: 14px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .section-title {
    padding: 12px 16px;
    font-size: 13px;
    font-weight: 850;
    color: #fff;
    background: linear-gradient(135deg, #6b0d10 0%, #8d1518 60%, #611012 100%);
    border-bottom: 1px solid rgba(82, 5, 7, .40);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .section-title span {
    font-weight: 700;
    opacity: .92;
    font-size: 12px;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .section-title-light {
    background: linear-gradient(180deg, #fffafa, #f7e7e7);
    color: var(--vino-dark);
    border-bottom: 1px solid var(--line);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .bascula-resumen {
    display: grid;
    grid-template-columns: minmax(360px, 1.35fr) repeat(4, minmax(150px, 1fr));
    gap: 12px;
    padding: 14px;
    background: linear-gradient(180deg, #fff8f8, #f4e6e6);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .peso-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, .14);
    background: radial-gradient(circle at top right, rgba(195, 37, 41, .38), transparent 38%), linear-gradient(145deg, #190405 0%, #31090a 48%, #120304 100%);
    color: #fff;
    padding: 16px;
    min-height: 210px;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.10), 0 18px 34px rgba(43, 4, 4, .22);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .peso-panel::after {
    content: "";
    position: absolute;
    inset: auto -80px -90px auto;
    width: 220px;
    height: 220px;
    border-radius: 999px;
    border: 28px solid rgba(255,255,255,.04);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .peso-status {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: #ffe1e1;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .peso-status strong,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .scale-name {
    color: #fff;
    font-weight: 850;
    letter-spacing: .04em;
    text-transform: uppercase;
    white-space: nowrap;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .connection-wrap {
    display: inline-flex;
    align-items: center;
    min-width: 0;
    gap: 7px;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.10);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
    flex: 0 0 10px;
    background: var(--red);
    box-shadow: 0 0 0 5px rgba(185, 28, 28, .18), 0 0 14px rgba(185, 28, 28, .80);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .dot.ok {
    background: #22c55e;
    box-shadow: 0 0 0 5px rgba(34, 197, 94, .18), 0 0 16px rgba(34, 197, 94, .80);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .peso-display {
    position: relative;
    z-index: 1;
    margin: 20px 0 16px;
    padding: 16px 14px 14px;
    border-radius: 14px;
    background: linear-gradient(180deg, #050808 0%, #101514 100%);
    border: 1px solid rgba(255,255,255,.10);
    box-shadow: inset 0 0 0 1px rgba(0,0,0,.40), inset 0 -12px 30px rgba(255, 0, 0, .08);
    text-align: right;
    font-family: Consolas, Monaco, "Courier New", monospace;
    font-size: clamp(44px, 5vw, 76px);
    line-height: .95;
    color: #ff3434;
    text-shadow: 0 0 12px rgba(255, 52, 52, .45);
    letter-spacing: 1px;
    font-variant-numeric: tabular-nums;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .peso-display small {
    font-size: clamp(15px, 1.4vw, 22px);
    color: #ffd0d0;
    margin-left: 6px;
    text-shadow: none;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .peso-actions {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 10px;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .tool-btn,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .small-btn,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .pm-btn,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .lookup-btn {
    min-height: 36px;
    border: 1px solid var(--line-strong);
    border-radius: 10px;
    background: linear-gradient(180deg, #fff, #f6e8e8);
    color: var(--vino-dark);
    cursor: pointer;
    font-family: inherit;
    font-size: 12px;
    font-weight: 850;
    white-space: nowrap;
    transition: transform .14s ease, box-shadow .14s ease, background .14s ease;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .tool-btn {
    min-width: 112px;
    padding: 0 13px;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .tool-btn.primary,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .pm-btn-primary {
    color: #fff;
    border-color: #650b0d;
    background: linear-gradient(135deg, #b91c1c 0%, #8f1215 55%, #58080a 100%);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .tool-btn.success,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .pm-btn-success {
    color: #fff;
    border-color: #10663a;
    background: linear-gradient(135deg, #24a35a 0%, #157f49 100%);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .tool-btn.warning,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .pm-btn-warning {
    color: #4c2b00;
    border-color: #d69a2d;
    background: linear-gradient(135deg, #fff2be 0%, #f1c35b 100%);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .tool-btn.danger,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .pm-btn-danger {
    color: #fff;
    border-color: #790a0c;
    background: linear-gradient(135deg, #ce1f24 0%, #8f1114 100%);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .kpi {
    min-height: 108px;
    border: 1px solid rgba(123, 17, 19, .13);
    background: linear-gradient(180deg, #ffffff, #fff7f7);
    padding: 14px;
    border-radius: 15px;
    box-shadow: inset 4px 0 0 rgba(123, 17, 19, .16), var(--shadow-soft);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .kpi label {
    display: block;
    color: var(--muted);
    font-size: 11px;
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: .05em;
    margin-bottom: 6px;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .kpi strong {
    color: var(--vino-dark);
    font-size: clamp(22px, 2.5vw, 32px);
    line-height: 1.1;
    font-weight: 900;
    word-break: break-word;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .kpi .muted,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .text-muted {
    display: block;
    color: var(--muted);
    font-size: 11px;
    margin-top: 4px;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .view-panel {
    display: none;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .view-panel.active {
    display: block;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .form-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(128px, 1fr));
    gap: 12px;
    padding: 16px;
    background: linear-gradient(180deg, #fffafa, #f8eeee);
    align-items: end;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .form-grid.compact {
    grid-template-columns: repeat(4, minmax(150px, 1fr));
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .form-group {
    min-width: 0;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .form-group.full {
    grid-column: 1 / -1;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .form-group.span-2 {
    grid-column: span 2;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .form-group label {
    display: block;
    color: var(--vino-dark);
    font-size: 12px;
    margin-bottom: 6px;
    font-weight: 850;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) input,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) select,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) textarea,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .form-control,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .form-select {
    height: 38px !important;
    padding: 7px 10px !important;
    border: 1px solid #cda7a7 !important;
    background: #fff !important;
    font-family: inherit !important;
    font-size: 13px !important;
    width: 100%;
    border-radius: 10px !important;
    box-shadow: inset 0 1px 0 rgba(0,0,0,.02) !important;
    color: #321111 !important;
    outline: none !important;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) input:focus,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) select:focus,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) textarea:focus {
    border-color: var(--vino-2) !important;
    box-shadow: 0 0 0 3px rgba(157, 22, 25, .13) !important;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) input[readonly],
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) textarea[readonly] {
    background: #f3e8e8 !important;
    color: #6f5151 !important;
    cursor: not-allowed;
    border-style: dashed !important;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) #codigoSap[readonly],
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) #sku[readonly] {
    background: #f3e8e8 !important;
    color: #4f3838 !important;
    font-weight: 800;
    pointer-events: none;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) input.manual-enabled,
    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) textarea.manual-enabled {
    background: #ffffff !important;
    color: #321111 !important;
    cursor: text;
    border-style: solid !important;
    box-shadow: 0 0 0 3px rgba(183, 121, 31, .14) !important;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) textarea {
    height: 74px !important;
    min-height: 74px !important;
    resize: vertical;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .lookup-row {
    display: grid;
    grid-template-columns: 1fr 86px;
    gap: 8px;
    align-items: center;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .lookup-btn {
    height: 38px;
    color: #fff;
    border-color: #701012;
    background: linear-gradient(135deg, var(--vino-2), #661012);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .lookup-panel {
    display: none;
    margin-top: 7px;
    border: 1px solid var(--line-strong);
    background: #fff;
    max-height: 220px;
    overflow: auto;
    position: relative;
    z-index: 20;
    border-radius: 12px;
    box-shadow: var(--shadow-soft);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .lookup-panel.active {
    display: block;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .lookup-panel table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .lookup-panel th {
    background: #7b1113;
    color: #fff;
    text-align: left;
    padding: 8px;
    position: sticky;
    top: 0;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .lookup-panel td {
    border-bottom: 1px solid #f0dada;
    padding: 8px;
    color: #211;
    cursor: pointer;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .lookup-panel tr:hover td {
    background: #fff1f1;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .lookup-empty {
    padding: 10px;
    font-size: 12px;
    color: var(--muted);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .operation-summary {
    display: grid;
    grid-template-columns: 1.1fr repeat(4, minmax(130px, 1fr));
    gap: 12px;
    padding: 14px 16px;
    background: #fff;
    border-top: 1px solid var(--line);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .summary-card {
    min-height: 82px;
    border: 1px solid rgba(123, 17, 19, .13);
    border-radius: 14px;
    padding: 12px;
    background: linear-gradient(180deg, #fff, #fff8f8);
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .summary-card label {
    display: block;
    color: var(--muted);
    font-size: 11px;
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: .05em;
    margin-bottom: 7px;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .summary-card strong {
    display: block;
    color: var(--text);
    font-size: 18px;
    line-height: 1.1;
    font-weight: 900;
    overflow: hidden;
    text-overflow: ellipsis;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .summary-card .sub {
    margin-top: 5px;
    color: var(--muted);
    font-size: 11px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .estado-operativo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-width: 118px;
    padding: 7px 10px;
    border-radius: 999px;
    font-size: 12px !important;
    font-weight: 900;
    letter-spacing: .04em;
    text-transform: uppercase;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .estado-operativo.nuevo {
    color: #6d3d00;
    background: #fff4ce;
    border: 1px solid #efc96f;
    }

    :is(#basculaApp, #catalogModalBackdrop, #ticketPrintArea) .estado-operativo.pendiente {
    color: #6d3d00;
    background: #fff4ce;
