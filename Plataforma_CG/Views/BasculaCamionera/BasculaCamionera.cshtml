@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Báscula Camionera";
}

<style>
    :root {
        --bg: #f5eeee;
        --bg-2: #eadada;
        --surface: #ffffff;
        --surface-soft: #fff7f7;
        --surface-muted: #f7eaea;
        --panel: #ffffff;
        --panel-2: #fbf1f1;
        --line: #e2c7c7;
        --line-strong: #caa1a1;
        --text: #2b1515;
        --muted: #7c5a5a;
        --vino: #7b1113;
        --vino-2: #9d1619;
        --vino-3: #b42024;
        --vino-dark: #3a0809;
        --green: #16834a;
        --amber: #b7791f;
        --red: #b91c1c;
        --shadow: 0 14px 35px rgba(61, 14, 14, .13);
        --shadow-soft: 0 8px 22px rgba(61, 14, 14, .08);
        --radius-lg: 18px;
        --radius-md: 12px;
        --radius-sm: 8px;
    }

    * {
        box-sizing: border-box;
    }

    html,
    body {
        min-height: 100%;
    }

    body {
        margin: 0 !important;
        padding: 0 !important;
        font-family: "Segoe UI", Tahoma, Verdana, Arial, sans-serif;
        background: radial-gradient(circle at top left, #fff 0, var(--bg) 34%, #e7d4d4 100%) !important;
        color: var(--text);
    }

    .container,
    .container-fluid,
    main,
    .body-content {
        max-width: 100% !important;
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .window {
        width: 100%;
        min-height: 100vh;
        overflow: hidden;
        background: linear-gradient(180deg, #f9f1f1 0%, #eedede 100%);
    }

    .app-header {
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        padding: 14px 18px;
        background: linear-gradient(135deg, #3b0809 0%, #681012 50%, #8f1719 100%);
        color: #fff;
        border-bottom: 1px solid rgba(255, 255, 255, .16);
        box-shadow: 0 12px 30px rgba(70, 0, 0, .22);
    }

    .brand-block {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 280px;
    }

    .brand-mark {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        border: 1px solid rgba(255, 255, 255, .42);
        background: linear-gradient(180deg, rgba(255,255,255,.20), rgba(255,255,255,.04));
        color: #fff;
        font-weight: 900;
        letter-spacing: .6px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.25);
    }

    .brand-block h1 {
        margin: 0;
        font-size: clamp(20px, 2vw, 30px);
        font-weight: 850;
        letter-spacing: -.4px;
        line-height: 1;
    }

    .brand-block p {
        margin: 5px 0 0;
        color: #ffe5e5;
        font-size: 12px;
    }

    .eyebrow {
        color: #ffd2d2;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .11em;
        text-transform: uppercase;
        margin-bottom: 4px;
    }

    .toolbar,
    .header-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
    }

    .operator-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(130px, 1fr));
        gap: 1px;
        background: rgba(123, 17, 19, .18);
        border-bottom: 1px solid var(--line-strong);
    }

    .strip-item {
        padding: 9px 16px;
        background: rgba(255, 250, 250, .82);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .strip-item span {
        color: var(--muted);
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .05em;
    }

    .strip-item strong {
        color: var(--vino-dark);
        font-size: 12px;
        text-align: right;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .content {
        padding: 16px;
    }

    .workspace {
        max-width: 1780px;
        margin: 0 auto;
    }

    .tabs {
        display: flex;
        gap: 8px;
        margin-bottom: 12px;
        flex-wrap: wrap;
    }

    .tab {
        min-height: 38px;
        border: 1px solid var(--line-strong);
        border-radius: 999px;
        padding: 0 16px;
        background: rgba(255, 255, 255, .82);
        color: var(--vino-dark);
        cursor: pointer;
        font-size: 12px;
        font-weight: 800;
        box-shadow: var(--shadow-soft);
        white-space: nowrap;
        transition: transform .14s ease, box-shadow .14s ease, background .14s ease;
    }

    .tab:hover,
    .tool-btn:hover,
    .pm-btn:hover,
    .lookup-btn:hover,
    .small-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 10px 22px rgba(79, 10, 10, .16);
    }

    .tab.active {
        background: linear-gradient(135deg, var(--vino-2), #5c090b);
        color: #fff;
        border-color: #641112;
        box-shadow: 0 12px 26px rgba(123, 17, 19, .24);
    }

    .section {
        border: 1px solid rgba(123, 17, 19, .14);
        background: rgba(255, 255, 255, .90);
        margin-bottom: 14px;
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-soft);
    }

    .section-title {
        padding: 12px 16px;
        font-size: 13px;
        font-weight: 850;
        color: #fff;
        background: linear-gradient(135deg, #6b0d10 0%, #8d1518 60%, #611012 100%);
        border-bottom: 1px solid rgba(82, 5, 7, .40);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .section-title span {
        font-weight: 700;
        opacity: .92;
        font-size: 12px;
    }

    .section-title-light {
        background: linear-gradient(180deg, #fffafa, #f7e7e7);
        color: var(--vino-dark);
        border-bottom: 1px solid var(--line);
    }

    .bascula-resumen {
        display: grid;
        grid-template-columns: minmax(360px, 1.35fr) repeat(4, minmax(150px, 1fr));
        gap: 12px;
        padding: 14px;
        background: linear-gradient(180deg, #fff8f8, #f4e6e6);
    }

    .peso-panel {
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, .14);
        background: radial-gradient(circle at top right, rgba(195, 37, 41, .38), transparent 38%), linear-gradient(145deg, #190405 0%, #31090a 48%, #120304 100%);
        color: #fff;
        padding: 16px;
        min-height: 210px;
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.10), 0 18px 34px rgba(43, 4, 4, .22);
    }

    .peso-panel::after {
        content: "";
        position: absolute;
        inset: auto -80px -90px auto;
        width: 220px;
        height: 220px;
        border-radius: 999px;
        border: 28px solid rgba(255,255,255,.04);
    }

    .peso-status {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        font-size: 12px;
        color: #ffe1e1;
    }

    .peso-status strong,
    .scale-name {
        color: #fff;
        font-weight: 850;
        letter-spacing: .04em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .connection-wrap {
        display: inline-flex;
        align-items: center;
        min-width: 0;
        gap: 7px;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.10);
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
        flex: 0 0 10px;
        background: var(--red);
        box-shadow: 0 0 0 5px rgba(185, 28, 28, .18), 0 0 14px rgba(185, 28, 28, .80);
    }

    .dot.ok {
        background: #22c55e;
        box-shadow: 0 0 0 5px rgba(34, 197, 94, .18), 0 0 16px rgba(34, 197, 94, .80);
    }

    .peso-display {
        position: relative;
        z-index: 1;
        margin: 20px 0 16px;
        padding: 16px 14px 14px;
        border-radius: 14px;
        background: linear-gradient(180deg, #050808 0%, #101514 100%);
        border: 1px solid rgba(255,255,255,.10);
        box-shadow: inset 0 0 0 1px rgba(0,0,0,.40), inset 0 -12px 30px rgba(255, 0, 0, .08);
        text-align: right;
        font-family: Consolas, Monaco, "Courier New", monospace;
        font-size: clamp(44px, 5vw, 76px);
        line-height: .95;
        color: #ff3434;
        text-shadow: 0 0 12px rgba(255, 52, 52, .45);
        letter-spacing: 1px;
        font-variant-numeric: tabular-nums;
    }

    .peso-display small {
        font-size: clamp(15px, 1.4vw, 22px);
        color: #ffd0d0;
        margin-left: 6px;
        text-shadow: none;
    }

    .peso-actions {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 10px;
    }

    .tool-btn,
    .small-btn,
    .pm-btn,
    .lookup-btn {
        min-height: 36px;
        border: 1px solid var(--line-strong);
        border-radius: 10px;
        background: linear-gradient(180deg, #fff, #f6e8e8);
        color: var(--vino-dark);
        cursor: pointer;
        font-family: inherit;
        font-size: 12px;
        font-weight: 850;
        white-space: nowrap;
        transition: transform .14s ease, box-shadow .14s ease, background .14s ease;
    }

    .tool-btn {
        min-width: 112px;
        padding: 0 13px;
    }

    .tool-btn.primary,
    .pm-btn-primary {
        color: #fff;
        border-color: #650b0d;
        background: linear-gradient(135deg, #b91c1c 0%, #8f1215 55%, #58080a 100%);
    }

    .tool-btn.success,
    .pm-btn-success {
        color: #fff;
        border-color: #10663a;
        background: linear-gradient(135deg, #24a35a 0%, #157f49 100%);
    }

    .tool-btn.warning,
    .pm-btn-warning {
        color: #4c2b00;
        border-color: #d69a2d;
        background: linear-gradient(135deg, #fff2be 0%, #f1c35b 100%);
    }

    .tool-btn.danger,
    .pm-btn-danger {
        color: #fff;
        border-color: #790a0c;
        background: linear-gradient(135deg, #ce1f24 0%, #8f1114 100%);
    }

    .kpi {
        min-height: 108px;
        border: 1px solid rgba(123, 17, 19, .13);
        background: linear-gradient(180deg, #ffffff, #fff7f7);
        padding: 14px;
        border-radius: 15px;
        box-shadow: inset 4px 0 0 rgba(123, 17, 19, .16), var(--shadow-soft);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .kpi label {
        display: block;
        color: var(--muted);
        font-size: 11px;
        font-weight: 850;
        text-transform: uppercase;
        letter-spacing: .05em;
        margin-bottom: 6px;
    }

    .kpi strong {
        color: var(--vino-dark);
        font-size: clamp(22px, 2.5vw, 32px);
        line-height: 1.1;
        font-weight: 900;
        word-break: break-word;
    }

    .kpi .muted,
    .text-muted {
        display: block;
        color: var(--muted);
        font-size: 11px;
        margin-top: 4px;
    }

    .view-panel {
        display: none;
    }

    .view-panel.active {
        display: block;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(128px, 1fr));
        gap: 12px;
        padding: 16px;
        background: linear-gradient(180deg, #fffafa, #f8eeee);
        align-items: end;
    }

    .form-grid.compact {
        grid-template-columns: repeat(4, minmax(150px, 1fr));
    }

    .form-group {
        min-width: 0;
    }

    .form-group.full {
        grid-column: 1 / -1;
    }

    .form-group.span-2 {
        grid-column: span 2;
    }

    .form-group label {
        display: block;
        color: var(--vino-dark);
        font-size: 12px;
        margin-bottom: 6px;
        font-weight: 850;
    }

    input,
    select,
    textarea,
    .form-control,
    .form-select {
        height: 38px !important;
        padding: 7px 10px !important;
        border: 1px solid #cda7a7 !important;
        background: #fff !important;
        font-family: inherit !important;
        font-size: 13px !important;
        width: 100%;
        border-radius: 10px !important;
        box-shadow: inset 0 1px 0 rgba(0,0,0,.02) !important;
        color: #321111 !important;
        outline: none !important;
    }

    input:focus,
    select:focus,
    textarea:focus {
        border-color: var(--vino-2) !important;
        box-shadow: 0 0 0 3px rgba(157, 22, 25, .13) !important;
    }

    input[readonly],
    textarea[readonly] {
        background: #f3e8e8 !important;
        color: #6f5151 !important;
        cursor: not-allowed;
        border-style: dashed !important;
    }

    #codigoSap[readonly],
    #sku[readonly] {
        background: #f3e8e8 !important;
        color: #4f3838 !important;
        font-weight: 800;
        pointer-events: none;
    }

    input.manual-enabled,
    textarea.manual-enabled {
        background: #ffffff !important;
        color: #321111 !important;
        cursor: text;
        border-style: solid !important;
        box-shadow: 0 0 0 3px rgba(183, 121, 31, .14) !important;
    }

    textarea {
        height: 74px !important;
        min-height: 74px !important;
        resize: vertical;
    }

    .lookup-row {
        display: grid;
        grid-template-columns: 1fr 86px;
        gap: 8px;
        align-items: center;
    }

    .lookup-btn {
        height: 38px;
        color: #fff;
        border-color: #701012;
        background: linear-gradient(135deg, var(--vino-2), #661012);
    }

    .lookup-panel {
        display: none;
        margin-top: 7px;
        border: 1px solid var(--line-strong);
        background: #fff;
        max-height: 220px;
        overflow: auto;
        position: relative;
        z-index: 20;
        border-radius: 12px;
        box-shadow: var(--shadow-soft);
    }

    .lookup-panel.active {
        display: block;
    }

    .lookup-panel table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

    .lookup-panel th {
        background: #7b1113;
        color: #fff;
        text-align: left;
        padding: 8px;
        position: sticky;
        top: 0;
    }

    .lookup-panel td {
        border-bottom: 1px solid #f0dada;
        padding: 8px;
        color: #211;
        cursor: pointer;
    }

    .lookup-panel tr:hover td {
        background: #fff1f1;
    }

    .lookup-empty {
        padding: 10px;
        font-size: 12px;
        color: var(--muted);
    }

    .operation-summary {
        display: grid;
        grid-template-columns: 1.1fr repeat(4, minmax(130px, 1fr));
        gap: 12px;
        padding: 14px 16px;
        background: #fff;
        border-top: 1px solid var(--line);
    }

    .summary-card {
        min-height: 82px;
        border: 1px solid rgba(123, 17, 19, .13);
        border-radius: 14px;
        padding: 12px;
        background: linear-gradient(180deg, #fff, #fff8f8);
    }

    .summary-card label {
        display: block;
        color: var(--muted);
        font-size: 11px;
        font-weight: 850;
        text-transform: uppercase;
        letter-spacing: .05em;
        margin-bottom: 7px;
    }

    .summary-card strong {
        display: block;
        color: var(--text);
        font-size: 18px;
        line-height: 1.1;
        font-weight: 900;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .summary-card .sub {
        margin-top: 5px;
        color: var(--muted);
        font-size: 11px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .estado-operativo {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        min-width: 118px;
        padding: 7px 10px;
        border-radius: 999px;
        font-size: 12px !important;
        font-weight: 900;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .estado-operativo.nuevo {
        color: #6d3d00;
        background: #fff4ce;
        border: 1px solid #efc96f;
    }

    .estado-operativo.pendiente {
        color: #6d3d00;
        background: #fff4ce;
        border: 1px solid #efc96f;
    }

    .estado-operativo.cerrado {
        color: #0f5132;
        background: #dcfce7;
        border: 1px solid #86efac;
    }

    .pm-actions {
        display: flex;
        align-items: center;
        gap: 9px;
        flex-wrap: wrap;
        padding: 12px 16px;
        background: linear-gradient(180deg, #fffafa, #f3e5e5);
        border-top: 1px solid var(--line);
    }

    .pm-btn {
        min-height: 38px;
        padding: 0 15px;
    }

    .table-wrap {
        padding: 0;
        overflow: auto;
        max-height: 62vh;
        background: #fff;
        width: 100%;
        border-top: 1px solid var(--line);
    }

    .table-wrap table {
        width: 100%;
        min-width: 1050px;
        table-layout: fixed;
        border-collapse: separate !important;
        border-spacing: 0 !important;
        font-size: 12px;
        background: #fff;
    }

    .table-wrap thead th {
        position: sticky;
        top: 0;
        z-index: 10;
        background: linear-gradient(135deg, #751012, #4e080a) !important;
        color: #fff !important;
        border-right: 1px solid rgba(255,255,255,.12);
        border-bottom: 1px solid #3b0708;
        padding: 10px 8px;
        text-align: left;
        white-space: nowrap;
        font-size: 12px;
        font-weight: 850;
    }

    .table-wrap tbody td {
        background: #fff;
        border-right: 1px solid #efdada;
        border-bottom: 1px solid #efdada;
        padding: 9px 8px;
        white-space: nowrap;
        vertical-align: middle;
        font-size: 12px;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #1f1212;
    }

    .table-wrap tbody tr:nth-child(even) td {
        background: #fff7f7;
    }

    .table-wrap tbody tr:hover td {
        background: #fff0f0;
    }

    .num {
        text-align: right !important;
        font-variant-numeric: tabular-nums;
    }

    .center {
        text-align: center !important;
    }

    .badge-est {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        min-width: 96px;
        text-align: center;
        padding: 5px 9px;
        border: 1px solid transparent;
        font-size: 11px;
        font-weight: 900;
        border-radius: 999px;
        line-height: 1.2;
        white-space: nowrap;
    }

    .est-pendiente {
        background: #fff4cc;
        border-color: #e9c864;
        color: #745000;
    }

    .est-cerrado {
        background: #dff7e8;
        border-color: #75c995;
        color: #146c43;
    }

    .ticket-preview {
        padding: 10px;
        display: grid;
        grid-template-columns: repeat(4, minmax(120px, 1fr));
        gap: 8px;
        background: #fffafa;
    }

    .ticket-box {
        border: 1px solid #d8bcbc;
        background: #fff;
        padding: 8px;
        min-height: 58px;
    }

    .ticket-box label {
        display: block;
        color: #7a0000;
        font-size: 11px;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .ticket-box strong {
        font-size: 15px;
        color: #111;
    }

    .raw-box {
        margin: 0;
        padding: 14px 16px;
        background: #120505;
        color: #ffecec;
        border: 0;
        border-top: 1px solid #6d2525;
        min-height: 96px;
        max-height: 160px;
        overflow: auto;
        font-family: Consolas, Monaco, monospace;
        font-size: 12px;
        white-space: pre-wrap;
    }

    .statusbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 9px 16px;
        font-size: 12px;
        color: var(--vino-dark);
        border-top: 1px solid var(--line-strong);
        background: rgba(255, 255, 255, .72);
        flex-wrap: wrap;
    }

    .statusbar div {
        min-width: 0;
    }

    .log-item {
        display: grid;
        grid-template-columns: 170px 1fr;
        gap: 10px;
        border-bottom: 1px solid #d8bcbc;
        padding: 8px;
        font-size: 12px;
    }

    .log-item time {
        color: #7a0000;
        font-weight: bold;
    }

    .log-item strong {
        display: block;
        color: #3b1717;
    }

    .log-item p {
        margin: 2px 0 0;
        color: #6a3a3a;
    }

    #ticketPrintArea {
        display: none;
    }

    .ticket-impresion {
        width: 72mm;
        padding: 2mm 3mm;
        margin: 0;
        background: #fff;
        color: #000;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 10px;
        line-height: 1.12;
    }

    .ticket-impresion .center {
        text-align: center;
    }

    .ticket-impresion .logo {
        font-size: 16px;
        font-weight: 900;
        letter-spacing: .4px;
        line-height: 1;
    }

    .ticket-impresion .subtitulo {
        font-size: 9px;
        font-weight: 400;
        color: #333;
        margin-top: 1px;
    }

    .ticket-impresion .folio-ticket {
        font-size: 17px;
        font-weight: 900;
        margin-top: 2px;
        line-height: 1;
    }

    .ticket-impresion .line {
        border-top: 1px dashed #000;
