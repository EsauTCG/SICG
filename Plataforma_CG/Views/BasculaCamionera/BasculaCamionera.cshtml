        box-shadow: inset 0 1px 0 rgba(255,255,255,.10), 0 14px 28px rgba(43, 4, 4, .20) !important;
        transition: background .25s ease, box-shadow .25s ease, border-color .25s ease;
    }

    .peso-panel.scale-stable {
        background:
            radial-gradient(circle at top right, rgba(34, 197, 94, .24), transparent 38%),
