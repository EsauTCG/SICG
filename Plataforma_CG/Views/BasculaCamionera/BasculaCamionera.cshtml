    function renderClientesSapPanel() {
        var panel = byId("clientesSapPanel");
        if (!panel) return;

        panel.innerHTML = "";

        if (!clientesSapCache.length) {
            panel.innerHTML = '<div class="lookup-empty">Sin clientes encontrados.</div>';
