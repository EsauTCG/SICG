    /* =========================================================
       BOTONES DE PÁNICO BAJO LOS KPI
       Acciones principales con efecto mecánico de presión.
       ========================================================= */
    #basculaApp .panic-actions-bar {
        position: relative;
        display: grid;
        grid-template-columns: minmax(240px, .7fr) minmax(520px, 1.3fr);
        align-items: center;
        gap: 18px;
        margin: 0;
        padding: 14px 18px 20px;
        border-top: 1px solid rgba(123, 17, 19, .12);
        border-bottom: 1px solid rgba(123, 17, 19, .18);
        background:
            radial-gradient(circle at 85% 0%, rgba(123,17,19,.08), transparent 30%),
            linear-gradient(180deg, #fffafa 0%, #f3e4e4 100%);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.9);
    }

    #basculaApp .panic-actions-title {
        min-width: 0;
        padding-left: 12px;
        border-left: 5px solid #7b1113;
    }

    #basculaApp .panic-actions-title span,
    #basculaApp .panic-actions-title strong {
        display: block;
    }

    #basculaApp .panic-actions-kicker {
        margin-bottom: 4px;
        color: #8f1215;
        font-size: 10px;
        font-weight: 950;
        letter-spacing: .12em;
    }

    #basculaApp .panic-actions-title strong {
        max-width: 430px;
        color: #4b2020;
        font-size: 12px;
        line-height: 1.35;
    }

    #basculaApp .panic-actions-buttons {
        display: grid;
        grid-template-columns: repeat(2, minmax(230px, 1fr));
        align-items: stretch;
        gap: 18px;
        min-width: 0;
    }

    #basculaApp .panic-btn {
        --panic-top: #b91c1c;
        --panic-bottom: #7b1113;
        --panic-edge: #500709;
        --panic-glow: rgba(185, 28, 28, .30);

        position: relative;
        isolation: isolate;
        min-width: 0;
        min-height: 88px;
        padding: 12px 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 15px;
        overflow: hidden;

        border: 2px solid rgba(255,255,255,.42);
        border-radius: 20px;
        background:
            radial-gradient(circle at 25% 10%, rgba(255,255,255,.25), transparent 24%),
            linear-gradient(180deg, var(--panic-top) 0%, var(--panic-bottom) 72%, var(--panic-edge) 100%);
        color: #fff;
        cursor: pointer;
        font-family: inherit;
        text-align: left;
        text-shadow: 0 2px 4px rgba(0,0,0,.25);

        transform: translateY(0);
        box-shadow:
            0 11px 0 var(--panic-edge),
            0 17px 28px var(--panic-glow),
            inset 0 2px 0 rgba(255,255,255,.32),
            inset 0 -5px 10px rgba(0,0,0,.17);
        transition:
            transform .075s ease,
            box-shadow .075s ease,
            filter .12s ease,
            opacity .12s ease;
        -webkit-tap-highlight-color: transparent;
        user-select: none;
    }

    #basculaApp .panic-btn::before {
        content: "";
        position: absolute;
        inset: 6px;
        z-index: -1;
        border: 1px solid rgba(255,255,255,.18);
        border-radius: 14px;
        pointer-events: none;
    }

    #basculaApp .panic-btn::after {
        content: "";
        position: absolute;
        right: -30px;
        bottom: -48px;
        z-index: -1;
        width: 130px;
        height: 130px;
        border: 20px solid rgba(255,255,255,.08);
        border-radius: 999px;
        pointer-events: none;
    }

    #basculaApp .panic-btn:hover:not(:disabled) {
        filter: brightness(1.07) saturate(1.05);
    }

    #basculaApp .panic-btn:active:not(:disabled),
    #basculaApp .panic-btn.is-pressed:not(:disabled) {
        transform: translateY(9px) scale(.995);
        box-shadow:
            0 2px 0 var(--panic-edge),
            0 7px 13px var(--panic-glow),
            inset 0 3px 10px rgba(0,0,0,.25),
            inset 0 1px 0 rgba(255,255,255,.16);
    }

    #basculaApp .panic-btn:focus-visible {
        outline: 4px solid rgba(255,255,255,.95);
        outline-offset: 3px;
    }

    #basculaApp .panic-btn:disabled {
        cursor: not-allowed;
        opacity: .52;
        filter: grayscale(.28);
        transform: translateY(6px);
        box-shadow:
            0 5px 0 #5d4a4a,
            0 9px 16px rgba(60,30,30,.16),
            inset 0 2px 5px rgba(0,0,0,.15);
    }

    #basculaApp .panic-btn-entry {
        --panic-top: #f2b72b;
        --panic-bottom: #c7830b;
        --panic-edge: #845000;
        --panic-glow: rgba(199, 131, 11, .34);
        color: #3c2200;
        text-shadow: 0 1px 0 rgba(255,255,255,.28);
    }

    #basculaApp .panic-btn-exit {
        --panic-top: #22a65a;
        --panic-bottom: #157f49;
        --panic-edge: #0b512d;
        --panic-glow: rgba(21, 127, 73, .32);
    }

    #basculaApp .panic-btn-icon {
        width: 52px;
        height: 52px;
        flex: 0 0 52px;
        display: grid;
        place-items: center;
        border: 1px solid rgba(255,255,255,.34);
        border-radius: 50%;
        background: rgba(255,255,255,.17);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.25);
        font-size: 25px;
    }

    #basculaApp .panic-btn-copy {
        min-width: 0;
    }

    #basculaApp .panic-btn-copy small,
    #basculaApp .panic-btn-copy strong {
        display: block;
    }

    #basculaApp .panic-btn-copy small {
        margin-bottom: 3px;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: .10em;
        opacity: .84;
    }

    #basculaApp .panic-btn-copy strong {
        font-size: clamp(17px, 1.35vw, 24px);
        line-height: 1.05;
        font-weight: 950;
        white-space: nowrap;
    }

    /* Ya no se muestran duplicados de entrada/salida en la barra inferior. */
    #basculaApp #btnGuardarEntrada2,
    #basculaApp #btnCerrarSalida2 {
        display: none !important;
    }

    @@media screen and (max-width: 1100px) {
        #basculaApp .panic-actions-bar {
            grid-template-columns: 1fr;
            gap: 12px;
        }

        #basculaApp .panic-actions-title strong {
            max-width: none;
        }
    }

    @@media screen and (max-width: 720px) {
        #basculaApp .panic-actions-bar {
            padding: 12px 10px 18px;
        }

        #basculaApp .panic-actions-buttons {
            grid-template-columns: 1fr;
            gap: 16px;
        }

        #basculaApp .panic-btn {
            min-height: 76px;
            padding: 10px 15px;
            border-radius: 17px;
        }

        #basculaApp .panic-btn-icon {
            width: 44px;
            height: 44px;
            flex-basis: 44px;
            font-size: 21px;
        }

        #basculaApp .panic-btn-copy strong {
            font-size: 18px;
        }
    }

    @@media (prefers-reduced-motion: reduce) {
        #basculaApp .panic-btn {
            transition: none !important;
        }
    }



    /* =========================================================
       POSICIÓN DE LOS BOTONES DE PÁNICO DENTRO DEL RESUMEN
       En escritorio quedan exactamente debajo de los cuatro KPI,
       mientras el indicador de báscula ocupa las dos filas.
       ========================================================= */
    #basculaApp .bascula-resumen > .panic-actions-bar {
        min-width: 0;
        margin: 0;
        border: 1px solid rgba(123, 17, 19, .18);
        border-radius: 16px;
