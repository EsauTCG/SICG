    /* =========================================================
       KPIS CON COLOR OPERATIVO / FULLSCREEN
       Movimientos = vino, pendientes = ámbar, netos = verde,
       folio = oscuro ejecutivo. Insertado al final para
       sobrescribir estilos compactos previos.
       ========================================================= */

    .bascula-resumen .kpi {
        position: relative !important;
        overflow: hidden !important;
        border-radius: 18px !important;
        border: 1px solid rgba(255,255,255,.34) !important;
        box-shadow: 0 16px 32px rgba(45, 8, 8, .16) !important;
        display: grid !important;
        grid-template-rows: auto 1fr auto !important;
        align-items: stretch !important;
        justify-items: center !important;
        text-align: center !important;
        min-height: clamp(128px, 16vh, 210px) !important;
        padding: clamp(12px, 1vw, 18px) !important;
        isolation: isolate;
    }

    .bascula-resumen .kpi::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -2;
        opacity: 1;
    }

    .bascula-resumen .kpi::after {
        content: "";
        position: absolute;
        right: -38px;
        bottom: -48px;
        width: 150px;
        height: 150px;
        border-radius: 999px;
        background: rgba(255,255,255,.15);
        border: 24px solid rgba(255,255,255,.06);
        pointer-events: none;
        z-index: -1;
    }

    .bascula-resumen .kpi label,
    .bascula-resumen .kpi strong,
    .bascula-resumen .kpi .muted,
    .bascula-resumen .kpi .text-muted {
        position: relative !important;
        z-index: 1 !important;
        width: 100% !important;
        text-align: center !important;
    }

    .bascula-resumen .kpi label {
        color: rgba(255,255,255,.90) !important;
        font-size: clamp(11px, .74vw, 13px) !important;
        line-height: 1.15 !important;
        letter-spacing: .07em !important;
        font-weight: 950 !important;
        text-transform: uppercase !important;
        margin: 0 !important;
    }

    .bascula-resumen .kpi strong {
        color: #fff !important;
        height: 100% !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        margin: 0 !important;
        line-height: 1 !important;
        text-shadow: 0 3px 10px rgba(0,0,0,.25) !important;
        font-size: clamp(28px, 3vw, 46px) !important;
        font-weight: 950 !important;
        word-break: normal !important;
        overflow-wrap: anywhere !important;
    }

    .bascula-resumen .kpi .muted,
    .bascula-resumen .kpi .text-muted {
        color: rgba(255,255,255,.88) !important;
        font-size: clamp(11px, .72vw, 13px) !important;
        font-weight: 700 !important;
        margin: 0 !important;
    }

    .bascula-resumen .kpi-movimientos {
        background: linear-gradient(135deg, #7b1113 0%, #a3161a 56%, #56090b 100%) !important;
        box-shadow: inset 5px 0 0 rgba(255,255,255,.18), 0 16px 32px rgba(123,17,19,.26) !important;
    }

    .bascula-resumen .kpi-pendientes {
        background: linear-gradient(135deg, #9f5f08 0%, #d99521 56%, #704006 100%) !important;
