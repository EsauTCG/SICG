    /* =========================================================
       TRÁILER PNG PERSONALIZADO EN INDICADOR DE BÁSCULA
       Coloque su imagen transparente en:
       wwwroot/img/bascula/trailer-bascula.png
       ========================================================= */

    .truck-vehicle.truck-vehicle-img {
        position: absolute !important;
        left: 50% !important;
        bottom: 11px !important;
        width: clamp(205px, 47vw, 345px) !important;
        height: 82px !important;
        opacity: 0;
        pointer-events: none;
        transform: translateX(-205%) !important;
        transition: transform 1.15s cubic-bezier(.22,.85,.23,1), opacity .45s ease !important;
        will-change: transform, opacity;
        z-index: 8;
        overflow: visible !important;
    }

    .truck-scene.active .truck-vehicle.truck-vehicle-img {
        transform: translateX(-50%) !important;
        opacity: 1 !important;
    }

    .truck-scene.leaving .truck-vehicle.truck-vehicle-img {
        transform: translateX(92%) !important;
        opacity: 0 !important;
        transition: transform .85s cubic-bezier(.55,.08,.78,.2), opacity .35s ease !important;
    }

    .truck-scene.empty .truck-vehicle.truck-vehicle-img {
        transform: translateX(-205%) !important;
        opacity: 0 !important;
    }

    .truck-img {
        position: relative;
        z-index: 2;
        display: block;
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center bottom;
        user-select: none;
        -webkit-user-drag: none;
        filter: drop-shadow(0 9px 9px rgba(0,0,0,.36));
    }

    .truck-scene.active .truck-img {
        animation: trailerFloat 2.2s ease-in-out infinite;
    }

    .truck-scene.leaving .truck-img,
    .truck-scene.empty .truck-img {
        animation: none;
    }

    .truck-img-shadow {
        position: absolute;
        left: 8%;
        right: 8%;
        bottom: 2px;
        height: 12px;
        border-radius: 999px;
        background: rgba(0,0,0,.30);
        filter: blur(5px);
        z-index: 1;
    }

    .truck-vehicle.truck-vehicle-img .truck-cab,
    .truck-vehicle.truck-vehicle-img .truck-cab-window,
    .truck-vehicle.truck-vehicle-img .truck-cab-light,
    .truck-vehicle.truck-vehicle-img .truck-trailer-box,
    .truck-vehicle.truck-vehicle-img .truck-trailer-line,
    .truck-vehicle.truck-vehicle-img .truck-wheel,
    .truck-vehicle.truck-vehicle-img .truck-shadow {
        display: none !important;
    }

    @@keyframes trailerFloat {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-2px);
        }
    }

    @@media (max-width: 1500px) and (min-width: 901px) {
