            tokenPreRegistro: state.preRegistro ? state.preRegistro.token : "",
            folioPreRegistro: state.preRegistro ? state.preRegistro.folioPreRegistro : "",
            origenCaptura: state.preRegistro ? "PRE_REGISTRO_QR" : "CAPTURA_CASETA",
