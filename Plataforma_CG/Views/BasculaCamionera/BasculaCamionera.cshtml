    }

    @@media screen and (min-width: 1441px) {
        #basculaApp .bascula-resumen {
            grid-template-rows: auto minmax(118px, 1fr);
            align-items: stretch;
        }

        #basculaApp .bascula-resumen > .peso-panel {
            grid-column: 1;
            grid-row: 1 / span 2;
            height: 100%;
        }

        #basculaApp .bascula-resumen > .panic-actions-bar {
            grid-column: 2 / -1;
            grid-row: 2;
        }
    }

    @@media screen and (max-width: 1440px) {
        #basculaApp .bascula-resumen > .peso-panel {
            grid-row: auto;
            height: auto;
        }

        #basculaApp .bascula-resumen > .panic-actions-bar {
            grid-column: 1 / -1;
            grid-row: auto;
        }
    }

    @@media screen and (max-width: 720px) {
        #basculaApp .bascula-resumen > .panic-actions-bar {
            border-radius: 13px;
        }
    }

