    /* =========================================================
       TRAILER ANIMADO SOBRE LA BÁSCULA
       ========================================================= */

    .truck-scene {
        position: relative;
        z-index: 1;
        height: 88px;
        margin: 10px 0 4px;
        overflow: hidden;
        border-radius: 14px;
        background: linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.02));
        border: 1px solid rgba(255,255,255,.07);
    }

    .truck-scale-lane {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 8px;
        height: 18px;
        border-radius: 999px;
        background: linear-gradient(180deg, #2d3438 0%, #1b2126 100%);
        box-shadow: inset 0 2px 3px rgba(255,255,255,.06);
    }

    .truck-scale-platform {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        bottom: 14px;
        width: 62%;
        height: 24px;
        border-radius: 8px;
        background: linear-gradient(180deg, #7a8791 0%, #53616b 100%);
        box-shadow: inset 0 2px 0 rgba(255,255,255,.18), 0 3px 8px rgba(0,0,0,.25);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .truck-scale-mark {
        width: 10%;
        height: 4px;
        border-radius: 999px;
        background: rgba(230, 239, 245, .85);
        display: inline-block;
    }

    .truck-scale-label {
        position: absolute;
        left: 50%;
        top: -14px;
        transform: translateX(-50%);
        font-size: 9px;
        font-weight: 800;
        letter-spacing: .12em;
        color: #e8efef;
        text-transform: uppercase;
        white-space: nowrap;
        opacity: .9;
    }

    .truck-vehicle {
        --truck-x: -125%;
        position: absolute;
        left: 0;
        bottom: 22px;
        width: 210px;
        height: 48px;
        transform: translateX(var(--truck-x));
        opacity: 0;
        transition: transform 1.15s cubic-bezier(.22,.85,.23,1), opacity .45s ease;
        pointer-events: none;
        will-change: transform, opacity;
    }

    .truck-scene.active .truck-vehicle {
        --truck-x: 74%;
        opacity: 1;
    }

    .truck-scene.leaving .truck-vehicle {
        --truck-x: 130%;
        opacity: 0;
        transition: transform .85s cubic-bezier(.55,.08,.78,.2), opacity .35s ease;
    }

    .truck-cab,
    .truck-trailer-box,
    .truck-cab-window,
    .truck-cab-light,
    .truck-wheel,
    .truck-trailer-line,
    .truck-shadow {
        position: absolute;
    }

    .truck-cab {
        right: 0;
        bottom: 10px;
        width: 46px;
        height: 26px;
        border-radius: 8px 8px 6px 6px;
        background: linear-gradient(180deg, #d11d22 0%, #8f1114 100%);
        box-shadow: inset 0 2px 0 rgba(255,255,255,.16);
    }

    .truck-cab::before {
        content: "";
        position: absolute;
        left: -12px;
        top: 8px;
        width: 14px;
        height: 14px;
        border-radius: 8px 0 0 6px;
        background: linear-gradient(180deg, #cf1b20 0%, #8e1013 100%);
    }

    .truck-cab-window {
        right: 10px;
        bottom: 23px;
        width: 18px;
        height: 9px;
        border-radius: 3px;
        background: linear-gradient(180deg, #d8f4ff 0%, #8fcee7 100%);
    }

    .truck-cab-light {
        right: -3px;
        bottom: 16px;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #ffd166;
        box-shadow: 0 0 10px rgba(255, 209, 102, .55);
    }

    .truck-trailer-box {
        left: 10px;
        bottom: 14px;
        width: 132px;
        height: 28px;
        border-radius: 6px;
        background: linear-gradient(180deg, #eef1f3 0%, #bcc5cb 100%);
        border: 1px solid rgba(40,44,48,.25);
        box-shadow: inset 0 2px 0 rgba(255,255,255,.34);
    }

    .truck-trailer-box::before,
    .truck-trailer-box::after {
        content: "";
        position: absolute;
        top: 4px;
        bottom: 4px;
        width: 2px;
        background: rgba(70,80,90,.28);
    }

    .truck-trailer-box::before { left: 24px; }
    .truck-trailer-box::after { right: 24px; }

    .truck-trailer-line {
        left: 148px;
        bottom: 20px;
        width: 14px;
        height: 3px;
        background: #6e7980;
        border-radius: 999px;
    }

    .truck-wheel {
        bottom: 0;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: radial-gradient(circle at 35% 35%, #717171 0 18%, #232323 19% 62%, #080808 63% 100%);
        box-shadow: inset 0 0 0 2px #383838;
        animation: truckWheelSpin 1.1s linear infinite;
    }

    .truck-scene:not(.active) .truck-wheel,
    .truck-scene.leaving .truck-wheel {
        animation-duration: .45s;
    }

    .truck-wheel-1 { left: 32px; }
    .truck-wheel-2 { left: 70px; }
    .truck-wheel-3 { left: 122px; }
    .truck-wheel-4 { left: 168px; }

    .truck-shadow {
        left: 18px;
        right: 10px;
        bottom: 2px;
        height: 8px;
        border-radius: 999px;
        background: rgba(0,0,0,.24);
        filter: blur(4px);
    }

    .truck-scene.empty .truck-vehicle {
        --truck-x: -125%;
        opacity: 0;
    }

    @@keyframes truckWheelSpin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    @@media (max-width: 900px) {
        .truck-scene {
            height: 76px;
        }

        .truck-vehicle {
            width: 172px;
            height: 40px;
            bottom: 20px;
        }

        .truck-trailer-box {
            width: 106px;
            height: 24px;
        }

        .truck-cab {
            width: 38px;
            height: 22px;
        }

        .truck-wheel {
            width: 15px;
            height: 15px;
        }

        .truck-wheel-1 { left: 24px; }
        .truck-wheel-2 { left: 56px; }
        .truck-wheel-3 { left: 100px; }
        .truck-wheel-4 { left: 138px; }
    }



    /* =========================================================
       AJUSTE FINAL: INDICADOR NORMAL + VERDE CUANDO ESTÁ ESTABLE
       Conserva el tráiler animado sin hacer gigante el display.
       ========================================================= */

    .bascula-resumen {
        grid-template-columns: minmax(330px, 380px) repeat(4, minmax(0, 1fr)) !important;
