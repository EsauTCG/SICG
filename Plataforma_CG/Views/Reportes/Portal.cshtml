@model List<Plataforma_CG.Models.Reportes.ViewModels.ReportePortalItemViewModel>

@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Portal de Reportes";

    var reportes = Model ?? new List<Plataforma_CG.Models.Reportes.ViewModels.ReportePortalItemViewModel>();
}

<style>
    /* ============================================================
       FONDO GENERAL - PORTAL DE REPORTES
    ============================================================ */

    html,
    body,
    main,
    .main,
    .body-content,
    .content-wrapper,
    .layout-main-content,
    .layout-container-fluid,
    .container,
    .container-fluid {
        background: #e9edf2 !important;
    }

.reports-page {
    width: 100% !important;
    max-width: 1850px !important;
    min-height: calc(100vh - 90px);
    margin: 0 auto !important;
    padding: 1.25rem 1.5rem 2rem !important;
    box-sizing: border-box !important;
    background: transparent !important;
    box-shadow: none !important;
    border: none !important;
    border-radius: 0 !important;
}

    /* ============================================================
       ENCABEZADO
    ============================================================ */

    .reports-header {
        background: linear-gradient(135deg, #8b0000, #c82333);
        color: #fff;
        border-radius: 18px;
        padding: 2rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
    }

    .reports-header h2 {
        font-weight: 700;
        margin-bottom: .35rem;
    }

    .reports-header p {
        margin-bottom: 0;
        opacity: .9;
    }

    /* ============================================================
       GRID RESPONSIVO
    ============================================================ */

    .reports-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(285px, 1fr));
        gap: 1.25rem;
        width: 100%;
    }

    .report-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
        height: 100%;
        min-width: 0;
    }

    /* ============================================================
       TARJETAS
    ============================================================ */

    .report-card {
        border: 1px solid #c79d9d !important;
        border-radius: 18px;
        height: 100%;
        transition: all .22s ease-in-out;
        box-shadow: 0 4px 14px rgba(70, 12, 12, 0.10);
        overflow: hidden;
        background: #fffafa !important;
    }

    .report-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 28px rgba(70, 12, 12, 0.18);
    }

    .report-card-body {
        padding: 1.75rem;
        display: flex;
        flex-direction: column;
        height: 100%;
        min-height: 260px;
        background: #fffafa !important;
    }

    .report-icon-box {
        width: 72px;
        height: 72px;
        border-radius: 18px;
        background: #f1dede !important;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.25rem;
        flex: 0 0 auto;
    }

    .report-icon-box i {
        font-size: 2rem;
        color: #c82333;
    }

    .report-title {
        color: #343a40;
        font-weight: 700;
        margin-bottom: .5rem;
    }

    .report-description {
        color: #6c757d;
        font-size: .95rem;
        line-height: 1.45;
        flex-grow: 1;
        margin-bottom: 1.5rem;
    }

    .report-action {
        color: #c82333;
        font-weight: 600;
        font-size: .95rem;
        display: flex;
        align-items: center;
        gap: .4rem;
        margin-top: auto;
    }

    .report-card:hover .report-action {
        color: #8b0000;
    }

    .report-key {
        margin-top: .75rem;
        font-size: .75rem;
        color: #9b8b8b;
        word-break: break-all;
    }

    /* ============================================================
       VACÍO
    ============================================================ */

    .empty-reports {
        background: #fffafa !important;
        border: 1px solid #c79d9d !important;
        border-radius: 18px;
        padding: 3rem 2rem;
        text-align: center;
        box-shadow: 0 4px 14px rgba(70, 12, 12, 0.10);
    }

    .empty-reports i {
        font-size: 3rem;
        color: #c79d9d;
        margin-bottom: 1rem;
    }

    .empty-reports h4 {
        font-weight: 700;
        color: #343a40;
        margin-bottom: .5rem;
    }

    .empty-reports p {
        color: #6c757d;
        margin-bottom: 0;
    }

    /* ============================================================
       PANTALLAS GRANDES
    ============================================================ */

    @@media (min-width: 1400px) {
        .reports-page {
            max-width: 1850px !important;
            padding-left: 2rem !important;
            padding-right: 2rem !important;
        }

        .reports-header {
            padding: 2.25rem 2.5rem;
            margin-bottom: 1.75rem;
        }

        .reports-grid {
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 1.5rem;
        }

        .report-card-body {
            padding: 2rem;
            min-height: 285px;
        }
    }

    @@media (min-width: 1800px) {
        .reports-page {
            max-width: 1900px !important;
            padding-left: 2.25rem !important;
            padding-right: 2.25rem !important;
        }

        .reports-grid {
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: 1.65rem;
        }

        .report-card-body {
            min-height: 300px;
        }
    }

    /* ============================================================
       CELULAR
    ============================================================ */

    @@media (max-width: 768px) {
        .reports-page {
            padding: .75rem .75rem 1.5rem !important;
        }

        .reports-header {
            border-radius: 12px;
            padding: 1.25rem;
            margin-bottom: 1rem;
        }

        .reports-header h2 {
            font-size: 1.35rem;
        }

        .reports-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .report-card {
            border-radius: 12px;
        }

        .report-card-body {
            padding: 1.25rem;
            min-height: auto;
        }
    }

    /* ============================================================
       DARK MODE
    ============================================================ */

    body[data-theme="dark"],
    body[data-theme="dark"] html,
    body[data-theme="dark"] main,
    body[data-theme="dark"] .main,
    body[data-theme="dark"] .body-content,
    body[data-theme="dark"] .content-wrapper,
    body[data-theme="dark"] .layout-main-content,
    body[data-theme="dark"] .layout-container-fluid,
    body[data-theme="dark"] .container,
    body[data-theme="dark"] .container-fluid {
        background: #0f172a !important;
    }

    body[data-theme="dark"] .reports-page {
        background: transparent !important;
        color: #e5e7eb !important;
    }

    body[data-theme="dark"] .reports-header {
        background: linear-gradient(135deg, #7f1d1d, #dc2626) !important;
        box-shadow: 0 16px 36px rgba(0, 0, 0, .35) !important;
    }

    body[data-theme="dark"] .report-card,
    body[data-theme="dark"] .empty-reports {
        background: #111827 !important;
        color: #e5e7eb !important;
        box-shadow: 0 10px 26px rgba(0, 0, 0, .34) !important;
        border: 1px solid rgba(255, 255, 255, .10) !important;
    }

    body[data-theme="dark"] .report-card-body {
        background: #111827 !important;
    }

    body[data-theme="dark"] .report-title,
    body[data-theme="dark"] .empty-reports h4 {
        color: #f9fafb !important;
    }

    body[data-theme="dark"] .report-description,
    body[data-theme="dark"] .empty-reports p {
        color: #cbd5e1 !important;
    }

    body[data-theme="dark"] .report-icon-box {
        background: rgba(248, 113, 113, .15) !important;
    }

    body[data-theme="dark"] .report-icon-box i,
    body[data-theme="dark"] .report-action {
        color: #f87171 !important;
    }

    body[data-theme="dark"] .report-card:hover .report-action {
        color: #fecaca !important;
    }

    body[data-theme="dark"] .report-key {
        color: #94a3b8 !important;
    }

    /* ============================================================
   QUITAR MARCO / CAJA EXTERNA DEL PORTAL
============================================================ */

.layout-main-content,
.layout-main-content .layout-container-fluid,
.layout-container-fluid,
.reports-page {
    background: transparent !important;
    box-shadow: none !important;
    border: none !important;
    border-radius: 0 !important;
}

.container-fluid.reports-page {
    background: transparent !important;
    box-shadow: none !important;
    border: none !important;
    border-radius: 0 !important;
}

/* ============================================================
   EXPANDIR UN POCO MÁS SEGÚN TAMAÑO DE PANTALLA
============================================================ */

.container-fluid.reports-page,
.reports-page {
    width: 100% !important;
    max-width: none !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    padding-left: clamp(.75rem, 1.2vw, 1.75rem) !important;
    padding-right: clamp(.75rem, 1.2vw, 1.75rem) !important;
}

.reports-header,
.reports-grid {
    width: 100% !important;
    max-width: none !important;
}

/* Pantallas grandes */
@@media (min-width: 1200px) {
    .reports-page {
        padding-left: 1rem !important;
        padding-right: 1rem !important;
    }

    .reports-grid {
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)) !important;
    }
}

/* Pantallas muy grandes */
@@media (min-width: 1600px) {
    .reports-page {
        padding-left: 1.25rem !important;
        padding-right: 1.25rem !important;
    }

    .reports-grid {
        grid-template-columns: repeat(auto-fit, minmax(315px, 1fr)) !important;
    }
}

/* Pantallas extra grandes */
@@media (min-width: 1900px) {
    .reports-page {
        padding-left: 1.5rem !important;
        padding-right: 1.5rem !important;
    }

    .reports-grid {
        grid-template-columns: repeat(auto-fit, minmax(330px, 1fr)) !important;
    }
}

/* ============================================================
   QUITAR FONDO GRIS DEL FOOTER
============================================================ */

footer,
.footer,
footer.footer,
.layout-footer,
.main-footer,
.app-footer,
.footer.bg-light,
footer.bg-light {
    background: transparent !important;
    background-color: transparent !important;
    border: none !important;
    box-shadow: none !important;
}

footer .container,
footer .container-fluid,
.footer .container,
.footer .container-fluid {
    background: transparent !important;
    background-color: transparent !important;
    border: none !important;
    box-shadow: none !important;
}
</style>

<div class="container-fluid reports-page">

    <div class="reports-header">
        <h2>Portal de Reportes</h2>
        <p>Seleccione el reporte que desea consultar para visualizar información operativa y comercial.</p>
    </div>

    @if (!reportes.Any())
    {
        <div class="empty-reports">
            <i class="fas fa-database d-block"></i>

            <h4>No hay reportes disponibles</h4>

            <p>
                Cree vistas en SQL Server dentro del schema <strong>rpt</strong>
                para que aparezcan automáticamente en este portal.
            </p>
        </div>
    }
    else
    {
        <div class="reports-grid">
            @foreach (var reporte in reportes)
            {
                <a asp-controller="Reportes"
                   asp-action="Visor"
                   asp-route-reportKey="@reporte.ReportKey"
                   class="report-card-link">

                    <div class="card report-card">
                        <div class="report-card-body">

                            <div class="report-icon-box">
                                <i class="@reporte.Icono"></i>
                            </div>

                            <h4 class="report-title">
                                @reporte.Titulo
                            </h4>

                            <p class="report-description">
                                @reporte.Descripcion
                            </p>

                            <div class="report-action">
                                Abrir reporte
                                <i class="fas fa-arrow-right"></i>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(reporte.Schema) &&
                                 !string.IsNullOrWhiteSpace(reporte.ViewName))
                            {
                                <div class="report-key">
                                    @reporte.Schema.@reporte.ViewName
                                </div>
                            }

                        </div>
                    </div>

                </a>
            }
        </div>
    }

</div>