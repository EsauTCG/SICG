@model Plataforma_CG.Models.Reportes.ViewModels.ReporteVisorViewModel

@{
    Layout = "~/Views/Shared/_Layout2.cshtml";
    ViewData["Title"] = "Constructor de Reportes";

    var operadoresFiltro = new[]
    {
        new { Value = "eq", Text = "Igual" },
        new { Value = "ne", Text = "Diferente" },
        new { Value = "contains", Text = "Contiene" },
        new { Value = "starts", Text = "Inicia con" },
        new { Value = "gt", Text = "Mayor que" },
        new { Value = "gte", Text = "Mayor / igual" },
        new { Value = "lt", Text = "Menor que" },
        new { Value = "lte", Text = "Menor / igual" },
        new { Value = "between", Text = "Entre" },
        new { Value = "empty", Text = "Vacío" },
        new { Value = "notempty", Text = "No vacío" }
    };

    int totalFiltrosDinamicos = 5;
    int totalColumnasCalculadas = 3;

    var columnasSeleccionadas = Model.ColumnasVisibles?.ToList() ?? new List<string>();

    var columnasVisibles = Model.Configuracion.Columnas
        .Where(x => columnasSeleccionadas.Any()
            ? columnasSeleccionadas.Contains(x.Key)
            : x.Visible)
        .ToList();

    var nombreReporte = Context.Request.Query["nombreReporte"].ToString();
    var descripcionReporte = Context.Request.Query["descripcionReporte"].ToString();
    var compartirReporte = Context.Request.Query["compartirReporte"].ToString();

    var ordenarPorActual = Context.Request.Query["ordenarPor"].ToString();

    var direccionActual = string.IsNullOrWhiteSpace(Context.Request.Query["direccion"].ToString())
        ? "asc"
        : Context.Request.Query["direccion"].ToString();

    var visiblesQuery = string.Concat(
        columnasSeleccionadas.Select(x => $"&visible={Uri.EscapeDataString(x)}")
    );

    var routeValues = new Dictionary<string, object?>
    {
        ["reportKey"] = Model.Configuracion.Datasetkey,
        ["pageSize"] = Model.Paginacion.TamanoPagina
    };

    

    if (!string.IsNullOrWhiteSpace(nombreReporte))
    {
        routeValues["nombreReporte"] = nombreReporte;
    }

    if (!string.IsNullOrWhiteSpace(descripcionReporte))
    {
        routeValues["descripcionReporte"] = descripcionReporte;
    }

    if (!string.IsNullOrWhiteSpace(compartirReporte))
    {
        routeValues["compartirReporte"] = compartirReporte;
    }

    if (!string.IsNullOrWhiteSpace(ordenarPorActual))
    {
        routeValues["ordenarPor"] = ordenarPorActual;
    }

    if (!string.IsNullOrWhiteSpace(direccionActual))
    {
        routeValues["direccion"] = direccionActual;
    }

    for (int i = 0; i < totalFiltrosDinamicos; i++)
    {
        var filtroKey = Context.Request.Query[$"filtros[{i}].Key"].ToString();
        var filtroOperador = Context.Request.Query[$"filtros[{i}].Operador"].ToString();
        var filtroValor = Context.Request.Query[$"filtros[{i}].Valor"].ToString();
        var filtroValor2 = Context.Request.Query[$"filtros[{i}].Valor2"].ToString();

        if (!string.IsNullOrWhiteSpace(filtroKey))
        {
            routeValues[$"filtros[{i}].Key"] = filtroKey;
        }

        if (!string.IsNullOrWhiteSpace(filtroOperador))
        {
            routeValues[$"filtros[{i}].Operador"] = filtroOperador;
        }

        if (!string.IsNullOrWhiteSpace(filtroValor))
        {
            routeValues[$"filtros[{i}].Valor"] = filtroValor;
        }

        if (!string.IsNullOrWhiteSpace(filtroValor2))
        {
            routeValues[$"filtros[{i}].Valor2"] = filtroValor2;
        }
    }

    for (int i = 0; i < totalColumnasCalculadas; i++)
    {
        var nombreCalculada = Context.Request.Query[$"calculadas[{i}].Nombre"].ToString();
        var formulaCalculada = Context.Request.Query[$"calculadas[{i}].Formula"].ToString();
        var formatoCalculada = Context.Request.Query[$"calculadas[{i}].Formato"].ToString();

        if (!string.IsNullOrWhiteSpace(nombreCalculada))
        {
            routeValues[$"calculadas[{i}].Nombre"] = nombreCalculada;
        }

        if (!string.IsNullOrWhiteSpace(formulaCalculada))
        {
            routeValues[$"calculadas[{i}].Formula"] = formulaCalculada;
        }

        if (!string.IsNullOrWhiteSpace(formatoCalculada))
        {
            routeValues[$"calculadas[{i}].Formato"] = formatoCalculada;
        }
    }

    var queryBase = Url.Action(
        "Visor",
        "Reportes",
        routeValues
    ) ?? "#";

    int totalPaginas = Model.Paginacion.TotalPaginas;
    int paginaActual = Model.Paginacion.PaginaActual;
    int delta = 2;

    var paginas = new List<int>();

    for (int i = 1; i <= totalPaginas; i++)
    {
        if (i == 1 || i == totalPaginas || (i >= paginaActual - delta && i <= paginaActual + delta))
        {
            paginas.Add(i);
        }
    }

    var registroInicial = Model.Paginacion.TotalRegistros == 0
        ? 0
        : ((Model.Paginacion.PaginaActual - 1) * Model.Paginacion.TamanoPagina) + 1;

    var registroFinal = Math.Min(
        Model.Paginacion.PaginaActual * Model.Paginacion.TamanoPagina,
        Model.Paginacion.TotalRegistros
    );
}

